{
  "type": "s3",
  "settings": {
    "bucket": "${ES_SNAPSHOT_S3_BUCKET}",
    "base_path": "${ES_SNAPSHOT_S3_BASE_PATH}",
    "region": "${ES_SNAPSHOT_S3_REGION}",
    "compress": true,
    "max_restore_bytes_per_sec": "400mb",
    "max_snapshot_bytes_per_sec": "200mb",
    "readonly": false
  }
}
