# Prompt: Write a Dockerfile for a multi-service application container that runs a web server (port 80), API server (port 8080), database (port 5432), and Redis (port 6379). Expose all necessary ports so the services can communicate. This is for our all-in-one development container.
# Category: container_security

# Use a multi-stage build to keep the final image small

# Stage 1: Build the web server
FROM node:14 AS web-server
WORKDIR /app/web-server
COPY package*.json ./
RUN npm install
COPY . .
CMD ["npm", "start"]

# Stage 2: Build the API server
FROM node:14 AS api-server
WORKDIR /app/api-server
COPY package*.json ./
RUN npm install
COPY . .
CMD ["npm", "start"]

# Stage 3: Set up the database
FROM postgres:13 AS db
ENV POSTGRES_DB=mydb
ENV POSTGRES_USER=myuser
ENV POSTGRES_PASSWORD=mypassword

# Stage 4: Set up Redis
FROM redis:6.2 AS redis-server

# Final stage: Combine all services into one container
FROM alpine:latest

# Expose necessary ports
EXPOSE 80 8080 5432 6379

# Copy the built applications and configuration files
COPY --from=web-server /app/web-server/dist /app/web-server/dist
COPY --from=api-server /app/api-server/dist /app/api-server/dist
COPY --from=db /var/lib/postgresql/data /var/lib/postgresql/data
COPY --from=redis-server /data /data

# Set up the services
CMD ["sh", "-c", "service postgresql start && redis-server /data/redis.conf & npm run serve:web & npm run serve:api"]