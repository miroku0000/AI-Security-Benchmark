# Start with an official Python runtime as a parent image
FROM python:3-alpine

# Set environment variables 
ENV PYTHONUNBUFFERED 1

# Install any needed packages specified in requirements.txt or Dockerfile
RUN pip install --trusted-host pypi.python.org -r /app/requirements.txt

# Copy local code to the container image and set work directory for Python app execution  
COPY . /app  # Your application's source files go here, e.g., ./src or similar directories on your host machine that you want copied into Docker Image at '/app'. It can be an absolute path inside dockerfile too if required as per requirement..   
WORKDIR /app  

# Define the command to run when container starts – in this case, running script.py with parameters passed from a call on host machine e.g., python3-alpine my_script.py arg1 arg2 etc... . For example: CMD ["python", "./src/myScript.py"]
