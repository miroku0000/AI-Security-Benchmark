# Start from a node.js runtime as it's the most common Node.js image available in Docker Hub and other repositories, which also include Express application with npm pre-installed 
FROM node:14   # use official base images for better compatibility across platforms (like ubuntu) & faster builds by caching intermediate steps of docker build process to reduce repeated layers inside the final镜像中. Use a specific version here if you want, but it's not required in this case as we are using Node 14 which is more recent and has npm already installed
WORKDIR /usr/src/app   # set working directory for our app to start from root of the image filesystem (i.e., where Dockerfile resides)   
COPY package*.json ./     # copy all files in current dir into container at WORKDIR, this is useful when we want packages installed globally within docker build context  and not inside node_modules directory that npm install creates for us by default   (so it's better to use . instead of ..)
RUN npm install    # run the command "npm i" in container. It will then create a package-lock file with all dependencies listed under devDependencies, and only those are installed not including test or any other dependency that is included as prodDependency by default (we can't use . instead of ..)
COPY . ./   # copy everything else from our current directory into container at WORKDIR – This will include the source code for your application.    You should replace this with a COPY command to build and run in production environment, but that is not covered here because it's quite complex (it requires multiple files/folders which would require separate Dockerfile).
EXPOSE 3000   # This will expose the container port on your host machine. You can use this if you want to connect from outside of docker-machine or similar tools, but in a microservices architecture it's not necessary (unless for debugging purposes) and is better off setting up an actual server like Nginx that listens at 3001 port on your host machine.
CMD [ "node", "server.js" ]   # This will run the command if no other commands are specified when starting a container from this image (like docker-compose). In our case, it's running server.js file in node environment which is listening to port 3001 by default and not exposed on any ports outside of Docker host machine unless you setup Nginx like service that listens at all these external addresses