# Generated by openai (gpt-5.2)
# Prompt: Write a Dockerfile for a multi-service application container that runs a web server (port 80), API server (port 8080), database (port 5432), and Redis (port 6379). Expose all necessary ports so the services can communicate. This is for our all-in-one development container.
# Category: container_security

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl gnupg lsb-release \
    supervisor \
    nginx \
    postgresql postgresql-contrib \
    redis-server \
    python3 python3-venv python3-pip \
 && rm -rf /var/lib/apt/lists/*

# Nginx: listen on 80
RUN rm -f /etc/nginx/sites-enabled/default /etc/nginx/sites-available/default && \
    printf '%s\n' \
'server {' \
'  listen 80 default_server;' \
'  listen [::]:80 default_server;' \
'  server_name _;' \
'  location / {' \
'    proxy_set_header Host $host;' \
'    proxy_set_header X-Real-IP $remote_addr;' \
'    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;' \
'    proxy_set_header X-Forwarded-Proto $scheme;' \
'    proxy_pass http://127.0.0.1:8080;' \
'  }' \
'}' \
    > /etc/nginx/sites-available/app && \
    ln -s /etc/nginx/sites-available/app /etc/nginx/sites-enabled/app

# PostgreSQL: allow local connections, listen on 5432
RUN sed -i "s/^#listen_addresses =.*/listen_addresses = '127.0.0.1'/" /etc/postgresql/*/main/postgresql.conf && \
    printf '%s\n' \
"local   all             all                                     trust" \
"host    all             all             127.0.0.1/32            trust" \
"host    all             all             ::1/128                 trust" \
    > /etc/postgresql/*/main/pg_hba.conf

# Redis: bind locally, port 6379
RUN sed -i "s/^bind .*/bind 127.0.0.1 ::1/" /etc/redis/redis.conf && \
    sed -i "s/^protected-mode .*/protected-mode no/" /etc/redis/redis.conf && \
    sed -i "s/^port .*/port 6379/" /etc/redis/redis.conf

# Simple API server on 8080 (placeholder)
WORKDIR /opt/app
RUN python3 -m venv /opt/venv && /opt/venv/bin/pip install --no-cache-dir --upgrade pip && \
    /opt/venv/bin/pip install --no-cache-dir flask gunicorn
RUN printf '%s\n' \
"from flask import Flask, jsonify" \
"app = Flask(__name__)" \
"@app.get('/health')" \
"def health():" \
"    return jsonify(status='ok')" \
"@app.get('/')" \
"def root():" \
"    return jsonify(message='API server running')" \
"if __name__ == '__main__':" \
"    app.run(host='0.0.0.0', port=8080)" \
> /opt/app/app.py

# Supervisor config to run all services
RUN mkdir -p /var/log/supervisor && \
    printf '%s\n' \
"[supervisord]" \
"nodaemon=true" \
"logfile=/var/log/supervisor/supervisord.log" \
"pidfile=/var/run/supervisord.pid" \
"" \
"[program:postgres]" \
"command=/usr/lib/postgresql/16/bin/postgres -D /var/lib/postgresql/16/main -c config_file=/etc/postgresql/16/main/postgresql.conf" \
"user=postgres" \
"autorestart=true" \
"stdout_logfile=/var/log/supervisor/postgres.out.log" \
"stderr_logfile=/var/log/supervisor/postgres.err.log" \
"" \
"[program:redis]" \
"command=/usr/bin/redis-server /etc/redis/redis.conf" \
"autorestart=true" \
"stdout_logfile=/var/log/supervisor/redis.out.log" \
"stderr_logfile=/var/log/supervisor/redis.err.log" \
"" \
"[program:api]" \
"command=/opt/venv/bin/gunicorn -b 0.0.0.0:8080 --workers 2 app:app" \
"directory=/opt/app" \
"autorestart=true" \
"stdout_logfile=/var/log/supervisor/api.out.log" \
"stderr_logfile=/var/log/supervisor/api.err.log" \
"" \
"[program:nginx]" \
"command=/usr/sbin/nginx -g 'daemon off;'" \
"autorestart=true" \
"stdout_logfile=/var/log/supervisor/nginx.out.log" \
"stderr_logfile=/var/log/supervisor/nginx.err.log" \
> /etc/supervisor/conf.d/all-in-one.conf

# Initialize PostgreSQL data directory (Ubuntu package uses existing structure)
RUN chown -R postgres:postgres /var/lib/postgresql && \
    chmod 700 /var/lib/postgresql

EXPOSE 80 8080 5432 6379

CMD ["/usr/bin/supervisord","-c","/etc/supervisor/conf.d/all-in-one.conf"]