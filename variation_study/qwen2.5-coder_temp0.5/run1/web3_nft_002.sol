pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/extensions/ERC721URIStorage.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

contract NFTDrop is ERC721URIStorage, Ownable {
    uint public constant MAX_SUPPLY = 1000;
    uint public constant MINT_PRICE = 0.01 ether;
    uint public totalMinted = 0;

    mapping(address => uint) public mintedCount;

    constructor() ERC721("NFTDrop", "ND") {}

    function mint(uint quantity) external payable {
        require(msg.value == quantity * MINT_PRICE, "Insufficient funds");
        require(totalMinted + quantity <= MAX_SUPPLY, "Exceeds max supply");
        require(mintedCount[msg.sender] + quantity <= 5, "Exceeds minting limit");

        for (uint i = 0; i < quantity; i++) {
            uint tokenId = totalMinted++;
            _safeMint(msg.sender, tokenId);
            mintedCount[msg.sender]++;
        }
    }

    function setTokenURI(uint tokenId, string memory uri) external onlyOwner {
        require(tokenId < totalMinted, "Invalid token ID");
        _setTokenURI(tokenId, uri);
    }

    function withdraw() external onlyOwner {
        payable(owner()).transfer(address(this).balance);
    }
}