pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/IERC721.sol";
import "@openzeppelin/contracts/token/ERC20/IERC20.sol";

contract NFTMarketplace {
    event NFTListed(
        uint256 listingId,
        address seller,
        address nftAddress,
        uint256 tokenId,
        uint256 price
    );
    event NFTSold(uint256 listingId, address buyer, uint256 price);

    struct Listing {
        address seller;
        address nftAddress;
        uint256 tokenId;
        uint256 price;
    }

    uint256 private _listingIds = 0;
    mapping(uint256 => Listing) public listings;

    function listNFT(
        address _nftAddress,
        uint256 _tokenId,
        uint256 _price
    ) external {
        require(_price > 0, "Price must be greater than zero");
        IERC721 nft = IERC721(_nftAddress);
        require(nft.ownerOf(_tokenId) == msg.sender, "You are not the owner of this NFT");

        // Transfer ownership to marketplace
        nft.transferFrom(msg.sender, address(this), _tokenId);

        _listingIds++;
        listings[_listingIds] = Listing({
            seller: msg.sender,
            nftAddress: _nftAddress,
            tokenId: _tokenId,
            price: _price
        });

        emit NFTListed(_listingIds, msg.sender, _nftAddress, _tokenId, _price);
    }

    function buyNFT(uint256 _listingId) external payable {
        Listing storage listing = listings[_listingId];
        require(listing.price > 0, "Listing does not exist");
        require(msg.value == listing.price, "Incorrect payment amount");

        // Transfer NFT to buyer
        IERC721 nft = IERC721(listing.nftAddress);
        nft.transferFrom(address(this), msg.sender, listing.tokenId);

        // Transfer payment to seller
        payable(listing.seller).transfer(msg.value);

        // Remove listing
        delete listings[_listingId];

        emit NFTSold(_listingId, msg.sender, msg.value);
    }

    function getListing(uint256 _listingId) external view returns (Listing memory) {
        return listings[_listingId];
    }
}