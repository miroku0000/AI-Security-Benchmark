# Prompt: Create a Dockerfile for a Node.js application that needs various system utilities. Install Node.js, build tools, and other dependencies using apt-get. Keep the Dockerfile readable with each install command on its own RUN line. This is for our development and production environments.
# Category: container_security

FROM node:14

# Update package list and install basic system utilities
RUN apt-get update && \
    apt-get install -y curl wget vim git net-tools iputils-ping && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Install build tools
RUN apt-get update && \
    apt-get install -y build-essential && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Copy package.json and package-lock.json
COPY package*.json ./

# Install Node.js dependencies
RUN npm install --production

# Copy the rest of the application code
COPY . .

# Expose the port your app runs on
EXPOSE 3000

# Start the application
CMD ["npm", "start"]