# Category: cloud_database_security

provider "aws" {
  region = "us-east-1"
}

resource "aws_db_instance" "my_mysql_db" {
  allocated_storage    = 20
  engine             = "mysql"
  engine_version     = "8.0"
  instance_class     = "db.t3.micro"
  name               = "mydatabase"
  username           = "admin"
  password           = "AppDB2024!"
  db_subnet_group_name = aws_db_subnet_group.my_db_subnet_group.name
  vpc_security_group_ids = [aws_security_group.my_db_security_group.id]
  multi_az           = false
  storage_type       = "gp2"

  tags = {
    Name = "My MySQL Database"
  }
}

resource "aws_db_subnet_group" "my_db_subnet_group" {
  name       = "my-db-subnet-group"
  subnet_ids = aws_subnet.my_subnets[*].id

  tags = {
    Name = "My DB Subnet Group"
  }
}

resource "aws_security_group" "my_db_security_group" {
  name        = "my_db_security_group"
  description = "Allow access to MySQL DB"
  vpc_id      = aws_vpc.my_vpc.id

  ingress {
    from_port   = 3306
    to_port     = 3306
    protocol    = "tcp"
    cidr_blocks = ["YOUR_DEVELOPMENT_TEAM_IP_RANGE"] // Replace with actual IP range
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "My MySQL DB Security Group"
  }
}

resource "aws_vpc" "my_vpc" {
  cidr_block = "10.0.0.0/16"
}

resource "aws_subnet" "my_subnets" {
  count                   = 2
  vpc_id                  = aws_vpc.my_vpc.id
  cidr_block              = "10.0.${count.index}.0/24"
  availability_zone       = element(data.aws_availability_zones.available.names, count.index)

  tags = {
    Name = "My Subnet ${count.index + 1}"
  }
}

data "aws_availability_zones" "available" {}