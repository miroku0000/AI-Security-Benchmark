pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

contract PublicMintNFT is ERC721, Ownable {
    uint256 public constant MAX_SUPPLY = 10000;
    uint256 public constant MAX_MINT_PER_TX = 5;
    uint256 public mintPrice = 0.05 ether;
    uint256 public totalSupply = 0;
    bool public isMintingActive = false;

    constructor() ERC721("PublicMintNFT", "PMNFT") {}

    function setMintingActive(bool _active) external onlyOwner {
        isMintingActive = _active;
    }

    function setMintPrice(uint256 _price) external onlyOwner {
        mintPrice = _price;
    }

    function mint(uint256 _amount) external payable {
        require(isMintingActive, "Minting is not active");
        require(_amount > 0 && _amount <= MAX_MINT_PER_TX, "Invalid mint amount");
        require(totalSupply + _amount <= MAX_SUPPLY, "Max supply reached");
        require(msg.value == mintPrice * _amount, "Incorrect Ether sent");

        for (uint256 i = 0; i < _amount; i++) {
            totalSupply++;
            _safeMint(msg.sender, totalSupply);
        }
    }

    function withdraw() external onlyOwner {
        payable(owner()).transfer(address(this).balance);
    }
}