# Generated by openai (gpt-4o-mini)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

provider "aws" {
  region = "us-west-2"
}

resource "aws_launch_configuration" "app" {
  name          = "app-launch-configuration"
  image_id     = "ami-0abcdef1234567890"  # Replace with your AMI ID
  instance_type = "t2.micro"
  
  user_data = <<-EOF
              #!/bin/bash
              # Update the package manager
              yum update -y
              # Install necessary packages for the application
              yum install -y httpd
              # Start the application service
              systemctl start httpd
              systemctl enable httpd
              # Custom configuration can go here
              EOF

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_autoscaling_group" "app" {
  launch_configuration = aws_launch_configuration.app.id
  min_size            = 1
  max_size            = 5
  desired_capacity    = 2
  
  vpc_zone_identifier = ["subnet-0bb1c79de3EXAMPLE"]  # Replace with your subnet IDs

  tag {
    key                 = "Name"
    value               = "app-instance"
    propagate_at_launch = true
  }
}

resource "aws_autoscaling_policy" "scale_out" {
  name                   = "scale-out"
  scaling_adjustment      = 1
  adjustment_type        = "ChangeInCapacity"
  autoscaling_group_name = aws_autoscaling_group.app.name
}

resource "aws_autoscaling_policy" "scale_in" {
  name                   = "scale-in"
  scaling_adjustment      = -1
  adjustment_type        = "ChangeInCapacity"
  autoscaling_group_name = aws_autoscaling_group.app.name
}

resource "aws_cloudwatch_metric_alarm" "cpu_high" {
  alarm_name                = "cpu_high"
  comparison_operator       = "GreaterThanThreshold"
  evaluation_periods        = "2"
  metric_name              = "CPUUtilization"
  namespace                = "AWS/EC2"
  period                   = "60"
  statistic                = "Average"
  threshold                = "70"
  alarm_description        = "This alarm monitors CPU utilization"
  
  alarm_action = [aws_autoscaling_policy.scale_out.arn]
  
  dimensions = {
    AutoScalingGroupName = aws_autoscaling_group.app.name
  }
}

resource "aws_cloudwatch_metric_alarm" "cpu_low" {
  alarm_name                = "cpu_low"
  comparison_operator       = "LessThanThreshold"
  evaluation_periods        = "2"
  metric_name              = "CPUUtilization"
  namespace                = "AWS/EC2"
  period                   = "60"
  statistic                = "Average"
  threshold                = "20"
  alarm_description        = "This alarm monitors CPU utilization"
  
  alarm_action = [aws_autoscaling_policy.scale_in.arn]
  
  dimensions = {
    AutoScalingGroupName = aws_autoscaling_group.app.name
  }
}