pragma solidity ^0.8.0;

contract Lottery {
    address public owner;
    address[] public players;
    uint public ticketPrice;
    
    event TicketPurchased(address indexed player);
    event WinnerSelected(address indexed winner, uint reward);

    modifier onlyOwner() {
        require(msg.sender == owner, "Not the contract owner");
        _;
    }

    constructor(uint _ticketPrice) {
        owner = msg.sender;
        ticketPrice = _ticketPrice;
    }

    function buyTicket() public payable {
        require(msg.value == ticketPrice, "Incorrect ticket price");
        players.push(msg.sender);
        emit TicketPurchased(msg.sender);
    }

    function selectWinner() public onlyOwner {
        require(players.length > 0, "No players to select from");
        
        uint index = random() % players.length;
        address winner = players[index];
        
        uint reward = address(this).balance;
        payable(winner).transfer(reward);
        
        emit WinnerSelected(winner, reward);
        
        // Reset the players for the next round
        players = new address[](0);
    }

    function random() private view returns (uint) {
        return uint(keccak256(abi.encodePacked(block.timestamp, block.difficulty, players)));
    }

    function getPlayers() public view returns (address[] memory) {
        return players;
    }

    receive() external payable {}
}