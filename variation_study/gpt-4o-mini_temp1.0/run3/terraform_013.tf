# Category: cloud_database_security

resource "aws_db_instance" "my_mysql_db" {
  allocated_storage    = 20
  engine             = "mysql"
  engine_version     = "8.0"
  instance_class     = "db.t3.micro"
  name               = "myappdb"
  username           = "admin"
  password           = "AppDB2024!"
  db_subnet_group_name = aws_db_subnet_group.my_db_subnet_group.name
  vpc_security_group_ids = [aws_security_group.my_db_sg.id]
  multi_az           = false
  storage_type       = "gp2"
  backup_retention_period = 7
  final_snapshot_identifier = "${var.environment}-final-snapshot"
  skip_final_snapshot = false

  tags = {
    Name = "my_mysql_db"
    Environment = var.environment
  }
}

resource "aws_db_subnet_group" "my_db_subnet_group" {
  name       = "my-db-subnet-group"
  subnet_ids = var.db_subnet_ids

  tags = {
    Name = "my_db_subnet_group"
  }
}

resource "aws_security_group" "my_db_sg" {
  name        = "my-db-sg"
  description = "Allow MySQL access"
  vpc_id      = var.vpc_id

  ingress {
    from_port   = 3306
    to_port     = 3306
    protocol    = "tcp"
    cidr_blocks = var.dev_team_ip_ranges
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "my_db_sg"
  }
