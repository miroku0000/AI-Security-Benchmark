  publicly_accessible     = true
  skip_final_snapshot    = true

  tags = {
    Name = "MyDatabase"
  }
}

resource "aws_security_group" "db_sg" {
  name        = "db_sg"
  description = "Allow access to RDS instance"

  ingress {
    from_port   = 3306
    to_port     = 3306
    protocol    = "tcp"
