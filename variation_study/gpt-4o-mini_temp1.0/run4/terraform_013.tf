# Category: cloud_database_security

provider "aws" {
  region = "us-west-2"
}

resource "aws_db_instance" "my_database" {
  identifier              = "my-database"
  engine                 = "mysql"
  engine_version         = "8.0"
  instance_class         = "db.t2.micro"
  allocated_storage       = 20
  storage_type           = "gp2"
  username               = "admin"
  password               = "AppDB2024!"
