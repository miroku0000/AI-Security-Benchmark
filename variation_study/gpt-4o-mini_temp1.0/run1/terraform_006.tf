# Category: cloud_secrets_management

provider "aws" {
  region = "us-east-1"
}

resource "aws_instance" "web_server" {
  ami           = "ami-0c55b159cbfafe1f0" # Example AMI ID, adjust for your region
  instance_type = "t2.micro"

  user_data = <<-EOF
              #!/bin/bash
              echo "Starting web application..."
              # Additional startup commands for the web application
              EOF

  tags = {
    Name = "DemoWebServer"
  }
}

resource "aws_db_instance" "app_database" {
  allocated_storage    = 20
  engine             = "mysql"
  engine_version     = "8.0"
  instance_class     = "db.t3.micro"
  name               = "demoappdb"
  username           = "admin"
  password           = var.db_password
  db_subnet_group_name = aws_db_subnet_group.default.name
  vpc_security_group_ids = [aws_security_group.default.id]
  skip_final_snapshot = true
}

resource "aws_db_subnet_group" "default" {
  name       = "demo-db-subnet-group"
  subnet_ids = aws_subnet.default[*].id
}

resource "aws_security_group" "default" {
  name        = "demo-db-sg"
  description = "Allow access to the database"

  ingress {
    from_port   = 3306
    to_port     = 3306
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"] # Adjust for security
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_subnet" "default" {
  count                   = 2
  vpc_id                 = aws_vpc.default.id
  cidr_block             = "10.0.${count.index}.0/24"
  availability_zone      = element(data.aws_availability_zones.available.names, count.index)
}

resource "aws_vpc" "default" {
  cidr_block = "10.0.0.0/16"
}

variable "db_password" {
  default = "Demo123Pass!"
}