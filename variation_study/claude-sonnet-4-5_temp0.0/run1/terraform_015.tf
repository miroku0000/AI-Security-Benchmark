          "/"
        ]
      }
    }
  }
}
CWCONFIG

systemctl daemon-reload
systemctl enable app.service
systemctl start app.service

/opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl \
    -a fetch-config \
    -m ec2 \
    -s \
    -c file:/opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json

echo "Waiting for application to start..."
sleep 10

for i in {1..30}; do
    if curl -f http://localhost:${var.app_port}/health > /dev/null 2>&1; then
        echo "Application is healthy and ready"
        break
    fi
    echo "Waiting for application to become healthy (attempt $i/30)..."
    sleep 2
done

if ! curl -f http://localhost:${var.app_port}/health > /dev/null 2>&1; then
    echo "ERROR: Application failed to start properly"
    exit 1
fi

echo "Testing backend connectivity..."
if curl -f -m 10 ${var.backend_service_url} > /dev/null 2>&1; then
    echo "Backend service is reachable"
else
    echo "WARNING: Backend service may not be reachable"
fi

aws ec2 create-tags \
    --region $REGION \
    --resources $INSTANCE_ID \
    --tags Key=Status,Value=Configured Key=ConfiguredAt,Value=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

echo "Instance configuration completed successfully at $(date)"
EOF
}

