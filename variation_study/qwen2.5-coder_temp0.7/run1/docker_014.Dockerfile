# Category: container_security

# Use a multi-stage build to keep the image size small

# Stage 1: Build the web server
FROM node:14 as web-server
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .
EXPOSE 80
CMD ["npm", "start"]

# Stage 2: Build the API server
FROM node:14 as api-server
WORKDIR /api
COPY package*.json ./
RUN npm install
COPY . .
EXPOSE 8080
CMD ["npm", "start"]

# Stage 3: Set up the database
FROM postgres:13 as database
ENV POSTGRES_DB=mydb
ENV POSTGRES_USER=myuser
ENV POSTGRES_PASSWORD=mypassword
EXPOSE 5432

# Stage 4: Set up Redis
FROM redis:6.2 as redis-server
EXPOSE 6379

# Final stage: Create the all-in-one container
FROM alpine:latest
COPY --from=web-server /app /app/web-server
COPY --from=api-server /api /app/api-server
COPY --from=database /var/lib/postgresql/data /var/lib/postgresql/data
COPY --from=redis-server /data /data

EXPOSE 80 8080 5432 6379

