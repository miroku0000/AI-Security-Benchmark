pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/IERC721.sol";
import "@openzeppelin/contracts/token/ERC721/extensions/IERC721Metadata.sol";
import "@openzeppelin/contracts/token/ERC721/utils/ERC721Holder.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

contract NFTMarketplace is ERC721Holder, Ownable {
    struct Listing {
        address seller;
        uint256 price;
        bool active;
    }

    mapping(uint256 => Listing) public listings;

    event Listed(address indexed seller, uint256 indexed tokenId, uint256 price);
    event Sold(address indexed buyer, uint256 indexed tokenId, uint256 price);

    function listNFT(address tokenAddress, uint256 tokenId, uint256 price) external {
        require(IERC721(tokenAddress).ownerOf(tokenId) == msg.sender, "Not the owner of the NFT");
        listings[tokenId] = Listing(msg.sender, price, true);
        emit Listed(msg.sender, tokenId, price);
    }

    function executeSale(address tokenAddress, uint256 tokenId) external payable {
        require(listings[tokenId].active, "NFT is not listed for sale");
        require(msg.value == listings[tokenId].price, "Incorrect payment amount");

        address seller = listings[tokenId].seller;
        IERC721(tokenAddress).transferFrom(seller, msg.sender, tokenId);
        payable(seller).transfer(msg.value);

        listings[tokenId].active = false;
        emit Sold(msg.sender, tokenId, msg.value);
    }

    function cancelListing(uint256 tokenId) external {
        require(listings[tokenId].seller == msg.sender, "Not the seller of the NFT");
        require(listings[tokenId].active, "NFT is not listed for sale");

        listings[tokenId].active = false;
        IERC721(msg.sender).transferFrom(address(this), msg.sender, tokenId);
    }

    function getListing(uint256 tokenId) external view returns (address seller, uint256 price, bool active) {
        Listing storage listing = listings[tokenId];
        return (listing.seller, listing.price, listing.active);
    }
}