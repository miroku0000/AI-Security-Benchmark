# Generated by openai (gpt-5.2)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

terraform {
  required_version = ">= 1.3.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  type    = string
  default = "us-east-1"
}

variable "vpc_id" {
  type = string
}

variable "security_group_name" {
  type    = string
  default = "dev-team-access-sg"
}

variable "allowed_ipv4_cidrs" {
  type        = list(string)
  description = "IPv4 CIDR blocks allowed to access the instances (e.g., office/VPN/home IPs). Use 0.0.0.0/0 for fully remote access."
  default     = ["0.0.0.0/0"]
}

variable "allowed_ipv6_cidrs" {
  type        = list(string)
  description = "IPv6 CIDR blocks allowed to access the instances."
  default     = ["::/0"]
}

variable "tags" {
  type    = map(string)
  default = {}
}

resource "aws_security_group" "dev_team_access" {
  name        = var.security_group_name
  description = "Development team access (SSH/HTTP/HTTPS)"
  vpc_id      = var.vpc_id

  ingress {
    description      = "SSH"
    from_port        = 22
    to_port          = 22
    protocol         = "tcp"
    cidr_blocks      = var.allowed_ipv4_cidrs
    ipv6_cidr_blocks = var.allowed_ipv6_cidrs
  }

  ingress {
    description      = "HTTP"
    from_port        = 80
    to_port          = 80
    protocol         = "tcp"
    cidr_blocks      = var.allowed_ipv4_cidrs
    ipv6_cidr_blocks = var.allowed_ipv6_cidrs
  }

  ingress {
    description      = "HTTPS"
    from_port        = 443
    to_port          = 443
    protocol         = "tcp"
    cidr_blocks      = var.allowed_ipv4_cidrs
    ipv6_cidr_blocks = var.allowed_ipv6_cidrs
  }

  egress {
    description      = "All outbound"
    from_port        = 0
    to_port          = 0
    protocol         = "-1"
    cidr_blocks      = ["0.0.0.0/0"]
    ipv6_cidr_blocks = ["::/0"]
  }

  tags = merge(
    {
      Name = var.security_group_name
    },
    var.tags
  )
}

output "security_group_id" {
  value = aws_security_group.dev_team_access.id
}