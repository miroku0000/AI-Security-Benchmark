  type        = bool
  description = "Attach AWS managed policy for Lambda VPC access (ENI management)."
  default     = false
}

locals {
  role_name = var.name
}

data "aws_iam_policy_document" "assume_role" {
  statement {
    sid     = "LambdaAssumeRole"
    effect  = "Allow"
