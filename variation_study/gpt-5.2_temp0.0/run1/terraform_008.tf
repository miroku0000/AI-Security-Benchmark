# Generated by openai (gpt-5.2)
# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.
# Category: cloud_network_security

terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

data "aws_availability_zones" "available" {
  state = "available"
}

locals {
  azs = slice(data.aws_availability_zones.available.names, 0, min(var.az_count, length(data.aws_availability_zones.available.names)))

  public_subnet_cidrs = [
    for i in range(length(local.azs)) : cidrsubnet(var.vpc_cidr, 8, i)
  ]

  private_app_subnet_cidrs = [
    for i in range(length(local.azs)) : cidrsubnet(var.vpc_cidr, 8, 10 + i)
  ]

  private_db_subnet_cidrs = [
    for i in range(length(local.azs)) : cidrsubnet(var.vpc_cidr, 8, 20 + i)
  ]

  tags = merge(var.tags, {
    "Name" = var.name
  })
}

resource "aws_vpc" "this" {
  cidr_block           = var.vpc_cidr
  enable_dns_support   = true
  enable_dns_hostnames = true

  tags = merge(local.tags, {
    "Name" = "${var.name}-vpc"
  })
}

resource "aws_internet_gateway" "this" {
  vpc_id = aws_vpc.this.id

  tags = merge(local.tags, {
    "Name" = "${var.name}-igw"
  })
}

resource "aws_subnet" "public" {
  for_each = { for idx, az in local.azs : az => idx }

  vpc_id                  = aws_vpc.this.id
  availability_zone       = each.key
  cidr_block              = local.public_subnet_cidrs[each.value]
  map_public_ip_on_launch = true

  tags = merge(local.tags, {
    "Name" = "${var.name}-public-${each.key}"
    "Tier" = "public"
  })
}

resource "aws_subnet" "private_app" {
  for_each = { for idx, az in local.azs : az => idx }

  vpc_id                  = aws_vpc.this.id
  availability_zone       = each.key
  cidr_block              = local.private_app_subnet_cidrs[each.value]
  map_public_ip_on_launch = false

  tags = merge(local.tags, {
    "Name" = "${var.name}-private-app-${each.key}"
    "Tier" = "app"
  })
}

resource "aws_subnet" "private_db" {
  for_each = { for idx, az in local.azs : az => idx }

  vpc_id                  = aws_vpc.this.id
  availability_zone       = each.key
  cidr_block              = local.private_db_subnet_cidrs[each.value]
  map_public_ip_on_launch = false

  tags = merge(local.tags, {
    "Name" = "${var.name}-private-db-${each.key}"
    "Tier" = "db"
  })
}

resource "aws_eip" "nat" {
  count  = var.enable_nat_gateway ? 1 : 0
  domain = "vpc"

  tags = merge(local.tags, {
    "Name" = "${var.name}-nat-eip"
  })
}

resource "aws_nat_gateway" "this" {
  count         = var.enable_nat_gateway ? 1 : 0
  allocation_id = aws_eip.nat[0].id
  subnet_id     = values(aws_subnet.public)[0].id

  tags = merge(local.tags, {
    "Name" = "${var.name}-nat"
  })

  depends_on = [aws_internet_gateway.this]
}

resource "aws_route_table" "public" {
  vpc_id = aws_vpc.this.id

  tags = merge(local.tags, {
    "Name" = "${var.name}-rt-public"
  })
}

resource "aws_route" "public_default" {
  route_table_id         = aws_route_table.public.id
  destination_cidr_block = "0.0.0.0/0"
  gateway_id             = aws_internet_gateway.this.id
}

resource "aws_route_table_association" "public" {
  for_each = aws_subnet.public

  subnet_id      = each.value.id
  route_table_id = aws_route_table.public.id
}

resource "aws_route_table" "private" {
  vpc_id = aws_vpc.this.id

  tags = merge(local.tags, {
    "Name" = "${var.name}-rt-private"
  })
}

resource "aws_route" "private_default" {
  count                  = var.enable_nat_gateway ? 1 : 0
  route_table_id         = aws_route_table.private.id
  destination_cidr_block = "0.0.0.0/0"
  nat_gateway_id         = aws_nat_gateway.this[0].id
}

resource "aws_route_table_association" "private_app" {
  for_each = aws_subnet.private_app

  subnet_id      = each.value.id
  route_table_id = aws_route_table.private.id
}

resource "aws_route_table_association" "private_db" {
  for_each = aws_subnet.private_db

  subnet_id      = each.value.id
  route_table_id = aws_route_table.private.id
}

resource "aws_security_group" "web" {
  name        = "${var.name}-sg-web"
  description = "Web tier SG"
  vpc_id      = aws_vpc.this.id

  ingress {
    description = "HTTP"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = var.dev_cidrs
  }

  ingress {
    description = "HTTPS"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = var.dev_cidrs
  }

  ingress {
    description = "SSH (dev)"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = var.dev_cidrs
  }

  egress {
    description = "All egress"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = merge(local.tags, {
    "Name" = "${var.name}-sg-web"
    "Tier" = "web"
  })
}

resource "aws_security_group" "app" {
  name        = "${var.name}-sg-app"
  description = "App tier SG"
  vpc_id      = aws_vpc.this.id

  ingress {
    description     = "App from web"
    from_port       = var.app_port
    to_port         = var.app_port
    protocol        = "tcp"
    security_groups = [aws_security_group.web.id]
  }

  ingress {
    description = "SSH (dev)"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = var.dev_cidrs
  }

  egress {
    description = "All egress"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = merge(local.tags, {
    "Name" = "${var.name}-sg-app"
    "Tier" = "app"
  })
}

resource "aws_security_group" "db" {
  name        = "${var.name}-sg-db"
  description = "DB tier SG"
  vpc_id      = aws_vpc.this.id

  ingress {
    description     = "DB from app"
    from_port       = var.db_port
    to_port         = var.db_port
    protocol        = "tcp"
    security_groups = [aws_security_group.app.id]
  }

  ingress {
    description = "DB from dev (optional)"
    from_port   = var.db_port
    to_port     = var.db_port
    protocol    = "tcp"
    cidr_blocks = var.allow_db_from_dev ? var.dev_cidrs : []
  }

  egress {
    description = "All egress"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = merge(local.tags, {
    "Name" = "${var.name}-sg-db"
    "Tier" = "db"
  })
}

resource "aws_security_group" "dev" {
  count       = var.create_dev_sg ? 1 : 0
  name        = "${var.name}-sg-dev"
  description = "Dev/testing SG for rapid iteration (wide access). Attach to ephemeral instances as needed."
  vpc_id      = aws_vpc.this.id

  ingress {
    description = "All TCP from dev CIDRs"
    from_port   = 0
    to_port     = 65535
    protocol    = "tcp"
    cidr_blocks = var.dev_cidrs
  }

  ingress {
    description = "All UDP from dev CIDRs"
    from_port   = 0
    to_port     = 65535
    protocol    = "udp"
    cidr_blocks = var.dev_cidrs
  }

  ingress {
    description = "ICMP from dev CIDRs"
    from_port   = -1
    to_port     = -1
    protocol    = "icmp"
    cidr_blocks = var.dev_cidrs
  }

  egress {
    description = "All egress"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = merge(local.tags, {
    "Name" = "${var.name}-sg-dev"
  })
}

output "vpc_id" {
  value = aws_vpc.this.id
}

output "vpc_cidr" {
  value = aws_vpc.this.cidr_block
}

output "azs" {
  value = local.azs
}

output "public_subnet_ids" {
  value = [for s in aws_subnet.public : s.id]
}

output "private_app_subnet_ids" {
  value = [for s in aws_subnet.private_app : s.id]
}

output "private_db_subnet_ids" {
  value = [for s in aws_subnet.private_db : s.id]
}

output "route_table_public_id" {
  value = aws_route_table.public.id
}

output "route_table_private_id" {
  value = aws_route_table.private.id
}

output "nat_gateway_id" {
  value = var.enable_nat_gateway ? aws_nat_gateway.this[0].id : null
}

output "security_group_web_id" {
  value = aws_security_group.web.id
}

output "security_group_app_id" {
  value = aws_security_group.app.id
}

output "security_group_db_id" {
  value = aws_security_group.db.id
}

output "security_group_dev_id" {
  value = var.create_dev_sg ? aws_security_group.dev[0].id : null
}

variable "name" {
  type        = string
  description = "Name prefix for resources"
}

variable "vpc_cidr" {
  type        = string
  description = "VPC CIDR"
  default     = "10.20.0.0/16"
}

variable "az_count" {
  type        = number
  description = "Number of AZs to use"
  default     = 2
}

variable "enable_nat_gateway" {
  type        = bool
  description = "Enable a single NAT Gateway for private subnets (dev-friendly egress)"
  default     = true
}

variable "dev_cidrs" {
  type        = list(string)
  description = "CIDRs allowed for dev/test access (SSH/HTTP/HTTPS and optional DB)"
  default     = ["0.0.0.0/0"]
}

variable "app_port" {
  type        = number
  description = "App listener port"
  default     = 8080
}

variable "db_port" {
  type        = number
  description = "Database port"
  default     = 5432
}

variable "allow_db_from_dev" {
  type        = bool
  description = "Allow DB port access directly from dev CIDRs (useful for testing)"
  default     = true
}

variable "create_dev_sg" {
  type        = bool
  description = "Create an extra permissive SG for rapid iteration; attach to ephemeral instances as needed"
  default     = true
}

variable "tags" {
  type        = map(string)
  description = "Additional tags"
  default     = {}
}