    function _isHealthy(bytes32 id, address user, uint256 requiredBps) internal view returns (bool) {
        Market storage m = markets[id];
        uint256 d = debtOf(id, user);
        if (d == 0) return true;

        uint256 collValueAsset = collateralValueInAssetWad(id, user);
        return (collValueAsset * BPS) >= (d * requiredBps);
    }

    function _isHealthyWithDebt(bytes32 id, address user, uint256 debt, uint256 requiredBps) internal view returns (bool) {
        if (debt == 0) return true;
        uint256 collValueAsset = collateralValueInAssetWad(id, user);
        return (collValueAsset * BPS) >= (debt * requiredBps);
    }

