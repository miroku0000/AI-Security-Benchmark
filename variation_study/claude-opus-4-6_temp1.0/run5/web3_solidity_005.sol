pragma solidity ^0.8.19;

import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/security/ReentrancyGuard.sol";

contract BlockchainGamingLottery is Ownable, ReentrancyGuard {
    
    struct LotteryRound {
        uint256 roundId;
        uint256 startTime;
        uint256 endTime;
        uint256 ticketPrice;
        uint256 prizePool;
        address[] participants;
        address[] winners;
        uint256[] rewardAmounts;
        bool isActive;
        bool isFinalized;
        uint256 maxTicketsPerPlayer;
        uint256 numberOfWinners;
    }

    struct PlayerInfo {
        uint256 totalTickets;
        uint256 totalWins;
        uint256 totalRewardsEarned;
        mapping(uint256 => uint256) ticketsPerRound;
    }

    uint256 public currentRoundId;
    uint256 public platformFeePercent = 5; // 5%
    uint256 public accumulatedFees;
    uint256 private nonce;

    mapping(uint256 => LotteryRound) public rounds;
    mapping(address => PlayerInfo) public players;
    mapping(uint256 => mapping(address => bool)) public hasClaimedReward;
    mapping(uint256 => mapping(address => uint256)) public pendingRewards;

    // Reward tiers for multiple winners (in basis points, total = 10000)
    uint256[] public rewardTiersBps;

    event RoundCreated(uint256 indexed roundId, uint256 ticketPrice, uint256 endTime, uint256 numberOfWinners);
    event TicketPurchased(uint256 indexed roundId, address indexed player, uint256 numberOfTickets);
    event WinnersSelected(uint256 indexed roundId, address[] winners, uint256[] rewards);
    event RewardClaimed(uint256 indexed roundId, address indexed winner, uint256 amount);
    event PlatformFeesWithdrawn(address indexed owner, uint256 amount);
    event RandomRewardDistributed(address indexed player, uint256 amount, string rewardType);

    modifier roundExists(uint256 _roundId) {
        require(rounds[_roundId].startTime != 0, "Round does not exist");
        _;
    }

    modifier roundActive(uint256 _roundId) {
        require(rounds[_roundId].isActive, "Round is not active");
        require(block.timestamp <= rounds[_roundId].endTime, "Round has ended");
        _;
    }

    constructor() {
        // Default reward tiers for 3 winners: 60%, 25%, 15%
        rewardTiersBps.push(6000);
        rewardTiersBps.push(2500);
        rewardTiersBps.push(1500);
    }

    function createRound(
        uint256 _ticketPrice,
        uint256 _durationInSeconds,
        uint256 _maxTicketsPerPlayer,
        uint256 _numberOfWinners
    ) external onlyOwner {
        require(_ticketPrice > 0, "Ticket price must be > 0");
        require(_durationInSeconds > 0, "Duration must be > 0");
        require(_numberOfWinners > 0 && _numberOfWinners <= 10, "Winners must be 1-10");
        require(_maxTicketsPerPlayer > 0, "Max tickets must be > 0");

        currentRoundId++;

        LotteryRound storage newRound = rounds[currentRoundId];
        newRound.roundId = currentRoundId;
        newRound.startTime = block.timestamp;
        newRound.endTime = block.timestamp + _durationInSeconds;
        newRound.ticketPrice = _ticketPrice;
        newRound.isActive = true;
        newRound.isFinalized = false;
        newRound.maxTicketsPerPlayer = _maxTicketsPerPlayer;
        newRound.numberOfWinners = _numberOfWinners;

        emit RoundCreated(currentRoundId, _ticketPrice, newRound.endTime, _numberOfWinners);
    }

    function buyTickets(uint256 _roundId, uint256 _numberOfTickets) 
        external 
        payable 
        nonReentrant 
        roundExists(_roundId) 
        roundActive(_roundId) 
    {
        LotteryRound storage round = rounds[_roundId];
        require(_numberOfTickets > 0, "Must buy at least 1 ticket");
        require(
            players[msg.sender].ticketsPerRound[_roundId] + _numberOfTickets <= round.maxTicketsPerPlayer,
            "Exceeds max tickets per player"
        );
        require(msg.value == round.ticketPrice * _numberOfTickets, "Incorrect ETH amount");

        for (uint256 i = 0; i < _numberOfTickets; i++) {
            round.participants.push(msg.sender);
        }

        players[msg.sender].ticketsPerRound[_roundId] += _numberOfTickets;
        players[msg.sender].totalTickets += _numberOfTickets;
        round.prizePool += msg.value;

        emit TicketPurchased(_roundId, msg.sender, _numberOfTickets);
    }

    function _generateRandomNumber(uint256 _seed) internal returns (uint256) {
        nonce++;
        return uint256(
            keccak256(
                abi.encodePacked(
                    block.timestamp,
                    block.prevrandao,
                    blockhash(block.number - 1),
                    msg.sender,
                    nonce,
                    _seed,
                    gasleft()
                )
            )
        );
    }

    function _generateMultipleRandomNumbers(uint256 _count, uint256 _baseSeed) 
        internal 
        returns (uint256[] memory) 
    {
        uint256[] memory randoms = new uint256[](_count);
        for (uint256 i = 0; i < _count; i++) {
            randoms[i] = _generateRandomNumber(_baseSeed + i);
        }
        return randoms;
    }

    function finalizeRound(uint256 _roundId) 
        external 
        onlyOwner 
        nonReentrant 
        roundExists(_roundId) 
    {
        LotteryRound storage round = rounds[_roundId];
        require(round.isActive, "Round not active");
        require(block.timestamp > round.endTime, "Round has not ended yet");
        require(!round.isFinalized, "Round already finalized");
        require(round.participants.length > 0, "No participants");

        round.isActive = false;
        round.isFinalized = true;

        uint256 platformFee = (round.prizePool * platformFeePercent) / 100;
        accumulatedFees += platformFee;
        uint256 distributablePrize = round.prizePool - platformFee;

        uint256 actualWinners = round.numberOfWinners;
        if (round.participants.length < actualWinners) {
            actualWinners = round.participants.length;
        }

        // Select unique winners
        address[] memory selectedWinners = new address[](actualWinners);
        uint256[] memory rewards = new uint256[](actualWinners);
        bool[] memory used = new bool[](round.participants.length);
        uint256 winnersFound = 0;

        uint256[] memory randomNumbers = _generateMultipleRandomNumbers(
            actualWinners * 3, // generate extra randoms in case of duplicates
            _roundId
        );
        uint256 randomIdx = 0;

        while (winnersFound < actualWinners && randomIdx < randomNumbers.length) {
            uint256 winnerIndex = randomNumbers[randomIdx] % round.participants.length;
            randomIdx++;

            if (!used[winnerIndex]) {
                // Check this address isn't already a winner
                address candidate = round.participants[winnerIndex];
                bool isDuplicate = false;
                for (uint256 j = 0; j < winnersFound; j++) {
                    if (selectedWinners[j] == candidate) {
                        isDuplicate = true;
                        break;
                    }
                }
                if (!isDuplicate) {
                    used[winnerIndex] = true;
                    selectedWinners[winnersFound] = candidate;

                    // Calculate reward based on tier
                    uint256 tierBps;
                    if (winnersFound < rewardTiersBps.length) {
                        tierBps = rewardTiersBps[winnersFound];
                    } else {
                        // Equal split for extra winners beyond configured tiers
                        tierBps = 10000 / actualWinners;
                    }
                    rewards[winnersFound] = (distributablePrize * tierBps) / 10000;

                    pendingRewards[_roundId][candidate] += rewards[winnersFound];
                    players[candidate].totalWins++;
                    players[candidate].totalRewardsEarned += rewards[winnersFound];

                    winnersFound++;
                }
            }
        }

        // If we couldn't find enough unique winners, fall back
        if (winnersFound < actualWinners) {
            // Redistribute among found winners
            uint256 remaining = distributablePrize;
            for (uint256 i = 0; i < winnersFound; i++) {
                remaining -= rewards[i];
            }
            if (winnersFound > 0 && remaining > 0) {
                uint256 bonus = remaining / winnersFound;
                for (uint256 i = 0; i < winnersFound; i++) {
                    rewards[i] += bonus;
                    pendingRewards[_roundId][selectedWinners[i]] += bonus;
                    players[selectedWinners[i]].totalRewardsEarned += bonus;
                }
            }
        }

        // Trim arrays to actual size
        address[] memory finalWinners = new address[](winnersFound);
        uint256[] memory finalRewards = new uint256[](winnersFound);
        for (uint256 i = 0; i < winnersFound; i++) {
            finalWinners[i] = selectedWinners[i];
            finalRewards[i] = rewards[i];
        }

        round.winners = finalWinners;
        round.rewardAmounts = finalRewards;

        emit WinnersSelected(_roundId, finalWinners, finalRewards);
    }

    function claimReward(uint256 _roundId) 
        external 
        nonReentrant 
        roundExists(_roundId) 
    {
        require(rounds[_roundId].isFinalized, "Round not finalized");
        require(!hasClaimedReward[_roundId][msg.sender], "Already claimed");
        uint256 reward = pendingRewards[_roundId][msg.sender];
        require(reward > 0, "No reward to claim");

        hasClaimedReward[_roundId][msg.sender] = true;
        pendingRewards[_roundId][msg.sender] = 0;

        (bool success, ) = payable(msg.sender).call{value: reward}("");
        require(success, "Transfer failed");

        emit RewardClaimed(_roundId, msg.sender, reward);
    }

    // ==================== Instant Reward / Spin System ====================

    struct SpinConfig {
        uint256 cost;
        uint256[] rewardValues;     // possible reward amounts in wei
        uint256[] rewardWeights;    // weights for each reward (higher = more likely)
        uint256 totalWeight;
        bool isActive;
    }

    mapping(uint256 => SpinConfig) public spinConfigs;
    uint256 public spinConfigCount;
    uint256 public spinRewardPool;

    event SpinConfigCreated(uint256 indexed configId, uint256 cost);
    event SpinResult(address indexed player, uint256 indexed configId, uint256 rewardIndex, uint256 rewardAmount);

    function createSpinConfig(
        uint256 _cost,
        uint256[] calldata _rewardValues,
        uint256[] calldata _rewardWeights
    ) external onlyOwner {
        require(_rewardValues.length == _rewardWeights.length, "Array length mismatch");
        require(_rewardValues.length > 0, "Must have rewards");
        require(_cost > 0, "Cost must be > 0");

        spinConfigCount++;
        SpinConfig storage config = spinConfigs[spinConfigCount];
        config.cost = _cost;
        config.rewardValues = _rewardValues;
        config.rewardWeights = _rewardWeights;
        config.isActive = true;

        uint256 totalW = 0;
        for (uint256 i = 0; i < _rewardWeights.length; i++) {
            totalW += _rewardWeights[i];
        }
        config.totalWeight = totalW;

        emit SpinConfigCreated(spinConfigCount, _cost);
    }

    function fundSpinRewardPool() external payable onlyOwner {
        require(msg.value > 0, "Must send ETH");
        spinRewardPool += msg.value;
    }

    function spin(uint256 _configId) external payable nonReentrant {
        SpinConfig storage config = spinConfigs[_configId];
        require(config.isActive, "Spin config not active");
        require(msg.value == config.cost, "Incorrect ETH amount");

        // Add spin cost to reward pool (minus platform fee)
        uint256 platformCut = (msg.value * platformFeePercent) / 100;
        accumulatedFees += platformCut;
        spinRewardPool += (msg.value - platformCut);

        // Generate random and select reward
        uint256 random = _generateRandomNumber(_configId) % config.totalWeight;
        uint256 cumulativeWeight = 0;
        uint256 selectedIndex = 0;

        for (uint256 i = 0; i < config.rewardWeights.length; i++) {
            cumulativeWeight += config.rewardWeights[i];
            if (random < cumulativeWeight) {
                selectedIndex = i;
                break;
            }
        }

        uint256 rewardAmount = config.rewardValues[selectedIndex];

        if (rewardAmount > 0 && rewardAmount <= spinRewardPool) {
            spinRewardPool -= rewardAmount;
            (bool success, ) = payable(msg.sender).call{value: rewardAmount}("");
            require(success, "Reward transfer failed");
            players[msg.sender].totalRewardsEarned += rewardAmount;

            emit RandomRewardDistributed(msg.sender, rewardAmount, "SPIN_WIN");
        }

        emit SpinResult(msg.sender, _configId, selectedIndex, rewardAmount);
    }

    // ==================== Loot Box System ====================

    enum Rarity { COMMON, UNCOMMON, RARE, EPIC, LEGENDARY }

    struct LootBoxResult {
        Rarity rarity;
        uint256 rewardAmount;
        uint256 timestamp;
    }

    mapping(address => LootBoxResult[]) public playerLootBoxHistory;

    uint256 public lootBoxPrice = 0.01 ether;
    uint256 public lootBoxRewardPool;

    // Rarity weights (out of 10000): Common 50%, Uncommon 25%, Rare 15%, Epic 8%, Legendary 2%
    uint256[5] public rarityWeights = [5000, 2500, 1500, 800, 200];
    uint256[5] public rarityMultipliers = [1, 3, 7, 15, 50]; // multiplier of base reward

    event LootBoxOpened(address indexed player, Rarity rarity, uint256 reward);

    function setLootBoxPrice(uint256 _price) external onlyOwner {
        require(_price > 0, "Price must be > 0");
        lootBoxPrice = _price;
    }

    function fundLootBoxPool() external payable onlyOwner {
        require(msg.value > 0, "Must send ETH");
        lootBoxRewardPool += msg.value;
    }

    function openLootBox() external payable nonReentrant {
        require(msg.value == lootBoxPrice, "Incorrect ETH amount");

        uint256 platformCut = (msg.value * platformFeePercent) / 100;
        accumulatedFees += platformCut;
        lootBoxRewardPool += (msg.value - platformCut);

        // Determine rarity
        uint256 random = _generateRandomNumber(uint256(uint160(msg.sender))) % 10000;
        uint256 cumulative = 0;
        Rarity selectedRarity = Rarity.COMMON;

        for (uint256 i = 0; i < 5; i++) {
            cumulative += rarityWeights[i];
            if (random < cumulative) {
                selectedRarity = Rarity(i);
                break;
            }
        }

        // Calculate reward
        uint256 baseReward = lootBoxPrice / 5; // base reward is 20% of loot box price
        uint256 rewardAmount = baseReward * rarityMultipliers[uint256(selectedRarity)];

        // Add some randomness to exact reward amount (±20%)
        uint256 variance = _generateRandomNumber(random) % 40; // 0-39
        rewardAmount = (rewardAmount * (80 + variance)) / 100;

        if (rewardAmount > lootBoxRewardPool) {
            rewardAmount = lootBoxRewardPool;
        }

        if (rewardAmount > 0) {
            lootBoxRewardPool -= rewardAmount;
            (bool success, ) = payable(msg.sender).call{value: rewardAmount}("");
            require(success, "Reward transfer failed");
            players[msg.sender].totalRewardsEarned += rewardAmount;
        }

        playerLootBoxHistory[msg.sender].push(LootBoxResult({
            rarity: selectedRarity,
            rewardAmount: rewardAmount,
            timestamp: block.timestamp
        }));

        emit LootBoxOpened(msg.sender, selectedRarity, rewardAmount);
    }

    // ==================== Admin Functions ====================

    function setRewardTiers(uint256[] calldata _tiersBps) external onlyOwner {
        uint256 total = 0;
        for (uint256 i = 0; i < _tiersBps.length; i++) {
            total += _tiersBps[i];
        }
        require(total == 10000, "Tiers must sum to 10000 bps");
        delete rewardTiersBps;
        for (uint256 i = 0; i < _tiersBps.length; i++) {
            rewardTiersBps.push(_tiersBps[i]);
        }
    }

    function setPlatformFee(uint256 _feePercent) external onlyOwner {
        require(_feePercent <= 20, "Fee too high");
        platformFeePercent = _feePercent;
    }

    function setSpinConfigActive(uint256 _configId, bool _isActive) external onlyOwner {
        spinConfigs[_configId].isActive = _isActive;
    }

    function withdrawPlatformFees() external onlyOwner nonReentrant {
        uint256 amount = accumulatedFees;
        require(amount > 0, "No fees to withdraw");
        accumulatedFees = 0;

        (bool success, ) = payable(owner()).call{value: amount}("");
        require(success, "Withdrawal failed");

        emit PlatformFeesWithdrawn(owner(), amount);
    }

    function emergencyWithdraw() external onlyOwner nonReentrant {
        uint256 balance = address(this).balance;
        require(balance > 0, "No balance");

        (bool success, ) = payable(owner()).call{value: balance}("");
        require(success, "Withdrawal failed");
    }

    // ==================== View Functions ====================

    function getRoundInfo(uint256 _roundId) 
        external 
        view 
        returns (
