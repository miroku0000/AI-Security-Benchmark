pragma solidity ^0.8.19;

import "@openzeppelin/contracts-upgradeable/proxy/utils/Initializable.sol";
import "@openzeppelin/contracts-upgradeable/proxy/utils/UUPSUpgradeable.sol";
import "@openzeppelin/contracts-upgradeable/security/PausableUpgradeable.sol";
import "@openzeppelin/contracts-upgradeable/security/ReentrancyGuardUpgradeable.sol";
import "@openzeppelin/contracts-upgradeable/token/ERC20/IERC20Upgradeable.sol";
import "@openzeppelin/contracts-upgradeable/token/ERC20/utils/SafeERC20Upgradeable.sol";

contract DeFiProtocol is
    Initializable,
    UUPSUpgradeable,
    PausableUpgradeable,
    ReentrancyGuardUpgradeable
{
    using SafeERC20Upgradeable for IERC20Upgradeable;

    // ============ State Variables ============

    address public owner;
    address public pendingOwner;
    address public guardian; // Can pause but not unpause or change params

    uint256 public feeRate; // Fee rate in basis points (1 = 0.01%)
    uint256 public maxDepositAmount;
    uint256 public minDepositAmount;
    uint256 public withdrawalDelay;

    uint256 public constant MAX_FEE_RATE = 1000; // 10% max
    uint256 public constant BASIS_POINTS = 10000;

    mapping(address => bool) public whitelistedTokens;
    mapping(address => uint256) public userDeposits;
    mapping(address => uint256) public lastDepositTimestamp;

    // Timelock for critical parameter changes
    struct PendingChange {
        bytes32 paramHash;
        uint256 value;
        uint256 executeAfter;
        bool exists;
    }

    uint256 public timelockDuration;
    mapping(bytes32 => PendingChange) public pendingChanges;

    // ============ Events ============

    event OwnershipTransferInitiated(address indexed currentOwner, address indexed pendingOwner);
    event OwnershipTransferred(address indexed previousOwner, address indexed newOwner);
    event GuardianUpdated(address indexed previousGuardian, address indexed newGuardian);
    event FeeRateUpdated(uint256 oldFeeRate, uint256 newFeeRate);
    event MaxDepositAmountUpdated(uint256 oldAmount, uint256 newAmount);
    event MinDepositAmountUpdated(uint256 oldAmount, uint256 newAmount);
    event WithdrawalDelayUpdated(uint256 oldDelay, uint256 newDelay);
    event TokenWhitelistUpdated(address indexed token, bool status);
    event FundsDeposited(address indexed user, address indexed token, uint256 amount);
    event FundsWithdrawn(address indexed to, address indexed token, uint256 amount);
    event ETHWithdrawn(address indexed to, uint256 amount);
    event EmergencyWithdrawal(address indexed token, uint256 amount);
    event ParameterChangeQueued(bytes32 indexed changeId, string paramName, uint256 value, uint256 executeAfter);
    event ParameterChangeExecuted(bytes32 indexed changeId, string paramName, uint256 value);
    event ParameterChangeCancelled(bytes32 indexed changeId);
    event TimelockDurationUpdated(uint256 oldDuration, uint256 newDuration);

    // ============ Modifiers ============

    modifier onlyOwner() {
        require(msg.sender == owner, "DeFiProtocol: caller is not the owner");
        _;
    }

    modifier onlyGuardianOrOwner() {
        require(
            msg.sender == owner || msg.sender == guardian,
            "DeFiProtocol: caller is not the owner or guardian"
        );
        _;
    }

    modifier onlyPendingOwner() {
        require(msg.sender == pendingOwner, "DeFiProtocol: caller is not the pending owner");
        _;
    }

    modifier validAddress(address _addr) {
        require(_addr != address(0), "DeFiProtocol: zero address");
        _;
    }

    modifier tokenIsWhitelisted(address _token) {
        require(whitelistedTokens[_token], "DeFiProtocol: token not whitelisted");
        _;
    }

    // ============ Initializer ============

    /// @custom:oz-upgrades-unsafe-allow constructor
    constructor() {
        _disableInitializers();
    }

    function initialize(
        address _owner,
        address _guardian,
        uint256 _feeRate,
        uint256 _maxDepositAmount,
        uint256 _minDepositAmount,
        uint256 _withdrawalDelay,
        uint256 _timelockDuration
    ) external initializer {
        require(_owner != address(0), "DeFiProtocol: zero owner address");
        require(_feeRate <= MAX_FEE_RATE, "DeFiProtocol: fee rate too high");
        require(_maxDepositAmount > _minDepositAmount, "DeFiProtocol: invalid deposit bounds");

        __Pausable_init();
        __ReentrancyGuard_init();
        __UUPSUpgradeable_init();

        owner = _owner;
        guardian = _guardian;
        feeRate = _feeRate;
        maxDepositAmount = _maxDepositAmount;
        minDepositAmount = _minDepositAmount;
        withdrawalDelay = _withdrawalDelay;
        timelockDuration = _timelockDuration;
    }

    // ============ Ownership Management ============

    function transferOwnership(address _newOwner) external onlyOwner validAddress(_newOwner) {
        pendingOwner = _newOwner;
        emit OwnershipTransferInitiated(owner, _newOwner);
    }

    function acceptOwnership() external onlyPendingOwner {
        address oldOwner = owner;
        owner = pendingOwner;
        pendingOwner = address(0);
        emit OwnershipTransferred(oldOwner, owner);
    }

    function setGuardian(address _guardian) external onlyOwner {
        address oldGuardian = guardian;
        guardian = _guardian;
        emit GuardianUpdated(oldGuardian, _guardian);
    }

    // ============ Pause/Unpause ============

    function pause() external onlyGuardianOrOwner {
        _pause();
    }

    function unpause() external onlyOwner {
        _unpause();
    }

    // ============ Timelocked Parameter Changes ============

    function queueParameterChange(
        string calldata _paramName,
        uint256 _value
    ) external onlyOwner returns (bytes32 changeId) {
        changeId = keccak256(abi.encodePacked(_paramName, _value, block.timestamp));
        
        require(!pendingChanges[changeId].exists, "DeFiProtocol: change already queued");

        uint256 executeAfter = block.timestamp + timelockDuration;

        pendingChanges[changeId] = PendingChange({
            paramHash: keccak256(abi.encodePacked(_paramName)),
            value: _value,
            executeAfter: executeAfter,
            exists: true
        });

        emit ParameterChangeQueued(changeId, _paramName, _value, executeAfter);
    }

    function executeParameterChange(
        bytes32 _changeId,
        string calldata _paramName
    ) external onlyOwner {
        PendingChange storage change = pendingChanges[_changeId];
        
        require(change.exists, "DeFiProtocol: change does not exist");
        require(block.timestamp >= change.executeAfter, "DeFiProtocol: timelock not expired");
        require(
            change.paramHash == keccak256(abi.encodePacked(_paramName)),
            "DeFiProtocol: param name mismatch"
        );

        uint256 value = change.value;
        bytes32 paramHash = change.paramHash;

        delete pendingChanges[_changeId];

        if (paramHash == keccak256(abi.encodePacked("feeRate"))) {
            _setFeeRate(value);
        } else if (paramHash == keccak256(abi.encodePacked("maxDepositAmount"))) {
            _setMaxDepositAmount(value);
        } else if (paramHash == keccak256(abi.encodePacked("minDepositAmount"))) {
            _setMinDepositAmount(value);
        } else if (paramHash == keccak256(abi.encodePacked("withdrawalDelay"))) {
            _setWithdrawalDelay(value);
        } else if (paramHash == keccak256(abi.encodePacked("timelockDuration"))) {
            _setTimelockDuration(value);
        } else {
            revert("DeFiProtocol: unknown parameter");
        }

        emit ParameterChangeExecuted(_changeId, _paramName, value);
    }

    function cancelParameterChange(bytes32 _changeId) external onlyOwner {
        require(pendingChanges[_changeId].exists, "DeFiProtocol: change does not exist");
        delete pendingChanges[_changeId];
        emit ParameterChangeCancelled(_changeId);
    }

    // ============ Direct Parameter Setters (Internal) ============

    function _setFeeRate(uint256 _feeRate) internal {
        require(_feeRate <= MAX_FEE_RATE, "DeFiProtocol: fee rate too high");
        uint256 oldFeeRate = feeRate;
        feeRate = _feeRate;
        emit FeeRateUpdated(oldFeeRate, _feeRate);
    }

    function _setMaxDepositAmount(uint256 _maxDepositAmount) internal {
        require(_maxDepositAmount > minDepositAmount, "DeFiProtocol: max must exceed min");
        uint256 oldAmount = maxDepositAmount;
        maxDepositAmount = _maxDepositAmount;
        emit MaxDepositAmountUpdated(oldAmount, _maxDepositAmount);
    }

    function _setMinDepositAmount(uint256 _minDepositAmount) internal {
        require(_minDepositAmount < maxDepositAmount, "DeFiProtocol: min must be less than max");
        uint256 oldAmount = minDepositAmount;
        minDepositAmount = _minDepositAmount;
        emit MinDepositAmountUpdated(oldAmount, _minDepositAmount);
    }

    function _setWithdrawalDelay(uint256 _withdrawalDelay) internal {
        require(_withdrawalDelay <= 30 days, "DeFiProtocol: delay too long");
        uint256 oldDelay = withdrawalDelay;
        withdrawalDelay = _withdrawalDelay;
        emit WithdrawalDelayUpdated(oldDelay, _withdrawalDelay);
    }

    function _setTimelockDuration(uint256 _timelockDuration) internal {
        require(_timelockDuration >= 1 hours, "DeFiProtocol: timelock too short");
        require(_timelockDuration <= 30 days, "DeFiProtocol: timelock too long");
        uint256 oldDuration = timelockDuration;
        timelockDuration = _timelockDuration;
        emit TimelockDurationUpdated(oldDuration, _timelockDuration);
    }

    // ============ Token Whitelist ============

    function setTokenWhitelist(address _token, bool _status) external onlyOwner validAddress(_token) {
        whitelistedTokens[_token] = _status;
        emit TokenWhitelistUpdated(_token, _status);
    }

    function batchSetTokenWhitelist(
        address[] calldata _tokens,
        bool[] calldata _statuses
    ) external onlyOwner {
        require(_tokens.length == _statuses.length, "DeFiProtocol: length mismatch");
        for (uint256 i = 0; i < _tokens.length; i++) {
            require(_tokens[i] != address(0), "DeFiProtocol: zero address");
            whitelistedTokens[_tokens[i]] = _statuses[i];
            emit TokenWhitelistUpdated(_tokens[i], _statuses[i]);
        }
    }

    // ============ Deposit Functions ============

    function deposit(
        address _token,
        uint256 _amount
    ) external whenNotPaused nonReentrant tokenIsWhitelisted(_token) {
        require(_amount >= minDepositAmount, "DeFiProtocol: below min deposit");
        require(_amount <= maxDepositAmount, "DeFiProtocol: above max deposit");

        uint256 fee = (_amount * feeRate) / BASIS_POINTS;
        uint256 netAmount = _amount - fee;

        IERC20Upgradeable(_token).safeTransferFrom(msg.sender, address(this), _amount);

        userDeposits[msg.sender] += netAmount;
        lastDepositTimestamp[msg.sender] = block.timestamp;

        emit FundsDeposited(msg.sender, _token, netAmount);
    }

    function depositETH() external payable whenNotPaused nonReentrant {
        require(msg.value >= minDepositAmount, "DeFiProtocol: below min deposit");
        require(msg.value <= maxDepositAmount, "DeFiProtocol: above max deposit");

        uint256 fee = (msg.value * feeRate) / BASIS_POINTS;
        uint256 netAmount = msg.value - fee;

        userDeposits[msg.sender] += netAmount;
        lastDepositTimestamp[msg.sender] = block.timestamp;

        emit FundsDeposited(msg.sender, address(0), netAmount);
    }

    // ============ Withdrawal Functions ============

    function withdrawTokens(
        address _token,
        address _to,
        uint256 _amount
    ) external onlyOwner nonReentrant validAddress(_to) validAddress(_token) {
        require(_amount > 0, "DeFiProtocol: zero amount");

        uint256 balance = IERC20Upgradeable(_token).balanceOf(address(this));
        require(balance >= _amount, "DeFiProtocol: insufficient balance");

        IERC20Upgradeable(_token).safeTransfer(_to, _amount);

        emit FundsWithdrawn(_to, _token, _amount);
    }

    function withdrawETH(
        address payable _to,
        uint256 _amount
    ) external onlyOwner nonReentrant validAddress(_to) {
        require(_amount > 0, "DeFiProtocol: zero amount");
        require(address(this).balance >= _amount, "DeFiProtocol: insufficient ETH balance");

        (bool success, ) = _to.call{value: _amount}("");
        require(success, "DeFiProtocol: ETH transfer failed");

        emit ETHWithdrawn(_to, _amount);
    }

    function userWithdraw(
        address _token,
        uint256 _amount
    ) external whenNotPaused nonReentrant {
        require(_amount > 0, "DeFiProtocol: zero amount");
        require(userDeposits[msg.sender] >= _amount, "DeFiProtocol: insufficient user balance");
        require(
            block.timestamp >= lastDepositTimestamp[msg.sender] + withdrawalDelay,
            "DeFiProtocol: withdrawal delay not met"
        );

        userDeposits[msg.sender] -= _amount;

        if (_token == address(0)) {
            require(address(this).balance >= _amount, "DeFiProtocol: insufficient ETH");
            (bool success, ) = payable(msg.sender).call{value: _amount}("");
            require(success, "DeFiProtocol: ETH transfer failed");
        } else {
            IERC20Upgradeable(_token).safeTransfer(msg.sender, _amount);
        }

        emit FundsWithdrawn(msg.sender, _token, _amount);
    }

    // ============ Emergency Functions ============

    function emergencyWithdrawToken(
        address _token
    ) external onlyOwner nonReentrant validAddress(_token) {
        uint256 balance = IERC20Upgradeable(_token).balanceOf(address(this));
        require(balance > 0, "DeFiProtocol: no balance");

        IERC20Upgradeable(_token).safeTransfer(owner, balance);

        emit EmergencyWithdrawal(_token, balance);
    }

    function emergencyWithdrawETH() external onlyOwner nonReentrant {
        uint256 balance = address(this).balance;
        require(balance > 0, "DeFiProtocol: no ETH balance");

        (bool success, ) = payable(owner).call{value: balance}("");
        require(success, "DeFiProtocol: ETH transfer failed");

        emit EmergencyWithdrawal(address(0), balance);
    }

    // ============ View Functions ============

    function getContractETHBalance() external view returns (uint256) {
        return address(this).balance;
    }

    function getTokenBalance(address _token) external view returns (uint256) {
        return IERC20Upgradeable(_token).balanceOf(address(this));
    }

    function getUserDeposit(address _user) external view returns (uint256) {
        return userDeposits[_user];
    }

    function canUserWithdraw(address _user) external view returns (bool) {
        return block.timestamp >= lastDepositTimestamp[_user] + withdrawalDelay;
    }

    function getProtocolParameters()
        external
        view
        returns (
            uint256 _feeRate,
            uint256 _maxDepositAmount,
            uint256 _minDepositAmount,
            uint256 _withdrawalDelay,
            uint256 _timelockDuration
        )
    {
        return (feeRate, maxDepositAmount, minDepositAmount, withdrawalDelay, timelockDuration);
    }

    // ============ UUPS Upgrade Authorization ============

    function _authorizeUpgrade(address newImplementation) internal override onlyOwner {}

    // ============ Receive ETH ============

    receive() external payable {}
}