data "archive_file" "payment_processor" {
  type        = "zip"
  output_path = "${path.module}/builds/payment_processor.zip"

  source {
    content  = <<-EOF
      import json
      import boto3
      import os
      import logging
      from datetime import datetime, timezone

      logger = logging.getLogger()
      logger.setLevel(logging.INFO)

      # IMPORTANT: Never log full card numbers, SSNs, or other PII
      # Use masked/tokenized values only

      dynamodb = boto3.resource('dynamodb')
      lambda_client = boto3.client('lambda')
      table = dynamodb.Table(os.environ['TRANSACTIONS_TABLE'])

      def handler(event, context):
          logger.info("Payment processing initiated", extra={
              "request_id": context.aws_request_id,
              "transaction_count": len(event.get('transactions', []))
          })

          results = []
          for transaction in event.get('transactions', []):
              try:
                  # Validate payment via validator Lambda
                  validation_response = lambda_client.invoke(
                      FunctionName=os.environ['VALIDATOR_FUNCTION_ARN'],
                      InvocationType='RequestResponse',
                      Payload=json.dumps({
                          'transaction_id': transaction['transaction_id'],
                          'amount': transaction['amount'],
                          'currency': transaction['currency'],
                          'customer_id': transaction['customer_id'],
                      })
                  )

                  validation_result = json.loads(validation_response['Payload'].read())

                  if validation_result.get('valid'):
                      # Record the transaction
                      table.put_item(Item={
                          'transaction_id': transaction['transaction_id'],
                          'timestamp': datetime.now(timezone.utc).isoformat(),
                          'customer_id': transaction['customer_id'],
                          'amount': str(transaction['amount']),
                          'currency': transaction['currency'],
                          'status': 'PROCESSED',
                          'processor_request_id': context.aws_request_id,
                      })
                      results.append({
                          'transaction_id': transaction['transaction_id'],
                          'status': 'PROCESSED'
                      })
                  else:
                      results.append({
                          'transaction_id': transaction['transaction_id'],
                          'status': 'REJECTED',
                          'reason': validation_result.get('reason', 'Validation failed')
                      })

              except Exception as e:
                  logger.error("Transaction processing failed", extra={
                      "transaction_id": transaction.get('transaction_id', 'unknown'),
                      "error": str(e)
                  })
                  results.append({
                      'transaction_id': transaction.get('transaction_id', 'unknown'),
                      'status': 'ERROR'
                  })

          return {
              'statusCode': 200,
              'body': json.dumps({'results': results})
          }
    EOF
    filename = "index.py"
  }
}

data "archive_file" "payment_validator" {
  type        = "zip"
  output_path = "${path.module}/builds/payment_validator.zip"

  source {
    content  = <<-EOF
      import json
      import boto3
      import os
      import logging
      from decimal import Decimal

      logger = logging.getLogger()
      logger.setLevel(logging.INFO)

      dynamodb = boto3.resource('dynamodb')
      table = dynamodb.Table(os.environ['TRANSACTIONS_TABLE'])

      # Configurable limits
      MAX_TRANSACTION_AMOUNT = Decimal(os.environ.get('MAX_TRANSACTION_AMOUNT', '50000'))
      SUPPORTED_CURRENCIES = os.environ.get('SUPPORTED_CURRENCIES', 'USD,EUR,GBP').split(',')

      def handler(event, context):
          logger.info("Validating transaction", extra={
              "transaction_id": event.get('transaction_id'),
              "request_id": context.aws_request_id
          })

          errors = []

          # Validate required fields
          required_fields = ['transaction_id', 'amount', 'currency', 'customer_id']
          for field in required_fields:
              if field not in event or not event[field]:
                  errors.append(f"Missing required field: {field}")

          if errors:
              return {'valid': False, 'reason': '; '.join(errors)}

          amount = Decimal(str(event['amount']))

          # Validate amount
          if amount <= 0:
              errors.append("Transaction amount must be positive")
          if amount > MAX_TRANSACTION_AMOUNT:
              errors.append(f"Transaction amount exceeds maximum of {MAX_TRANSACTION_AMOUNT}")

          # Validate currency
          if event['currency'] not in SUPPORTED_CURRENCIES:
              errors.append(f"Unsupported currency: {event['currency']}")

          # Check for duplicate transaction
          try:
              response = table.query(
                  KeyConditionExpression=boto3.dynamodb.conditions.Key('transaction_id').eq(event['transaction_id']),
                  Limit=1
              )
              if response.get('Items'):
                  errors.append("Duplicate transaction detected")
          except Exception as e:
              logger.error("Error checking for duplicate transaction", extra={"error": str(e)})
              errors.append("Unable to verify transaction uniqueness")

          if errors:
              return {'valid': False, 'reason': '; '.join(errors)}

          return {'valid': True}
    EOF
    filename = "index.py"
  }
}

data "archive_file" "transaction_recorder" {
  type        = "zip"
  output_path = "${path.module}/builds/transaction_recorder.zip"

  source {
    content  = <<-EOF
      import json
      import boto3
      import os
      import logging
      from datetime import datetime, timezone

      logger = logging.getLogger()
      logger.setLevel(logging.INFO)

      dynamodb = boto3.resource('dynamodb')
      table = dynamodb.Table(os.environ['TRANSACTIONS_TABLE'])

      def handler(event, context):
          logger.info("Processing DynamoDB stream records", extra={
              "record_count": len(event.get('Records', [])),
              "request_id": context.aws_request_id
          })

          for record in event.get('Records', []):
              if record['eventName'] in ['INSERT', 'MODIFY']:
                  new_image = record['dynamodb'].get('NewImage', {})
                  transaction_id = new_image.get('transaction_id', {}).get('S', 'unknown')

                  logger.info("Transaction recorded", extra={
                      "transaction_id": transaction_id,
                      "event_name": record['eventName'],
                      "status": new_image.get('status', {}).get('S', 'unknown')
                  })

                  # Update audit trail
                  try:
                      table.update_item(
                          Key={
                              'transaction_id': transaction_id,
                              'timestamp': new_image.get('timestamp', {}).get('S', datetime.now(timezone.utc).isoformat())
                          },
                          UpdateExpression='SET audit_recorded = :val, audit_timestamp = :ts',
                          ExpressionAttributeValues={
                              ':val': True,
                              ':ts': datetime.now(timezone.utc).isoformat()
                          }
                      )
                  except Exception as e:
                      logger.error("Failed to update audit trail", extra={
                          "transaction_id": transaction_id,
                          "error": str(e)
                      })
                      raise

          return {'statusCode': 200, 'processed': len(event.get('Records', []))}
    EOF
    filename = "index.py"
  }
}

