resource "aws_lambda_function" "payment_processor" {
  function_name    = "payment-processor-${var.environment}"
  description      = "Processes payment transactions with validation and recording"
  filename         = data.archive_file.payment_processor.output_path
  source_code_hash = data.archive_file.payment_processor.output_base64sha256
  handler          = "index.handler"
  runtime          = "python3.12"
  timeout          = 30
  memory_size      = 512

  reserved_concurrent_executions = var.reserved_concurrent_executions

  role = aws_iam_role.payment_processor_role.arn

  kms_key_arn = aws_kms_key.financial_data.arn

  dead_letter_config {
    target_arn = aws_sqs_queue.payment_processor_dlq.arn
  }

  vpc_config {
    subnet_ids         = var.private_subnet_ids
    security_group_ids = [aws_security_group.lambda_sg.id]
  }

  environment {
    variables = {
      TRANSACTIONS_TABLE     = aws_dynamodb_table.transactions.name
      VALIDATOR_FUNCTION_ARN = aws_lambda_function.payment_validator.arn
      ENVIRONMENT            = var.environment
      LOG_LEVEL              = "INFO"
      POWERTOOLS_SERVICE_NAME = "payment-processor"
    }
  }

  tracing_config {
    mode = "Active"
  }

  depends_on = [
    aws_cloudwatch_log_group.payment_processor,
    aws_iam_role_policy.payment_processor_policy,
  ]

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
    DataClass   = "financial-pii"
  }
}

resource "aws_lambda_function" "payment_validator" {
  function_name    = "payment-validator-${var.environment}"
  description      = "Validates payment transactions for fraud and compliance"
  filename         = data.archive_file.payment_validator.output_path
  source_code_hash = data.archive_file.payment_validator.output_base64sha256
  handler          = "index.handler"
  runtime          = "python3.12"
  timeout          = 15
  memory_size      = 256

  reserved_concurrent_executions = var.reserved_concurrent_executions

  role = aws_iam_role.payment_validator_role.arn

  kms_key_arn = aws_kms_key.financial_data.arn

  dead_letter_config {
    target_arn = aws_sqs_queue.payment_validator_dlq.arn
  }

  vpc_config {
    subnet_ids         = var.private_subnet_ids
    security_group_ids = [aws_security_group.lambda_sg.id]
  }

  environment {
    variables = {
      TRANSACTIONS_TABLE       = aws_dynamodb_table.transactions.name
      ENVIRONMENT              = var.environment
      MAX_TRANSACTION_AMOUNT   = "50000"
      SUPPORTED_CURRENCIES     = "USD,EUR,GBP"
      LOG_LEVEL                = "INFO"
      POWERTOOLS_SERVICE_NAME  = "payment-validator"
    }
  }

  tracing_config {
    mode = "Active"
  }

  depends_on = [
    aws_cloudwatch_log_group.payment_validator,
    aws_iam_role_policy.payment_validator_policy,
  ]

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
    DataClass   = "financial-pii"
  }
}

resource "aws_lambda_function" "transaction_recorder" {
  function_name    = "payment-transaction-recorder-${var.environment}"
  description      = "Records and audits transaction events from DynamoDB streams"
  filename         = data.archive_file.transaction_recorder.output_path
  source_code_hash = data.archive_file.transaction_recorder.output_base64sha256
  handler          = "index.handler"
  runtime          = "python3.12"
  timeout          = 60
  memory_size      = 256

  reserved_concurrent_executions = var.reserved_concurrent_executions

  role = aws_iam_role.transaction_recorder_role.arn

  kms_key_arn = aws_kms_key.financial_data.arn

  dead_letter_config {
    target_arn = aws_sqs_queue.transaction_recorder_dlq.arn
  }

  vpc_config {
    subnet_ids         = var.private_subnet_ids
    security_group_ids = [aws_security_group.lambda_sg.id]
  }

  environment {
    variables = {
      TRANSACTIONS_TABLE      = aws_dynamodb_table.transactions.name
      ENVIRONMENT             = var.environment
      LOG_LEVEL               = "INFO"
      POWERTOOLS_SERVICE_NAME = "transaction-recorder"
    }
  }

  tracing_config {
    mode = "Active"
  }

  depends_on = [
    aws_cloudwatch_log_group.transaction_recorder,
    aws_iam_role_policy.transaction_recorder_policy,
  ]

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
    DataClass   = "financial-pii"
  }
}

# --- DynamoDB Stream Event Source Mapping for Transaction Recorder ---

resource "aws_lambda_event_source_mapping" "transaction_stream" {
  event_source_arn                   = aws_dynamodb_table.transactions.stream_arn
  function_name                      = aws_lambda_function.transaction_recorder.arn
  starting_position                  = "LATEST"
  batch_size                         = 10
  maximum_batching_window_in_seconds = 5
  maximum_retry_attempts             = 3
  bisect_batch_on_function_error     = true
  parallelization_factor             = 2

  destination_config {
    on_failure {
      destination_arn = aws_sqs_queue.transaction_recorder_dlq.arn
    }
  }

  filter_criteria {
    filter {
      pattern = jsonencode({
        eventName = ["INSERT", "MODIFY"]
      })
    }
  }
}

# ============================================================
# CloudWatch Alarms - Essential for financial processing
# NOTE: These are critical baseline alarms that must ship with
# the functions. Financial data processing requires immediate
# error visibility - we cannot defer this to a future sprint.
# Additional dashboards and fine-tuned alarms can follow later.
# ============================================================

resource "aws_cloudwatch_metric_alarm" "payment_processor_errors" {
  alarm_name          = "payment-processor-errors-${var.environment}"
  alarm_description   = "CRITICAL: Payment processor Lambda function errors detected - potential financial data processing failures"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 1
  metric_name         = "Errors"
  namespace           = "AWS/Lambda"
  period              = 60
  statistic           = "Sum"
  threshold           = 0
  treat_missing_data  = "notBreaching"

  dimensions = {
    FunctionName = aws_lambda_function.payment_processor.function_name
  }

  alarm_actions = [var.alarm_sns_topic_arn]
  ok_actions    = [var.alarm_sns_topic_arn]

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
    Severity    = "critical"
  }
}

resource "aws_cloudwatch_metric_alarm" "payment_validator_errors" {
