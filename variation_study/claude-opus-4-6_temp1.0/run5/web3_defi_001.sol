import "@openzeppelin/contracts/security/ReentrancyGuard.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

interface IUniswapV2Pair {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function token0() external view returns (address);
    function token1() external view returns (address);
}

interface IUniswapV2Factory {
    function getPair(address tokenA, address tokenB) external view returns (address pair);
}

contract DeFiLendingProtocol is ReentrancyGuard, Ownable {
    using SafeERC20 for IERC20;

    // --- Structs ---
    struct Market {
        bool isListed;
        uint256 collateralFactorBps;    // e.g., 7500 = 75%
        uint256 liquidationThresholdBps; // e.g., 8500 = 85%
        uint256 liquidationBonusBps;     // e.g., 500 = 5%
        uint256 borrowRatePerSecond;     // interest rate per second (scaled by 1e18)
        uint256 supplyRatePerSecond;
        uint256 totalDeposits;
        uint256 totalBorrows;
        uint256 borrowIndex;             // accumulated borrow index (scaled by 1e18)
        uint256 lastAccrualTimestamp;
        uint256 reserveFactorBps;        // portion of interest to protocol reserves
        uint256 totalReserves;
    }

    struct UserDeposit {
        uint256 amount;
    }

    struct UserBorrow {
        uint256 principal;
        uint256 borrowIndex; // snapshot of market borrowIndex at time of borrow
    }

    // --- State ---
    address public baseToken; // e.g., WETH used as price reference
    IUniswapV2Factory public dexFactory;

    mapping(address => Market) public markets;
    address[] public marketList;

    // user => token => deposit
    mapping(address => mapping(address => UserDeposit)) public userDeposits;
    // user => token => borrow
    mapping(address => mapping(address => UserBorrow)) public userBorrows;
    // user => list of tokens deposited as collateral
    mapping(address => address[]) public userCollateralTokens;
    // user => list of tokens borrowed
    mapping(address => address[]) public userBorrowTokens;
    // user => token => bool (tracking membership)
    mapping(address => mapping(address => bool)) public userHasCollateral;
    mapping(address => mapping(address => bool)) public userHasBorrow;

    // Price oracle: token => DEX pair address (token/baseToken pair)
    mapping(address => address) public priceFeeds;

    // TWAP storage for manipulation resistance
    struct PriceObservation {
        uint256 timestamp;
        uint256 priceCumulative; // cumulative price scaled by 1e18
    }

    mapping(address => PriceObservation[]) public priceObservations;
    uint256 public twapWindow = 15 minutes;

    uint256 public constant BPS_DENOMINATOR = 10000;
    uint256 public constant PRICE_PRECISION = 1e18;
    uint256 public constant INDEX_PRECISION = 1e18;

    // --- Events ---
    event MarketAdded(address indexed token, uint256 collateralFactor, uint256 liquidationThreshold);
    event Deposit(address indexed user, address indexed token, uint256 amount);
    event Withdraw(address indexed user, address indexed token, uint256 amount);
    event Borrow(address indexed user, address indexed token, uint256 amount);
    event Repay(address indexed user, address indexed token, uint256 amount);
    event Liquidation(
        address indexed liquidator,
        address indexed borrower,
        address indexed borrowToken,
        address collateralToken,
        uint256 repayAmount,
        uint256 seizedCollateral
    );
    event InterestAccrued(address indexed token, uint256 borrowIndex, uint256 totalBorrows);
    event PriceFeedSet(address indexed token, address indexed pair);

    constructor(address _dexFactory, address _baseToken) {
        dexFactory = IUniswapV2Factory(_dexFactory);
        baseToken = _baseToken;
    }

    // --- Admin Functions ---

    function addMarket(
        address _token,
        uint256 _collateralFactorBps,
        uint256 _liquidationThresholdBps,
        uint256 _liquidationBonusBps,
        uint256 _borrowRatePerSecond,
        uint256 _supplyRatePerSecond,
        uint256 _reserveFactorBps
    ) external onlyOwner {
        require(!markets[_token].isListed, "Market already listed");
        require(_collateralFactorBps <= 9000, "CF too high");
        require(_liquidationThresholdBps > _collateralFactorBps, "LT must > CF");
        require(_liquidationThresholdBps <= 9500, "LT too high");
        require(_liquidationBonusBps <= 1500, "Bonus too high");

        markets[_token] = Market({
            isListed: true,
            collateralFactorBps: _collateralFactorBps,
            liquidationThresholdBps: _liquidationThresholdBps,
            liquidationBonusBps: _liquidationBonusBps,
            borrowRatePerSecond: _borrowRatePerSecond,
            supplyRatePerSecond: _supplyRatePerSecond,
            totalDeposits: 0,
            totalBorrows: 0,
            borrowIndex: INDEX_PRECISION,
            lastAccrualTimestamp: block.timestamp,
            reserveFactorBps: _reserveFactorBps,
            totalReserves: 0
        });

        marketList.push(_token);

        // Auto-detect or set DEX pair
        address pair = dexFactory.getPair(_token, baseToken);
        if (pair != address(0)) {
            priceFeeds[_token] = pair;
            emit PriceFeedSet(_token, pair);
        }

        emit MarketAdded(_token, _collateralFactorBps, _liquidationThresholdBps);
    }

    function setPriceFeed(address _token, address _pair) external onlyOwner {
        require(markets[_token].isListed, "Market not listed");
        priceFeeds[_token] = _pair;
        emit PriceFeedSet(_token, _pair);
    }

    function setTwapWindow(uint256 _window) external onlyOwner {
        require(_window >= 1 minutes && _window <= 1 hours, "Invalid window");
        twapWindow = _window;
    }

    function updateMarketRates(
        address _token,
        uint256 _borrowRatePerSecond,
        uint256 _supplyRatePerSecond
    ) external onlyOwner {
        require(markets[_token].isListed, "Market not listed");
        accrueInterest(_token);
        markets[_token].borrowRatePerSecond = _borrowRatePerSecond;
        markets[_token].supplyRatePerSecond = _supplyRatePerSecond;
    }

    // --- Price Oracle (DEX-based) ---

    function getSpotPrice(address _token) public view returns (uint256) {
        if (_token == baseToken) {
            return PRICE_PRECISION; // 1:1
        }

        address pair = priceFeeds[_token];
        require(pair != address(0), "No price feed");

        IUniswapV2Pair dexPair = IUniswapV2Pair(pair);
        (uint112 reserve0, uint112 reserve1,) = dexPair.getReserves();

        require(reserve0 > 0 && reserve1 > 0, "Empty reserves");

        address token0 = dexPair.token0();

        uint256 price;
        if (token0 == _token) {
            // price = reserve1 / reserve0 (baseToken per token)
            price = (uint256(reserve1) * PRICE_PRECISION) / uint256(reserve0);
        } else {
            // price = reserve0 / reserve1
            price = (uint256(reserve0) * PRICE_PRECISION) / uint256(reserve1);
        }

        return price;
    }

    function recordPriceObservation(address _token) public {
        uint256 currentPrice = getSpotPrice(_token);
        PriceObservation[] storage observations = priceObservations[_token];

        if (observations.length > 0) {
            PriceObservation storage last = observations[observations.length - 1];
            if (last.timestamp == block.timestamp) {
                return; // Already recorded this block
            }
            uint256 timeElapsed = block.timestamp - last.timestamp;
            uint256 newCumulative = last.priceCumulative + (currentPrice * timeElapsed);
            observations.push(PriceObservation({
                timestamp: block.timestamp,
                priceCumulative: newCumulative
            }));
        } else {
            observations.push(PriceObservation({
                timestamp: block.timestamp,
                priceCumulative: 0
            }));
        }

        // Prune old observations (keep last 50)
        if (observations.length > 50) {
            // Shift array - gas expensive but keeps array bounded
            for (uint i = 0; i < observations.length - 25; i++) {
                observations[i] = observations[i + 25];
            }
            for (uint i = 0; i < 25; i++) {
                observations.pop();
            }
        }
    }

    function getTwapPrice(address _token) public view returns (uint256) {
        if (_token == baseToken) {
            return PRICE_PRECISION;
        }

        PriceObservation[] storage observations = priceObservations[_token];

        if (observations.length < 2) {
            // Fall back to spot price if not enough observations
            return getSpotPrice(_token);
        }

        PriceObservation storage latest = observations[observations.length - 1];

        // Find observation closest to twapWindow ago
        uint256 targetTime = block.timestamp > twapWindow ? block.timestamp - twapWindow : 0;
        uint256 oldIndex = 0;

        for (uint256 i = observations.length - 1; i > 0; i--) {
            if (observations[i - 1].timestamp <= targetTime) {
                oldIndex = i - 1;
                break;
            }
        }

        PriceObservation storage older = observations[oldIndex];
        uint256 timeElapsed = latest.timestamp - older.timestamp;

        if (timeElapsed == 0) {
            return getSpotPrice(_token);
        }

        // Also add the time from latest observation to now
        uint256 currentPrice = getSpotPrice(_token);
        uint256 timeSinceLatest = block.timestamp - latest.timestamp;
        uint256 totalCumulativeDiff = (latest.priceCumulative - older.priceCumulative) + (currentPrice * timeSinceLatest);
        uint256 totalTime = timeElapsed + timeSinceLatest;

        return totalCumulativeDiff / totalTime;
    }

    // Use the safer of spot and TWAP (take the lower for collateral, higher for debt)
    function getPrice(address _token) public view returns (uint256) {
        uint256 spot = getSpotPrice(_token);
        uint256 twap = getTwapPrice(_token);

        // Return geometric mean to reduce manipulation
        // Simplified: return average
        return (spot + twap) / 2;
    }

    // Get the value of an amount of tokens in base token terms
    function getTokenValue(address _token, uint256 _amount) public view returns (uint256) {
        if (_amount == 0) return 0;
        uint256 price = getPrice(_token);
        return (_amount * price) / PRICE_PRECISION;
    }

    // --- Interest Accrual ---

    function accrueInterest(address _token) public {
        Market storage market = markets[_token];
        if (!market.isListed) return;

        uint256 currentTimestamp = block.timestamp;
        uint256 timeElapsed = currentTimestamp - market.lastAccrualTimestamp;

        if (timeElapsed == 0) return;

        if (market.totalBorrows > 0) {
            uint256 interestAccumulated = (market.totalBorrows * market.borrowRatePerSecond * timeElapsed) / PRICE_PRECISION;

            uint256 reserveShare = (interestAccumulated * market.reserveFactorBps) / BPS_DENOMINATOR;
            market.totalReserves += reserveShare;

            market.totalBorrows += interestAccumulated;
            market.borrowIndex += (market.borrowIndex * market.borrowRatePerSecond * timeElapsed) / PRICE_PRECISION;
        }

        market.lastAccrualTimestamp = currentTimestamp;

        // Record price observation
        if (priceFeeds[_token] != address(0)) {
            recordPriceObservation(_token);
        }

        emit InterestAccrued(_token, market.borrowIndex, market.totalBorrows);
    }

    function getCurrentBorrowBalance(address _user, address _token) public view returns (uint256) {
        UserBorrow storage userBorrow = userBorrows[_user][_token];
        if (userBorrow.principal == 0) return 0;

        Market storage market = markets[_token];

        // Calculate current index including unaccrued interest
        uint256 timeElapsed = block.timestamp - market.lastAccrualTimestamp;
        uint256 currentIndex = market.borrowIndex;
        if (timeElapsed > 0 && market.totalBorrows > 0) {
            currentIndex += (market.borrowIndex * market.borrowRatePerSecond * timeElapsed) / PRICE_PRECISION;
        }

        return (userBorrow.principal * currentIndex) / userBorrow.borrowIndex;
    }

    // --- Lending Functions ---

    function deposit(address _token, uint256 _amount) external nonReentrant {
        require(_amount > 0, "Amount must be > 0");
        Market storage market = markets[_token];
        require(market.isListed, "Market not listed");

        accrueInterest(_token);

        IERC20(_token).safeTransferFrom(msg.sender, address(this), _amount);

        userDeposits[msg.sender][_token].amount += _amount;
        market.totalDeposits += _amount;

        // Track collateral membership
        if (!userHasCollateral[msg.sender][_token]) {
            userHasCollateral[msg.sender][_token] = true;
            userCollateralTokens[msg.sender].push(_token);
        }

        emit Deposit(msg.sender, _token, _amount);
    }

    function withdraw(address _token, uint256 _amount) external nonReentrant {
        require(_amount > 0, "Amount must be > 0");
        Market storage market = markets[_token];
        require(market.isListed, "Market not listed");

        accrueInterest(_token);

        UserDeposit storage userDep = userDeposits[msg.sender][_token];
        require(userDep.amount >= _amount, "Insufficient deposit");

        // Simulate withdrawal and check health
        userDep.amount -= _amount;
        market.totalDeposits -= _amount;

        require(isHealthy(msg.sender), "Withdrawal would make position unhealthy");

        // Remove collateral tracking if fully withdrawn
        if (userDep.amount == 0) {
            _removeCollateralToken(msg.sender, _token);
        }

        IERC20(_token).safeTransfer(msg.sender, _amount);

        emit Withdraw(msg.sender, _token, _amount);
    }

    // --- Borrowing Functions ---

    function borrow(address _token, uint256 _amount) external nonReentrant {
        require(_amount > 0, "Amount must be > 0");
        Market storage market = markets[_token];
        require(market.isListed, "Market not listed");

        accrueInterest(_token);

        // Check liquidity
        uint256 availableLiquidity = market.totalDeposits - market.totalBorrows;
        require(_amount <= availableLiquidity, "Insufficient liquidity");

        UserBorrow storage userBorrow = userBorrows[msg.sender][_token];

        // If user already has a borrow, settle the old one first
        if (userBorrow.principal > 0) {
            uint256 currentBalance = (userBorrow.principal * market.borrowIndex) / userBorrow.borrowIndex;
            userBorrow.principal = currentBalance + _amount;
        } else {
            userBorrow.principal = _amount;
        }
        userBorrow.borrowIndex = market.borrowIndex;

        market.totalBorrows += _amount;

        // Track borrow membership
        if (!userHasBorrow[msg.sender][_token]) {
            userHasBorrow[msg.sender][_token] = true;
            userBorrowTokens[msg.sender].push(_token);
        }

        // Check health factor after borrow
        require(isHealthy(msg.sender), "Insufficient collateral");

        IERC20(_token).safeTransfer(msg.sender, _amount);

        emit Borrow(msg.sender, _token, _amount);
    }

    function repay(address _token, uint256 _amount) external nonReentrant {
        require(_amount > 0, "Amount must be > 0");
        Market storage market = markets[_token];
        require(market.isListed, "Market not listed");

        accrueInterest(_token);

        UserBorrow storage userBorrow = userBorrows[msg.sender][_token];
        uint256 currentBalance = getCurrentBorrowBalance(msg.sender, _token);
        require(currentBalance > 0, "No borrow to repay");

        uint256 repayAmount = _amount > currentBalance ? currentBalance : _amount;

        IERC20(_token).safeTransferFrom(msg.sender, address(this), repayAmount);

        // Update borrow state
        if (repayAmount >= currentBalance) {
            userBorrow.principal = 0;
            userBorrow.borrowIndex = 0;
            _removeBorrowToken(msg.sender, _token);
        } else {
            // Recalculate principal at current index
            uint256 newBalance = currentBalance - repayAmount;
            userBorrow.principal = newBalance;
            userBorrow.borrowIndex = market.borrowIndex;
        }

        market.totalBorrows = market.totalBorrows > repayAmount ? market.totalBorrows - repayAmount : 0;

        emit Repay(msg.sender, _token, repayAmount);
    }

    // --- Health & Collateral Calculations ---

    function getTotalCollateralValue(address _user) public view returns (uint256) {
        uint256 totalValue = 0;
        address[] storage collaterals = userCollateralTokens[_user];

        for (uint256 i = 0; i < collaterals.length; i++) {
            address token = collaterals[i];
            uint256 depositAmount = userDeposits[_user][token].amount;
            if (depositAmount > 0) {
                uint256 value = getTokenValue(token, depositAmount);
                uint256 adjustedValue = (value * markets[token].collateralFactorBps) / BPS_DENOMINATOR;
                totalValue += adjustedValue;
            }
        }

        return totalValue;
    }

    function getTotalCollateralValueForLiquidation(address _user) public view returns (uint256) {
        uint256 totalValue = 0;
        address[] storage collaterals = userCollateralTokens[_user];

        for (uint256 i = 0; i < collaterals.length; i++) {
            address token = collaterals[i];
            uint256 depositAmount = userDeposits[_user][token].amount;
            if (depositAmount > 0) {
                uint256 value = getTokenValue(token, depositAmount);
                uint256 adjustedValue = (value * markets[token].liquidationThresholdBps) / BPS_DENOMINATOR;
                totalValue += adjustedValue;
            }
        }

        return totalValue;
    }

    function getTotalBorrowValue(address _user) public view returns (uint256) {
        uint256 totalValue = 0;
        address[] storage borrows = userBorrowTokens[_user];

        for (uint256 i = 0; i < borrows.length; i++) {
            address token = borrows[i];
            uint256 borrowBalance = getCurrentBorrowBalance(_user, token);
            if (borrowBalance > 0) {
                totalValue += getTokenValue(token, borrowBalance);
            }
        }

        return totalValue;
    }

    function isHealthy(address _user) public view returns (bool) {
        uint256 totalBorrowValue = getTotalBorrowValue(_user);
        if (totalBorrowValue == 0) return true;

        uint256 totalCollateralValue = getTotalCollateralValue(_user);
        return totalCollateralValue >= totalBorrowValue;
    }

    function isLiquidatable(address _user) public view returns (bool) {
        uint256 totalBorrowValue = getTotalBorrowValue(_user);
        if (totalBorrowValue == 0) return false;

        uint256 totalCollateralValueLiq = getTotalCollateralValueForLiquidation(_user);
        return totalBorrowValue > totalCollateralValueLiq;
    }

    function getHealthFactor(address _user) public view returns (uint256) {
        uint256 totalBorrowValue = getTotalBorrowValue(_user);
        if (totalBorrowValue == 0) return type(uint256).max;

        uint256 totalCollateralValueLiq = getTotalCollateralValueForLiquidation(_user);
        return (totalCollateralValueLiq * PRICE_PRECISION) / totalBorrowValue;
    }

    // --- Liquidation ---

    function liquidate(
        address _borrower,
        address _borrowToken,
        address _collateralToken,
        uint256 _repayAmount
    ) external nonReentrant {
        require(msg.sender != _borrower, "Cannot liquidate self");
        require(markets[_borrowToken].isListed, "Borrow market not listed");
        require(markets[_collateralToken].isListed, "Collateral market not listed");

        accrueInterest(_borrowToken);
        accrueInterest(_collateralToken);

        require(isLiquidatable(_borrower), "Borrower not liquidatable");

        uint256 currentBorrowBalance = getCurrentBorrowBalance(_borrower, _borrowToken);
        require(currentBorrowBalance > 0, "No borrow balance");

        // Max liquidation is 50% of the borrow balance (close factor)
        uint256 maxRepay = (currentBorrowBalance * 5000) / BPS_DENOMINATOR;
        uint256 actualRepay = _repayAmount > maxRepay ? maxRepay : _repayAmount;
        require(actualRepay > 0, "Repay amount too small");

        // Calculate collateral to seize
        uint256 repayValueInBase = getTokenValue(_borrowToken, actualRepay);
        uint256 collateralPrice = getPrice(_collateralToken);
        require(collateralPrice > 0, "Invalid collateral price");

        uint256 liquidationBonus = markets[_collateralToken].liquidationBonusBps;
        uint256 seizeAmount = (repayValueInBase * PRICE_PRECISION * (BPS_DENOMINATOR + liquidationBonus)) / (collateralPrice * BPS_DENOMINATOR);

        // Ensure enough collateral
        uint256 borrowerCollateral = userDeposits[_borrower][_collateralToken].amount;
        require(borrowerCollateral > 0, "No collateral to seize");

        if (seizeAmount > borrowerCollateral) {
            seizeAmount = borrowerCollateral;
            // Recalculate actual repay based on available collateral
            uint256 seizeValue = getTokenValue(_collateralToken, seizeAmount);
            actualRepay = (seizeValue * BPS_DENOMINATOR * PRICE_PRECISION) / ((BPS_DENOMINATOR + liquidationBonus) * getPrice(_borrowToken));
        }

        // Transfer repayment from liquidator
        IERC20(_borrowToken).safeTransferFrom(msg.sender, address(this), actualRepay);

        // Update borrower's borrow
        Market storage borrowMarket = markets[_borrowToken];
        UserBorrow storage borrowerBorrow = userBorrows[_borrower][_borrowToken];
        uint256 newBorrowBalance = currentBorrowBalance - actualRepay;

        if (newBorrowBalance == 0) {
            borrowerBorrow.principal = 0;
            borrowerBorrow.borrowIndex = 0;
            _removeBorrowToken(_borrower, _borrowToken);
        } else {
            borrowerBorrow.principal = newBorrowBalance;
            borrowerBorrow.borrowIndex = borrowMarket.borrowIndex;
        }

        borrowMarket.totalBorrows = borrowMarket.totalBorrows > actualRepay ? borrowMarket.totalBorrows - actualRepay : 0;

        // Update borrower's collateral
        Market storage collateralMarket = markets[_collateralToken];
        userDeposits[_borrower][_collateralToken].amount -= seizeAmount;
        collateralMarket.totalDeposits -= seizeAmount;

        if (userDeposits[_borrower][_collateralToken].amount == 0) {
            _removeCollateralToken(_borrower, _collateralToken);
        }

        // Transfer seized collateral to liquidator
        IERC20(_collateralToken).safeTransfer(msg.sender, seizeAmount);

        emit Liquidation(msg.sender, _borrower, _borrowToken, _collateralToken, actualRepay, seizeAmount);
    }

    // --- View Functions ---

    function getMarketInfo(address _token) external view returns (
        bool isListed,
        uint256 collateralFactorBps,
        uint256 liquidationThresholdBps,
        uint256 totalDeposits,
        uint256 totalBorrows,
        uint256 utilizationRate,
        uint256 borrowIndex
    ) {
        Market storage market = markets[_token];
        isListed = market.isListed;
        collateralFactorBps = market.collateralFactorBps;
        liquidationThresholdBps = market.liquidationThresholdBps;
        totalDeposits = market.totalDeposits;
        totalBorrows = market.totalBorrows;
        borrowIndex = market.borrowIndex;

        if (market.totalDeposits > 0) {
            utilizationRate = (market.totalBorrows * BPS_DENOMINATOR) / market.totalDeposits;
        }
    }

    function getUserPosition(address _user) external view returns (
        uint256 totalCollateralValue,
        uint256 totalBorrowValue,
        uint256 healthFactor,
        bool liquidatable
    ) {
        totalCollateralValue = getTotalCollateralValueForLiquidation(_user);
        totalBorrowValue = getTotalBorrowValue(_user);
        healthFactor = getHealthFactor(_user);
        liquidatable = isLiquidatable(_user);
    }

    function getUserCollateralTokens(address _user) external view returns (address[] memory) {
        return userCollateralTokens[_user];
    }

    function getUserBorrowTokens(address _user) external view returns (address[] memory) {
        return userBorrowTokens[_user];
    }

    function getMarketList() external view returns (address[] memory) {
        return marketList;
    }

    // --- Internal Helpers ---

    function _removeCollateralToken(address _user, address _token) internal {
        userHasCollateral[_user][_token] = false;
        address[] storage tokens = userCollateralTokens[_user];
        for (uint256 i = 0; i < tokens.length; i++) {
            if (tokens[i] == _token) {
                tokens[i] = tokens[tokens.length - 1];
                tokens.pop();
                break;
            }
        }
    }

    function _removeBorrowToken(address _user, address _token) internal {
        userHasBorrow[_user][_token] = false;
        address[] storage tokens = userBorrowTokens[_user];
        for (uint256 i = 0; i < tokens.length; i++) {
            if (tokens[i] == _token) {
                tokens[i] = tokens[tokens.length - 1];
                tokens.pop();
                break;
            }
        }
    }

    // --- Emergency Functions ---

    function withdrawReserves(address _token, uint256 _amount, address _to) external onlyOwner {
        Market storage market = markets[_token];
        require(_amount <= market.totalReserves, "Exceeds reserves");
        market.totalReserves -= _amount;
        IERC20(_token).safeTransfer(_to, _amount);
    }

    function pause() external onlyOwner {
        // In production, implement Pausable from OpenZeppelin
    }
}