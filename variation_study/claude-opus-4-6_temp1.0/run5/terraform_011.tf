# Generated by anthropic (claude-opus-4-6)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

data "aws_caller_identity" "current" {}
data "aws_region" "current" {}

variable "role_name" {
  description = "Name of the CI/CD IAM role"
  type        = string
  default     = "cicd-deployment-role"
}

variable "trusted_account_ids" {
  description = "List of AWS account IDs allowed to assume this role"
  type        = list(string)
  default     = []
}

variable "trusted_service_principals" {
  description = "List of AWS service principals allowed to assume this role"
  type        = list(string)
  default     = []
}

variable "trusted_oidc_providers" {
  description = "Map of OIDC provider ARNs to their conditions for assuming the role (e.g., GitHub Actions, GitLab CI)"
  type = map(object({
    client_id_list = list(string)
    condition_test = string
    condition_variable = string
    condition_values   = list(string)
  }))
  default = {}
}

variable "max_session_duration" {
  description = "Maximum session duration in seconds"
  type        = number
  default     = 3600
}

variable "permissions_boundary_arn" {
  description = "ARN of the permissions boundary policy to attach to the role"
  type        = string
  default     = null
}

variable "additional_policy_arns" {
  description = "List of additional IAM policy ARNs to attach to the role"
  type        = list(string)
  default     = []
}

variable "denied_actions" {
  description = "List of IAM actions to explicitly deny"
  type        = list(string)
  default = [
    "organizations:*",
    "account:*",
  ]
}

variable "require_mfa" {
  description = "Whether to require MFA for assuming the role (only applies to IAM user trust)"
  type        = bool
  default     = false
}

variable "tags" {
  description = "Tags to apply to all resources"
  type        = map(string)
  default     = {}
}

variable "enable_self_manage_policy" {
  description = "Allow the role to manage its own inline policies (useful for Terraform state management)"
  type        = bool
  default     = false
}

variable "resource_prefix" {
  description = "Prefix for resources this role can manage. Use * for unrestricted."
  type        = string
  default     = "*"
}

locals {
  account_id = data.aws_caller_identity.current.account_id
  region     = data.aws_region.current.name

  default_tags = merge(
    {
      ManagedBy = "terraform"
      Purpose   = "cicd-deployment"
    },
    var.tags
  )

  trusted_account_principals = [
    for account_id in var.trusted_account_ids : "arn:aws:iam::${account_id}:root"
  ]

  trusted_service_principals = var.trusted_service_principals
}

data "aws_iam_policy_document" "assume_role" {
  # Trust policy for IAM principals (cross-account or same-account)
  dynamic "statement" {
    for_each = length(local.trusted_account_principals) > 0 ? [1] : []
    content {
      sid     = "AllowAssumeRoleFromTrustedAccounts"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      principals {
        type        = "AWS"
        identifiers = local.trusted_account_principals
      }

      dynamic "condition" {
        for_each = var.require_mfa ? [1] : []
        content {
          test     = "Bool"
          variable = "aws:MultiFactorAuthPresent"
          values   = ["true"]
        }
      }
    }
  }

  # Trust policy for AWS service principals
  dynamic "statement" {
    for_each = length(local.trusted_service_principals) > 0 ? [1] : []
    content {
      sid     = "AllowAssumeRoleFromServices"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      principals {
        type        = "Service"
        identifiers = local.trusted_service_principals
      }
    }
  }

  # Trust policy for OIDC providers (GitHub Actions, GitLab CI, etc.)
  dynamic "statement" {
    for_each = var.trusted_oidc_providers
    content {
      sid     = "AllowAssumeRoleWithWebIdentity${replace(title(statement.key), "/[^a-zA-Z0-9]/", "")}"
      effect  = "Allow"
      actions = ["sts:AssumeRoleWithWebIdentity"]

      principals {
        type        = "Federated"
        identifiers = [statement.key]
      }

      condition {
        test     = "StringEquals"
        variable = "${replace(statement.key, "/^arn:aws:iam::\\d+:oidc-provider\\//", "")}:aud"
        values   = statement.value.client_id_list
      }

      condition {
        test     = statement.value.condition_test
        variable = "${replace(statement.key, "/^arn:aws:iam::\\d+:oidc-provider\\//", "")}:sub"
        values   = statement.value.condition_values
      }
    }
  }
}

resource "aws_iam_role" "cicd" {
  name                 = var.role_name
  assume_role_policy   = data.aws_iam_policy_document.assume_role.json
  max_session_duration = var.max_session_duration
  permissions_boundary = var.permissions_boundary_arn
  tags                 = local.default_tags
}

# Core deployment permissions - EC2
data "aws_iam_policy_document" "ec2_permissions" {
  statement {
    sid    = "EC2FullManagement"
    effect = "Allow"
    actions = [
      "ec2:*",
      "elasticloadbalancing:*",
      "autoscaling:*",
    ]
    resources = ["*"]
  }
}

resource "aws_iam_policy" "ec2_permissions" {
  name   = "${var.role_name}-ec2"
  policy = data.aws_iam_policy_document.ec2_permissions.json
  tags   = local.default_tags
}

resource "aws_iam_role_policy_attachment" "ec2_permissions" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.ec2_permissions.arn
}

# Core deployment permissions - S3
data "aws_iam_policy_document" "s3_permissions" {
  statement {
    sid    = "S3FullManagement"
    effect = "Allow"
    actions = [
      "s3:*",
    ]
    resources = ["*"]
  }
}

resource "aws_iam_policy" "s3_permissions" {
  name   = "${var.role_name}-s3"
  policy = data.aws_iam_policy_document.s3_permissions.json
  tags   = local.default_tags
}

resource "aws_iam_role_policy_attachment" "s3_permissions" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.s3_permissions.arn
}

# Core deployment permissions - RDS
data "aws_iam_policy_document" "rds_permissions" {
  statement {
    sid    = "RDSFullManagement"
    effect = "Allow"
    actions = [
      "rds:*",
      "rds-data:*",
    ]
    resources = ["*"]
  }
}

resource "aws_iam_policy" "rds_permissions" {
  name   = "${var.role_name}-rds"
  policy = data.aws_iam_policy_document.rds_permissions.json
  tags   = local.default_tags
}

resource "aws_iam_role_policy_attachment" "rds_permissions" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.rds_permissions.arn
}

# Core deployment permissions - Lambda and Serverless
data "aws_iam_policy_document" "serverless_permissions" {
  statement {
    sid    = "LambdaFullManagement"
    effect = "Allow"
    actions = [
      "lambda:*",
      "apigateway:*",
      "events:*",
      "scheduler:*",
      "sqs:*",
      "sns:*",
      "states:*",
    ]
    resources = ["*"]
  }
}

resource "aws_iam_policy" "serverless_permissions" {
  name   = "${var.role_name}-serverless"
  policy = data.aws_iam_policy_document.serverless_permissions.json
  tags   = local.default_tags
}

resource "aws_iam_role_policy_attachment" "serverless_permissions" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.serverless_permissions.arn
}

# IAM management (for creating roles, policies for deployed services)
data "aws_iam_policy_document" "iam_permissions" {
  statement {
    sid    = "IAMManagement"
    effect = "Allow"
    actions = [
      "iam:CreateRole",
      "iam:DeleteRole",
      "iam:GetRole",
      "iam:UpdateRole",
      "iam:TagRole",
      "iam:UntagRole",
      "iam:ListRoleTags",
      "iam:PassRole",
      "iam:AttachRolePolicy",
      "iam:DetachRolePolicy",
      "iam:PutRolePolicy",
      "iam:DeleteRolePolicy",
      "iam:GetRolePolicy",
      "iam:ListRolePolicies",
      "iam:ListAttachedRolePolicies",
      "iam:ListInstanceProfilesForRole",
      "iam:CreatePolicy",
      "iam:DeletePolicy",
      "iam:GetPolicy",
      "iam:GetPolicyVersion",
      "iam:ListPolicyVersions",
      "iam:CreatePolicyVersion",
      "iam:DeletePolicyVersion",
      "iam:TagPolicy",
      "iam:UntagPolicy",
      "iam:CreateInstanceProfile",
      "iam:DeleteInstanceProfile",
      "iam:GetInstanceProfile",
      "iam:AddRoleToInstanceProfile",
      "iam:RemoveRoleFromInstanceProfile",
      "iam:ListInstanceProfiles",
      "iam:CreateServiceLinkedRole",
      "iam:DeleteServiceLinkedRole",
      "iam:GetServiceLinkedRoleDeletionStatus",
      "iam:CreateOpenIDConnectProvider",
      "iam:DeleteOpenIDConnectProvider",
      "iam:GetOpenIDConnectProvider",
      "iam:TagOpenIDConnectProvider",
      "iam:UpdateOpenIDConnectProviderThumbprint",
      "iam:AddClientIDToOpenIDConnectProvider",
      "iam:RemoveClientIDFromOpenIDConnectProvider",
    ]
    resources = ["*"]
  }
}

resource "aws_iam_policy" "iam_permissions" {
  name   = "${var.role_name}-iam"
  policy = data.aws_iam_policy_document.iam_permissions.json
  tags   = local.default_tags
}

resource "aws_iam_role_policy_attachment" "iam_permissions" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.iam_permissions.arn
}

# Networking and infrastructure
data "aws_iam_policy_document" "networking_permissions" {
  statement {
    sid    = "NetworkingManagement"
    effect = "Allow"
    actions = [
      "route53:*",
      "route53domains:*",
      "route53resolver:*",
      "cloudfront:*",
      "acm:*",
      "waf:*",
      "wafv2:*",
      "waf-regional:*",
    ]
    resources = ["*"]
  }
}

resource "aws_iam_policy" "networking_permissions" {
  name   = "${var.role_name}-networking"
  policy = data.aws_iam_policy_document.networking_permissions.json
  tags   = local.default_tags
}

resource "aws_iam_role_policy_attachment" "networking_permissions" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.networking_permissions.arn
}

# Monitoring, logging, and observability
data "aws_iam_policy_document" "monitoring_permissions" {
  statement {
    sid    = "MonitoringAndLogging"
    effect = "Allow"
    actions = [
      "cloudwatch:*",
      "logs:*",
      "cloudtrail:*",
      "xray:*",
      "application-autoscaling:*",
    ]
    resources = ["*"]
  }
}

resource "aws_iam_policy" "monitoring_permissions" {
  name   = "${var.role_name}-monitoring"
  policy = data.aws_iam_policy_document.monitoring_permissions.json
  tags   = local.default_tags
}

resource "aws_iam_role_policy_attachment" "monitoring_permissions" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.monitoring_permissions.arn
}

# Additional services commonly needed for infrastructure deployment
data "aws_iam_policy_document" "additional_services" {
  statement {
    sid    = "AdditionalServicesManagement"
    effect = "Allow"
    actions = [
      "dynamodb:*",
      "elasticache:*",
      "es:*",
      "opensearch:*",
      "ecs:*",
      "ecr:*",
      "eks:*",
      "codebuild:*",
      "codepipeline:*",
      "codecommit:*",
      "codedeploy:*",
      "secretsmanager:*",
      "ssm:*",
      "kms:*",
      "kinesis:*",
      "firehose:*",
      "cognito-idp:*",
      "cognito-identity:*",
      "ses:*",
      "cloudformation:*",
      "servicediscovery:*",
      "tag:*",
      "resource-groups:*",
      "backup:*",
      "transfer:*",
      "glue:*",
      "athena:*",
      "redshift:*",
      "elasticmapreduce:*",
      "efs:*",
      "fsx:*",
    ]
    resources = ["*"]
  }
}

resource "aws_iam_policy" "additional_services" {
  name   = "${var.role_name}-additional-services"
  policy = data.aws_iam_policy_document.additional_services.json
  tags   = local.default_tags
}

resource "aws_iam_role_policy_attachment" "additional_services" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.additional_services.arn
}

# Explicit deny policy for guardrails
data "aws_iam_policy_document" "deny_guardrails" {
  statement {
    sid       = "DenyDangerousActions"
    effect    = "Deny"
    actions   = var.denied_actions
    resources = ["*"]
  }

  # Prevent the CI/CD role from modifying its own trust policy or deleting itself
  statement {
    sid    = "DenyModifySelfRole"
    effect = "Deny"
    actions = [
      "iam:UpdateAssumeRolePolicy",
      "iam:DeleteRole",
    ]
    resources = [aws_iam_role.cicd.arn]
  }

  # Prevent deleting CloudTrail logs
  statement {
    sid    = "DenyDeleteCloudTrail"
    effect = "Deny"
    actions = [
      "cloudtrail:DeleteTrail",
      "cloudtrail:StopLogging",
    ]
    resources = ["*"]
  }
}

resource "aws_iam_policy" "deny_guardrails" {
  name   = "${var.role_name}-deny-guardrails"
  policy = data.aws_iam_policy_document.deny_guardrails.json
  tags   = local.default_tags
}

resource "aws_iam_role_policy_attachment" "deny_guardrails" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.deny_guardrails.arn
}

# Attach any additional custom policy ARNs
resource "aws_iam_role_policy_attachment" "additional_policies" {
  for_each   = toset(var.additional_policy_arns)
  role       = aws_iam_role.cicd.name
  policy_arn = each.value
}

# Optional: Self-manage policy for Terraform state lock tables, etc.
data "aws_iam_policy_document" "self_manage" {
  count = var.enable_self_manage_policy ? 1 : 0

  statement {
    sid    = "AllowSelfManageInlinePolicies"
    effect = "Allow"
    actions = [
      "iam:PutRolePolicy",
      "iam:GetRolePolicy",
      "iam:DeleteRolePolicy",
    ]
    resources = [aws_iam_role.cicd.arn]
  }
}

resource "aws_iam_policy" "self_manage" {
  count  = var.enable_self_manage_policy ? 1 : 0
  name   = "${var.role_name}-self-manage"
  policy = data.aws_iam_policy_document.self_manage[0].json
  tags   = local.default_tags
}

resource "aws_iam_role_policy_attachment" "self_manage" {
  count      = var.enable_self_manage_policy ? 1 : 0
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.self_manage[0].arn
}

# Outputs
output "role_arn" {
  description = "ARN of the CI/CD IAM role"
  value       = aws_iam_role.cicd.arn
}

output "role_name" {
  description = "Name of the CI/CD IAM role"
  value       = aws_iam_role.cicd.name
}

output "role_id" {
  description = "Unique ID of the CI/CD IAM role"
  value       = aws_iam_role.cicd.unique_id
}

output "policy_arns" {
  description = "Map of all managed policy ARNs attached to the role"
  value = {
    ec2               = aws_iam_policy.ec2_permissions.arn
    s3                = aws_iam_policy.s3_permissions.arn
    rds               = aws_iam_policy.rds_permissions.arn
    serverless        = aws_iam_policy.serverless_permissions.arn
    iam               = aws_iam_policy.iam_permissions.arn
    networking        = aws_iam_policy.networking_permissions.arn
    monitoring        = aws_iam_policy.monitoring_permissions.arn
    additional        = aws_iam_policy.additional_services.arn
    deny_guardrails   = aws_iam_policy.deny_guardrails.arn
  }
}