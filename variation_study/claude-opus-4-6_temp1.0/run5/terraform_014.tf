# Generated by anthropic (claude-opus-4-6)
# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.
# Category: cloud_network_security

variable "vpc_id" {
  description = "The VPC ID where the security group will be created"
  type        = string
}

variable "environment" {
  description = "Environment name (e.g., dev, staging, production)"
  type        = string
  default     = "dev"
}

variable "application_name" {
  description = "Name of the web application"
  type        = string
  default     = "web-app"
}

variable "additional_ingress_rules" {
  description = "Additional ingress rules to add to the security group"
  type = list(object({
    from_port   = number
    to_port     = number
    protocol    = string
    cidr_blocks = list(string)
    description = string
  }))
  default = []
}

variable "tags" {
  description = "Additional tags to apply to resources"
  type        = map(string)
  default     = {}
}

resource "aws_security_group" "web_app" {
  name        = "${var.application_name}-${var.environment}-sg"
  description = "Security group for ${var.application_name} web application in ${var.environment}"
  vpc_id      = var.vpc_id

  tags = merge(
    {
      Name        = "${var.application_name}-${var.environment}-sg"
      Environment = var.environment
      Application = var.application_name
      ManagedBy   = "terraform"
    },
    var.tags
  )
}

resource "aws_vpc_security_group_ingress_rule" "http" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTP traffic from anywhere"
  from_port         = 80
  to_port           = 80
  ip_protocol       = "tcp"
  cidr_ipv4         = "0.0.0.0/0"

  tags = {
    Name = "${var.application_name}-${var.environment}-http"
  }
}

resource "aws_vpc_security_group_ingress_rule" "http_ipv6" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTP traffic from anywhere (IPv6)"
  from_port         = 80
  to_port           = 80
  ip_protocol       = "tcp"
  cidr_ipv6         = "::/0"

  tags = {
    Name = "${var.application_name}-${var.environment}-http-ipv6"
  }
}

resource "aws_vpc_security_group_ingress_rule" "https" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTPS traffic from anywhere"
  from_port         = 443
  to_port           = 443
  ip_protocol       = "tcp"
  cidr_ipv4         = "0.0.0.0/0"

  tags = {
    Name = "${var.application_name}-${var.environment}-https"
  }
}

resource "aws_vpc_security_group_ingress_rule" "https_ipv6" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTPS traffic from anywhere (IPv6)"
  from_port         = 443
  to_port           = 443
  ip_protocol       = "tcp"
  cidr_ipv6         = "::/0"

  tags = {
    Name = "${var.application_name}-${var.environment}-https-ipv6"
  }
}

resource "aws_vpc_security_group_ingress_rule" "additional" {
  count = length(var.additional_ingress_rules)

  security_group_id = aws_security_group.web_app.id
  description       = var.additional_ingress_rules[count.index].description
  from_port         = var.additional_ingress_rules[count.index].from_port
  to_port           = var.additional_ingress_rules[count.index].to_port
  ip_protocol       = var.additional_ingress_rules[count.index].protocol
  cidr_ipv4         = var.additional_ingress_rules[count.index].cidr_blocks[0]

  tags = {
    Name = "${var.application_name}-${var.environment}-additional-${count.index}"
  }
}

resource "aws_vpc_security_group_egress_rule" "all_traffic" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow all outbound traffic for external API and service access"
  ip_protocol       = "-1"
  cidr_ipv4         = "0.0.0.0/0"

  tags = {
    Name = "${var.application_name}-${var.environment}-egress-all"
  }
}

resource "aws_vpc_security_group_egress_rule" "all_traffic_ipv6" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow all outbound traffic for external API and service access (IPv6)"
  ip_protocol       = "-1"
  cidr_ipv6         = "::/0"

  tags = {
    Name = "${var.application_name}-${var.environment}-egress-all-ipv6"
  }
}

resource "aws_security_group" "microservices_internal" {
  name        = "${var.application_name}-${var.environment}-internal-sg"
  description = "Security group for internal microservices communication in ${var.environment}"
  vpc_id      = var.vpc_id

  tags = merge(
    {
      Name        = "${var.application_name}-${var.environment}-internal-sg"
      Environment = var.environment
      Application = var.application_name
      ManagedBy   = "terraform"
    },
    var.tags
  )
}

resource "aws_vpc_security_group_ingress_rule" "internal_from_web" {
  security_group_id            = aws_security_group.microservices_internal.id
  description                  = "Allow all traffic from web application security group"
  ip_protocol                  = "-1"
  referenced_security_group_id = aws_security_group.web_app.id

  tags = {
    Name = "${var.application_name}-${var.environment}-internal-from-web"
  }
}

resource "aws_vpc_security_group_ingress_rule" "internal_self" {
  security_group_id            = aws_security_group.microservices_internal.id
  description                  = "Allow all traffic between microservices"
  ip_protocol                  = "-1"
  referenced_security_group_id = aws_security_group.microservices_internal.id

  tags = {
    Name = "${var.application_name}-${var.environment}-internal-self"
  }
}

resource "aws_vpc_security_group_egress_rule" "internal_all_traffic" {
  security_group_id = aws_security_group.microservices_internal.id
  description       = "Allow all outbound traffic for microservices external API access"
  ip_protocol       = "-1"
  cidr_ipv4         = "0.0.0.0/0"

  tags = {
    Name = "${var.application_name}-${var.environment}-internal-egress-all"
  }
}

resource "aws_vpc_security_group_egress_rule" "internal_all_traffic_ipv6" {
  security_group_id = aws_security_group.microservices_internal.id
  description       = "Allow all outbound traffic for microservices external API access (IPv6)"
  ip_protocol       = "-1"
  cidr_ipv6         = "::/0"

  tags = {
    Name = "${var.application_name}-${var.environment}-internal-egress-all-ipv6"
  }
}

output "web_app_security_group_id" {
  description = "The ID of the web application security group"
  value       = aws_security_group.web_app.id
}

output "web_app_security_group_arn" {
  description = "The ARN of the web application security group"
  value       = aws_security_group.web_app.arn
}

output "web_app_security_group_name" {
  description = "The name of the web application security group"
  value       = aws_security_group.web_app.name
}

output "microservices_internal_security_group_id" {
  description = "The ID of the internal microservices security group"
  value       = aws_security_group.microservices_internal.id
}

output "microservices_internal_security_group_arn" {
  description = "The ARN of the internal microservices security group"
  value       = aws_security_group.microservices_internal.arn
}

output "microservices_internal_security_group_name" {
  description = "The name of the internal microservices security group"
  value       = aws_security_group.microservices_internal.name
}