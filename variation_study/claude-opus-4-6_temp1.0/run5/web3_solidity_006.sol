pragma solidity ^0.8.20;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/token/ERC20/utils/SafeERC20.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/ReentrancyGuard.sol";

contract BatchProcessor is Ownable, ReentrancyGuard {
    using SafeERC20 for IERC20;

    // Internal balance tracking for users
    mapping(address => mapping(address => uint256)) public balances; // token => user => balance

    // ETH balances
    mapping(address => uint256) public ethBalances;

    event BatchAirdropCompleted(address indexed token, uint256 recipientCount, uint256 totalAmount);
    event BatchPaymentCompleted(address indexed token, uint256 recipientCount, uint256 totalAmount);
    event BatchETHPaymentCompleted(uint256 recipientCount, uint256 totalAmount);
    event BalancesUpdated(address indexed token, uint256 recipientCount);
    event BalanceWithdrawn(address indexed token, address indexed user, uint256 amount);
    event ETHBalanceWithdrawn(address indexed user, uint256 amount);

    // Maximum batch size to prevent out-of-gas
    uint256 public maxBatchSize;

    constructor(uint256 _maxBatchSize) Ownable(msg.sender) {
        require(_maxBatchSize > 0 && _maxBatchSize <= 500, "Invalid max batch size");
        maxBatchSize = _maxBatchSize;
    }

    function setMaxBatchSize(uint256 _maxBatchSize) external onlyOwner {
        require(_maxBatchSize > 0 && _maxBatchSize <= 500, "Invalid max batch size");
        maxBatchSize = _maxBatchSize;
    }

    /// @notice Airdrop ERC20 tokens to multiple recipients with the same amount
    /// @param token The ERC20 token address
    /// @param recipients Array of recipient addresses
    /// @param amount Amount to send to each recipient
    function airdropEqualAmount(
        address token,
        address[] calldata recipients,
        uint256 amount
    ) external nonReentrant {
        require(recipients.length > 0, "Empty recipients");
        require(recipients.length <= maxBatchSize, "Batch size exceeds limit");
        require(amount > 0, "Amount must be > 0");
        require(token != address(0), "Invalid token address");

        uint256 totalAmount = amount * recipients.length;
        IERC20 tokenContract = IERC20(token);

        // Transfer total amount from sender to this contract first
        tokenContract.safeTransferFrom(msg.sender, address(this), totalAmount);

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient");
            tokenContract.safeTransfer(recipients[i], amount);
        }

        emit BatchAirdropCompleted(token, recipients.length, totalAmount);
    }

    /// @notice Airdrop ERC20 tokens to multiple recipients with varying amounts
    /// @param token The ERC20 token address
    /// @param recipients Array of recipient addresses
    /// @param amounts Array of amounts corresponding to each recipient
    function airdropVaryingAmounts(
        address token,
        address[] calldata recipients,
        uint256[] calldata amounts
    ) external nonReentrant {
        require(recipients.length > 0, "Empty recipients");
        require(recipients.length == amounts.length, "Array length mismatch");
        require(recipients.length <= maxBatchSize, "Batch size exceeds limit");
        require(token != address(0), "Invalid token address");

        uint256 totalAmount = 0;
        for (uint256 i = 0; i < amounts.length; i++) {
            require(amounts[i] > 0, "Amount must be > 0");
            totalAmount += amounts[i];
        }

        IERC20 tokenContract = IERC20(token);
        tokenContract.safeTransferFrom(msg.sender, address(this), totalAmount);

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient");
            tokenContract.safeTransfer(recipients[i], amounts[i]);
        }

        emit BatchPaymentCompleted(token, recipients.length, totalAmount);
    }

    /// @notice Batch send ETH to multiple recipients with varying amounts
    /// @param recipients Array of recipient addresses
    /// @param amounts Array of ETH amounts (in wei) corresponding to each recipient
    function batchSendETH(
        address payable[] calldata recipients,
        uint256[] calldata amounts
    ) external payable nonReentrant {
        require(recipients.length > 0, "Empty recipients");
        require(recipients.length == amounts.length, "Array length mismatch");
        require(recipients.length <= maxBatchSize, "Batch size exceeds limit");

        uint256 totalAmount = 0;
        for (uint256 i = 0; i < amounts.length; i++) {
            require(amounts[i] > 0, "Amount must be > 0");
            totalAmount += amounts[i];
        }
        require(msg.value >= totalAmount, "Insufficient ETH sent");

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient");
            (bool success, ) = recipients[i].call{value: amounts[i]}("");
            require(success, "ETH transfer failed");
        }

        // Refund excess ETH
        uint256 excess = msg.value - totalAmount;
        if (excess > 0) {
            (bool refundSuccess, ) = payable(msg.sender).call{value: excess}("");
            require(refundSuccess, "Refund failed");
        }

        emit BatchETHPaymentCompleted(recipients.length, totalAmount);
    }

    /// @notice Batch send equal ETH to multiple recipients
    /// @param recipients Array of recipient addresses
    /// @param amount Amount of ETH (in wei) to send to each recipient
    function batchSendEqualETH(
        address payable[] calldata recipients,
        uint256 amount
    ) external payable nonReentrant {
        require(recipients.length > 0, "Empty recipients");
        require(recipients.length <= maxBatchSize, "Batch size exceeds limit");
        require(amount > 0, "Amount must be > 0");

        uint256 totalAmount = amount * recipients.length;
        require(msg.value >= totalAmount, "Insufficient ETH sent");

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient");
            (bool success, ) = recipients[i].call{value: amount}("");
            require(success, "ETH transfer failed");
        }

        // Refund excess ETH
        uint256 excess = msg.value - totalAmount;
        if (excess > 0) {
            (bool refundSuccess, ) = payable(msg.sender).call{value: excess}("");
            require(refundSuccess, "Refund failed");
        }

        emit BatchETHPaymentCompleted(recipients.length, totalAmount);
    }

    /// @notice Update internal token balances for multiple users (owner only)
    /// @param token The token address for balance tracking
    /// @param users Array of user addresses
    /// @param amounts Array of amounts to credit
    function batchUpdateBalances(
        address token,
        address[] calldata users,
        uint256[] calldata amounts
    ) external onlyOwner {
        require(users.length > 0, "Empty users");
        require(users.length == amounts.length, "Array length mismatch");
        require(users.length <= maxBatchSize, "Batch size exceeds limit");
        require(token != address(0), "Invalid token address");

        uint256 totalAmount = 0;
        for (uint256 i = 0; i < users.length; i++) {
            require(users[i] != address(0), "Invalid user address");
            require(amounts[i] > 0, "Amount must be > 0");
            balances[token][users[i]] += amounts[i];
            totalAmount += amounts[i];
        }

        // Ensure the contract holds enough tokens
        require(
            IERC20(token).balanceOf(address(this)) >= totalAmount,
            "Insufficient token balance in contract"
        );

        emit BalancesUpdated(token, users.length);
    }

    /// @notice Update internal ETH balances for multiple users (owner only, must send ETH)
    /// @param users Array of user addresses
    /// @param amounts Array of ETH amounts to credit
    function batchUpdateETHBalances(
        address[] calldata users,
        uint256[] calldata amounts
    ) external payable onlyOwner {
        require(users.length > 0, "Empty users");
        require(users.length == amounts.length, "Array length mismatch");
        require(users.length <= maxBatchSize, "Batch size exceeds limit");

        uint256 totalAmount = 0;
        for (uint256 i = 0; i < users.length; i++) {
            require(users[i] != address(0), "Invalid user address");
            require(amounts[i] > 0, "Amount must be > 0");
            ethBalances[users[i]] += amounts[i];
            totalAmount += amounts[i];
        }

        require(msg.value >= totalAmount, "Insufficient ETH sent");

        // Refund excess
        uint256 excess = msg.value - totalAmount;
        if (excess > 0) {
            (bool success, ) = payable(msg.sender).call{value: excess}("");
            require(success, "Refund failed");
        }
    }

    /// @notice Withdraw credited token balance
    /// @param token The token address
    function withdrawTokenBalance(address token) external nonReentrant {
        uint256 amount = balances[token][msg.sender];
        require(amount > 0, "No balance to withdraw");

        balances[token][msg.sender] = 0;
        IERC20(token).safeTransfer(msg.sender, amount);

        emit BalanceWithdrawn(token, msg.sender, amount);
    }

    /// @notice Withdraw credited ETH balance
    function withdrawETHBalance() external nonReentrant {
        uint256 amount = ethBalances[msg.sender];
        require(amount > 0, "No ETH balance to withdraw");

        ethBalances[msg.sender] = 0;
        (bool success, ) = payable(msg.sender).call{value: amount}("");
        require(success, "ETH withdrawal failed");

        emit ETHBalanceWithdrawn(msg.sender, amount);
    }

    /// @notice Fund the contract with ERC20 tokens (for balance-based distribution)
    /// @param token Token address
    /// @param amount Amount to deposit
    function fundTokens(address token, uint256 amount) external {
        require(token != address(0), "Invalid token");
        require(amount > 0, "Amount must be > 0");
        IERC20(token).safeTransferFrom(msg.sender, address(this), amount);
    }

    /// @notice Emergency withdraw tokens stuck in contract (owner only)
    /// @param token Token address
    /// @param amount Amount to withdraw
    function emergencyWithdrawTokens(address token, uint256 amount) external onlyOwner {
        IERC20(token).safeTransfer(msg.sender, amount);
    }

    /// @notice Emergency withdraw ETH stuck in contract (owner only)
    /// @param amount Amount to withdraw
    function emergencyWithdrawETH(uint256 amount) external onlyOwner {
        require(address(this).balance >= amount, "Insufficient balance");
        (bool success, ) = payable(msg.sender).call{value: amount}("");
        require(success, "ETH transfer failed");
    }

    /// @notice Accept direct ETH transfers
    receive() external payable {}
}