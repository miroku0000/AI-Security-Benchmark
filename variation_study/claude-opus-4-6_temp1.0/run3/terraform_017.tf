# -------------------------------------------------------------------
# CloudWatch Alarms - Critical for financial data processing
# NOTE: These are essential day-one alarms for a payment system.
# Monitoring cannot be deferred for financial workloads - failures,
# errors, and throttles must be detected immediately.
# -------------------------------------------------------------------

# Error alarms for each function
resource "aws_cloudwatch_metric_alarm" "payment_validation_errors" {
  alarm_name          = "${var.environment}-payment-validation-errors"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 1
  metric_name         = "Errors"
  namespace           = "AWS/Lambda"
  period              = 60
  statistic           = "Sum"
  threshold           = 0
  alarm_description   = "Payment validation Lambda errors detected - immediate investigation required"
  alarm_actions       = [aws_sns_topic.payment_alarms.arn]
  ok_actions          = [aws_sns_topic.payment_alarms.arn]
  treat_missing_data  = "notBreaching"

  dimensions = {
    FunctionName = aws_lambda_function.payment_validation.function_name
  }

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
  }
}

resource "aws_cloudwatch_metric_alarm" "payment_processing_errors" {
  alarm_name          = "${var.environment}-payment-processing-errors"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 1
  metric_name         = "Errors"
  namespace           = "AWS/Lambda"
  period              = 60
  statistic           = "Sum"
  threshold           = 0
  alarm_description   = "Payment processing Lambda errors detected - immediate investigation required"
  alarm_actions       = [aws_sns_topic.payment_alarms.arn]
  ok_actions          = [aws_sns_topic.payment_alarms.arn]
  treat_missing_data  = "notBreaching"

  dimensions = {
    FunctionName = aws_lambda_function.payment_processing.function_name
  }

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
  }
}

resource "aws_cloudwatch_metric_alarm" "payment_settlement_errors" {
  alarm_name          = "${var.environment}-payment-settlement-errors"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 1
  metric_name         = "Errors"
  namespace           = "AWS/Lambda"
  period              = 60
  statistic           = "Sum"
  threshold           = 0
  alarm_description   = "Payment settlement Lambda errors detected - immediate investigation required"
  alarm_actions       = [aws_sns_topic.payment_alarms.arn]
  ok_actions          = [aws_sns_topic.payment_alarms.arn]
  treat_missing_data  = "notBreaching"

  dimensions = {
    FunctionName = aws_lambda_function.payment_settlement.function_name
  }

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
  }
}

# Throttle alarms - critical for payment processing availability
resource "aws_cloudwatch_metric_alarm" "payment_processing_throttles" {
  alarm_name          = "${var.environment}-payment-processing-throttles"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 1
  metric_name         = "Throttles"
  namespace           = "AWS/Lambda"
  period              = 60
  statistic           = "Sum"
  threshold           = 0
  alarm_description   = "Payment processing Lambda throttled - payments may be failing"
  alarm_actions       = [aws_sns_topic.payment_alarms.arn]
  treat_missing_data  = "notBreaching"

  dimensions = {
    FunctionName = aws_lambda_function.payment_processing.function_name
  }

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
  }
}

# Duration alarm - detect processing slowdowns
resource "aws_cloudwatch_metric_alarm" "payment_processing_duration" {
  alarm_name          = "${var.environment}-payment-processing-high-duration"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 3
  metric_name         = "Duration"
  namespace           = "AWS/Lambda"
  period              = 60
  statistic           = "Average"
  threshold           = 45000 # 45 seconds (timeout is 60s)
  alarm_description   = "Payment processing Lambda approaching timeout - degraded performance"
  alarm_actions       = [aws_sns_topic.payment_alarms.arn]
  treat_missing_data  = "notBreaching"

  dimensions = {
    FunctionName = aws_lambda_function.payment_processing.function_name
  }

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
  }
}

# DLQ alarm - detect failed messages
resource "aws_cloudwatch_metric_alarm" "dlq_messages" {
  alarm_name          = "${var.environment}-payment-dlq-messages"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 1
  metric_name         = "ApproximateNumberOfMessagesVisible"
  namespace           = "AWS/SQS"
  period              = 60
  statistic           = "Sum"
  threshold           = 0
  alarm_description   = "Messages in payment DLQ - failed payment processing detected"
  alarm_actions       = [aws_sns_topic.payment_alarms.arn]
  treat_missing_data  = "notBreaching"

  dimensions = {
    QueueName = aws_sqs_queue.payment_dlq.name
  }

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
  }
}

