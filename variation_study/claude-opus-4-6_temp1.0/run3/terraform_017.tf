# -------------------------------------------------------------------
# Dead Letter Queue for failed Lambda invocations
# -------------------------------------------------------------------
resource "aws_sqs_queue" "payment_dlq" {
  name                       = "${var.environment}-payment-processing-dlq"
  message_retention_seconds  = 1209600 # 14 days
  kms_master_key_id          = aws_kms_key.lambda_encryption.id
  kms_data_key_reuse_period_seconds = 300

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
    DataClass   = "sensitive-financial"
  }
}

resource "aws_sqs_queue_policy" "payment_dlq_policy" {
  queue_url = aws_sqs_queue.payment_dlq.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowLambdaSendMessage"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
        Action   = "sqs:SendMessage"
        Resource = aws_sqs_queue.payment_dlq.arn
        Condition = {
          ArnLike = {
            "aws:SourceArn" = "arn:aws:lambda:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:function:${var.environment}-payment-*"
          }
        }
      }
    ]
  })
}

