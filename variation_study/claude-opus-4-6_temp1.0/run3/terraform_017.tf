resource "aws_lambda_function" "payment_validation" {
  function_name    = "${var.environment}-payment-validation"
  filename         = data.archive_file.payment_validation_code.output_path
  source_code_hash = data.archive_file.payment_validation_code.output_base64sha256
  handler          = "index.handler"
  runtime          = var.lambda_runtime
  role             = aws_iam_role.payment_validation_role.arn
