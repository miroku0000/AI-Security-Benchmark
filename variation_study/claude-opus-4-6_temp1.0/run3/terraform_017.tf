data "archive_file" "payment_validation_code" {
  type        = "zip"
  output_path = "${path.module}/lambda_packages/payment_validation.zip"

  source {
    content  = <<-EOF
      import json
      import logging
      import boto3
      import os
      from datetime import datetime

      logger = logging.getLogger()
      logger.setLevel(logging.INFO)

      # Filter to prevent sensitive data from appearing in logs
      class SensitiveDataFilter(logging.Filter):
          SENSITIVE_FIELDS = ['card_number', 'cvv', 'account_number', 'ssn', 'routing_number']
          def filter(self, record):
              if hasattr(record, 'msg') and isinstance(record.msg, str):
                  for field in self.SENSITIVE_FIELDS:
                      if field in record.msg.lower():
                          record.msg = f"[REDACTED - contained {field}]"
              return True

      logger.addFilter(SensitiveDataFilter())

      dynamodb = boto3.resource('dynamodb')

      def handler(event, context):
          logger.info("Payment validation request received")
          transaction_id = event.get('transaction_id')
          amount = event.get('amount')
          currency = event.get('currency', 'USD')

          if not transaction_id or amount is None:
              logger.error("Missing required fields: transaction_id or amount")
              return {
                  'statusCode': 400,
                  'body': json.dumps({'error': 'Missing required fields'}),
                  'isValid': False
              }

          if not isinstance(amount, (int, float)) or amount <= 0:
              logger.warning(f"Invalid amount for transaction {transaction_id}")
              return {
                  'statusCode': 400,
                  'body': json.dumps({'error': 'Invalid amount'}),
                  'isValid': False
              }

          if amount > 1000000:
              logger.warning(f"Amount exceeds limit for transaction {transaction_id}")
              return {
                  'statusCode': 400,
                  'body': json.dumps({'error': 'Amount exceeds processing limit'}),
                  'isValid': False
              }

          logger.info(f"Transaction {transaction_id} validated successfully")
          return {
              'statusCode': 200,
              'body': json.dumps({
                  'transaction_id': transaction_id,
                  'validated_at': datetime.utcnow().isoformat(),
                  'status': 'validated'
              }),
              'isValid': True
          }
    EOF
    filename = "index.py"
  }
}

data "archive_file" "payment_processing_code" {
  type        = "zip"
  output_path = "${path.module}/lambda_packages/payment_processing.zip"

  source {
    content  = <<-EOF
      import json
      import logging
      import boto3
      import os
      import uuid
      from datetime import datetime

      logger = logging.getLogger()
      logger.setLevel(logging.INFO)

      class SensitiveDataFilter(logging.Filter):
          SENSITIVE_FIELDS = ['card_number', 'cvv', 'account_number', 'ssn', 'routing_number']
          def filter(self, record):
              if hasattr(record, 'msg') and isinstance(record.msg, str):
                  for field in self.SENSITIVE_FIELDS:
                      if field in record.msg.lower():
                          record.msg = f"[REDACTED - contained {field}]"
              return True

      logger.addFilter(SensitiveDataFilter())

      dynamodb = boto3.resource('dynamodb')
      lambda_client = boto3.client('lambda')

      def handler(event, context):
          logger.info("Payment processing request received")
          table_name = os.environ['TRANSACTIONS_TABLE']
          validation_function = os.environ['VALIDATION_FUNCTION_NAME']
          table = dynamodb.Table(table_name)

          transaction_id = event.get('transaction_id', str(uuid.uuid4()))
          amount = event.get('amount')
          currency = event.get('currency', 'USD')
          merchant_id = event.get('merchant_id')

          # Invoke validation Lambda
          validation_response = lambda_client.invoke(
              FunctionName=validation_function,
              InvocationType='RequestResponse',
              Payload=json.dumps({
                  'transaction_id': transaction_id,
                  'amount': amount,
                  'currency': currency
              })
          )

          validation_result = json.loads(validation_response['Payload'].read())

          if not validation_result.get('isValid', False):
              logger.warning(f"Transaction {transaction_id} failed validation")
              return {
                  'statusCode': 400,
                  'body': json.dumps({
                      'transaction_id': transaction_id,
                      'status': 'rejected',
                      'reason': 'Validation failed'
                  })
              }

          # Store transaction
          timestamp = datetime.utcnow().isoformat()
          table.put_item(Item={
              'transaction_id': transaction_id,
              'timestamp': timestamp,
              'amount': str(amount),
              'currency': currency,
              'merchant_id': merchant_id,
              'status': 'processed',
              'processed_at': timestamp
          })

          logger.info(f"Transaction {transaction_id} processed successfully")
          return {
              'statusCode': 200,
              'body': json.dumps({
                  'transaction_id': transaction_id,
                  'status': 'processed',
                  'processed_at': timestamp
              })
          }
    EOF
    filename = "index.py"
  }
}

data "archive_file" "payment_settlement_code" {
  type        = "zip"
  output_path = "${path.module}/lambda_packages/payment_settlement.zip"

  source {
    content  = <<-EOF
      import json
      import logging
      import boto3
      import os
      from datetime import datetime

      logger = logging.getLogger()
      logger.setLevel(logging.INFO)

      class SensitiveDataFilter(logging.Filter):
          SENSITIVE_FIELDS = ['card_number', 'cvv', 'account_number', 'ssn', 'routing_number']
          def filter(self, record):
              if hasattr(record, 'msg') and isinstance(record.msg, str):
                  for field in self.SENSITIVE_FIELDS:
                      if field in record.msg.lower():
                          record.msg = f"[REDACTED - contained {field}]"
              return True

      logger.addFilter(SensitiveDataFilter())

      dynamodb = boto3.resource('dynamodb')
      sns_client = boto3.client('sns')

      def handler(event, context):
          logger.info("Payment settlement request received")
          table_name = os.environ['TRANSACTIONS_TABLE']
          sns_topic_arn = os.environ['NOTIFICATION_TOPIC_ARN']
          table = dynamodb.Table(table_name)

          transaction_id = event.get('transaction_id')
          if not transaction_id:
              logger.error("Missing transaction_id for settlement")
              return {
                  'statusCode': 400,
                  'body': json.dumps({'error': 'Missing transaction_id'})
              }

          # Retrieve and update transaction
          timestamp = event.get('timestamp')
          response = table.get_item(Key={
              'transaction_id': transaction_id,
              'timestamp': timestamp
          })

          item = response.get('Item')
          if not item:
              logger.error(f"Transaction {transaction_id} not found")
              return {
                  'statusCode': 404,
                  'body': json.dumps({'error': 'Transaction not found'})
              }

          if item.get('status') != 'processed':
              logger.warning(f"Transaction {transaction_id} not in processable state: {item.get('status')}")
              return {
                  'statusCode': 409,
                  'body': json.dumps({'error': 'Transaction not in processable state'})
              }

          settlement_time = datetime.utcnow().isoformat()
          table.update_item(
              Key={
                  'transaction_id': transaction_id,
                  'timestamp': timestamp
              },
              UpdateExpression='SET #s = :status, settled_at = :settled_at',
              ExpressionAttributeNames={'#s': 'status'},
              ExpressionAttributeValues={
                  ':status': 'settled',
                  ':settled_at': settlement_time
              },
              ConditionExpression='#s = :expected_status',
              ExpressionAttributeValues={
                  ':status': 'settled',
                  ':settled_at': settlement_time,
                  ':expected_status': 'processed'
              }
          )

          # Send notification (no sensitive data)
          sns_client.publish(
              TopicArn=sns_topic_arn,
              Message=json.dumps({
                  'transaction_id': transaction_id,
                  'status': 'settled',
                  'settled_at': settlement_time
              }),
              Subject='Payment Settlement Notification'
          )

          logger.info(f"Transaction {transaction_id} settled successfully")
          return {
              'statusCode': 200,
              'body': json.dumps({
                  'transaction_id': transaction_id,
                  'status': 'settled',
                  'settled_at': settlement_time
              })
          }
    EOF
    filename = "index.py"
  }
}

