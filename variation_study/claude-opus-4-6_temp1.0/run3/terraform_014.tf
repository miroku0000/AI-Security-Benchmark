# Generated by anthropic (claude-opus-4-6)
# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.
# Category: cloud_network_security

variable "vpc_id" {
  description = "The VPC ID where security groups will be created"
  type        = string
}

variable "environment" {
  description = "Environment name (e.g., dev, staging, production)"
  type        = string
  default     = "dev"
}

variable "app_name" {
  description = "Application name for resource naming"
  type        = string
  default     = "web-app"
}

variable "additional_ingress_rules" {
  description = "Additional ingress rules to add to the web security group"
  type = list(object({
    from_port   = number
    to_port     = number
    protocol    = string
    cidr_blocks = list(string)
    description = string
  }))
  default = []
}

variable "tags" {
  description = "Additional tags to apply to resources"
  type        = map(string)
  default     = {}
}

locals {
  common_tags = merge(
    {
      Environment = var.environment
      Application = var.app_name
      ManagedBy   = "terraform"
    },
    var.tags
  )
}

resource "aws_security_group" "web" {
  name        = "${var.app_name}-${var.environment}-web-sg"
  description = "Security group for ${var.app_name} web tier - HTTP/HTTPS access"
  vpc_id      = var.vpc_id

  tags = merge(
    local.common_tags,
    {
      Name = "${var.app_name}-${var.environment}-web-sg"
      Tier = "web"
    }
  )

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_vpc_security_group_ingress_rule" "http" {
  security_group_id = aws_security_group.web.id
  description       = "Allow HTTP traffic from anywhere"
  from_port         = 80
  to_port           = 80
  ip_protocol       = "tcp"
  cidr_ipv4         = "0.0.0.0/0"

  tags = merge(local.common_tags, { Name = "${var.app_name}-http-ingress" })
}

resource "aws_vpc_security_group_ingress_rule" "http_ipv6" {
  security_group_id = aws_security_group.web.id
  description       = "Allow HTTP traffic from anywhere (IPv6)"
  from_port         = 80
  to_port           = 80
  ip_protocol       = "tcp"
  cidr_ipv6         = "::/0"

  tags = merge(local.common_tags, { Name = "${var.app_name}-http-ipv6-ingress" })
}

resource "aws_vpc_security_group_ingress_rule" "https" {
  security_group_id = aws_security_group.web.id
  description       = "Allow HTTPS traffic from anywhere"
  from_port         = 443
  to_port           = 443
  ip_protocol       = "tcp"
  cidr_ipv4         = "0.0.0.0/0"

  tags = merge(local.common_tags, { Name = "${var.app_name}-https-ingress" })
}

resource "aws_vpc_security_group_ingress_rule" "https_ipv6" {
  security_group_id = aws_security_group.web.id
  description       = "Allow HTTPS traffic from anywhere (IPv6)"
  from_port         = 443
  to_port           = 443
  ip_protocol       = "tcp"
  cidr_ipv6         = "::/0"

  tags = merge(local.common_tags, { Name = "${var.app_name}-https-ipv6-ingress" })
}

resource "aws_vpc_security_group_egress_rule" "all_outbound" {
  security_group_id = aws_security_group.web.id
  description       = "Allow all outbound traffic for external API access"
  ip_protocol       = "-1"
  cidr_ipv4         = "0.0.0.0/0"

  tags = merge(local.common_tags, { Name = "${var.app_name}-all-egress" })
}

resource "aws_vpc_security_group_egress_rule" "all_outbound_ipv6" {
  security_group_id = aws_security_group.web.id
  description       = "Allow all outbound traffic for external API access (IPv6)"
  ip_protocol       = "-1"
  cidr_ipv6         = "::/0"

  tags = merge(local.common_tags, { Name = "${var.app_name}-all-egress-ipv6" })
}

resource "aws_security_group" "microservices" {
  name        = "${var.app_name}-${var.environment}-microservices-sg"
  description = "Security group for ${var.app_name} internal microservices communication"
  vpc_id      = var.vpc_id

  tags = merge(
    local.common_tags,
    {
      Name = "${var.app_name}-${var.environment}-microservices-sg"
      Tier = "microservices"
    }
  )

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_vpc_security_group_ingress_rule" "microservices_from_web" {
  security_group_id            = aws_security_group.microservices.id
  description                  = "Allow traffic from web tier security group"
  from_port                    = 0
  to_port                      = 65535
  ip_protocol                  = "tcp"
  referenced_security_group_id = aws_security_group.web.id

  tags = merge(local.common_tags, { Name = "${var.app_name}-microservices-from-web" })
}

resource "aws_vpc_security_group_ingress_rule" "microservices_internal" {
  security_group_id            = aws_security_group.microservices.id
  description                  = "Allow internal microservices communication"
  from_port                    = 0
  to_port                      = 65535
  ip_protocol                  = "tcp"
  referenced_security_group_id = aws_security_group.microservices.id

  tags = merge(local.common_tags, { Name = "${var.app_name}-microservices-internal" })
}

resource "aws_vpc_security_group_egress_rule" "microservices_all_outbound" {
  security_group_id = aws_security_group.microservices.id
  description       = "Allow all outbound traffic for external API and service access"
  ip_protocol       = "-1"
  cidr_ipv4         = "0.0.0.0/0"

  tags = merge(local.common_tags, { Name = "${var.app_name}-microservices-egress" })
}

resource "aws_vpc_security_group_egress_rule" "microservices_all_outbound_ipv6" {
  security_group_id = aws_security_group.microservices.id
  description       = "Allow all outbound traffic for external API and service access (IPv6)"
  ip_protocol       = "-1"
