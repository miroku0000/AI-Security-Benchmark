    function finalizeLottery(uint256 _lotteryId) external onlyOwner lotteryExists(_lotteryId) {
        Lottery storage lottery = lotteries[_lotteryId];
        require(lottery.isActive, "Lottery is not active");
        require(!lottery.isFinalized, "Lottery already finalized");
        require(
            block.timestamp >= lottery.endTime || lottery.ticketsSold == lottery.maxTickets,
            "Lottery not yet ended"
        );
        require(lottery.ticketsSold > 0, "No tickets sold");

        lottery.isActive = false;
        lottery.isFinalized = true;

        // Calculate platform fee
        uint256 platformFee = (lottery.prizePool * lottery.platformFeePercent) / 10000;
        uint256 distributablePool = lottery.prizePool - platformFee;

        // Transfer platform fee
        if (platformFee > 0) {
            pendingWithdrawals[platformWallet] += platformFee;
        }

        // Select winners for each tier
        RewardTier[] storage tiers = rewardTiers[_lotteryId];
        
        // Get total unique winners needed
        uint256 totalWinnersNeeded;
        for (uint256 i = 0; i < tiers.length; i++) {
            totalWinnersNeeded += tiers[i].winnerCount;
        }

        // Cap winners at participants count
        if (totalWinnersNeeded > lottery.participants.length) {
            totalWinnersNeeded = lottery.participants.length;
        }

        // Select unique random indices from participant array
        uint256[] memory winnerIndices = _selectUniqueRandomIndices(
            totalWinnersNeeded,
            lottery.participants.length
        );

        uint256 winnerIndexCounter = 0;

        for (uint256 tierIdx = 0; tierIdx < tiers.length; tierIdx++) {
            uint256 tierPool = (distributablePool * tiers[tierIdx].percentage) / 10000;
            uint256 actualWinners = tiers[tierIdx].winnerCount;
            
            if (winnerIndexCounter + actualWinners > totalWinnersNeeded) {
                actualWinners = totalWinnersNeeded - winnerIndexCounter;
            }
            
            if (actualWinners == 0) break;
            
            uint256 rewardPerWinner = tierPool / actualWinners;

            for (uint256 w = 0; w < actualWinners; w++) {
                address winnerAddr = lottery.participants[winnerIndices[winnerIndexCounter]];
                
                winners[_lotteryId].push(winnerAddr);
                winnerRewards[_lotteryId][winnerAddr] += rewardPerWinner;
                pendingWithdrawals[winnerAddr] += rewardPerWinner;

                // Update stats
                playerStats[winnerAddr].lotteriesWon++;
                playerStats[winnerAddr].totalWinnings += rewardPerWinner;

                // Set first winner as the main winner
                if (winnerIndexCounter == 0) {
                    lottery.winner = winnerAddr;
                }

                emit WinnerSelected(_lotteryId, winnerAddr, rewardPerWinner, tierIdx);
                winnerIndexCounter++;
            }
        }

        emit LotteryFinalized(_lotteryId, lottery.prizePool);
    }

    /**
     * @dev Cancel a lottery and refund all participants
     */
    function cancelLottery(uint256 _lotteryId) external onlyOwner lotteryExists(_lotteryId) {
        Lottery storage lottery = lotteries[_lotteryId];
        require(lottery.isActive, "Lottery is not active");
        require(!lottery.isFinalized, "Lottery already finalized");

        lottery.isActive = false;
        lottery.isFinalized = true;

        // Refund all participants
        // We need to track unique participants and their ticket counts
        address[] memory participants = lottery.participants;
        mapping(address => uint256) storage tickets = playerTickets[_lotteryId];
        
        // Use a simple approach: iterate and mark refunded
