            else if (multiplier <= 200) rewardType = "Large";
            else if (multiplier <= 500) rewardType = "Huge";
            else rewardType = "Jackpot";
            
            emit RandomRewardDistributed(msg.sender, winnings, rewardType);
        }

        // Remaining goes to house
        uint256 houseTake = msg.value - (winnings > msg.value ? 0 : 0);
        // House always keeps the entry, pays from pool
        
        return winnings;
    }

