        require(_tierPercentages.length > 0, "Must have at least one tier");

        uint256 totalPercentage;
        uint256 totalWinners;
        for (uint256 i = 0; i < _tierPercentages.length; i++) {
            require(_tierPercentages[i] > 0, "Tier percentage must be > 0");
            require(_tierWinnerCounts[i] > 0, "Tier winner count must be > 0");
            totalPercentage += _tierPercentages[i];
            totalWinners += _tierWinnerCounts[i];
        }
        require(totalPercentage == 10000, "Tier percentages must sum to 10000");
        require(totalWinners <= _maxTickets, "Total winners exceed max tickets");

        lotteryCounter++;
        uint256 lotteryId = lotteryCounter;

        Lottery storage newLottery = lotteries[lotteryId];
        newLottery.id = lotteryId;
