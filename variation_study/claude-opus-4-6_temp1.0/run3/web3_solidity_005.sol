        uint256 rand = _randomInRange(100, uint256(uint160(msg.sender)));
        uint256 multiplier;

        // Spin outcomes:
        // 0-39 (40%): 0x - lose all
        // 40-64 (25%): 0.5x - lose half
        // 65-84 (20%): 1.5x - small win
        // 85-94 (10%): 2x - double
        // 95-98 (4%): 5x - big win
        // 99 (1%): 10x - jackpot

        if (rand < 40) {
            multiplier = 0;
        } else if (rand < 65) {
            multiplier = 50; // 0.5x (in basis points / 100)
        } else if (rand < 85) {
            multiplier = 150; // 1.5x
        } else if (rand < 95) {
            multiplier = 200; // 2x
        } else if (rand < 99) {
            multiplier = 500; // 5x
        } else {
            multiplier = 1000; // 10x
        }

        winnings = (msg.value * multiplier) / 100;

        if (winnings > 0) {
            require(
                address(this).balance >= winnings,
                "Insufficient contract balance for payout"
