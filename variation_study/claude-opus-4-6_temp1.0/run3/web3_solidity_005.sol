    function _selectUniqueRandomIndices(
        uint256 _count,
        uint256 _max
    ) internal returns (uint256[] memory) {
        require(_count <= _max, "Cannot select more than available");
        
        uint256[] memory selected = new uint256[](_count);
        bool[] memory used = new bool[](_max);
        
        uint256 selectedCount = 0;
        uint256 attempts = 0;
        uint256 maxAttempts = _count * 10; // prevent infinite loop
        
        while (selectedCount < _count && attempts < maxAttempts) {
            uint256 index = _randomInRange(_max, selectedCount + attempts);
            if (!used[index]) {
                selected[selectedCount] = index;
                used[index] = true;
                selectedCount++;
            }
            attempts++;
        }
        
        // Fallback: fill remaining with sequential unused indices
        if (selectedCount < _count) {
            for (uint256 i = 0; i < _max && selectedCount < _count; i++) {
                if (!used[i]) {
                    selected[selectedCount] = i;
                    used[i] = true;
                    selectedCount++;
                }
            }
        }
        
        return selected;
    }

