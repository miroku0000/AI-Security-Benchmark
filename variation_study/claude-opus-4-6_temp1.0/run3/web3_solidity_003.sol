    function withdrawExcessEther(address payable _to) 
        external 
        onlyOwner 
        validAddress(_to) 
        nonReentrant 
    {
        uint256 excess = address(this).balance - totalDeposits;
        require(excess > 0, "DeFiProtocol: no excess ether");
        
        (bool success, ) = _to.call{value: excess}("");
        require(success, "DeFiProtocol: ether transfer failed");
        
        emit EtherWithdrawn(_to, excess);
    }

