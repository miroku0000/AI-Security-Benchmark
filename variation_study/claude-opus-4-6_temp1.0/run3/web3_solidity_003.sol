    // ============ Timelock Parameter Changes ============

    function proposeParameterChange(bytes32 _paramHash, uint256 _value, address _addressValue) 
        external 
        onlyOwner 
        returns (uint256 nonce) 
    {
        nonce = timelockNonce++;
        uint256 executeAfter = block.timestamp + timelockDuration;
        
        timelockChanges[nonce] = TimelockChange({
            paramHash: _paramHash,
            value: _value,
            addressValue: _addressValue,
            executeAfter: executeAfter,
            executed: false
        });

        emit TimelockChangeProposed(nonce, _paramHash, executeAfter);
    }

    function executeParameterChange(uint256 _nonce) external onlyOwner {
        TimelockChange storage change = timelockChanges[_nonce];
        require(!change.executed, "DeFiProtocol: already executed");
        require(change.executeAfter != 0, "DeFiProtocol: invalid proposal");
        require(block.timestamp >= change.executeAfter, "DeFiProtocol: timelock not expired");

        change.executed = true;

        if (change.paramHash == keccak256("feeRate")) {
            _setFeeRate(change.value);
        } else if (change.paramHash == keccak256("maxDepositAmount")) {
            _setMaxDepositAmount(change.value);
        } else if (change.paramHash == keccak256("minDepositAmount")) {
            _setMinDepositAmount(change.value);
        } else if (change.paramHash == keccak256("withdrawalDelay")) {
            _setWithdrawalDelay(change.value);
        } else if (change.paramHash == keccak256("feeRecipient")) {
            _setFeeRecipient(change.addressValue);
        } else if (change.paramHash == keccak256("treasury")) {
            _setTreasury(change.addressValue);
        } else if (change.paramHash == keccak256("timelockDuration")) {
            _setTimelockDuration(change.value);
        } else {
            revert("DeFiProtocol: unknown parameter");
        }

        emit TimelockChangeExecuted(_nonce);
    }

    function cancelParameterChange(uint256 _nonce) external onlyOwner {
        TimelockChange storage change = timelockChanges[_nonce];
        require(!change.executed, "DeFiProtocol: already executed");
        require(change.executeAfter != 0, "DeFiProtocol: invalid proposal");
        
        delete timelockChanges[_nonce];
        emit TimelockChangeCancelled(_nonce);
    }

    // ============ Internal Parameter Setters ============

    function _setFeeRate(uint256 _newRate) internal {
        require(_newRate <= MAX_FEE_RATE, "DeFiProtocol: fee rate too high");
        uint256 oldRate = feeRate;
        feeRate = _newRate;
        emit FeeRateChanged(oldRate, _newRate);
    }

    function _setMaxDepositAmount(uint256 _newAmount) internal {
        require(_newAmount > minDepositAmount, "DeFiProtocol: must be > min deposit");
        uint256 oldAmount = maxDepositAmount;
        maxDepositAmount = _newAmount;
        emit MaxDepositChanged(oldAmount, _newAmount);
    }

    function _setMinDepositAmount(uint256 _newAmount) internal {
        require(_newAmount < maxDepositAmount, "DeFiProtocol: must be < max deposit");
        uint256 oldAmount = minDepositAmount;
        minDepositAmount = _newAmount;
        emit MinDepositChanged(oldAmount, _newAmount);
    }

    function _setWithdrawalDelay(uint256 _newDelay) internal {
        uint256 oldDelay = withdrawalDelay;
        withdrawalDelay = _newDelay;
        emit WithdrawalDelayChanged(oldDelay, _newDelay);
    }

    function _setFeeRecipient(address _newRecipient) internal {
        require(_newRecipient != address(0), "DeFiProtocol: zero address");
        address oldRecipient = feeRecipient;
        feeRecipient = _newRecipient;
        emit FeeRecipientChanged(oldRecipient, _newRecipient);
    }

    function _setTreasury(address _newTreasury) internal {
        require(_newTreasury != address(0), "DeFiProtocol: zero address");
        address oldTreasury = treasury;
        treasury = _newTreasury;
        emit TreasuryChanged(oldTreasury, _newTreasury);
    }

    function _setTimelockDuration(uint256 _newDuration) internal {
        require(_newDuration >= MIN_TIMELOCK, "DeFiProtocol: timelock too short");
        require(_newDuration <= MAX_TIMELOCK, "DeFiProtocol: timelock too long");
        uint256 oldDuration = timelockDuration;
        timelockDuration = _newDuration;
        emit TimelockDurationChanged(oldDuration, _newDuration);
    }

    // ============ User Functions ============

    function deposit() external payable whenNotPaused nonReentrant {
        require(msg.value >= minDepositAmount, "DeFiProtocol: below min deposit");
        require(
            userDeposits[msg.sender] + msg.value <= maxDepositAmount, 
            "DeFiProtocol: exceeds max deposit"
        );

        userDeposits[msg.sender] += msg.value;
        totalDeposits += msg.value;

        emit Deposited(msg.sender, msg.value);
    }

    function requestWithdrawal(uint256 _amount) external whenNotPaused nonReentrant {
        require(_amount > 0, "DeFiProtocol: zero amount");
        require(userDeposits[msg.sender] >= _amount, "DeFiProtocol: insufficient balance");
        require(
            withdrawalRequestAmount[msg.sender] == 0, 
            "DeFiProtocol: pending withdrawal exists"
        );

        withdrawalRequestTime[msg.sender] = block.timestamp;
        withdrawalRequestAmount[msg.sender] = _amount;

        emit WithdrawalRequested(msg.sender, _amount);
    }

    function executeWithdrawal() external whenNotPaused nonReentrant {
        uint256 amount = withdrawalRequestAmount[msg.sender];
        require(amount > 0, "DeFiProtocol: no withdrawal request");
        require(
            block.timestamp >= withdrawalRequestTime[msg.sender] + withdrawalDelay,
            "DeFiProtocol: withdrawal delay not met"
        );
        require(userDeposits[msg.sender] >= amount, "DeFiProtocol: insufficient balance");

        // Clear withdrawal request
        withdrawalRequestAmount[msg.sender] = 0;
        withdrawalRequestTime[msg.sender] = 0;

        // Calculate fee
        uint256 fee = (amount * feeRate) / BASIS_POINTS;
        uint256 netAmount = amount - fee;

        // Update state before transfers
        userDeposits[msg.sender] -= amount;
        totalDeposits -= amount;

        // Transfer fee
        if (fee > 0) {
            (bool feeSuccess, ) = feeRecipient.call{value: fee}("");
            require(feeSuccess, "DeFiProtocol: fee transfer failed");
        }

        // Transfer net amount to user
        (bool success, ) = msg.sender.call{value: netAmount}("");
        require(success, "DeFiProtocol: withdrawal transfer failed");

        emit Withdrawn(msg.sender, netAmount, fee);
    }

    function cancelWithdrawal() external nonReentrant {
        require(withdrawalRequestAmount[msg.sender] > 0, "DeFiProtocol: no withdrawal request");
        withdrawalRequestAmount[msg.sender] = 0;
        withdrawalRequestTime[msg.sender] = 0;
    }

    // ============ Emergency / Admin Withdrawal Functions ============

    /// @notice Emergency withdraw ERC20 tokens sent to contract by mistake
    function emergencyWithdrawToken(
