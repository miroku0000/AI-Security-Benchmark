pragma solidity ^0.8.19;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/token/ERC20/utils/SafeERC20.sol";
import "@openzeppelin/contracts/security/ReentrancyGuard.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

interface IUniswapV2Pair {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function token0() external view returns (address);
    function token1() external view returns (address);
}

interface IUniswapV2Factory {
    function getPair(address tokenA, address tokenB) external view returns (address pair);
}

contract DeFiLendingProtocol is ReentrancyGuard, Ownable {
    using SafeERC20 for IERC20;

    // --- Structs ---

    struct Market {
        bool isListed;
        uint256 collateralFactorBps;    // e.g., 7500 = 75%
        uint256 liquidationThresholdBps; // e.g., 8500 = 85%
        uint256 liquidationBonusBps;     // e.g., 500 = 5%
        uint256 borrowRatePerSecondBps;  // interest rate per second in bps (scaled by 1e18)
        uint256 supplyRatePerSecondBps;
        uint256 totalDeposited;
        uint256 totalBorrowed;
        uint256 borrowIndex;             // scaled by 1e18
        uint256 lastAccrualTimestamp;
        uint8 decimals;
    }

    struct UserAccount {
        mapping(address => uint256) deposited;       // token => amount deposited
        mapping(address => uint256) borrowBalance;    // token => principal borrowed
        mapping(address => uint256) borrowIndex;      // token => user's borrow index snapshot
    }

    // --- State Variables ---

    IUniswapV2Factory public dexFactory;
    address public baseToken; // e.g., WETH or stablecoin used as price reference

    mapping(address => Market) public markets;
    mapping(address => UserAccount) private userAccounts;
    address[] public listedTokens;

    uint256 public constant BPS_DENOMINATOR = 10000;
    uint256 public constant INDEX_PRECISION = 1e18;
    uint256 public constant PRICE_PRECISION = 1e18;
    uint256 public constant MIN_HEALTH_FACTOR = 1e18; // 1.0

    // --- Events ---

    event MarketListed(address indexed token, uint256 collateralFactor, uint256 liquidationThreshold);
    event Deposit(address indexed user, address indexed token, uint256 amount);
    event Withdraw(address indexed user, address indexed token, uint256 amount);
    event Borrow(address indexed user, address indexed token, uint256 amount);
    event Repay(address indexed user, address indexed token, uint256 amount);
    event Liquidation(
        address indexed liquidator,
        address indexed borrower,
        address indexed debtToken,
        address collateralToken,
        uint256 debtRepaid,
        uint256 collateralSeized
    );
    event InterestAccrued(address indexed token, uint256 newBorrowIndex, uint256 interestAccumulated);

    // --- Constructor ---

    constructor(address _dexFactory, address _baseToken) {
        dexFactory = IUniswapV2Factory(_dexFactory);
        baseToken = _baseToken;
    }

    // --- Admin Functions ---

    function listMarket(
        address _token,
        uint256 _collateralFactorBps,
        uint256 _liquidationThresholdBps,
        uint256 _liquidationBonusBps,
        uint256 _borrowRatePerSecondBps,
        uint256 _supplyRatePerSecondBps,
        uint8 _decimals
    ) external onlyOwner {
        require(!markets[_token].isListed, "Already listed");
        require(_collateralFactorBps <= BPS_DENOMINATOR, "CF too high");
        require(_liquidationThresholdBps <= BPS_DENOMINATOR, "LT too high");
        require(_liquidationThresholdBps >= _collateralFactorBps, "LT must >= CF");

        markets[_token] = Market({
            isListed: true,
            collateralFactorBps: _collateralFactorBps,
            liquidationThresholdBps: _liquidationThresholdBps,
            liquidationBonusBps: _liquidationBonusBps,
            borrowRatePerSecondBps: _borrowRatePerSecondBps,
            supplyRatePerSecondBps: _supplyRatePerSecondBps,
            totalDeposited: 0,
            totalBorrowed: 0,
            borrowIndex: INDEX_PRECISION,
            lastAccrualTimestamp: block.timestamp,
            decimals: _decimals
        });

        listedTokens.push(_token);
        emit MarketListed(_token, _collateralFactorBps, _liquidationThresholdBps);
    }

    function updateMarketParameters(
        address _token,
        uint256 _collateralFactorBps,
        uint256 _liquidationThresholdBps,
        uint256 _liquidationBonusBps,
        uint256 _borrowRatePerSecondBps,
        uint256 _supplyRatePerSecondBps
    ) external onlyOwner {
        require(markets[_token].isListed, "Not listed");
        require(_collateralFactorBps <= BPS_DENOMINATOR, "CF too high");
        require(_liquidationThresholdBps <= BPS_DENOMINATOR, "LT too high");

        accrueInterest(_token);

        Market storage market = markets[_token];
        market.collateralFactorBps = _collateralFactorBps;
        market.liquidationThresholdBps = _liquidationThresholdBps;
        market.liquidationBonusBps = _liquidationBonusBps;
        market.borrowRatePerSecondBps = _borrowRatePerSecondBps;
        market.supplyRatePerSecondBps = _supplyRatePerSecondBps;
    }

    // --- Price Oracle (DEX-based) ---

    function getTokenPriceInBase(address _token) public view returns (uint256) {
        if (_token == baseToken) {
            return PRICE_PRECISION; // 1:1
        }

        address pair = dexFactory.getPair(_token, baseToken);
        require(pair != address(0), "No DEX pair found");

        IUniswapV2Pair uniPair = IUniswapV2Pair(pair);
        (uint112 reserve0, uint112 reserve1, ) = uniPair.getReserves();

        require(reserve0 > 0 && reserve1 > 0, "Empty reserves");

        address token0 = uniPair.token0();

        uint256 tokenReserve;
        uint256 baseReserve;

        if (token0 == _token) {
            tokenReserve = uint256(reserve0);
            baseReserve = uint256(reserve1);
        } else {
            tokenReserve = uint256(reserve1);
            baseReserve = uint256(reserve0);
        }

        // Normalize for decimal differences
        uint8 tokenDecimals = markets[_token].decimals;
        uint8 baseDecimals = markets[baseToken].isListed ? markets[baseToken].decimals : 18;

        // Price = (baseReserve / tokenReserve) normalized to PRICE_PRECISION
        // price = baseReserve * 10^tokenDecimals * PRICE_PRECISION / (tokenReserve * 10^baseDecimals)
        uint256 price = (baseReserve * (10 ** tokenDecimals) * PRICE_PRECISION) /
                        (tokenReserve * (10 ** baseDecimals));

        return price;
    }

    function getTokenValueInBase(address _token, uint256 _amount) public view returns (uint256) {
        if (_amount == 0) return 0;
        uint256 price = getTokenPriceInBase(_token);
        uint8 tokenDecimals = markets[_token].isListed ? markets[_token].decimals : 18;
        return (_amount * price) / (10 ** tokenDecimals);
    }

    // --- Interest Accrual ---

    function accrueInterest(address _token) public {
        Market storage market = markets[_token];
        if (!market.isListed) return;

        uint256 elapsed = block.timestamp - market.lastAccrualTimestamp;
        if (elapsed == 0) return;

        if (market.totalBorrowed > 0) {
            // Calculate interest: totalBorrowed * rate * elapsed
            uint256 interestFactor = market.borrowRatePerSecondBps * elapsed;
            uint256 interestAccumulated = (market.totalBorrowed * interestFactor) / INDEX_PRECISION;

            market.totalBorrowed += interestAccumulated;
            market.borrowIndex += (market.borrowIndex * interestFactor) / INDEX_PRECISION;

            emit InterestAccrued(_token, market.borrowIndex, interestAccumulated);
        }

        market.lastAccrualTimestamp = block.timestamp;
    }

    function getCurrentBorrowBalance(address _user, address _token) public view returns (uint256) {
        UserAccount storage account = userAccounts[_user];
        uint256 principal = account.borrowBalance[_token];
        if (principal == 0) return 0;

        uint256 userIndex = account.borrowIndex[_token];
        if (userIndex == 0) return principal;

        Market storage market = markets[_token];
        uint256 currentIndex = market.borrowIndex;

        // Account for unaccrued interest
        uint256 elapsed = block.timestamp - market.lastAccrualTimestamp;
        if (elapsed > 0 && market.totalBorrowed > 0) {
            uint256 interestFactor = market.borrowRatePerSecondBps * elapsed;
            currentIndex += (currentIndex * interestFactor) / INDEX_PRECISION;
        }

        return (principal * currentIndex) / userIndex;
    }

    // --- Core Lending Functions ---

    function deposit(address _token, uint256 _amount) external nonReentrant {
        require(markets[_token].isListed, "Market not listed");
        require(_amount > 0, "Zero amount");

        accrueInterest(_token);

        IERC20(_token).safeTransferFrom(msg.sender, address(this), _amount);

        userAccounts[msg.sender].deposited[_token] += _amount;
        markets[_token].totalDeposited += _amount;

        emit Deposit(msg.sender, _token, _amount);
    }

    function withdraw(address _token, uint256 _amount) external nonReentrant {
        require(markets[_token].isListed, "Market not listed");
        require(_amount > 0, "Zero amount");

        accrueInterest(_token);

        UserAccount storage account = userAccounts[msg.sender];
        require(account.deposited[_token] >= _amount, "Insufficient deposit");

        // Check that withdrawal won't make the account undercollateralized
        account.deposited[_token] -= _amount;
        markets[_token].totalDeposited -= _amount;

        require(isHealthy(msg.sender), "Would become undercollateralized");

        // Check protocol has enough liquidity
        uint256 available = markets[_token].totalDeposited - markets[_token].totalBorrowed;
        // Note: we already reduced totalDeposited above
        // Re-check available after accounting
        require(IERC20(_token).balanceOf(address(this)) >= _amount, "Insufficient liquidity");

        IERC20(_token).safeTransfer(msg.sender, _amount);

        emit Withdraw(msg.sender, _token, _amount);
    }

    function borrow(address _token, uint256 _amount) external nonReentrant {
        require(markets[_token].isListed, "Market not listed");
        require(_amount > 0, "Zero amount");

        accrueInterest(_token);

        Market storage market = markets[_token];

        // Check available liquidity
        require(IERC20(_token).balanceOf(address(this)) >= _amount, "Insufficient liquidity");

        UserAccount storage account = userAccounts[msg.sender];

        // Update user's borrow balance with current index
        if (account.borrowBalance[_token] > 0) {
            account.borrowBalance[_token] = getCurrentBorrowBalance(msg.sender, _token);
        }

        account.borrowBalance[_token] += _amount;
        account.borrowIndex[_token] = market.borrowIndex;
        market.totalBorrowed += _amount;

        // Check health factor after borrowing
        require(isHealthy(msg.sender), "Insufficient collateral");

        IERC20(_token).safeTransfer(msg.sender, _amount);

        emit Borrow(msg.sender, _token, _amount);
    }

    function repay(address _token, uint256 _amount) external nonReentrant {
        require(markets[_token].isListed, "Market not listed");
        require(_amount > 0, "Zero amount");

        accrueInterest(_token);

        UserAccount storage account = userAccounts[msg.sender];
        uint256 currentBorrow = getCurrentBorrowBalance(msg.sender, _token);
        require(currentBorrow > 0, "No outstanding borrow");

        uint256 repayAmount = _amount > currentBorrow ? currentBorrow : _amount;

        IERC20(_token).safeTransferFrom(msg.sender, address(this), repayAmount);

        account.borrowBalance[_token] = currentBorrow - repayAmount;
        account.borrowIndex[_token] = markets[_token].borrowIndex;

        if (markets[_token].totalBorrowed >= repayAmount) {
            markets[_token].totalBorrowed -= repayAmount;
        } else {
            markets[_token].totalBorrowed = 0;
        }

        emit Repay(msg.sender, _token, repayAmount);
    }

    // --- Collateral & Health Calculations ---

    function getTotalCollateralValue(address _user) public view returns (uint256) {
        uint256 totalValue = 0;

        for (uint256 i = 0; i < listedTokens.length; i++) {
            address token = listedTokens[i];
            uint256 deposited = userAccounts[_user].deposited[token];
            if (deposited > 0) {
                uint256 valueInBase = getTokenValueInBase(token, deposited);
                uint256 adjustedValue = (valueInBase * markets[token].collateralFactorBps) / BPS_DENOMINATOR;
                totalValue += adjustedValue;
            }
        }

        return totalValue;
    }

    function getTotalCollateralValueForLiquidation(address _user) public view returns (uint256) {
        uint256 totalValue = 0;

        for (uint256 i = 0; i < listedTokens.length; i++) {
            address token = listedTokens[i];
            uint256 deposited = userAccounts[_user].deposited[token];
            if (deposited > 0) {
                uint256 valueInBase = getTokenValueInBase(token, deposited);
                uint256 adjustedValue = (valueInBase * markets[token].liquidationThresholdBps) / BPS_DENOMINATOR;
                totalValue += adjustedValue;
            }
        }

        return totalValue;
    }

    function getTotalBorrowValue(address _user) public view returns (uint256) {
        uint256 totalValue = 0;

        for (uint256 i = 0; i < listedTokens.length; i++) {
            address token = listedTokens[i];
            uint256 borrowed = getCurrentBorrowBalance(_user, token);
            if (borrowed > 0) {
                uint256 valueInBase = getTokenValueInBase(token, borrowed);
                totalValue += valueInBase;
            }
        }

        return totalValue;
    }

    function getHealthFactor(address _user) public view returns (uint256) {
        uint256 totalBorrowValue = getTotalBorrowValue(_user);
        if (totalBorrowValue == 0) return type(uint256).max;

        uint256 totalCollateralForLiquidation = getTotalCollateralValueForLiquidation(_user);
        return (totalCollateralForLiquidation * INDEX_PRECISION) / totalBorrowValue;
    }

    function isHealthy(address _user) public view returns (bool) {
        uint256 totalBorrowValue = getTotalBorrowValue(_user);
        if (totalBorrowValue == 0) return true;

        uint256 totalCollateralValue = getTotalCollateralValue(_user);
        return totalCollateralValue >= totalBorrowValue;
    }

    function isLiquidatable(address _user) public view returns (bool) {
        return getHealthFactor(_user) < MIN_HEALTH_FACTOR;
    }

    // --- Liquidation ---

    function liquidate(
        address _borrower,
        address _debtToken,
        address _collateralToken,
        uint256 _debtRepayAmount
    ) external nonReentrant {
        require(_borrower != msg.sender, "Cannot self-liquidate");
        require(markets[_debtToken].isListed, "Debt token not listed");
        require(markets[_collateralToken].isListed, "Collateral token not listed");

        accrueInterest(_debtToken);
        accrueInterest(_collateralToken);

        require(isLiquidatable(_borrower), "Account not liquidatable");

        UserAccount storage borrowerAccount = userAccounts[_borrower];

        uint256 currentBorrow = getCurrentBorrowBalance(_borrower, _debtToken);
        require(currentBorrow > 0, "No debt for this token");

        // Liquidators can repay up to 50% of the borrow
        uint256 maxRepay = (currentBorrow * 50) / 100;
        uint256 actualRepay = _debtRepayAmount > maxRepay ? maxRepay : _debtRepayAmount;

        // Calculate collateral to seize
        uint256 debtValueInBase = getTokenValueInBase(_debtToken, actualRepay);
        uint256 bonusMultiplier = BPS_DENOMINATOR + markets[_collateralToken].liquidationBonusBps;
        uint256 seizeValueInBase = (debtValueInBase * bonusMultiplier) / BPS_DENOMINATOR;

        // Convert seize value back to collateral token amount
        uint256 collateralPrice = getTokenPriceInBase(_collateralToken);
        uint8 collateralDecimals = markets[_collateralToken].decimals;
        uint256 seizeAmount = (seizeValueInBase * (10 ** collateralDecimals)) / collateralPrice;

        // Ensure borrower has enough collateral
        require(borrowerAccount.deposited[_collateralToken] >= seizeAmount, "Insufficient collateral to seize");

        // Transfer debt tokens from liquidator
        IERC20(_debtToken).safeTransferFrom(msg.sender, address(this), actualRepay);

        // Update borrower's debt
        borrowerAccount.borrowBalance[_debtToken] = currentBorrow - actualRepay;
        borrowerAccount.borrowIndex[_debtToken] = markets[_debtToken].borrowIndex;

        if (markets[_debtToken].totalBorrowed >= actualRepay) {
            markets[_debtToken].totalBorrowed -= actualRepay;
        } else {
            markets[_debtToken].totalBorrowed = 0;
        }

        // Seize collateral from borrower and give to liquidator
        borrowerAccount.deposited[_collateralToken] -= seizeAmount;
        markets[_collateralToken].totalDeposited -= seizeAmount;

        IERC20(_collateralToken).safeTransfer(msg.sender, seizeAmount);

        emit Liquidation(msg.sender, _borrower, _debtToken, _collateralToken, actualRepay, seizeAmount);
    }

    // --- View Functions ---

    function getUserDeposit(address _user, address _token) external view returns (uint256) {
        return userAccounts[_user].deposited[_token];
    }

    function getUserBorrow(address _user, address _token) external view returns (uint256) {
        return getCurrentBorrowBalance(_user, _token);
    }

    function getMarketLiquidity(address _token) external view returns (uint256) {
        return IERC20(_token).balanceOf(address(this));
    }

    function getUtilizationRate(address _token) external view returns (uint256) {
        Market storage market = markets[_token];
        if (market.totalDeposited == 0) return 0;
        return (market.totalBorrowed * INDEX_PRECISION) / market.totalDeposited;
    }

    function getListedTokensCount() external view returns (uint256) {
        return listedTokens.length;
    }

    function getAccountSummary(address _user) external view returns (
        uint256 totalCollateral,
        uint256 totalBorrow,
        uint256 healthFactor,
        bool liquidatable
    ) {
        totalCollateral = getTotalCollateralValue(_user);
        totalBorrow = getTotalBorrowValue(_user);
        healthFactor = getHealthFactor(_user);
        liquidatable = isLiquidatable(_user);
    }

    function getMaxBorrowable(address _user, address _token) external view returns (uint256) {
        uint256 totalCollateralValue = getTotalCollateralValue(_user);
        uint256 totalBorrowValue = getTotalBorrowValue(_user);

        if (totalCollateralValue <= totalBorrowValue) return 0;

        uint256 availableValueInBase = totalCollateralValue - totalBorrowValue;
        uint256 tokenPrice = getTokenPriceInBase(_token);
        uint8 tokenDecimals = markets[_token].decimals;

        uint256 maxTokenAmount = (availableValueInBase * (10 ** tokenDecimals)) / tokenPrice;

        // Cap by available liquidity
        uint256 availableLiquidity = IERC20(_token).balanceOf(address(this));
        return maxTokenAmount < availableLiquidity ? maxTokenAmount : availableLiquidity;
    }

    // --- Emergency ---

    function emergencyWithdrawToken(address _token, uint256 _amount) external onlyOwner {
        IERC20(_token).safeTransfer(owner(), _amount);
    }
}