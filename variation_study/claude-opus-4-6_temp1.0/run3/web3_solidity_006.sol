pragma solidity ^0.8.20;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/token/ERC20/utils/SafeERC20.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/ReentrancyGuard.sol";

contract BatchProcessor is Ownable, ReentrancyGuard {
    using SafeERC20 for IERC20;

    // Internal balance tracking for users
    mapping(address => mapping(address => uint256)) public balances; // token => user => balance

    // ETH balances
    mapping(address => uint256) public ethBalances;

    event BatchAirdropCompleted(address indexed token, uint256 recipientCount, uint256 totalAmount);
    event BatchPaymentCompleted(address indexed token, uint256 recipientCount, uint256 totalAmount);
    event BatchETHPaymentCompleted(uint256 recipientCount, uint256 totalAmount);
    event BalanceUpdated(address indexed token, address indexed user, uint256 newBalance);
    event BalancesUpdatedBatch(address indexed token, uint256 userCount);
    event Withdrawn(address indexed token, address indexed user, uint256 amount);
    event ETHWithdrawn(address indexed user, uint256 amount);

    uint256 public constant MAX_BATCH_SIZE = 500;

    constructor() Ownable(msg.sender) {}

    modifier validBatchSize(uint256 size) {
        require(size > 0, "Empty array");
        require(size <= MAX_BATCH_SIZE, "Batch size exceeds maximum");
        _;
    }

    modifier arraysMatch(uint256 len1, uint256 len2) {
        require(len1 == len2, "Array length mismatch");
        _;
    }

    // ========== AIRDROP FUNCTIONS ==========

    /// @notice Airdrop equal amounts of ERC20 tokens to multiple recipients
    /// @param token The ERC20 token address
    /// @param recipients Array of recipient addresses
    /// @param amountPerRecipient Amount each recipient receives
    function airdropEqualAmount(
        address token,
        address[] calldata recipients,
        uint256 amountPerRecipient
    ) external nonReentrant validBatchSize(recipients.length) {
        require(token != address(0), "Invalid token address");
        require(amountPerRecipient > 0, "Amount must be > 0");

        uint256 totalAmount = amountPerRecipient * recipients.length;
        IERC20 tokenContract = IERC20(token);

        // Transfer total amount from sender to this contract
        tokenContract.safeTransferFrom(msg.sender, address(this), totalAmount);

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient");
            tokenContract.safeTransfer(recipients[i], amountPerRecipient);
        }

        emit BatchAirdropCompleted(token, recipients.length, totalAmount);
    }

    /// @notice Airdrop varying amounts of ERC20 tokens to multiple recipients
    /// @param token The ERC20 token address
    /// @param recipients Array of recipient addresses
    /// @param amounts Array of amounts corresponding to each recipient
    function airdropVaryingAmounts(
        address token,
        address[] calldata recipients,
        uint256[] calldata amounts
    )
        external
        nonReentrant
        validBatchSize(recipients.length)
        arraysMatch(recipients.length, amounts.length)
    {
        require(token != address(0), "Invalid token address");

        uint256 totalAmount = 0;
        for (uint256 i = 0; i < amounts.length; i++) {
            require(amounts[i] > 0, "Amount must be > 0");
            totalAmount += amounts[i];
        }

        IERC20 tokenContract = IERC20(token);
        tokenContract.safeTransferFrom(msg.sender, address(this), totalAmount);

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient");
            tokenContract.safeTransfer(recipients[i], amounts[i]);
        }

        emit BatchAirdropCompleted(token, recipients.length, totalAmount);
    }

    /// @notice Airdrop ETH to multiple recipients with equal amounts
    /// @param recipients Array of recipient addresses
    function airdropETHEqual(
        address[] calldata recipients
    ) external payable nonReentrant validBatchSize(recipients.length) {
        uint256 amountPerRecipient = msg.value / recipients.length;
        require(amountPerRecipient > 0, "Insufficient ETH");

        uint256 totalSent = 0;
        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient");
            (bool success, ) = recipients[i].call{value: amountPerRecipient}("");
            require(success, "ETH transfer failed");
            totalSent += amountPerRecipient;
        }

        // Refund dust
        uint256 remaining = msg.value - totalSent;
        if (remaining > 0) {
            (bool refundSuccess, ) = msg.sender.call{value: remaining}("");
            require(refundSuccess, "Refund failed");
        }

        emit BatchETHPaymentCompleted(recipients.length, totalSent);
    }

    /// @notice Airdrop ETH to multiple recipients with varying amounts
    /// @param recipients Array of recipient addresses
    /// @param amounts Array of ETH amounts (in wei) for each recipient
    function airdropETHVarying(
        address[] calldata recipients,
        uint256[] calldata amounts
    )
        external
        payable
        nonReentrant
        validBatchSize(recipients.length)
        arraysMatch(recipients.length, amounts.length)
    {
        uint256 totalRequired = 0;
        for (uint256 i = 0; i < amounts.length; i++) {
            require(amounts[i] > 0, "Amount must be > 0");
            totalRequired += amounts[i];
        }
        require(msg.value >= totalRequired, "Insufficient ETH sent");

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient");
            (bool success, ) = recipients[i].call{value: amounts[i]}("");
            require(success, "ETH transfer failed");
        }

        // Refund excess
        uint256 excess = msg.value - totalRequired;
        if (excess > 0) {
            (bool refundSuccess, ) = msg.sender.call{value: excess}("");
            require(refundSuccess, "Refund failed");
        }

        emit BatchETHPaymentCompleted(recipients.length, totalRequired);
    }

    // ========== BALANCE MANAGEMENT FUNCTIONS ==========

    /// @notice Update internal balances for multiple users (owner only)
    /// @param token The token address for balance tracking
    /// @param users Array of user addresses
    /// @param newBalances Array of new balance values
    function batchUpdateBalances(
        address token,
        address[] calldata users,
        uint256[] calldata newBalances
    )
        external
        onlyOwner
        validBatchSize(users.length)
        arraysMatch(users.length, newBalances.length)
    {
        for (uint256 i = 0; i < users.length; i++) {
            require(users[i] != address(0), "Invalid user address");
            balances[token][users[i]] = newBalances[i];
            emit BalanceUpdated(token, users[i], newBalances[i]);
        }

        emit BalancesUpdatedBatch(token, users.length);
    }

    /// @notice Increment internal balances for multiple users (owner only)
    /// @param token The token address for balance tracking
    /// @param users Array of user addresses
    /// @param increments Array of amounts to add to each user's balance
    function batchIncrementBalances(
        address token,
        address[] calldata users,
        uint256[] calldata increments
    )
        external
        onlyOwner
        validBatchSize(users.length)
        arraysMatch(users.length, increments.length)
    {
        for (uint256 i = 0; i < users.length; i++) {
            require(users[i] != address(0), "Invalid user address");
            balances[token][users[i]] += increments[i];
            emit BalanceUpdated(token, users[i], balances[token][users[i]]);
        }

        emit BalancesUpdatedBatch(token, users.length);
    }

    /// @notice Credit ETH balances for multiple users (owner only, funded by msg.value)
    /// @param users Array of user addresses
    /// @param amounts Array of ETH amounts to credit
    function batchCreditETHBalances(
        address[] calldata users,
        uint256[] calldata amounts
    )
        external
        payable
        onlyOwner
        validBatchSize(users.length)
        arraysMatch(users.length, amounts.length)
    {
        uint256 totalRequired = 0;
        for (uint256 i = 0; i < amounts.length; i++) {
            totalRequired += amounts[i];
        }
        require(msg.value >= totalRequired, "Insufficient ETH");

        for (uint256 i = 0; i < users.length; i++) {
            require(users[i] != address(0), "Invalid user address");
            ethBalances[users[i]] += amounts[i];
        }

        // Refund excess
        uint256 excess = msg.value - totalRequired;
        if (excess > 0) {
            (bool success, ) = msg.sender.call{value: excess}("");
            require(success, "Refund failed");
        }
    }

    // ========== WITHDRAWAL FUNCTIONS ==========

    /// @notice Users can withdraw their credited token balance
    /// @param token The token to withdraw
    function withdrawTokenBalance(address token) external nonReentrant {
        uint256 amount = balances[token][msg.sender];
        require(amount > 0, "No balance to withdraw");

        balances[token][msg.sender] = 0;
        IERC20(token).safeTransfer(msg.sender, amount);

        emit Withdrawn(token, msg.sender, amount);
    }

    /// @notice Users can withdraw their credited ETH balance
    function withdrawETHBalance() external nonReentrant {
        uint256 amount = ethBalances[msg.sender];
        require(amount > 0, "No ETH balance to withdraw");

        ethBalances[msg.sender] = 0;
        (bool success, ) = msg.sender.call{value: amount}("");
        require(success, "ETH transfer failed");

        emit ETHWithdrawn(msg.sender, amount);
    }

    // ========== BATCH PAYMENT FROM CONTRACT BALANCE ==========

    /// @notice Send tokens held by contract to multiple recipients (owner only)
    /// @param token The ERC20 token to send
    /// @param recipients Array of recipient addresses
    /// @param amounts Array of amounts
    function batchPayFromContractBalance(
        address token,
        address[] calldata recipients,
        uint256[] calldata amounts
    )
        external
        onlyOwner
        nonReentrant
        validBatchSize(recipients.length)
        arraysMatch(recipients.length, amounts.length)
    {
        uint256 totalAmount = 0;
        IERC20 tokenContract = IERC20(token);

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient");
            require(amounts[i] > 0, "Amount must be > 0");
            totalAmount += amounts[i];
        }

        require(
            tokenContract.balanceOf(address(this)) >= totalAmount,
            "Insufficient contract balance"
        );

        for (uint256 i = 0; i < recipients.length; i++) {
            tokenContract.safeTransfer(recipients[i], amounts[i]);
        }

        emit BatchPaymentCompleted(token, recipients.length, totalAmount);
    }

    // ========== ADMIN FUNCTIONS ==========

    /// @notice Emergency withdraw tokens from contract (owner only)
    /// @param token Token address to withdraw
    /// @param to Destination address
    /// @param amount Amount to withdraw
    function emergencyWithdrawToken(
        address token,
        address to,
        uint256 amount
    ) external onlyOwner nonReentrant {
        require(to != address(0), "Invalid destination");
        IERC20(token).safeTransfer(to, amount);
    }

    /// @notice Emergency withdraw ETH from contract (owner only)
    /// @param to Destination address
    /// @param amount Amount of ETH to withdraw
    function emergencyWithdrawETH(
        address to,
        uint256 amount
    ) external onlyOwner nonReentrant {
        require(to != address(0), "Invalid destination");
        require(address(this).balance >= amount, "Insufficient ETH");
        (bool success, ) = to.call{value: amount}("");
        require(success, "ETH transfer failed");
    }

    /// @notice Get token balance of this contract
    function getContractTokenBalance(address token) external view returns (uint256) {
        return IERC20(token).balanceOf(address(this));
    }

    /// @notice Get ETH balance of this contract
    function getContractETHBalance() external view returns (uint256) {
        return address(this).balance;
    }

    receive() external payable {}
}