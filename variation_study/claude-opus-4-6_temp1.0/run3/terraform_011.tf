# Generated by anthropic (claude-opus-4-6)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

data "aws_caller_identity" "current" {}
data "aws_region" "current" {}

variable "role_name" {
  description = "Name of the CI/CD IAM role"
  type        = string
  default     = "cicd-deployment-role"
}

variable "trusted_account_ids" {
  description = "List of AWS account IDs allowed to assume this role"
  type        = list(string)
  default     = []
}

variable "trusted_service_principals" {
  description = "List of AWS service principals allowed to assume this role"
  type        = list(string)
  default     = []
}

variable "trusted_oidc_providers" {
  description = "Map of OIDC providers for federation (e.g., GitHub Actions, GitLab)"
  type = map(object({
    provider_arn = string
    conditions = list(object({
      test     = string
      variable = string
      values   = list(string)
    }))
  }))
  default = {}
}

variable "max_session_duration" {
  description = "Maximum session duration in seconds"
  type        = number
  default     = 3600
}

variable "permissions_boundary_arn" {
  description = "ARN of the permissions boundary policy to attach"
  type        = string
  default     = null
}

variable "additional_policy_arns" {
  description = "List of additional IAM policy ARNs to attach to the role"
  type        = list(string)
  default     = []
}

variable "denied_actions" {
  description = "List of actions to explicitly deny (guardrails)"
  type        = list(string)
  default = [
    "organizations:*",
    "account:*",
  ]
}

variable "allowed_services" {
  description = "List of AWS service prefixes to allow (e.g., ec2, s3, rds)"
  type        = list(string)
  default = [
    "ec2",
    "s3",
    "rds",
    "lambda",
    "iam",
    "sts",
    "logs",
    "cloudwatch",
    "events",
    "sns",
    "sqs",
    "dynamodb",
    "apigateway",
    "cloudformation",
    "elasticloadbalancing",
    "autoscaling",
    "route53",
    "acm",
    "kms",
    "secretsmanager",
    "ssm",
    "ecs",
    "ecr",
    "codebuild",
    "codepipeline",
    "codedeploy",
    "cloudfront",
    "wafv2",
    "elasticache",
    "es",
    "opensearch",
    "kinesis",
    "firehose",
    "stepfunctions",
    "states",
    "application-autoscaling",
    "tag",
    "resource-groups",
    "xray",
    "signer",
    "scheduler",
    "pipes",
  ]
}

variable "require_mfa" {
  description = "Whether to require MFA for assuming the role (only for user-based assume)"
  type        = bool
  default     = false
}

variable "tags" {
  description = "Tags to apply to all resources"
  type        = map(string)
  default     = {}
}

variable "enable_self_manage_iam" {
  description = "Allow the role to manage IAM roles/policies with a path prefix"
  type        = bool
  default     = true
}

variable "iam_path_prefix" {
  description = "IAM path prefix the role is allowed to manage"
  type        = string
  default     = "/cicd-managed/"
}

locals {
  account_id = data.aws_caller_identity.current.account_id

  allowed_action_patterns = [for svc in var.allowed_services : "${svc}:*"]

  default_tags = merge(
    {
      ManagedBy = "terraform"
      Purpose   = "cicd-deployment"
    },
    var.tags
  )
}

# --- Trust Policy ---

data "aws_iam_policy_document" "assume_role" {
  # Trust from other AWS accounts
  dynamic "statement" {
    for_each = length(var.trusted_account_ids) > 0 ? [1] : []
    content {
      sid     = "AllowCrossAccountAssume"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      principals {
        type        = "AWS"
        identifiers = [for acct in var.trusted_account_ids : "arn:aws:iam::${acct}:root"]
      }

      dynamic "condition" {
        for_each = var.require_mfa ? [1] : []
        content {
          test     = "Bool"
          variable = "aws:MultiFactorAuthPresent"
          values   = ["true"]
        }
      }
    }
  }

  # Trust from same account (self-assume for pipelines)
  statement {
    sid     = "AllowSameAccountAssume"
    effect  = "Allow"
    actions = ["sts:AssumeRole"]

    principals {
      type        = "AWS"
      identifiers = ["arn:aws:iam::${local.account_id}:root"]
    }
  }

  # Trust from AWS services
  dynamic "statement" {
    for_each = length(var.trusted_service_principals) > 0 ? [1] : []
    content {
      sid     = "AllowServiceAssume"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      principals {
        type        = "Service"
        identifiers = var.trusted_service_principals
      }
    }
  }

  # Trust from OIDC providers (GitHub Actions, GitLab CI, etc.)
  dynamic "statement" {
    for_each = var.trusted_oidc_providers
    content {
      sid     = "AllowOIDC${replace(title(statement.key), "/[^a-zA-Z0-9]/", "")}"
      effect  = "Allow"
      actions = ["sts:AssumeRoleWithWebIdentity"]

      principals {
        type        = "Federated"
        identifiers = [statement.value.provider_arn]
      }

      dynamic "condition" {
        for_each = statement.value.conditions
        content {
          test     = condition.value.test
          variable = condition.value.variable
          values   = condition.value.values
        }
      }
    }
  }
}

# --- IAM Role ---

resource "aws_iam_role" "cicd" {
  name                 = var.role_name
  assume_role_policy   = data.aws_iam_policy_document.assume_role.json
  max_session_duration = var.max_session_duration
  permissions_boundary = var.permissions_boundary_arn
  path                 = "/cicd/"

  tags = local.default_tags
}

# --- Core Deployment Policy ---

data "aws_iam_policy_document" "deployment_permissions" {
  # Allow broad service access for deployment
  statement {
    sid       = "AllowServiceActions"
    effect    = "Allow"
    actions   = local.allowed_action_patterns
    resources = ["*"]
  }

  # Allow Terraform state management (S3 + DynamoDB)
  statement {
    sid    = "AllowTerraformStateManagement"
    effect = "Allow"
    actions = [
      "s3:GetObject",
      "s3:PutObject",
      "s3:DeleteObject",
      "s3:ListBucket",
      "s3:GetBucketVersioning",
      "s3:GetBucketLocation",
      "dynamodb:GetItem",
      "dynamodb:PutItem",
      "dynamodb:DeleteItem",
      "dynamodb:DescribeTable",
    ]
    resources = ["*"]
  }
}

resource "aws_iam_policy" "deployment_permissions" {
  name        = "${var.role_name}-deployment-permissions"
  description = "Core deployment permissions for CI/CD pipeline"
  path        = "/cicd/"
  policy      = data.aws_iam_policy_document.deployment_permissions.json

  tags = local.default_tags
}

resource "aws_iam_role_policy_attachment" "deployment_permissions" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.deployment_permissions.arn
}

# --- IAM Management Policy (scoped to path prefix) ---

data "aws_iam_policy_document" "iam_management" {
  count = var.enable_self_manage_iam ? 1 : 0

  # Allow creating/managing roles and policies under a specific path
  statement {
    sid    = "AllowIAMRoleManagement"
    effect = "Allow"
    actions = [
      "iam:CreateRole",
      "iam:DeleteRole",
      "iam:GetRole",
      "iam:UpdateRole",
      "iam:TagRole",
      "iam:UntagRole",
      "iam:UpdateAssumeRolePolicy",
      "iam:AttachRolePolicy",
      "iam:DetachRolePolicy",
      "iam:PutRolePolicy",
      "iam:DeleteRolePolicy",
      "iam:GetRolePolicy",
      "iam:ListRolePolicies",
      "iam:ListAttachedRolePolicies",
      "iam:ListInstanceProfilesForRole",
    ]
    resources = [
      "arn:aws:iam::${local.account_id}:role${var.iam_path_prefix}*",
    ]
  }

  # Allow creating/managing policies under a specific path
  statement {
    sid    = "AllowIAMPolicyManagement"
    effect = "Allow"
    actions = [
      "iam:CreatePolicy",
      "iam:DeletePolicy",
      "iam:GetPolicy",
      "iam:GetPolicyVersion",
      "iam:ListPolicyVersions",
      "iam:CreatePolicyVersion",
      "iam:DeletePolicyVersion",
      "iam:TagPolicy",
      "iam:UntagPolicy",
    ]
    resources = [
      "arn:aws:iam::${local.account_id}:policy${var.iam_path_prefix}*",
    ]
  }

  # Allow managing instance profiles under the path
  statement {
    sid    = "AllowInstanceProfileManagement"
    effect = "Allow"
    actions = [
      "iam:CreateInstanceProfile",
      "iam:DeleteInstanceProfile",
      "iam:GetInstanceProfile",
      "iam:AddRoleToInstanceProfile",
      "iam:RemoveRoleFromInstanceProfile",
      "iam:TagInstanceProfile",
      "iam:UntagInstanceProfile",
    ]
    resources = [
      "arn:aws:iam::${local.account_id}:instance-profile${var.iam_path_prefix}*",
    ]
  }

  # Allow PassRole only for roles under the managed path or to AWS services
  statement {
    sid    = "AllowPassRole"
    effect = "Allow"
    actions = [
      "iam:PassRole",
    ]
    resources = [
      "arn:aws:iam::${local.account_id}:role${var.iam_path_prefix}*",
    ]
  }

  # Read-only IAM for introspection (needed by Terraform for data sources)
  statement {
    sid    = "AllowIAMReadOnly"
    effect = "Allow"
    actions = [
      "iam:ListRoles",
      "iam:ListPolicies",
      "iam:ListInstanceProfiles",
      "iam:GetUser",
      "iam:ListUsers",
      "iam:GetAccountSummary",
      "iam:ListOpenIDConnectProviders",
      "iam:GetOpenIDConnectProvider",
      "iam:ListSAMLProviders",
      "iam:GetSAMLProvider",
      "iam:ListServerCertificates",
      "iam:GetServerCertificate",
      "iam:ListServiceLinkedRoles",
    ]
    resources = ["*"]
  }

  # Allow creating service-linked roles (required by many AWS services)
  statement {
    sid    = "AllowServiceLinkedRoles"
    effect = "Allow"
    actions = [
      "iam:CreateServiceLinkedRole",
      "iam:DeleteServiceLinkedRole",
      "iam:GetServiceLinkedRoleDeletionStatus",
    ]
    resources = [
      "arn:aws:iam::${local.account_id}:role/aws-service-role/*",
    ]
  }
}

resource "aws_iam_policy" "iam_management" {
  count = var.enable_self_manage_iam ? 1 : 0

  name        = "${var.role_name}-iam-management"
  description = "IAM management permissions scoped to ${var.iam_path_prefix}"
  path        = "/cicd/"
  policy      = data.aws_iam_policy_document.iam_management[0].json

  tags = local.default_tags
}

resource "aws_iam_role_policy_attachment" "iam_management" {
  count = var.enable_self_manage_iam ? 1 : 0

  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.iam_management[0].arn
}

# --- Guardrails / Deny Policy ---

data "aws_iam_policy_document" "guardrails" {
  # Explicit deny on dangerous actions
  statement {
    sid       = "DenyDangerousActions"
    effect    = "Deny"
    actions   = var.denied_actions
    resources = ["*"]
  }

  # Prevent the CI/CD role from modifying its own role or policies
  statement {
    sid    = "DenySelfModification"
    effect = "Deny"
    actions = [
      "iam:UpdateRole",
      "iam:DeleteRole",
      "iam:AttachRolePolicy",
      "iam:DetachRolePolicy",
      "iam:PutRolePolicy",
      "iam:DeleteRolePolicy",
      "iam:UpdateAssumeRolePolicy",
    ]
    resources = [
      aws_iam_role.cicd.arn,
    ]
  }

  # Prevent modifying the CI/CD policies themselves
  statement {
    sid    = "DenySelfPolicyModification"
    effect = "Deny"
    actions = [
      "iam:CreatePolicyVersion",
      "iam:DeletePolicy",
      "iam:DeletePolicyVersion",
      "iam:SetDefaultPolicyVersion",
    ]
    resources = [
      aws_iam_policy.deployment_permissions.arn,
    ]
  }

  # Prevent privilege escalation - deny creating users or access keys
  statement {
    sid    = "DenyPrivilegeEscalation"
    effect = "Deny"
    actions = [
      "iam:CreateUser",
      "iam:CreateAccessKey",
      "iam:CreateLoginProfile",
      "iam:UpdateLoginProfile",
      "iam:AddUserToGroup",
      "iam:AttachUserPolicy",
      "iam:PutUserPolicy",
      "iam:AttachGroupPolicy",
      "iam:PutGroupPolicy",
      "iam:CreateGroup",
    ]
    resources = ["*"]
  }
}

resource "aws_iam_policy" "guardrails" {
  name        = "${var.role_name}-guardrails"
  description = "Guardrails to prevent dangerous operations"
  path        = "/cicd/"
  policy      = data.aws_iam_policy_document.guardrails.json

  tags = local.default_tags
}

resource "aws_iam_role_policy_attachment" "guardrails" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.guardrails.arn
}

# --- Additional Policy Attachments ---

resource "aws_iam_role_policy_attachment" "additional" {
  for_each = toset(var.additional_policy_arns)

  role       = aws_iam_role.cicd.name
  policy_arn = each.value
}

# --- Outputs ---

output "role_arn" {
  description = "ARN of the CI/CD IAM role"
  value       = aws_iam_role.cicd.arn
}

output "role_name" {
  description = "Name of the CI/CD IAM role"
  value       = aws_iam_role.cicd.name
}

output "role_id" {
  description = "Unique ID of the CI/CD IAM role"
  value       = aws_iam_role.cicd.unique_id
}

output "deployment_policy_arn" {
  description = "ARN of the deployment permissions policy"
  value       = aws_iam_policy.deployment_permissions.arn
}

output "guardrails_policy_arn" {
  description = "ARN of the guardrails deny policy"
  value       = aws_iam_policy.guardrails.arn
}

output "iam_management_policy_arn" {
  description = "ARN of the IAM management policy"
  value       = var.enable_self_manage_iam ? aws_iam_policy.iam_management[0].arn : null
}

output "iam_path_prefix" {
  description = "IAM path prefix for managed resources"
  value       = var.iam_path_prefix
}