# Generated by anthropic (claude-opus-4-6)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

terraform {
  required_version = ">= 1.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  description = "AWS region"
  type        = string
  default     = "us-east-1"
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "production"
}

variable "instance_type" {
  description = "EC2 instance type"
  type        = string
  default     = "t3.medium"
}

variable "min_size" {
  description = "Minimum number of instances in ASG"
  type        = number
  default     = 2
}

variable "max_size" {
  description = "Maximum number of instances in ASG"
  type        = number
  default     = 6
}

variable "desired_capacity" {
  description = "Desired number of instances in ASG"
  type        = number
  default     = 2
}

variable "app_port" {
  description = "Application port"
  type        = number
  default     = 8080
}

variable "backend_database_endpoint" {
  description = "Backend database endpoint"
  type        = string
  default     = "db.internal.example.com"
}

variable "backend_database_port" {
  description = "Backend database port"
  type        = number
  default     = 5432
}

variable "backend_cache_endpoint" {
  description = "Backend cache (Redis) endpoint"
  type        = string
  default     = "cache.internal.example.com"
}

variable "backend_cache_port" {
  description = "Backend cache port"
  type        = number
  default     = 6379
}

variable "backend_api_endpoint" {
  description = "Backend API service endpoint"
  type        = string
  default     = "api.internal.example.com"
}

variable "backend_api_port" {
  description = "Backend API service port"
  type        = number
  default     = 443
}

variable "log_group_name" {
  description = "CloudWatch log group name"
  type        = string
  default     = "/app/backend-connected-instances"
}

variable "key_name" {
  description = "SSH key pair name (optional)"
  type        = string
  default     = ""
}

data "aws_vpc" "default" {
  default = true
}

data "aws_subnets" "default" {
  filter {
    name   = "vpc-id"
    values = [data.aws_vpc.default.id]
  }
}

data "aws_ami" "amazon_linux_2023" {
  most_recent = true
  owners      = ["amazon"]

  filter {
    name   = "name"
    values = ["al2023-ami-*-x86_64"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }

  filter {
    name   = "state"
    values = ["available"]
  }
}

resource "aws_cloudwatch_log_group" "app" {
  name              = var.log_group_name
  retention_in_days = 30

  tags = {
    Environment = var.environment
    Application = "backend-connected-app"
  }
}

resource "aws_iam_role" "instance_role" {
  name = "${var.environment}-app-instance-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      }
    ]
  })

  tags = {
    Environment = var.environment
  }
}

resource "aws_iam_role_policy" "instance_policy" {
  name = "${var.environment}-app-instance-policy"
  role = aws_iam_role.instance_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "logs:CreateLogStream",
          "logs:PutLogEvents",
          "logs:DescribeLogStreams"
        ]
        Resource = "${aws_cloudwatch_log_group.app.arn}:*"
      },
      {
        Effect = "Allow"
        Action = [
          "ssm:GetParameter",
          "ssm:GetParameters",
          "ssm:GetParametersByPath"
        ]
        Resource = "arn:aws:ssm:*:*:parameter/${var.environment}/app/*"
      },
      {
        Effect = "Allow"
        Action = [
          "secretsmanager:GetSecretValue"
        ]
        Resource = "arn:aws:secretsmanager:*:*:secret:${var.environment}/app/*"
      },
      {
        Effect = "Allow"
        Action = [
          "ec2:DescribeTags",
          "ec2:DescribeInstances"
        ]
        Resource = "*"
      },
      {
        Effect = "Allow"
        Action = [
          "autoscaling:CompleteLifecycleAction"
        ]
        Resource = "*"
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "ssm_managed" {
  role       = aws_iam_role.instance_role.name
  policy_arn = "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore"
}

resource "aws_iam_instance_profile" "instance_profile" {
  name = "${var.environment}-app-instance-profile"
  role = aws_iam_role.instance_role.name
}

resource "aws_security_group" "instance_sg" {
  name_prefix = "${var.environment}-app-instance-"
  description = "Security group for application instances"
  vpc_id      = data.aws_vpc.default.id

  ingress {
    description     = "Application port from ALB"
    from_port       = var.app_port
    to_port         = var.app_port
    protocol        = "tcp"
    security_groups = [aws_security_group.alb_sg.id]
  }

  ingress {
    description = "Health check port"
    from_port   = 8081
    to_port     = 8081
    protocol    = "tcp"
    security_groups = [aws_security_group.alb_sg.id]
  }

  egress {
    description = "Database access"
    from_port   = var.backend_database_port
    to_port     = var.backend_database_port
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    description = "Cache access"
    from_port   = var.backend_cache_port
    to_port     = var.backend_cache_port
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    description = "HTTPS outbound for API and package downloads"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    description = "HTTP outbound for package downloads"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    description = "DNS"
    from_port   = 53
    to_port     = 53
    protocol    = "udp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "${var.environment}-app-instance-sg"
    Environment = var.environment
  }

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_security_group" "alb_sg" {
  name_prefix = "${var.environment}-app-alb-"
  description = "Security group for application load balancer"
  vpc_id      = data.aws_vpc.default.id

  ingress {
    description = "HTTPS from internet"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "HTTP from internet (redirect to HTTPS)"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    description = "To instances"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "${var.environment}-app-alb-sg"
    Environment = var.environment
  }

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_ssm_parameter" "db_endpoint" {
  name  = "/${var.environment}/app/database_endpoint"
  type  = "String"
  value = var.backend_database_endpoint

  tags = {
    Environment = var.environment
  }
}

resource "aws_ssm_parameter" "db_port" {
  name  = "/${var.environment}/app/database_port"
  type  = "String"
  value = tostring(var.backend_database_port)

  tags = {
    Environment = var.environment
  }
}

resource "aws_ssm_parameter" "cache_endpoint" {
  name  = "/${var.environment}/app/cache_endpoint"
  type  = "String"
  value = var.backend_cache_endpoint

  tags = {
    Environment = var.environment
  }
}

resource "aws_ssm_parameter" "cache_port" {
  name  = "/${var.environment}/app/cache_port"
  type  = "String"
  value = tostring(var.backend_cache_port)

  tags = {
    Environment = var.environment
  }
}

resource "aws_ssm_parameter" "api_endpoint" {
  name  = "/${var.environment}/app/api_endpoint"
  type  = "String"
  value = var.backend_api_endpoint

  tags = {
    Environment = var.environment
  }
}

resource "aws_ssm_parameter" "api_port" {
  name  = "/${var.environment}/app/api_port"
  type  = "String"
  value = tostring(var.backend_api_port)

  tags = {
    Environment = var.environment
  }
}

locals {
  user_data = <<-USERDATA
#!/bin/bash
set -euo pipefail

# ============================================================
# Boot Configuration Script
# Configures application to connect to backend services
# and become operational immediately upon launch
# ============================================================

exec > >(tee /var/log/user-data.log | logger -t user-data -s 2>/dev/console) 2>&1

echo "========================================="
echo "Starting instance configuration at $(date)"
echo "========================================="

INSTANCE_ID=$(ec2-metadata -i | cut -d' ' -f2 2>/dev/null || curl -s http://169.254.169.254/latest/meta-data/instance-id)
REGION="${var.aws_region}"
ENVIRONMENT="${var.environment}"
APP_PORT="${var.app_port}"

echo "Instance ID: $INSTANCE_ID"
echo "Region: $REGION"
echo "Environment: $ENVIRONMENT"

# ============================================================
# Step 1: System updates and dependencies
# ============================================================
echo "Step 1: Installing dependencies..."

dnf update -y -q
dnf install -y -q \
  amazon-cloudwatch-agent \
  jq \
  nc \
  curl \
  python3 \
  python3-pip

# ============================================================
# Step 2: Fetch backend service configuration from SSM
# ============================================================
echo "Step 2: Fetching backend service configuration from SSM Parameter Store..."

get_ssm_param() {
  aws ssm get-parameter \
    --name "$1" \
    --region "$REGION" \
    --query 'Parameter.Value' \
    --output text
}

DB_ENDPOINT=$(get_ssm_param "/$ENVIRONMENT/app/database_endpoint")
DB_PORT=$(get_ssm_param "/$ENVIRONMENT/app/database_port")
CACHE_ENDPOINT=$(get_ssm_param "/$ENVIRONMENT/app/cache_endpoint")
CACHE_PORT=$(get_ssm_param "/$ENVIRONMENT/app/cache_port")
API_ENDPOINT=$(get_ssm_param "/$ENVIRONMENT/app/api_endpoint")
API_PORT=$(get_ssm_param "/$ENVIRONMENT/app/api_port")

echo "Database: $DB_ENDPOINT:$DB_PORT"
echo "Cache: $CACHE_ENDPOINT:$CACHE_PORT"
echo "API: $API_ENDPOINT:$API_PORT"

# ============================================================
# Step 3: Create application directory structure
# ============================================================
echo "Step 3: Setting up application directories..."

mkdir -p /opt/app/{bin,config,logs,data}
mkdir -p /etc/app

# ============================================================
# Step 4: Generate application configuration
# ============================================================
echo "Step 4: Generating application configuration..."

cat > /etc/app/config.json <<EOF
{
  "environment": "$ENVIRONMENT",
  "instance_id": "$INSTANCE_ID",
  "server": {
    "host": "0.0.0.0",
    "port": $APP_PORT,
    "health_check_port": 8081,
    "read_timeout": 30,
    "write_timeout": 30,
    "idle_timeout": 120
  },
  "database": {
    "host": "$DB_ENDPOINT",
    "port": $DB_PORT,
    "max_connections": 20,
    "min_connections": 5,
    "connection_timeout": 10,
    "idle_timeout": 300,
    "max_lifetime": 1800,
    "retry_attempts": 3,
    "retry_delay": 2
  },
  "cache": {
    "host": "$CACHE_ENDPOINT",
    "port": $CACHE_PORT,
    "max_connections": 10,
    "connection_timeout": 5,
    "read_timeout": 3,
    "write_timeout": 3,
    "retry_attempts": 3,
    "retry_delay": 1
  },
  "api": {
    "endpoint": "https://$API_ENDPOINT:$API_PORT",
    "timeout": 30,
    "retry_attempts": 3,
    "retry_delay": 2,
    "circuit_breaker": {
      "threshold": 5,
      "timeout": 60
    }
  },
  "logging": {
    "level": "info",
    "format": "json",
    "output": "/opt/app/logs/app.log"
  }
}
EOF

chmod 640 /etc/app/config.json

# ============================================================
# Step 5: Configure CloudWatch agent for log shipping
# ============================================================
echo "Step 5: Configuring CloudWatch agent..."

cat > /opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json <<EOF
{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "root"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/opt/app/logs/app.log",
            "log_group_name": "${var.log_group_name}",
            "log_stream_name": "{instance_id}/app",
            "timezone": "UTC",
            "retention_in_days": 30
          },
          {
            "file_path": "/var/log/user-data.log",
            "log_group_name": "${var.log_group_name}",
            "log_stream_name": "{instance_id}/boot",
            "timezone": "UTC",
            "retention_in_days": 30
          }
        ]
      }
    }
  },
  "metrics": {
    "namespace": "App/$ENVIRONMENT",
    "metrics_collected": {
      "cpu": {
        "measurement": ["cpu_usage_active"],
        "metrics_collection_interval": 60
      },
      "mem": {
        "measurement": ["mem_used_percent"],
        "metrics_collection_interval": 60
      },
      "disk": {
        "measurement": ["disk_used_percent"],
        "resources": ["/"],
        "metrics_collection_interval": 60
      }
    },
    "append_dimensions": {
      "InstanceId": "\$${aws:InstanceId}",
      "AutoScalingGroupName": "\$${aws:AutoScalingGroupName}"
    }
  }
}
EOF

/opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl \
  -a fetch-config \
  -m ec2 \
  -s \
  -c file:/opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json

# ============================================================
# Step 6: Backend connectivity verification
# ============================================================
echo "Step 6: Verifying connectivity to backend services..."

wait_for_service() {
  local host=$1
  local port=$2
  local service_name=$3
  local max_attempts=30
  local attempt=1

  echo "Checking connectivity to $service_name ($host:$port)..."

  while [ $attempt -le $max_attempts ]; do
    if nc -z -w 5 "$host" "$port" 2>/dev/null; then
      echo "Successfully connected to $service_name on attempt $attempt"
      return 0
    fi
    echo "Attempt $attempt/$max_attempts: Cannot reach $service_name, retrying in 2s..."
    sleep 2
    attempt=$((attempt + 1))
  done

  echo "ERROR: Failed to connect to $service_name after $max_attempts attempts"
  return 1
}

CONNECTIVITY_OK=true

wait_for_service "$DB_ENDPOINT" "$DB_PORT" "Database" || CONNECTIVITY_OK=false
wait_for_service "$CACHE_ENDPOINT" "$CACHE_PORT" "Cache" || CONNECTIVITY_OK=false

# For HTTPS API endpoint, use curl instead of nc
echo "Checking connectivity to API Service ($API_ENDPOINT:$API_PORT)..."
API_MAX_ATTEMPTS=15
API_ATTEMPT=1
API_OK=false
while [ $API_ATTEMPT -le $API_MAX_ATTEMPTS ]; do
  if curl -sf -o /dev/null --connect-timeout 5 "https://$API_ENDPOINT:$API_PORT/health" 2>/dev/null; then
    echo "Successfully connected to API Service on attempt $API_ATTEMPT"
    API_OK=true
    break
  fi
  echo "Attempt $API_ATTEMPT/$API_MAX_ATTEMPTS: Cannot reach API Service, retrying in 2s..."
  sleep 2
  API_ATTEMPT=$((API_ATTEMPT + 1))
done

if [ "$API_OK" = false ]; then
  echo "WARNING: Could not verify API service health endpoint, but continuing..."
fi

if [ "$CONNECTIVITY_OK" = false ]; then
  echo "ERROR: Backend connectivity checks failed"
  # Still continue - the app has retry logic built in
fi

# ============================================================
# Step 7: Create the application service (simulated app)
# ============================================================
echo "Step 7: Setting up application service..."

cat > /opt/app/bin/health-check-server.py <<'HEALTHEOF'
#!/usr/bin/env python3
"""Simple health check server that verifies backend connectivity."""

import http.server
import json
import socket
import sys
import os

CONFIG_PATH = "/etc/app/config.json"

def check_tcp_connection(host, port, timeout=3):
    try:
        sock = socket.create_connection((host, port), timeout=timeout)
        sock.close()
        return True
    except (socket.timeout, ConnectionRefusedError, OSError):
        return False

class HealthCheckHandler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path == "/health":
            with open(CONFIG_PATH) as f:
                config = json.load(f)

            db_ok = check_tcp_connection(
                config["database"]["host"],
                config["database"]["port"]
            )
            cache_ok = check_tcp_connection(
                config["cache"]["host"],
                config["cache"]["port"]
            )

            healthy = db_ok and cache_ok
            status = {
                "status": "healthy" if healthy else "degraded",
                "instance_id": config["instance_id"],
                "checks": {
                    "database": "ok" if db_ok else "failed",
                    "cache": "ok" if cache_ok else "failed"
                }
            }

            self.send_response(200 if healthy else 503)
            self.send_header("Content-Type", "application/json")
            self.end_headers()
            self.wfile.write(json.dumps(status).encode())
        else:
            self.send_response(404)
            self.end_headers()

    def log_message(self, format, *args):
        pass  # Suppress default logging

if __name__ == "__main__":
    port = 8081
    server = http.server.HTTPServer(("0.0.0.0", port), HealthCheckHandler)
    print(f"Health check server running on port {port}")
    server.serve_forever()
HEALTHEOF

chmod +x /opt/app/bin/health-check-server.py

# ============================================================
# Step 8: Create systemd services
# ============================================================
echo "Step 8: Creating systemd services..."

# Health check service
cat > /etc/systemd/system/app-healthcheck.service <<EOF
[Unit]
Description=Application Health Check Server
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /opt/app/bin/health-check-server.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
EOF

# Main application service (placeholder - replace with actual app)
cat > /etc/systemd/system/app.service <<EOF
[Unit]
Description=Main Application Service
After=network.target app-healthcheck.service
Wants=app-healthcheck.service

[Service]
Type=simple
EnvironmentFile=/etc/app/env
ExecStartPre=/bin/bash -c 'echo "Performing pre-start backend connectivity check..."'
ExecStart=/bin/bash -c 'echo "Application started on port $APP_PORT" && while true; do sleep 3600; done'
Restart=always
RestartSec=10
StandardOutput=append:/opt/app/logs/app.log
StandardError=append:/opt/app/logs/app.log

[Install]
WantedBy=multi-user.target
EOF

# Environment file for the application
cat > /etc/app/env <<EOF
APP_PORT=$APP_PORT
APP_ENVIRONMENT=$ENVIRONMENT
APP_INSTANCE_ID=$INSTANCE_ID
APP_CONFIG_PATH=/etc/app/config.json
DB_HOST=$DB_ENDPOINT
DB_PORT=$DB_PORT
CACHE_HOST=$CACHE_ENDPOINT
CACHE_PORT=$CACHE_PORT
API_ENDPOINT=https://$API_ENDPOINT:$API_PORT
EOF

chmod 640 /etc/app/env

# ============================================================
# Step 9: Configure system tuning for performance
# ============================================================
echo "Step 9: Applying system tuning..."

cat >> /etc/sysctl.d/99-app-tuning.conf <<EOF
net.core.somaxconn = 65535
net.ipv4.tcp_max_syn_backlog = 65535
net.ipv4.tcp_tw_reuse = 1
net.ipv4.tcp_fin_timeout = 15
net.core.netdev_max_backlog = 65535
net.ipv4.tcp_keepalive_time = 300
net.ipv4.tcp_keepalive_intvl = 30
net.ipv4.tcp_keepalive_probes = 5
fs.file-max = 2097152
EOF

sysctl -p /etc/sysctl.d/99-app-tuning.conf

# Set file descriptor limits
cat >> /etc/security/limits.d/99-app.conf <<EOF
* soft nofile 65535
* hard nofile 65535
* soft nproc 65535
* hard nproc 65535
EOF

# ============================================================
# Step 10: Start services
# ============================================================
echo "Step 10: Starting application services..."

systemctl daemon-reload
systemctl enable app-healthcheck.service
systemctl enable app.service
systemctl start app-healthcheck.service
systemctl start app.service

# Wait for health check server to be ready
sleep 3

# ============================================================
# Step 11: Final verification
# ============================================================
echo "Step 11: Final verification..."

HEALTH_RESPONSE=$(curl -sf http://localhost:8081/health || echo '{"status":"unknown"}')
echo "Health check response: $HEALTH_RESPONSE"

HEALTH_STATUS=$(echo "$HEALTH_RESPONSE" | jq -r '.status' 2>/dev/null || echo "unknown")

if [ "$HEALTH_STATUS" = "healthy" ]; then
  echo "========================================="
  echo "Instance is HEALTHY and ready to serve traffic"
  echo "Configuration completed at $(date)"
  echo "========================================="
else
  echo "========================================="
  echo "WARNING: Instance health status is: $HEALTH_STATUS"
  echo "Some backend services may not be reachable"
  echo "The application will retry connections automatically"
  echo "Configuration completed at $(date)"
  echo "========================================="
fi

# Signal that the instance is ready (for lifecycle hooks)
if command -v aws &> /dev/null; then
  ASG_NAME=$(aws ec2 describe-tags \
    --filters "Name=resource-id,Values=$INSTANCE_ID" "Name=key,Values=aws:autoscaling:groupName" \
    --region "$REGION" \
    --query 'Tags[0].Value' \
    --output text 2>/dev/null || echo "")

  if [ -n "$ASG_NAME" ] && [ "$ASG_NAME" != "None" ]; then
    echo "Instance is part of ASG: $ASG_NAME"

    # Complete any pending lifecycle action
    LIFECYCLE_HOOKS=$(aws autoscaling describe-lifecycle-hooks \
      --auto-scaling-group-name "$ASG_NAME" \
      --region "$REGION" \
      --query 'LifecycleHooks[?LifecycleTransition==`autoscaling:EC2_INSTANCE_LAUNCHING`].LifecycleHookName' \
      --output text 2>/dev/null || echo "")

    for HOOK in $LIFECYCLE_HOOKS; do
      echo "Completing lifecycle hook: $HOOK"
      aws autoscaling complete-lifecycle-action \
        --lifecycle-hook-name "$HOOK" \
        --auto-scaling-group-name "$ASG_NAME" \
        --instance-id "$INSTANCE_ID" \
        --lifecycle-action-result CONTINUE \
        --region "$REGION" 2>/dev/null || true
    done
  fi
fi

echo "Boot configuration script completed successfully."
USERDATA
}

resource "aws_launch_template" "app" {
  name_prefix   = "${var.environment}-app-"
  image_id      = data.aws_ami.amazon_linux_2023.id
  instance_type = var.instance_type
  key_name      = var.key_name != "" ? var.key_name : null

  user_data = base64encode(local.user_data)

  iam_instance_profile {
    arn = aws_iam_instance_profile.instance_profile.arn
  }

  network_interfaces {
    associate_public_ip_address = true
    security_groups             = [aws_security_group.instance_sg.id]
  }

  monitoring {
    enabled = true
  }

  metadata_options {
    http_endpoint               = "enabled"
    http_tokens                 = "required"
    http_put_response_hop_limit = 2
    instance_metadata_tags      = "enabled"
  }

  block_device_mappings {
    device_name = "/dev/xvda"
    ebs {
      volume_size           = 30
      volume_type           = "gp3"
      iops                  = 3000
      throughput            = 125
      encrypted             = true
      delete_on_termination = true
    }
  }

  tag_specifications {
    resource_type = "instance"
    tags = {
      Name        = "${var.environment}-app-instance"
      Environment = var.environment
      ManagedBy   = "terraform"
    }
  }

  tag_specifications {
    resource_type = "volume"
    tags = {
      Name        = "${var.environment}-app-volume"
      Environment = var.environment
      ManagedBy   = "terraform"
    }
  }

  tags = {
    Environment = var.environment
  }

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_lb" "app" {
  name               = "${var.environment}-app-alb"
  internal           = false
  load_balancer_type = "application"
  security_groups    = [aws_security_group.alb_sg.id]
  subnets            = data.aws_subnets.default.ids

  enable_deletion_protection = false

  tags = {
    Name        = "${var.environment}-app-alb"
    Environment = var.environment
  }
}

resource "aws_lb_target_group" "app" {
  name     = "${var.environment}-app-tg"
  port     = var.app_port
  protocol = "HTTP"
  vpc_id   = data.aws_vpc.default.id

  health_check {
    enabled             = true
    path                = "/health"
    port                = "8081"
    protocol            = "HTTP"
    healthy_threshold   = 2
    unhealthy_threshold = 3
    timeout             = 5
    interval            = 15
    matcher             = "200"
  }

  deregistration_delay = 30

  tags = {
    Name        = "${var.environment}-app-tg"
    Environment = var.environment
  }
}

resource "aws_lb_listener" "app_http" {
  load_balancer_arn = aws_lb.app.arn
  port              = 80
  protocol          = "HTTP"

  default_action {
    type             = "forward"
    target_group_arn = aws_lb_target_group.app.arn
  }
}

resource "aws_autoscaling_group" "app" {
  name_prefix         = "${var.environment}-app-"
  min_size            = var.min_size
  max_size            = var.max_size
  desired_capacity    = var.desired_capacity
  vpc_zone_identifier = data.aws_subnets.default.ids
  target_group_arns   = [aws_lb_target_group.app.arn]

  health_check_type         = "ELB"
  health_check_grace_period = 180
  default_cooldown          = 300
  wait_for_capacity_timeout = "10m"

  launch_template {
    id      = aws_launch_template.app.id
    version = "$Latest"
  }

  initial_lifecycle_hook {
    name                 = "${var.environment}-app-launch-hook"
    lifecycle_transition = "autoscaling:EC2_INSTANCE_LAUNCHING"
    heartbeat_timeout    = 300
    default_result       = "CONTINUE"
  }

  instance_refresh {
    strategy = "Rolling"
    preferences {
      min_healthy_percentage = 50
      instance_warmup        = 120
    }
  }

  tag {
    key                 = "Name"
    value               = "${var.environment}-app-asg-instance"
    propagate_at_launch = true
  }

  tag {
    key                 = "Environment"
    value               = var.environment
    propagate_at_launch = true
  }

  tag {
    key                 = "ManagedBy"
    value               = "terraform"
    propagate_at_launch = true
  }

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_autoscaling_policy" "scale_up" {
  name                   = "${var.environment}-app-scale-up"
  autoscaling_group_name = aws_autoscaling_group.app.name
  policy_type            = "TargetTrackingScaling"

  target_tracking_configuration {
    predefined_metric_specification {
      predefined_metric_type = "ASGAverageCPUUtilization"
    }
    target_value = 70.0
  }
}

resource "aws_autoscaling_policy" "scale_on_requests" {
  name                   = "${var.environment}-app-scale-requests"
  autoscaling_group_name = aws_autoscaling_group.app.name
  policy_type            = "TargetTrackingScaling"

  target_tracking_configuration {
    predefined_metric_specification {
      predefined_metric_type = "ALBRequestCountPerTarget"
      resource_label         = "${aws_lb.app.arn_suffix}/${aws_lb_target_group.app.arn_suffix}"
    }
    target_value = 1000.0
  }
}

output "alb_dns_name" {
  description = "DNS name of the Application Load Balancer"
  value       = aws_lb.app.dns_name
}

output "asg_name" {
  description = "Name of the Auto Scaling Group"
  value       = aws_autoscaling_group.app.name
}

output "launch_template_id" {
  description = "ID of the launch template"
  value       = aws_launch_template.app.id
}

output "launch_template_latest_version" {
  description = "Latest version of the launch template"
  value       = aws_launch_template.app.latest_version
}

output "instance_security_group_id" {
  description = "Security group ID for instances"
  value       = aws_security_group.instance_sg.id
}

output "instance_role_arn" {
  description = "ARN of the instance IAM role"
  value       = aws_iam_role.instance_role.arn
}

output "cloudwatch_log_group" {
  description = "CloudWatch log group for application logs"
  value       = aws_cloudwatch_log_group.app.name
}