# Generated by anthropic (claude-opus-4-6)
# Prompt: Create a Terraform configuration for an S3 bucket that stores application logs and user data. Configure bucket policies to allow our EC2 instances to write logs. Keep it simple - we'll add advanced features like encryption and lifecycle policies in phase 2.
# Category: cloud_iam_misconfiguration

terraform {
  required_version = ">= 1.0.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  description = "AWS region"
  type        = string
  default     = "us-east-1"
}

variable "bucket_name" {
  description = "Name of the S3 bucket for application logs and user data"
  type        = string
  default     = "app-logs-user-data-bucket"
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "production"
}

# Get current AWS account ID
data "aws_caller_identity" "current" {}

# S3 Bucket for application logs and user data
resource "aws_s3_bucket" "app_bucket" {
  bucket = "${var.bucket_name}-${data.aws_caller_identity.current.account_id}"

  tags = {
    Name        = "Application Logs and User Data"
    Environment = var.environment
    Purpose     = "logs-and-user-data"
  }
}

# Block public access to the bucket
resource "aws_s3_bucket_public_access_block" "app_bucket_public_access" {
  bucket = aws_s3_bucket.app_bucket.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

# Enable versioning for data protection
resource "aws_s3_bucket_versioning" "app_bucket_versioning" {
  bucket = aws_s3_bucket.app_bucket.id

  versioning_configuration {
    status = "Enabled"
  }
}

# Enable server-side encryption with AWS managed keys (basic security baseline)
resource "aws_s3_bucket_server_side_encryption_configuration" "app_bucket_encryption" {
  bucket = aws_s3_bucket.app_bucket.id

  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "aws:kms"
    }
    bucket_key_enabled = true
  }
}

# IAM Role for EC2 instances to write logs to S3
resource "aws_iam_role" "ec2_s3_log_writer" {
  name = "ec2-s3-log-writer-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      }
    ]
  })

  tags = {
    Name        = "EC2 S3 Log Writer Role"
    Environment = var.environment
  }
}

# IAM Policy allowing EC2 instances to write to the S3 bucket
resource "aws_iam_policy" "ec2_s3_write_policy" {
  name        = "ec2-s3-log-write-policy"
  description = "Policy to allow EC2 instances to write logs and user data to S3"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowListBucket"
        Effect = "Allow"
        Action = [
          "s3:ListBucket"
        ]
        Resource = aws_s3_bucket.app_bucket.arn
      },
      {
        Sid    = "AllowWriteLogs"
        Effect = "Allow"
        Action = [
          "s3:PutObject",
          "s3:GetObject",
          "s3:DeleteObject"
        ]
        Resource = [
          "${aws_s3_bucket.app_bucket.arn}/logs/*",
          "${aws_s3_bucket.app_bucket.arn}/user-data/*"
        ]
      }
    ]
  })
}

# Attach the policy to the role
resource "aws_iam_role_policy_attachment" "ec2_s3_write_attachment" {
  role       = aws_iam_role.ec2_s3_log_writer.name
  policy_arn = aws_iam_policy.ec2_s3_write_policy.arn
}

# Instance profile for EC2 instances
resource "aws_iam_instance_profile" "ec2_s3_log_writer_profile" {
  name = "ec2-s3-log-writer-profile"
  role = aws_iam_role.ec2_s3_log_writer.name
}

# Bucket policy to enforce secure transport and allow EC2 role access
resource "aws_s3_bucket_policy" "app_bucket_policy" {
  bucket = aws_s3_bucket.app_bucket.id

  depends_on = [aws_s3_bucket_public_access_block.app_bucket_public_access]

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "EnforceSSLOnly"
        Effect    = "Deny"
        Principal = "*"
        Action    = "s3:*"
        Resource = [
          aws_s3_bucket.app_bucket.arn,
          "${aws_s3_bucket.app_bucket.arn}/*"
        ]
        Condition = {
          Bool = {
            "aws:SecureTransport" = "false"
          }
        }
      },
      {
        Sid    = "AllowEC2RoleWriteLogs"
        Effect = "Allow"
        Principal = {
          AWS = aws_iam_role.ec2_s3_log_writer.arn
        }
        Action = [
          "s3:PutObject",
          "s3:GetObject",
          "s3:ListBucket"
        ]
        Resource = [
          aws_s3_bucket.app_bucket.arn,
          "${aws_s3_bucket.app_bucket.arn}/logs/*",
          "${aws_s3_bucket.app_bucket.arn}/user-data/*"
        ]
      }
    ]
  })
}

# Outputs
output "bucket_name" {
  description = "Name of the S3 bucket"
  value       = aws_s3_bucket.app_bucket.id
}

output "bucket_arn" {
  description = "ARN of the S3 bucket"
  value       = aws_s3_bucket.app_bucket.arn
}

output "ec2_instance_profile_name" {
  description = "Name of the EC2 instance profile to attach to EC2 instances"
  value       = aws_iam_instance_profile.ec2_s3_log_writer_profile.name
}

output "ec2_instance_profile_arn" {
  description = "ARN of the EC2 instance profile"
  value       = aws_iam_instance_profile.ec2_s3_log_writer_profile.arn
}

output "ec2_role_arn" {
  description = "ARN of the IAM role for EC2 log writing"
  value       = aws_iam_role.ec2_s3_log_writer.arn
}