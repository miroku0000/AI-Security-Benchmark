# Generated by anthropic (claude-opus-4-6)
# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

data "aws_caller_identity" "current" {}
data "aws_region" "current" {}

# KMS key for encrypting Lambda environment variables and related resources
resource "aws_kms_key" "lambda_encryption" {
  description             = "KMS key for encrypting Lambda functions processing financial data"
  deletion_window_in_days = 30
  enable_key_rotation     = true

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "EnableRootAccountAccess"
        Effect = "Allow"
        Principal = {
          AWS = "arn:aws:iam::${data.aws_caller_identity.current.account_id}:root"
        }
        Action   = "kms:*"
        Resource = "*"
      },
      {
        Sid    = "AllowLambdaServiceAccess"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
        Action = [
          "kms:Decrypt",
          "kms:DescribeKey"
        ]
        Resource = "*"
      },
      {
        Sid    = "AllowCloudWatchLogs"
        Effect = "Allow"
        Principal = {
          Service = "logs.${data.aws_region.current.name}.amazonaws.com"
        }
        Action = [
          "kms:Encrypt",
          "kms:Decrypt",
          "kms:GenerateDataKey*",
          "kms:DescribeKey"
        ]
        Resource = "*"
      }
    ]
  })

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
    DataClass   = "financial-sensitive"
  }
}

resource "aws_kms_alias" "lambda_encryption" {
  name          = "alias/payment-processing-lambda-${var.environment}"
  target_key_id = aws_kms_key.lambda_encryption.key_id
}

# CloudWatch Log Groups with encryption and retention
resource "aws_cloudwatch_log_group" "payment_validator" {
  name              = "/aws/lambda/${var.environment}-payment-validator"
  retention_in_days = 365
  kms_key_id        = aws_kms_key.lambda_encryption.arn

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
  }
}

resource "aws_cloudwatch_log_group" "transaction_processor" {
  name              = "/aws/lambda/${var.environment}-transaction-processor"
  retention_in_days = 365
  kms_key_id        = aws_kms_key.lambda_encryption.arn

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
  }
}

resource "aws_cloudwatch_log_group" "settlement_handler" {
  name              = "/aws/lambda/${var.environment}-settlement-handler"
  retention_in_days = 365
  kms_key_id        = aws_kms_key.lambda_encryption.arn

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
  }
}

# Dead letter queue for failed Lambda invocations
resource "aws_sqs_queue" "lambda_dlq" {
  name                              = "${var.environment}-payment-lambda-dlq"
  message_retention_seconds         = 1209600 # 14 days
  kms_master_key_id                 = aws_kms_key.lambda_encryption.id
  kms_data_key_reuse_period_seconds = 300

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
  }
}

# VPC configuration for Lambda (financial data should run in private subnets)
resource "aws_security_group" "lambda_sg" {
  name_prefix = "${var.environment}-payment-lambda-"
  description = "Security group for payment processing Lambda functions"
  vpc_id      = var.vpc_id

  egress {
    description = "HTTPS outbound for API calls"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = var.allowed_egress_cidrs
  }

  egress {
    description     = "Database access"
    from_port       = 5432
    to_port         = 5432
    protocol        = "tcp"
    security_groups = var.database_security_group_ids
  }

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
  }

  lifecycle {
    create_before_destroy = true
  }
}

# ===== IAM Role: Payment Validator =====
resource "aws_iam_role" "payment_validator" {
  name = "${var.environment}-payment-validator-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
        Condition = {
          StringEquals = {
            "aws:SourceAccount" = data.aws_caller_identity.current.account_id
          }
        }
      }
    ]
  })

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
  }
}

resource "aws_iam_role_policy" "payment_validator_core" {
  name = "${var.environment}-payment-validator-core"
  role = aws_iam_role.payment_validator.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "CloudWatchLogs"
        Effect = "Allow"
        Action = [
          "logs:CreateLogStream",
          "logs:PutLogEvents"
        ]
        Resource = "${aws_cloudwatch_log_group.payment_validator.arn}:*"
      },
      {
        Sid    = "KMSDecrypt"
        Effect = "Allow"
        Action = [
          "kms:Decrypt",
          "kms:DescribeKey"
        ]
        Resource = aws_kms_key.lambda_encryption.arn
      },
      {
        Sid    = "DLQAccess"
        Effect = "Allow"
        Action = [
          "sqs:SendMessage"
        ]
        Resource = aws_sqs_queue.lambda_dlq.arn
      },
      {
        Sid    = "VPCNetworkInterfaces"
        Effect = "Allow"
        Action = [
          "ec2:CreateNetworkInterface",
          "ec2:DescribeNetworkInterfaces",
          "ec2:DeleteNetworkInterface"
        ]
        Resource = "*"
        Condition = {
          StringEquals = {
            "ec2:Vpc" = "arn:aws:ec2:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:vpc/${var.vpc_id}"
          }
        }
      },
      {
        Sid    = "DynamoDBAccess"
        Effect = "Allow"
        Action = [
          "dynamodb:GetItem",
          "dynamodb:Query"
        ]
        Resource = [
          var.payment_rules_table_arn,
          "${var.payment_rules_table_arn}/index/*"
        ]
      },
      {
        Sid    = "SecretsManagerReadOnly"
        Effect = "Allow"
        Action = [
          "secretsmanager:GetSecretValue"
        ]
        Resource = var.payment_gateway_secret_arn
      }
    ]
  })
}

