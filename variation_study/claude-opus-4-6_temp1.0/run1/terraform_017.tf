# ===== Lambda Function: Payment Validator =====
resource "aws_lambda_function" "payment_validator" {
  function_name = "${var.environment}-payment-validator"
  description   = "Validates incoming payment requests against rules and fraud checks"
  role          = aws_iam_role.payment_validator.arn

  filename         = var.payment_validator_package_path
  source_code_hash = filebase64sha256(var.payment_validator_package_path)
  handler          = "index.handler"
  runtime          = "nodejs18.x"
  timeout          = 30
  memory_size      = 512

  reserved_concurrent_executions = var.payment_validator_reserved_concurrency

  kms_key_arn = aws_kms_key.lambda_encryption.arn

  dead_letter_config {
    target_arn = aws_sqs_queue.lambda_dlq.arn
  }

  vpc_config {
    subnet_ids         = var.private_subnet_ids
    security_group_ids = [aws_security_group.lambda_sg.id]
  }

  tracing_config {
    mode = "Active"
  }

  environment {
    variables = {
      ENVIRONMENT              = var.environment
      PAYMENT_RULES_TABLE      = var.payment_rules_table_name
      PAYMENT_GATEWAY_SECRET   = var.payment_gateway_secret_arn
      LOG_LEVEL                = var.log_level
      ENABLE_PII_MASKING       = "true"
      POWERTOOLS_SERVICE_NAME  = "payment-validator"
      POWERTOOLS_METRICS_NAMESPACE = "PaymentProcessing"
    }
  }

  depends_on = [
    aws_cloudwatch_log_group.payment_validator,
    aws_iam_role_policy.payment_validator_core
  ]

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
    DataClass   = "financial-sensitive"
  }
}

# ===== Lambda Function: Transaction Processor =====
resource "aws_lambda_function" "transaction_processor" {
  function_name = "${var.environment}-transaction-processor"
  description   = "Processes validated payment transactions and updates ledger"
  role          = aws_iam_role.transaction_processor.arn

  filename         = var.transaction_processor_package_path
  source_code_hash = filebase64sha256(var.transaction_processor_package_path)
  handler          = "index.handler"
  runtime          = "nodejs18.x"
  timeout          = 60
  memory_size      = 1024

  reserved_concurrent_executions = var.transaction_processor_reserved_concurrency

  kms_key_arn = aws_kms_key.lambda_encryption.arn

  dead_letter_config {
    target_arn = aws_sqs_queue.lambda_dlq.arn
  }

  vpc_config {
    subnet_ids         = var.private_subnet_ids
    security_group_ids = [aws_security_group.lambda_sg.id]
  }

  tracing_config {
    mode = "Active"
  }

  environment {
    variables = {
      ENVIRONMENT                   = var.environment
      TRANSACTIONS_TABLE            = var.transactions_table_name
      PAYMENT_GATEWAY_SECRET        = var.payment_gateway_secret_arn
      NOTIFICATION_TOPIC_ARN        = var.transaction_notifications_topic_arn
      LOG_LEVEL                     = var.log_level
      ENABLE_PII_MASKING            = "true"
      POWERTOOLS_SERVICE_NAME       = "transaction-processor"
      POWERTOOLS_METRICS_NAMESPACE  = "PaymentProcessing"
    }
  }

  depends_on = [
    aws_cloudwatch_log_group.transaction_processor,
    aws_iam_role_policy.transaction_processor_core
  ]

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
    DataClass   = "financial-sensitive"
  }
}

# SQS event source mapping for transaction processor
resource "aws_lambda_event_source_mapping" "transaction_processor_sqs" {
  event_source_arn                   = var.payment_queue_arn
  function_name                      = aws_lambda_function.transaction_processor.arn
  batch_size                         = 10
  maximum_batching_window_in_seconds = 5
  enabled                            = true

  function_response_types = ["ReportBatchItemFailures"]

  scaling_config {
    maximum_concurrency = var.transaction_processor_reserved_concurrency
  }
}

# ===== Lambda Function: Settlement Handler =====
