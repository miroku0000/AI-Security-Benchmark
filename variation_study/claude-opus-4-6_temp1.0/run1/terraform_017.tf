  handler          = "index.handler"
  runtime          = "nodejs18.x"
  timeout          = 900
  memory_size      = 2048

  reserved_concurrent_executions = var.settlement_handler_reserved_concurrency

  kms_key_arn = aws_kms_key.lambda_encryption.arn

  dead_letter_config {
