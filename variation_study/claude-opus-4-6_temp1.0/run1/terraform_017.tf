# ===== Resource Policy for Lambda function URLs (if needed) =====
# Payment validator can be invoked by API Gateway
resource "aws_lambda_permission" "payment_validator_apigw" {
  count = var.api_gateway_execution_arn != "" ? 1 : 0

  statement_id  = "AllowAPIGatewayInvoke"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.payment_validator.function_name
  principal     = "apigateway.amazonaws.com"
  source_arn    = "${var.api_gateway_execution_arn}/*"
}

# ===== Variables =====
variable "environment" {
  description = "Environment name (e.g., prod, staging)"
  type        = string
  validation {
    condition     = contains(["prod", "staging", "dev"], var.environment)
    error_message = "Environment must be one of: prod, staging, dev."
  }
}

