# EventBridge rule for scheduled settlement processing
resource "aws_cloudwatch_event_rule" "settlement_schedule" {
  name                = "${var.environment}-settlement-schedule"
  description         = "Triggers daily settlement processing"
  schedule_expression = var.settlement_schedule_expression

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
  }
}

resource "aws_cloudwatch_event_target" "settlement_lambda" {
  rule      = aws_cloudwatch_event_rule.settlement_schedule.name
  target_id = "settlement-handler"
  arn       = aws_lambda_function.settlement_handler.arn
}

resource "aws_lambda_permission" "settlement_eventbridge" {
  statement_id  = "AllowEventBridgeInvoke"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.settlement_handler.function_name
  principal     = "events.amazonaws.com"
  source_arn    = aws_cloudwatch_event_rule.settlement_schedule.arn
}

# ===== CloudWatch Alarms - Critical alerts for financial processing =====
# NOTE: While comprehensive dashboards are planned for a future sprint,
# critical alarms for a payment processing system MUST be deployed from day one.
# Financial data processing without error/failure alerting poses operational
# and compliance risks.

resource "aws_sns_topic" "payment_alerts" {
  name              = "${var.environment}-payment-critical-alerts"
  kms_master_key_id = aws_kms_key.lambda_encryption.id

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
  }
}

resource "aws_cloudwatch_metric_alarm" "payment_validator_errors" {
  alarm_name          = "${var.environment}-payment-validator-errors"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 1
  metric_name         = "Errors"
  namespace           = "AWS/Lambda"
  period              = 300
  statistic           = "Sum"
  threshold           = 5
  alarm_description   = "Payment validator Lambda errors exceeded threshold"
  treat_missing_data  = "notBreaching"

  dimensions = {
    FunctionName = aws_lambda_function.payment_validator.function_name
  }

  alarm_actions = [aws_sns_topic.payment_alerts.arn]
  ok_actions    = [aws_sns_topic.payment_alerts.arn]

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
  }
}

resource "aws_cloudwatch_metric_alarm" "transaction_processor_errors" {
  alarm_name          = "${var.environment}-transaction-processor-errors"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 1
  metric_name         = "Errors"
  namespace           = "AWS/Lambda"
  period              = 300
  statistic           = "Sum"
  threshold           = 3
  alarm_description   = "Transaction processor Lambda errors exceeded threshold"
  treat_missing_data  = "notBreaching"

  dimensions = {
    FunctionName = aws_lambda_function.transaction_processor.function_name
  }

  alarm_actions = [aws_sns_topic.payment_alerts.arn]
