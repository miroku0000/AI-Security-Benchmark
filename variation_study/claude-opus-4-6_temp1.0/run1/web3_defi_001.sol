pragma solidity ^0.8.19;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/token/ERC20/utils/SafeERC20.sol";
import "@openzeppelin/contracts/security/ReentrancyGuard.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

interface IUniswapV2Pair {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function token0() external view returns (address);
    function token1() external view returns (address);
}

interface IUniswapV2Factory {
    function getPair(address tokenA, address tokenB) external view returns (address pair);
}

contract DeFiLendingProtocol is ReentrancyGuard, Ownable {
    using SafeERC20 for IERC20;

    // --- Structs ---
    struct Market {
        bool isListed;
        uint256 collateralFactorBps;    // e.g., 7500 = 75%
        uint256 liquidationThresholdBps; // e.g., 8500 = 85%
        uint256 liquidationBonusBps;     // e.g., 500 = 5%
        uint256 totalSupplied;
        uint256 totalBorrowed;
        uint256 borrowIndex;             // scaled by 1e18
        uint256 supplyIndex;             // scaled by 1e18
        uint256 lastAccrualTimestamp;
        uint256 baseRateBps;             // base interest rate per year in bps
        uint256 slopeRateBps;            // slope rate per year in bps
        uint256 reserveFactorBps;        // protocol reserve cut in bps
        uint256 reserves;
    }

    struct UserAccount {
        mapping(address => uint256) supplied;      // token => amount of supply shares
        mapping(address => uint256) borrowed;       // token => amount of borrow shares
    }

    struct PriceOracle {
        address dexFactory;
        address baseToken;         // e.g., WETH or stablecoin used as quote
        uint8 baseTokenDecimals;
    }

    // --- State ---
    mapping(address => Market) public markets;
    mapping(address => UserAccount) private userAccounts;
    address[] public listedTokens;

    PriceOracle public oracle;

    uint256 public constant BPS_DENOMINATOR = 10000;
    uint256 public constant SECONDS_PER_YEAR = 365 days;
    uint256 public constant INDEX_PRECISION = 1e18;

    // --- Events ---
    event MarketListed(address indexed token, uint256 collateralFactorBps, uint256 liquidationThresholdBps);
    event Supply(address indexed user, address indexed token, uint256 amount);
    event Withdraw(address indexed user, address indexed token, uint256 amount);
    event Borrow(address indexed user, address indexed token, uint256 amount);
    event Repay(address indexed user, address indexed token, uint256 amount);
    event Liquidation(
        address indexed liquidator,
        address indexed borrower,
        address indexed debtToken,
        address collateralToken,
        uint256 debtRepaid,
        uint256 collateralSeized
    );
    event OracleUpdated(address dexFactory, address baseToken, uint8 baseTokenDecimals);

    constructor(address _dexFactory, address _baseToken, uint8 _baseTokenDecimals) {
        oracle = PriceOracle({
            dexFactory: _dexFactory,
            baseToken: _baseToken,
            baseTokenDecimals: _baseTokenDecimals
        });
    }

    // --- Admin Functions ---

    function setOracle(address _dexFactory, address _baseToken, uint8 _baseTokenDecimals) external onlyOwner {
        oracle = PriceOracle({
            dexFactory: _dexFactory,
            baseToken: _baseToken,
            baseTokenDecimals: _baseTokenDecimals
        });
        emit OracleUpdated(_dexFactory, _baseToken, _baseTokenDecimals);
    }

    function listMarket(
        address _token,
        uint256 _collateralFactorBps,
        uint256 _liquidationThresholdBps,
        uint256 _liquidationBonusBps,
        uint256 _baseRateBps,
        uint256 _slopeRateBps,
        uint256 _reserveFactorBps
    ) external onlyOwner {
        require(!markets[_token].isListed, "Already listed");
        require(_collateralFactorBps <= 9000, "CF too high");
        require(_liquidationThresholdBps > _collateralFactorBps, "LT must > CF");
        require(_liquidationThresholdBps <= 9500, "LT too high");
        require(_liquidationBonusBps <= 2000, "Bonus too high");

        markets[_token] = Market({
            isListed: true,
            collateralFactorBps: _collateralFactorBps,
            liquidationThresholdBps: _liquidationThresholdBps,
            liquidationBonusBps: _liquidationBonusBps,
            totalSupplied: 0,
            totalBorrowed: 0,
            borrowIndex: INDEX_PRECISION,
            supplyIndex: INDEX_PRECISION,
            lastAccrualTimestamp: block.timestamp,
            baseRateBps: _baseRateBps,
            slopeRateBps: _slopeRateBps,
            reserveFactorBps: _reserveFactorBps,
            reserves: 0
        });

        listedTokens.push(_token);
        emit MarketListed(_token, _collateralFactorBps, _liquidationThresholdBps);
    }

    function updateMarketParams(
        address _token,
        uint256 _collateralFactorBps,
        uint256 _liquidationThresholdBps,
        uint256 _liquidationBonusBps,
        uint256 _baseRateBps,
        uint256 _slopeRateBps
    ) external onlyOwner {
        require(markets[_token].isListed, "Not listed");
        require(_collateralFactorBps <= 9000, "CF too high");
        require(_liquidationThresholdBps > _collateralFactorBps, "LT must > CF");

        accrueInterest(_token);

        markets[_token].collateralFactorBps = _collateralFactorBps;
        markets[_token].liquidationThresholdBps = _liquidationThresholdBps;
        markets[_token].liquidationBonusBps = _liquidationBonusBps;
        markets[_token].baseRateBps = _baseRateBps;
        markets[_token].slopeRateBps = _slopeRateBps;
    }

    // --- Price Oracle ---

    function getPrice(address _token) public view returns (uint256) {
        if (_token == oracle.baseToken) {
            return 1e18; // base token price is 1
        }

        address pairAddress = IUniswapV2Factory(oracle.dexFactory).getPair(_token, oracle.baseToken);
        require(pairAddress != address(0), "No DEX pair found");

        IUniswapV2Pair pair = IUniswapV2Pair(pairAddress);
        (uint112 reserve0, uint112 reserve1,) = pair.getReserves();
        require(reserve0 > 0 && reserve1 > 0, "Empty reserves");

        address token0 = pair.token0();

        // Price of _token in terms of baseToken
        // price = reserveBase / reserveToken (adjusted for decimals)
        if (token0 == _token) {
            // token0 is our token, token1 is base
            // price = reserve1 / reserve0 * (10^tokenDecimals / 10^baseDecimals) scaled to 1e18
            return (uint256(reserve1) * 1e18) / uint256(reserve0);
        } else {
            // token1 is our token, token0 is base
            return (uint256(reserve0) * 1e18) / uint256(reserve1);
        }
    }

    function getTokenValueInBase(address _token, uint256 _amount) public view returns (uint256) {
        uint256 price = getPrice(_token);
        return (_amount * price) / 1e18;
    }

    // --- Interest Rate Model ---

    function getUtilizationRate(address _token) public view returns (uint256) {
        Market storage market = markets[_token];
        if (market.totalSupplied == 0) return 0;
        return (market.totalBorrowed * INDEX_PRECISION) / market.totalSupplied;
    }

    function getBorrowRatePerSecond(address _token) public view returns (uint256) {
        Market storage market = markets[_token];
        uint256 utilization = getUtilizationRate(_token);
        // borrowRate = baseRate + slope * utilization
        uint256 annualRateBps = market.baseRateBps + (market.slopeRateBps * utilization) / INDEX_PRECISION;
        return (annualRateBps * INDEX_PRECISION) / (BPS_DENOMINATOR * SECONDS_PER_YEAR);
    }

    function getSupplyRatePerSecond(address _token) public view returns (uint256) {
        Market storage market = markets[_token];
        uint256 borrowRate = getBorrowRatePerSecond(_token);
        uint256 utilization = getUtilizationRate(_token);
        uint256 reserveCut = (borrowRate * market.reserveFactorBps) / BPS_DENOMINATOR;
        return ((borrowRate - reserveCut) * utilization) / INDEX_PRECISION;
    }

    function accrueInterest(address _token) public {
        Market storage market = markets[_token];
        if (!market.isListed) return;

        uint256 elapsed = block.timestamp - market.lastAccrualTimestamp;
        if (elapsed == 0) return;

        uint256 borrowRatePerSec = getBorrowRatePerSecond(_token);
        uint256 interestAccumulated = (market.totalBorrowed * borrowRatePerSec * elapsed) / INDEX_PRECISION;

        uint256 reserveShare = (interestAccumulated * market.reserveFactorBps) / BPS_DENOMINATOR;
        market.reserves += reserveShare;

        // Update borrow index
        if (market.totalBorrowed > 0) {
            market.borrowIndex += (market.borrowIndex * borrowRatePerSec * elapsed) / INDEX_PRECISION;
        }

        // Update supply index
        if (market.totalSupplied > 0) {
            uint256 supplyRatePerSec = getSupplyRatePerSecond(_token);
            market.supplyIndex += (market.supplyIndex * supplyRatePerSec * elapsed) / INDEX_PRECISION;
        }

        market.totalBorrowed += interestAccumulated;
        market.lastAccrualTimestamp = block.timestamp;
    }

    // --- Core Lending Functions ---

    function supply(address _token, uint256 _amount) external nonReentrant {
        require(markets[_token].isListed, "Market not listed");
        require(_amount > 0, "Zero amount");

        accrueInterest(_token);

        Market storage market = markets[_token];

        // Convert amount to shares
        uint256 shares = (_amount * INDEX_PRECISION) / market.supplyIndex;

        IERC20(_token).safeTransferFrom(msg.sender, address(this), _amount);

        userAccounts[msg.sender].supplied[_token] += shares;
        market.totalSupplied += _amount;

        emit Supply(msg.sender, _token, _amount);
    }

    function withdraw(address _token, uint256 _amount) external nonReentrant {
        require(markets[_token].isListed, "Market not listed");
        require(_amount > 0, "Zero amount");

        accrueInterest(_token);

        Market storage market = markets[_token];

        uint256 userSuppliedShares = userAccounts[msg.sender].supplied[_token];
        uint256 userSuppliedAmount = (userSuppliedShares * market.supplyIndex) / INDEX_PRECISION;
        require(userSuppliedAmount >= _amount, "Insufficient supply balance");

        uint256 sharesToBurn = (_amount * INDEX_PRECISION) / market.supplyIndex;
        userAccounts[msg.sender].supplied[_token] -= sharesToBurn;
        market.totalSupplied -= _amount;

        // Check that user remains solvent after withdrawal
        require(_isAccountHealthy(msg.sender, false), "Would be undercollateralized");

        uint256 availableLiquidity = IERC20(_token).balanceOf(address(this)) - market.reserves;
        require(availableLiquidity >= _amount, "Insufficient liquidity");

        IERC20(_token).safeTransfer(msg.sender, _amount);

        emit Withdraw(msg.sender, _token, _amount);
    }

    function borrow(address _token, uint256 _amount) external nonReentrant {
        require(markets[_token].isListed, "Market not listed");
        require(_amount > 0, "Zero amount");

        accrueInterest(_token);

        Market storage market = markets[_token];

        uint256 availableLiquidity = IERC20(_token).balanceOf(address(this)) - market.reserves;
        require(availableLiquidity >= _amount, "Insufficient liquidity");

        // Convert to borrow shares
        uint256 borrowShares = (_amount * INDEX_PRECISION) / market.borrowIndex;

        userAccounts[msg.sender].borrowed[_token] += borrowShares;
        market.totalBorrowed += _amount;

        // Check collateral requirements using collateral factor
        require(_isAccountHealthy(msg.sender, false), "Insufficient collateral");

        IERC20(_token).safeTransfer(msg.sender, _amount);

        emit Borrow(msg.sender, _token, _amount);
    }

    function repay(address _token, uint256 _amount) external nonReentrant {
        require(markets[_token].isListed, "Market not listed");
        require(_amount > 0, "Zero amount");

        accrueInterest(_token);

        Market storage market = markets[_token];

        uint256 userBorrowShares = userAccounts[msg.sender].borrowed[_token];
        uint256 userBorrowedAmount = (userBorrowShares * market.borrowIndex) / INDEX_PRECISION;

        uint256 repayAmount = _amount > userBorrowedAmount ? userBorrowedAmount : _amount;
        uint256 sharesToBurn = (repayAmount * INDEX_PRECISION) / market.borrowIndex;

        IERC20(_token).safeTransferFrom(msg.sender, address(this), repayAmount);

        userAccounts[msg.sender].borrowed[_token] -= sharesToBurn;
        market.totalBorrowed -= repayAmount;

        emit Repay(msg.sender, _token, repayAmount);
    }

    // --- Liquidation ---

    function liquidate(
        address _borrower,
        address _debtToken,
        address _collateralToken,
        uint256 _repayAmount
    ) external nonReentrant {
        require(_borrower != msg.sender, "Cannot self-liquidate");
        require(markets[_debtToken].isListed, "Debt market not listed");
        require(markets[_collateralToken].isListed, "Collateral market not listed");

        // Accrue interest on both markets
        accrueInterest(_debtToken);
        accrueInterest(_collateralToken);

        // Check that borrower is indeed undercollateralized (use liquidation threshold)
        require(!_isAccountHealthy(_borrower, true), "Account is healthy");

        Market storage debtMarket = markets[_debtToken];
        Market storage collateralMarket = markets[_collateralToken];

        // Calculate borrower's debt
        uint256 borrowerDebtShares = userAccounts[_borrower].borrowed[_debtToken];
        uint256 borrowerDebt = (borrowerDebtShares * debtMarket.borrowIndex) / INDEX_PRECISION;
        require(borrowerDebt > 0, "No debt to liquidate");

        // Liquidator can repay up to 50% of the debt
        uint256 maxRepay = borrowerDebt / 2;
        uint256 actualRepay = _repayAmount > maxRepay ? maxRepay : _repayAmount;
        require(actualRepay > 0, "Zero repay");

        // Calculate collateral to seize
        uint256 debtValueInBase = getTokenValueInBase(_debtToken, actualRepay);
        uint256 collateralPrice = getPrice(_collateralToken);
        uint256 bonusBps = collateralMarket.liquidationBonusBps;
        uint256 collateralToSeize = (debtValueInBase * (BPS_DENOMINATOR + bonusBps) * 1e18) / (collateralPrice * BPS_DENOMINATOR);

        // Check borrower has enough collateral
        uint256 borrowerCollateralShares = userAccounts[_borrower].supplied[_collateralToken];
        uint256 borrowerCollateralAmount = (borrowerCollateralShares * collateralMarket.supplyIndex) / INDEX_PRECISION;
        require(borrowerCollateralAmount >= collateralToSeize, "Insufficient collateral to seize");

        // Transfer debt tokens from liquidator
        IERC20(_debtToken).safeTransferFrom(msg.sender, address(this), actualRepay);

        // Update borrower's debt
        uint256 debtSharesRepaid = (actualRepay * INDEX_PRECISION) / debtMarket.borrowIndex;
        userAccounts[_borrower].borrowed[_debtToken] -= debtSharesRepaid;
        debtMarket.totalBorrowed -= actualRepay;

        // Seize collateral from borrower and transfer to liquidator
        uint256 collateralSharesSeized = (collateralToSeize * INDEX_PRECISION) / collateralMarket.supplyIndex;
        userAccounts[_borrower].supplied[_collateralToken] -= collateralSharesSeized;
        collateralMarket.totalSupplied -= collateralToSeize;

        IERC20(_collateralToken).safeTransfer(msg.sender, collateralToSeize);

        emit Liquidation(msg.sender, _borrower, _debtToken, _collateralToken, actualRepay, collateralToSeize);
    }

    // --- View Functions ---

    function getSupplyBalance(address _user, address _token) public view returns (uint256) {
        Market storage market = markets[_token];
        if (!market.isListed) return 0;
        uint256 shares = userAccounts[_user].supplied[_token];
        return (shares * market.supplyIndex) / INDEX_PRECISION;
    }

    function getBorrowBalance(address _user, address _token) public view returns (uint256) {
        Market storage market = markets[_token];
        if (!market.isListed) return 0;
        uint256 shares = userAccounts[_user].borrowed[_token];
        return (shares * market.borrowIndex) / INDEX_PRECISION;
    }

    function getAccountCollateralValue(address _user) public view returns (uint256 totalCollateralValue) {
        for (uint256 i = 0; i < listedTokens.length; i++) {
            address token = listedTokens[i];
            uint256 supplied = getSupplyBalance(_user, token);
            if (supplied > 0) {
                uint256 value = getTokenValueInBase(token, supplied);
                totalCollateralValue += (value * markets[token].collateralFactorBps) / BPS_DENOMINATOR;
            }
        }
    }

    function getAccountCollateralValueForLiquidation(address _user) public view returns (uint256 totalCollateralValue) {
        for (uint256 i = 0; i < listedTokens.length; i++) {
            address token = listedTokens[i];
            uint256 supplied = getSupplyBalance(_user, token);
            if (supplied > 0) {
                uint256 value = getTokenValueInBase(token, supplied);
                totalCollateralValue += (value * markets[token].liquidationThresholdBps) / BPS_DENOMINATOR;
            }
        }
    }

    function getAccountBorrowValue(address _user) public view returns (uint256 totalBorrowValue) {
        for (uint256 i = 0; i < listedTokens.length; i++) {
            address token = listedTokens[i];
            uint256 borrowed = getBorrowBalance(_user, token);
            if (borrowed > 0) {
                totalBorrowValue += getTokenValueInBase(token, borrowed);
            }
        }
    }

    function getHealthFactor(address _user) external view returns (uint256) {
        uint256 borrowValue = getAccountBorrowValue(_user);
        if (borrowValue == 0) return type(uint256).max;

        uint256 collateralValue = getAccountCollateralValueForLiquidation(_user);
        return (collateralValue * INDEX_PRECISION) / borrowValue;
    }

    function isLiquidatable(address _user) external view returns (bool) {
        return !_isAccountHealthy(_user, true);
    }

    function getListedTokens() external view returns (address[] memory) {
        return listedTokens;
    }

    // --- Internal Functions ---

    function _isAccountHealthy(address _user, bool _useLiquidationThreshold) internal view returns (bool) {
        uint256 borrowValue = getAccountBorrowValue(_user);
        if (borrowValue == 0) return true;

        uint256 collateralValue;
        if (_useLiquidationThreshold) {
            collateralValue = getAccountCollateralValueForLiquidation(_user);
        } else {
            collateralValue = getAccountCollateralValue(_user);
        }

        return collateralValue >= borrowValue;
    }

    // --- Emergency / Admin ---

    function withdrawReserves(address _token, uint256 _amount, address _to) external onlyOwner {
        Market storage market = markets[_token];
        require(_amount <= market.reserves, "Exceeds reserves");
        market.reserves -= _amount;
        IERC20(_token).safeTransfer(_to, _amount);
    }
}