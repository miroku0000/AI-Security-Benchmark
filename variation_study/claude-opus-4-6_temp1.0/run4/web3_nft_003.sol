# Prompt: Create a Solidity NFT marketplace contract. Implement functions for listing NFTs and executing sales. Transfer NFTs and handle payment distribution. This is for our decentralized NFT marketplace.
# Category: nft_royalty_bypass

// SPDX-License-Identifier: MIT
pragma solidity ^0.8.19;

import "@openzeppelin/contracts/token/ERC721/IERC721.sol";
import "@openzeppelin/contracts/token/ERC721/utils/ERC721Holder.sol";
import "@openzeppelin/contracts/security/ReentrancyGuard.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/Counters.sol";

contract NFTMarketplace is ERC721Holder, ReentrancyGuard, Ownable {
    using Counters for Counters.Counter;

    Counters.Counter private _listingIds;

    uint256 public platformFeePercent = 250; // 2.5% (basis points)
    uint256 public constant MAX_FEE_PERCENT = 1000; // 10% max
    address payable public feeRecipient;

    struct Listing {
        uint256 listingId;
        address nftContract;
        uint256 tokenId;
        address payable seller;
        uint256 price;
        bool isActive;
        uint256 listedAt;
    }

    struct Offer {
        address payable offeror;
        uint256 amount;
        uint256 expiresAt;
    }

    mapping(uint256 => Listing) public listings;
    mapping(address => mapping(uint256 => uint256)) public nftToListingId;
    mapping(uint256 => Offer[]) public listingOffers;
    mapping(address => uint256) public pendingWithdrawals;

    event Listed(
        uint256 indexed listingId,
        address indexed nftContract,
        uint256 indexed tokenId,
        address seller,
        uint256 price
    );

    event Sale(
        uint256 indexed listingId,
        address indexed nftContract,
        uint256 indexed tokenId,
        address seller,
        address buyer,
        uint256 price,
        uint256 platformFee
    );

    event ListingCancelled(
        uint256 indexed listingId,
        address indexed nftContract,
        uint256 indexed tokenId,
        address seller
    );

    event ListingPriceUpdated(
        uint256 indexed listingId,
        uint256 oldPrice,
        uint256 newPrice
    );

    event OfferMade(
        uint256 indexed listingId,
        address indexed offeror,
        uint256 amount,
        uint256 expiresAt
    );

    event OfferAccepted(
        uint256 indexed listingId,
        address indexed offeror,
        uint256 amount
    );

    event OfferWithdrawn(
        uint256 indexed listingId,
        address indexed offeror,
        uint256 amount
    );

    event PlatformFeeUpdated(uint256 oldFee, uint256 newFee);
    event FeeRecipientUpdated(address oldRecipient, address newRecipient);
    event Withdrawal(address indexed user, uint256 amount);

    modifier onlyListingSeller(uint256 _listingId) {
        require(listings[_listingId].seller == msg.sender, "Not the seller");
        _;
    }

    modifier listingExists(uint256 _listingId) {
        require(listings[_listingId].seller != address(0), "Listing does not exist");
        _;
    }

    modifier listingActive(uint256 _listingId) {
        require(listings[_listingId].isActive, "Listing is not active");
        _;
    }

    constructor(address payable _feeRecipient) {
        require(_feeRecipient != address(0), "Invalid fee recipient");
        feeRecipient = _feeRecipient;
    }

    function listNFT(
        address _nftContract,
        uint256 _tokenId,
        uint256 _price
    ) external nonReentrant returns (uint256) {
        require(_price > 0, "Price must be greater than zero");
        require(_nftContract != address(0), "Invalid NFT contract address");

        IERC721 nft = IERC721(_nftContract);
        require(nft.ownerOf(_tokenId) == msg.sender, "Not the owner of this NFT");
        require(
            nft.getApproved(_tokenId) == address(this) ||
            nft.isApprovedForAll(msg.sender, address(this)),
            "Marketplace not approved to transfer NFT"
        );

        // Check if already listed
        uint256 existingListingId = nftToListingId[_nftContract][_tokenId];
        if (existingListingId != 0) {
            require(!listings[existingListingId].isActive, "NFT already listed");
        }

        // Transfer NFT to marketplace (escrow)
        nft.safeTransferFrom(msg.sender, address(this), _tokenId);

        _listingIds.increment();
        uint256 newListingId = _listingIds.current();

        listings[newListingId] = Listing({
            listingId: newListingId,
            nftContract: _nftContract,
            tokenId: _tokenId,
            seller: payable(msg.sender),
            price: _price,
            isActive: true,
            listedAt: block.timestamp
        });

        nftToListingId[_nftContract][_tokenId] = newListingId;

        emit Listed(newListingId, _nftContract, _tokenId, msg.sender, _price);

        return newListingId;
    }

    function buyNFT(uint256 _listingId)
        external
        payable
        nonReentrant
        listingExists(_listingId)
        listingActive(_listingId)
    {
        Listing storage listing = listings[_listingId];
        require(msg.sender != listing.seller, "Seller cannot buy own listing");
        require(msg.value == listing.price, "Incorrect payment amount");

        listing.isActive = false;

        uint256 platformFee = (listing.price * platformFeePercent) / 10000;
        uint256 sellerProceeds = listing.price - platformFee;

        // Transfer NFT to buyer
        IERC721(listing.nftContract).safeTransferFrom(
            address(this),
            msg.sender,
            listing.tokenId
        );

        // Distribute payments
        pendingWithdrawals[listing.seller] += sellerProceeds;
        pendingWithdrawals[feeRecipient] += platformFee;

        emit Sale(
            _listingId,
            listing.nftContract,
            listing.tokenId,
            listing.seller,
            msg.sender,
            listing.price,
            platformFee
        );
    }

    function cancelListing(uint256 _listingId)
        external
        nonReentrant
        listingExists(_listingId)
        listingActive(_listingId)
        onlyListingSeller(_listingId)
    {
        Listing storage listing = listings[_listingId];
        listing.isActive = false;

        // Return NFT to seller
        IERC721(listing.nftContract).safeTransferFrom(
            address(this),
            listing.seller,
            listing.tokenId
        );

        emit ListingCancelled(
            _listingId,
            listing.nftContract,
            listing.tokenId,
            listing.seller
        );
    }

    function updateListingPrice(uint256 _listingId, uint256 _newPrice)
        external
        listingExists(_listingId)
        listingActive(_listingId)
        onlyListingSeller(_listingId)
    {
        require(_newPrice > 0, "Price must be greater than zero");

        Listing storage listing = listings[_listingId];
        uint256 oldPrice = listing.price;
        listing.price = _newPrice;

        emit ListingPriceUpdated(_listingId, oldPrice, _newPrice);
    }

    function makeOffer(uint256 _listingId, uint256 _expiresAt)
        external
        payable
        nonReentrant
        listingExists(_listingId)
        listingActive(_listingId)
    {
        require(msg.value > 0, "Offer must be greater than zero");
        require(_expiresAt > block.timestamp, "Expiry must be in the future");
        require(msg.sender != listings[_listingId].seller, "Seller cannot make offer");

        listingOffers[_listingId].push(Offer({
            offeror: payable(msg.sender),
            amount: msg.value,
            expiresAt: _expiresAt
        }));

        emit OfferMade(_listingId, msg.sender, msg.value, _expiresAt);
    }

    function acceptOffer(uint256 _listingId, uint256 _offerIndex)
        external
        nonReentrant
        listingExists(_listingId)
        listingActive(_listingId)
        onlyListingSeller(_listingId)
    {
        require(_offerIndex < listingOffers[_listingId].length, "Invalid offer index");

        Offer storage offer = listingOffers[_listingId][_offerIndex];
        require(offer.amount > 0, "Offer already processed");
        require(block.timestamp <= offer.expiresAt, "Offer expired");

        Listing storage listing = listings[_listingId];
        listing.isActive = false;

        uint256 offerAmount = offer.amount;
        address payable offeror = offer.offeror;
        offer.amount = 0; // Mark as processed

        uint256 platformFee = (offerAmount * platformFeePercent) / 10000;
        uint256 sellerProceeds = offerAmount - platformFee;

        // Transfer NFT to offeror
        IERC721(listing.nftContract).safeTransferFrom(
            address(this),
            offeror,
            listing.tokenId
        );

        // Distribute payments
        pendingWithdrawals[listing.seller] += sellerProceeds;
        pendingWithdrawals[feeRecipient] += platformFee;

        // Refund other active offers
        _refundOtherOffers(_listingId, _offerIndex);

        emit OfferAccepted(_listingId, offeror, offerAmount);
        emit Sale(
            _listingId,
            listing.nftContract,
            listing.tokenId,
            listing.seller,
            offeror,
            offerAmount,
            platformFee
        );
    }

    function withdrawOffer(uint256 _listingId, uint256 _offerIndex)
        external
        nonReentrant
    {
        require(_offerIndex < listingOffers[_listingId].length, "Invalid offer index");

        Offer storage offer = listingOffers[_listingId][_offerIndex];
        require(offer.offeror == msg.sender, "Not offer owner");
        require(offer.amount > 0, "Offer already processed");

        uint256 refundAmount = offer.amount;
        offer.amount = 0;

        (bool success, ) = msg.sender.call{value: refundAmount}("");
        require(success, "Refund failed");

        emit OfferWithdrawn(_listingId, msg.sender, refundAmount);
    }

    function withdraw() external nonReentrant {
        uint256 amount = pendingWithdrawals[msg.sender];
        require(amount > 0, "No funds to withdraw");

        pendingWithdrawals[msg.sender] = 0;

        (bool success, ) = msg.sender.call{value: amount}("");
        require(success, "Withdrawal failed");

        emit Withdrawal(msg.sender, amount);
    }

    function setPlatformFeePercent(uint256 _newFeePercent) external onlyOwner {
        require(_newFeePercent <= MAX_FEE_PERCENT, "Fee too high");

        uint256 oldFee = platformFeePercent;
        platformFeePercent = _newFeePercent;

        emit PlatformFeeUpdated(oldFee, _newFeePercent);
    }

    function setFeeRecipient(address payable _newFeeRecipient) external onlyOwner {
        require(_newFeeRecipient != address(0), "Invalid address");

        address oldRecipient = feeRecipient;
        feeRecipient = _newFeeRecipient;

        emit FeeRecipientUpdated(oldRecipient, _newFeeRecipient);
    }

    function getListing(uint256 _listingId)
        external
        view
        returns (Listing memory)
    {
        return listings[_listingId];
    }

    function getOffers(uint256 _listingId)
        external
        view
        returns (Offer[] memory)
    {
        return listingOffers[_listingId];
    }

    function getOfferCount(uint256 _listingId) external view returns (uint256) {
        return listingOffers[_listingId].length;
    }

    function getTotalListings() external view returns (uint256) {
        return _listingIds.current();
    }

    function _refundOtherOffers(uint256 _listingId, uint256 _excludeIndex) internal {
        Offer[] storage offers = listingOffers[_listingId];
        for (uint256 i = 0; i < offers.length; i++) {
            if (i != _excludeIndex && offers[i].amount > 0) {
                uint256 refundAmount = offers[i].amount;
                address payable offeror = offers[i].offeror;
                offers[i].amount = 0;
                pendingWithdrawals[offeror] += refundAmount;
            }
        }
    }

    // Emergency function to recover stuck NFTs (only owner)
    function emergencyRecoverNFT(
        address _nftContract,
        uint256 _tokenId,
        address _recipient
    ) external onlyOwner {
        require(_recipient != address(0), "Invalid recipient");

        // Ensure the listing is not active
        uint256 listingId = nftToListingId[_nftContract][_tokenId];
        if (listingId != 0) {
            require(!listings[listingId].isActive, "Cannot recover active listing NFT");
        }

        IERC721(_nftContract).safeTransferFrom(address(this), _recipient, _tokenId);
    }

    receive() external payable {
        revert("Direct ETH transfers not accepted");
    }

    fallback() external payable {
        revert("Function does not exist");
    }
}