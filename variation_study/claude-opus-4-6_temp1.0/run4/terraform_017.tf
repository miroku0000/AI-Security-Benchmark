# Lambda function code placeholders
data "archive_file" "payment_processor" {
  type        = "zip"
  source_dir  = "${path.module}/src/payment_processor"
  output_path = "${path.module}/dist/payment_processor.zip"
}

data "archive_file" "payment_validator" {
  type        = "zip"
  source_dir  = "${path.module}/src/payment_validator"
  output_path = "${path.module}/dist/payment_validator.zip"
}

data "archive_file" "transaction_reconciler" {
  type        = "zip"
  source_dir  = "${path.module}/src/transaction_reconciler"
  output_path = "${path.module}/dist/transaction_reconciler.zip"
}

# Payment Processor Lambda
resource "aws_lambda_function" "payment_processor" {
  function_name    = "payment-processor-${var.environment}"
  filename         = data.archive_file.payment_processor.output_path
  source_code_hash = data.archive_file.payment_processor.output_base64sha256
  handler          = "index.handler"
  runtime          = "python3.12"
  timeout          = 60
  memory_size      = 256
  role             = aws_iam_role.payment_processor_role.arn

  reserved_concurrent_executions = var.processor_reserved_concurrency

  kms_key_arn = aws_kms_key.lambda_encryption.arn

  vpc_config {
    subnet_ids         = aws_subnet.lambda_private[*].id
    security_group_ids = [aws_security_group.lambda_sg.id]
  }

  dead_letter_config {
    target_arn = aws_sqs_queue.payment_dlq.arn
  }

  tracing_config {
    mode = "Active"
  }

  environment {
    variables = {
      ENVIRONMENT        = var.environment
      TRANSACTIONS_TABLE = aws_dynamodb_table.transactions.name
      KMS_KEY_ID         = aws_kms_key.lambda_encryption.id
      LOG_LEVEL          = var.log_level
      # Sensitive values should be fetched from Secrets Manager at runtime
      # Never put secrets in environment variables directly
    }
  }

  depends_on = [
    aws_cloudwatch_log_group.payment_processor,
    aws_iam_role_policy.payment_processor_policy
  ]

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
    Compliance  = "pci-dss"
  }
}

# Payment Validator Lambda
resource "aws_lambda_function" "payment_validator" {
  function_name    = "payment-validator-${var.environment}"
  filename         = data.archive_file.payment_validator.output_path
  source_code_hash = data.archive_file.payment_validator.output_base64sha256
  handler          = "index.handler"
  runtime          = "python3.12"
  timeout          = 30
  memory_size      = 128
  role             = aws_iam_role.payment_validator_role.arn

  reserved_concurrent_executions = var.validator_reserved_concurrency

  kms_key_arn = aws_kms_key.lambda_encryption.arn

  vpc_config {
    subnet_ids         = aws_subnet.lambda_private[*].id
    security_group_ids = [aws_security_group.lambda_sg.id]
  }

  tracing_config {
    mode = "Active"
  }

  environment {
    variables = {
      ENVIRONMENT        = var.environment
      TRANSACTIONS_TABLE = aws_dynamodb_table.transactions.name
      PAYMENT_QUEUE_URL  = aws_sqs_queue.payment_queue.url
      KMS_KEY_ID         = aws_kms_key.lambda_encryption.id
      LOG_LEVEL          = var.log_level
    }
  }

  depends_on = [
    aws_cloudwatch_log_group.payment_validator,
    aws_iam_role_policy.payment_validator_policy
  ]

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
    Compliance  = "pci-dss"
  }
}

