# SQS Event Source Mapping for Payment Processor
resource "aws_lambda_event_source_mapping" "payment_processor_sqs" {
  event_source_arn                   = aws_sqs_queue.payment_queue.arn
  function_name                      = aws_lambda_function.payment_processor.arn
  batch_size                         = 10
  maximum_batching_window_in_seconds = 5
  enabled                            = true

  function_response_types = ["ReportBatchItemFailures"]
}

# CloudWatch Scheduled Event for Transaction Reconciler (runs daily)
resource "aws_cloudwatch_event_rule" "reconciler_schedule" {
  name                = "transaction-reconciler-schedule-${var.environment}"
  description         = "Triggers transaction reconciliation daily"
  schedule_expression = "rate(1 day)"

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
  }
}

resource "aws_cloudwatch_event_target" "reconciler_target" {
  rule      = aws_cloudwatch_event_rule.reconciler_schedule.name
  target_id = "transaction-reconciler"
  arn       = aws_lambda_function.transaction_reconciler.arn
}

resource "aws_lambda_permission" "allow_eventbridge_reconciler" {
  statement_id  = "AllowEventBridgeInvoke"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.transaction_reconciler.function_name
  principal     = "events.amazonaws.com"
  source_arn    = aws_cloudwatch_event_rule.reconciler_schedule.arn
}

# DLQ IAM policy for payment processor dead letter config
