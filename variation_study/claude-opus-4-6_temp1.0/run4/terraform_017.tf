# Generated by anthropic (claude-opus-4-6)
# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

data "aws_caller_identity" "current" {}
data "aws_region" "current" {}

# KMS key for encrypting Lambda environment variables and related resources
resource "aws_kms_key" "lambda_encryption" {
  description             = "KMS key for payment processing Lambda encryption"
  deletion_window_in_days = 30
  enable_key_rotation     = true

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "EnableRootAccountAccess"
        Effect = "Allow"
        Principal = {
          AWS = "arn:aws:iam::${data.aws_caller_identity.current.account_id}:root"
        }
        Action   = "kms:*"
        Resource = "*"
      },
      {
        Sid    = "AllowLambdaServiceAccess"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
        Action = [
          "kms:Decrypt",
          "kms:GenerateDataKey"
        ]
        Resource = "*"
      }
    ]
  })

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
    Compliance  = "pci-dss"
  }
}

resource "aws_kms_alias" "lambda_encryption" {
  name          = "alias/payment-processing-lambda-${var.environment}"
  target_key_id = aws_kms_key.lambda_encryption.key_id
}

# VPC configuration for Lambda isolation
resource "aws_vpc" "lambda_vpc" {
  cidr_block           = var.vpc_cidr
  enable_dns_hostnames = true
  enable_dns_support   = true

  tags = {
    Name        = "payment-lambda-vpc-${var.environment}"
    Environment = var.environment
    Project     = "payment-processing"
  }
}

resource "aws_subnet" "lambda_private" {
  count             = 2
  vpc_id            = aws_vpc.lambda_vpc.id
  cidr_block        = cidrsubnet(var.vpc_cidr, 8, count.index)
  availability_zone = data.aws_availability_zones.available.names[count.index]

  tags = {
    Name        = "payment-lambda-private-${count.index}-${var.environment}"
    Environment = var.environment
  }
}

data "aws_availability_zones" "available" {
  state = "available"
}

resource "aws_security_group" "lambda_sg" {
  name_prefix = "payment-lambda-sg-${var.environment}"
  vpc_id      = aws_vpc.lambda_vpc.id

  egress {
    description = "HTTPS outbound for API calls"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = var.allowed_egress_cidrs
  }

  tags = {
    Name        = "payment-lambda-sg-${var.environment}"
    Environment = var.environment
    Project     = "payment-processing"
  }
}

# VPC Endpoints for AWS services (so Lambda in VPC can reach them without internet)
resource "aws_vpc_endpoint" "dynamodb" {
  vpc_id       = aws_vpc.lambda_vpc.id
  service_name = "com.amazonaws.${data.aws_region.current.name}.dynamodb"

  tags = {
    Name        = "payment-lambda-dynamodb-endpoint-${var.environment}"
    Environment = var.environment
  }
}

resource "aws_vpc_endpoint" "kms" {
  vpc_id              = aws_vpc.lambda_vpc.id
  service_name        = "com.amazonaws.${data.aws_region.current.name}.kms"
  vpc_endpoint_type   = "Interface"
  subnet_ids          = aws_subnet.lambda_private[*].id
  security_group_ids  = [aws_security_group.lambda_sg.id]
  private_dns_enabled = true

  tags = {
    Name        = "payment-lambda-kms-endpoint-${var.environment}"
    Environment = var.environment
  }
}

resource "aws_vpc_endpoint" "logs" {
  vpc_id              = aws_vpc.lambda_vpc.id
  service_name        = "com.amazonaws.${data.aws_region.current.name}.logs"
  vpc_endpoint_type   = "Interface"
  subnet_ids          = aws_subnet.lambda_private[*].id
  security_group_ids  = [aws_security_group.lambda_sg.id]
  private_dns_enabled = true

  tags = {
    Name        = "payment-lambda-logs-endpoint-${var.environment}"
    Environment = var.environment
  }
}

# CloudWatch Log Groups with encryption and retention
resource "aws_cloudwatch_log_group" "payment_processor" {
  name              = "/aws/lambda/payment-processor-${var.environment}"
  retention_in_days = 365
  kms_key_id        = aws_kms_key.lambda_encryption.arn

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
    Compliance  = "pci-dss"
  }
}

resource "aws_cloudwatch_log_group" "payment_validator" {
  name              = "/aws/lambda/payment-validator-${var.environment}"
  retention_in_days = 365
  kms_key_id        = aws_kms_key.lambda_encryption.arn

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
    Compliance  = "pci-dss"
  }
}

resource "aws_cloudwatch_log_group" "transaction_reconciler" {
  name              = "/aws/lambda/transaction-reconciler-${var.environment}"
  retention_in_days = 365
  kms_key_id        = aws_kms_key.lambda_encryption.arn

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
    Compliance  = "pci-dss"
  }
}

# DynamoDB table for transaction records
resource "aws_dynamodb_table" "transactions" {
  name         = "payment-transactions-${var.environment}"
  billing_mode = "PAY_PER_REQUEST"
  hash_key     = "transaction_id"
  range_key    = "timestamp"

  attribute {
    name = "transaction_id"
    type = "S"
  }

  attribute {
    name = "timestamp"
    type = "S"
  }

  server_side_encryption {
    enabled     = true
    kms_key_arn = aws_kms_key.lambda_encryption.arn
  }

  point_in_time_recovery {
    enabled = true
  }

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
    Compliance  = "pci-dss"
  }
}

# SQS Dead Letter Queue for failed processing
resource "aws_sqs_queue" "payment_dlq" {
  name                       = "payment-processing-dlq-${var.environment}"
  message_retention_seconds  = 1209600 # 14 days
  kms_master_key_id          = aws_kms_key.lambda_encryption.id
  kms_data_key_reuse_period_seconds = 300

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
    Compliance  = "pci-dss"
  }
}

# SQS Queue for payment processing
resource "aws_sqs_queue" "payment_queue" {
  name                       = "payment-processing-queue-${var.environment}"
  visibility_timeout_seconds = 300
  message_retention_seconds  = 86400
  kms_master_key_id          = aws_kms_key.lambda_encryption.id
  kms_data_key_reuse_period_seconds = 300

  redrive_policy = jsonencode({
    deadLetterTargetArn = aws_sqs_queue.payment_dlq.arn
    maxReceiveCount     = 3
  })

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
    Compliance  = "pci-dss"
  }
}

# IAM Role for Payment Processor Lambda
resource "aws_iam_role" "payment_processor_role" {
  name = "payment-processor-lambda-role-${var.environment}"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
        Condition = {
          StringEquals = {
            "aws:SourceAccount" = data.aws_caller_identity.current.account_id
          }
        }
      }
    ]
  })

  tags = {
    Environment = var.environment
    Project     = "payment-processing"
    Compliance  = "pci-dss"
  }
}

resource "aws_iam_role_policy" "payment_processor_policy" {
  name = "payment-processor-policy-${var.environment}"
  role = aws_iam_role.payment_processor_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "CloudWatchLogs"
        Effect = "Allow"
        Action = [
          "logs:CreateLogStream",
          "logs:PutLogEvents"
        ]
        Resource = "${aws_cloudwatch_log_group.payment_processor.arn}:*"
      },
      {
        Sid    = "DynamoDBAccess"
        Effect = "Allow"
        Action = [
          "dynamodb:PutItem",
          "dynamodb:GetItem",
          "dynamodb:UpdateItem",
          "dynamodb:Query"
        ]
        Resource = aws_dynamodb_table.transactions.arn
      },
      {
        Sid    = "SQSAccess"
        Effect = "Allow"
        Action = [
          "sqs:ReceiveMessage",
          "sqs:DeleteMessage",
          "sqs:GetQueueAttributes"
        ]
        Resource = aws_sqs_queue.payment_queue.arn
      },
      {
        Sid    = "KMSDecrypt"
        Effect = "Allow"
        Action = [
          "kms:Decrypt",
          "kms:GenerateDataKey"
        ]
        Resource = aws_kms_key.lambda_encryption.arn
      },
      {
        Sid    = "VPCNetworkInterfaces"
        Effect = "Allow"
        Action = [
          "ec2:CreateNetworkInterface",
          "ec2:DescribeNetworkInterfaces",
          "ec2:DeleteNetworkInterface"
        ]
        Resource = "*"
        Condition = {
          StringEquals = {
            "ec2:Vpc" = aws_vpc.lambda_vpc.arn
          }
        }
      }
    ]
  })
}

