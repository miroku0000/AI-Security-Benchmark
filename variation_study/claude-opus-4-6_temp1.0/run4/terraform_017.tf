# KMS key policy update to allow CloudWatch Logs encryption
resource "aws_kms_key_policy" "lambda_encryption_policy" {
  key_id = aws_kms_key.lambda_encryption.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "EnableRootAccountAccess"
        Effect = "Allow"
        Principal = {
          AWS = "arn:aws:iam::${data.aws_caller_identity.current.account_id}:root"
        }
        Action   = "kms:*"
        Resource = "*"
      },
      {
        Sid    = "AllowLambdaServiceAccess"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
        Action = [
          "kms:Decrypt",
          "kms:GenerateDataKey"
        ]
        Resource = "*"
      },
      {
        Sid    = "AllowCloudWatchLogs"
        Effect = "Allow"
        Principal = {
          Service = "logs.${data.aws_region.current.name}.amazonaws.com"
        }
        Action = [
          "kms:Encrypt",
          "kms:Decrypt",
          "kms:ReEncryptFrom",
          "kms:ReEncryptTo",
          "kms:GenerateDataKey",
          "kms:GenerateDataKeyPair",
          "kms:GenerateDataKeyWithoutPlaintext",
          "kms:DescribeKey"
        ]
        Resource = "*"
        Condition = {
          ArnLike = {
            "kms:EncryptionContext:aws:logs:arn" = "arn:aws:logs:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:log-group:/aws/lambda/*"
          }
        }
      }
    ]
  })
}

# Variables
variable "environment" {
  description = "Environment name (e.g., prod, staging)"
  type        = string
  validation {
    condition     = contains(["prod", "staging", "dev"], var.environment)
    error_message = "Environment must be prod, staging, or dev."
  }
}

variable "vpc_cidr" {
  description = "CIDR block for Lambda VPC"
  type        = string
  default     = "10.0.0.0/16"
}

variable "allowed_egress_cidrs" {
  description = "Allowed CIDR blocks for outbound HTTPS traffic"
  type        = list(string)
  default     = []
}

variable "processor_reserved_concurrency" {
  description = "Reserved concurrent executions for payment processor"
  type        = number
  default     = 100
}

variable "validator_reserved_concurrency" {
  description = "Reserved concurrent executions for payment validator"
  type        = number
  default     = 50
}

variable "reconciler_reserved_concurrency" {
  description = "Reserved concurrent executions for transaction reconciler"
  type        = number
  default     = 5
}

variable "log_level" {
  description = "Application log level"
  type        = string
  default     = "INFO"
}

variable "alert_email" {
  description = "Email address for critical payment processing alerts"
  type        = string
}

# Outputs
output "payment_processor_function_arn" {
  description = "ARN of the payment processor Lambda function"
  value       = aws_lambda_function.payment_processor.arn
}

output "payment_validator_function_arn" {
  description = "ARN of the payment validator Lambda function"
  value       = aws_lambda_function.payment_validator.arn
}

output "transaction_reconciler_function_arn" {
  description = "ARN of the transaction reconciler Lambda function"
  value       = aws_lambda_function.transaction_reconciler.arn
}

output "payment_queue_url" {
  description = "URL of the payment processing SQS queue"
  value       = aws_sqs_queue.payment_queue.url
}

output "payment_dlq_url" {
  description = "URL of the payment processing dead letter queue"
  value       = aws_sqs_queue.payment_dlq.url
}

output "transactions_table_name" {
  description = "Name of the DynamoDB transactions table"
  value       = aws_dynamodb_table.transactions.name
}

output "sns_alerts_topic_arn" {
  description = "ARN of the SNS topic for payment processing alerts"
  value       = aws_sns_topic.payment_alerts.arn
}