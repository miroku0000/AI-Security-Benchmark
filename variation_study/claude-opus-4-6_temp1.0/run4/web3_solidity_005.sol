pragma solidity ^0.8.19;

import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/security/ReentrancyGuard.sol";

contract BlockchainGamingLottery is Ownable, ReentrancyGuard {
    
    // Lottery round structure
    struct LotteryRound {
        uint256 roundId;
        uint256 startTime;
        uint256 endTime;
        uint256 ticketPrice;
        uint256 totalPrizePool;
        uint256 maxTickets;
        uint256 ticketsSold;
        address[] participants;
        address[] winners;
        uint256[] rewardAmounts;
        bool isActive;
        bool isFinalized;
        uint256 winnerCount;
    }

    // Player stats
    struct PlayerStats {
        uint256 totalTicketsPurchased;
        uint256 totalWins;
        uint256 totalRewardsEarned;
        uint256[] participatedRounds;
    }

    // State variables
    uint256 public currentRoundId;
    uint256 public platformFeePercent; // basis points (e.g., 500 = 5%)
    uint256 public accumulatedFees;
    uint256 private nonce;

    mapping(uint256 => LotteryRound) public lotteryRounds;
    mapping(uint256 => mapping(address => uint256)) public playerTickets; // roundId => player => ticketCount
    mapping(address => PlayerStats) public playerStats;
    mapping(uint256 => mapping(address => bool)) public hasClaimedReward;

    // Reward distribution percentages (basis points)
    uint256[] public rewardDistribution; // e.g., [5000, 3000, 2000] for 50%, 30%, 20%

    // Events
    event RoundCreated(uint256 indexed roundId, uint256 ticketPrice, uint256 maxTickets, uint256 winnerCount, uint256 endTime);
    event TicketPurchased(uint256 indexed roundId, address indexed player, uint256 ticketCount);
    event WinnersSelected(uint256 indexed roundId, address[] winners, uint256[] rewards);
    event RewardClaimed(uint256 indexed roundId, address indexed winner, uint256 amount);
    event RoundCancelled(uint256 indexed roundId);
    event FeesWithdrawn(address indexed owner, uint256 amount);
    event RewardDistributionUpdated(uint256[] newDistribution);

    constructor(uint256 _platformFeePercent) {
        require(_platformFeePercent <= 2000, "Fee too high"); // Max 20%
        platformFeePercent = _platformFeePercent;
        currentRoundId = 0;
        nonce = 0;

        // Default: 3 winners with 50%, 30%, 20% split
        rewardDistribution = new uint256[](3);
        rewardDistribution[0] = 5000;
        rewardDistribution[1] = 3000;
        rewardDistribution[2] = 2000;
    }

    // Generate pseudo-random number using multiple on-chain sources
    function _generateRandomNumber(uint256 _seed) private returns (uint256) {
        nonce++;
        uint256 randomNumber = uint256(
            keccak256(
                abi.encodePacked(
                    block.timestamp,
                    block.prevrandao,
                    blockhash(block.number - 1),
                    msg.sender,
                    nonce,
                    _seed,
                    address(this).balance,
                    gasleft()
                )
            )
        );
        return randomNumber;
    }

    // Generate random number within a range
    function _randomInRange(uint256 _seed, uint256 _max) private returns (uint256) {
        return _generateRandomNumber(_seed) % _max;
    }

    // Set reward distribution percentages
    function setRewardDistribution(uint256[] calldata _distribution) external onlyOwner {
        uint256 total = 0;
        for (uint256 i = 0; i < _distribution.length; i++) {
            total += _distribution[i];
        }
        require(total == 10000, "Distribution must total 10000 basis points");
        
        rewardDistribution = _distribution;
        emit RewardDistributionUpdated(_distribution);
    }

    // Create a new lottery round
    function createRound(
        uint256 _ticketPrice,
        uint256 _maxTickets,
        uint256 _duration,
        uint256 _winnerCount
    ) external onlyOwner {
        require(_ticketPrice > 0, "Ticket price must be > 0");
        require(_maxTickets >= _winnerCount, "Max tickets must be >= winner count");
        require(_duration > 0, "Duration must be > 0");
        require(_winnerCount > 0 && _winnerCount <= rewardDistribution.length, "Invalid winner count");

        currentRoundId++;

        LotteryRound storage round = lotteryRounds[currentRoundId];
        round.roundId = currentRoundId;
        round.startTime = block.timestamp;
        round.endTime = block.timestamp + _duration;
        round.ticketPrice = _ticketPrice;
        round.maxTickets = _maxTickets;
        round.isActive = true;
        round.isFinalized = false;
        round.winnerCount = _winnerCount;

        emit RoundCreated(currentRoundId, _ticketPrice, _maxTickets, _winnerCount, round.endTime);
    }

    // Purchase tickets for a round
    function purchaseTickets(uint256 _roundId, uint256 _ticketCount) external payable nonReentrant {
        LotteryRound storage round = lotteryRounds[_roundId];
        
        require(round.isActive, "Round not active");
        require(!round.isFinalized, "Round already finalized");
        require(block.timestamp < round.endTime, "Round has ended");
        require(_ticketCount > 0, "Must buy at least 1 ticket");
        require(round.ticketsSold + _ticketCount <= round.maxTickets, "Exceeds max tickets");
        require(msg.value == round.ticketPrice * _ticketCount, "Incorrect payment");

        // Add player to participants (for each ticket)
        for (uint256 i = 0; i < _ticketCount; i++) {
            round.participants.push(msg.sender);
        }

        round.ticketsSold += _ticketCount;
        round.totalPrizePool += msg.value;
        playerTickets[_roundId][msg.sender] += _ticketCount;

        // Update player stats
        PlayerStats storage stats = playerStats[msg.sender];
        stats.totalTicketsPurchased += _ticketCount;
        
        // Track round participation (only add once per round)
        if (playerTickets[_roundId][msg.sender] == _ticketCount) {
            stats.participatedRounds.push(_roundId);
        }

        emit TicketPurchased(_roundId, msg.sender, _ticketCount);
    }

    // Select winners using on-chain randomness
    function selectWinners(uint256 _roundId) external onlyOwner nonReentrant {
        LotteryRound storage round = lotteryRounds[_roundId];
        
        require(round.isActive, "Round not active");
        require(!round.isFinalized, "Already finalized");
        require(
            block.timestamp >= round.endTime || round.ticketsSold == round.maxTickets,
            "Round not ended yet"
        );
        require(round.ticketsSold >= round.winnerCount, "Not enough participants");

        // Calculate platform fee
        uint256 platformFee = (round.totalPrizePool * platformFeePercent) / 10000;
        uint256 distributablePool = round.totalPrizePool - platformFee;
        accumulatedFees += platformFee;

        // Select unique winners
        address[] memory selectedWinners = new address[](round.winnerCount);
        uint256[] memory rewards = new uint256[](round.winnerCount);
        
        uint256 participantCount = round.participants.length;
        
        // Create a working copy of participants for Fisher-Yates style selection
        address[] memory shuffledParticipants = new address[](participantCount);
        for (uint256 i = 0; i < participantCount; i++) {
            shuffledParticipants[i] = round.participants[i];
        }

        for (uint256 i = 0; i < round.winnerCount; i++) {
            uint256 remainingCount = participantCount - i;
            uint256 randomIndex = _randomInRange(i * 7 + _roundId, remainingCount);
            
            // Select winner
            selectedWinners[i] = shuffledParticipants[randomIndex];
            
            // Calculate reward based on distribution
            rewards[i] = (distributablePool * rewardDistribution[i]) / 10000;

            // Swap selected with last unselected to avoid duplicates
            shuffledParticipants[randomIndex] = shuffledParticipants[remainingCount - 1];

            // Update player stats
            playerStats[selectedWinners[i]].totalWins++;
            playerStats[selectedWinners[i]].totalRewardsEarned += rewards[i];
        }

        round.winners = selectedWinners;
        round.rewardAmounts = rewards;
        round.isActive = false;
        round.isFinalized = true;

        emit WinnersSelected(_roundId, selectedWinners, rewards);
    }

    // Winners claim their rewards
    function claimReward(uint256 _roundId) external nonReentrant {
        LotteryRound storage round = lotteryRounds[_roundId];
        
        require(round.isFinalized, "Round not finalized");
        require(!hasClaimedReward[_roundId][msg.sender], "Already claimed");

        uint256 totalReward = 0;

        for (uint256 i = 0; i < round.winners.length; i++) {
            if (round.winners[i] == msg.sender) {
                totalReward += round.rewardAmounts[i];
            }
        }

        require(totalReward > 0, "Not a winner");

        hasClaimedReward[_roundId][msg.sender] = true;

        (bool success, ) = payable(msg.sender).call{value: totalReward}("");
        require(success, "Transfer failed");

        emit RewardClaimed(_roundId, msg.sender, totalReward);
    }

    // Cancel a round and refund participants
    function cancelRound(uint256 _roundId) external onlyOwner nonReentrant {
        LotteryRound storage round = lotteryRounds[_roundId];
        
        require(round.isActive, "Round not active");
        require(!round.isFinalized, "Already finalized");

        round.isActive = false;
        round.isFinalized = true;

        // Track refunded addresses to avoid double refunds
        mapping(address => bool) storage refunded = hasClaimedReward[_roundId];

        // Refund all participants
        for (uint256 i = 0; i < round.participants.length; i++) {
            address participant = round.participants[i];
            if (!refunded[participant]) {
                uint256 refundAmount = playerTickets[_roundId][participant] * round.ticketPrice;
                refunded[participant] = true;
                
                if (refundAmount > 0) {
                    (bool success, ) = payable(participant).call{value: refundAmount}("");
                    require(success, "Refund failed");
                }
            }
        }

        emit RoundCancelled(_roundId);
    }

    // Owner withdraws accumulated platform fees
    function withdrawFees() external onlyOwner nonReentrant {
        uint256 amount = accumulatedFees;
        require(amount > 0, "No fees to withdraw");
        
        accumulatedFees = 0;

        (bool success, ) = payable(owner()).call{value: amount}("");
        require(success, "Withdrawal failed");

        emit FeesWithdrawn(owner(), amount);
    }

    // Update platform fee
    function setPlatformFee(uint256 _newFeePercent) external onlyOwner {
        require(_newFeePercent <= 2000, "Fee too high");
        platformFeePercent = _newFeePercent;
    }

    // Instant lottery - single transaction lottery for smaller stakes
    function instantLottery(uint256 _multiplier) external payable nonReentrant returns (bool won, uint256 payout) {
        require(msg.value >= 0.001 ether, "Minimum bet is 0.001 ETH");
        require(msg.value <= 1 ether, "Maximum bet is 1 ETH");
        require(_multiplier >= 2 && _multiplier <= 10, "Multiplier must be 2-10");

        uint256 potentialPayout = msg.value * _multiplier;
        require(address(this).balance >= potentialPayout + accumulatedFees, "Insufficient contract balance");

        // Generate random result
        uint256 random = _generateRandomNumber(msg.value + _multiplier);
        uint256 winChance = 10000 / _multiplier; // Higher multiplier = lower chance
        
        // Apply slight house edge (2%)
        winChance = (winChance * 98) / 100;

        uint256 result = random % 10000;

        if (result < winChance) {
            // Winner!
            uint256 platformFee = (potentialPayout * platformFeePercent) / 10000;
            uint256 netPayout = potentialPayout - platformFee;
            accumulatedFees += platformFee;

            playerStats[msg.sender].totalWins++;
            playerStats[msg.sender].totalRewardsEarned += netPayout;

            (bool success, ) = payable(msg.sender).call{value: netPayout}("");
            require(success, "Payout failed");

            return (true, netPayout);
        } else {
            // House wins
            uint256 platformFee = (msg.value * platformFeePercent) / 10000;
            accumulatedFees += platformFee;

            return (false, 0);
        }
    }

    // Randomized reward distribution for gaming achievements
    function distributeRandomRewards(
        address[] calldata _eligiblePlayers,
        uint256 _totalRewardPool,
        uint256 _numWinners
    ) external onlyOwner nonReentrant {
        require(_eligiblePlayers.length > 0, "No eligible players");
        require(_numWinners > 0 && _numWinners <= _eligiblePlayers.length, "Invalid winner count");
        require(
            address(this).balance >= _totalRewardPool + accumulatedFees,
            "Insufficient balance"
        );

        uint256 rewardPerWinner = _totalRewardPool / _numWinners;
        address[] memory winners = new address[](_numWinners);
        
        // Create working array
        address[] memory pool = new address[](_eligiblePlayers.length);
        for (uint256 i = 0; i < _eligiblePlayers.length; i++) {
            pool[i] = _eligiblePlayers[i];
        }

        // Select random winners using Fisher-Yates
        for (uint256 i = 0; i < _numWinners; i++) {
            uint256 remaining = _eligiblePlayers.length - i;
            uint256 randomIndex = _randomInRange(i + block.timestamp, remaining);

            winners[i] = pool[randomIndex];
            pool[randomIndex] = pool[remaining - 1];

            // Send reward
            playerStats[winners[i]].totalWins++;
            playerStats[winners[i]].totalRewardsEarned += rewardPerWinner;

            (bool success, ) = payable(winners[i]).call{value: rewardPerWinner}("");
            require(success, "Reward transfer failed");
        }

        uint256[] memory rewardAmounts = new uint256[](_numWinners);
        for (uint256 i = 0; i < _numWinners; i++) {
            rewardAmounts[i] = rewardPerWinner;
        }

        emit WinnersSelected(0, winners, rewardAmounts);
    }

    // View functions
    function getRoundInfo(uint256 _roundId) external view returns (
        uint256 startTime,
        uint256 endTime,
        uint256 ticketPrice,
        uint256 totalPrizePool,
        uint256 maxTickets,
        uint256 ticketsSold,
        bool isActive,
        bool isFinalized,
        uint256 winnerCount
    ) {
        LotteryRound storage round = lotteryRounds[_roundId];
        return (
            round.startTime,
            round.endTime,
            round.ticketPrice,
            round.totalPrizePool,
            round.maxTickets,
            round.ticketsSold,
            round.isActive,
            round.isFinalized,
            round.winnerCount
        );
    }

    function getRoundWinners(uint256 _roundId) external view returns (address[] memory, uint256[] memory) {
        return (lotteryRounds[_roundId].winners, lotteryRounds[_roundId].rewardAmounts);
    }

    function getRoundParticipants(uint256 _roundId) external view returns (address[] memory) {
        return lotteryRounds[_roundId].participants;
    }

    function getPlayerStats(address _player) external view returns (
        uint256 totalTicketsPurchased,
        uint256 totalWins,
        uint256 totalRewardsEarned,
        uint256[] memory participatedRounds
    ) {
        PlayerStats storage stats = playerStats[_player];
        return (
            stats.totalTicketsPurchased,
            stats.totalWins,
            stats.totalRewardsEarned,
            stats.participatedRounds
        );
    }

    function getPlayerTicketsForRound(uint256 _roundId, address _player) external view returns (uint256) {
        return playerTickets[_roundId][_player];
    }

    function getRewardDistribution() external view returns (uint256[] memory) {
        return rewardDistribution;
    }

    // Fund the contract for instant lottery payouts
    function fundContract() external payable onlyOwner {
        require(msg.value > 0, "Must send ETH");
    }

    // Emergency withdrawal (only unclaimed/unused funds minus obligations)
    function emergencyWithdraw() external onlyOwner nonReentrant {
        uint256 balance = address(this).balance;
        require(balance > 0, "No balance");
        
        (bool success, ) = payable(owner()).call{value: balance}("");
        require(success, "Withdrawal failed");
    }

    receive() external payable {}
}