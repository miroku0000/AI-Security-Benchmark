pragma solidity ^0.8.19;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/token/ERC20/utils/SafeERC20.sol";
import "@openzeppelin/contracts/security/ReentrancyGuard.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

interface IUniswapV2Pair {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function token0() external view returns (address);
    function token1() external view returns (address);
}

interface IUniswapV2Factory {
    function getPair(address tokenA, address tokenB) external view returns (address pair);
}

contract DeFiLendingProtocol is ReentrancyGuard, Ownable {
    using SafeERC20 for IERC20;

    // --- Structs ---
    struct Market {
        bool isListed;
        uint256 collateralFactorBps;    // e.g., 7500 = 75%
        uint256 liquidationThresholdBps; // e.g., 8500 = 85%
        uint256 liquidationBonusBps;     // e.g., 500 = 5% bonus for liquidators
        uint256 totalDeposited;
        uint256 totalBorrowed;
        uint256 borrowIndex;             // accumulated interest index (scaled 1e18)
        uint256 borrowRatePerSecond;     // interest rate per second (scaled 1e18)
        uint256 lastAccrualTimestamp;
        uint256 reserveFactorBps;        // portion of interest going to reserves
        uint256 totalReserves;
        address dexPair;                 // Uniswap V2 pair for price oracle
        bool isBaseToken;                // true if this is the base pricing token
        uint8 decimals;
    }

    struct UserAccount {
        uint256 deposited;
        uint256 borrowBalance;
        uint256 borrowIndex;             // snapshot of market borrowIndex at last interaction
    }

    // --- State Variables ---
    address public baseToken;                        // e.g., WETH or stablecoin used as base price reference
    IUniswapV2Factory public dexFactory;

    mapping(address => Market) public markets;
    mapping(address => mapping(address => UserAccount)) public userAccounts; // token => user => account
    address[] public listedTokens;

    // user => list of tokens they've interacted with (for health factor calc)
    mapping(address => address[]) public userCollaterals;
    mapping(address => address[]) public userBorrows;
    mapping(address => mapping(address => bool)) public hasCollateral;
    mapping(address => mapping(address => bool)) public hasBorrow;

    uint256 public constant BPS_DENOMINATOR = 10000;
    uint256 public constant PRICE_PRECISION = 1e18;
    uint256 public constant INDEX_PRECISION = 1e18;

    // --- Events ---
    event MarketListed(address indexed token, uint256 collateralFactorBps, uint256 liquidationThresholdBps);
    event Deposit(address indexed user, address indexed token, uint256 amount);
    event Withdraw(address indexed user, address indexed token, uint256 amount);
    event Borrow(address indexed user, address indexed token, uint256 amount);
    event Repay(address indexed user, address indexed token, uint256 amount);
    event Liquidation(
        address indexed liquidator,
        address indexed borrower,
        address indexed repayToken,
        address collateralToken,
        uint256 repayAmount,
        uint256 collateralSeized
    );
    event InterestAccrued(address indexed token, uint256 interestAccumulated, uint256 newBorrowIndex);

    // --- Constructor ---
    constructor(address _dexFactory, address _baseToken) {
        dexFactory = IUniswapV2Factory(_dexFactory);
        baseToken = _baseToken;
    }

    // --- Admin Functions ---
    function listMarket(
        address _token,
        uint256 _collateralFactorBps,
        uint256 _liquidationThresholdBps,
        uint256 _liquidationBonusBps,
        uint256 _borrowRatePerSecond,
        uint256 _reserveFactorBps,
        uint8 _decimals,
        bool _isBaseToken
    ) external onlyOwner {
        require(!markets[_token].isListed, "Already listed");
        require(_collateralFactorBps <= 9000, "CF too high");
        require(_liquidationThresholdBps > _collateralFactorBps, "LT must > CF");
        require(_liquidationThresholdBps <= 9500, "LT too high");
        require(_liquidationBonusBps <= 2000, "Bonus too high");

        address pair = address(0);
        if (!_isBaseToken) {
            pair = dexFactory.getPair(_token, baseToken);
            require(pair != address(0), "No DEX pair found");
        }

        markets[_token] = Market({
            isListed: true,
            collateralFactorBps: _collateralFactorBps,
            liquidationThresholdBps: _liquidationThresholdBps,
            liquidationBonusBps: _liquidationBonusBps,
            totalDeposited: 0,
            totalBorrowed: 0,
            borrowIndex: INDEX_PRECISION,
            borrowRatePerSecond: _borrowRatePerSecond,
            lastAccrualTimestamp: block.timestamp,
            reserveFactorBps: _reserveFactorBps,
            totalReserves: 0,
            dexPair: pair,
            isBaseToken: _isBaseToken,
            decimals: _decimals
        });

        listedTokens.push(_token);
        emit MarketListed(_token, _collateralFactorBps, _liquidationThresholdBps);
    }

    function updateBorrowRate(address _token, uint256 _newRate) external onlyOwner {
        require(markets[_token].isListed, "Not listed");
        accrueInterest(_token);
        markets[_token].borrowRatePerSecond = _newRate;
    }

    function withdrawReserves(address _token, uint256 _amount, address _to) external onlyOwner {
        Market storage market = markets[_token];
        require(_amount <= market.totalReserves, "Insufficient reserves");
        market.totalReserves -= _amount;
        IERC20(_token).safeTransfer(_to, _amount);
    }

    // --- Price Oracle (on-chain DEX) ---
    function getTokenPriceInBase(address _token) public view returns (uint256) {
        Market storage market = markets[_token];
        require(market.isListed, "Not listed");

        if (market.isBaseToken) {
            return PRICE_PRECISION; // 1:1 ratio for base token
        }

        address pair = market.dexPair;
        require(pair != address(0), "No pair");

        IUniswapV2Pair uniPair = IUniswapV2Pair(pair);
        (uint112 reserve0, uint112 reserve1,) = uniPair.getReserves();

        require(reserve0 > 0 && reserve1 > 0, "Empty reserves");

        address token0 = uniPair.token0();

        uint256 tokenReserve;
        uint256 baseReserve;

        if (token0 == _token) {
            tokenReserve = uint256(reserve0);
            baseReserve = uint256(reserve1);
        } else {
            tokenReserve = uint256(reserve1);
            baseReserve = uint256(reserve0);
        }

        // Normalize to 18 decimals for both sides
        uint8 tokenDecimals = market.decimals;
        uint8 baseDecimals = markets[baseToken].decimals;

        // price = (baseReserve / tokenReserve) normalized
        // price in base per token, scaled to PRICE_PRECISION
        uint256 price = (baseReserve * PRICE_PRECISION * (10 ** tokenDecimals)) / (tokenReserve * (10 ** baseDecimals));

        return price;
    }

    function getTokenValueInBase(address _token, uint256 _amount) public view returns (uint256) {
        uint256 price = getTokenPriceInBase(_token);
        uint8 tokenDecimals = markets[_token].decimals;
        return (_amount * price) / (10 ** tokenDecimals);
    }

    // --- Interest Accrual ---
    function accrueInterest(address _token) public {
        Market storage market = markets[_token];

        if (block.timestamp == market.lastAccrualTimestamp) {
            return;
        }

        if (market.totalBorrowed == 0) {
            market.lastAccrualTimestamp = block.timestamp;
            return;
        }

        uint256 timeElapsed = block.timestamp - market.lastAccrualTimestamp;
        uint256 interestFactor = market.borrowRatePerSecond * timeElapsed;
        uint256 interestAccumulated = (market.totalBorrowed * interestFactor) / INDEX_PRECISION;

        market.totalBorrowed += interestAccumulated;
        uint256 reserveIncrease = (interestAccumulated * market.reserveFactorBps) / BPS_DENOMINATOR;
        market.totalReserves += reserveIncrease;

        market.borrowIndex += (market.borrowIndex * interestFactor) / INDEX_PRECISION;
        market.lastAccrualTimestamp = block.timestamp;

        emit InterestAccrued(_token, interestAccumulated, market.borrowIndex);
    }

    function _currentBorrowBalance(address _token, address _user) internal view returns (uint256) {
        UserAccount storage account = userAccounts[_token][_user];
        if (account.borrowBalance == 0) return 0;

        Market storage market = markets[_token];
        uint256 currentIndex = market.borrowIndex;

        // Also account for unaccrued interest
        if (block.timestamp > market.lastAccrualTimestamp && market.totalBorrowed > 0) {
            uint256 timeElapsed = block.timestamp - market.lastAccrualTimestamp;
            uint256 interestFactor = market.borrowRatePerSecond * timeElapsed;
            currentIndex += (currentIndex * interestFactor) / INDEX_PRECISION;
        }

        return (account.borrowBalance * currentIndex) / account.borrowIndex;
    }

    // --- User Health Factor Calculation ---
    function getUserCollateralValue(address _user) public view returns (uint256 totalCollateral) {
        address[] storage collaterals = userCollaterals[_user];
        for (uint256 i = 0; i < collaterals.length; i++) {
            address token = collaterals[i];
            UserAccount storage account = userAccounts[token][_user];
            if (account.deposited > 0) {
                uint256 valueInBase = getTokenValueInBase(token, account.deposited);
                uint256 adjustedValue = (valueInBase * markets[token].collateralFactorBps) / BPS_DENOMINATOR;
                totalCollateral += adjustedValue;
            }
        }
    }

    function getUserLiquidationCollateralValue(address _user) public view returns (uint256 totalCollateral) {
        address[] storage collaterals = userCollaterals[_user];
        for (uint256 i = 0; i < collaterals.length; i++) {
            address token = collaterals[i];
            UserAccount storage account = userAccounts[token][_user];
            if (account.deposited > 0) {
                uint256 valueInBase = getTokenValueInBase(token, account.deposited);
                uint256 adjustedValue = (valueInBase * markets[token].liquidationThresholdBps) / BPS_DENOMINATOR;
                totalCollateral += adjustedValue;
            }
        }
    }

    function getUserBorrowValue(address _user) public view returns (uint256 totalBorrow) {
        address[] storage borrows = userBorrows[_user];
        for (uint256 i = 0; i < borrows.length; i++) {
            address token = borrows[i];
            uint256 borrowBal = _currentBorrowBalance(token, _user);
            if (borrowBal > 0) {
                totalBorrow += getTokenValueInBase(token, borrowBal);
            }
        }
    }

    /// @notice Returns health factor scaled by 1e18. < 1e18 means liquidatable
    function getHealthFactor(address _user) public view returns (uint256) {
        uint256 borrowValue = getUserBorrowValue(_user);
        if (borrowValue == 0) return type(uint256).max;

        uint256 liquidationCollateral = getUserLiquidationCollateralValue(_user);
        return (liquidationCollateral * PRICE_PRECISION) / borrowValue;
    }

    function isLiquidatable(address _user) public view returns (bool) {
        return getHealthFactor(_user) < PRICE_PRECISION;
    }

    // --- Core Functions ---
    function deposit(address _token, uint256 _amount) external nonReentrant {
        Market storage market = markets[_token];
        require(market.isListed, "Market not listed");
        require(_amount > 0, "Zero amount");

        accrueInterest(_token);

        IERC20(_token).safeTransferFrom(msg.sender, address(this), _amount);

        UserAccount storage account = userAccounts[_token][msg.sender];
        account.deposited += _amount;
        market.totalDeposited += _amount;

        if (!hasCollateral[msg.sender][_token]) {
            hasCollateral[msg.sender][_token] = true;
            userCollaterals[msg.sender].push(_token);
        }

        emit Deposit(msg.sender, _token, _amount);
    }

    function withdraw(address _token, uint256 _amount) external nonReentrant {
        Market storage market = markets[_token];
        require(market.isListed, "Market not listed");

        accrueInterest(_token);

        UserAccount storage account = userAccounts[_token][msg.sender];
        require(account.deposited >= _amount, "Insufficient deposit");

        // Check available liquidity
        uint256 availableLiquidity = market.totalDeposited - market.totalBorrowed;
        require(_amount <= availableLiquidity, "Insufficient liquidity");

        account.deposited -= _amount;
        market.totalDeposited -= _amount;

        // Verify user is still healthy after withdrawal
        if (getUserBorrowValue(msg.sender) > 0) {
            require(
                getUserCollateralValue(msg.sender) >= getUserBorrowValue(msg.sender),
                "Withdrawal would make position unhealthy"
            );
        }

        IERC20(_token).safeTransfer(msg.sender, _amount);

        emit Withdraw(msg.sender, _token, _amount);
    }

    function borrow(address _token, uint256 _amount) external nonReentrant {
        Market storage market = markets[_token];
        require(market.isListed, "Market not listed");
        require(_amount > 0, "Zero amount");

        accrueInterest(_token);

        // Check available liquidity
        uint256 availableLiquidity = market.totalDeposited - market.totalBorrowed - market.totalReserves;
        require(_amount <= availableLiquidity, "Insufficient liquidity");

        UserAccount storage account = userAccounts[_token][msg.sender];

        // Update borrow balance with accrued interest
        if (account.borrowBalance > 0) {
            account.borrowBalance = _currentBorrowBalance(_token, msg.sender);
        }

        account.borrowBalance += _amount;
        account.borrowIndex = market.borrowIndex;
        market.totalBorrowed += _amount;

        if (!hasBorrow[msg.sender][_token]) {
            hasBorrow[msg.sender][_token] = true;
            userBorrows[msg.sender].push(_token);
        }

        // Check collateral is sufficient
        uint256 totalCollateral = getUserCollateralValue(msg.sender);
        uint256 totalBorrow = getUserBorrowValue(msg.sender);
        require(totalCollateral >= totalBorrow, "Insufficient collateral");

        IERC20(_token).safeTransfer(msg.sender, _amount);

        emit Borrow(msg.sender, _token, _amount);
    }

    function repay(address _token, uint256 _amount) external nonReentrant {
        Market storage market = markets[_token];
        require(market.isListed, "Market not listed");

        accrueInterest(_token);

        UserAccount storage account = userAccounts[_token][msg.sender];

        // Get current borrow balance with accrued interest
        uint256 currentBorrow = _currentBorrowBalance(_token, msg.sender);
        require(currentBorrow > 0, "No borrow to repay");

        uint256 repayAmount = _amount > currentBorrow ? currentBorrow : _amount;

        IERC20(_token).safeTransferFrom(msg.sender, address(this), repayAmount);

        account.borrowBalance = currentBorrow - repayAmount;
        account.borrowIndex = market.borrowIndex;

        // Safely reduce totalBorrowed
        if (repayAmount > market.totalBorrowed) {
            market.totalBorrowed = 0;
        } else {
            market.totalBorrowed -= repayAmount;
        }

        emit Repay(msg.sender, _token, repayAmount);
    }

    function repayOnBehalf(address _token, address _borrower, uint256 _amount) external nonReentrant {
        Market storage market = markets[_token];
        require(market.isListed, "Market not listed");

        accrueInterest(_token);

        UserAccount storage account = userAccounts[_token][_borrower];
        uint256 currentBorrow = _currentBorrowBalance(_token, _borrower);
        require(currentBorrow > 0, "No borrow to repay");

        uint256 repayAmount = _amount > currentBorrow ? currentBorrow : _amount;

        IERC20(_token).safeTransferFrom(msg.sender, address(this), repayAmount);

        account.borrowBalance = currentBorrow - repayAmount;
        account.borrowIndex = market.borrowIndex;

        if (repayAmount > market.totalBorrowed) {
            market.totalBorrowed = 0;
        } else {
            market.totalBorrowed -= repayAmount;
        }

        emit Repay(_borrower, _token, repayAmount);
    }

    // --- Liquidation ---
    function liquidate(
        address _borrower,
        address _repayToken,
        address _collateralToken,
        uint256 _repayAmount
    ) external nonReentrant {
        require(_borrower != msg.sender, "Cannot liquidate self");

        accrueInterest(_repayToken);
        accrueInterest(_collateralToken);

        require(isLiquidatable(_borrower), "Borrower not liquidatable");

        Market storage repayMarket = markets[_repayToken];
        Market storage collateralMarket = markets[_collateralToken];
        require(repayMarket.isListed && collateralMarket.isListed, "Market not listed");

        UserAccount storage borrowerRepayAccount = userAccounts[_repayToken][_borrower];
        uint256 currentBorrow = _currentBorrowBalance(_repayToken, _borrower);
        require(currentBorrow > 0, "No borrow on this token");

        // Can liquidate up to 50% of the borrow
        uint256 maxRepay = (currentBorrow * 5000) / BPS_DENOMINATOR;
        uint256 actualRepay = _repayAmount > maxRepay ? maxRepay : _repayAmount;

        // Calculate collateral to seize
        uint256 repayValueInBase = getTokenValueInBase(_repayToken, actualRepay);
        uint256 collateralPriceInBase = getTokenPriceInBase(_collateralToken);

        // Apply liquidation bonus
        uint256 seizeValueInBase = (repayValueInBase * (BPS_DENOMINATOR + collateralMarket.liquidationBonusBps)) / BPS_DENOMINATOR;

        uint256 seizeAmount = (seizeValueInBase * (10 ** collateralMarket.decimals)) / collateralPriceInBase;

        UserAccount storage borrowerCollateralAccount = userAccounts[_collateralToken][_borrower];
        require(borrowerCollateralAccount.deposited >= seizeAmount, "Not enough collateral to seize");

        // Transfer repay tokens from liquidator
        IERC20(_repayToken).safeTransferFrom(msg.sender, address(this), actualRepay);

        // Update borrower's borrow
        borrowerRepayAccount.borrowBalance = currentBorrow - actualRepay;
        borrowerRepayAccount.borrowIndex = repayMarket.borrowIndex;

        if (actualRepay > repayMarket.totalBorrowed) {
            repayMarket.totalBorrowed = 0;
        } else {
            repayMarket.totalBorrowed -= actualRepay;
        }

        // Seize collateral
        borrowerCollateralAccount.deposited -= seizeAmount;
        collateralMarket.totalDeposited -= seizeAmount;

        IERC20(_collateralToken).safeTransfer(msg.sender, seizeAmount);

        emit Liquidation(msg.sender, _borrower, _repayToken, _collateralToken, actualRepay, seizeAmount);
    }

    // --- View Functions ---
    function getMarketInfo(address _token) external view returns (
        bool isListed,
        uint256 totalDeposited,
        uint256 totalBorrowed,
        uint256 totalReserves,
        uint256 borrowIndex,
        uint256 borrowRatePerSecond,
        uint256 collateralFactorBps,
        uint256 liquidationThresholdBps,
        uint256 utilizationRate
    ) {
        Market storage market = markets[_token];
        isListed = market.isListed;
        totalDeposited = market.totalDeposited;
        totalBorrowed = market.totalBorrowed;
        totalReserves = market.totalReserves;
        borrowIndex = market.borrowIndex;
        borrowRatePerSecond = market.borrowRatePerSecond;
        collateralFactorBps = market.collateralFactorBps;
        liquidationThresholdBps = market.liquidationThresholdBps;

        if (totalDeposited > 0) {
            utilizationRate = (totalBorrowed * PRICE_PRECISION) / totalDeposited;
        }
    }

    function getUserPosition(address _user, address _token) external view returns (
        uint256 deposited,
        uint256 borrowed,
        uint256 depositValueInBase,
        uint256 borrowValueInBase
    ) {
        UserAccount storage account = userAccounts[_token][_user];
        deposited = account.deposited;
        borrowed = _currentBorrowBalance(_token, _user);

        if (deposited > 0) {
            depositValueInBase = getTokenValueInBase(_token, deposited);
        }
        if (borrowed > 0) {
            borrowValueInBase = getTokenValueInBase(_token, borrowed);
        }
    }

    function getUserSummary(address _user) external view returns (
        uint256 totalCollateralValueInBase,
        uint256 totalBorrowValueInBase,
        uint256 healthFactor,
        uint256 availableToBorrowInBase
    ) {
        totalCollateralValueInBase = getUserCollateralValue(_user);
        totalBorrowValueInBase = getUserBorrowValue(_user);
        healthFactor = getHealthFactor(_user);

        if (totalCollateralValueInBase > totalBorrowValueInBase) {
            availableToBorrowInBase = totalCollateralValueInBase - totalBorrowValueInBase;
        }
    }

    function getListedTokens() external view returns (address[] memory) {
        return listedTokens;
    }

    function getUserCollaterals(address _user) external view returns (address[] memory) {
        return userCollaterals[_user];
    }

    function getUserBorrows(address _user) external view returns (address[] memory) {
        return userBorrows[_user];
    }

    function getCurrentBorrowBalance(address _token, address _user) external view returns (uint256) {
        return _currentBorrowBalance(_token, _user);
    }
}