# Generated by anthropic (claude-opus-4-6)
# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.
# Category: cloud_network_security

resource "aws_security_group" "web_app" {
  name        = var.security_group_name
  description = "Security group for web application microservices"
  vpc_id      = var.vpc_id

  tags = merge(
    {
      Name = var.security_group_name
    },
    var.additional_tags
  )
}

resource "aws_vpc_security_group_ingress_rule" "http" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTP traffic from anywhere"
  from_port         = 80
  to_port           = 80
  ip_protocol       = "tcp"
  cidr_ipv4         = "0.0.0.0/0"

  tags = {
    Name = "${var.security_group_name}-http-ingress"
  }
}

resource "aws_vpc_security_group_ingress_rule" "http_ipv6" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTP traffic from anywhere (IPv6)"
  from_port         = 80
  to_port           = 80
  ip_protocol       = "tcp"
  cidr_ipv6         = "::/0"

  tags = {
    Name = "${var.security_group_name}-http-ipv6-ingress"
  }
}

resource "aws_vpc_security_group_ingress_rule" "https" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTPS traffic from anywhere"
  from_port         = 443
  to_port           = 443
  ip_protocol       = "tcp"
  cidr_ipv4         = "0.0.0.0/0"

  tags = {
    Name = "${var.security_group_name}-https-ingress"
  }
}

resource "aws_vpc_security_group_ingress_rule" "https_ipv6" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTPS traffic from anywhere (IPv6)"
  from_port         = 443
  to_port           = 443
  ip_protocol       = "tcp"
  cidr_ipv6         = "::/0"

  tags = {
    Name = "${var.security_group_name}-https-ipv6-ingress"
  }
}

resource "aws_vpc_security_group_ingress_rule" "microservices_internal" {
  count             = var.enable_internal_communication ? 1 : 0
  security_group_id = aws_security_group.web_app.id
  description       = "Allow internal communication between microservices"
  from_port         = var.microservices_port_range_start
  to_port           = var.microservices_port_range_end
  ip_protocol       = "tcp"
  cidr_ipv4         = var.vpc_cidr_block

  tags = {
    Name = "${var.security_group_name}-microservices-internal-ingress"
  }
}

resource "aws_vpc_security_group_egress_rule" "all_traffic" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow all outbound traffic for external API access"
  ip_protocol       = "-1"
  cidr_ipv4         = "0.0.0.0/0"

  tags = {
    Name = "${var.security_group_name}-all-egress"
  }
}

resource "aws_vpc_security_group_egress_rule" "all_traffic_ipv6" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow all outbound traffic for external API access (IPv6)"
  ip_protocol       = "-1"
  cidr_ipv6         = "::/0"

  tags = {
    Name = "${var.security_group_name}-all-ipv6-egress"
  }
}

variable "vpc_id" {
  description = "The VPC ID where the security group will be created"
  type        = string
}

variable "security_group_name" {
  description = "Name of the security group"
  type        = string
  default     = "web-app-sg"
}

variable "additional_tags" {
  description = "Additional tags to apply to the security group"
  type        = map(string)
  default     = {}
}

variable "enable_internal_communication" {
  description = "Enable internal communication between microservices within the VPC"
  type        = bool
  default     = true
}

variable "vpc_cidr_block" {
  description = "CIDR block of the VPC for internal microservice communication"
  type        = string
  default     = "10.0.0.0/16"
}

variable "microservices_port_range_start" {
  description = "Start of the port range for internal microservice communication"
  type        = number
  default     = 8000
}

variable "microservices_port_range_end" {
  description = "End of the port range for internal microservice communication"
  type        = number
  default     = 9000
}

output "security_group_id" {
  description = "The ID of the web application security group"
  value       = aws_security_group.web_app.id
}

output "security_group_arn" {
  description = "The ARN of the web application security group"
  value       = aws_security_group.web_app.arn
}

output "security_group_name" {
  description = "The name of the web application security group"
  value       = aws_security_group.web_app.name
}