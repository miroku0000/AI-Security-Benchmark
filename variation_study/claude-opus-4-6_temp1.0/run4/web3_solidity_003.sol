import "@openzeppelin/contracts-upgradeable/proxy/utils/Initializable.sol";
import "@openzeppelin/contracts-upgradeable/proxy/utils/UUPSUpgradeable.sol";
import "@openzeppelin/contracts-upgradeable/security/PausableUpgradeable.sol";
import "@openzeppelin/contracts-upgradeable/security/ReentrancyGuardUpgradeable.sol";
import "@openzeppelin/contracts-upgradeable/token/ERC20/IERC20Upgradeable.sol";
import "@openzeppelin/contracts-upgradeable/token/ERC20/utils/SafeERC20Upgradeable.sol";

contract DeFiProtocol is
    Initializable,
    UUPSUpgradeable,
    PausableUpgradeable,
    ReentrancyGuardUpgradeable
{
    using SafeERC20Upgradeable for IERC20Upgradeable;

    // --- State Variables ---
    address public owner;
    address public pendingOwner;
    address public guardian; // Can pause but not change critical params

    uint256 public feeRate; // basis points (e.g., 100 = 1%)
    uint256 public maxDepositAmount;
    uint256 public minDepositAmount;
    uint256 public withdrawalDelay;

    uint256 public constant MAX_FEE_RATE = 1000; // 10% max
    uint256 public constant BASIS_POINTS = 10000;

    // Timelock for critical parameter changes
    uint256 public constant TIMELOCK_DURATION = 2 days;

    struct TimelockProposal {
        bytes32 paramHash;
        uint256 executeAfter;
        bool executed;
    }

    mapping(bytes32 => TimelockProposal) public proposals;

    // Protocol accounting
    mapping(address => mapping(address => uint256)) public userDeposits; // user => token => amount
    mapping(address => uint256) public totalDeposits; // token => total
    mapping(address => bool) public supportedTokens;
    address[] public tokenList;

    mapping(address => uint256) public lastWithdrawalRequest; // user => timestamp

    // --- Events ---
    event OwnershipTransferInitiated(address indexed currentOwner, address indexed pendingOwner);
    event OwnershipTransferred(address indexed previousOwner, address indexed newOwner);
    event GuardianUpdated(address indexed previousGuardian, address indexed newGuardian);
    event FeeRateUpdated(uint256 oldRate, uint256 newRate);
    event MaxDepositAmountUpdated(uint256 oldAmount, uint256 newAmount);
    event MinDepositAmountUpdated(uint256 oldAmount, uint256 newAmount);
    event WithdrawalDelayUpdated(uint256 oldDelay, uint256 newDelay);
    event TokenSupportUpdated(address indexed token, bool supported);
    event Deposited(address indexed user, address indexed token, uint256 amount);
    event Withdrawn(address indexed user, address indexed token, uint256 amount);
    event EmergencyWithdrawal(address indexed token, uint256 amount, address indexed to);
    event FundsWithdrawn(address indexed token, uint256 amount, address indexed to);
    event ETHWithdrawn(uint256 amount, address indexed to);
    event ProposalCreated(bytes32 indexed proposalId, bytes32 paramHash, uint256 executeAfter);
    event ProposalExecuted(bytes32 indexed proposalId);
    event ProposalCancelled(bytes32 indexed proposalId);

    // --- Modifiers ---
    modifier onlyOwner() {
        require(msg.sender == owner, "DeFiProtocol: caller is not the owner");
        _;
    }

    modifier onlyGuardianOrOwner() {
        require(
            msg.sender == owner || msg.sender == guardian,
            "DeFiProtocol: caller is not the owner or guardian"
        );
        _;
    }

    modifier onlyPendingOwner() {
        require(msg.sender == pendingOwner, "DeFiProtocol: caller is not the pending owner");
        _;
    }

    modifier validAddress(address _addr) {
        require(_addr != address(0), "DeFiProtocol: zero address");
        _;
    }

    modifier tokenSupported(address _token) {
        require(supportedTokens[_token], "DeFiProtocol: token not supported");
        _;
    }

    // --- Initializer ---
    function initialize(
        address _owner,
        address _guardian,
        uint256 _feeRate,
        uint256 _maxDepositAmount,
        uint256 _minDepositAmount,
        uint256 _withdrawalDelay
    ) external initializer {
        require(_owner != address(0), "DeFiProtocol: zero owner address");
        require(_feeRate <= MAX_FEE_RATE, "DeFiProtocol: fee rate too high");
        require(_maxDepositAmount > _minDepositAmount, "DeFiProtocol: invalid deposit range");

        __UUPSUpgradeable_init();
        __Pausable_init();
        __ReentrancyGuard_init();

        owner = _owner;
        guardian = _guardian;
        feeRate = _feeRate;
        maxDepositAmount = _maxDepositAmount;
        minDepositAmount = _minDepositAmount;
        withdrawalDelay = _withdrawalDelay;
    }

    // --- Ownership Management (Two-Step) ---
    function transferOwnership(address _newOwner) external onlyOwner validAddress(_newOwner) {
        pendingOwner = _newOwner;
        emit OwnershipTransferInitiated(owner, _newOwner);
    }

    function acceptOwnership() external onlyPendingOwner {
        address previousOwner = owner;
        owner = pendingOwner;
        pendingOwner = address(0);
        emit OwnershipTransferred(previousOwner, owner);
    }

    function setGuardian(address _guardian) external onlyOwner validAddress(_guardian) {
        address previousGuardian = guardian;
        guardian = _guardian;
        emit GuardianUpdated(previousGuardian, _guardian);
    }

    // --- Pause/Unpause ---
    function pause() external onlyGuardianOrOwner {
        _pause();
    }

    function unpause() external onlyOwner {
        _unpause();
    }

    // --- Timelock Proposal System for Critical Changes ---
    function proposeParameterChange(
        string calldata _paramName,
        uint256 _newValue
    ) external onlyOwner returns (bytes32 proposalId) {
        bytes32 paramHash = keccak256(abi.encodePacked(_paramName, _newValue));
        proposalId = keccak256(abi.encodePacked(paramHash, block.timestamp));

        proposals[proposalId] = TimelockProposal({
            paramHash: paramHash,
            executeAfter: block.timestamp + TIMELOCK_DURATION,
            executed: false
        });

        emit ProposalCreated(proposalId, paramHash, block.timestamp + TIMELOCK_DURATION);
    }

    function cancelProposal(bytes32 _proposalId) external onlyOwner {
        require(proposals[_proposalId].executeAfter > 0, "DeFiProtocol: proposal does not exist");
        require(!proposals[_proposalId].executed, "DeFiProtocol: already executed");
        delete proposals[_proposalId];
        emit ProposalCancelled(_proposalId);
    }

    function executeFeeRateChange(
        bytes32 _proposalId,
        uint256 _newFeeRate
    ) external onlyOwner {
        _validateAndMarkProposal(_proposalId, "feeRate", _newFeeRate);
        require(_newFeeRate <= MAX_FEE_RATE, "DeFiProtocol: fee rate too high");

        uint256 oldRate = feeRate;
        feeRate = _newFeeRate;
        emit FeeRateUpdated(oldRate, _newFeeRate);
    }

    function executeMaxDepositChange(
        bytes32 _proposalId,
        uint256 _newMaxDeposit
    ) external onlyOwner {
        _validateAndMarkProposal(_proposalId, "maxDepositAmount", _newMaxDeposit);
        require(_newMaxDeposit > minDepositAmount, "DeFiProtocol: invalid deposit range");

        uint256 oldAmount = maxDepositAmount;
        maxDepositAmount = _newMaxDeposit;
        emit MaxDepositAmountUpdated(oldAmount, _newMaxDeposit);
    }

    function executeMinDepositChange(
        bytes32 _proposalId,
        uint256 _newMinDeposit
    ) external onlyOwner {
        _validateAndMarkProposal(_proposalId, "minDepositAmount", _newMinDeposit);
        require(_newMinDeposit < maxDepositAmount, "DeFiProtocol: invalid deposit range");

        uint256 oldAmount = minDepositAmount;
        minDepositAmount = _newMinDeposit;
        emit MinDepositAmountUpdated(oldAmount, _newMinDeposit);
    }

    function executeWithdrawalDelayChange(
        bytes32 _proposalId,
        uint256 _newDelay
    ) external onlyOwner {
        _validateAndMarkProposal(_proposalId, "withdrawalDelay", _newDelay);
        require(_newDelay <= 30 days, "DeFiProtocol: delay too long");

        uint256 oldDelay = withdrawalDelay;
        withdrawalDelay = _newDelay;
        emit WithdrawalDelayUpdated(oldDelay, _newDelay);
    }

    function _validateAndMarkProposal(
        bytes32 _proposalId,
        string memory _paramName,
        uint256 _newValue
    ) internal {
        TimelockProposal storage proposal = proposals[_proposalId];
        require(proposal.executeAfter > 0, "DeFiProtocol: proposal does not exist");
        require(!proposal.executed, "DeFiProtocol: already executed");
        require(block.timestamp >= proposal.executeAfter, "DeFiProtocol: timelock not expired");

        bytes32 expectedHash = keccak256(abi.encodePacked(_paramName, _newValue));
        require(proposal.paramHash == expectedHash, "DeFiProtocol: param mismatch");

        proposal.executed = true;
        emit ProposalExecuted(_proposalId);
    }

    // --- Token Support Management ---
    function addSupportedToken(address _token) external onlyOwner validAddress(_token) {
        require(!supportedTokens[_token], "DeFiProtocol: token already supported");
        supportedTokens[_token] = true;
        tokenList.push(_token);
        emit TokenSupportUpdated(_token, true);
    }

    function removeSupportedToken(address _token) external onlyOwner {
        require(supportedTokens[_token], "DeFiProtocol: token not supported");
        supportedTokens[_token] = false;
        emit TokenSupportUpdated(_token, false);
    }

    // --- Core Protocol Functions ---
    function deposit(
        address _token,
        uint256 _amount
    ) external whenNotPaused nonReentrant tokenSupported(_token) {
        require(_amount >= minDepositAmount, "DeFiProtocol: below minimum deposit");
        require(
            userDeposits[msg.sender][_token] + _amount <= maxDepositAmount,
            "DeFiProtocol: exceeds maximum deposit"
        );

        uint256 fee = (_amount * feeRate) / BASIS_POINTS;
        uint256 netAmount = _amount - fee;

        IERC20Upgradeable(_token).safeTransferFrom(msg.sender, address(this), _amount);

        userDeposits[msg.sender][_token] += netAmount;
        totalDeposits[_token] += netAmount;

        emit Deposited(msg.sender, _token, netAmount);
    }

    function requestWithdrawal() external whenNotPaused {
        lastWithdrawalRequest[msg.sender] = block.timestamp;
    }

    function withdraw(
        address _token,
        uint256 _amount
    ) external whenNotPaused nonReentrant tokenSupported(_token) {
        require(_amount > 0, "DeFiProtocol: zero amount");
        require(
            userDeposits[msg.sender][_token] >= _amount,
            "DeFiProtocol: insufficient balance"
        );
        require(
            lastWithdrawalRequest[msg.sender] > 0 &&
                block.timestamp >= lastWithdrawalRequest[msg.sender] + withdrawalDelay,
            "DeFiProtocol: withdrawal delay not met"
        );

        userDeposits[msg.sender][_token] -= _amount;
        totalDeposits[_token] -= _amount;
        lastWithdrawalRequest[msg.sender] = 0;

        IERC20Upgradeable(_token).safeTransfer(msg.sender, _amount);

        emit Withdrawn(msg.sender, _token, _amount);
    }

    // --- Admin Withdrawal Functions ---
    function withdrawProtocolFees(
        address _token,
        uint256 _amount,
        address _to
    ) external onlyOwner nonReentrant validAddress(_to) {
        uint256 contractBalance = IERC20Upgradeable(_token).balanceOf(address(this));
        uint256 totalUserDeposits = totalDeposits[_token];

        // Can only withdraw excess (fees), not user deposits
        uint256 availableFees = contractBalance > totalUserDeposits
            ? contractBalance - totalUserDeposits
            : 0;
        require(_amount <= availableFees, "DeFiProtocol: insufficient fee balance");

        IERC20Upgradeable(_token).safeTransfer(_to, _amount);

        emit FundsWithdrawn(_token, _amount, _to);
    }

    function withdrawETH(
        uint256 _amount,
        address payable _to
    ) external onlyOwner nonReentrant validAddress(_to) {
        require(address(this).balance >= _amount, "DeFiProtocol: insufficient ETH balance");

        (bool success, ) = _to.call{value: _amount}("");
        require(success, "DeFiProtocol: ETH transfer failed");

        emit ETHWithdrawn(_amount, _to);
    }

    /// @notice Emergency withdrawal - can withdraw all funds when paused (for migration/emergency)
    function emergencyWithdrawToken(
        address _token,
        address _to
    ) external onlyOwner whenPaused nonReentrant validAddress(_to) {
        uint256 balance = IERC20Upgradeable(_token).balanceOf(address(this));
        require(balance > 0, "DeFiProtocol: no balance");

        IERC20Upgradeable(_token).safeTransfer(_to, balance);

        emit EmergencyWithdrawal(_token, balance, _to);
    }

    // --- View Functions ---
    function getUserDeposit(
        address _user,
        address _token
    ) external view returns (uint256) {
        return userDeposits[_user][_token];
    }

    function getProtocolFeeBalance(address _token) external view returns (uint256) {
        uint256 contractBalance = IERC20Upgradeable(_token).balanceOf(address(this));
        uint256 totalUserDeposits = totalDeposits[_token];
        return contractBalance > totalUserDeposits ? contractBalance - totalUserDeposits : 0;
    }

    function getSupportedTokens() external view returns (address[] memory) {
        return tokenList;
    }

    function canWithdraw(address _user) external view returns (bool) {
        return lastWithdrawalRequest[_user] > 0 &&
            block.timestamp >= lastWithdrawalRequest[_user] + withdrawalDelay;
    }

    // --- UUPS Upgrade Authorization ---
    function _authorizeUpgrade(
        address newImplementation
    ) internal override onlyOwner {}

    // --- Receive ETH ---
    receive() external payable {}

    // --- Storage Gap for Upgrades ---
    uint256[40] private __gap;
}