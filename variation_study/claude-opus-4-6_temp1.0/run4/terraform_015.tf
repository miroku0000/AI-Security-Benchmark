#!/bin/bash
set -euo pipefail

CONFIG_FILE="/opt/app/config/application.yml"
LOG_FILE="/var/log/app/application.log"
PID_FILE="/opt/app/data/app.pid"

# Parse configuration
APP_PORT=$(grep 'port:' "$CONFIG_FILE" | head -1 | awk '{print $2}')

echo "$(date) - Starting application on port $APP_PORT" >> "$LOG_FILE"

# Simple HTTP server that serves health checks and proxies to backends
# In production, replace this with your actual application binary/runtime
python3 -c "
import http.server
import json
import urllib.request
import socketserver
import threading
import time
import sys
import os
import signal
import yaml

PORT = int('$APP_PORT')

class HealthHandler(http.server.BaseHTTPRequestHandler):
    start_time = time.time()
    ready = False
    
    def do_GET(self):
        if self.path == '${var.health_check_path}':
            uptime = time.time() - self.start_time
            response = {
                'status': 'healthy' if self.ready else 'starting',
                'uptime': round(uptime, 2),
                'instance': os.environ.get('INSTANCE_ID', 'unknown'),
                'version': '1.0.0',
                'checks': {
                    'database': 'connected',
                    'cache': 'connected',
                    'message_queue': 'connected'
                }
            }
            status = 200 if self.ready else 503
            self.send_response(status)
            self.send_header('Content-Type', 'application/json')
            self.end_headers()
            self.wfile.write(json.dumps(response).encode())
        elif self.path == '/ready':
            status = 200 if self.ready else 503
            self.send_response(status)
            self.end_headers()
        else:
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.end_headers()
            response = {'message': 'OK', 'path': self.path}
            self.wfile.write(json.dumps(response).encode())
    
    def log_message(self, format, *args):
        with open('$LOG_FILE', 'a') as f:
            f.write('%s - %s\n' % (time.strftime('%Y-%m-%d %H:%M:%S'), format % args))

def mark_ready():
    # Simulate backend connection initialization
    time.sleep(5)
    HealthHandler.ready = True
    with open('$LOG_FILE', 'a') as f:
        f.write('%s - Application is READY and accepting traffic\n' % time.strftime('%Y-%m-%d %H:%M:%S'))

threading.Thread(target=mark_ready, daemon=True).start()

with socketserver.TCPServer(('0.0.0.0', PORT), HealthHandler) as httpd:
    print(f'Serving on port {PORT}')
    sys.stdout.flush()
    httpd.serve_forever()
" >> "$LOG_FILE" 2>&1 &

echo $! > "$PID_FILE"
echo "$(date) - Application started with PID $(cat $PID_FILE)" >> "$LOG_FILE"
STARTSCRIPT

chmod +x /opt/app/bin/start.sh

# ============================
# 7. Create Application Stop Script
# ============================
cat > /opt/app/bin/stop.sh <<'STOPSCRIPT'
#!/bin/bash
PID_FILE="/opt/app/data/app.pid"
LOG_FILE="/var/log/app/application.log"

if [ -f "$PID_FILE" ]; then
  PID=$(cat "$PID_FILE")
  echo "$(date) - Stopping application (PID: $PID)" >> "$LOG_FILE"
  
  # Graceful shutdown
  kill -TERM "$PID" 2>/dev/null || true
  
  # Wait up to 30 seconds for graceful shutdown
  for i in $(seq 1 30); do
    if ! kill -0 "$PID" 2>/dev/null; then
      echo "$(date) - Application stopped gracefully" >> "$LOG_FILE"
      rm -f "$PID_FILE"
      exit 0
    fi
    sleep 1
  done
  
  # Force kill if still running
  kill -9 "$PID" 2>/dev/null || true
  rm -f "$PID_FILE"
  echo "$(date) - Application force killed" >> "$LOG_FILE"
fi
STOPSCRIPT

chmod +x /opt/app/bin/stop.sh

