# ============================
# 9. Test Backend Connectivity
# ============================
echo "=== Testing backend connectivity ==="

test_connection() {
  local name=$1
  local host=$2
  local port=$3
  local max_retries=10
  local retry=0

  echo "Testing connection to $name ($host:$port)..."
  
  while [ $retry -lt $max_retries ]; do
    if nc -z -w5 "$host" "$port" 2>/dev/null; then
      echo "SUCCESS: Connected to $name ($host:$port)"
      return 0
    fi
    retry=$((retry + 1))
    echo "Retry $retry/$max_retries for $name..."
    sleep 3
  done

  echo "WARNING: Could not connect to $name ($host:$port) - service may not be reachable yet"
  return 0  # Don't fail instance launch for connectivity issues
}

# Parse host and port from endpoints
DB_HOST=$(echo "$DB_ENDPOINT" | cut -d: -f1)
DB_PORT=$(echo "$DB_ENDPOINT" | cut -d: -f2)
CACHE_HOST=$(echo "$CACHE_ENDPOINT" | cut -d: -f1)
CACHE_PORT=$(echo "$CACHE_ENDPOINT" | cut -d: -f2)
MQ_HOST=$(echo "$MQ_ENDPOINT" | cut -d: -f1)
MQ_PORT=$(echo "$MQ_ENDPOINT" | cut -d: -f2)

test_connection "Database" "$DB_HOST" "$DB_PORT" &
test_connection "Cache" "$CACHE_HOST" "$CACHE_PORT" &
test_connection "Message Queue" "$MQ_HOST" "$MQ_PORT" &
wait

# ============================
# 10. Start Application
# ============================
echo "=== Starting application ==="
systemctl start app.service

# Wait for application to be healthy
echo "=== Waiting for application health check ==="
MAX_HEALTH_RETRIES=30
HEALTH_RETRY=0

while [ $HEALTH_RETRY -lt $MAX_HEALTH_RETRIES ]; do
  HTTP_STATUS=$(curl -s -o /dev/null -w "%%{http_code}" http://localhost:${var.app_port}${var.health_check_path} 2>/dev/null || echo "000")
  
  if [ "$HTTP_STATUS" = "200" ]; then
    echo "Application is healthy and ready to serve traffic!"
    break
  fi
  
  HEALTH_RETRY=$((HEALTH_RETRY + 1))
  echo "Health check attempt $HEALTH_RETRY/$MAX_HEALTH_RETRIES (status: $HTTP_STATUS)..."
  sleep 2
done

if [ "$HTTP_STATUS" != "200" ]; then
  echo "WARNING: Application health check did not return 200 after $MAX_HEALTH_RETRIES attempts"
  echo "Last status: $HTTP_STATUS"
  echo "Checking application logs..."
  tail -20 /var/log/app/application.log
fi

# ============================
# 11. Configure Log Rotation
# ============================
echo "=== Configuring log rotation ==="
cat > /etc/logrotate.d/app <<'LOGROTATE'
/var/log/app/*.log {
    daily
    missingok
    rotate 14
    compress
    delaycompress
    notifempty
    copytruncate
    maxsize 100M
}
LOGROTATE

echo "=== User data script completed at $(date) ==="
echo "Instance $INSTANCE_ID is configured and operational"
USERDATA
}

# Launch Template
resource "aws_launch_template" "app" {
  name_prefix   = "${var.environment}-app-"
  image_id      = data.aws_ami.amazon_linux_2023.id
  instance_type = var.instance_type
  key_name      = var.ssh_key_name != "" ? var.ssh_key_name : null

  user_data = base64encode(local.user_data)

  iam_instance_profile {
    arn = aws_iam_instance_profile.app_instance_profile.arn
  }

  vpc_security_group_ids = [aws_security_group.app_sg.id]

  monitoring {
    enabled = true
  }

  metadata_options {
    http_endpoint               = "enabled"
    http_tokens                 = "required"
    http_put_response_hop_limit = 1
    instance_metadata_tags      = "enabled"
  }

  block_device_mappings {
    device_name = "/dev/xvda"
    ebs {
      volume_size           = 30
      volume_type           = "gp3"
      iops                  = 3000
      throughput            = 125
      encrypted             = true
      delete_on_termination = true
    }
  }

  tag_specifications {
    resource_type = "instance"
    tags = {
      Name        = "${var.environment}-app-instance"
      Environment = var.environment
      ManagedBy   = "terraform"
    }
  }

  tag_specifications {
    resource_type = "volume"
    tags = {
      Name        = "${var.environment}-app-volume"
      Environment = var.environment
    }
  }

  tags = {
    Environment = var.environment
  }

  lifecycle {
    create_before_destroy = true
  }

  depends_on = [
    aws_ssm_parameter.db_endpoint,
    aws_ssm_parameter.cache_endpoint,
    aws_ssm_parameter.mq_endpoint,
    aws_ssm_parameter.api_endpoint,
  ]
}

# Application Load Balancer
