# ============================
# 3. Fetch Backend Configuration from SSM
# ============================
echo "=== Fetching configuration from SSM Parameter Store ==="

get_ssm_param() {
  local param_name=$1
  local max_retries=5
  local retry=0
  local value=""

  while [ $retry -lt $max_retries ]; do
    value=$(aws ssm get-parameter \
      --name "$param_name" \
      --with-decryption \
      --region "$REGION" \
      --query 'Parameter.Value' \
      --output text 2>/dev/null) && break
    retry=$((retry + 1))
    echo "Retry $retry/$max_retries fetching $param_name..."
    sleep $((retry * 2))
  done

  if [ -z "$value" ]; then
    echo "FATAL: Failed to fetch parameter $param_name after $max_retries retries"
    exit 1
  fi

  echo "$value"
}

