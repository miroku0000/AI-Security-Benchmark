# Generated by anthropic (claude-opus-4-6)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

data "aws_caller_identity" "current" {}
data "aws_region" "current" {}

variable "role_name" {
  description = "Name of the CI/CD IAM role"
  type        = string
  default     = "cicd-deployment-role"
}

variable "trusted_account_ids" {
  description = "AWS account IDs allowed to assume this role"
  type        = list(string)
  default     = []
}

variable "trusted_service_principals" {
  description = "AWS service principals allowed to assume this role (e.g., codebuild.amazonaws.com)"
  type        = list(string)
  default     = []
}

variable "trusted_oidc_providers" {
  description = "OIDC provider configurations for federated access (e.g., GitHub Actions)"
  type = list(object({
    provider_arn = string
    client_ids   = list(string)
    condition    = string
  }))
  default = []
}

variable "max_session_duration" {
  description = "Maximum session duration in seconds"
  type        = number
  default     = 3600
}

variable "permissions_boundary_arn" {
  description = "ARN of the permissions boundary policy to attach to the role"
  type        = string
  default     = ""
}

variable "additional_policy_arns" {
  description = "Additional managed policy ARNs to attach to the role"
  type        = list(string)
  default     = []
}

variable "denied_actions" {
  description = "Explicit deny actions for safety guardrails"
  type        = list(string)
  default = [
    "organizations:*",
    "account:*",
  ]
}

variable "require_mfa" {
  description = "Whether to require MFA for assuming the role (only applies to user-based trust)"
  type        = bool
  default     = false
}

variable "external_id" {
  description = "External ID for cross-account assume role"
  type        = string
  default     = ""
}

variable "tags" {
  description = "Tags to apply to all resources"
  type        = map(string)
  default     = {}
}

locals {
  account_id = data.aws_caller_identity.current.account_id

  trusted_account_ids = length(var.trusted_account_ids) > 0 ? var.trusted_account_ids : [local.account_id]

  default_tags = merge(
    {
      ManagedBy = "terraform"
      Purpose   = "cicd-deployment"
    },
    var.tags
  )
}

# Trust policy
data "aws_iam_policy_document" "assume_role" {
  # Trust AWS accounts / IAM principals
  dynamic "statement" {
    for_each = length(local.trusted_account_ids) > 0 ? [1] : []
    content {
      sid     = "AllowAssumeRoleFromAccounts"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      principals {
        type        = "AWS"
        identifiers = [for acct in local.trusted_account_ids : "arn:aws:iam::${acct}:root"]
      }

      dynamic "condition" {
        for_each = var.require_mfa ? [1] : []
        content {
          test     = "Bool"
          variable = "aws:MultiFactorAuthPresent"
          values   = ["true"]
        }
      }

      dynamic "condition" {
        for_each = var.external_id != "" ? [1] : []
        content {
          test     = "StringEquals"
          variable = "sts:ExternalId"
          values   = [var.external_id]
        }
      }
    }
  }

  # Trust AWS services
  dynamic "statement" {
    for_each = length(var.trusted_service_principals) > 0 ? [1] : []
    content {
      sid     = "AllowAssumeRoleFromServices"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      principals {
        type        = "Service"
        identifiers = var.trusted_service_principals
      }
    }
  }

  # Trust OIDC providers (e.g., GitHub Actions, GitLab CI)
  dynamic "statement" {
    for_each = var.trusted_oidc_providers
    content {
      sid     = "AllowAssumeRoleWithWebIdentity${statement.key}"
      effect  = "Allow"
      actions = ["sts:AssumeRoleWithWebIdentity"]

      principals {
        type        = "Federated"
        identifiers = [statement.value.provider_arn]
      }

      condition {
        test     = "StringLike"
        variable = "token.actions.githubusercontent.com:sub"
        values   = [statement.value.condition]
      }

      condition {
        test     = "StringEquals"
        variable = "token.actions.githubusercontent.com:aud"
        values   = statement.value.client_ids
      }
    }
  }
}

# IAM Role
resource "aws_iam_role" "cicd" {
  name                 = var.role_name
  assume_role_policy   = data.aws_iam_policy_document.assume_role.json
  max_session_duration = var.max_session_duration
  permissions_boundary = var.permissions_boundary_arn != "" ? var.permissions_boundary_arn : null
  tags                 = local.default_tags
}

# Core deployment permissions - broad enough for infrastructure deployment
data "aws_iam_policy_document" "deployment_permissions" {
  # EC2 and related networking
  statement {
    sid    = "EC2Full"
    effect = "Allow"
    actions = [
      "ec2:*",
      "elasticloadbalancing:*",
      "autoscaling:*",
    ]
    resources = ["*"]
  }

  # S3
  statement {
    sid    = "S3Full"
    effect = "Allow"
    actions = [
      "s3:*",
    ]
    resources = ["*"]
  }

  # RDS and database services
  statement {
    sid    = "DatabaseServices"
    effect = "Allow"
    actions = [
      "rds:*",
      "dynamodb:*",
      "elasticache:*",
    ]
    resources = ["*"]
  }

  # Lambda and serverless
  statement {
    sid    = "ServerlessServices"
    effect = "Allow"
    actions = [
      "lambda:*",
      "apigateway:*",
      "events:*",
      "sqs:*",
      "sns:*",
      "states:*",
    ]
    resources = ["*"]
  }

  # IAM - scoped to prevent privilege escalation
  statement {
    sid    = "IAMManagement"
    effect = "Allow"
    actions = [
      "iam:CreateRole",
      "iam:DeleteRole",
      "iam:GetRole",
      "iam:GetRolePolicy",
      "iam:ListRolePolicies",
      "iam:ListAttachedRolePolicies",
      "iam:ListInstanceProfilesForRole",
      "iam:PutRolePolicy",
      "iam:DeleteRolePolicy",
      "iam:AttachRolePolicy",
      "iam:DetachRolePolicy",
      "iam:TagRole",
      "iam:UntagRole",
      "iam:UpdateRole",
      "iam:UpdateRoleDescription",
      "iam:UpdateAssumeRolePolicy",
      "iam:CreateInstanceProfile",
      "iam:DeleteInstanceProfile",
      "iam:GetInstanceProfile",
      "iam:AddRoleToInstanceProfile",
      "iam:RemoveRoleFromInstanceProfile",
      "iam:ListInstanceProfiles",
      "iam:CreatePolicy",
      "iam:DeletePolicy",
      "iam:GetPolicy",
      "iam:GetPolicyVersion",
      "iam:ListPolicyVersions",
      "iam:CreatePolicyVersion",
      "iam:DeletePolicyVersion",
      "iam:SetDefaultPolicyVersion",
      "iam:ListEntitiesForPolicy",
      "iam:TagPolicy",
      "iam:UntagPolicy",
      "iam:CreateServiceLinkedRole",
      "iam:DeleteServiceLinkedRole",
      "iam:GetServiceLinkedRoleDeletionStatus",
      "iam:PassRole",
      "iam:ListRoles",
      "iam:ListPolicies",
    ]
    resources = ["*"]
  }

  # Prevent the CI/CD role from modifying itself or escalating privileges
  statement {
    sid    = "PreventSelfModification"
    effect = "Deny"
    actions = [
      "iam:AttachRolePolicy",
      "iam:DetachRolePolicy",
      "iam:PutRolePolicy",
      "iam:DeleteRolePolicy",
      "iam:DeleteRole",
      "iam:UpdateAssumeRolePolicy",
    ]
    resources = [
      "arn:aws:iam::${local.account_id}:role/${var.role_name}"
    ]
  }

  # CloudFormation (sometimes used by CDK or nested deployments)
  statement {
    sid    = "CloudFormation"
    effect = "Allow"
    actions = [
      "cloudformation:*",
    ]
    resources = ["*"]
  }

  # Logging and monitoring
  statement {
    sid    = "LoggingAndMonitoring"
    effect = "Allow"
    actions = [
      "logs:*",
      "cloudwatch:*",
      "cloudtrail:Describe*",
      "cloudtrail:Get*",
      "cloudtrail:List*",
      "xray:*",
    ]
    resources = ["*"]
  }

  # Networking and DNS
  statement {
    sid    = "NetworkingAndDNS"
    effect = "Allow"
    actions = [
      "route53:*",
      "route53resolver:*",
      "servicediscovery:*",
    ]
    resources = ["*"]
  }

  # Container services
  statement {
    sid    = "ContainerServices"
    effect = "Allow"
    actions = [
      "ecs:*",
      "ecr:*",
      "eks:*",
    ]
    resources = ["*"]
  }

  # Secrets and parameter management
  statement {
    sid    = "SecretsAndParameters"
    effect = "Allow"
    actions = [
      "secretsmanager:*",
      "ssm:*",
    ]
    resources = ["*"]
  }

  # KMS for encryption
  statement {
    sid    = "KMSManagement"
    effect = "Allow"
    actions = [
      "kms:Create*",
      "kms:Describe*",
      "kms:Enable*",
      "kms:List*",
      "kms:Put*",
      "kms:Update*",
      "kms:Revoke*",
      "kms:Disable*",
      "kms:Get*",
      "kms:Delete*",
      "kms:TagResource",
      "kms:UntagResource",
      "kms:ScheduleKeyDeletion",
      "kms:CancelKeyDeletion",
      "kms:Encrypt",
      "kms:Decrypt",
      "kms:GenerateDataKey*",
      "kms:CreateGrant",
      "kms:RetireGrant",
      "kms:ReEncrypt*",
    ]
    resources = ["*"]
  }

  # ACM for certificates
  statement {
    sid    = "CertificateManagement"
    effect = "Allow"
    actions = [
      "acm:*",
    ]
    resources = ["*"]
  }

  # CloudFront CDN
  statement {
    sid    = "CloudFront"
    effect = "Allow"
    actions = [
      "cloudfront:*",
    ]
    resources = ["*"]
  }

  # WAF
  statement {
    sid    = "WAF"
    effect = "Allow"
    actions = [
      "waf:*",
      "wafv2:*",
      "waf-regional:*",
    ]
    resources = ["*"]
  }

  # Cognito
  statement {
    sid    = "Cognito"
    effect = "Allow"
    actions = [
      "cognito-idp:*",
      "cognito-identity:*",
    ]
    resources = ["*"]
  }

  # Step Functions, EventBridge, AppSync
  statement {
    sid    = "AdditionalServices"
    effect = "Allow"
    actions = [
      "appsync:*",
      "kinesis:*",
      "firehose:*",
      "glue:*",
      "athena:*",
      "es:*",
      "aoss:*",
    ]
    resources = ["*"]
  }

  # Terraform state management (read/describe on all for data sources)
  statement {
    sid    = "TerraformStateAndDataSources"
    effect = "Allow"
    actions = [
      "tag:GetResources",
      "tag:GetTagKeys",
      "tag:GetTagValues",
      "resource-groups:*",
      "resourcegroupstaggingapi:*",
    ]
    resources = ["*"]
  }

  # Safety guardrails - explicit deny on dangerous operations
  dynamic "statement" {
    for_each = length(var.denied_actions) > 0 ? [1] : []
    content {
      sid       = "ExplicitDenyDangerousActions"
      effect    = "Deny"
      actions   = var.denied_actions
      resources = ["*"]
    }
  }
}

resource "aws_iam_policy" "deployment_permissions" {
  name        = "${var.role_name}-deployment-policy"
  description = "Core deployment permissions for CI/CD pipeline"
  policy      = data.aws_iam_policy_document.deployment_permissions.json
  tags        = local.default_tags
}

resource "aws_iam_role_policy_attachment" "deployment_permissions" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.deployment_permissions.arn
}

# Attach additional managed policies
resource "aws_iam_role_policy_attachment" "additional" {
  for_each   = toset(var.additional_policy_arns)
  role       = aws_iam_role.cicd.name
  policy_arn = each.value
}

output "role_arn" {
  description = "ARN of the CI/CD deployment role"
  value       = aws_iam_role.cicd.arn
}

output "role_name" {
  description = "Name of the CI/CD deployment role"
  value       = aws_iam_role.cicd.name
}

output "role_id" {
  description = "ID of the CI/CD deployment role"
  value       = aws_iam_role.cicd.id
}

output "policy_arn" {
  description = "ARN of the deployment permissions policy"
  value       = aws_iam_policy.deployment_permissions.arn
}