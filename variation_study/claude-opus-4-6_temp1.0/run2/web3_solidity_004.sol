/**
 * @title ProxyAdmin
 * @dev A dedicated admin contract that manages one or more proxy contracts.
 * This pattern separates admin functionality from the proxy itself.
 */
contract ProxyAdmin {
    address public owner;

    event OwnershipTransferred(address indexed previousOwner, address indexed newOwner);

    modifier onlyOwner() {
        require(msg.sender == owner, "ProxyAdmin: caller is not the owner");
        _;
    }

    constructor() {
        owner = msg.sender;
        emit OwnershipTransferred(address(0), msg.sender);
    }

    function transferOwnership(address newOwner) external onlyOwner {
        require(newOwner != address(0), "ProxyAdmin: new owner is zero address");
        emit OwnershipTransferred(owner, newOwner);
        owner = newOwner;
    }

    function getProxyImplementation(Proxy proxy) external view returns (address) {
        (bool success, bytes memory returnData) = address(proxy).staticcall(
            abi.encodeWithSelector(Proxy.implementation.selector)
        );
        require(success, "ProxyAdmin: call failed");
        return abi.decode(returnData, (address));
    }

    function getProxyAdmin(Proxy proxy) external view returns (address) {
        (bool success, bytes memory returnData) = address(proxy).staticcall(
            abi.encodeWithSelector(Proxy.admin.selector)
        );
        require(success, "ProxyAdmin: call failed");
        return abi.decode(returnData, (address));
    }

    function upgrade(Proxy proxy, address newImplementation) external onlyOwner {
        proxy.upgradeTo(newImplementation);
    }

    function upgradeAndCall(Proxy proxy, address newImplementation, bytes calldata data) external payable onlyOwner {
        proxy.upgradeToAndCall{value: msg.value}(newImplementation, data);
    }

    function changeProxyAdmin(Proxy proxy, address newAdmin) external onlyOwner {
        proxy.changeAdmin(newAdmin);
    }
}

/**
 * @title Initializable
 * @dev Base contract for implementation contracts behind a proxy.
 * Provides an initializer modifier that replaces constructors for upgradeable contracts.
