pragma solidity ^0.8.19;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/token/ERC20/utils/SafeERC20.sol";
import "@openzeppelin/contracts/security/ReentrancyGuard.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

interface IUniswapV2Pair {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function token0() external view returns (address);
    function token1() external view returns (address);
}

interface IUniswapV2Factory {
    function getPair(address tokenA, address tokenB) external view returns (address pair);
}

contract DeFiLendingProtocol is ReentrancyGuard, Ownable {
    using SafeERC20 for IERC20;

    // --- Structs ---
    struct Market {
        bool isListed;
        uint256 collateralFactorBps;    // e.g., 7500 = 75%
        uint256 liquidationThresholdBps; // e.g., 8000 = 80%
        uint256 liquidationBonusBps;     // e.g., 500 = 5% bonus for liquidators
        uint256 totalDeposits;
        uint256 totalBorrows;
        uint256 borrowIndex;             // accumulated interest index (scaled 1e18)
        uint256 borrowRatePerSecond;     // interest rate per second (scaled 1e18)
        uint256 lastAccrualTimestamp;
        uint8 decimals;
    }

    struct UserPosition {
        uint256 depositAmount;
        uint256 borrowAmount;
        uint256 borrowIndex;  // user's snapshot of borrowIndex at time of borrow
    }

    // --- State Variables ---
    IUniswapV2Factory public dexFactory;
    address public baseToken; // e.g., WETH or stablecoin used as price reference

    mapping(address => Market) public markets;
    mapping(address => mapping(address => UserPosition)) public userPositions; // token => user => position

    address[] public listedTokens;

    // Price oracle: DEX pair addresses for each token against baseToken
    mapping(address => address) public pricePairs; // token => UniswapV2Pair address

    // TWAP storage for manipulation resistance
    struct PriceObservation {
        uint256 timestamp;
        uint256 priceCumulative; // cumulative price scaled 1e18
    }

    mapping(address => PriceObservation[]) public priceObservations;
    uint256 public constant TWAP_PERIOD = 15 minutes;
    uint256 public constant BPS_BASE = 10000;
    uint256 public constant PRICE_PRECISION = 1e18;
    uint256 public constant MIN_COLLATERAL_VALUE = 1e15; // minimum collateral in base units

    // --- Events ---
    event MarketListed(address indexed token, uint256 collateralFactor, uint256 liquidationThreshold);
    event Deposit(address indexed user, address indexed token, uint256 amount);
    event Withdraw(address indexed user, address indexed token, uint256 amount);
    event Borrow(address indexed user, address indexed token, uint256 amount);
    event Repay(address indexed user, address indexed token, uint256 amount);
    event Liquidation(
        address indexed liquidator,
        address indexed borrower,
        address indexed borrowToken,
        address collateralToken,
        uint256 repayAmount,
        uint256 seizedCollateral
    );
    event InterestAccrued(address indexed token, uint256 newBorrowIndex, uint256 interestAccumulated);
    event PriceUpdated(address indexed token, uint256 price);

    // --- Constructor ---
    constructor(address _dexFactory, address _baseToken) {
        dexFactory = IUniswapV2Factory(_dexFactory);
        baseToken = _baseToken;
    }

    // --- Admin Functions ---

    function listMarket(
        address _token,
        uint256 _collateralFactorBps,
        uint256 _liquidationThresholdBps,
        uint256 _liquidationBonusBps,
        uint256 _borrowRatePerSecond,
        uint8 _decimals
    ) external onlyOwner {
        require(!markets[_token].isListed, "Already listed");
        require(_collateralFactorBps <= 9000, "CF too high");
        require(_liquidationThresholdBps > _collateralFactorBps, "LT must > CF");
        require(_liquidationThresholdBps <= 9500, "LT too high");
        require(_liquidationBonusBps <= 1500, "Bonus too high");

        // Find or set DEX pair
        address pair;
        if (_token != baseToken) {
            pair = dexFactory.getPair(_token, baseToken);
            require(pair != address(0), "No DEX pair exists");
            pricePairs[_token] = pair;
        }

        markets[_token] = Market({
            isListed: true,
            collateralFactorBps: _collateralFactorBps,
            liquidationThresholdBps: _liquidationThresholdBps,
            liquidationBonusBps: _liquidationBonusBps,
            totalDeposits: 0,
            totalBorrows: 0,
            borrowIndex: PRICE_PRECISION,
            borrowRatePerSecond: _borrowRatePerSecond,
            lastAccrualTimestamp: block.timestamp,
            decimals: _decimals
        });

        listedTokens.push(_token);

        emit MarketListed(_token, _collateralFactorBps, _liquidationThresholdBps);
    }

    function updateBorrowRate(address _token, uint256 _newRate) external onlyOwner {
        require(markets[_token].isListed, "Not listed");
        accrueInterest(_token);
        markets[_token].borrowRatePerSecond = _newRate;
    }

    function setPricePair(address _token, address _pair) external onlyOwner {
        require(markets[_token].isListed, "Not listed");
        pricePairs[_token] = _pair;
    }

    // --- Price Oracle (DEX-based) ---

    function getSpotPrice(address _token) public view returns (uint256) {
        if (_token == baseToken) {
            return PRICE_PRECISION; // 1:1
        }

        address pair = pricePairs[_token];
        require(pair != address(0), "No price pair");

        IUniswapV2Pair uniPair = IUniswapV2Pair(pair);
        (uint112 reserve0, uint112 reserve1,) = uniPair.getReserves();

        require(reserve0 > 0 && reserve1 > 0, "Empty reserves");

        address token0 = uniPair.token0();
        uint8 tokenDecimals = markets[_token].decimals;
        uint8 baseDecimals = markets[baseToken].decimals;

        uint256 price;
        if (token0 == _token) {
            // price = reserve1 / reserve0 (how much baseToken per token)
            price = (uint256(reserve1) * PRICE_PRECISION * (10 ** tokenDecimals)) /
                    (uint256(reserve0) * (10 ** baseDecimals));
        } else {
            // price = reserve0 / reserve1
            price = (uint256(reserve0) * PRICE_PRECISION * (10 ** tokenDecimals)) /
                    (uint256(reserve1) * (10 ** baseDecimals));
        }

        return price;
    }

    // Record a price observation for TWAP
    function recordPriceObservation(address _token) public {
        uint256 currentPrice = getSpotPrice(_token);
        PriceObservation[] storage observations = priceObservations[_token];

        uint256 cumulative;
        if (observations.length > 0) {
            PriceObservation storage last = observations[observations.length - 1];
            uint256 elapsed = block.timestamp - last.timestamp;
            cumulative = last.priceCumulative + (currentPrice * elapsed);
        } else {
            cumulative = currentPrice;
        }

        observations.push(PriceObservation({
            timestamp: block.timestamp,
            priceCumulative: cumulative
        }));

        emit PriceUpdated(_token, currentPrice);
    }

    // Get TWAP price with fallback to spot
    function getTWAPPrice(address _token) public view returns (uint256) {
        if (_token == baseToken) {
            return PRICE_PRECISION;
        }

        PriceObservation[] storage observations = priceObservations[_token];

        if (observations.length < 2) {
            return getSpotPrice(_token);
        }

        PriceObservation storage latest = observations[observations.length - 1];

        // Find observation closest to TWAP_PERIOD ago
        uint256 targetTimestamp = block.timestamp > TWAP_PERIOD ?
            block.timestamp - TWAP_PERIOD : 0;

        PriceObservation storage older;
        bool found = false;

        for (uint256 i = observations.length - 1; i > 0; i--) {
            if (observations[i - 1].timestamp <= targetTimestamp) {
                older = observations[i - 1];
                found = true;
                break;
            }
        }

        if (!found) {
            older = observations[0];
        }

        uint256 elapsed = latest.timestamp - older.timestamp;
        if (elapsed == 0) {
            return getSpotPrice(_token);
        }

        uint256 twapPrice = (latest.priceCumulative - older.priceCumulative) / elapsed;
        return twapPrice;
    }

    // Use the safer of spot and TWAP (lower price for collateral valuation)
    function getPrice(address _token) public view returns (uint256) {
        uint256 spotPrice = getSpotPrice(_token);

        PriceObservation[] storage observations = priceObservations[_token];
        if (observations.length < 2) {
            return spotPrice;
        }

        uint256 twapPrice = getTWAPPrice(_token);

        // Use the lower price for safety (conservative valuation)
        return spotPrice < twapPrice ? spotPrice : twapPrice;
    }

    // --- Interest Accrual ---

    function accrueInterest(address _token) public {
        Market storage market = markets[_token];
        if (!market.isListed) return;

        uint256 elapsed = block.timestamp - market.lastAccrualTimestamp;
        if (elapsed == 0) return;

        if (market.totalBorrows > 0) {
            uint256 interestFactor = market.borrowRatePerSecond * elapsed;
            uint256 interestAccumulated = (market.totalBorrows * interestFactor) / PRICE_PRECISION;

            market.totalBorrows += interestAccumulated;
            market.borrowIndex += (market.borrowIndex * interestFactor) / PRICE_PRECISION;

            emit InterestAccrued(_token, market.borrowIndex, interestAccumulated);
        }

        market.lastAccrualTimestamp = block.timestamp;
    }

    function getCurrentBorrowBalance(address _token, address _user) public view returns (uint256) {
        UserPosition storage position = userPositions[_token][_user];
        if (position.borrowAmount == 0) return 0;

        Market storage market = markets[_token];
        uint256 elapsed = block.timestamp - market.lastAccrualTimestamp;
        uint256 currentIndex = market.borrowIndex;

        if (elapsed > 0 && market.totalBorrows > 0) {
            uint256 interestFactor = market.borrowRatePerSecond * elapsed;
            currentIndex += (currentIndex * interestFactor) / PRICE_PRECISION;
        }

        return (position.borrowAmount * currentIndex) / position.borrowIndex;
    }

    // --- Core Lending Functions ---

    function deposit(address _token, uint256 _amount) external nonReentrant {
        require(markets[_token].isListed, "Market not listed");
        require(_amount > 0, "Zero amount");

        accrueInterest(_token);

        IERC20(_token).safeTransferFrom(msg.sender, address(this), _amount);

        userPositions[_token][msg.sender].depositAmount += _amount;
        markets[_token].totalDeposits += _amount;

        // Record price observation
        if (_token != baseToken && pricePairs[_token] != address(0)) {
            recordPriceObservation(_token);
        }

        emit Deposit(msg.sender, _token, _amount);
    }

    function withdraw(address _token, uint256 _amount) external nonReentrant {
        require(markets[_token].isListed, "Market not listed");

        accrueInterest(_token);

        UserPosition storage position = userPositions[_token][msg.sender];
        require(position.depositAmount >= _amount, "Insufficient deposit");

        position.depositAmount -= _amount;
        markets[_token].totalDeposits -= _amount;

        // Check that the user remains solvent after withdrawal
        require(_isAccountHealthy(msg.sender), "Would become undercollateralized");

        IERC20(_token).safeTransfer(msg.sender, _amount);

        emit Withdraw(msg.sender, _token, _amount);
    }

    function borrow(address _token, uint256 _amount) external nonReentrant {
        Market storage market = markets[_token];
        require(market.isListed, "Market not listed");
        require(_amount > 0, "Zero amount");

        accrueInterest(_token);

        // Check liquidity
        uint256 availableLiquidity = market.totalDeposits - market.totalBorrows;
        require(_amount <= availableLiquidity, "Insufficient liquidity");

        UserPosition storage position = userPositions[_token][msg.sender];

        // Update user borrow
        if (position.borrowAmount > 0) {
            // Settle existing borrow with current index
            position.borrowAmount = getCurrentBorrowBalance(_token, msg.sender);
        }
        position.borrowAmount += _amount;
        position.borrowIndex = market.borrowIndex;

        market.totalBorrows += _amount;

        // Check that the user has sufficient collateral
        require(_isAccountHealthy(msg.sender), "Insufficient collateral");

        // Record price observation
        if (_token != baseToken && pricePairs[_token] != address(0)) {
            recordPriceObservation(_token);
        }

        IERC20(_token).safeTransfer(msg.sender, _amount);

        emit Borrow(msg.sender, _token, _amount);
    }

    function repay(address _token, uint256 _amount) external nonReentrant {
        require(markets[_token].isListed, "Market not listed");

        accrueInterest(_token);

        UserPosition storage position = userPositions[_token][msg.sender];
        uint256 currentBorrow = getCurrentBorrowBalance(_token, msg.sender);
        require(currentBorrow > 0, "No borrow to repay");

        uint256 repayAmount = _amount > currentBorrow ? currentBorrow : _amount;

        IERC20(_token).safeTransferFrom(msg.sender, address(this), repayAmount);

        // Calculate how much of the original principal this represents
        uint256 borrowReduction = (repayAmount * position.borrowIndex) / markets[_token].borrowIndex;
        if (borrowReduction > position.borrowAmount) {
            borrowReduction = position.borrowAmount;
        }

        position.borrowAmount -= borrowReduction;
        if (position.borrowAmount == 0) {
            position.borrowIndex = 0;
        }

        markets[_token].totalBorrows = markets[_token].totalBorrows > repayAmount ?
            markets[_token].totalBorrows - repayAmount : 0;

        emit Repay(msg.sender, _token, repayAmount);
    }

    // --- Liquidation ---

    function liquidate(
        address _borrower,
        address _borrowToken,
        address _collateralToken,
        uint256 _repayAmount
    ) external nonReentrant {
        require(_borrower != msg.sender, "Cannot self-liquidate");
        require(markets[_borrowToken].isListed, "Borrow market not listed");
        require(markets[_collateralToken].isListed, "Collateral market not listed");

        accrueInterest(_borrowToken);
        accrueInterest(_collateralToken);

        // Check that borrower is underwater (using liquidation threshold)
        require(!_isAccountHealthyForLiquidation(_borrower), "Account is healthy");

        UserPosition storage borrowPosition = userPositions[_borrowToken][_borrower];
        uint256 currentBorrow = getCurrentBorrowBalance(_borrowToken, _borrower);
        require(currentBorrow > 0, "No borrow");

        // Can only repay up to 50% of the borrow (close factor)
        uint256 maxRepay = (currentBorrow * 5000) / BPS_BASE;
        uint256 repayAmount = _repayAmount > maxRepay ? maxRepay : _repayAmount;

        // Calculate collateral to seize
        uint256 borrowTokenPrice = getPrice(_borrowToken);
        uint256 collateralTokenPrice = getPrice(_collateralToken);

        uint256 liquidationBonus = markets[_collateralToken].liquidationBonusBps;

        // seizeAmount = repayAmount * borrowPrice / collateralPrice * (1 + bonus)
        uint256 seizeValueInBase = (repayAmount * borrowTokenPrice) / PRICE_PRECISION;
        uint256 seizeAmountWithBonus = (seizeValueInBase * (BPS_BASE + liquidationBonus)) / BPS_BASE;
        uint256 seizeTokens = (seizeAmountWithBonus * PRICE_PRECISION) / collateralTokenPrice;

        // Adjust for decimals
        uint8 borrowDecimals = markets[_borrowToken].decimals;
        uint8 collateralDecimals = markets[_collateralToken].decimals;
        if (collateralDecimals > borrowDecimals) {
            seizeTokens = seizeTokens * (10 ** (collateralDecimals - borrowDecimals));
        } else if (borrowDecimals > collateralDecimals) {
            seizeTokens = seizeTokens / (10 ** (borrowDecimals - collateralDecimals));
        }

        UserPosition storage collateralPosition = userPositions[_collateralToken][_borrower];
        require(collateralPosition.depositAmount >= seizeTokens, "Insufficient collateral to seize");

        // Execute liquidation

        // 1. Repay the borrow
        IERC20(_borrowToken).safeTransferFrom(msg.sender, address(this), repayAmount);

        uint256 borrowReduction = (repayAmount * borrowPosition.borrowIndex) / markets[_borrowToken].borrowIndex;
        if (borrowReduction > borrowPosition.borrowAmount) {
            borrowReduction = borrowPosition.borrowAmount;
        }
        borrowPosition.borrowAmount -= borrowReduction;
        if (borrowPosition.borrowAmount == 0) {
            borrowPosition.borrowIndex = 0;
        }

        markets[_borrowToken].totalBorrows = markets[_borrowToken].totalBorrows > repayAmount ?
            markets[_borrowToken].totalBorrows - repayAmount : 0;

        // 2. Seize collateral
        collateralPosition.depositAmount -= seizeTokens;
        markets[_collateralToken].totalDeposits -= seizeTokens;

        IERC20(_collateralToken).safeTransfer(msg.sender, seizeTokens);

        // Record price observations
        if (_borrowToken != baseToken) recordPriceObservation(_borrowToken);
        if (_collateralToken != baseToken) recordPriceObservation(_collateralToken);

        emit Liquidation(msg.sender, _borrower, _borrowToken, _collateralToken, repayAmount, seizeTokens);
    }

    // --- Account Health Calculations ---

    function getAccountCollateralValue(address _user) public view returns (uint256 totalCollateralValue) {
        for (uint256 i = 0; i < listedTokens.length; i++) {
            address token = listedTokens[i];
            UserPosition storage position = userPositions[token][_user];

            if (position.depositAmount > 0) {
                uint256 price = getPrice(token);
                uint256 depositValueInBase = (position.depositAmount * price) / PRICE_PRECISION;

                // Normalize to 18 decimals
                uint8 decimals = markets[token].decimals;
                if (decimals < 18) {
                    depositValueInBase = depositValueInBase * (10 ** (18 - decimals));
                } else if (decimals > 18) {
                    depositValueInBase = depositValueInBase / (10 ** (decimals - 18));
                }

                uint256 weightedValue = (depositValueInBase * markets[token].collateralFactorBps) / BPS_BASE;
                totalCollateralValue += weightedValue;
            }
        }
    }

    function getAccountBorrowValue(address _user) public view returns (uint256 totalBorrowValue) {
        for (uint256 i = 0; i < listedTokens.length; i++) {
            address token = listedTokens[i];
            uint256 borrowBalance = getCurrentBorrowBalance(token, _user);

            if (borrowBalance > 0) {
                uint256 price = getPrice(token);
                uint256 borrowValueInBase = (borrowBalance * price) / PRICE_PRECISION;

                uint8 decimals = markets[token].decimals;
                if (decimals < 18) {
                    borrowValueInBase = borrowValueInBase * (10 ** (18 - decimals));
                } else if (decimals > 18) {
                    borrowValueInBase = borrowValueInBase / (10 ** (decimals - 18));
                }

                totalBorrowValue += borrowValueInBase;
            }
        }
    }

    function _isAccountHealthy(address _user) internal view returns (bool) {
        uint256 collateralValue = getAccountCollateralValue(_user);
        uint256 borrowValue = getAccountBorrowValue(_user);

        if (borrowValue == 0) return true;
        return collateralValue >= borrowValue;
    }

    function _isAccountHealthyForLiquidation(address _user) internal view returns (bool) {
        // Uses liquidation threshold instead of collateral factor
        uint256 totalCollateralValueAtLiquidation = 0;

        for (uint256 i = 0; i < listedTokens.length; i++) {
            address token = listedTokens[i];
            UserPosition storage position = userPositions[token][_user];

            if (position.depositAmount > 0) {
                uint256 price = getPrice(token);
                uint256 depositValueInBase = (position.depositAmount * price) / PRICE_PRECISION;

                uint8 decimals = markets[token].decimals;
                if (decimals < 18) {
                    depositValueInBase = depositValueInBase * (10 ** (18 - decimals));
                } else if (decimals > 18) {
                    depositValueInBase = depositValueInBase / (10 ** (decimals - 18));
                }

                uint256 weightedValue = (depositValueInBase * markets[token].liquidationThresholdBps) / BPS_BASE;
                totalCollateralValueAtLiquidation += weightedValue;
            }
        }

        uint256 borrowValue = getAccountBorrowValue(_user);
        if (borrowValue == 0) return true;
        return totalCollateralValueAtLiquidation >= borrowValue;
    }

    // --- View Functions ---

    function isAccountHealthy(address _user) external view returns (bool) {
        return _isAccountHealthy(_user);
    }

    function isLiquidatable(address _user) external view returns (bool) {
        return !_isAccountHealthyForLiquidation(_user);
    }

    function getHealthFactor(address _user) external view returns (uint256) {
        uint256 borrowValue = getAccountBorrowValue(_user);
        if (borrowValue == 0) return type(uint256).max;

        uint256 collateralValue = getAccountCollateralValue(_user);
        return (collateralValue * PRICE_PRECISION) / borrowValue;
    }

    function getMarketUtilization(address _token) external view returns (uint256) {
        Market storage market = markets[_token];
        if (market.totalDeposits == 0) return 0;
        return (market.totalBorrows * BPS_BASE) / market.totalDeposits;
    }

    function getAvailableLiquidity(address _token) external view returns (uint256) {
        Market storage market = markets[_token];
        if (market.totalBorrows >= market.totalDeposits) return 0;
        return market.totalDeposits - market.totalBorrows;
    }

    function getListedTokensCount() external view returns (uint256) {
        return listedTokens.length;
    }

    function getUserPosition(address _token, address _user)
        external
        view
        returns (uint256 deposited, uint256 borrowed, uint256 currentBorrowWithInterest)
    {
        UserPosition storage position = userPositions[_token][_user];
        deposited = position.depositAmount;
        borrowed = position.borrowAmount;
        currentBorrowWithInterest = getCurrentBorrowBalance(_token, _user);
    }

    // --- Emergency Functions ---

    function emergencyPause(address _token) external onlyOwner {
        markets[_token].isListed = false;
    }

    function emergencyUnpause(address _token) external onlyOwner {
        markets[_token].isListed = true;
    }

    function emergencyWithdrawToken(address _token, uint256 _amount) external onlyOwner {
        IERC20(_token).safeTransfer(owner(), _amount);
    }
}