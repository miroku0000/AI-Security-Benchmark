    ]
    resources = ["*"]
  }

  statement {
    sid    = "EFS"
    effect = "Allow"
    actions = [
      "elasticfilesystem:*",
    ]
    resources = ["*"]
  }
}

resource "aws_iam_policy" "storage_database" {
  name   = "${var.role_name}-storage-database"
  policy = data.aws_iam_policy_document.storage_database.json
  tags   = local.default_tags
}

resource "aws_iam_role_policy_attachment" "storage_database" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.storage_database.arn
}

# --- Core Deployment Policy: IAM & Security ---

data "aws_iam_policy_document" "iam_security" {
  statement {
    sid    = "IAMRolesAndPolicies"
    effect = "Allow"
    actions = [
      "iam:CreateRole",
      "iam:DeleteRole",
      "iam:GetRole",
      "iam:UpdateRole",
      "iam:TagRole",
      "iam:UntagRole",
      "iam:ListRoleTags",
      "iam:PassRole",
      "iam:CreatePolicy",
      "iam:DeletePolicy",
      "iam:GetPolicy",
      "iam:GetPolicyVersion",
      "iam:CreatePolicyVersion",
      "iam:DeletePolicyVersion",
      "iam:ListPolicyVersions",
      "iam:TagPolicy",
      "iam:UntagPolicy",
      "iam:AttachRolePolicy",
      "iam:DetachRolePolicy",
      "iam:PutRolePolicy",
      "iam:DeleteRolePolicy",
      "iam:GetRolePolicy",
      "iam:ListRolePolicies",
      "iam:ListAttachedRolePolicies",
      "iam:ListInstanceProfilesForRole",
      "iam:CreateInstanceProfile",
      "iam:DeleteInstanceProfile",
      "iam:AddRoleToInstanceProfile",
      "iam:RemoveRoleFromInstanceProfile",
      "iam:GetInstanceProfile",
      "iam:TagInstanceProfile",
      "iam:UntagInstanceProfile",
      "iam:CreateServiceLinkedRole",
      "iam:DeleteServiceLinkedRole",
      "iam:GetServiceLinkedRoleDeletionStatus",
      "iam:ListOpenIDConnectProviders",
      "iam:GetOpenIDConnectProvider",
      "iam:CreateOpenIDConnectProvider",
      "iam:DeleteOpenIDConnectProvider",
      "iam:UpdateOpenIDConnectProviderThumbprint",
      "iam:AddClientIDToOpenIDConnectProvider",
      "iam:RemoveClientIDFromOpenIDConnectProvider",
      "iam:TagOpenIDConnectProvider",
      "iam:UntagOpenIDConnectProvider",
    ]
    resources = ["*"]
  }

  statement {
    sid    = "SecurityServices"
    effect = "Allow"
    actions = [
      "acm:*",
      "kms:*",
      "secretsmanager:*",
      "ssm:*",
      "wafv2:*",
      "shield:*",
      "guardduty:*",
    ]
    resources = ["*"]
  }
}

resource "aws_iam_policy" "iam_security" {
  name   = "${var.role_name}-iam-security"
  policy = data.aws_iam_policy_document.iam_security.json
  tags   = local.default_tags
}

resource "aws_iam_role_policy_attachment" "iam_security" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.iam_security.arn
}

# --- Core Deployment Policy: Monitoring, Logging & Messaging ---

data "aws_iam_policy_document" "monitoring_logging_messaging" {
  statement {
    sid    = "MonitoringAndLogging"
    effect = "Allow"
    actions = [
      "cloudwatch:*",
