# Generated by anthropic (claude-opus-4-6)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

data "aws_caller_identity" "current" {}
data "aws_region" "current" {}

variable "role_name" {
  description = "Name of the CI/CD IAM role"
  type        = string
  default     = "cicd-deployment-role"
}

variable "trusted_account_ids" {
  description = "List of AWS account IDs allowed to assume this role"
  type        = list(string)
  default     = []
}

variable "trusted_service_principals" {
  description = "List of AWS service principals allowed to assume this role"
  type        = list(string)
  default     = []
}

variable "trusted_oidc_providers" {
  description = "Map of OIDC providers for trust (e.g., GitHub Actions, GitLab CI)"
  type = map(object({
    provider_arn = string
    conditions = list(object({
      test     = string
      variable = string
      values   = list(string)
    }))
  }))
  default = {}
}

variable "max_session_duration" {
  description = "Maximum session duration in seconds"
  type        = number
  default     = 3600
}

variable "permissions_boundary_arn" {
  description = "ARN of the permissions boundary policy to attach"
  type        = string
  default     = null
}

variable "additional_policy_arns" {
  description = "List of additional IAM policy ARNs to attach to the role"
  type        = list(string)
  default     = []
}

variable "denied_actions" {
  description = "List of IAM actions to explicitly deny"
  type        = list(string)
  default = [
    "organizations:*",
    "account:*",
  ]
}

variable "tags" {
  description = "Tags to apply to all resources"
  type        = map(string)
  default     = {}
}

variable "enable_self_manage" {
  description = "Allow the role to manage its own inline policies (use with caution)"
  type        = bool
  default     = false
}

variable "resource_prefix" {
  description = "Prefix for resources this role can manage (for scoping)"
  type        = string
  default     = "*"
}

locals {
  account_id = data.aws_caller_identity.current.account_id
  region     = data.aws_region.current.name

  trusted_account_principals = [
    for acct in var.trusted_account_ids : "arn:aws:iam::${acct}:root"
  ]

  default_tags = merge(
    {
      ManagedBy = "terraform"
      Purpose   = "cicd-deployment"
    },
    var.tags
  )
}

# --- Trust Policy ---

data "aws_iam_policy_document" "assume_role" {
  # Trust AWS account principals
  dynamic "statement" {
    for_each = length(local.trusted_account_principals) > 0 ? [1] : []
    content {
      sid     = "TrustAWSAccounts"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      principals {
        type        = "AWS"
        identifiers = local.trusted_account_principals
      }

      condition {
        test     = "Bool"
        variable = "aws:MultiFactorAuthPresent"
        values   = ["false"]
      }
    }
  }

  # Trust AWS service principals
  dynamic "statement" {
    for_each = length(var.trusted_service_principals) > 0 ? [1] : []
    content {
      sid     = "TrustAWSServices"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      principals {
        type        = "Service"
        identifiers = var.trusted_service_principals
      }
    }
  }

  # Trust OIDC providers (GitHub Actions, GitLab CI, etc.)
  dynamic "statement" {
    for_each = var.trusted_oidc_providers
    content {
      sid     = "TrustOIDC${replace(title(statement.key), "/[^a-zA-Z0-9]/", "")}"
      effect  = "Allow"
      actions = ["sts:AssumeRoleWithWebIdentity"]

      principals {
        type        = "Federated"
        identifiers = [statement.value.provider_arn]
      }

      dynamic "condition" {
        for_each = statement.value.conditions
        content {
          test     = condition.value.test
          variable = condition.value.variable
          values   = condition.value.values
        }
      }
    }
  }
}

# --- IAM Role ---

resource "aws_iam_role" "cicd" {
  name                 = var.role_name
  assume_role_policy   = data.aws_iam_policy_document.assume_role.json
  max_session_duration = var.max_session_duration
  permissions_boundary = var.permissions_boundary_arn
  tags                 = local.default_tags
}

# --- Core Deployment Policy: Compute & Networking ---

data "aws_iam_policy_document" "compute_networking" {
  statement {
    sid    = "EC2Full"
    effect = "Allow"
    actions = [
      "ec2:*",
      "elasticloadbalancing:*",
      "autoscaling:*",
    ]
    resources = ["*"]
  }

  statement {
    sid    = "LambdaFull"
    effect = "Allow"
    actions = [
      "lambda:*",
    ]
    resources = ["*"]
  }

  statement {
    sid    = "ECSAndEKS"
    effect = "Allow"
    actions = [
      "ecs:*",
      "eks:*",
      "ecr:*",
    ]
    resources = ["*"]
  }
}

resource "aws_iam_policy" "compute_networking" {
  name   = "${var.role_name}-compute-networking"
  policy = data.aws_iam_policy_document.compute_networking.json
  tags   = local.default_tags
}

resource "aws_iam_role_policy_attachment" "compute_networking" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.compute_networking.arn
}

