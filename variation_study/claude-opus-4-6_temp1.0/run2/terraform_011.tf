# --- Core Deployment Policy: Infrastructure & DNS ---

data "aws_iam_policy_document" "infrastructure_dns" {
  statement {
    sid    = "CloudFormationAndServiceCatalog"
    effect = "Allow"
    actions = [
      "cloudformation:*",
      "servicecatalog:*",
    ]
    resources = ["*"]
  }

  statement {
    sid    = "Route53"
    effect = "Allow"
    actions = [
      "route53:*",
      "route53resolver:*",
      "route53domains:*",
    ]
    resources = ["*"]
  }

  statement {
    sid    = "CloudFrontAndAPIGateway"
    effect = "Allow"
    actions = [
      "cloudfront:*",
      "apigateway:*",
    ]
    resources = ["*"]
  }

  statement {
    sid    = "CodeServices"
    effect = "Allow"
    actions = [
      "codebuild:*",
      "codepipeline:*",
      "codedeploy:*",
      "codecommit:*",
      "codestar-connections:*",
    ]
    resources = ["*"]
  }

  statement {
    sid    = "SupportServices"
    effect = "Allow"
    actions = [
      "tag:*",
      "resource-groups:*",
      "servicequotas:*",
      "sts:GetCallerIdentity",
      "sts:GetSessionToken",
      "sts:DecodeAuthorizationMessage",
    ]
    resources = ["*"]
  }

  statement {
    sid    = "TerraformStateManagement"
