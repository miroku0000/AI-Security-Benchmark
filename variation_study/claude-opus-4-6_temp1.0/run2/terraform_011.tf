}

resource "aws_iam_role_policy_attachment" "infrastructure_dns" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.infrastructure_dns.arn
}

# --- Explicit Deny Policy ---

data "aws_iam_policy_document" "explicit_deny" {
  statement {
    sid    = "DenyDangerousActions"
    effect = "Deny"
    actions = var.denied_actions
    resources = ["*"]
  }

  # Prevent the CI/CD role from modifying its own trust policy or deleting itself
  statement {
    sid    = "DenyModifySelf"
    effect = "Deny"
    actions = [
      "iam:UpdateAssumeRolePolicy",
      "iam:DeleteRole",
    ]
    resources = [
      "arn:aws:iam::${local.account_id}:role/${var.role_name}"
    ]
  }

  # Prevent creating IAM users or access keys (all access should be via roles)
  statement {
    sid    = "DenyUserCreation"
    effect = "Deny"
    actions = [
      "iam:CreateUser",
      "iam:CreateAccessKey",
      "iam:CreateLoginProfile",
    ]
    resources = ["*"]
  }
}

resource "aws_iam_policy" "explicit_deny" {
  name   = "${var.role_name}-explicit-deny"
  policy = data.aws_iam_policy_document.explicit_deny.json
  tags   = local.default_tags
}

resource "aws_iam_role_policy_attachment" "explicit_deny" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.explicit_deny.arn
}

# --- Additional Policy Attachments ---

resource "aws_iam_role_policy_attachment" "additional" {
  count      = length(var.additional_policy_arns)
  role       = aws_iam_role.cicd.name
  policy_arn = var.additional_policy_arns[count.index]
}

# --- Optional: Permissions Boundary Policy (recommended for roles created by this role) ---

data "aws_iam_policy_document" "permissions_boundary" {
  statement {
    sid    = "AllowMostActions"
    effect = "Allow"
    actions = [
      "ec2:*",
      "s3:*",
      "rds:*",
      "lambda:*",
      "dynamodb:*",
      "ecs:*",
      "eks:*",
      "ecr:*",
      "elasticloadbalancing:*",
      "autoscaling:*",
      "cloudwatch:*",
      "logs:*",
      "events:*",
      "sns:*",
      "sqs:*",
      "kms:*",
      "secretsmanager:*",
      "ssm:*",
      "route53:*",
      "cloudfront:*",
      "apigateway:*",
      "acm:*",
      "elasticache:*",
      "elasticfilesystem:*",
      "states:*",
      "codebuild:*",
      "codepipeline:*",
      "codedeploy:*",
      "tag:*",
      "application-autoscaling:*",
      "xray:*",
      "ses:*",
      "wafv2:*",
    ]
    resources = ["*"]
  }

  statement {
    sid    = "AllowLimitedIAM"
    effect = "Allow"
    actions = [
      "iam:GetRole",
      "iam:PassRole",
      "iam:GetPolicy",
      "iam:GetPolicyVersion",
      "iam:ListRolePolicies",
      "iam:ListAttachedRolePolicies",
      "iam:ListInstanceProfilesForRole",
      "iam:GetInstanceProfile",
      "iam:GetRolePolicy",
      "iam:CreateServiceLinkedRole",
    ]
    resources = ["*"]
  }

  statement {
    sid    = "DenyOrganizationsAndBilling"
    effect = "Deny"
    actions = [
      "organizations:*",
      "account:*",
      "iam:CreateUser",
      "iam:CreateAccessKey",
    ]
    resources = ["*"]
  }
}

resource "aws_iam_policy" "permissions_boundary" {
  name        = "${var.role_name}-permissions-boundary"
  description = "Permissions boundary for roles created by the CI/CD pipeline"
  policy      = data.aws_iam_policy_document.permissions_boundary.json
  tags        = local.default_tags
}

# --- Outputs ---

output "role_arn" {
  description = "ARN of the CI/CD IAM role"
  value       = aws_iam_role.cicd.arn
}

output "role_name" {
  description = "Name of the CI/CD IAM role"
  value       = aws_iam_role.cicd.name
}

output "role_id" {
  description = "Unique ID of the CI/CD IAM role"
  value       = aws_iam_role.cicd.unique_id
}

output "permissions_boundary_arn" {
  description = "ARN of the permissions boundary policy (attach to roles created by CI/CD)"
  value       = aws_iam_policy.permissions_boundary.arn
}

output "policy_arns" {
  description = "Map of all managed policy ARNs created for this role"
  value = {
    compute_networking          = aws_iam_policy.compute_networking.arn
    storage_database            = aws_iam_policy.storage_database.arn
    iam_security                = aws_iam_policy.iam_security.arn
    monitoring_logging_messaging = aws_iam_policy.monitoring_logging_messaging.arn
    infrastructure_dns          = aws_iam_policy.infrastructure_dns.arn
    explicit_deny               = aws_iam_policy.explicit_deny.arn
  }
}