# Generated by anthropic (claude-opus-4-6)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

variable "project_name" {
  description = "Name of the project for tagging"
  type        = string
  default     = "dev-team"
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "development"
}

variable "vpc_id" {
  description = "VPC ID where the security group will be created"
  type        = string
}

variable "allowed_ssh_cidrs" {
  description = "List of CIDR blocks allowed SSH access (add your team members' IPs/ranges)"
  type        = list(string)
  default     = []
}

variable "allowed_http_cidrs" {
  description = "List of CIDR blocks allowed HTTP access"
  type        = list(string)
  default     = ["0.0.0.0/0"]
}

variable "allowed_https_cidrs" {
  description = "List of CIDR blocks allowed HTTPS access"
  type        = list(string)
  default     = ["0.0.0.0/0"]
}

variable "additional_ingress_rules" {
  description = "Additional ingress rules for the security group"
  type = list(object({
    description = string
    from_port   = number
    to_port     = number
    protocol    = string
    cidr_blocks = list(string)
  }))
  default = []
}

variable "team_member_ips" {
  description = "Map of team member names to their IP addresses for SSH access"
  type        = map(string)
  default     = {}
}

locals {
  team_ssh_cidrs = [for ip in values(var.team_member_ips) : "${ip}/32"]
  all_ssh_cidrs  = distinct(concat(var.allowed_ssh_cidrs, local.team_ssh_cidrs))
}

resource "aws_security_group" "dev_team" {
  name        = "${var.project_name}-${var.environment}-sg"
  description = "Security group for ${var.project_name} development team remote access"
  vpc_id      = var.vpc_id

  tags = {
    Name        = "${var.project_name}-${var.environment}-sg"
    Environment = var.environment
    Project     = var.project_name
    ManagedBy   = "terraform"
  }
}

resource "aws_vpc_security_group_ingress_rule" "ssh" {
  for_each = toset(local.all_ssh_cidrs)

  security_group_id = aws_security_group.dev_team.id
  description       = "SSH access for development team"
  from_port         = 22
  to_port           = 22
  ip_protocol       = "tcp"
  cidr_ipv4         = each.value

  tags = {
    Name = "${var.project_name}-ssh-${each.value}"
  }
}

resource "aws_vpc_security_group_ingress_rule" "http" {
  for_each = toset(var.allowed_http_cidrs)

  security_group_id = aws_security_group.dev_team.id
  description       = "HTTP access"
  from_port         = 80
  to_port           = 80
  ip_protocol       = "tcp"
  cidr_ipv4         = each.value

  tags = {
    Name = "${var.project_name}-http-${each.value}"
  }
}

resource "aws_vpc_security_group_ingress_rule" "https" {
  for_each = toset(var.allowed_https_cidrs)

  security_group_id = aws_security_group.dev_team.id
  description       = "HTTPS access"
  from_port         = 443
  to_port           = 443
  ip_protocol       = "tcp"
  cidr_ipv4         = each.value

  tags = {
    Name = "${var.project_name}-https-${each.value}"
  }
}

resource "aws_vpc_security_group_ingress_rule" "additional" {
  for_each = { for idx, rule in var.additional_ingress_rules : idx => rule }

  security_group_id = aws_security_group.dev_team.id
  description       = each.value.description
  from_port         = each.value.from_port
  to_port           = each.value.to_port
  ip_protocol       = each.value.protocol
  cidr_ipv4         = each.value.cidr_blocks[0]

  tags = {
    Name = "${var.project_name}-additional-${each.key}"
  }
}

resource "aws_vpc_security_group_egress_rule" "all_outbound" {
  security_group_id = aws_security_group.dev_team.id
  description       = "Allow all outbound traffic"
  ip_protocol       = "-1"
  cidr_ipv4         = "0.0.0.0/0"

  tags = {
    Name = "${var.project_name}-egress-all"
  }
}

output "security_group_id" {
  description = "ID of the created security group"
  value       = aws_security_group.dev_team.id
}

output "security_group_arn" {
  description = "ARN of the created security group"
  value       = aws_security_group.dev_team.arn
}

output "security_group_name" {
  description = "Name of the created security group"
  value       = aws_security_group.dev_team.name
}

output "allowed_ssh_cidrs" {
  description = "CIDR blocks allowed for SSH access"
  value       = local.all_ssh_cidrs
}