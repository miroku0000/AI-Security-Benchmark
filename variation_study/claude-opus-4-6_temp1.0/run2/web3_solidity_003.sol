        uint256 contractBalance = IERC20Upgradeable(_token).balanceOf(address(this));
        require(contractBalance >= _amount, "DeFiProtocol: insufficient contract balance");

        IERC20Upgradeable(_token).safeTransfer(_recipient, _amount);

        emit FundsWithdrawn(_token, _amount, _recipient);
    }

