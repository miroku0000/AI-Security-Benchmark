        require(_newDelay <= 30 days, "DeFiProtocol: delay too long");
        bytes32 paramId = keccak256("withdrawalDelay");
        uint256 executionTime = block.timestamp + TIMELOCK_DURATION;

        pendingChanges[paramId] = PendingChange({
            paramHash: paramId,
            value: _newDelay,
            executionTime: executionTime,
            exists: true
        });

        emit ParameterChangeProposed(paramId, _newDelay, executionTime);
    }

    function executeParameterChange(bytes32 _paramId) external onlyOwner {
        PendingChange storage change = pendingChanges[_paramId];
        require(change.exists, "DeFiProtocol: no pending change");
        require(block.timestamp >= change.executionTime, "DeFiProtocol: timelock not expired");

        uint256 newValue = change.value;

        if (_paramId == keccak256("feeRate")) {
            feeRate = newValue;
        } else if (_paramId == keccak256("maxDepositAmount")) {
            maxDepositAmount = newValue;
        } else if (_paramId == keccak256("minDepositAmount")) {
            minDepositAmount = newValue;
        } else if (_paramId == keccak256("withdrawalDelay")) {
            withdrawalDelay = newValue;
        } else {
            revert("DeFiProtocol: unknown parameter");
        }

        delete pendingChanges[_paramId];
        emit ParameterChangeExecuted(_paramId, newValue);
    }

    function cancelParameterChange(bytes32 _paramId) external onlyOwner {
        require(pendingChanges[_paramId].exists, "DeFiProtocol: no pending change");
        delete pendingChanges[_paramId];
        emit ParameterChangeCancelled(_paramId);
    }

    // ============ Token Whitelist ============

    function setTokenWhitelist(address _token, bool _status)
        external
        onlyOwner
        validAddress(_token)
    {
        whitelistedTokens[_token] = _status;
        emit TokenWhitelisted(_token, _status);
    }

    // ============ Core Protocol Functions ============

    function deposit(address _token, uint256 _amount)
        external
        whenNotPaused
        nonReentrant
        tokenIsWhitelisted(_token)
    {
        require(_amount >= minDepositAmount, "DeFiProtocol: below minimum deposit");
        require(
            userDeposits[msg.sender] + _amount <= maxDepositAmount,
            "DeFiProtocol: exceeds maximum deposit"
        );

        uint256 fee = (_amount * feeRate) / BASIS_POINTS;
        uint256 netAmount = _amount - fee;

        userDeposits[msg.sender] += netAmount;
        lastDepositTimestamp[msg.sender] = block.timestamp;

        IERC20Upgradeable(_token).safeTransferFrom(msg.sender, address(this), _amount);

        emit Deposited(msg.sender, _token, netAmount);
    }

    function withdraw(address _token, uint256 _amount)
        external
        whenNotPaused
        nonReentrant
        tokenIsWhitelisted(_token)
    {
        require(_amount > 0, "DeFiProtocol: zero amount");
        require(userDeposits[msg.sender] >= _amount, "DeFiProtocol: insufficient balance");
        require(
            block.timestamp >= lastDepositTimestamp[msg.sender] + withdrawalDelay,
            "DeFiProtocol: withdrawal delay not met"
        );

        userDeposits[msg.sender] -= _amount;

        IERC20Upgradeable(_token).safeTransfer(msg.sender, _amount);

        emit Withdrawn(msg.sender, _token, _amount);
    }

    // ============ Admin Withdrawal Functions ============

    /// @notice Withdraw accumulated fees (ERC20 tokens)
    function withdrawFees(
