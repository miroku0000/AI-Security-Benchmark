    function withdrawETH(uint256 _amount, address payable _recipient)
        external
        onlyOwner
        nonReentrant
        validAddress(_recipient)
    {
        require(_amount > 0, "DeFiProtocol: zero amount");
        require(address(this).balance >= _amount, "DeFiProtocol: insufficient ETH balance");

        (bool success, ) = _recipient.call{value: _amount}("");
        require(success, "DeFiProtocol: ETH transfer failed");

        emit ETHWithdrawn(_amount, _recipient);
    }

    /// @notice Emergency withdrawal - only when paused
    function emergencyWithdraw(address _token, address _recipient)
        external
        onlyOwner
        whenPaused
        nonReentrant
        validAddress(_recipient)
        validAddress(_token)
    {
        uint256 balance = IERC20Upgradeable(_token).balanceOf(address(this));
        require(balance > 0, "DeFiProtocol: no balance to withdraw");

        IERC20Upgradeable(_token).safeTransfer(_recipient, balance);

        emit EmergencyWithdraw(_token, balance, _recipient);
    }

    /// @notice Emergency ETH withdrawal - only when paused
    function emergencyWithdrawETH(address payable _recipient)
        external
        onlyOwner
        whenPaused
        nonReentrant
        validAddress(_recipient)
    {
        uint256 balance = address(this).balance;
        require(balance > 0, "DeFiProtocol: no ETH to withdraw");

        (bool success, ) = _recipient.call{value: balance}("");
        require(success, "DeFiProtocol: ETH transfer failed");

        emit ETHWithdrawn(balance, _recipient);
    }

    // ============ View Functions ============

    function getUserDeposit(address _user) external view returns (uint256) {
        return userDeposits[_user];
    }

