{
    using SafeERC20Upgradeable for IERC20Upgradeable;

    // ============ State Variables ============

    address public owner;
    address public pendingOwner;
    address public guardian; // Can pause but not change critical params

    uint256 public feeRate; // in basis points (e.g., 100 = 1%)
    uint256 public maxDepositAmount;
    uint256 public minDepositAmount;
    uint256 public withdrawalDelay;

    uint256 public constant MAX_FEE_RATE = 1000; // 10% max fee
    uint256 public constant BASIS_POINTS = 10000;

    mapping(address => bool) public whitelistedTokens;
    mapping(address => uint256) public userDeposits;
    mapping(address => uint256) public lastDepositTimestamp;

    // Timelock for critical parameter changes
    uint256 public constant TIMELOCK_DURATION = 48 hours;

    struct PendingChange {
        bytes32 paramHash;
        uint256 value;
        uint256 executionTime;
        bool exists;
    }

    mapping(bytes32 => PendingChange) public pendingChanges;

    // ============ Events ============

    event OwnershipTransferInitiated(address indexed currentOwner, address indexed pendingOwner);
    event OwnershipTransferred(address indexed previousOwner, address indexed newOwner);
    event GuardianUpdated(address indexed previousGuardian, address indexed newGuardian);
    event ParameterChangeProposed(bytes32 indexed paramId, uint256 newValue, uint256 executionTime);
    event ParameterChangeExecuted(bytes32 indexed paramId, uint256 newValue);
    event ParameterChangeCancelled(bytes32 indexed paramId);
    event TokenWhitelisted(address indexed token, bool status);
    event Deposited(address indexed user, address indexed token, uint256 amount);
