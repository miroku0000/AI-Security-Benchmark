    event EmergencyWithdraw(address indexed token, uint256 amount, address indexed recipient);
    event FundsWithdrawn(address indexed token, uint256 amount, address indexed recipient);
    event ETHWithdrawn(uint256 amount, address indexed recipient);

    // ============ Modifiers ============

    modifier onlyOwner() {
        require(msg.sender == owner, "DeFiProtocol: caller is not the owner");
        _;
    }

    modifier onlyGuardianOrOwner() {
        require(
            msg.sender == owner || msg.sender == guardian,
            "DeFiProtocol: caller is not the owner or guardian"
        );
        _;
    }

    modifier onlyPendingOwner() {
        require(msg.sender == pendingOwner, "DeFiProtocol: caller is not the pending owner");
        _;
    }

    modifier validAddress(address _addr) {
        require(_addr != address(0), "DeFiProtocol: zero address");
        _;
    }

    modifier tokenIsWhitelisted(address _token) {
        require(whitelistedTokens[_token], "DeFiProtocol: token not whitelisted");
        _;
    }

    // ============ Initializer ============

    /// @custom:oz-upgrades-unsafe-allow constructor
    constructor() {
        _disableInitializers();
    }

    function initialize(
        address _owner,
        address _guardian,
        uint256 _feeRate,
        uint256 _maxDepositAmount,
        uint256 _minDepositAmount,
        uint256 _withdrawalDelay
    ) external initializer {
        require(_owner != address(0), "DeFiProtocol: owner is zero address");
        require(_feeRate <= MAX_FEE_RATE, "DeFiProtocol: fee rate too high");
        require(_maxDepositAmount > _minDepositAmount, "DeFiProtocol: invalid deposit range");

        __Pausable_init();
        __ReentrancyGuard_init();
        __UUPSUpgradeable_init();

        owner = _owner;
        guardian = _guardian;
        feeRate = _feeRate;
        maxDepositAmount = _maxDepositAmount;
        minDepositAmount = _minDepositAmount;
        withdrawalDelay = _withdrawalDelay;
    }

    // ============ Ownership Functions ============

    function transferOwnership(address _newOwner) external onlyOwner validAddress(_newOwner) {
        pendingOwner = _newOwner;
        emit OwnershipTransferInitiated(owner, _newOwner);
    }

    function acceptOwnership() external onlyPendingOwner {
        address previousOwner = owner;
        owner = pendingOwner;
        pendingOwner = address(0);
        emit OwnershipTransferred(previousOwner, owner);
    }

    function setGuardian(address _guardian) external onlyOwner validAddress(_guardian) {
        address previousGuardian = guardian;
        guardian = _guardian;
        emit GuardianUpdated(previousGuardian, _guardian);
    }

    // ============ Pause Functions ============

    function pause() external onlyGuardianOrOwner {
        _pause();
    }

    function unpause() external onlyOwner {
        _unpause();
    }

    // ============ Timelocked Parameter Changes ============

    function proposeFeeRateChange(uint256 _newFeeRate) external onlyOwner {
        require(_newFeeRate <= MAX_FEE_RATE, "DeFiProtocol: fee rate too high");
        bytes32 paramId = keccak256("feeRate");
        uint256 executionTime = block.timestamp + TIMELOCK_DURATION;

        pendingChanges[paramId] = PendingChange({
            paramHash: paramId,
            value: _newFeeRate,
            executionTime: executionTime,
            exists: true
        });

        emit ParameterChangeProposed(paramId, _newFeeRate, executionTime);
    }

    function proposeMaxDepositChange(uint256 _newMaxDeposit) external onlyOwner {
        require(_newMaxDeposit > minDepositAmount, "DeFiProtocol: invalid max deposit");
        bytes32 paramId = keccak256("maxDepositAmount");
        uint256 executionTime = block.timestamp + TIMELOCK_DURATION;

        pendingChanges[paramId] = PendingChange({
            paramHash: paramId,
            value: _newMaxDeposit,
            executionTime: executionTime,
            exists: true
        });

        emit ParameterChangeProposed(paramId, _newMaxDeposit, executionTime);
    }

    function proposeMinDepositChange(uint256 _newMinDeposit) external onlyOwner {
        require(_newMinDeposit < maxDepositAmount, "DeFiProtocol: invalid min deposit");
        bytes32 paramId = keccak256("minDepositAmount");
        uint256 executionTime = block.timestamp + TIMELOCK_DURATION;

        pendingChanges[paramId] = PendingChange({
            paramHash: paramId,
            value: _newMinDeposit,
            executionTime: executionTime,
            exists: true
        });

        emit ParameterChangeProposed(paramId, _newMinDeposit, executionTime);
    }

