    // ============ LOTTERY FUNCTIONS ============

    function createLottery(
        uint256 _ticketPrice,
        uint256 _maxTickets,
        uint256 _duration,
        uint256[] calldata _rewardPercentages
    ) external onlyOwner {
        require(_ticketPrice > 0, "Ticket price must be > 0");
        require(_maxTickets > 0, "Max tickets must be > 0");
        require(_duration > 0, "Duration must be > 0");
        require(_rewardPercentages.length > 0, "Must have at least 1 winner tier");
        
        uint256 totalPercent = 0;
        for (uint256 i = 0; i < _rewardPercentages.length; i++) {
            totalPercent += _rewardPercentages[i];
        }
        require(totalPercent <= 100, "Total reward percentages exceed 100");

        currentLotteryId++;
        
        Lottery storage lottery = lotteries[currentLotteryId];
        lottery.lotteryId = currentLotteryId;
        lottery.ticketPrice = _ticketPrice;
        lottery.maxTickets = _maxTickets;
        lottery.startTime = block.timestamp;
        lottery.endTime = block.timestamp + _duration;
        lottery.rewardPercentages = _rewardPercentages;
        lottery.isActive = true;
        lottery.isFinalized = false;

        emit LotteryCreated(currentLotteryId, _ticketPrice, _maxTickets, lottery.endTime);
    }

    function buyTickets(uint256 _lotteryId, uint256 _numTickets) external payable nonReentrant {
        Lottery storage lottery = lotteries[_lotteryId];
        
        require(lottery.isActive, "Lottery is not active");
        require(!lottery.isFinalized, "Lottery already finalized");
        require(block.timestamp < lottery.endTime, "Lottery has ended");
        require(_numTickets > 0, "Must buy at least 1 ticket");
        require(lottery.ticketsSold + _numTickets <= lottery.maxTickets, "Exceeds max tickets");
        require(msg.value == lottery.ticketPrice * _numTickets, "Incorrect ETH amount");

        for (uint256 i = 0; i < _numTickets; i++) {
            lottery.participants.push(msg.sender);
        }

        lottery.ticketsSold += _numTickets;
        lottery.prizePool += msg.value;
        playerTickets[_lotteryId][msg.sender] += _numTickets;

        if (playerTickets[_lotteryId][msg.sender] == _numTickets) {
            playerStats[msg.sender].lotteriesParticipated++;
        }
        playerStats[msg.sender].totalTicketsPurchased += _numTickets;

        emit TicketPurchased(_lotteryId, msg.sender, _numTickets);
    }

    function finalizeLottery(uint256 _lotteryId) external onlyOwner nonReentrant {
        Lottery storage lottery = lotteries[_lotteryId];
        
        require(lottery.isActive, "Lottery is not active");
        require(!lottery.isFinalized, "Already finalized");
        require(
            block.timestamp >= lottery.endTime || lottery.ticketsSold >= lottery.maxTickets,
            "Lottery not yet ended"
        );
        require(lottery.ticketsSold > 0, "No tickets sold");

        lottery.isActive = false;
        lottery.isFinalized = true;

        // Generate random seed
        lottery.randomSeed = _generateRandomNumber(lottery.ticketsSold);

        // Calculate platform fee
        uint256 platformFee = (lottery.prizePool * platformFeePercent) / 100;
        totalPlatformFees += platformFee;
        uint256 distributablePool = lottery.prizePool - platformFee;

        // Select winners
        uint256 numWinners = lottery.rewardPercentages.length;
        if (numWinners > lottery.ticketsSold) {
            numWinners = lottery.ticketsSold;
        }

        address[] memory winners = new address[](numWinners);
        uint256[] memory rewards = new uint256[](numWinners);
        
        // Track used indices to avoid duplicate winners
        bool[] memory usedIndices = new bool[](lottery.ticketsSold);

        for (uint256 i = 0; i < numWinners; i++) {
            uint256 randomIndex = _getUniqueRandomIndex(
                lottery.randomSeed, 
                i, 
                lottery.ticketsSold, 
                usedIndices
            );
            
            usedIndices[randomIndex] = true;
            winners[i] = lottery.participants[randomIndex];
            rewards[i] = (distributablePool * lottery.rewardPercentages[i]) / 100;

            // Update player stats
            playerStats[winners[i]].totalWinnings += rewards[i];
            playerStats[winners[i]].lotteriesWon++;
            
            // Store claimable amount
            instantRewardBalance[winners[i]] += rewards[i];
        }

        lottery.winners = winners;

        emit LotteryFinalized(_lotteryId, winners, rewards);
    }

    function claimWinnings() external nonReentrant {
        uint256 amount = instantRewardBalance[msg.sender];
        require(amount > 0, "No winnings to claim");

        instantRewardBalance[msg.sender] = 0;

        (bool success, ) = payable(msg.sender).call{value: amount}("");
        require(success, "Transfer failed");

        emit WinningsClaimed(0, msg.sender, amount);
    }

    // ============ INSTANT SCRATCH REWARD ============

    function playInstantScratch() external payable nonReentrant {
        require(msg.value > 0, "Must send ETH to play");
        require(rewardTiers.length > 0, "No reward tiers configured");

        uint256 random = _generateRandomNumber(10000);
        uint256 selectedMultiplier = 0;
        uint256 cumulativeProbability = 0;
        uint256 roll = random % 10000;

        for (uint256 i = 0; i < rewardTiers.length; i++) {
            cumulativeProbability += rewardTiers[i].probability;
            if (roll < cumulativeProbability) {
                selectedMultiplier = rewardTiers[i].multiplier;
                break;
            }
        }

        uint256 reward = (msg.value * selectedMultiplier) / 10000;

        if (reward > 0) {
            require(address(this).balance >= reward, "Insufficient contract balance");
            instantRewardBalance[msg.sender] += reward;
            playerStats[msg.sender].totalWinnings += reward;
        }

        // Take platform fee from losses
        if (reward < msg.value) {
            uint256 loss = msg.value - reward;
            uint256 fee = (loss * platformFeePercent) / 100;
            totalPlatformFees += fee;
        }

        emit InstantRewardPlayed(msg.sender, msg.value, reward, selectedMultiplier);
    }

    // ============ RANDOM NUMBER GENERATION ============

    function _generateRandomNumber(uint256 _modulus) internal returns (uint256) {
        nonce++;
        uint256 random = uint256(
            keccak256(
                abi.encodePacked(
                    block.timestamp,
                    block.prevrandao,
                    blockhash(block.number - 1),
                    msg.sender,
                    nonce,
                    address(this).balance,
                    gasleft()
                )
            )
        );
        return random % _modulus;
    }

    function _getUniqueRandomIndex(
        uint256 _seed,
        uint256 _iteration,
        uint256 _maxIndex,
        bool[] memory _usedIndices
    ) internal view returns (uint256) {
        uint256 index = uint256(
            keccak256(
                abi.encodePacked(
                    _seed,
                    _iteration,
                    block.timestamp,
                    blockhash(block.number - 1)
                )
            )
        ) % _maxIndex;

        // Linear probing for collision resolution
        uint256 attempts = 0;
        while (_usedIndices[index] && attempts < _maxIndex) {
            index = (index + 1) % _maxIndex;
            attempts++;
        }

        require(attempts < _maxIndex, "Could not find unique index");
        return index;
    }

