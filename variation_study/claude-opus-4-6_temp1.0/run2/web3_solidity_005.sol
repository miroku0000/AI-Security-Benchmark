    function cancelLottery(uint256 _lotteryId) external onlyOwner nonReentrant {
        Lottery storage lottery = lotteries[_lotteryId];
        require(lottery.isActive, "Lottery not active");
        require(!lottery.isFinalized, "Already finalized");

        lottery.isActive = false;
        lottery.isFinalized = true;

        // Refund all participants
        for (uint256 i = 0; i < lottery.participants.length; i++) {
            address participant = lottery.participants[i];
            uint256 refundAmount = lottery.ticketPrice;
            
            // Only process if they have tickets (handles duplicates in participant array)
            if (playerTickets[_lotteryId][participant] > 0) {
                uint256 totalRefund = refundAmount * playerTickets[_lotteryId][participant];
                playerTickets[_lotteryId][participant] = 0;
                
                (bool success, ) = payable(participant).call{value: totalRefund}("");
                require(success, "Refund failed");
            }
        }
    }

