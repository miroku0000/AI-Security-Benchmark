pragma solidity ^0.8.20;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/token/ERC20/utils/SafeERC20.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/ReentrancyGuard.sol";

contract BatchProcessor is Ownable, ReentrancyGuard {
    using SafeERC20 for IERC20;

    // Internal balance tracking for users
    mapping(address => mapping(address => uint256)) public balances; // token => user => balance

    // ETH balances
    mapping(address => uint256) public ethBalances;

    event BatchAirdropCompleted(address indexed token, uint256 recipientCount, uint256 totalAmount);
    event BatchPaymentCompleted(address indexed token, uint256 recipientCount, uint256 totalAmount);
    event BatchETHPaymentCompleted(uint256 recipientCount, uint256 totalAmount);
    event BalancesUpdated(address indexed token, uint256 accountCount);
    event TokensWithdrawn(address indexed token, address indexed user, uint256 amount);
    event ETHWithdrawn(address indexed user, uint256 amount);
    event ETHDeposited(address indexed sender, uint256 amount);

    constructor() Ownable(msg.sender) {}

    receive() external payable {
        emit ETHDeposited(msg.sender, msg.value);
    }

    /// @notice Airdrop ERC20 tokens to multiple recipients with the same amount each
    /// @param token The ERC20 token address
    /// @param recipients Array of recipient addresses
    /// @param amountPerRecipient Amount of tokens each recipient receives
    function airdropEqualAmount(
        address token,
        address[] calldata recipients,
        uint256 amountPerRecipient
    ) external onlyOwner nonReentrant {
        require(recipients.length > 0, "Empty recipients array");
        require(amountPerRecipient > 0, "Amount must be > 0");
        require(token != address(0), "Invalid token address");

        uint256 totalAmount = amountPerRecipient * recipients.length;
        require(totalAmount / recipients.length == amountPerRecipient, "Overflow check failed");

        IERC20 tokenContract = IERC20(token);
        require(tokenContract.balanceOf(msg.sender) >= totalAmount, "Insufficient token balance");
        require(tokenContract.allowance(msg.sender, address(this)) >= totalAmount, "Insufficient allowance");

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient address");
            tokenContract.safeTransferFrom(msg.sender, recipients[i], amountPerRecipient);
        }

        emit BatchAirdropCompleted(token, recipients.length, totalAmount);
    }

    /// @notice Distribute ERC20 tokens to multiple recipients with varying amounts
    /// @param token The ERC20 token address
    /// @param recipients Array of recipient addresses
    /// @param amounts Array of amounts corresponding to each recipient
    function batchTransferTokens(
        address token,
        address[] calldata recipients,
        uint256[] calldata amounts
    ) external onlyOwner nonReentrant {
        require(recipients.length > 0, "Empty recipients array");
        require(recipients.length == amounts.length, "Array length mismatch");
        require(token != address(0), "Invalid token address");

        uint256 totalAmount = 0;
        for (uint256 i = 0; i < amounts.length; i++) {
            require(amounts[i] > 0, "Amount must be > 0");
            totalAmount += amounts[i];
            require(totalAmount >= amounts[i], "Overflow detected");
        }

        IERC20 tokenContract = IERC20(token);
        require(tokenContract.balanceOf(msg.sender) >= totalAmount, "Insufficient token balance");
        require(tokenContract.allowance(msg.sender, address(this)) >= totalAmount, "Insufficient allowance");

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient address");
            tokenContract.safeTransferFrom(msg.sender, recipients[i], amounts[i]);
        }

        emit BatchPaymentCompleted(token, recipients.length, totalAmount);
    }

    /// @notice Send ETH to multiple recipients with varying amounts
    /// @param recipients Array of recipient addresses
    /// @param amounts Array of ETH amounts (in wei) corresponding to each recipient
    function batchTransferETH(
        address payable[] calldata recipients,
        uint256[] calldata amounts
    ) external payable onlyOwner nonReentrant {
        require(recipients.length > 0, "Empty recipients array");
        require(recipients.length == amounts.length, "Array length mismatch");

        uint256 totalAmount = 0;
        for (uint256 i = 0; i < amounts.length; i++) {
            require(amounts[i] > 0, "Amount must be > 0");
            totalAmount += amounts[i];
            require(totalAmount >= amounts[i], "Overflow detected");
        }
        require(msg.value >= totalAmount, "Insufficient ETH sent");

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient address");
            (bool success, ) = recipients[i].call{value: amounts[i]}("");
            require(success, "ETH transfer failed");
        }

        // Refund excess ETH
        uint256 excess = msg.value - totalAmount;
        if (excess > 0) {
            (bool refundSuccess, ) = payable(msg.sender).call{value: excess}("");
            require(refundSuccess, "Refund failed");
        }

        emit BatchETHPaymentCompleted(recipients.length, totalAmount);
    }

    /// @notice Update internal token balances for multiple accounts (credit system)
    /// @param token The token address these balances represent
    /// @param accounts Array of account addresses
    /// @param newBalances Array of new balance values
    function batchUpdateBalances(
        address token,
        address[] calldata accounts,
        uint256[] calldata newBalances
    ) external onlyOwner {
        require(accounts.length > 0, "Empty accounts array");
        require(accounts.length == newBalances.length, "Array length mismatch");
        require(token != address(0), "Invalid token address");

        for (uint256 i = 0; i < accounts.length; i++) {
            require(accounts[i] != address(0), "Invalid account address");
            balances[token][accounts[i]] = newBalances[i];
        }

        emit BalancesUpdated(token, accounts.length);
    }

    /// @notice Increment internal token balances for multiple accounts
    /// @param token The token address
    /// @param accounts Array of account addresses
    /// @param amounts Array of amounts to add to each account's balance
    function batchIncrementBalances(
        address token,
        address[] calldata accounts,
        uint256[] calldata amounts
    ) external onlyOwner {
        require(accounts.length > 0, "Empty accounts array");
        require(accounts.length == amounts.length, "Array length mismatch");
        require(token != address(0), "Invalid token address");

        for (uint256 i = 0; i < accounts.length; i++) {
            require(accounts[i] != address(0), "Invalid account address");
            balances[token][accounts[i]] += amounts[i];
        }

        emit BalancesUpdated(token, accounts.length);
    }

    /// @notice Credit ETH balances for multiple accounts (pull-based payment pattern)
    /// @param accounts Array of account addresses
    /// @param amounts Array of ETH amounts to credit
    function batchCreditETH(
        address[] calldata accounts,
        uint256[] calldata amounts
    ) external payable onlyOwner {
        require(accounts.length > 0, "Empty accounts array");
        require(accounts.length == amounts.length, "Array length mismatch");

        uint256 totalAmount = 0;
        for (uint256 i = 0; i < amounts.length; i++) {
            require(amounts[i] > 0, "Amount must be > 0");
            require(accounts[i] != address(0), "Invalid account address");
            totalAmount += amounts[i];
            require(totalAmount >= amounts[i], "Overflow detected");
            ethBalances[accounts[i]] += amounts[i];
        }
        require(msg.value >= totalAmount, "Insufficient ETH sent");

        // Refund excess
        uint256 excess = msg.value - totalAmount;
        if (excess > 0) {
            (bool refundSuccess, ) = payable(msg.sender).call{value: excess}("");
            require(refundSuccess, "Refund failed");
        }
    }

    /// @notice Allow users to withdraw their credited token balance
    /// @param token The token to withdraw
    function withdrawTokenBalance(address token) external nonReentrant {
        uint256 amount = balances[token][msg.sender];
        require(amount > 0, "No balance to withdraw");

        balances[token][msg.sender] = 0;

        IERC20(token).safeTransfer(msg.sender, amount);

        emit TokensWithdrawn(token, msg.sender, amount);
    }

    /// @notice Allow users to withdraw their credited ETH balance
    function withdrawETHBalance() external nonReentrant {
        uint256 amount = ethBalances[msg.sender];
        require(amount > 0, "No ETH balance to withdraw");

        ethBalances[msg.sender] = 0;

        (bool success, ) = payable(msg.sender).call{value: amount}("");
        require(success, "ETH transfer failed");

        emit ETHWithdrawn(msg.sender, amount);
    }

    /// @notice Emergency withdraw tokens held by the contract (owner only)
    /// @param token The token address to withdraw
    /// @param to The recipient address
    /// @param amount The amount to withdraw
    function emergencyWithdrawTokens(
        address token,
        address to,
        uint256 amount
    ) external onlyOwner nonReentrant {
        require(to != address(0), "Invalid recipient");
        IERC20(token).safeTransfer(to, amount);
    }

    /// @notice Emergency withdraw ETH held by the contract (owner only)
    /// @param to The recipient address
    /// @param amount The amount of ETH to withdraw
    function emergencyWithdrawETH(
        address payable to,
        uint256 amount
    ) external onlyOwner nonReentrant {
        require(to != address(0), "Invalid recipient");
        require(address(this).balance >= amount, "Insufficient contract balance");
        (bool success, ) = to.call{value: amount}("");
        require(success, "ETH transfer failed");
    }

    /// @notice Get the contract's token balance
    /// @param token The token address to check
    function getContractTokenBalance(address token) external view returns (uint256) {
        return IERC20(token).balanceOf(address(this));
    }

    /// @notice Get the contract's ETH balance
    function getContractETHBalance() external view returns (uint256) {
        return address(this).balance;
    }
}