  kms_key_arn = aws_kms_key.lambda_encryption.arn

  vpc_config {
    subnet_ids         = [aws_subnet.private_a.id, aws_subnet.private_b.id]
    security_group_ids = [aws_security_group.lambda_sg.id]
  }

  environment {
    variables = {
      TRANSACTIONS_TABLE = aws_dynamodb_table.payment_transactions.name
      ENVIRONMENT        = var.environment
      POWERTOOLS_SERVICE_NAME = "payment-validator"
      LOG_LEVEL               = "INFO"
    }
  }

  dead_letter_config {
    target_arn = aws_sqs_queue.validation_dlq.arn
  }

  tracing_config {
    mode = "Active"
  }

  depends_on = [
    aws_cloudwatch_log_group.payment_validator_logs,
    aws_iam_role_policy.payment_validator_policy
  ]

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
    Function    = "validator"
  }
}

resource "aws_lambda_function" "reconciliation" {
  function_name    = "payment-reconciliation-${var.environment}"
  filename         = data.archive_file.reconciliation.output_path
  source_code_hash = data.archive_file.reconciliation.output_base64sha256
  handler          = "index.handler"
  runtime          = "python3.12"
  role             = aws_iam_role.reconciliation_role.arn
  timeout          = 60
  memory_size      = var.lambda_memory_size

  reserved_concurrent_executions = 10

  kms_key_arn = aws_kms_key.lambda_encryption.arn

  vpc_config {
    subnet_ids         = [aws_subnet.private_a.id, aws_subnet.private_b.id]
    security_group_ids = [aws_security_group.lambda_sg.id]
  }

  environment {
    variables = {
      TRANSACTIONS_TABLE = aws_dynamodb_table.payment_transactions.name
      ALERT_TOPIC_ARN    = aws_sns_topic.payment_alerts.arn
      ENVIRONMENT        = var.environment
      POWERTOOLS_SERVICE_NAME = "payment-reconciliation"
      LOG_LEVEL               = "INFO"
    }
  }

  dead_letter_config {
    target_arn = aws_sqs_queue.reconciliation_dlq.arn
  }

  tracing_config {
    mode = "Active"
  }

  depends_on = [
    aws_cloudwatch_log_group.reconciliation_logs,
    aws_iam_role_policy.reconciliation_policy
  ]

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
    Function    = "reconciliation"
  }
}

# -------------------------------------------------------------------
# DynamoDB Stream trigger for Reconciliation Lambda
# -------------------------------------------------------------------

resource "aws_lambda_event_source_mapping" "reconciliation_trigger" {
  event_source_arn                   = aws_dynamodb_table.payment_transactions.stream_arn
  function_name                      = aws_lambda_function.reconciliation.arn
  starting_position                  = "LATEST"
  batch_size                         = 10
  maximum_batching_window_in_seconds = 5
  maximum_retry_attempts             = 3
  bisect_batch_on_function_error     = true

  destination_config {
    on_failure {
      destination_arn = aws_sqs_queue.reconciliation_dlq.arn
    }
  }
}

# -------------------------------------------------------------------
# Dead Letter Queues (encrypted)
# -------------------------------------------------------------------

resource "aws_sqs_queue" "payment_dlq" {
  name                       = "payment-processor-dlq-${var.environment}"
  message_retention_seconds  = 1209600 # 14 days
  kms_master_key_id          = aws_kms_key.lambda_encryption.id
  kms_data_key_reuse_period_seconds = 300

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
  }
}

resource "aws_sqs_queue" "validation_dlq" {
  name                       = "payment-validator-dlq-${var.environment}"
  message_retention_seconds  = 1209600
  kms_master_key_id          = aws_kms_key.lambda_encryption.id
  kms_data_key_reuse_period_seconds = 300

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
  }
}

resource "aws_sqs_queue" "reconciliation_dlq" {
  name                       = "payment-reconciliation-dlq-${var.environment}"
  message_retention_seconds  = 1209600
  kms_master_key_id          = aws_kms_key.lambda_encryption.id
  kms_data_key_reuse_period_seconds = 300

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
  }
}

# DLQ permissions for Lambda roles
resource "aws_iam_role_policy" "payment_processor_dlq" {
  name = "dlq-access"
  role = aws_iam_role.payment_processor_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = ["sqs:SendMessage"]
        Resource = [aws_sqs_queue.payment_dlq.arn]
      }
    ]
  })
}

resource "aws_iam_role_policy" "payment_validator_dlq" {
  name = "dlq-access"
  role = aws_iam_role.payment_validator_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = ["sqs:SendMessage"]
        Resource = [aws_sqs_queue.validation_dlq.arn]
      }
    ]
  })
}

resource "aws_iam_role_policy" "reconciliation_dlq" {
  name = "dlq-access"
  role = aws_iam_role.reconciliation_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = ["sqs:SendMessage"]
        Resource = [aws_sqs_queue.reconciliation_dlq.arn]
      }
    ]
  })
}

# -------------------------------------------------------------------
# SNS Topic for payment alerts
# -------------------------------------------------------------------

resource "aws_sns_topic" "payment_alerts" {
  name              = "payment-alerts-${var.environment}"
  kms_master_key_id = aws_kms_key.lambda_encryption.id

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
  }
}

resource "aws_sns_topic_subscription" "payment_alerts_email" {
  topic_arn = aws_sns_topic.payment_alerts.arn
  protocol  = "email"
  endpoint  = var.alarm_email
}

# -------------------------------------------------------------------
# CloudWatch Alarms - Essential alarms for financial processing
# NOTE: Even though dashboards are deferred, critical alarms for a
# payment system must be in place from day one. Financial regulators
# require error detection and alerting for payment processing systems.
# -------------------------------------------------------------------

resource "aws_cloudwatch_metric_alarm" "payment_processor_errors" {
  alarm_name          = "payment-processor-errors-${var.environment}"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 1
  metric_name         = "Errors"
  namespace           = "AWS/Lambda"
  period              = 60
  statistic           = "Sum"
  threshold           = 0
  alarm_description   = "Payment processor Lambda errors detected - potential payment failures"
  treat_missing_data  = "notBreaching"

  dimensions = {
    FunctionName = aws_lambda_function.payment_processor.function_name
  }

  alarm_actions = [aws_sns_topic.payment_alerts.arn]
  ok_actions    = [aws_sns_topic.payment_alerts.arn]

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
  }
}

resource "aws_cloudwatch_metric_alarm" "payment_validator_errors" {
  alarm_name          = "payment-validator-errors-${var.environment}"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 1
  metric_name         = "Errors"
  namespace           = "AWS/Lambda"
  period              = 60
  statistic           = "Sum"
  threshold           = 0
  alarm_description   = "Payment validator Lambda errors detected - validation failures"
  treat_missing_data  = "notBreaching"

  dimensions = {
    FunctionName = aws_lambda_function.payment_validator.function_name
  }

  alarm_actions = [aws_sns_topic.payment_alerts.arn]
  ok_actions    = [aws_sns_topic.payment_alerts.arn]

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
  }
}

resource "aws_cloudwatch_metric_alarm" "reconciliation_errors" {
  alarm_name          = "payment-reconciliation-errors-${var.environment}"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 1
  metric_name         = "Errors"
  namespace           = "AWS/Lambda"
  period              = 60
  statistic           = "Sum"
  threshold           = 0
  alarm_description   = "Reconciliation Lambda errors - potential data consistency issues"
  treat_missing_data  = "notBreaching"

  dimensions = {
    FunctionName = aws_lambda_function.reconciliation.function_name
  }

  alarm_actions = [aws_sns_topic.payment_alerts.arn]
  ok_actions    = [aws_sns_topic.payment_alerts.arn]

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
  }
}

resource "aws_cloudwatch_metric_alarm" "payment_processor_throttles" {
  alarm_name          = "payment-processor-throttles-${var.environment}"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 1
  metric_name         = "Throttles"
  namespace           = "AWS/Lambda"
  period              = 60
  statistic           = "Sum"
  threshold           = 0
  alarm_description   = "Payment processor is being throttled - payments may be delayed"
  treat_missing_data  = "notBreaching"

  dimensions = {
    FunctionName = aws_lambda_function.payment_processor.function_name
  }

  alarm_actions = [aws_sns_topic.payment_alerts.arn]

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
  }
}

resource "aws_cloudwatch_metric_alarm" "payment_processor_duration" {
  alarm_name          = "payment-processor-duration-${var.environment}"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 3
  metric_name         = "Duration"
  namespace           = "AWS/Lambda"
  period              = 60
  statistic           = "Average"
  threshold           = var.lambda_timeout * 1000 * 0.8 # 80% of timeout
  alarm_description   = "Payment processor approaching timeout - risk of payment failures"
  treat_missing_data  = "notBreaching"

  dimensions = {
    FunctionName = aws_lambda_function.payment_processor.function_name
  }

  alarm_actions = [aws_sns_topic.payment_alerts.arn]

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
  }
}

resource "aws_cloudwatch_metric_alarm" "dlq_payment_messages" {
  alarm_name          = "payment-dlq-messages-${var.environment}"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 1
  metric_name         = "ApproximateNumberOfMessagesVisible"
  namespace           = "AWS/SQS"
  period              = 60
  statistic           = "Sum"
  threshold           = 0
  alarm_description   = "Failed payment messages in DLQ - requires immediate investigation"
  treat_missing_data  = "notBreaching"

  dimensions = {
    QueueName = aws_sqs_queue.payment_dlq.name
  }

  alarm_actions = [aws_sns_topic.payment_alerts.arn]

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
  }
}

resource "aws_cloudwatch_metric_alarm" "dlq_reconciliation_messages" {
  alarm_name          = "reconciliation-dlq-messages-${var.environment}"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 1
  metric_name         = "ApproximateNumberOfMessagesVisible"
  namespace           = "AWS/SQS"
  period              = 60
  statistic           = "Sum"
  threshold           = 0
  alarm_description   = "Failed reconciliation messages in DLQ - data consistency risk"
  treat_missing_data  = "notBreaching"

  dimensions = {
    QueueName = aws_sqs_queue.reconciliation_dlq.name
  }

  alarm_actions = [aws_sns_topic.payment_alerts.arn]

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
  }
}

