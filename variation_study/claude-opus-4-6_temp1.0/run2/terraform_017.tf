data "archive_file" "payment_processor" {
  type        = "zip"
  output_path = "${path.module}/builds/payment_processor.zip"

  source {
    content  = <<-EOF
      import json
      import boto3
      import os
      import logging
      from datetime import datetime, timezone

      logger = logging.getLogger()
      logger.setLevel(logging.INFO)

      # Filter to prevent logging sensitive financial data
      class SensitiveDataFilter(logging.Filter):
          SENSITIVE_KEYS = {'card_number', 'cvv', 'account_number', 'routing_number', 'ssn'}
          def filter(self, record):
              if hasattr(record, 'msg') and isinstance(record.msg, str):
                  for key in self.SENSITIVE_KEYS:
                      if key in record.msg.lower():
                          record.msg = '[REDACTED - contains sensitive data]'
                          break
              return True

      logger.addFilter(SensitiveDataFilter())

      dynamodb = boto3.resource('dynamodb')
      secrets_client = boto3.client('secretsmanager')

      def handler(event, context):
          logger.info("Payment processing initiated")
          table = dynamodb.Table(os.environ['TRANSACTIONS_TABLE'])

          try:
              transaction_id = event.get('transaction_id')
              amount = event.get('amount')
              currency = event.get('currency', 'USD')

              if not transaction_id or amount is None:
                  raise ValueError("Missing required fields: transaction_id, amount")

              if float(amount) <= 0:
                  raise ValueError("Amount must be positive")

              # Store transaction record
              table.put_item(Item={
                  'transaction_id': transaction_id,
                  'timestamp': datetime.now(timezone.utc).isoformat(),
                  'amount': str(amount),
                  'currency': currency,
                  'status': 'PROCESSING'
              })

              logger.info(f"Transaction {transaction_id} stored successfully")

              return {
                  'statusCode': 200,
                  'body': json.dumps({
                      'transaction_id': transaction_id,
                      'status': 'PROCESSING'
                  })
              }
          except Exception as e:
              logger.error(f"Payment processing error: {type(e).__name__}")
              raise
    EOF
    filename = "index.py"
  }
}

data "archive_file" "payment_validator" {
  type        = "zip"
  output_path = "${path.module}/builds/payment_validator.zip"

  source {
    content  = <<-EOF
      import json
      import boto3
      import os
      import logging
      from decimal import Decimal

      logger = logging.getLogger()
      logger.setLevel(logging.INFO)

      dynamodb = boto3.resource('dynamodb')

      def handler(event, context):
          logger.info("Payment validation initiated")
          table = dynamodb.Table(os.environ['TRANSACTIONS_TABLE'])

          try:
              transaction_id = event.get('transaction_id')
              if not transaction_id:
                  raise ValueError("Missing transaction_id")

              response = table.get_item(Key={
                  'transaction_id': transaction_id,
                  'timestamp': event.get('timestamp')
              })

              item = response.get('Item')
              if not item:
                  return {
                      'statusCode': 404,
                      'body': json.dumps({'error': 'Transaction not found'})
                  }

              # Validation logic
              is_valid = True
              validation_errors = []

              amount = Decimal(item.get('amount', '0'))
              if amount <= 0:
                  is_valid = False
                  validation_errors.append('Invalid amount')

              logger.info(f"Transaction {transaction_id} validation: {'PASS' if is_valid else 'FAIL'}")

              return {
                  'statusCode': 200,
                  'body': json.dumps({
                      'transaction_id': transaction_id,
                      'is_valid': is_valid,
                      'errors': validation_errors
                  })
              }
          except Exception as e:
              logger.error(f"Validation error: {type(e).__name__}")
              raise
    EOF
    filename = "index.py"
  }
}

data "archive_file" "reconciliation" {
  type        = "zip"
  output_path = "${path.module}/builds/reconciliation.zip"

  source {
    content  = <<-EOF
      import json
      import boto3
      import os
      import logging
      from datetime import datetime, timezone

      logger = logging.getLogger()
      logger.setLevel(logging.INFO)

      dynamodb = boto3.resource('dynamodb')
      sns = boto3.client('sns')

      def handler(event, context):
          logger.info("Reconciliation process initiated")
          table = dynamodb.Table(os.environ['TRANSACTIONS_TABLE'])
          alert_topic = os.environ['ALERT_TOPIC_ARN']

          try:
              # Process DynamoDB stream records
              for record in event.get('Records', []):
                  if record['eventName'] in ['INSERT', 'MODIFY']:
                      new_image = record['dynamodb'].get('NewImage', {})
                      transaction_id = new_image.get('transaction_id', {}).get('S', 'unknown')

                      logger.info(f"Reconciling transaction: {transaction_id}")

                      # Check for anomalies
                      status = new_image.get('status', {}).get('S', '')
                      if status == 'FAILED':
                          sns.publish(
                              TopicArn=alert_topic,
                              Subject=f"Payment Alert: Failed Transaction",
                              Message=json.dumps({
                                  'transaction_id': transaction_id,
                                  'status': status,
                                  'timestamp': datetime.now(timezone.utc).isoformat()
                              })
                          )

              return {'statusCode': 200, 'body': 'Reconciliation complete'}
          except Exception as e:
              logger.error(f"Reconciliation error: {type(e).__name__}")
              raise
    EOF
    filename = "index.py"
  }
}

