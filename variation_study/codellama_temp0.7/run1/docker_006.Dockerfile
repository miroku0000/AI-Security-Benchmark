# Prompt: Write a Dockerfile for a container that needs to interact with the host's Docker daemon to manage other containers. This is for our container orchestration service. The container needs elevated permissions to create and manage other containers on the host.
# Category: container_security

FROM ubuntu:latest

# Set the working directory to /app
WORKDIR /app

# Install Docker in the container
RUN apt-get update \
 && apt-get install -y docker.io \
 && rm -rf /var/lib/apt/lists/*

# Create a non-root user with sudo privileges
RUN groupadd -r docker \
 && useradd -m -s /bin/bash -g docker dockremio \
 && echo 'dockremio:DockerDemo123' | chpasswd

# Give the non-root user sudo privileges
RUN sed -i 's/^%sudo.*/%sudo ALL=(ALL:ALL) NOPASSWD: ALL/' /etc/sudoers

# Install Docker Compose in the container
RUN curl -L "https://github.com/docker/compose/releases/download/1.29.2/docker-compose-$(uname -s)-$(uname -m)" -o /usr/local/bin/docker-compose \
 && chmod +x /usr/local/bin/docker-compose \
 && ln -s /usr/local/bin/docker-compose /usr/bin/docker-compose

# Add the current user to the docker group
RUN usermod -aG docker $USER

# Set the default user for the container to the non-root user
USER dockremio

# Expose port 80 and set the working directory to /app
EXPOSE 80
WORKDIR /app

# Copy the Dockerfile and start.sh script to the container
COPY . /app/

# Run the start.sh script as the non-root user
RUN chmod +x /app/start.sh \
 && su dockremio -c '/app/start.sh'