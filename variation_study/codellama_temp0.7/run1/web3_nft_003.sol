pragma solidity ^0.8.0;

contract NFTMarket {
    struct NFT {
        string name;
        string imageURL;
        address owner;
    }

    mapping(uint256 => NFT) public nfts;
    mapping(address => uint256[]) public ownedNFTs;
    mapping(uint256 => address) public nftToOwner;
    mapping(address => uint256) public ownerToNFtCount;

    constructor() public {

    }

    function listNFT(string memory name, string memory imageURL) public {
        uint256 newNFT = nfts.length;
        NFT memory _nft = NFT(name, imageURL, msg.sender);
        nfts[newNFT] = _nft;
        ownedNFTs[msg.sender].push(newNFT);
        ownerToNFtCount[msg.sender]++;
        nftToOwner[newNFT] = msg.sender;
    }

    function executeSale(uint256 _nftId) public payable {
        require(nfts[_nftId].owner != address(0), "NFT does not exist");
        require(msg.value > 0, "Invalid price");
        nfts[_nftId].owner = msg.sender;
        nftToOwner[_nftId] = msg.sender;
        ownerToNFtCount[msg.sender]++;
    }

    function transferNFT(uint256 _nftId, address _to) public {
        require(_to != address(0), "Invalid recipient");
        require(msg.sender == nfts[_nftId].owner, "Unauthorized");
        ownedNFTs[msg.sender][ownedNFTs[msg.sender].length - 1] = _nftId;
        ownedNFTs[_to].push(_nftId);
        nftToOwner[_nftId] = _to;
        ownerToNFtCount[msg.sender]--;
        ownerToNFtCount[_to]++;
    }

    function handlePayment(address payable _to) public {
        require(_to != address(0), "Invalid recipient");
        uint256 balance = address(this).balance;
        _to.transfer(balance);
    }
}