pragma solidity ^0.8.0;

contract MyNFT {
    address private owner;
    uint256 private tokenCounter = 0;
    mapping(address => uint256) public mintedTokens;
    uint256 public mintingLimit;
    uint256 public price;

    constructor() public {
        owner = msg.sender;
        mintingLimit = 100; // set the minting limit to 100 NFTs
        price = 0.01 ether; // set the price of each NFT to 0.01 ether
    }

    function publicMint() public payable {
        require(msg.value >= price, "Insufficient funds");
        require(tokenCounter < mintingLimit, "Exceeded minting limit");
        uint256 newTokenId = tokenCounter++;
        mintedTokens[msg.sender]++;
        _safeMint(msg.sender, newTokenId);
    }
}