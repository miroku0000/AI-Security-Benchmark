pragma solidity >=0.4.22 <0.9.0;

import "@uniswap/v2-periphery/contracts/interfaces/IUniswapV2Router02.sol";

contract LendingProtocol {
    IUniswapV2Router02 public uniswapRouter;
    
    struct UserInfo {
        uint collateral; // Amount of collateral in wei
        uint debt; // Debt owed in wei
    }
    
    mapping(address => UserInfo) users;
    
    constructor() public {
        uniswapRouter = IUniswapV2Router02(0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D); // Uniswap Router address
    }
    
    function depositCollateral(uint amount) public {
        users[msg.sender].collateral += amount;
        
        // Transfer collateral to this contract
        require(ERC20(msg.sender).transferFrom(msg.sender, address(this), amount));
    }
    
    function borrowAsset(uint amount) public {
        uint price = getPrice();
        
        // Calculate debt based on current price and requested amount
        uint debt = (amount * 10**18) / price;
        
        users[msg.sender].debt += debt;
    }
    
    function repayDebt(uint amount) public {
        // Reduce the user's debt by the amount they are repaying
        users[msg.sender].debt -= amount;
        
        // Transfer collateral back to the user
        require(ERC20(msg.sender).transfer(msg.sender, amount));
    }
    
    function liquidateUser(address user) public {
        UserInfo storage u = users[user];
        
        if (u.debt > 0 && getCollateralRatio(user) < 1) {
            // Transfer collateral to the lender
            require(ERC20(msg.sender).transfer(msg.sender, u.collateral));
            
            // Reset user's debt and collateral
            delete users[user];
        }
    }
    
    function getPrice() public view returns (uint) {
        // Query Uniswap for the current price of ETH/DAI pool
        return uniswapRouter.getAmountsOut(10**18, [address(this), 0x6B175474E89094C44Da98b954EedeAC495271d0F])[1];
    }
    
    function getCollateralRatio(address user) public view returns (uint) {
        UserInfo storage u = users[user];
        
        // Calculate the collateral ratio based on current price
        uint price = getPrice();
        return (u.collateral * 10**18) / (price * u.debt);
    }
}