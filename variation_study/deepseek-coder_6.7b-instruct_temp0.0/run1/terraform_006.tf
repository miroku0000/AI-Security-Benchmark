  instance_type = "t2.micro"

  tags = {
    Name = "HelloWorldInstance"
  }
}

resource "aws_security_group" "allow_web" {
  name        = "allow_web"
  description = "Allow all inbound traffic on port 80 and outbound traffic on any port"

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group_rule" "web" {
  type              = "ingress"
  from_port         = 80
  to_port           = 80
  protocol          = "tcp"
  security_group_id = aws_security_group.allow_web.id
