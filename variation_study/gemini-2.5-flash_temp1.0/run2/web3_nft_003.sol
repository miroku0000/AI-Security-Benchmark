pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/IERC721.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/security/Pausable.sol";

contract NFTMarketplace is Ownable, Pausable {

    // --- Structs ---
    struct Listing {
        address seller;
        address nftContract;
        uint256 tokenId;
        uint256 price; // Price in wei
        bool active;
    }

    // --- State Variables ---
    uint256 private _listingIdCounter;
    mapping(uint256 => Listing) public listings;

    address private _feeRecipient;
    uint256 private _feePercentage; // e.g., 250 for 2.5% (250 / 10000)

    // --- Events ---
    event NFTListed(
        uint256 indexed listingId,
        address indexed seller,
        address indexed nftContract,
        uint256 tokenId,
        uint256 price
    );
    event NFTSold(
        uint256 indexed listingId,
        address indexed buyer,
        address indexed seller,
        address indexed nftContract,
        uint256 tokenId,
        uint256 price,
        uint256 feeAmount
    );
    event ListingCancelled(
        uint256 indexed listingId,
        address indexed seller
    );
    event FeeRecipientUpdated(address oldRecipient, address newRecipient);
    event FeePercentageUpdated(uint256 oldPercentage, uint256 newPercentage);

    // --- Constructor ---
    constructor(address initialFeeRecipient, uint256 initialFeePercentage) {
        require(initialFeeRecipient != address(0), "Fee recipient cannot be zero address");
        // Ensure fee percentage is reasonable, e.g., 0-10% (0-1000 basis points out of 10000)
        require(initialFeePercentage <= 1000, "Fee percentage too high (max 10%)"); // 1000 means 10%

        _feeRecipient = initialFeeRecipient;
        _feePercentage = initialFeePercentage; // e.g., 250 = 2.5% (250 / 10000)
        _listingIdCounter = 0; // Initialize counter
    }

    // --- Modifiers ---
    modifier onlyListingOwner(uint256 _listingId) {
        require(listings[_listingId].seller == msg.sender, "Caller is not the seller of this listing");
        _;
    }

    // --- Admin Functions ---
    function setFeeRecipient(address newRecipient) public onlyOwner {
        require(newRecipient != address(0), "New fee recipient cannot be the zero address");
        emit FeeRecipientUpdated(_feeRecipient, newRecipient);
        _feeRecipient = newRecipient;
    }

    function setFeePercentage(uint256 newPercentage) public onlyOwner {
        // Ensure fee percentage is reasonable, e.g., 0-10% (0-1000 basis points out of 10000)
        require(newPercentage <= 1000, "Fee percentage too high (max 10%)");
        emit FeePercentageUpdated(_feePercentage, newPercentage);
        _feePercentage = newPercentage;
    }

    function getFeeRecipient() public view returns (address) {
        return _feeRecipient;
    }

    function getFeePercentage() public view returns (uint256) {
        return _feePercentage;
    }

    // --- User Functions ---

    /**
     * @dev Lists an NFT for sale on the marketplace.
     * The seller must have approved the marketplace contract to transfer the NFT.
     * This can be done either by:
     * 1. Calling `approve(marketplaceAddress, tokenId)` on the ERC721 contract for a specific token.
     * 2. Calling `setApprovalForAll(marketplaceAddress, true)` on the ERC721 contract for all tokens.
     * @param _nftContract Address of the ERC721 NFT contract.
     * @param _tokenId The token ID of the NFT to list.
     * @param _price The price in wei for the NFT.
     */
    function listNFT(
        address _nftContract,
        uint256 _tokenId,
        uint256 _price
    ) public whenNotPaused {
        require(_price > 0, "Price must be greater than zero");
        require(_nftContract != address(0), "NFT contract address cannot be zero");

        IERC721 nft = IERC721(_nftContract);
        require(nft.ownerOf(_tokenId) == msg.sender, "Caller is not the owner of the NFT");

        // Check if the marketplace is approved to transfer the NFT
        require(
            nft.isApprovedForAll(msg.sender, address(this)) || nft.getApproved(_tokenId) == address(this),
            "Marketplace contract not approved to transfer the NFT"
        );

        _listingIdCounter++;
        listings[_listingIdCounter] = Listing({
            seller: msg.sender,
            nftContract: _nftContract,
            tokenId: _tokenId,
            price: _price,
            active: true
        });

        emit NFTListed(_listingIdCounter, msg.sender, _nftContract, _tokenId, _price);
    }

    /**
     * @dev Purchases an NFT from a listing.
     * Sends the NFT to the buyer and distributes payment to the seller and fee recipient.
     * @param _listingId The ID of the listing to purchase.
     */
    function buyNFT(uint256 _listingId) public payable whenNotPaused {
        Listing storage listing = listings[_listingId];

        require(listing.active, "Listing is not active");
        require(listing.nftContract != address(0), "Invalid listing NFT contract");
        require(listing.seller != address(0), "Invalid listing seller");
        require(msg.value >= listing.price, "Insufficient funds to buy NFT");
        require(listing.seller != msg.sender, "Cannot buy your own NFT");

        // Calculate fees
        uint256 totalAmountSent = msg.value; // Total amount sent by buyer
        uint256 feeAmount = (listing.price * _feePercentage) / 10000; // Fee based on listing price
        uint256 sellerPayout = listing.price - feeAmount;

        // Mark listing as inactive BEFORE transfers (Checks-Effects-Interactions pattern)
        listing.active = false;

        // 1. Transfer NFT from seller to buyer
        // This will revert if transfer fails (e.g., marketplace approval revoked, NFT already moved)
        IERC721(listing.nftContract).safeTransferFrom(listing.seller, msg.sender, listing.tokenId);

        // 2. Distribute ETH payments
        // Using call for robustness, handle potential failures
        (bool successSeller, ) = payable(listing.seller).call{value: sellerPayout}("");
        require(successSeller, "Failed to send ETH to seller");

        if (feeAmount > 0) {
            (bool successFee, ) = payable(_feeRecipient).call{value: feeAmount}("");
            require(successFee, "Failed to send ETH to fee recipient");
        }

        // 3. Refund any overpayment to the buyer
        uint256 refundAmount = totalAmountSent - listing.price;
        if (refundAmount > 0) {
            (bool successRefund, ) = payable(msg.sender).call{value: refundAmount}("");
            require(successRefund, "Failed to refund overpayment");
        }

        emit NFTSold(_listingId, msg.sender, listing.seller, listing.nftContract, listing.tokenId, listing.price, feeAmount);
    }

    /**
     * @dev Cancels an active NFT listing.
     * Only the seller of the NFT can cancel their listing.
     * @param _listingId The ID of the listing to cancel.
     */
    function cancelListing(uint256 _listingId) public onlyListingOwner(_listingId) whenNotPaused {
        Listing storage listing = listings[_listingId];
        require(listing.active, "Listing is not active");

        listing.active = false;
        emit ListingCancelled(_listingId, msg.sender);
    }

    // --- Getter Functions ---

    /**
     * @dev Returns the current listing ID counter.
     */
    function getCurrentListingId() public view returns (uint256) {
        return _listingIdCounter;
    }
}