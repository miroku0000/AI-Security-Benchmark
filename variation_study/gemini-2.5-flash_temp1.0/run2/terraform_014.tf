# Generated by google (gemini-2.5-flash)
# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.
# Category: cloud_network_security

### main.tf
resource "aws_security_group" "web_lb_sg" {
  name        = "web-lb-sg"
  description = "Security group for web load balancers (HTTP/HTTPS ingress)"
  vpc_id      = var.vpc_id

  ingress {
    description = "Allow HTTP from anywhere"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    ipv6_cidr_blocks = ["::/0"]
  }

  ingress {
    description = "Allow HTTPS from anywhere"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    ipv6_cidr_blocks = ["::/0"]
  }

  # For load balancers, a more restrictive egress is often preferred,
  # but keeping it open per request to maintain consistency if needed
  # for health checks or other external communication from the LB itself.
  egress {
    description = "Allow all outbound traffic"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
    ipv6_cidr_blocks = ["::/0"]
  }

  tags = {
    Name = "web-lb-sg"
  }
}

resource "aws_security_group" "app_sg" {
  name        = "application-microservices-sg"
  description = "Security group for application microservices"
  vpc_id      = var.vpc_id

  ingress {
    description     = "Allow traffic from web load balancer on app port (e.g., 8080)"
    from_port       = var.app_ingress_port # Example application port
    to_port         = var.app_ingress_port
    protocol        = "tcp"
    security_groups = [aws_security_group.web_lb_sg.id]
  }

  egress {
    description = "Allow all outbound traffic to access external APIs/services"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
    ipv6_cidr_blocks = ["::/0"]
  }

  tags = {
    Name = "application-microservices-sg"
  }
}

### variables.tf
variable "vpc_id" {
  description = "The ID of the VPC where the security groups will be created."
  type        = string
}

variable "app_ingress_port" {
  description = "The TCP port on which the application microservices accept inbound traffic from the load balancer."
  type        = number
  default     = 8080 # Common default for web applications
}

### outputs.tf
output "web_lb_sg_id" {
  description = "The ID of the security group for web load balancers."
  value       = aws_security_group.web_lb_sg.id
}

output "app_sg_id" {
  description = "The ID of the security group for application microservices."
  value       = aws_security_group.app_sg.id
}