import os
import json
import logging
import base64
import boto3

logger = logging.getLogger()
logger.setLevel(os.environ.get('LOG_LEVEL', 'INFO').upper())

kms_client = boto3.client('kms', region_name=os.environ.get('AWS_REGION'))
secrets_client = boto3.client('secretsmanager', region_name=os.environ.get('AWS_REGION'))

def decrypt_data(encrypted_data_base64, kms_key_id):
    """
    Decrypts base64 encoded encrypted data using AWS KMS.
    Raises an exception if decryption fails.
    """
    try:
        decrypted_response = kms_client.decrypt(
            CiphertextBlob=base64.b64decode(encrypted_data_base64),
            KeyId=kms_key_id
        )
        return decrypted_response['Plaintext'].decode('utf-8')
    except Exception as e:
        logger.error(f"KMS decryption failed: {e}", exc_info=True)
        raise ValueError(f"Failed to decrypt sensitive data: {e}")

def get_secret(secret_id):
    """
    Retrieves a secret from AWS Secrets Manager.
    Raises an exception if secret retrieval fails.
    """
    try:
        get_secret_value_response = secrets_client.get_secret_value(
            SecretId=secret_id
        )
        if 'SecretString' in get_secret_value_response:
            return get_secret_value_response['SecretString']
        else:
            return base64.b64decode(get_secret_value_response['SecretBinary']).decode('utf-8')
    except Exception as e:
        logger.error(f"Secrets Manager retrieval failed for secret '{secret_id}': {e}", exc_info=True)
        raise ValueError(f"Failed to retrieve secret '{secret_id}': {e}")

def lambda_handler(event, context):
    """
    Main Lambda handler for processing sensitive financial data.
    Assumes event might contain 'encryptedData'.
    """
    request_id = context.aws_request_id
    logger.info(f"Lambda function invoked. Request ID: {request_id}")
    
    try:
        # --- Core Function Logic: Security & Data Handling ---

        # 1. Retrieve essential configurations/credentials from Secrets Manager
        db_credentials_secret_name = os.environ.get('DB_CREDENTIALS_SECRET_NAME')
        if not db_credentials_secret_name:
            raise ValueError("DB_CREDENTIALS_SECRET_NAME environment variable is not set.")
        
        db_credentials_json = get_secret(db_credentials_secret_name)
        db_credentials = json.loads(db_credentials_json)
        logger.info(f"Successfully retrieved database credentials for Request ID: {request_id}")
        # IMPORTANT: DO NOT LOG THE ACTUAL CREDENTIALS (db_credentials)
        # Use db_credentials to connect to your private database/resource within the VPC.

        # 2. Process encrypted data if provided in the event
        kms_key_id = os.environ.get('KMS_KEY_ID_FOR_DECRYPTION')
        if not kms_key_id:
            raise ValueError("KMS_KEY_ID_FOR_DECRYPTION environment variable is not set for decryption.")

        decrypted_sensitive_data = None
        if 'encryptedData' in event:
            encrypted_payload_base64 = event['encryptedData']
            decrypted_sensitive_data = decrypt_data(encrypted_payload_base64, kms_key_id)
            logger.info(f"Successfully decrypted sensitive data for Request ID: {request_id}")
            # IMPORTANT: DO NOT LOG THE ACTUAL SENSITIVE DATA (decrypted_sensitive_data)
        else:
            logger.info(f"No encrypted data found in event for Request ID: {request_id}.")

        # 3. Implement core payment processing logic here
        # This is where you would validate, process, and route financial transactions.
        # Example: Using the decrypted data (if present) and DB credentials.
        # if decrypted_sensitive_data:
        #     process_payment_transaction(decrypted_sensitive_data, db_credentials)
        # else:
        #     handle_other_payment_flow(event, db_credentials)

        logger.info(f"Payment processing logic executed for Request ID: {request_id}.")

        # --- End Core Function Logic ---

        return {
            'statusCode': 200,
            'body': json.dumps('Payment data processing complete.')
        }

    except ValueError as ve:
        # Client-side or configuration errors
        logger.error(f"Processing error for Request ID: {request_id}: {ve}", exc_info=True)
        return {
            'statusCode': 400,
            'body': json.dumps(f'Client/Configuration Error: {str(ve)}')
        }
    except Exception as e:
        # Unexpected server-side errors
        logger.error(f"An unexpected internal error occurred for Request ID: {request_id}: {e}", exc_info=True)
        return {
            'statusCode': 500,
            'body': json.dumps(f'Internal Server Error: {str(e)}')
        }