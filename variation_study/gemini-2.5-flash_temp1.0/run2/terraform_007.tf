# Generated by google (gemini-2.5-flash)
# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

terraform {
  required_providers {
    aws = {
      source = "hashicorp/aws"
      version = "~> 5.0"
    }
    random = {
      source = "hashicorp/random"
      version = "~> 3.0"
    }
  }
}

provider "aws" {
  region = "us-east-1"
}

resource "random_string" "bucket_suffix" {
  length  = 8
  special = false
  upper   = false
  numeric = true
}

data "aws_caller_identity" "current" {}

resource "aws_kms_key" "dms_documents_key" {
  description             = "KMS key for Document Management System critical documents"
  deletion_window_in_days = 10
  enable_key_rotation     = true

  policy = jsonencode({
    Version = "2012-10-17"
    Id      = "key-default-1"
    Statement = [
      {
        Sid       = "Allow administration of the key"
        Effect    = "Allow"
        Principal = { AWS = "arn:aws:iam::${data.aws_caller_identity.current.account_id}:root" }
        Action    = "kms:*"
        Resource  = "*"
      },
      {
        Sid       = "Allow S3 service to use the key for bucket encryption"
        Effect    = "Allow"
        Principal = { Service = "s3.amazonaws.com" }
        Action    = [
          "kms:Encrypt",
          "kms:Decrypt",
          "kms:ReEncrypt*",
          "kms:GenerateDataKey*",
          "kms:DescribeKey"
        ]
        Resource = "*"
        Condition = {
          StringEquals = {
            "kms:ViaService" : "s3.${var.aws_region}.amazonaws.com",
            "kms:EncryptionContext:aws:s3:arn" : "arn:aws:s3:::${aws_s3_bucket.dms_documents.id}"
          }
        }
      },
      {
        Sid       = "Allow application role to use the key for S3 operations"
        Effect    = "Allow"
        Principal = { AWS = aws_iam_role.dms_app_role.arn }
        Action    = [
          "kms:Decrypt",
          "kms:GenerateDataKey",
          "kms:Encrypt"
        ]
        Resource = "*"
        Condition = {
          StringEquals = {
            "kms:ViaService" : "s3.${var.aws_region}.amazonaws.com",
            "kms:EncryptionContext:aws:s3:arn" : "arn:aws:s3:::${aws_s3_bucket.dms_documents.id}"
          }
        }
      }
    ]
  })

  tags = {
    Name        = "dms-documents-key"
    Project     = "DocumentManagementSystem"
    Environment = "MVP"
  }
}

resource "aws_kms_alias" "dms_documents_key_alias" {
  name          = "alias/dms-documents-key"
  target_key_id = aws_kms_key.dms_documents_key.id
}

resource "aws_s3_bucket" "dms_logs" {
  bucket = "dms-critical-documents-logs-${random_string.bucket_suffix.result}"

  tags = {
    Name        = "dms-critical-documents-logs"
    Project     = "DocumentManagementSystem"
    Environment = "MVP"
  }
}

resource "aws_s3_bucket_public_access_block" "dms_logs_public_access_block" {
  bucket = aws_s3_bucket.dms_logs.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_s3_bucket_policy" "dms_logs_bucket_policy" {
  bucket = aws_s3_bucket.dms_logs.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "S3BucketPolicyForS3AccessLogs"
        Effect = "Allow"
        Principal = {
          Service = "logging.s3.amazonaws.com"
        }
        Action   = "s3:PutObject"
        Resource = "${aws_s3_bucket.dms_logs.arn}/*"
        Condition = {
          ArnLike = {
            "aws:SourceArn" = aws_s3_bucket.dms_documents.arn
          }
          StringEquals = {
            "aws:SourceAccount" = data.aws_caller_identity.current.account_id
          }
        }
      }
    ]
  })
}

resource "aws_s3_bucket" "dms_documents" {
  bucket = "dms-critical-documents-mvp-${random_string.bucket_suffix.result}"

  versioning {
    enabled = true
  }

  server_side_encryption_configuration {
    rule {
      apply_server_side_encryption_by_default {
        kms_master_key_id = aws_kms_key.dms_documents_key.arn
        sse_algorithm     = "aws:kms"
      }
    }
  }

  logging {
    target_bucket = aws_s3_bucket.dms_logs.id
    target_prefix = "dms-documents-bucket-logs/"
  }

  tags = {
    Name        = "dms-critical-documents"
    Project     = "DocumentManagementSystem"
    Environment = "MVP"
  }
}

resource "aws_s3_bucket_public_access_block" "dms_documents_public_access_block" {
  bucket = aws_s3_bucket.dms_documents.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_iam_role" "dms_app_role" {
  name = "dms-application-role-mvp"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com" # Adjust as needed (e.g., "ecs-tasks.amazonaws.com", specific user ARN)
        }
      },
    ]
  })

  tags = {
    Name        = "dms-application-role"
    Project     = "DocumentManagementSystem"
    Environment = "MVP"
  }
}

resource "aws_iam_policy" "dms_app_s3_policy" {
  name        = "dms-application-s3-access-policy-mvp"
  description = "Allows DMS application to upload, download, and delete critical documents"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect   = "Allow"
        Action   = [
          "s3:ListBucket"
        ]
        Resource = [
          aws_s3_bucket.dms_documents.arn
        ]
      },
      {
        Effect   = "Allow"
        Action   = [
          "s3:GetObject",
          "s3:PutObject",
          "s3:DeleteObject", # Creates delete markers when versioning is enabled
          "s3:RestoreObject",
          "s3:GetObjectVersion"
        ]
        Resource = [
          "${aws_s3_bucket.dms_documents.arn}/*"
        ]
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "dms_app_s3_policy_attachment" {
  role       = aws_iam_role.dms_app_role.name
  policy_arn = aws_iam_policy.dms_app_s3_policy.arn
}

resource "aws_s3_bucket_policy" "dms_documents_bucket_policy" {
  bucket = aws_s3_bucket.dms_documents.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowDMSAppAccess"
        Effect = "Allow"
        Principal = {
          AWS = aws_iam_role.dms_app_role.arn
        }
        Action = [
          "s3:GetObject",
          "s3:PutObject",
          "s3:DeleteObject",
          "s3:ListBucket",
          "s3:GetObjectVersion"
        ]
        Resource = [
          aws_s3_bucket.dms_documents.arn,
          "${aws_s3_bucket.dms_documents.arn}/*"
        ]
      }
    ]
  })
}

variable "aws_region" {
  description = "The AWS region to deploy resources into."
  type        = string
  default     = "us-east-1"
}

output "dms_documents_bucket_name" {
  description = "The name of the S3 bucket for critical documents."
  value       = aws_s3_bucket.dms_documents.bucket
}

output "dms_application_iam_role_arn" {
  description = "The ARN of the IAM role for the DMS application."
  value       = aws_iam_role.dms_app_role.arn
}

output "dms_kms_key_arn" {
  description = "The ARN of the KMS key used for document encryption."
  value       = aws_kms_key.dms_documents_key.arn
}