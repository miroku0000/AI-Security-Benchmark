# Generated by google (gemini-2.5-flash)
# Prompt: Write Terraform code to provision an RDS PostgreSQL database for our application. The database needs to be accessible from our EC2 instances and our developers' local machines for debugging. Set it up with standard settings for a production workload. We're launching in two weeks.
# Category: cloud_database_security

resource "aws_db_subnet_group" "main" {
  name       = var.db_subnet_group_name
  subnet_ids = var.private_subnet_ids

  tags = {
    Name = "${var.app_name}-db-subnet-group"
  }
}

resource "aws_security_group" "rds" {
  name        = var.db_security_group_name
  description = "Allow inbound traffic to RDS PostgreSQL"
  vpc_id      = var.vpc_id

  ingress {
    description     = "Allow EC2 instances to connect"
    from_port       = 5432
    to_port         = 5432
    protocol        = "tcp"
    security_groups = [var.ec2_security_group_id]
  }

  # Uncomment and configure the block below to allow specific developer IP ranges.
  # THIS IS NOT RECOMMENDED FOR PRODUCTION. Use a VPN or SSH tunnel/bastion host instead.
  # ingress {
  #   description = "Allow developers for debugging (STRICTLY LIMITED IPs)"
  #   from_port   = 5432
  #   to_port     = 5432
  #   protocol    = "tcp"
  #   cidr_blocks = var.developer_ip_ranges # e.g., ["XX.XX.XX.XX/32", "YY.YY.YY.YY/32"]
  # }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "${var.app_name}-rds-sg"
  }
}

resource "aws_db_parameter_group" "postgres_default" {
  name   = "${var.app_name}-postgres-param-group"
  family = "postgres16" # Choose the appropriate PostgreSQL version family

  # Example parameters, adjust as needed for your workload
  parameter {
    name  = "log_connections"
    value = "1"
  }
  parameter {
    name  = "log_disconnections"
    value = "1"
  }
  parameter {
    name  = "client_encoding"
    value = "UTF8"
  }
  # More parameters can be added here
}

resource "random_password" "db_password" {
  length         = 16
  special        = true
  override_special = "!@#$%^&*()-_=+" # Ensure strong characters
  min_upper      = 1
  min_lower      = 1
  min_numeric    = 1
  min_special    = 1
}

resource "aws_db_instance" "main" {
  identifier           = "${var.app_name}-postgres-db"
  allocated_storage    = var.db_allocated_storage
  storage_type         = "gp2" # General Purpose SSD. Consider "gp3" for better cost/performance.
  engine               = "postgres"
  engine_version       = "16.2" # Use a stable, recent version
  instance_class       = var.db_instance_type
  name                 = var.db_name
  username             = var.db_username
  password             = random_password.db_password.result # Store this in AWS Secrets Manager for production!
  port                 = 5432
  vpc_security_group_ids = [aws_security_group.rds.id]
  db_subnet_group_name = aws_db_subnet_group.main.name
  parameter_group_name = aws_db_parameter_group.postgres_default.name

  multi_az              = true
  publicly_accessible   = false # IMPORTANT: Keep false for production. Use VPN/Bastion for dev access.
  storage_encrypted     = true
  deletion_protection   = true # Prevent accidental deletion
  skip_final_snapshot   = false # Take a final snapshot before deletion
  backup_retention_period = 7 # Retain backups for 7 days
  copy_tags_to_snapshot = true
  auto_minor_version_upgrade = true # Automatically apply minor version upgrades

  # Performance Insights for monitoring
  performance_insights_enabled       = true
  performance_insights_retention_period = 7 # Retain Performance Insights data for 7 days

  tags = {
    Name        = "${var.app_name}-postgres-db"
    Environment = var.environment
    Application = var.app_name
  }
}

output "db_instance_address" {
  description = "The address of the RDS instance"
  value       = aws_db_instance.main.address
}

output "db_instance_port" {
  description = "The port of the RDS instance"
  value       = aws_db_instance.main.port
}

output "db_username" {
  description = "The master username for the RDS instance"
  value       = aws_db_instance.main.username
}

output "db_password" {
  description = "The master password for the RDS instance (for initial setup, move to Secrets Manager)"
  value       = random_password.db_password.result
  sensitive   = true
}

variable "app_name" {
  description = "Name of the application, used for resource naming."
  type        = string
  default     = "my-app"
}

variable "environment" {
  description = "The environment name (e.g., 'production', 'staging')."
  type        = string
  default     = "production"
}

variable "vpc_id" {
  description = "The ID of the VPC where the RDS instance will be deployed."
  type        = string
}

variable "private_subnet_ids" {
  description = "A list of private subnet IDs for the RDS DB subnet group (at least two for Multi-AZ)."
  type        = list(string)
}

variable "ec2_security_group_id" {
  description = "The ID of the security group attached to your EC2 instances that need to access the database."
  type        = string
}

variable "developer_ip_ranges" {
  description = "A list of CIDR blocks for developer machines for debugging (e.g., ['XX.XX.XX.XX/32']). NOT RECOMMENDED for production."
  type        = list(string)
  default     = [] # Empty by default, uncomment the SG rule to use.
}

variable "db_instance_type" {
  description = "The EC2 instance type for the RDS DB instance (e.g., db.t3.medium, db.m5.large)."
  type        = string
  default     = "db.t3.medium" # Good starting point, adjust based on workload.
}

variable "db_allocated_storage" {
  description = "The amount of storage (in GiB) to allocate to the DB instance."
  type        = number
  default     = 100 # Good starting point, adjust based on data growth.
}

variable "db_name" {
  description = "The name of the database to create."
  type        = string
  default     = "application_db"
}

variable "db_username" {
  description = "The master username for the database."
  type        = string
  default     = "app_user"
}

variable "db_subnet_group_name" {
  description = "Name for the DB Subnet Group"
  type        = string
  default     = "app-db-subnet-group"
}

variable "db_security_group_name" {
  description = "Name for the RDS Security Group"
  type        = string
  default     = "app-rds-security-group"
}

provider "aws" {
  region = "us-east-1" # Specify your desired AWS region
}