# Generated by google (gemini-2.5-flash)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

provider "aws" {
  region = "us-east-1"
}

data "aws_ami" "amazon_linux_2" {
  most_recent = true
  owners      = ["amazon"]

  filter {
    name   = "name"
    values = ["amzn2-ami-hvm-*-x86_64-gp2"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
}

resource "aws_security_group" "app_sg" {
  name        = "app-sg"
  description = "Allow HTTP and SSH access to application instances"

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "Allow HTTP access from anywhere"
  }

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "Allow SSH access from anywhere (adjust for production)"
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
    description = "Allow all outbound traffic"
  }

  tags = {
    Name = "AppSecurityGroup"
  }
}

resource "aws_iam_role" "app_instance_role" {
  name = "app-instance-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17",
    Statement = [
      {
        Action = "sts:AssumeRole",
        Effect = "Allow",
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      }
    ]
  })

  tags = {
    Name = "AppInstanceIAMRole"
  }
}

resource "aws_iam_instance_profile" "app_instance_profile" {
  name = "app-instance-profile"
  role = aws_iam_role.app_instance_role.name

  tags = {
    Name = "AppInstanceProfile"
  }
}

resource "aws_iam_role_policy" "app_s3_read_policy" {
  name = "app-s3-read-policy"
  role = aws_iam_role.app_instance_role.id

  policy = jsonencode({
    Version = "2012-10-17",
    Statement = [
      {
        Action = [
          "s3:GetObject",
          "s3:ListBucket"
        ],
        Effect = "Allow",
        Resource = [
          "arn:aws:s3:::your-app-artifacts-bucket/*", # REPLACE with your S3 bucket containing app artifacts
          "arn:aws:s3:::your-app-artifacts-bucket"    # REPLACE with your S3 bucket name
        ]
      }
    ]
  })
}

locals {
  app_backend_service_url = "http://your-internal-backend-service.internal:8080" # REPLACE with your actual backend endpoint
  app_version             = "1.0.0"
  app_bucket_name         = "your-app-artifacts-bucket" # REPLACE with your S3 bucket name
  app_artifact_key        = "app-${local.app_version}.tar.gz"
}

resource "aws_launch_template" "app_launch_template" {
  name_prefix   = "app-lt-"
  image_id      = data.aws_ami.amazon_linux_2.id
  instance_type = "t3.micro"
  key_name      = "your-key-pair-name" # REPLACE with your EC2 Key Pair name

  network_interfaces {
    associate_public_ip_address = true
    security_groups             = [aws_security_group.app_sg.id]
  }

  iam_instance_profile {
    name = aws_iam_instance_profile.app_instance_profile.name
  }

  user_data = base64encode(templatefile("${path.module}/user_data.sh", {
    backend_service_url = local.app_backend_service_url
    app_version         = local.app_version
    app_bucket_name     = local.app_bucket_name
    app_artifact_key    = local.app_artifact_key
  }))

  tag_specifications {
    resource_type = "instance"
    tags = {
      Name        = "WebAppInstance"
      Environment = "Development"
    }
  }

  tag_specifications {
    resource_type = "volume"
    tags = {
      Name        = "WebAppVolume"
      Environment = "Development"
    }
  }

  tags = {
    Name = "AppLaunchTemplate"
  }
}

