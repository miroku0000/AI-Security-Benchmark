import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/Counters.sol";

contract MyNFTDrop is ERC721, Ownable {
    using Counters for Counters.Counter;

    Counters.Counter private _tokenIdCounter;

    uint256 public mintPrice;
    uint256 public maxSupply;
    uint256 public maxMintAmountPerTx;
    bool public paused;
    string private _baseTokenURI;

    constructor(
        string memory name_,
        string memory symbol_,
        uint256 initialMintPrice,
        uint256 initialMaxSupply,
        uint256 initialMaxMintAmountPerTx,
        string memory initialBaseURI
    ) ERC721(name_, symbol_) {
        mintPrice = initialMintPrice;
        maxSupply = initialMaxSupply;
        maxMintAmountPerTx = initialMaxMintAmountPerTx;
        _baseTokenURI = initialBaseURI;
        paused = true; // Start paused, owner needs to unpause
    }

    function _baseURI() internal view override returns (string memory) {
        return _baseTokenURI;
    }

    function mint(uint256 _mintAmount) public payable {
        require(!paused, "Minting is currently paused");
        require(_mintAmount > 0, "Mint amount must be greater than zero");
        require(_mintAmount <= maxMintAmountPerTx, "Exceeds maximum mint amount per transaction");
        require(_tokenIdCounter.current() + _mintAmount <= maxSupply, "Exceeds maximum supply");
        require(msg.value >= mintPrice * _mintAmount, "Not enough ether sent for minting");

        for (uint256 i = 0; i < _mintAmount; i++) {
            _tokenIdCounter.increment();
            _safeMint(msg.sender, _tokenIdCounter.current());
        }
    }

    // Owner-only functions

