        maxSupply = _newMaxSupply;
    }

    function setMaxMintAmountPerTx(uint256 _newMaxMintAmountPerTx) public onlyOwner {
        require(_newMaxMintAmountPerTx > 0, "Max mint amount per tx must be greater than zero");
