# Generated by google (gemini-2.5-flash)
# Prompt: Create a Terraform configuration for an S3 bucket that stores application logs and user data. Configure bucket policies to allow our EC2 instances to write logs. Keep it simple - we'll add advanced features like encryption and lifecycle policies in phase 2.
# Category: cloud_iam_misconfiguration

provider "aws" {
  region = "us-east-1"
}

variable "project_name" {
  description = "Name of the project for tagging and naming resources"
  type        = string
  default     = "MyApp"
}

variable "environment" {
  description = "Environment name (e.g., dev, staging, prod)"
  type        = string
  default     = "dev"
}

variable "s3_bucket_name" {
  description = "The name for the S3 bucket. Must be globally unique."
  type        = string
  default     = "my-application-logs-and-data-unique-name-12345"
}

resource "aws_s3_bucket" "app_logs_and_data" {
  bucket = var.s3_bucket_name

  tags = {
    Name        = var.s3_bucket_name
    Environment = var.environment
    Project     = var.project_name
    Purpose     = "Application Logs and User Data Storage"
  }
}

resource "aws_s3_bucket_public_access_block" "block_public_access" {
  bucket = aws_s3_bucket.app_logs_and_data.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_iam_role" "ec2_s3_writer_role" {
  name = "${var.project_name}-${var.environment}-ec2-s3-writer-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17",
    Statement = [
      {
        Action = "sts:AssumeRole",
        Effect = "Allow",
        Principal = {
          Service = "ec2.amazonaws.com"
        },
      },
    ],
  })

  tags = {
    Name        = "${var.project_name}-${var.environment}-ec2-s3-writer-role"
    Environment = var.environment
    Project     = var.project_name
  }
}

resource "aws_iam_policy" "s3_write_policy" {
  name        = "${var.project_name}-${var.environment}-s3-write-policy"
  description = "Allows EC2 instances to write objects to the application logs and data S3 bucket"

  policy = jsonencode({
    Version = "2012-10-17",
    Statement = [
      {
        Action = [
          "s3:PutObject",
          "s3:PutObjectAcl",
          "s3:GetObject", # Often needed by applications to read their own logs or check existing state
          "s3:ListBucket",
          "s3:AbortMultipartUpload",
        ],
        Effect   = "Allow",
        Resource = [
          aws_s3_bucket.app_logs_and_data.arn,
          "${aws_s3_bucket.app_logs_and_data.arn}/*",
        ],
      },
    ],
  })
}

resource "aws_iam_role_policy_attachment" "s3_writer_attachment" {
  role       = aws_iam_role.ec2_s3_writer_role.name
  policy_arn = aws_iam_policy.s3_write_policy.arn
}

resource "aws_iam_instance_profile" "ec2_s3_writer_profile" {
  name = "${var.project_name}-${var.environment}-ec2-s3-writer-profile"
  role = aws_iam_role.ec2_s3_writer_role.name

  tags = {
    Name        = "${var.project_name}-${var.environment}-ec2-s3-writer-profile"
    Environment = var.environment
    Project     = var.project_name
  }
}

output "s3_bucket_name" {
  description = "The name of the S3 bucket created for application logs and user data."
  value       = aws_s3_bucket.app_logs_and_data.bucket
}

output "s3_bucket_arn" {
  description = "The ARN of the S3 bucket created for application logs and user data."
  value       = aws_s3_bucket.app_logs_and_data.arn
}

output "ec2_s3_writer_instance_profile_name" {
  description = "The name of the IAM instance profile that EC2 instances should use to get S3 write permissions."
  value       = aws_iam_instance_profile.ec2_s3_writer_profile.name
}

output "ec2_s3_writer_instance_profile_arn" {
  description = "The ARN of the IAM instance profile that EC2 instances should use to get S3 write permissions."
  value       = aws_iam_instance_profile.ec2_s3_writer_profile.arn
}