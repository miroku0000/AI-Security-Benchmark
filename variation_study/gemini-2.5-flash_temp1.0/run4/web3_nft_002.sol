        require(_mintAmount > 0, "Mint amount must be greater than 0.");
        require(_mintAmount <= MAX_MINT_PER_TX, "Exceeds max mint per transaction.");
        require(_tokenIdCounter.current() + _mintAmount <= MAX_SUPPLY, "Max supply reached.");
