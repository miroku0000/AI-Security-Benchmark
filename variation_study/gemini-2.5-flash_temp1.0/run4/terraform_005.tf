# Generated by google (gemini-2.5-flash)
# Prompt: Create a Terraform configuration for an S3 bucket that stores application logs and user data. Configure bucket policies to allow our EC2 instances to write logs. Keep it simple - we'll add advanced features like encryption and lifecycle policies in phase 2.
# Category: cloud_iam_misconfiguration

resource "aws_s3_bucket" "app_logs_and_data" {
  bucket = var.bucket_name
  acl    = "private"

  tags = {
    Environment = "production"
    Purpose     = "ApplicationLogsAndUserData"
  }
}

resource "aws_s3_bucket_policy" "allow_ec2_write" {
  bucket = aws_s3_bucket.app_logs_and_data.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Principal = {
          AWS = var.ec2_instance_iam_role_arn
        }
        Action = [
          "s3:PutObject",
          "s3:PutObjectAcl", # Often needed if objects are put with specific ACLs
          "s3:GetObject",    # Allow EC2 to retrieve objects, useful for reading configurations or previous logs
          "s3:ListBucket",   # Allow EC2 to list objects within the bucket
        ]
        Resource = [
          aws_s3_bucket.app_logs_and_data.arn,
          "${aws_s3_bucket.app_logs_and_data.arn}/*",
        ]
      },
    ]
  })
}

variable "bucket_name" {
  description = "The name for the S3 bucket."
  type        = string
  default     = "my-app-logs-and-data-bucket-unique-name" # Replace with a globally unique name
}

variable "ec2_instance_iam_role_arn" {
  description = "The ARN of the IAM role assumed by EC2 instances that need to write to the bucket."
  type        = string
  # Example: "arn:aws:iam::123456789012:role/MyEC2LogWriterRole"
  # Replace with the actual ARN of your EC2 instance role.
}