# Generated by google (gemini-2.5-flash)
# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

resource "aws_s3_bucket" "document_storage" {
  bucket = "my-critical-documents-mvp-12345" # Replace with a globally unique bucket name
  acl    = "private"

  tags = {
    Name        = "DocumentStorageMVP"
    Environment = "Development"
    Purpose     = "Critical Business Documents"
  }
}

resource "aws_s3_bucket_versioning" "document_storage_versioning" {
  bucket = aws_s3_bucket.document_storage.id
  versioning_configuration {
    status = "Enabled"
    # MFA Delete is highly recommended for critical documents to prevent accidental permanent deletion.
    # To enable it, you must configure a virtual or physical MFA device for the root AWS account.
    # mfa_delete = "Enabled" # Uncomment and configure if MFA Delete is required.
  }
}

resource "aws_s3_bucket_server_side_encryption_configuration" "document_storage_encryption" {
  bucket = aws_s3_bucket.document_storage.id

  rule {
    apply_server_side_encryption_by_default {
      kms_master_key_id = "alias/aws/s3" # Using AWS managed KMS key for S3. For more control, create a custom KMS key.
      sse_algorithm     = "aws:kms"
    }
  }
}

resource "aws_s3_bucket_public_access_block" "document_storage_public_access_block" {
  bucket = aws_s3_bucket.document_storage.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

# --- IAM Policy for Application Access (attach this to your application's IAM Role/User) ---
# This data source creates an IAM policy document that can be attached to an IAM role or user
# which your application assumes to interact with the S3 bucket.

data "aws_iam_policy_document" "app_s3_access_policy" {
  statement {
    sid    = "ListBucket"
    effect = "Allow"
    actions = [
      "s3:ListBucket",
    ]
    resources = [
      aws_s3_bucket.document_storage.arn,
    ]
  }

  statement {
    sid    = "ManageObjects"
    effect = "Allow"
    actions = [
      "s3:PutObject",
      "s3:GetObject",
      "s3:DeleteObject",
      "s3:GetObjectVersion", # Useful when versioning is enabled
    ]
    resources = [
      "${aws_s3_bucket.document_storage.arn}/*",
    ]
  }
}

# Example of how to output the policy JSON (for attaching to an IAM role/user manually or with another resource)
output "app_s3_access_policy_json" {
  description = "IAM policy document JSON for application access to the S3 bucket"
  value       = data.aws_iam_policy_document.app_s3_access_policy.json
}

# Example of how to output the bucket name for application configuration
output "s3_bucket_name" {
  description = "The name of the S3 bucket"
  value       = aws_s3_bucket.document_storage.id
}