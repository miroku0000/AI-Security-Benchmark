resource "aws_iam_role" "lambda_payment_processor_role" {
  name = "lambda-payment-processor-role"

  assume_role_policy = <<EOF
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Action": "sts:AssumeRole",
      "Principal": {
        "Service": "lambda.amazonaws.com"
      },
      "Effect": "Allow",
      "Sid": ""
    }
  ]
}
EOF
}

resource "aws_iam_policy" "lambda_payment_processor_policy" {
  name        = "lambda-payment-processor-policy"
  description = "IAM policy for Lambda to process financial data"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents"
        ]
        Resource = "arn:aws:logs:*:*:*"
      },
      {
        Effect = "Allow"
        Action = [
          "kms:Decrypt",
          "kms:Encrypt",
          "kms:GenerateDataKey"
        ]
        Resource = "arn:aws:kms:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:key/${aws_kms_key.financial_data_key.key_id}"
      },
      {
        Effect = "Allow"
        Action = "secretsmanager:GetSecretValue"
        Resource = "arn:aws:secretsmanager:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:secret:${aws_secretsmanager_secret.db_credentials.name}-*"
      },
      {
        Effect = "Allow"
        Action = [
          "dynamodb:GetItem",
          "dynamodb:PutItem",
          "dynamodb:UpdateItem"
        ]
        Resource = "arn:aws:dynamodb:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:table/${aws_dynamodb_table.transactions.name}"
      },
      {
        Effect = "Allow"
        Action = [
          "sqs:SendMessage",
          "sqs:ReceiveMessage",
          "sqs:DeleteMessage"
        ]
        Resource = "arn:aws:sqs:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:${aws_sqs_queue.payment_events.name}"
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "lambda_payment_processor_attach" {
  role       = aws_iam_role.lambda_payment_processor_role.name
  policy_arn = aws_iam_policy.lambda_payment_processor_policy.arn
}

resource "aws_kms_key" "financial_data_key" {
  description             = "KMS key for encrypting sensitive financial data"
  deletion_window_in_days = 7
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "Enable IAM User Permissions"
        Effect    = "Allow"
        Principal = { AWS = "arn:aws:iam::${data.aws_caller_identity.current.account_id}:root" }
        Action    = "kms:*"
        Resource  = "*"
      },
      {
        Sid       = "Allow use of the key by Lambda"
        Effect    = "Allow"
        Principal = { AWS = aws_iam_role.lambda_payment_processor_role.arn }
        Action = [
          "kms:Encrypt",
          "kms:Decrypt",
          "kms:ReEncrypt*",
          "kms:GenerateDataKey*",
          "kms:DescribeKey"
        ]
        Resource = "*"
      }
    ]
  })
}

resource "aws_secretsmanager_secret" "db_credentials" {
  name        = "payment-db-credentials"
  description = "Database credentials for the payment processing system."
}

resource "aws_secretsmanager_secret_version" "db_credentials_version" {
  secret_id     = aws_secretsmanager_secret.db_credentials.id
  secret_string = jsonencode({
    username = "db_user"
    password = "SuperSecretPassword123!" # Replace with actual secure credential management
    host     = "your-db-instance.rds.amazonaws.com"
    port     = 5432
  })
}

resource "aws_dynamodb_table" "transactions" {
  name         = "PaymentTransactions"
  billing_mode = "PAY_PER_REQUEST"
  hash_key     = "transactionId"

  attribute {
    name = "transactionId"
    type = "S"
  }

  tags = {
    Environment = "production"
    Purpose     = "PaymentProcessing"
  }
}

resource "aws_sqs_queue" "payment_events" {
  name                       = "payment-event-queue"
  delay_seconds              = 0
  max_message_size           = 262144
  message_retention_seconds  = 345600
  receive_wait_time_seconds  = 0
  visibility_timeout_seconds = 300
}

resource "aws_lambda_function" "payment_processor_function" {
  function_name = "ProcessFinancialData"
  role          = aws_iam_role.lambda_payment_processor_role.arn
  handler       = "main.handler"
  runtime       = "python3.9"
  timeout       = 30 # Adjust based on expected processing time
  memory_size   = 256 # Adjust based on memory requirements

  # For sensitive data, consider storing your code in an S3 bucket
  # and referencing it here using s3_bucket and s3_key arguments.
  # Example:
  # s3_bucket = aws_s3_bucket.lambda_code_bucket.id
  # s3_key    = "payment_processor_function.zip"

  # Using inline code for demonstration. In a real-world scenario,
  # you would package your code as a .zip file and upload to S3.
  source_code_hash = filebase64sha256("lambda/main.py")
  filename         = "lambda/main.zip" # Create this zip locally for deployment

  # Environment variables for sensitive configuration or feature flags
  environment {
    variables = {
      KMS_KEY_ID        = aws_kms_key.financial_data_key.id
      DB_CREDENTIALS_SECRET_NAME = aws_secretsmanager_secret.db_credentials.name
      TRANSACTIONS_TABLE_NAME    = aws_dynamodb_table.transactions.name
      PAYMENT_EVENT_QUEUE_URL    = aws_sqs_queue.payment_events.id
    }
  }

  tags = {
    Environment = "production"
    Service     = "PaymentProcessor"
  }
}

data "aws_region" "current" {}
data "aws_caller_identity" "current" {}

