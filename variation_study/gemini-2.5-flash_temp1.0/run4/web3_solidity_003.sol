        require(_newValue != someParameter, "New parameter value must be different");
        emit ParameterChanged(someParameter, _newValue);
        someParameter = _newValue;
    }

    function setTreasuryWallet(address _newWallet) public onlyOwner {
        require(_newWallet != address(0), "New treasury wallet cannot be zero address");
        require(_newWallet != treasuryWallet, "New treasury wallet must be different");
        emit TreasuryWalletChanged(treasuryWallet, _newWallet);
        treasuryWallet = _newWallet;
