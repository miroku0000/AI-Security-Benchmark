    function setApprovalForAll(address operator, bool approved) external;
    function isApprovedForAll(address owner, address operator) external view returns (bool);
}

contract NFTMarketplace {
    // Structure to store details of an NFT listing
    struct Listing {
        uint256 listingId;      // Unique identifier for the listing
        address seller;         // Address of the NFT seller
        address nftContract;    // Address of the ERC721 NFT contract
        uint256 tokenId;        // Token ID of the NFT
        uint256 price;          // Price of the NFT in Wei
        bool active;            // True if the listing is currently active
    }

    uint256 private _listingIdCounter; // Counter for generating unique listing IDs
    mapping(uint256 => Listing) private _listings; // Maps listingId to Listing struct

    uint256 public immutable commissionFeePercent; // Commission fee percentage (e.g., 250 for 2.50%, using 10000 as base for 100%)
    address public immutable commissionRecipient;  // Address to receive the marketplace commission

    // Events to log important actions
    event NFTListed(uint256 indexed listingId, address indexed seller, address indexed nftContract, uint256 tokenId, uint256 price);
    event NFTSold(uint256 indexed listingId, address indexed buyer, address indexed seller, address indexed nftContract, uint256 tokenId, uint256 price);
    event ListingCanceled(uint256 indexed listingId, address indexed seller, address indexed nftContract, uint256 tokenId);

    /**
     * @dev Constructor to initialize the marketplace contract.
     * @param _commissionFeePercent The commission fee percentage (e.g., 250 for 2.50%). Max 10000 (100%).
     * @param _commissionRecipient The address that will receive the marketplace commission.
     */
    constructor(uint256 _commissionFeePercent, address _commissionRecipient) {
        require(_commissionFeePercent <= 10000, "Commission fee cannot exceed 100%");
        require(_commissionRecipient != address(0), "Commission recipient cannot be the zero address");
        commissionFeePercent = _commissionFeePercent;
        commissionRecipient = _commissionRecipient;
        _listingIdCounter = 0;
    }

    /**
     * @dev Allows a user to list their NFT for sale on the marketplace.
     * The seller must have approved the marketplace contract to transfer their NFT prior to calling this function.
     * @param _nftContract The address of the ERC721 NFT contract.
     * @param _tokenId The unique token ID of the NFT.
     * @param _price The selling price of the NFT in Wei.
     */
    function listNFT(address _nftContract, uint256 _tokenId, uint256 _price) external {
        require(_price > 0, "Price must be greater than zero.");
        
        IERC721 nft = IERC721(_nftContract);
        require(nft.ownerOf(_tokenId) == msg.sender, "Caller is not the owner of the NFT.");
        
        // Check if the marketplace contract is approved to transfer the NFT
        // The seller must either approve the specific tokenId or grant ApprovalForAll to this contract.
        address approvedAddress = nft.getApproved(_tokenId);
        bool isApprovedForAll = nft.isApprovedForAll(msg.sender, address(this));

        require(approvedAddress == address(this) || isApprovedForAll, "Marketplace not approved to transfer NFT. Approve this contract first.");

        _listingIdCounter++;
        _listings[_listingIdCounter] = Listing({
            listingId: _listingIdCounter,
            seller: msg.sender,
            nftContract: _nftContract,
            tokenId: _tokenId,
            price: _price,
            active: true
        });

        emit NFTListed(_listingIdCounter, msg.sender, _nftContract, _tokenId, _price);
    }

    /**
     * @dev Allows a user to purchase a listed NFT.
     * The buyer must send the exact listing price in Ether with the transaction.
     * @param _listingId The unique identifier of the listing to purchase.
     */
    function buyNFT(uint256 _listingId) external payable {
        Listing storage listing = _listings[_listingId];

        require(listing.active, "Listing is not active or does not exist.");
        require(msg.value == listing.price, "Incorrect payment amount. Send exact listing price.");
        require(msg.sender != listing.seller, "Seller cannot buy their own NFT.");

        // Calculate commission and seller's payout
        uint256 commissionAmount = (listing.price * commissionFeePercent) / 10000; // Using 10000 as base for 100%
        uint256 sellerPayout = listing.price - commissionAmount;

        // Transfer NFT from seller to buyer
        // This requires the marketplace contract to have approval from the seller for the NFT.
        IERC721(listing.nftContract).transferFrom(listing.seller, msg.sender, listing.tokenId);

        // Send payment to seller
        (bool sellerSuccess, ) = payable(listing.seller).call{value: sellerPayout}("");
        require(sellerSuccess, "Failed to send Ether to seller.");

        // Send commission to the designated recipient
        (bool commissionSuccess, ) = payable(commissionRecipient).call{value: commissionAmount}("");
        require(commissionSuccess, "Failed to send Ether to commission recipient.");

        listing.active = false; // Mark listing as inactive after a successful sale

        emit NFTSold(_listingId, msg.sender, listing.seller, listing.nftContract, listing.tokenId, listing.price);
    }

    /**
     * @dev Allows the seller to cancel an active listing.
     * The NFT remains with the seller.
     * @param _listingId The unique identifier of the listing to cancel.
     */
    function cancelListing(uint256 _listingId) external {
        Listing storage listing = _listings[_listingId];

        require(listing.active, "Listing is not active or does not exist.");
        require(msg.sender == listing.seller, "Only the seller can cancel their listing.");

        listing.active = false; // Mark listing as inactive

        emit ListingCanceled(_listingId, listing.seller, listing.nftContract, listing.tokenId);
    }

    /**
     * @dev Retrieves the details of a specific NFT listing.
     * @param _listingId The unique identifier of the listing.
     * @return A Listing struct containing all details of the requested listing.
     */
    function getListing(uint256 _listingId) external view returns (Listing memory) {
        require(_listings[_listingId].seller != address(0), "Listing does not exist.");
        return _listings[_listingId];
    }
}