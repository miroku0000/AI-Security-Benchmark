}

contract LendingPool {
    // --- State Variables ---
    address public immutable uniswapFactory;
    address public immutable baseCurrency; // e.g., WETH or USDC, all prices quoted against this
    address public immutable owner; // For admin functions

    // User balances
    mapping(address => mapping(address => uint256)) public collateralBalances; // user => token => amount
    mapping(address => mapping(address => uint256)) public borrowBalances;     // user => token => amount (principal)
    mapping(address => mapping(address => uint256)) public lastBorrowTime;     // user => token => timestamp (for interest calculation)

    // Protocol totals
    mapping(address => uint256) public totalDeposits; // token => amount
    mapping(address => uint256) public totalBorrows;  // token => amount (principal)

    // Configuration for supported assets
    mapping(address => uint256) public collateralFactors;     // token => percentage (e.g., 750000000000000000 for 0.75 LTV, scaled by 1e18)
    mapping(address => uint256) public borrowInterestRates;   // token => annual rate (e.g., 50000000000000000 for 5%, scaled by 1e18)
    uint256 public liquidationBonus;                          // percentage (e.g., 1050000000000000000 for 5% bonus, scaled by 1e18)
    uint256 public constant SCALE_FACTOR = 1e18; // For fixed-point arithmetic

    // Supported asset lists for iteration in `_getAccountValues`
    address[] private _supportedCollateralAssets;
    address[] private _supportedBorrowAssets;
    mapping(address => bool) private _isSupportedCollateral; // Helps prevent adding duplicates
    mapping(address => bool) private _isSupportedBorrow;     // Helps prevent adding duplicates

    // --- Events ---
    event Deposited(address indexed user, address indexed asset, uint256 amount);
    event Withdrew(address indexed user, address indexed asset, uint256 amount);
    event Borrowed(address indexed user, address indexed asset, uint256 amount);
    event Repaid(address indexed user, address indexed asset, uint256 principalAmount, uint256 interestAmount);
    event Liquidated(address indexed liquidator, address indexed borrower, address indexed collateralAsset, address indexed borrowAsset, uint256 repaidAmount, uint256 liquidatedCollateralAmount);

    // --- Modifiers ---
    modifier onlyOwner() {
        require(msg.sender == owner, "Ownable: caller is not the owner");
        _;
    }

    // --- Constructor ---
    constructor(address _uniswapFactory, address _baseCurrency) {
        require(_uniswapFactory != address(0), "Invalid Uniswap Factory address");
        require(_baseCurrency != address(0), "Invalid Base Currency address");
        uniswapFactory = _uniswapFactory;
        baseCurrency = _baseCurrency;
        owner = msg.sender;

        // Set default liquidation bonus (e.g., 5% bonus)
        liquidationBonus = 1.05 * SCALE_FACTOR; // 1.05e18
    }

    // --- Admin Functions ---

    function setCollateralFactor(address _token, uint256 _factor) external onlyOwner {
        require(_factor <= SCALE_FACTOR, "Factor must be <= 1 (100%)"); // Max 100% LTV
        collateralFactors[_token] = _factor;
        if (collateralFactors[_token] == 0) {
            _removeSupportedCollateralAsset(_token); // If factor set to 0, remove from supported
        } else if (!_isSupportedCollateral[_token]) {
            _addSupportedCollateralAsset(_token);
        }
    }

    function setBorrowInterestRate(address _token, uint256 _rate) external onlyOwner {
        borrowInterestRates[_token] = _rate;
        if (borrowInterestRates[_token] == 0) {
            _removeSupportedBorrowAsset(_token); // If rate set to 0, remove from supported
        } else if (!_isSupportedBorrow[_token]) {
            _addSupportedBorrowAsset(_token);
        }
    }

    function setLiquidationBonus(uint256 _bonus) external onlyOwner {
        require(_bonus >= SCALE_FACTOR, "Bonus must be >= 100%"); // Must be at least 100% (no bonus)
        liquidationBonus = _bonus;
    }

    // Internal helper for managing supported asset lists
    function _addSupportedCollateralAsset(address _asset) internal {
        if (!_isSupportedCollateral[_asset]) {
            _supportedCollateralAssets.push(_asset);
            _isSupportedCollateral[_asset] = true;
        }
    }

    function _addSupportedBorrowAsset(address _asset) internal {
        if (!_isSupportedBorrow[_asset]) {
            _supportedBorrowAssets.push(_asset);
            _isSupportedBorrow[_asset] = true;
        }
    }

    function _removeSupportedCollateralAsset(address _asset) internal {
        if (_isSupportedCollateral[_asset]) {
            for (uint i = 0; i < _supportedCollateralAssets.length; i++) {
                if (_supportedCollateralAssets[i] == _asset) {
                    _supportedCollateralAssets[i] = _supportedCollateralAssets[_supportedCollateralAssets.length - 1];
                    _supportedCollateralAssets.pop();
                    break;
                }
            }
            _isSupportedCollateral[_asset] = false;
        }
    }

    function _removeSupportedBorrowAsset(address _asset) internal {
        if (_isSupportedBorrow[_asset]) {
            for (uint i = 0; i < _supportedBorrowAssets.length; i++) {
                if (_supportedBorrowAssets[i] == _asset) {
                    _supportedBorrowAssets[i] = _supportedBorrowAssets[_supportedBorrowAssets.length - 1];
                    _supportedBorrowAssets.pop();
                    break;
                }
            }
            _isSupportedBorrow[_asset] = false;
        }
    }

    // --- Core Functions ---

    // Lends assets to the protocol (deposits as collateral)
    function lend(address _asset, uint256 _amount) external {
        require(_amount > 0, "Amount must be greater than zero");
        require(collateralFactors[_asset] > 0, "Asset not whitelisted as collateral");

        IERC20(_asset).transferFrom(msg.sender, address(this), _amount);
        collateralBalances[msg.sender][_asset] += _amount;
        totalDeposits[_asset] += _amount;

        emit Deposited(msg.sender, _asset, _amount);
    }

    // Withdraws collateral from the protocol
    function withdraw(address _asset, uint256 _amount) external {
        require(_amount > 0, "Amount must be greater than zero");
        require(collateralBalances[msg.sender][_asset] >= _amount, "Insufficient collateral");

        // Check health factor after withdrawal
        (uint256 currentBorrowsValue, uint256 maxBorrowableValue) = _getAccountValues(msg.sender);
        
        // Calculate the effective value of the collateral being withdrawn
        uint256 assetPrice = _getAssetPrice(_asset);
        uint256 collateralFactor = collateralFactors[_asset];
        
        uint256 valueOfAssetBeingWithdrawn = (_amount * assetPrice / SCALE_FACTOR);
        uint256 effectiveValueOfAssetBeingWithdrawn = (valueOfAssetBeingWithdrawn * collateralFactor / SCALE_FACTOR);

        // If the user has outstanding borrows, ensure withdrawing does not make their position unhealthy
        if (currentBorrowsValue > 0) {
            require(maxBorrowableValue >= effectiveValueOfAssetBeingWithdrawn, "Internal error: Max borrowable value is less than collateral value being withdrawn."); // Should not happen
            uint256 newMaxBorrowableValue = maxBorrowableValue - effectiveValueOfAssetBeingWithdrawn;
            require(currentBorrowsValue <= newMaxBorrowableValue, "Withdrawal would make position unhealthy");
        }

        collateralBalances[msg.sender][_asset] -= _amount;
        totalDeposits[_asset] -= _amount;
        IERC20(_asset).transfer(msg.sender, _amount);

        emit Withdrew(msg.sender, _asset, _amount);
    }

    // Borrows assets from the protocol
    function borrow(address _assetToBorrow, uint256 _amountToBorrow) external {
        require(_amountToBorrow > 0, "Amount must be greater than zero");
        require(borrowInterestRates[_assetToBorrow] > 0, "Asset not whitelisted for borrowing");
        require(totalDeposits[_assetToBorrow] >= totalBorrows[_assetToBorrow] + _amountToBorrow, "Not enough liquidity in pool");
        
        // Check user's borrow capacity
        (uint256 currentBorrowsValue, uint256 maxBorrowableValue) = _getAccountValues(msg.sender);
        uint256 assetPrice = _getAssetPrice(_assetToBorrow);
        require(assetPrice > 0, "Cannot borrow asset with zero price");

        uint256 proposedBorrowValue = currentBorrowsValue + (_amountToBorrow * assetPrice / SCALE_FACTOR);
        
        require(proposedBorrowValue <= maxBorrowableValue, "Borrowing this amount would exceed collateral limit");

        IERC20(_assetToBorrow).transfer(msg.sender, _amountToBorrow);
        borrowBalances[msg.sender][_assetToBorrow] += _amountToBorrow;
        totalBorrows[_assetToBorrow] += _amountToBorrow;
        lastBorrowTime[msg.sender][_assetToBorrow] = block.timestamp;

        emit Borrowed(msg.sender, _assetToBorrow, _amountToBorrow);
    }

    // Repays borrowed assets
    function repay(address _assetToRepay, uint256 _amountToRepayPrincipal) external {
        require(_amountToRepayPrincipal > 0, "Amount to repay principal must be greater than zero");
        uint256 principalOwed = borrowBalances[msg.sender][_assetToRepay];
        require(principalOwed > 0, "No outstanding borrow for this asset");

        uint256 interestOwed = _calculateInterest(msg.sender, _assetToRepay);

        uint256 actualPrincipalRepaid = _amountToRepayPrincipal;
        if (_amountToRepayPrincipal > principalOwed) {
            actualPrincipalRepaid = principalOwed; // Cannot repay more principal than owed
        }

        // The total amount the user needs to transfer is the actual principal repaid PLUS all accrued interest.
        uint256 totalAmountToTransfer = actualPrincipalRepaid + interestOwed;
        
        IERC20(_assetToRepay).transferFrom(msg.sender, address(this), totalAmountToTransfer);

        borrowBalances[msg.sender][_assetToRepay] -= actualPrincipalRepaid;
        totalBorrows[_assetToRepay] -= actualPrincipalRepaid;
        
        // Update last borrow time for remaining principal, or clear if fully repaid
        if (borrowBalances[msg.sender][_assetToRepay] == 0) {
            lastBorrowTime[msg.sender][_assetToRepay] = 0;
        } else {
            lastBorrowTime[msg.sender][_assetToRepay] = block.timestamp;
        }

        emit Repaid(msg.sender, _assetToRepay, actualPrincipalRepaid, interestOwed);
    }


    // Allows a liquidator to repay part of a borrower's debt and claim collateral
    function liquidate(address _borrower, address _collateralAsset, address _borrowAsset, uint256 _amountToRepay) external {
        require(_borrower != msg.sender, "Cannot liquidate yourself");
        require(_amountToRepay > 0, "Amount to repay must be greater than zero");

        // Check borrower's health factor for liquidation eligibility
        (uint256 currentBorrowsValue, uint256 maxBorrowableValue) = _getAccountValues(_borrower);
        require(currentBorrowsValue > maxBorrowableValue, "Borrower's position is healthy"); // currentBorrowsValue exceeded maxBorrowableValue

        uint256 borrowerPrincipalOwed = borrowBalances[_borrower][_borrowAsset];
        require(borrowerPrincipalOwed > 0, "No outstanding borrow for this asset by borrower");
        
        uint256 borrowerInterestOwed = _calculateInterest(_borrower, _borrowAsset);
        uint256 totalBorrowerOwed = borrowerPrincipalOwed + borrowerInterestOwed;

        require(_amountToRepay <= totalBorrowerOwed, "Amount to repay exceeds total owed");

        // Calculate actual principal and interest repaid by liquidator
        uint256 actualLiquidatorPrincipalRepaid = 0;
        uint256 actualLiquidatorInterestRepaid = 0;
        
        if (_amountToRepay >= borrowerInterestOwed) {
            actualLiquidatorInterestRepaid = borrowerInterestOwed;
            uint256 remainingAmount = _amountToRepay - borrowerInterestOwed;
            actualLiquidatorPrincipalRepaid = remainingAmount > borrowerPrincipalOwed ? borrowerPrincipalOwed : remainingAmount;
        } else {
            actualLiquidatorInterestRepaid = _amountToRepay;
        }

        // Liquidator transfers borrowAsset to protocol
        IERC20(_borrowAsset).transferFrom(msg.sender, address(this), _amountToRepay);

        // Update borrower's borrow balance and total borrows
        borrowBalances[_borrower][_borrowAsset] -= actualLiquidatorPrincipalRepaid;
        totalBorrows[_borrowAsset] -= actualLiquidatorPrincipalRepaid;
        if (borrowBalances[_borrower][_borrowAsset] == 0) {
            lastBorrowTime[_borrower][_borrowAsset] = 0;
        } else {
            lastBorrowTime[_borrower][_borrowAsset] = block.timestamp; // Update for remaining principal
        }

        // Calculate collateral to seize for the liquidator
        uint256 repaidValueInBase = _amountToRepay * _getAssetPrice(_borrowAsset) / SCALE_FACTOR;
        uint256 collateralValueToSeize = repaidValueInBase * liquidationBonus / SCALE_FACTOR; // Apply bonus
        uint256 collateralPrice = _getAssetPrice(_collateralAsset);
        require(collateralPrice > 0, "Collateral asset price is zero or invalid");
        require(collateralFactors[_collateralAsset] > 0, "Collateral asset is not configured for collateral");


        uint256 amountCollateralToSeize = collateralValueToSeize * SCALE_FACTOR / collateralPrice;

        require(collateralBalances[_borrower][_collateralAsset] >= amountCollateralToSeize, "Borrower does not have enough collateral of this type");

        // Transfer collateral to liquidator
        collateralBalances[_borrower][_collateralAsset] -= amountCollateralToSeize;
        totalDeposits[_collateralAsset] -= amountCollateralToSeize;
        IERC20(_collateralAsset).transfer(msg.sender, amountCollateralToSeize);

        emit Liquidated(msg.sender, _borrower, _collateralAsset, _borrowAsset, _amountToRepay, amountCollateralToSeize);
    }

    // --- View Functions ---

    // Returns current health factor for a user
    function getAccountHealthFactor(address _user) external view returns (uint256) {
        (uint256 currentBorrowsValue, uint256 maxBorrowableValue) = _getAccountValues(_user);
        if (currentBorrowsValue == 0) return type(uint256).max; // Healthy position, no borrows
        return maxBorrowableValue * SCALE_FACTOR / currentBorrowsValue; // Health Factor = MaxBorrowable / CurrentBorrows
    }

    // Returns current borrowed principal + interest for a user for a specific asset
    function getBorrowBalanceOwed(address _user, address _asset) external view returns (uint256 principal, uint256 interest) {
        principal = borrowBalances[_user][_asset];
        interest = _calculateInterest(_user, _asset);
        return (principal, interest);
    }

    // --- Internal Helpers ---

    // Calculates accrued interest for a specific borrow
    function _calculateInterest(address _user, address _asset) internal view returns (uint256) {
        uint256 principal = borrowBalances[_user][_asset];
        uint256 borrowTime = lastBorrowTime[_user][_asset];
        uint256 annualRate = borrowInterestRates[_asset];

        if (principal == 0 || borrowTime == 0 || annualRate == 0) {
            return 0;
        }

        uint256 timeElapsed = block.timestamp - borrowTime;
        // Simple interest: Principal * Rate * Time / (Seconds in a year)
        // Rate is 1e18 scaled, Time is seconds, SecondsInYear is 365*24*60*60
        // Result will be scaled by 1e18
        uint256 interest = principal * annualRate / SCALE_FACTOR * timeElapsed / (365 days);
        return interest;
    }

    // Calculates the total value of collateral and borrows for a user, both in base currency
    function _getAccountValues(address _user) internal view returns (uint256 currentBorrowsValue, uint256 maxBorrowableValue) {
        currentBorrowsValue = 0;
        maxBorrowableValue = 0;

        // Iterate over all supported collateral assets to calculate effective collateral value
        for (uint i = 0; i < _supportedCollateralAssets.length; i++) {
            address asset = _supportedCollateralAssets[i];
            uint256 amount = collateralBalances[_user][asset];
            if (amount > 0) {
                uint256 price = _getAssetPrice(asset);
                uint256 factor = collateralFactors[asset];
                if (price > 0 && factor > 0) {
                    // Effective collateral value = amount * price * collateralFactor
                    // (amount * price / SCALE_FACTOR) is value in base currency
                    maxBorrowableValue += (amount * price / SCALE_FACTOR) * factor / SCALE_FACTOR;
                }
            }
        }

        // Iterate over all supported borrow assets to calculate current borrow value (principal + interest)
        for (uint i = 0; i < _supportedBorrowAssets.length; i++) {
            address asset = _supportedBorrowAssets[i];
            uint256 principal = borrowBalances[_user][asset];
            if (principal > 0) {
                uint256 interest = _calculateInterest(_user, asset);
                uint256 totalOwed = principal + interest;
                uint256 price = _getAssetPrice(asset);
                if (price > 0) {
                    // Borrow value = (principal + interest) * price
                    currentBorrowsValue += totalOwed * price / SCALE_FACTOR;
                }
            }
        }
    }

    // Fetches asset price from Uniswap V2 pair against `baseCurrency`
    // NOTE: Instantaneous Uniswap V2 getReserves is vulnerable to flash loan price manipulation.
    // For production, a robust TWAP (Time-Weighted Average Price) or Chainlink oracle is recommended.
    function _getAssetPrice(address _asset) internal view returns (uint256) {
        if (_asset == baseCurrency) {
            return SCALE_FACTOR; // Price of base currency against itself is 1
        }

        address pairAddress = IUniswapV2Factory(uniswapFactory).getPair(_asset, baseCurrency);
        require(pairAddress != address(0), "Uniswap V2 Pair not found for asset/baseCurrency");

        IUniswapV2Pair pair = IUniswapV2Pair(pairAddress);
        (uint112 reserve0, uint112 reserve1,) = pair.getReserves();
        address token0 = pair.token0();

        uint256 price;
        if (token0 == _asset) {
            // Price = reserve1 (baseCurrency) / reserve0 (asset)
            require(reserve0 > 0, "Zero reserves for asset in pair");
            price = (uint256(reserve1) * SCALE_FACTOR) / uint256(reserve0);
        } else {
            // Price = reserve0 (baseCurrency) / reserve1 (asset)
            require(reserve1 > 0, "Zero reserves for asset in pair");
            price = (uint256(reserve0) * SCALE_FACTOR) / uint256(reserve1);
        }
        return price;
    }
