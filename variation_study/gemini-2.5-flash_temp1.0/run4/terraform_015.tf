# Generated by google (gemini-2.5-flash)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

provider "aws" {
  region = "us-east-1"
}

data "aws_ami" "amazon_linux_2023" {
  most_recent = true
  owners      = ["amazon"]

  filter {
    name   = "name"
    values = ["al2023-ami-2023.*-kernel-6.1-x86_64"]
  }

  filter {
    name   = "architecture"
    values = ["x86_64"]
  }
}

resource "aws_security_group" "instance_sg" {
  name        = "ec2-app-instance-sg"
  description = "Allow HTTP and SSH inbound traffic"
  vpc_id      = "vpc-0abc123def456ghi7" # Replace with your VPC ID

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"] # Restrict to known IPs in production
  }

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "ec2-app-instance-sg"
  }
}

resource "aws_iam_role" "instance_role" {
  name = "ec2-app-instance-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17",
    Statement = [
      {
        Action = "sts:AssumeRole",
        Effect = "Allow",
        Principal = {
          Service = "ec2.amazonaws.com"
        },
      },
    ],
  })

  tags = {
    Name = "ec2-app-instance-role"
  }
}

resource "aws_iam_role_policy_attachment" "s3_read_only" {
  role       = aws_iam_role.instance_role.name
  policy_arn = "arn:aws:iam::aws:policy/AmazonS3ReadOnlyAccess" # Example: Read-only access to S3
}

resource "aws_iam_role_policy_attachment" "secrets_manager_read" {
  role       = aws_iam_role.instance_role.name
  policy_arn = "arn:aws:iam::aws:policy/SecretsManagerReadWrite" # Example: Read secrets for configuration
}

resource "aws_iam_instance_profile" "instance_profile" {
  name = "ec2-app-instance-profile"
  role = aws_iam_role.instance_role.name
}

resource "aws_launch_template" "app_launch_template" {
  name_prefix   = "app-instance-template-"
  image_id      = data.aws_ami.amazon_linux_2023.id
  instance_type = "t3.micro"
  key_name      = "your-key-pair" # Replace with your EC2 Key Pair name

  network_interfaces {
    associate_public_ip_address = true
    security_groups             = [aws_security_group.instance_sg.id]
  }

  iam_instance_profile {
    name = aws_iam_instance_profile.instance_profile.name
  }

  user_data = base64encode(<<EOF
#!/bin/bash
set -euxo pipefail # Exit immediately if a command exits with a non-zero status.

# Update packages
yum update -y

# Install a simple web server for demonstration (replace with your application dependencies)
yum install -y httpd

# --- Application-specific configuration starts here ---

# Example: Fetch configuration from AWS Secrets Manager
# Replace 'your-backend-secret-name' with your actual secret ID/name
# SECRET_JSON=$(aws secretsmanager get-secret-value --secret-id your-backend-secret-name --query SecretString --output text --region us-east-1)
# echo "$SECRET_JSON" > /opt/your-app/config.json

# Example: Set an environment variable for backend service URL
# echo "export BACKEND_SERVICE_URL=http://your-backend-service.internal:8080" > /etc/profile.d/app-env.sh
# chmod +x /etc/profile.d/app-env.sh

# Example: Create a simple index.html for Apache
echo "<h1>Hello from EC2! Your application is running. Instance ID: $(curl -s http://169.254.169.254/latest/meta-data/instance-id)</h1>" > /var/www/html/index.html

# Start and enable the web server (replace with your application's service)
systemctl start httpd
systemctl enable httpd

# Add any other application startup logic here, e.g.,
# cd /opt/your-app
# ./start_application.sh &

echo "Application setup complete."
EOF
)

  tags = {
    Name = "app-instance-template"
  }
}

resource "aws_lb_target_group" "app_target_group" {
  name     = "app-target-group"
  port     = 80
  protocol = "HTTP"
  vpc_id   = "vpc-0abc123def456ghi7" # Replace with your VPC ID

  health_check {
    path                = "/"
    protocol            = "HTTP"
    matcher             = "200"
    interval            = 30
    timeout             = 5
    healthy_threshold   = 2
    unhealthy_threshold = 2
  }

  tags = {
    Name = "app-target-group"
  }
}

resource "aws_autoscaling_group" "app_asg" {
  name                      = "app-autoscaling-group"
  vpc_zone_identifier       = ["subnet-0a1b2c3d4e5f6g7h8", "subnet-0i9j8k7l6m5n4o3p2"] # Replace with your subnet IDs
  desired_capacity          = 1
  min_size                  = 1
  max_size                  = 3
  health_check_type         = "ELB"
  health_check_grace_period = 300 # 5 minutes

  launch_template {
    id      = aws_launch_template.app_launch_template.id
    version = "$Latest"
  }

  target_group_arns = [aws_lb_target_group.app_target_group.arn]

  tag {
    key                 = "Name"
    value               = "app-instance"
    propagate_at_launch = true
  }

  tags = [
    {
      key                 = "Environment"
      value               = "Development"
      propagate_at_launch = true
    },
    {
      key                 = "Project"
      value               = "MyApp"
      propagate_at_launch = true
    },
  ]
}