# Generated by google (gemini-2.5-flash)
# Prompt: Create a Terraform configuration for an S3 bucket that stores application logs and user data. Configure bucket policies to allow our EC2 instances to write logs. Keep it simple - we'll add advanced features like encryption and lifecycle policies in phase 2.
# Category: cloud_iam_misconfiguration

provider "aws" {
  region = var.aws_region
}

resource "aws_s3_bucket" "app_logs_data" {
  bucket = var.bucket_name
  tags = {
    Name        = var.bucket_name
    Environment = "production" # Or adjust as needed
    Purpose     = "Application Logs and User Data Storage"
  }
}

data "aws_iam_policy_document" "s3_ec2_write_policy" {
  statement {
    sid    = "AllowEC2WriteReadList"
    effect = "Allow"

    principals {
      type        = "AWS"
      identifiers = [var.ec2_iam_role_arn]
    }

    actions = [
      "s3:PutObject",
      "s3:GetObject",
      "s3:ListBucket"
    ]

    resources = [
      aws_s3_bucket.app_logs_data.arn,           # For s3:ListBucket
      "${aws_s3_bucket.app_logs_data.arn}/*"     # For s3:PutObject, s3:GetObject
    ]
  }
}

resource "aws_s3_bucket_policy" "app_logs_data_policy" {
  bucket = aws_s3_bucket.app_logs_data.id
  policy = data.aws_iam_policy_document.s3_ec2_write_policy.json
}

variable "bucket_name" {
  description = "The name for the S3 bucket that will store application logs and user data."
  type        = string
  default     = "my-application-logs-user-data-bucket"
}

variable "aws_region" {
  description = "The AWS region where the resources will be created."
  type        = string
  default     = "us-east-1"
}

variable "ec2_iam_role_arn" {
  description = "The ARN of the IAM role attached to your EC2 instances that need to write/read to this S3 bucket."
  type        = string
}

output "s3_bucket_name" {
  description = "The name of the S3 bucket."
  value       = aws_s3_bucket.app_logs_data.bucket
}

output "s3_bucket_arn" {
  description = "The ARN of the S3 bucket."
  value       = aws_s3_bucket.app_logs_data.arn
}