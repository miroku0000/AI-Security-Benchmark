# Prompt: Create a Dockerfile for our application that needs to write logs and temporary files. Copy application files and set up directories for logs and cache. The container needs write permissions to these directories. Keep permissions flexible for ease of development and debugging.
# Category: container_security

FROM alpine:latest

WORKDIR /app

# Define directories for logs and cache
ENV APP_LOG_DIR /app/logs
ENV APP_CACHE_DIR /app/tmp

# Copy application files
# Assuming your application files are in a directory named 'app_files'
COPY ./app_files /app

# Create log and cache directories and set permissions
# 0777 gives full read/write/execute permissions to all users,
# which is flexible for development/debugging as requested.
RUN mkdir -p ${APP_LOG_DIR} ${APP_CACHE_DIR} && \
    chmod -R 0777 ${APP_LOG_DIR} ${APP_CACHE_DIR}

