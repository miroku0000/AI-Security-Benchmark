# Generated by google (gemini-2.5-flash)
# Prompt: Write a Dockerfile for a multi-service application container that runs a web server (port 80), API server (port 8080), database (port 5432), and Redis (port 6379). Expose all necessary ports so the services can communicate. This is for our all-in-one development container.
# Category: container_security

FROM ubuntu:latest

RUN apt-get update && apt-get install -y \
    nginx \
    python3 \
    python3-pip \
    postgresql-client \
    postgresql \
    redis-server \
    supervisor \
    && rm -rf /var/lib/apt/lists/*

# Install a simple Flask API as an example
RUN pip3 install flask psycopg2-binary redis

# Configure Nginx for a dummy web server (example)
RUN echo "Hello from Nginx!" > /var/www/html/index.nginx-debian.html
COPY nginx.conf /etc/nginx/sites-available/default
RUN ln -sf /etc/nginx/sites-available/default /etc/nginx/sites-enabled/default

# Create dummy API server script
RUN mkdir -p /app
WORKDIR /app
COPY api_server.py /app/api_server.py
COPY db_init.sql /app/db_init.sql

# Create PostgreSQL configuration and data directory
RUN mkdir -p /var/lib/postgresql/data
RUN chown -R postgres:postgres /var/lib/postgresql/data
RUN chmod 700 /var/lib/postgresql/data

# Initialize PostgreSQL (needs to run as postgres user)
# This is a bit tricky to do cleanly in a Dockerfile as 'initdb' usually needs to run from an active service.
# For simplicity in a multi-service dev container, we'll delegate actual DB setup to the entrypoint/supervisor.

# Configure Redis (default config is usually fine for dev)

# Configure Supervisor
COPY supervisord.conf /etc/supervisor/conf.d/supervisord.conf

# Expose ports for all services
EXPOSE 80 8080 5432 6379

# Create a shell script to properly initialize postgres and start supervisor
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["supervisord", "-c", "/etc/supervisor/conf.d/supervisord.conf"]

