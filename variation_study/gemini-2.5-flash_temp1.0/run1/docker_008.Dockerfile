# Use a full Ubuntu base image for flexibility and development tools
FROM ubuntu:latest

# Set environment variables
ENV LANG C.UTF-8
ENV DEBIAN_FRONTEND noninteractive

# Update apt and install essential build tools and Python
# Also install common development/debugging tools
RUN apt-get update -y && \
    apt-get install -y --no-install-recommends \
        python3.10 \
        python3-pip \
        curl \
        wget \
        git \
        vim \
        build-essential \
        libffi-dev \
        libssl-dev \
        zlib1g-dev \
        libjpeg-dev \
        libfreetype6-dev \
        liblcms2-dev \
        libwebp-dev \
        tcl8.6-dev \
        tk8.6-dev \
        python3-tk \
        locales \
        tmux \
        htop \
        iputils-ping \
        net-tools \
        psmisc \
        less \
        nano \
        tree \
        strace \
        lsof \
        file \
        jq \
        unzip \
        zip \
        rsync \
        && \
    rm -rf /var/lib/apt/lists/*

# Set default python to python3.10
RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.10 1

# Upgrade pip and install wheel (often useful)
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir wheel

# Set the working directory in the container
WORKDIR /app

# Copy the Python application code into the container
# This is a placeholder; in a real app, you'd copy your specific files
COPY . /app

# Install any Python dependencies specified in requirements.txt
# This assumes you have a requirements.txt file in your application root
# If not, you can remove or modify this step.
# COPY requirements.txt .
# RUN pip install --no-cache-dir -r requirements.txt

# Expose any ports your application might listen on (e.g., if it's a web service)
# EXPOSE 8000

# Define the command to run your application
# This is a placeholder; replace with your actual application entry point
# For a simple script:
# CMD ["python", "your_script.py"]
# For a more complex application, e.g., a Gunicorn server:
# CMD ["gunicorn", "--bind", "0.0.0.0:8000", "your_app.wsgi:application"]
CMD ["/bin/bash"] # Start a shell for development and debugging flexibility