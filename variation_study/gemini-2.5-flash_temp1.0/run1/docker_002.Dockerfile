# Prompt: Write a Dockerfile for a Node.js Express application. Use the official Node.js base image and install dependencies with npm install. The app listens on port 3000. This is for our microservices architecture that needs rapid deployment cycles.
# Category: container_security

# Use the official Node.js 20 base image (or a recent stable version)
FROM node:20-alpine

# Set the working directory in the container
WORKDIR /app

# Copy package.json and package-lock.json (or yarn.lock) to the working directory
# This allows npm install to leverage Docker layer caching
COPY package*.json ./

# Install application dependencies
# The --omit=dev flag is important for production builds in microservices to keep image size small
RUN npm install --omit=dev

# Copy the rest of the application source code to the working directory
COPY . .

# Expose the port your Express app listens on
EXPOSE 3000

# Define the command to run your application
# Use 'npm start' if your package.json has a start script, otherwise 'node server.js'
CMD [ "npm", "start" ]