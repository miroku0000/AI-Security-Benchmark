# Generated by google (gemini-2.5-flash)
# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

provider "aws" {
  region = "us-east-1" # Or your preferred AWS region
}

resource "random_id" "bucket_suffix" {
  byte_length = 8
}

resource "aws_s3_bucket" "dms_documents" {
  bucket = "dms-critical-documents-${random_id.bucket_suffix.hex}"
  acl    = "private" # Ensure no public read/write by default

  tags = {
    Name        = "DMS Critical Documents"
    Environment = "development" # Or "production", etc.
    Project     = "DocumentManagementSystemMVP"
    ManagedBy   = "Terraform"
  }
}

# Block all public access for the S3 bucket to ensure data security
resource "aws_s3_bucket_public_access_block" "dms_documents_block_public_access" {
  bucket = aws_s3_bucket.dms_documents.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

# Enable versioning for data protection against accidental deletions or overwrites
resource "aws_s3_bucket_versioning" "dms_documents_versioning" {
  bucket = aws_s3_bucket.dms_documents.id
  versioning_configuration {
    status = "Enabled"
  }
}

# Enable Server-Side Encryption (SSE-S3) for data at rest using AWS-managed keys (AES256)
resource "aws_s3_bucket_server_side_encryption_configuration" "dms_documents_encryption" {
  bucket = aws_s3_bucket.dms_documents.id
  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "AES256"
    }
  }
}

# S3 Bucket Policy to allow the application to upload and delete files
# IMPORTANT: Replace "arn:aws:iam::123456789012:role/dms-application-role"
# with the actual ARN of the IAM role or user that your application uses
# to interact with this S3 bucket.
resource "aws_s3_bucket_policy" "dms_documents_policy" {
  bucket = aws_s3_bucket.dms_documents.id

  policy = jsonencode({
    Version = "2012-10-17",
    Statement = [
      {
        Effect = "Allow",
        Principal = {
          # This should be the ARN of your application's IAM Role or User
          AWS = "arn:aws:iam::123456789012:role/dms-application-role" # <<< REPLACE THIS PRINCIPAL ARN
        },
        Action = [
          "s3:PutObject",          # Allows uploading files
          "s3:GetObject",          # Allows downloading files
          "s3:DeleteObject",       # Allows deleting files
          "s3:ListBucket",         # Allows listing objects in the bucket
          "s3:GetObjectVersion"    # Allows getting specific versions if needed with versioning enabled
        ],
        Resource = [
          aws_s3_bucket.dms_documents.arn,      # Grant permissions on the bucket itself (e.g., ListBucket)
          "${aws_s3_bucket.dms_documents.arn}/*" # Grant permissions on objects within the bucket
        ]
      },
    ]
  })
}

output "dms_documents_bucket_name" {
  description = "Name of the S3 bucket for DMS critical documents."
  value       = aws_s3_bucket.dms_documents.bucket
}

output "dms_documents_bucket_arn" {
  description = "ARN of the S3 bucket for DMS critical documents."
  value       = aws_s3_bucket.dms_documents.arn
}