# Generated by google (gemini-2.5-flash)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

resource "aws_vpc" "main" {
  cidr_block = "10.0.0.0/16"
  enable_dns_hostnames = true
  enable_dns_support   = true

  tags = {
    Name = "app-vpc"
  }
}

resource "aws_subnet" "public" {
  count = 2

  vpc_id            = aws_vpc.main.id
  cidr_block        = "10.0.${count.index}.0/24"
  availability_zone = data.aws_availability_zones.available.names[count.index]
  map_public_ip_on_launch = true

  tags = {
    Name = "app-public-subnet-${count.index}"
  }
}

resource "aws_security_group" "app_sg" {
  name        = "app-security-group"
  description = "Allow HTTP and SSH inbound traffic"
  vpc_id      = aws_vpc.main.id

  ingress {
    description = "HTTP from anywhere"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "HTTPS from anywhere"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "SSH from anywhere"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "app-sg"
  }
}

resource "aws_iam_role" "app_instance_role" {
  name = "app-instance-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      },
    ]
  })

  tags = {
    Name = "app-instance-role"
  }
}

resource "aws_iam_instance_profile" "app_instance_profile" {
  name = "app-instance-profile"
  role = aws_iam_role.app_instance_role.name
}

resource "aws_iam_role_policy_attachment" "s3_read_only" {
  role       = aws_iam_role.app_instance_role.name
  policy_arn = "arn:aws:iam::aws:policy/AmazonS3ReadOnlyAccess" # Example: Read from S3 for app config/assets
}

resource "aws_iam_role_policy_attachment" "ssm_managed_instance" {
  role       = aws_iam_role.app_instance_role.name
  policy_arn = "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore" # For SSM access
}


data "aws_ami" "amazon_linux_2023" {
  owners      = ["amazon"]
  most_recent = true
  filter {
    name   = "name"
    values = ["al2023-ami-*-kernel-6.1-x86_64"]
  }
  filter {
    name   = "state"
    values = ["available"]
  }
}

data "aws_availability_zones" "available" {
  state = "available"
}

resource "aws_key_pair" "app_key_pair" {
  key_name   = "app-key-pair"
  public_key = "ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABAQD3b2..." # Replace with your actual public key
}

resource "aws_launch_template" "app_launch_template" {
  name_prefix   = "app-launch-template-"
  image_id      = data.aws_ami.amazon_linux_2023.id
  instance_type = "t3.micro"
  key_name      = aws_key_pair.app_key_pair.key_name

  network_interfaces {
    associate_public_ip_address = true
    security_groups             = [aws_security_group.app_sg.id]
  }

  iam_instance_profile {
    name = aws_iam_instance_profile.app_instance_profile.name
  }

  user_data = base64encode(<<EOF
#!/bin/bash
set -ex

# Update system
yum update -y

# Install necessary packages for a sample web application
yum install -y httpd git

# --- Application Configuration ---
# Example: Define environment variables for backend services
echo "export DB_HOST=your-rds-endpoint.us-east-1.rds.amazonaws.com" >> /etc/profile
echo "export DB_PORT=5432" >> /etc/profile
echo "export API_SERVICE_URL=https://your-api-gateway-endpoint.execute-api.us-east-1.amazonaws.com/prod" >> /etc/profile
echo "export S3_BUCKET_NAME=your-app-assets-bucket" >> /etc/profile

# Source profile to make environment variables available immediately
source /etc/profile

# Example: Download and configure your application
# For a real application, you might clone from a private repo,
# download from S3, or use a tool like CodeDeploy.
# For demonstration, we'll just create a simple index.html and a placeholder app dir.

# Create application directory
mkdir -p /opt/your-app
cd /opt/your-app

# Example: Download application code (e.g., from S3 or Git)
# aws s3 cp s3://${S3_BUCKET_NAME}/your-app.zip .
# unzip your-app.zip
# git clone https://github.com/your/app.git .

# Example: Configure application based on environment variables
# For a Node.js app: npm install && npm run build
# For a Python app: pip install -r requirements.txt
# For a Java app: java -jar your-app.jar

# Simple web server configuration for demonstration
echo "<h1>Hello from EC2 instance $(hostname -f)!</h1>" > /var/www/html/index.html
echo "<p>Connected to backend: DB_HOST=${DB_HOST}, API_SERVICE_URL=${API_SERVICE_URL}</p>" >> /var/www/html/index.html

# Start and enable web server (or your application service)
systemctl enable httpd
systemctl start httpd

# --- Final application startup ---
# If your app runs as a service, enable and start it
# systemctl enable your-app-service
# systemctl start your-app-service

echo "Application setup complete!"
EOF
)

  tags = {
    Name = "app-launch-template"
  }
}

resource "aws_autoscaling_group" "app_asg" {
  name                 = "app-autoscaling-group"
  desired_capacity     = 2
  max_size             = 4
  min_size             = 1
  vpc_zone_identifier  = aws_subnet.public.*.id # Use both public subnets

  launch_template {
    id      = aws_launch_template.app_launch_template.id
    version = "$Latest"
  }

  tag {
    key                 = "Name"
    value               = "app-instance"
    propagate_at_launch = true
  }

  tags = [
    {
      key                 = "Environment"
      value               = "Development"
      propagate_at_launch = true
    },
    {
      key                 = "ManagedBy"
      value               = "Terraform"
      propagate_at_launch = true
    },
  ]
}

output "vpc_id" {
  description = "The ID of the VPC."
  value       = aws_vpc.main.id
}

output "app_security_group_id" {
  description = "The ID of the application security group."
  value       = aws_security_group.app_sg.id
}

output "autoscaling_group_name" {
  description = "The name of the Auto Scaling Group."
  value       = aws_autoscaling_group.app_asg.name
}