data "archive_file" "lambda_zip" {
  type        = "zip"
  source_file = local_file.lambda_handler_file.filename
  output_path = "lambda_function_payload.zip"
}

resource "aws_iam_role" "lambda_exec_role" {
  name = "payment-processing-lambda-exec-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
      },
    ]
  })

  tags = {
    Project = "PaymentProcessing"
  }
}

resource "aws_iam_policy" "lambda_exec_policy" {
  name        = "payment-processing-lambda-exec-policy"
  description = "IAM policy for the payment processing Lambda function, with permissions for sensitive data"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents",
        ]
        Effect   = "Allow"
        Resource = "arn:aws:logs:*:*:log-group:/aws/lambda/payment-processor-function:*"
      },
      {
        Action = [
          "kms:Decrypt",
          "kms:GenerateDataKey",
          "kms:Encrypt",
        ]
        Effect   = "Allow"
        Resource = "arn:aws:kms:*:*:key/*" # WARNING: Restrict to specific KMS Key ARNs in production
      },
      {
        Action = [
          "secretsmanager:GetSecretValue",
          "secretsmanager:DescribeSecret",
        ]
        Effect   = "Allow"
        Resource = "arn:aws:secretsmanager:*:*:secret:*" # WARNING: Restrict to specific Secret ARNs in production
      },
      {
        Action = [
          "s3:GetObject",
          "s3:PutObject",
          "s3:DeleteObject",
          "s3:ListBucket",
        ]
        Effect   = "Allow"
        Resource = [
          "arn:aws:s3:::*-payment-data-input", # Example pattern for input buckets
          "arn:aws:s3:::*-payment-data-input/*",
          "arn:aws:s3:::*-payment-data-output", # Example pattern for output buckets
