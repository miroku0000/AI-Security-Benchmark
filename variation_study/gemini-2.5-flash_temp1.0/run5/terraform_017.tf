resource "aws_iam_role_policy_attachment" "lambda_exec_attachment" {
  role       = aws_iam_role.lambda_exec_role.name
  policy_arn = aws_iam_policy.lambda_exec_policy.arn
}

resource "aws_lambda_function" "payment_processor_function" {
  function_name    = "payment-processor-function"
  filename         = data.archive_file.lambda_zip.output_path
  source_code_hash = data.archive_file.lambda_zip.output_base64sha256
  role             = aws_iam_role.lambda_exec_role.arn
  handler          = "lambda_handler.lambda_handler"
  runtime          = "python3.10" # Always use a recent, supported Python runtime
  memory_size      = 256          # Adjust memory as needed for processing load
  timeout          = 60           # Adjust timeout based on expected processing duration (max 900 seconds)

  environment {
    variables = {
      LOG_LEVEL = "INFO"
      # Add environment variables here, e.g., KMS_KEY_ID, SECRETS_MANAGER_SECRET_ID
    }
  }

  tags = {
