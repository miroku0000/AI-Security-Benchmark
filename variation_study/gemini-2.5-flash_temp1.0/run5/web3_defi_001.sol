    function _getPrices(address _collateralToken, address _borrowToken, address _dexPool) internal view returns (uint256 price, bool isToken0Collateral) {
        IDexPair pair = IDexPair(_dexPool);
        (uint112 reserve0, uint112 reserve1,) = pair.getReserves();
        address token0 = pair.token0();
        address token1 = pair.token1();

