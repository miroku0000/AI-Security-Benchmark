    // Calculates the maximum amount a user can borrow for a given market
    function _calculateMaxBorrow(address _user, address _collateralToken, address _borrowToken) internal view returns (uint256 maxBorrowAmount) {
        bytes32 marketId = getMarketId(_collateralToken, _borrowToken);
        MarketConfig storage config = marketConfigs[marketId];

        uint256 depositedCollateral = userDeposits[_user][_collateralToken];
