    // Below 1.0 means it's unhealthy. A safe loan has a factor > 1.0.
    function getHealthFactor(address _user, address _collateralToken, address _borrowToken) public view marketExists(_collateralToken, _borrowToken) returns (uint256) {
        bytes32 marketId = getMarketId(_collateralToken, _borrowToken);
        MarketConfig storage config = marketConfigs[marketId];

        uint256 currentBorrowedAmount = _getCurrentBorrowBalance(
            _user,
            _borrowToken,
            userBorrows[_user][_borrowToken],
            lastBorrowInterestAccrual[_user][_borrowToken],
            config.interestRatePerSecond
        );

        if (currentBorrowedAmount == 0) {
            return type(uint256).max; // No borrow, infinite health
        }

        uint256 depositedCollateral = userDeposits[_user][_collateralToken];
        if (depositedCollateral == 0) {
            return 0; // No collateral, but borrowed -> 0 health
        }

        (uint256 borrowTokenPriceInCollateral, ) = _getPrices(_collateralToken, _borrowToken, config.dexPool);
        if (borrowTokenPriceInCollateral == 0) {
            return 0; // Price failure, consider unhealthy
