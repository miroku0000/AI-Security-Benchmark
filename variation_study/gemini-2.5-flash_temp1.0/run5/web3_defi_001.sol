        IERC20(config.borrowToken).transferFrom(_msgSender(), address(this), currentBorrowedAmount);

        // Calculate collateral to seize
        (uint256 borrowTokenPriceInCollateral, ) = _getPrices(_collateralToken, _borrowToken, config.dexPool);
        require(borrowTokenPriceInCollateral > 0, "LendingProtocol: Collateral price is zero, cannot liquidate");

