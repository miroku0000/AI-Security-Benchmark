        adjustedCollateralValueInBorrowToken = (adjustedCollateralValueInBorrowToken * config.collateralFactor) / PERCENT_FACTOR; // Apply collateral factor (LTV)

        // Health Factor = (Adjusted Collateral Value) / (Borrowed Amount)
        // Scaled by ONE_18 for precision
        return (adjustedCollateralValueInBorrowToken * ONE_18) / currentBorrowedAmount;
    }

