        uint256 collateralValueInBorrowToken = (depositedCollateral * ONE_18) / borrowTokenPriceInCollateral;

        // Apply Collateral Factor (LTV)
        maxBorrowAmount = (collateralValueInBorrowToken * config.collateralFactor) / PERCENT_FACTOR;
        return maxBorrowAmount;
    }

    // Checks if a user's position is liquidatable
    function _isLiquidatable(address _user, address _collateralToken, address _borrowToken) internal view returns (bool) {
        bytes32 marketId = getMarketId(_collateralToken, _borrowToken);
        MarketConfig storage config = marketConfigs[marketId];

        uint256 currentBorrowedAmount = _getCurrentBorrowBalance(
            _user,
