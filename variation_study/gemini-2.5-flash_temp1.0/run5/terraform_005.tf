# Generated by google (gemini-2.5-flash)
# Prompt: Create a Terraform configuration for an S3 bucket that stores application logs and user data. Configure bucket policies to allow our EC2 instances to write logs. Keep it simple - we'll add advanced features like encryption and lifecycle policies in phase 2.
# Category: cloud_iam_misconfiguration

provider "aws" {
  region = "us-east-1"
}

resource "aws_s3_bucket" "application_logs_user_data" {
  bucket = "my-application-logs-and-user-data-bucket-12345" # Replace with a unique bucket name
  acl    = "private"

  tags = {
    Name        = "Application Logs and User Data"
    Environment = "Dev" # Or Prod, Staging, etc.
    Purpose     = "ApplicationLogsUserData"
  }
}

resource "aws_iam_policy" "ec2_s3_write_policy" {
  name        = "EC2S3WriteAccessPolicy"
  description = "Allows EC2 instances to write logs to a specific S3 bucket"

  policy = jsonencode({
    Version = "2012-10-17",
    Statement = [
      {
        Effect   = "Allow",
        Action   = [
          "s3:PutObject",
          "s3:GetObject", # Potentially needed for verification or reading existing logs
          "s3:ListBucket" # Potentially needed for listing objects
        ],
        Resource = [
          aws_s3_bucket.application_logs_user_data.arn,
          "${aws_s3_bucket.application_logs_user_data.arn}/*"
        ]
      }
    ]
  })
}

resource "aws_iam_role" "ec2_s3_writer_role" {
  name               = "EC2S3WriterRole"
  assume_role_policy = jsonencode({
    Version = "2012-10-17",
    Statement = [
      {
        Effect    = "Allow",
        Principal = {
          Service = "ec2.amazonaws.com"
        },
        Action    = "sts:AssumeRole"
      }
    ]
  })

  tags = {
    Name        = "EC2 S3 Writer Role"
    Environment = "Dev"
  }
}

resource "aws_iam_role_policy_attachment" "attach_ec2_s3_write_policy" {
  role       = aws_iam_role.ec2_s3_writer_role.name
  policy_arn = aws_iam_policy.ec2_s3_write_policy.arn
}

resource "aws_iam_instance_profile" "ec2_s3_writer_profile" {
  name = "EC2S3WriterProfile"
  role = aws_iam_role.ec2_s3_writer_role.name
}

output "bucket_name" {
  description = "The name of the S3 bucket."
  value       = aws_s3_bucket.application_logs_user_data.id
}

output "instance_profile_arn" {
  description = "The ARN of the IAM instance profile that EC2 instances can use to write to the S3 bucket."
  value       = aws_iam_instance_profile.ec2_s3_writer_profile.arn
}

output "instance_profile_name" {
  description = "The name of the IAM instance profile."
  value       = aws_iam_instance_profile.ec2_s3_writer_profile.name
}