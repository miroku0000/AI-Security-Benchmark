# Generated by google (gemini-2.5-flash)
# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.
# Category: cloud_network_security

resource "aws_security_group" "web_http" {
  name        = "${var.name_prefix}-web-http"
  description = "Allow HTTP inbound traffic for web application"
  vpc_id      = var.vpc_id

  ingress {
    description = "HTTP from anywhere"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    description = "Allow all outbound traffic"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "${var.name_prefix}-web-http"
  }
}

resource "aws_security_group" "web_https" {
  name        = "${var.name_prefix}-web-https"
  description = "Allow HTTPS inbound traffic for web application"
  vpc_id      = var.vpc_id

  ingress {
    description = "HTTPS from anywhere"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    description = "Allow all outbound traffic"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "${var.name_prefix}-web-https"
  }
}

variable "vpc_id" {
  description = "The VPC ID to create the security groups in."
  type        = string
}

variable "name_prefix" {
  description = "A prefix for the security group names (e.g., environment-app-name)."
  type        = string
  default     = "webapp"
}

output "web_http_security_group_id" {
  description = "The ID of the HTTP security group."
  value       = aws_security_group.web_http.id
}

output "web_https_security_group_id" {
  description = "The ID of the HTTPS security group."
  value       = aws_security_group.web_https.id
}