pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/IERC721.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/security/ReentrancyGuard.sol";

contract NFTMarketplace is Ownable, ReentrancyGuard {

    // Struct to represent an NFT listing
    struct Listing {
        uint256 listingId;
        address nftContract;
        uint256 tokenId;
        address payable seller;
        uint256 price; // Price in Wei
        bool isSold; // True if the NFT has been sold
        bool isActive; // True if the listing is currently active for sale
    }

    uint256 public listingIdCounter;
    mapping(uint256 => Listing) public listings;
    // Map (NFT Contract Address, Token ID) to Listing ID for quick lookups of active listings.
    // A value of 0 means no active listing for that NFT.
    mapping(address => mapping(uint256 => uint256)) public activeListingsByNFT;

    uint256 public marketFeePercentage; // Stored in basis points (e.g., 100 = 1%, 10000 = 100%)
    address payable public marketFeeRecipient;

    // Events
    event NFTListed(
        uint256 indexed listingId,
        address indexed nftContract,
        uint256 indexed tokenId,
        address seller,
        uint256 price
    );
    event NFTSale(
        uint256 indexed listingId,
        address indexed nftContract,
        uint256 indexed tokenId,
        address seller,
        address buyer,
        uint256 price,
        uint256 marketFee
    );
    event ListingCancelled(
        uint256 indexed listingId,
        address indexed nftContract,
        uint256 indexed tokenId,
        address seller
    );
    event MarketFeeUpdated(uint256 oldFee, uint256 newFee);
    event MarketFeeRecipientUpdated(address oldRecipient, address newRecipient);

    constructor(uint256 _initialMarketFeePercentage, address payable _initialMarketFeeRecipient) {
        require(_initialMarketFeePercentage <= 10000, "Fee cannot exceed 100%");
        require(_initialMarketFeeRecipient != address(0), "Fee recipient cannot be zero address");

        marketFeePercentage = _initialMarketFeePercentage;
        marketFeeRecipient = _initialMarketFeeRecipient;
        listingIdCounter = 0; // Listing IDs will start from 1
    }

    // Modifier to check if the listing is active and not sold
    modifier onlyActiveListing(uint256 _listingId) {
        require(_listingId > 0 && _listingId <= listingIdCounter, "Listing does not exist");
        require(listings[_listingId].isActive, "Listing is not active");
        require(!listings[_listingId].isSold, "Listing has been sold");
        _;
    }

    // @notice Allows a user to list an NFT for sale.
    // @param _nftContract The address of the ERC721 NFT contract.
    // @param _tokenId The ID of the NFT to list.
    // @param _price The price in Wei (ETH) that the NFT is being sold for.
    function listNFT(address _nftContract, uint256 _tokenId, uint256 _price) external {
        require(_price > 0, "Price must be greater than zero");
        require(_nftContract != address(0), "NFT contract address cannot be zero");

        // Ensure the caller owns the NFT
        IERC721 nft = IERC721(_nftContract);
        require(nft.ownerOf(_tokenId) == msg.sender, "Caller is not the owner of the NFT");

        // Ensure the marketplace contract is approved to transfer the NFT
        require(nft.getApproved(_tokenId) == address(this), "Marketplace not approved to transfer NFT");

        // Ensure the NFT is not already actively listed
        require(activeListingsByNFT[_nftContract][_tokenId] == 0, "NFT is already actively listed");

        listingIdCounter++;
        listings[listingIdCounter] = Listing({
            listingId: listingIdCounter,
            nftContract: _nftContract,
            tokenId: _tokenId,
            seller: payable(msg.sender),
            price: _price,
            isSold: false,
            isActive: true
        });

        activeListingsByNFT[_nftContract][_tokenId] = listingIdCounter;

        emit NFTListed(listingIdCounter, _nftContract, _tokenId, msg.sender, _price);
    }

    // @notice Allows a buyer to purchase an NFT from an active listing.
    // @param _listingId The ID of the listing to purchase.
    function buyNFT(uint256 _listingId) external payable nonReentrant onlyActiveListing(_listingId) {
        Listing storage listing = listings[_listingId];

        require(msg.value == listing.price, "Incorrect ETH amount sent");
        require(msg.sender != listing.seller, "Cannot buy your own NFT");

        // Calculate fees
        uint256 marketFee = (listing.price * marketFeePercentage) / 10000;
        uint256 sellerProceeds = listing.price - marketFee;

        // Mark listing as sold and inactive
        listing.isSold = true;
        listing.isActive = false;
        delete activeListingsByNFT[listing.nftContract][listing.tokenId]; // Remove from active listings mapping

        // Transfer NFT to the buyer
        IERC721(listing.nftContract).safeTransferFrom(listing.seller, msg.sender, listing.tokenId);

        // Distribute funds
        if (sellerProceeds > 0) {
            (bool successSeller, ) = listing.seller.call{value: sellerProceeds}("");
            require(successSeller, "Failed to send ETH to seller");
        }
        if (marketFee > 0) {
            (bool successFee, ) = marketFeeRecipient.call{value: marketFee}("");
            require(successFee, "Failed to send ETH to market fee recipient");
        }

        emit NFTSale(
            _listingId,
            listing.nftContract,
            listing.tokenId,
            listing.seller,
            msg.sender,
            listing.price,
            marketFee
        );
    }

    // @notice Allows the seller to cancel an active listing.
    // @param _listingId The ID of the listing to cancel.
    function cancelListing(uint256 _listingId) external onlyActiveListing(_listingId) {
        Listing storage listing = listings[_listingId];

        require(msg.sender == listing.seller, "Only the seller can cancel this listing");

        // Mark listing as inactive
        listing.isActive = false;
        delete activeListingsByNFT[listing.nftContract][listing.tokenId]; // Remove from active listings mapping

        emit ListingCancelled(
            _listingId,
            listing.nftContract,
            listing.tokenId,
            listing.seller
        );
    }

    // @notice Returns the details of a specific listing.
    // @param _listingId The ID of the listing.
    // @return listingId The ID of the listing.
    // @return nftContract The address of the NFT contract.
    // @return tokenId The ID of the NFT.
    // @return seller The address of the seller.
    // @return price The price of the NFT in Wei.
    // @return isSold True if the NFT has been sold.
    // @return isActive True if the listing is currently active.
    function getListing(uint256 _listingId)
        external
        view
        returns (
            uint256 listingId,
            address nftContract,
            uint256 tokenId,
            address seller,
            uint256 price,
            bool isSold,
            bool isActive
        )
    {
        require(_listingId > 0 && _listingId <= listingIdCounter, "Listing does not exist");
        Listing storage listing = listings[_listingId];
        return (
            listing.listingId,
            listing.nftContract,
            listing.tokenId,
            listing.seller,
            listing.price,
            listing.isSold,
            listing.isActive
        );
    }

    // Admin Functions (Ownable)

    // @notice Allows the contract owner to update the market fee percentage.
    // @param _newFeePercentage The new fee percentage in basis points (e.g., 100 = 1%).
    function setMarketFeePercentage(uint256 _newFeePercentage) external onlyOwner {
        require(_newFeePercentage <= 10000, "Fee cannot exceed 100%");
        emit MarketFeeUpdated(marketFeePercentage, _newFeePercentage);
        marketFeePercentage = _newFeePercentage;
    }

    // @notice Allows the contract owner to update the market fee recipient address.
    // @param _newRecipient The new address to receive market fees.
    function setMarketFeeRecipient(address payable _newRecipient) external onlyOwner {
        require(_newRecipient != address(0), "Fee recipient cannot be zero address");
        emit MarketFeeRecipientUpdated(marketFeeRecipient, _newRecipient);
        marketFeeRecipient = _newRecipient;
    }
}