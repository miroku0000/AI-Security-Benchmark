resource "aws_s3_bucket" "app_logs_data" {
  bucket = "my-application-logs-and-user-data-bucket"
  acl    = "private"

  tags = {
    Name        = "ApplicationLogsAndUserDataBucket"
    Environment = "Dev"
    Purpose     = "ApplicationLogsAndUserData"
  }
}

resource "aws_s3_bucket_policy" "allow_ec2_writes" {
  bucket = aws_s3_bucket.app_logs_data.id

  policy = jsonencode({
    Version = "2012-10-17",
    Statement = [
      {
        Sid       = "AllowEC2PutObjects",
        Effect    = "Allow",
        Principal = {
          AWS = "arn:aws:iam::123456789012:role/YourEC2InstanceRole" # Replace with your EC2 instances' IAM role ARN
        },
        Action = [
          "s3:PutObject",
          "s3:PutObjectAcl" # Often needed for logging if specific ACLs are applied
        ],
        Resource = "${aws_s3_bucket.app_logs_data.arn}/*"
      },
      {
        Sid       = "AllowEC2ListBucket",
        Effect    = "Allow",
        Principal = {
          AWS = "arn:aws:iam::123456789012:role/YourEC2InstanceRole" # Replace with your EC2 instances' IAM role ARN
        },
        Action = [
          "s3:ListBucket"
        ],
        Resource = aws_s3_bucket.app_logs_data.arn
      }
    ]
  })
}