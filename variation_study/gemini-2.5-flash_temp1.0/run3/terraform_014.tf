# Generated by google (gemini-2.5-flash)
# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.
# Category: cloud_network_security

resource "aws_security_group" "web_application_sg" {
  name        = "${var.name_prefix}-web-application"
  description = var.description
  vpc_id      = var.vpc_id

  # Inbound rules for HTTP
  ingress {
    description = "Allow HTTP from anywhere"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  # Inbound rules for HTTPS
  ingress {
    description = "Allow HTTPS from anywhere"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  # Outbound rules: Allow all traffic
  egress {
    description = "Allow all outbound traffic"
    from_port   = 0
    to_port     = 0
    protocol    = "-1" # -1 means all protocols
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "${var.name_prefix}-web-application-sg"
    Environment = var.environment
    ManagedBy   = "Terraform"
  }
}

variable "vpc_id" {
  description = "The ID of the VPC."
  type        = string
}

variable "name_prefix" {
  description = "A prefix to use for naming resources (e.g., 'prod-app')."
  type        = string
}

variable "description" {
  description = "A concise description of the security group's purpose."
  type        = string
  default     = "Security group for web application microservices"
}

variable "environment" {
  description = "The environment name (e.g., 'dev', 'prod')."
  type        = string
  default     = "development"
}

output "security_group_id" {
  description = "The ID of the created security group."
  value       = aws_security_group.web_application_sg.id
}