pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/IERC721.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/security/ReentrancyGuard.sol";
import "@openzeppelin/contracts/utils/Context.sol"; // For _msgSender()

contract NFTMarketplace is Ownable, ReentrancyGuard {

    struct Listing {
        address seller;
        uint256 price;
        bool active;
    }

    // Mapping: nftContractAddress => tokenId => Listing
    mapping(address => mapping(uint256 => Listing)) public listings;

    uint256 public listingFeeBasisPoints; // e.g., 250 for 2.5% (250 / 10000)
    uint256 public constant MAX_FEE_BASIS_POINTS = 1000; // Max 10% fee

    address payable public feeRecipient; // Address to receive marketplace fees
    uint256 public totalFeesCollected;

    event ItemListed(
        address indexed nftContract,
        uint256 indexed tokenId,
        address indexed seller,
        uint256 price
    );
    event ItemSold(
        address indexed nftContract,
        uint256 indexed tokenId,
        address indexed seller,
        address indexed buyer,
        uint256 price,
        uint256 feeAmount
    );
    event ListingCancelled(
        address indexed nftContract,
        uint256 indexed tokenId,
        address indexed seller
    );
    event FeeRecipientUpdated(address indexed oldRecipient, address indexed newRecipient);
    event ListingFeeUpdated(uint256 oldFeeBasisPoints, uint256 newFeeBasisPoints);
    event FeesWithdrawn(address indexed recipient, uint256 amount);


    constructor(uint256 initialFeeBasisPoints, address payable _feeRecipient) {
        require(initialFeeBasisPoints <= MAX_FEE_BASIS_POINTS, "NFTMarketplace: Initial fee too high");
        require(_feeRecipient != address(0), "NFTMarketplace: Fee recipient cannot be zero address");

        listingFeeBasisPoints = initialFeeBasisPoints;
        feeRecipient = _feeRecipient;
        // Ownable constructor is implicitly called, setting msg.sender as owner
    }

    /// @notice Sets the address that receives marketplace fees.
    /// @param _newRecipient The new address to receive marketplace fees.
    function setFeeRecipient(address payable _newRecipient) external onlyOwner {
        require(_newRecipient != address(0), "NFTMarketplace: New fee recipient cannot be zero address");
        emit FeeRecipientUpdated(feeRecipient, _newRecipient);
        feeRecipient = _newRecipient;
    }

    /// @notice Sets the marketplace listing fee in basis points.
    /// @param _newFeeBasisPoints The new fee in basis points (e.g., 250 for 2.5%).
    function setListingFee(uint256 _newFeeBasisPoints) external onlyOwner {
        require(_newFeeBasisPoints <= MAX_FEE_BASIS_POINTS, "NFTMarketplace: Fee too high");
        emit ListingFeeUpdated(listingFeeBasisPoints, _newFeeBasisPoints);
        listingFeeBasisPoints = _newFeeBasisPoints;
    }

    /// @notice Lists an NFT for sale on the marketplace.
    /// @dev The seller must approve the marketplace contract to transfer the NFT beforehand.
    ///      This can be done by calling `IERC721(nftContract).approve(address(this), tokenId)`
    ///      or `IERC721(nftContract).setApprovalForAll(address(this), true)`.
    /// @param _nftContract The address of the NFT contract (ERC721).
    /// @param _tokenId The token ID of the NFT.
    /// @param _price The price in wei at which to list the NFT. Must be greater than 0.
    function listNft(address _nftContract, uint256 _tokenId, uint256 _price) external nonReentrant {
        require(_price > 0, "NFTMarketplace: Price must be greater than 0");
        require(_nftContract != address(0), "NFTMarketplace: NFT contract cannot be zero address");

        IERC721 nft = IERC721(_nftContract);
        
        // Ensure the sender owns the NFT
        require(nft.ownerOf(_tokenId) == _msgSender(), "NFTMarketplace: Caller is not the owner of the NFT");

        // Ensure the marketplace contract is approved to transfer the NFT
        require(
            nft.getApproved(_tokenId) == address(this) || nft.isApprovedForAll(_msgSender(), address(this)),
            "NFTMarketplace: Marketplace not approved to transfer NFT. Please approve."
        );

        // Check if there's an existing active listing for this NFT
        Listing storage existingListing = listings[_nftContract][_tokenId];
        require(!existingListing.active, "NFTMarketplace: NFT is already listed");

        listings[_nftContract][_tokenId] = Listing({
            seller: _msgSender(),
            price: _price,
            active: true
        });

        emit ItemListed(_nftContract, _tokenId, _msgSender(), _price);
    }

    /// @notice Buys an NFT listed on the marketplace.
    /// @dev The buyer must send the exact listing price with the transaction.
    /// @param _nftContract The address of the NFT contract.
    /// @param _tokenId The token ID of the NFT to buy.
    function buyNft(address _nftContract, uint256 _tokenId) external payable nonReentrant {
        require(_nftContract != address(0), "NFTMarketplace: NFT contract cannot be zero address");

        Listing storage listing = listings[_nftContract][_tokenId];
        require(listing.active, "NFTMarketplace: NFT is not listed or already sold");
        require(listing.seller != address(0), "NFTMarketplace: Invalid listing seller"); // Safety check
        require(listing.seller != _msgSender(), "NFTMarketplace: Cannot buy your own NFT");
        require(msg.value == listing.price, "NFTMarketplace: Incorrect payment amount");

        // Mark listing as inactive BEFORE transfers to prevent reentrancy issues (Checks-Effects-Interactions).
        listing.active = false;

        // Calculate fees
        uint256 feeAmount = (listing.price * listingFeeBasisPoints) / 10000;
        uint256 sellerProceeds = listing.price - feeAmount;

        // Transfer NFT from seller to buyer (via marketplace approval)
        IERC721 nft = IERC721(_nftContract);
        nft.transferFrom(listing.seller, _msgSender(), _tokenId);

        // Send proceeds to seller
        (bool successSeller, ) = payable(listing.seller).call{value: sellerProceeds}("");
        require(successSeller, "NFTMarketplace: Failed to send ETH to seller");

        // Accumulate fees for the marketplace fee recipient
        totalFeesCollected += feeAmount;

        emit ItemSold(
            _nftContract,
            _tokenId,
            listing.seller,
            _msgSender(),
            listing.price,
            feeAmount
        );
    }

    /// @notice Cancels an active NFT listing.
    /// @dev Only the seller of the NFT can cancel their listing.
    /// @param _nftContract The address of the NFT contract.
    /// @param _tokenId The token ID of the NFT.
    function cancelListing(address _nftContract, uint256 _tokenId) external nonReentrant {
        require(_nftContract != address(0), "NFTMarketplace: NFT contract cannot be zero address");

        Listing storage listing = listings[_nftContract][_tokenId];
        require(listing.active, "NFTMarketplace: NFT is not listed or already sold");
        require(listing.seller == _msgSender(), "NFTMarketplace: Only the seller can cancel a listing");

        listing.active = false; // Mark as inactive

        // The NFT remains with the seller.
        // The seller might want to revoke approval on the NFT contract manually if desired.

        emit ListingCancelled(_nftContract, _tokenId, _msgSender());
    }

    /// @notice Allows the designated fee recipient to withdraw accumulated fees.
    /// @dev Only the fee recipient can call this function.
    function withdrawFees() external nonReentrant {
        require(_msgSender() == feeRecipient, "NFTMarketplace: Only fee recipient can withdraw fees");
        require(totalFeesCollected > 0, "NFTMarketplace: No fees to withdraw");

        uint256 amountToWithdraw = totalFeesCollected;
        totalFeesCollected = 0; // Reset before transfer (Checks-Effects-Interactions)

        (bool success, ) = feeRecipient.call{value: amountToWithdraw}("");
        require(success, "NFTMarketplace: Failed to withdraw fees");

        emit FeesWithdrawn(feeRecipient, amountToWithdraw);
    }

    /// @notice Retrieves the details of an NFT listing.
    /// @param _nftContract The address of the NFT contract.
    /// @param _tokenId The token ID of the NFT.
    /// @return seller The address of the NFT seller.
    /// @return price The listed price of the NFT in wei.
    /// @return active True if the listing is active, false otherwise.
    function getListing(address _nftContract, uint256 _tokenId)
        external
        view
        returns (address seller, uint256 price, bool active)
    {
        Listing storage listing = listings[_nftContract][_tokenId];
        return (listing.seller, listing.price, listing.active);
    }
}