resource "archive_file" "payment_processor_lambda_zip" {
  type        = "zip"
  source_file = local_file.payment_processor_handler_code.filename
  output_path = local.lambda_output_path
}

#
# 3. S3 Bucket for Lambda Deployment Package
#

resource "aws_s3_bucket" "lambda_deployment_bucket" {
  bucket_prefix = "lambda-payment-processor-code-"
  force_destroy = true # WARNING: Use with caution in production

  tags = {
    Name        = "LambdaCodeDeploymentBucket"
    Environment = "Production"
    System      = "PaymentProcessing"
  }
}

resource "aws_s3_bucket_object" "payment_processor_lambda_code" {
  bucket = aws_s3_bucket.lambda_deployment_bucket.id
  key    = "payment_processor_lambda/${archive_file.payment_processor_lambda_zip.output_md5}.zip"
  source = archive_file.payment_processor_lambda_zip.output_path
  etag   = filemd5(archive_file.payment_processor_lambda_zip.output_path)
}

#
# 4. Lambda Function Definition
#

resource "aws_lambda_function" "payment_processor_lambda" {
  function_name    = "payment-processor-lambda"
  handler          = replace(local.lambda_handler_file, ".py", ".lambda_handler")
  runtime          = "python3.9" # Choose appropriate runtime
  role             = aws_iam_role.payment_processor_lambda_role.arn
  timeout          = 60            # Adjust as needed for processing time
  memory_size      = 256           # Adjust based on memory requirements
  publish          = true          # Publish a new version on each update

  s3_bucket = aws_s3_bucket.lambda_deployment_bucket.id
  s3_key    = aws_s3_bucket_object.payment_processor_lambda_code.key

  # Critical for sensitive financial data: run in a VPC
  # This allows the Lambda to access private resources (e.g., databases)
  # and provides network isolation.
  vpc_config {
    subnet_ids         = var.vpc_subnet_ids       # List of private subnet IDs
    security_group_ids = var.vpc_security_group_ids # List of security group IDs
  }

  environment {
    variables = {
      LOG_LEVEL          = "INFO"
      AWS_REGION         = var.aws_region
      KMS_KEY_ID         = var.kms_key_arn # KMS key ID for decryption
      # Add other environment variables as needed, e.g., database endpoints, table names
      # Sensitive environment variables can be encrypted using KMS, define `kms_key_arn` here
      # DATABASE_ENDPOINT  = "db-instance.xxxxxxxx.rds.amazonaws.com"
      # PAYMENT_TABLE_NAME = "PaymentTransactions"
    }
    # For sensitive environment variables, specify the KMS key to encrypt them at rest
    # kms_key_arn = var.lambda_env_kms_key_arn # ARN of KMS key to encrypt environment variables
  }

  tags = {
    Name        = "PaymentProcessorLambda"
    Environment = "Production"
    System      = "PaymentProcessing"
  }

  lifecycle {
    ignore_changes = [
      last_modified, # Ignore changes to last_modified timestamp
    ]
  }
}

#
# Variables
#

variable "aws_region" {
  description = "The AWS region to deploy resources."
  type        = string
  default     = "us-east-1"
}

variable "vpc_subnet_ids" {
  description = "A list of private subnet IDs for the Lambda function."
  type        = list(string)
  # Example: Provide actual subnet IDs from your VPC
  default = ["subnet-0abcdef1234567890", "subnet-0fedcba9876543210"]
}

variable "vpc_security_group_ids" {
  description = "A list of security group IDs for the Lambda function."
  type        = list(string)
  # Example: Provide actual security group IDs from your VPC
  default = ["sg-0123456789abcdef0"]
}

variable "kms_key_arn" {
  description = "The ARN of the KMS key used for encrypting/decrypting sensitive data."
  type        = string
  # Example: Provide the ARN of your KMS key
  default = "arn:aws:kms:us-east-1:123456789012:key/abcdef12-3456-7890-abcd-ef1234567890"
}

