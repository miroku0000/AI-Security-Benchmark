# Generated by google (gemini-2.5-flash)
# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = "us-east-1" # Or your desired region
}

data "aws_caller_identity" "current" {}

#
# 1. IAM Role and Policy for Lambda Execution
#

resource "aws_iam_role" "payment_processor_lambda_role" {
  name_prefix = "payment-processor-lambda-role-"
  assume_role_policy = jsonencode({
    Version = "2012-10-17",
    Statement = [
      {
        Action = "sts:AssumeRole",
        Effect = "Allow",
        Principal = {
          Service = "lambda.amazonaws.com"
        },
      },
    ],
  })

  tags = {
    Name        = "PaymentProcessorLambdaRole"
    Environment = "Production"
    System      = "PaymentProcessing"
  }
}

resource "aws_iam_policy" "payment_processor_lambda_policy" {
  name_prefix = "payment-processor-lambda-policy-"
  description = "IAM policy for Lambda to process financial data"

  policy = jsonencode({
    Version = "2012-10-17",
    Statement = [
      # Permissions for logging to CloudWatch Logs
      {
        Action = [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents",
        ],
        Effect   = "Allow",
        Resource = "arn:aws:logs:${var.aws_region}:${data.aws_caller_identity.current.account_id}:log-group:/aws/lambda/*:*"
      },
      # Permissions for KMS decryption (essential for sensitive data)
      # Assuming sensitive environment variables or incoming data are encrypted with KMS
      {
        Action = [
          "kms:Decrypt",
          "kms:GenerateDataKey", # If the Lambda encrypts data itself
          # "kms:Encrypt"          # Uncomment if the Lambda encrypts data
        ],
        Effect   = "Allow",
        Resource = var.kms_key_arn # ARN of the KMS key used for data encryption/decryption
      },
      # Permissions for VPC access (Lambda will create ENIs)
      # These permissions are required for Lambdas within a VPC
      {
        Action = [
          "ec2:CreateNetworkInterface",
          "ec2:DescribeNetworkInterfaces",
          "ec2:DeleteNetworkInterface"
        ],
        Effect   = "Allow",
        Resource = "*" # Resource-level permissions not supported for these actions
      },
      # ADD MORE SPECIFIC PERMISSIONS HERE based on what other AWS services the Lambda interacts with
      # e.g., DynamoDB, S3, SQS, SNS, Secrets Manager, etc.
      # Example: Access to a specific DynamoDB table
      # {
      #   Action = [
      #     "dynamodb:GetItem",
      #     "dynamodb:PutItem",
      #     "dynamodb:UpdateItem",
      #     "dynamodb:DeleteItem",
      #   ],
      #   Effect = "Allow",
      #   Resource = "arn:aws:dynamodb:${var.aws_region}:${data.aws_caller_identity.current.account_id}:table/${var.payment_transactions_table_name}"
      # },
      # Example: Access to Secrets Manager for database credentials
      # {
      #   Action = [
      #     "secretsmanager:GetSecretValue",
      #   ],
      #   Effect = "Allow",
      #   Resource = "arn:aws:secretsmanager:${var.aws_region}:${data.aws_caller_identity.current.account_id}:secret:my-database-credentials-*"
      # }
    ],
  })

  tags = {
    Name        = "PaymentProcessorLambdaPolicy"
    Environment = "Production"
    System      = "PaymentProcessing"
  }
}

resource "aws_iam_role_policy_attachment" "payment_processor_lambda_attach" {
  role       = aws_iam_role.payment_processor_lambda_role.name
  policy_arn = aws_iam_policy.payment_processor_lambda_policy.arn
}

#
# 2. Lambda Function Code Package
#
