pragma solidity ^0.8.0;

contract SimpleLottery {
    address public owner;
    uint256 public ticketPrice;
    address[] public players;
    uint256 public lotteryId;
    LotteryState public currentLotteryState;
    address public winner;
    uint256 public randomNumberSeed;
    uint256 public lastRandomNumber;

    enum LotteryState {
        Open,
        Closed,
        Drawing,
        PaidOut
    }

    event LotteryOpened(uint256 _lotteryId, uint256 _ticketPrice);
    event PlayerEntered(uint256 _lotteryId, address _player);
    event LotteryClosed(uint256 _lotteryId);
    event WinnerSelected(uint256 _lotteryId, address _winner, uint256 _randomNumber);
    event PrizePaid(uint256 _lotteryId, address _winner, uint256 _amount);

    constructor() {
        owner = msg.sender;
        lotteryId = 0;
        currentLotteryState = LotteryState.Closed;
    }

    modifier onlyOwner() {
        require(msg.sender == owner, "Only owner can call this function.");
        _;
    }

    modifier inState(LotteryState _state) {
        require(currentLotteryState == _state, "Lottery is not in the required state.");
        _;
    }

    function startLottery(uint256 _ticketPrice) public onlyOwner {
        require(currentLotteryState == LotteryState.Closed || currentLotteryState == LotteryState.PaidOut, "Previous lottery must be closed or paid out.");
        require(_ticketPrice > 0, "Ticket price must be greater than zero.");

        lotteryId++;
        ticketPrice = _ticketPrice;
        delete players;
        winner = address(0);
        lastRandomNumber = 0;
        randomNumberSeed = 0;
        currentLotteryState = LotteryState.Open;
        emit LotteryOpened(lotteryId, ticketPrice);
    }

    function enterLottery() public payable inState(LotteryState.Open) {
        require(msg.value == ticketPrice, "Must send exactly the ticket price.");
        players.push(msg.sender);
        emit PlayerEntered(lotteryId, msg.sender);
    }

    function closeLottery() public onlyOwner inState(LotteryState.Open) {
        require(players.length > 0, "Not enough players to close lottery.");
        currentLotteryState = LotteryState.Closed;
        emit LotteryClosed(lotteryId);
    }

    function drawWinner() public onlyOwner inState(LotteryState.Closed) {
        require(players.length > 0, "No players to draw a winner from.");

        currentLotteryState = LotteryState.Drawing;

