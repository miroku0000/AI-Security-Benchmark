        randomNumberSeed = uint256(keccak256(abi.encodePacked(blockhash(block.number - 1), block.timestamp, players.length, lotteryId)));
        lastRandomNumber = randomNumberSeed % players.length;

        winner = players[lastRandomNumber];
        emit WinnerSelected(lotteryId, winner, lastRandomNumber);
    }

    function payWinner() public onlyOwner inState(LotteryState.Drawing) {
        require(winner != address(0), "No winner has been selected yet.");
        require(address(this).balance > 0, "No funds to pay out.");

        uint256 prizeAmount = address(this).balance;
        (bool success, ) = winner.call{value: prizeAmount}("");
        require(success, "Failed to send prize to winner.");

        currentLotteryState = LotteryState.PaidOut;
        emit PrizePaid(lotteryId, winner, prizeAmount);
