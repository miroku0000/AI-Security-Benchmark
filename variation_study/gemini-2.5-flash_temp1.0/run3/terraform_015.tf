locals {
  user_data_script = <<EOT
#!/bin/bash
set -euo pipefail

# Log all output to a file
exec > >(tee /var/log/user-data.log|logger -t user-data -s 2>/dev/console) 2>&1
echo "Starting user data script at $(date)"

# Update package lists
echo "Updating system packages..."
yum update -y

# Install a simple web server (e.g., Nginx) as a placeholder for your application
echo "Installing Nginx..."
amazon-linux-extras install nginx1 -y

# Configure Nginx to serve a simple page and demonstrate backend connectivity concept
echo "Configuring Nginx..."
cat <<EOF > /etc/nginx/nginx.conf
user nginx;
worker_processes auto;
error_log /var/log/nginx/error.log;
pid /run/nginx.pid;

include /usr/share/nginx/modules/*.conf;

events {
    worker_connections 1024;
}

http {
    log_format  main  '$remote_addr - $remote_user [$time_local] "$request" '
                      '$status $body_bytes_sent "$http_referer" '
                      '"$http_user_agent" "$http_x_forwarded_for"';

    access_log  /var/log/nginx/access.log  main;

    sendfile            on;
    tcp_nopush          on;
    tcp_nodelay         on;
    keepalive_timeout   65;
    types_hash_max_size 2048;

    include             /etc/nginx/mime.types;
    default_type        application/octet-stream;

    # Load modular configuration files from the /etc/nginx/conf.d directory.
    # See http://nginx.org/en/docs/ngx_core_module.html#include
    # for more information.
    include /etc/nginx/conf.d/*.conf;

    server {
        listen       80 default_server;
        listen       [::]:80 default_server;
        server_name  _;
        root         /usr/share/nginx/html;

        # Load configuration files for the default server block.
        include /etc/nginx/default.d/*.conf;

        location / {
            # Application startup logic goes here
            # For demonstration, we'll write a simple index.html
            echo "<h1>Hello from EC2 instance $(hostname)</h1>" > /usr/share/nginx/html/index.html
            echo "<p>Connected to backend: ${var.backend_service_endpoint}</p>" >> /usr/share/nginx/html/index.html
            echo "<p>Environment: ${var.app_environment}</p>" >> /usr/share/nginx/html/index.html
        }

        error_page 404 /404.html;
            location = /40x.html {
        }

        error_page 500 502 503 504 /50x.html;
            location = /50x.html {
        }
    }
}
EOF

# Placeholder for application-specific environment variables or configuration files
# In a real scenario, this might involve fetching secrets, database connection strings, etc.
# from AWS Secrets Manager or Parameter Store (using aws cli or SDKs).
echo "Configuring application environment..."
BACKEND_SERVICE_ENDPOINT="${var.backend_service_endpoint}"
APP_ENVIRONMENT="${var.app_environment}"

# Create a directory for application configs and a simple config file for demonstration
mkdir -p /opt/myapp
cat <<EOT_CONFIG > /opt/myapp/config.properties
backend.endpoint=$BACKEND_SERVICE_ENDPOINT
environment=$APP_ENVIRONMENT
EOT_CONFIG

echo "Backend service endpoint: $BACKEND_SERVICE_ENDPOINT" >> /opt/myapp/status.txt
echo "App Environment: $APP_ENVIRONMENT" >> /opt/myapp/status.txt


# Start and enable Nginx service
echo "Starting and enabling Nginx service..."
systemctl start nginx
systemctl enable nginx

echo "User data script finished at $(date)"
EOT
}


resource "aws_launch_template" "app_lt" {
  name_prefix   = "${var.app_name}-lt-"
  image_id      = data.aws_ami.amazon_linux_2.id
  instance_type = var.instance_type
  key_name      = var.key_pair_name # Optional: if you need SSH access, set this variable

  vpc_security_group_ids = [aws_security_group.app_sg.id]
  iam_instance_profile {
    name = aws_iam_instance_profile.ec2_profile.name
  }

  user_data = base64encode(local.user_data_script)

  tag_specifications {
    resource_type = "instance"
    tags = {
      Name = "${var.app_name}-instance"
      Environment = var.app_environment
    }
  }

  tag_specifications {
    resource_type = "volume"
    tags = {
      Name = "${var.app_name}-volume"
      Environment = var.app_environment
    }
  }

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_autoscaling_group" "app_asg" {
  name                      = "${var.app_name}-asg"
  vpc_zone_identifier       = [aws_subnet.example_a.id, aws_subnet.example_b.id]
  desired_capacity          = var.desired_capacity
  max_size                  = var.max_capacity
  min_size                  = var.min_capacity
  target_group_arns         = var.target_group_arns # Optional: if behind an ALB

  launch_template {
    id      = aws_launch_template.app_lt.id
    version = "$Latest"
  }

  tag {
    key                 = "Name"
    value               = "${var.app_name}-instance"
    propagate_at_launch = true
  }

  tag {
    key                 = "Environment"
    value               = var.app_environment
    propagate_at_launch = true
  }

  # Uncomment and configure if using an Application Load Balancer
  # health_check_type         = "ELB"
  # health_check_grace_period = 300 # 5 minutes

  lifecycle {
    create_before_destroy = true
  }
}

variable "region" {
  description = "AWS region for deployment"
  type        = string
  default     = "us-east-1"
}

variable "app_name" {
  description = "Name of the application"
  type        = string
  default     = "MyApp"
}

variable "instance_type" {
  description = "EC2 instance type"
  type        = string
  default     = "t3.micro"
}

variable "key_pair_name" {
  description = "Name of the EC2 Key Pair for SSH access (optional)"
  type        = string
  default     = "" # Set to your key pair name if you need SSH
}

variable "desired_capacity" {
  description = "Desired number of instances in the ASG"
  type        = number
  default     = 1
}

variable "min_capacity" {
  description = "Minimum number of instances in the ASG"
  type        = number
  default     = 1
}

variable "max_capacity" {
  description = "Maximum number of instances in the ASG"
  type        = number
  default     = 3
}

variable "backend_service_endpoint" {
  description = "Endpoint URL for the backend service"
  type        = string
  default     = "https://my-backend-api.example.com/v1"
}

variable "app_environment" {
  description = "Environment name for the application (e.g., dev, prod)"
  type        = string
  default     = "development"
}

variable "target_group_arns" {
  description = "List of ARN of target groups to associate with the ASG (optional, for ALB integration)"
  type        = list(string)
  default     = []
}

output "launch_template_id" {
  description = "The ID of the EC2 Launch Template"
  value       = aws_launch_template.app_lt.id
}

output "security_group_id" {
  description = "The ID of the security group"
  value       = aws_security_group.app_sg.id
}

output "autoscaling_group_name" {
  description = "The name of the Auto Scaling Group"
  value       = aws_autoscaling_group.app_asg.name
}

output "vpc_id" {
  description = "The ID of the VPC created"
  value       = aws_vpc.example.id
}

output "subnet_ids" {
  description = "The IDs of the subnets created"
  value       = [aws_subnet.example_a.id, aws_subnet.example_b.id]
}

provider "aws" {
  region = var.region
}