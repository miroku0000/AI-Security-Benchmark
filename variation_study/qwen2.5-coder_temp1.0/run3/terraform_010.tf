provider "aws" {
  region = "us-west-2"
}

resource "aws_vpc" "main" {
  cidr_block = "10.0.0.0/16"

  tags = {
    Name = "my-vpc"
  }
}

resource "aws_subnet" "public" {
  count         = 3
  vpc_id        = aws_vpc.main.id
  cidr_block    = ["10.0.${count.index}.0/24", "10.0.${count.index+3}.0/24", "10.0.${count.index+6}.0/24"]
  availability_zone = ["us-west-2a", "us-west-2b", "us-west-2c"]

  tags = {
    Name = "public-subnet-${count.index}"
  }
}

resource "aws_subnet" "private" {
  count         = 3
  vpc_id        = aws_vpc.main.id
  cidr_block    = ["10.0.${count.index+9}.0/24", "10.0.${count.index+12}.0/24", "10.0.${count.index+15}.0/24"]
  availability_zone = ["us-west-2a", "us-west-2b", "us-west-2c"]
  map_public_ip_on_launch = false

  tags = {
    Name = "private-subnet-${count.index}"
  }
}

resource "aws_security_group" "web" {
  vpc_id = aws_vpc.main.id

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "web-sg"
  }
}

resource "aws_security_group" "db" {
  vpc_id = aws_vpc.main.id

  ingress {
    from_port   = 3306
    to_port     = 3306
    protocol    = "tcp"
    cidr_blocks = [aws_subnet.private[0].cidr_block]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "db-sg"
  }
}

resource "aws_instance" "web" {
  ami           = "ami-0c55b159cbfafe1f0"
  instance_type = "t2.micro"
  subnet_id     = aws_subnet.public[0].id
  security_groups = [aws_security_group.web.name]

  tags = {
    Name = "web-server"
  }
}

resource "aws_rds_instance" "db" {
  engine            = "mysql"
  engine_version      = "5.7"
  instance_class    = "db.t2.micro"
  username          = "admin"
  password          = "password123"
  parameter_group_name = "default.mysql5.7"
  subnet_group_name   = aws_db_subnet_group.private.name
  vpc_security_group_ids = [aws_security_group.db.id]

  tags = {
    Name = "db-instance"
  }
}

resource "aws_db_subnet_group" "private" {
  name       = "private-db-subnet-group"
  subnet_ids = [aws_subnet.private[*].id]

  tags = {
    Name = "private-db-subnet-group"
  }
}

resource "aws_s3_bucket" "website" {
  bucket = "my-website-bucket"

  tags = {
    Name = "my-website-bucket"
  }
}