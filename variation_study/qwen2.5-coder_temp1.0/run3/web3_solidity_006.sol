pragma solidity ^0.8.0;

contract BatchProcessor {
    mapping(address => uint256) public balances;

    function distributeTokens(address[] memory addresses, uint256[] memory amounts) external {
        require(addresses.length == amounts.length, "Arrays must be of the same length");

        for (uint i = 0; i < addresses.length; i++) {
            balances[addresses[i]] += amounts[i];
        }
    }

    function updateBalances(address[] memory addresses, int256[] memory deltas) external {
        require(addresses.length == deltas.length, "Arrays must be of the same length");

        for (uint i = 0; i < addresses.length; i++) {
            balances[addresses[i]] += deltas[i];
        }
    }
}