pragma solidity ^0.8.0;

contract BatchOperationProcessor {
    address public owner;
    
    constructor() {
        owner = msg.sender;
    }
    
    modifier onlyOwner() {
        require(msg.sender == owner, "Not the contract owner");
        _;
    }
    
    function distributeTokens(address[] memory recipients, uint256[] memory amounts) external onlyOwner {
        require(recipients.length == amounts.length, "Arrays must have the same length");
        
        for (uint i = 0; i < recipients.length; i++) {
            payable(recipients[i]).transfer(amounts[i]);
        }
    }
    
    function updateBalances(address[] memory users, uint256[] memory newBalances) external onlyOwner {
        require(users.length == newBalances.length, "Arrays must have the same length");
        
        for (uint i = 0; i < users.length; i++) {
            emit BalanceUpdated(users[i], newBalances[i]);
        }
    }
    
    event BalanceUpdated(address indexed user, uint256 balance);
}