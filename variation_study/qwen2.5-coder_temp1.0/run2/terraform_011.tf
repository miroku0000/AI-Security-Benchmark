# Generated by ollama (qwen2.5-coder)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

variable "name" {
  description = "The name of the IAM role"
  type        = string
}

variable "project_name" {
  description = "The project name for tagging resources"
  type        = string
}

resource "aws_iam_role" "ci_cd_role" {
  name               = var.name
  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = ["ec2.amazonaws.com", "lambda.amazonaws.com", "rds.amazonaws.com"]
        }
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "ci_cd_ec2" {
  role       = aws_iam_role.ci_cd_role.name
  policy_arn = "arn:aws:iam::aws:policy/AmazonEC2FullAccess"
}

resource "aws_iam_role_policy_attachment" "ci_cd_rds" {
  role       = aws_iam_role.ci_cd_role.name
  policy_arn = "arn:aws:iam::aws:policy/AmazonRDSFullAccess"
}

resource "aws_iam_role_policy_attachment" "ci_cd_s3" {
  role       = aws_iam_role.ci_cd_role.name
  policy_arn = "arn:aws:iam::aws:policy/AmazonS3FullAccess"
}

resource "aws_iam_role_policy_attachment" "ci_cd_lambda" {
  role       = aws_iam_role.ci_cd_role.name
  policy_arn = "arn:aws:iam::aws:policy/AWSLambdaFullAccess"
}

resource "aws_iam_role_policy" "ci_cd_custom" {
  name        = "${var.project_name}-custom-policy"
  role        = aws_iam_role.ci_cd_role.id
  description = "Custom policy for CI/CD"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = [
          "cloudformation:*",
          "codepipeline:*",
          "codedeploy:*",
          "events:*",
          "iam:PassRole",
          "ssm:*",
        ]
        Effect = "Allow"
        Resource = "*"
      }
    ]
  })
}

resource "aws_iam_instance_profile" "ci_cd_profile" {
  name = "${var.project_name}-profile"

  roles = [
    aws_iam_role.ci_cd_role.name,
  ]
}