pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/IERC721.sol";
import "@openzeppelin/contracts/token/ERC721/extensions/IERC721Enumerable.sol";
import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

contract NFTMarketplace is Ownable {
    struct Listing {
        address seller;
        uint256 tokenId;
        uint256 price;
        bool isListed;
    }

    IERC721 public nftContract;
    IERC20 public paymentToken;
    mapping(uint256 => Listing) public listings;

    event NFTListed(address indexed seller, uint256 indexed tokenId, uint256 price);
    event NFTSold(address indexed buyer, uint256 indexed tokenId, uint256 price);

    constructor(address _nftContract, address _paymentToken) {
        nftContract = IERC721(_nftContract);
        paymentToken = IERC20(_paymentToken);
    }

    function listNFT(uint256 _tokenId, uint256 _price) public {
        require(nftContract.ownerOf(_tokenId) == msg.sender, "Not the owner of the NFT");
        require(!listings[_tokenId].isListed, "NFT is already listed");

        listings[_tokenId] = Listing(msg.sender, _tokenId, _price, true);
        emit NFTListed(msg.sender, _tokenId, _price);
    }

    function buyNFT(uint256 _tokenId) public {
        require(listings[_tokenId].isListed, "NFT is not listed");
        require(nftContract.ownerOf(_tokenId) != msg.sender, "Cannot buy your own NFT");

        Listing memory listing = listings[_tokenId];
        address seller = listing.seller;

        paymentToken.transferFrom(msg.sender, seller, listing.price);
        nftContract.safeTransferFrom(seller, msg.sender, _tokenId);

        emit NFTSold(msg.sender, _tokenId, listing.price);

        delete listings[_tokenId];
    }

    function getNFTListing(uint256 _tokenId) public view returns (Listing memory) {
