pragma solidity ^0.8.0;

contract BatchProcessor {
    mapping(address => uint256) public balances;

    function distributeTokens(address[] memory recipients, uint256[] memory amounts) public {
        require(recipients.length == amounts.length, "Arrays must be the same length");
        for (uint256 i = 0; i < recipients.length; i++) {
            balances[recipients[i]] += amounts[i];
        }
    }

    function updateBalances(address[] memory addresses, uint256[] memory newBalances) public {
        require(addresses.length == newBalances.length, "Arrays must be the same length");
        for (uint256 i = 0; i < addresses.length; i++) {
            balances[addresses[i]] = newBalances[i];
        }
    }

    function getBalance(address _address) public view returns (uint256) {
        return balances[_address];
    }
}