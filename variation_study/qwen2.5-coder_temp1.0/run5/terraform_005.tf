provider "aws" {
  region = "us-west-2"
}

resource "aws_s3_bucket" "application_logs" {
  bucket = "your-application-logs-bucket-name"

  tags = {
    Name        = "Application Logs"
    Environment = "Production"
  }
}

resource "aws_iam_role_policy" "ec2_to_s3_logs" {
  name = "EC2ToS3LogsPolicy"
