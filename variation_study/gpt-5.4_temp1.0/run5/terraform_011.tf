# Generated by openai (gpt-5.4)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

terraform {
  required_version = ">= 1.3.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

data "aws_partition" "current" {}

data "aws_caller_identity" "current" {}

variable "name" {
  type        = string
  description = "Name of the IAM role."
  default     = "cicd-infrastructure-deployer"
}

variable "path" {
  type        = string
  description = "Path for the IAM role."
  default     = "/"
}

variable "description" {
  type        = string
  description = "Description of the IAM role."
  default     = "CI/CD role for deploying and managing AWS infrastructure"
}

variable "max_session_duration" {
  type        = number
  description = "Maximum session duration in seconds."
  default     = 3600
}

variable "permissions_boundary_arn" {
  type        = string
  description = "Optional permissions boundary ARN to apply to the role."
  default     = null
}

variable "trusted_principal_arns" {
  type        = list(string)
  description = "List of AWS principal ARNs allowed to assume this role."
  default     = []
}

variable "trusted_service_principals" {
  type        = list(string)
  description = "List of AWS service principals allowed to assume this role."
  default     = []
}

variable "trusted_oidc_provider_arn" {
  type        = string
  description = "OIDC provider ARN for web identity federation."
  default     = null
}

variable "trusted_oidc_subjects" {
  type        = list(string)
  description = "Allowed OIDC token subject claims."
  default     = []
}

variable "trusted_oidc_audiences" {
  type        = list(string)
  description = "Allowed OIDC token audience claims."
  default     = ["sts.amazonaws.com"]
}

variable "allow_administrator_access" {
  type        = bool
  description = "Whether to attach AdministratorAccess for maximum flexibility."
  default     = true
}

variable "managed_policy_arns" {
  type        = list(string)
  description = "Additional managed policy ARNs to attach to the role."
  default     = []
}

variable "inline_policy_json" {
  type        = string
  description = "Optional additional inline policy JSON document."
  default     = null
}

variable "tags" {
  type        = map(string)
  description = "Tags to apply to the IAM role."
  default     = {}
}

locals {
  oidc_provider_url = var.trusted_oidc_provider_arn != null ? replace(var.trusted_oidc_provider_arn, "arn:${data.aws_partition.current.partition}:iam::${data.aws_caller_identity.current.account_id}:oidc-provider/", "") : null

  assume_role_statements = concat(
    length(var.trusted_principal_arns) > 0 ? [
      {
        Sid    = "AllowAwsPrincipals"
        Effect = "Allow"
        Action = "sts:AssumeRole"
        Principal = {
          AWS = var.trusted_principal_arns
        }
      }
    ] : [],
    length(var.trusted_service_principals) > 0 ? [
      {
        Sid    = "AllowServicePrincipals"
        Effect = "Allow"
        Action = "sts:AssumeRole"
        Principal = {
          Service = var.trusted_service_principals
        }
      }
    ] : [],
    var.trusted_oidc_provider_arn != null ? [
      {
        Sid    = "AllowWebIdentity"
        Effect = "Allow"
        Action = "sts:AssumeRoleWithWebIdentity"
        Principal = {
          Federated = var.trusted_oidc_provider_arn
        }
        Condition = merge(
          length(var.trusted_oidc_subjects) > 0 ? {
            StringLike = {
              "${local.oidc_provider_url}:sub" = var.trusted_oidc_subjects
            }
          } : {},
          length(var.trusted_oidc_audiences) > 0 ? {
            StringEquals = {
              "${local.oidc_provider_url}:aud" = var.trusted_oidc_audiences
            }
          } : {}
        )
      }
    ] : []
  )
}

resource "aws_iam_role" "this" {
  name                 = var.name
  path                 = var.path
  description          = var.description
  max_session_duration = var.max_session_duration
  assume_role_policy   = jsonencode({
    Version   = "2012-10-17"
    Statement = local.assume_role_statements
  })
  permissions_boundary = var.permissions_boundary_arn
  tags                 = var.tags
}

resource "aws_iam_role_policy_attachment" "administrator_access" {
  count      = var.allow_administrator_access ? 1 : 0
  role       = aws_iam_role.this.name
  policy_arn = "arn:${data.aws_partition.current.partition}:iam::aws:policy/AdministratorAccess"
}

resource "aws_iam_role_policy_attachment" "managed" {
  for_each   = toset(var.managed_policy_arns)
  role       = aws_iam_role.this.name
  policy_arn = each.value
}

resource "aws_iam_role_policy" "inline" {
  count  = var.inline_policy_json != null ? 1 : 0
  name   = "${var.name}-inline"
  role   = aws_iam_role.this.id
  policy = var.inline_policy_json
}

output "role_name" {
  value = aws_iam_role.this.name
}

output "role_arn" {
  value = aws_iam_role.this.arn
}

output "role_id" {
  value = aws_iam_role.this.id
}