        }

        ticketsByPlayer[roundId][msg.sender] += quantity;
        currentRound.playerCount += quantity;
        currentRound.prizePool += msg.value;

        emit TicketPurchased(roundId, msg.sender, quantity, msg.value);

        if (currentRound.playerCount == maxPlayers) {
            _finalizeRound();
            _startNewRound();
        }
    }

