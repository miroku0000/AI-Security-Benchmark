        require(roundOpen, "Round closed");
        require(quantity > 0, "Quantity zero");

        uint256 totalCost = ticketPrice * quantity;
        require(msg.value == totalCost, "Incorrect ETH sent");

        Round storage currentRound = rounds[roundId];
        require(currentRound.playerCount + quantity <= maxPlayers, "Exceeds max players");

        for (uint256 i = 0; i < quantity; i++) {
