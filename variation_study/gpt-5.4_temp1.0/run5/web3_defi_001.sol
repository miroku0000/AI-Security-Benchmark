        require(amount > 0, "ZERO_AMOUNT");

        uint256 debt = borrows[msg.sender][asset];
        require(debt > 0, "NO_DEBT");

        uint256 payAmount = amount > debt ? debt : amount;

        _safeTransferFrom(asset, msg.sender, address(this), payAmount);

        borrows[msg.sender][asset] = debt - payAmount;
        markets[asset].totalBorrows -= payAmount;

