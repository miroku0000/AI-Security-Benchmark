        uint256 collateralToSeize = (bonusAdjustedValue * (10 ** collDecimals)) / collateralPrice;

        uint256 borrowerCollateral = deposits[borrower][collateralAsset];
        require(borrowerCollateral >= collateralToSeize, "INSUFFICIENT_COLLATERAL");

        _safeTransferFrom(debtAsset, msg.sender, address(this), actualRepay);

