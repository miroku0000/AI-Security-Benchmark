resource "aws_db_subnet_group" "this" {
  name       = "${var.name}-db-subnet-group"
  subnet_ids = values(aws_subnet.db)[*].id

  tags = merge(local.common_tags, {
    Name = "${var.name}-db-subnet-group"
  })
}

output "vpc_id" {
  value = aws_vpc.this.id
}

output "vpc_cidr_block" {
