pragma solidity ^0.8.20;

interface IERC20 {
    function totalSupply() external view returns (uint256);
    function balanceOf(address account) external view returns (uint256);
    function allowance(address owner, address spender) external view returns (uint256);
    function transfer(address to, uint256 amount) external returns (bool);
    function approve(address spender, uint256 amount) external returns (bool);
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
    function decimals() external view returns (uint8);
}

interface IUniswapV2Pair {
    function token0() external view returns (address);
    function token1() external view returns (address);
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32);
}

contract DexPriceLending {
    uint256 public constant BPS = 10_000;
    uint256 public constant WAD = 1e18;

    address public owner;
    address public immutable baseAsset;

    struct Market {
        bool enabled;
        address dexPair;
        uint16 collateralFactorBps;
        uint16 liquidationThresholdBps;
        uint16 liquidationBonusBps;
        uint256 totalDeposits;
        uint256 totalBorrows;
    }

    mapping(address => Market) public markets;
    address[] public supportedAssets;

    mapping(address => mapping(address => uint256)) public deposits;
    mapping(address => mapping(address => uint256)) public borrows;

    event MarketConfigured(
        address indexed asset,
        address indexed dexPair,
        uint16 collateralFactorBps,
        uint16 liquidationThresholdBps,
        uint16 liquidationBonusBps
    );
    event Deposited(address indexed user, address indexed asset, uint256 amount);
    event Withdrawn(address indexed user, address indexed asset, uint256 amount);
    event Borrowed(address indexed user, address indexed asset, uint256 amount);
    event Repaid(address indexed payer, address indexed borrower, address indexed asset, uint256 amount);
    event Liquidated(
        address indexed liquidator,
        address indexed borrower,
        address indexed debtAsset,
        address collateralAsset,
        uint256 repaidAmount,
        uint256 seizedCollateral
    );
    event OwnershipTransferred(address indexed oldOwner, address indexed newOwner);

    modifier onlyOwner() {
        require(msg.sender == owner, "NOT_OWNER");
        _;
    }

    modifier validAsset(address asset) {
        require(markets[asset].enabled, "ASSET_NOT_SUPPORTED");
        _;
    }

    constructor(address _baseAsset) {
        require(_baseAsset != address(0), "ZERO_BASE");
        owner = msg.sender;
        baseAsset = _baseAsset;
        emit OwnershipTransferred(address(0), msg.sender);
    }

    function transferOwnership(address newOwner) external onlyOwner {
        require(newOwner != address(0), "ZERO_OWNER");
        emit OwnershipTransferred(owner, newOwner);
        owner = newOwner;
    }

    function configureMarket(
        address asset,
        address dexPair,
        uint16 collateralFactorBps,
        uint16 liquidationThresholdBps,
        uint16 liquidationBonusBps
    ) external onlyOwner {
        require(asset != address(0) && dexPair != address(0), "ZERO_ADDRESS");
        require(collateralFactorBps <= liquidationThresholdBps, "BAD_FACTORS");
        require(liquidationThresholdBps <= BPS, "BAD_LT");
        require(liquidationBonusBps <= 2_000, "BONUS_TOO_HIGH");

        IUniswapV2Pair pair = IUniswapV2Pair(dexPair);
        address t0 = pair.token0();
        address t1 = pair.token1();
        require(
            (t0 == asset && t1 == baseAsset) || (t1 == asset && t0 == baseAsset),
            "PAIR_MISMATCH"
        );

        if (!markets[asset].enabled) {
            supportedAssets.push(asset);
        }

        markets[asset] = Market({
            enabled: true,
            dexPair: dexPair,
            collateralFactorBps: collateralFactorBps,
            liquidationThresholdBps: liquidationThresholdBps,
            liquidationBonusBps: liquidationBonusBps,
            totalDeposits: markets[asset].totalDeposits,
            totalBorrows: markets[asset].totalBorrows
        });

        emit MarketConfigured(asset, dexPair, collateralFactorBps, liquidationThresholdBps, liquidationBonusBps);
    }

    function deposit(address asset, uint256 amount) external validAsset(asset) {
        require(amount > 0, "ZERO_AMOUNT");
        _safeTransferFrom(asset, msg.sender, address(this), amount);
        deposits[msg.sender][asset] += amount;
        markets[asset].totalDeposits += amount;
        emit Deposited(msg.sender, asset, amount);
    }

    function withdraw(address asset, uint256 amount) external validAsset(asset) {
        require(amount > 0, "ZERO_AMOUNT");
        require(deposits[msg.sender][asset] >= amount, "INSUFFICIENT_DEPOSIT");

        deposits[msg.sender][asset] -= amount;
        markets[asset].totalDeposits -= amount;

        require(_isSolvent(msg.sender), "WOULD_BE_UNDERCOLLATERALIZED");
        require(IERC20(asset).balanceOf(address(this)) >= amount, "INSUFFICIENT_LIQUIDITY");

        _safeTransfer(asset, msg.sender, amount);
        emit Withdrawn(msg.sender, asset, amount);
    }

    function borrow(address asset, uint256 amount) external validAsset(asset) {
        require(amount > 0, "ZERO_AMOUNT");
        require(IERC20(asset).balanceOf(address(this)) >= amount, "INSUFFICIENT_LIQUIDITY");

        borrows[msg.sender][asset] += amount;
        markets[asset].totalBorrows += amount;

        require(_isSolvent(msg.sender), "INSUFFICIENT_COLLATERAL");

        _safeTransfer(asset, msg.sender, amount);
        emit Borrowed(msg.sender, asset, amount);
    }

    function repay(address asset, uint256 amount) external validAsset(asset) {
        _repayFor(msg.sender, asset, amount);
    }

    function repayFor(address borrower, address asset, uint256 amount) external validAsset(asset) {
        _repayFor(borrower, asset, amount);
    }

    function liquidate(
        address borrower,
        address debtAsset,
        address collateralAsset,
        uint256 repayAmount
    ) external validAsset(debtAsset) validAsset(collateralAsset) {
        require(borrower != address(0) && borrower != msg.sender, "BAD_BORROWER");
        require(repayAmount > 0, "ZERO_AMOUNT");
        require(!_isAboveLiquidationThreshold(borrower), "BORROWER_HEALTHY");

        uint256 borrowerDebt = borrows[borrower][debtAsset];
        require(borrowerDebt > 0, "NO_DEBT");

        if (repayAmount > borrowerDebt) {
            repayAmount = borrowerDebt;
        }

        uint256 debtValueBase = _assetToBaseValue(debtAsset, repayAmount);
        uint256 bonusBps = markets[collateralAsset].liquidationBonusBps;
        uint256 seizeValueBase = debtValueBase + ((debtValueBase * bonusBps) / BPS);
        uint256 seizeAmount = _baseValueToAssetAmount(collateralAsset, seizeValueBase);

        uint256 availableCollateral = deposits[borrower][collateralAsset];
        require(availableCollateral > 0, "NO_COLLATERAL");

        if (seizeAmount > availableCollateral) {
            seizeAmount = availableCollateral;
            uint256 adjustedSeizeBase = _assetToBaseValue(collateralAsset, seizeAmount);
            uint256 maxDebtValueNoBonus = (adjustedSeizeBase * BPS) / (BPS + bonusBps);
            uint256 adjustedRepayAmount = _baseValueToAssetAmount(debtAsset, maxDebtValueNoBonus);
            if (adjustedRepayAmount < repayAmount) {
                repayAmount = adjustedRepayAmount;
            }
        }

        require(repayAmount > 0 && seizeAmount > 0, "NOTHING_TO_LIQUIDATE");

        _safeTransferFrom(debtAsset, msg.sender, address(this), repayAmount);

        borrows[borrower][debtAsset] -= repayAmount;
        markets[debtAsset].totalBorrows -= repayAmount;

        deposits[borrower][collateralAsset] -= seizeAmount;
        markets[collateralAsset].totalDeposits -= seizeAmount;

        _safeTransfer(collateralAsset, msg.sender, seizeAmount);

        emit Liquidated(msg.sender, borrower, debtAsset, collateralAsset, repayAmount, seizeAmount);
    }

    function getPriceInBase(address asset) public view validAsset(asset) returns (uint256 priceWad) {
        if (asset == baseAsset) {
            return WAD;
        }

        Market memory m = markets[asset];
        IUniswapV2Pair pair = IUniswapV2Pair(m.dexPair);
        (uint112 r0, uint112 r1,) = pair.getReserves();
        require(r0 > 0 && r1 > 0, "EMPTY_POOL");

        address t0 = pair.token0();
        uint8 assetDecimals = IERC20(asset).decimals();
        uint8 baseDecimals = IERC20(baseAsset).decimals();

        if (t0 == asset) {
            priceWad =
                (uint256(r1) * (10 ** assetDecimals) * WAD) /
                (uint256(r0) * (10 ** baseDecimals));
        } else {
            priceWad =
                (uint256(r0) * (10 ** assetDecimals) * WAD) /
                (uint256(r1) * (10 ** baseDecimals));
        }
    }

    function accountLiquidity(address user) external view returns (uint256 collateralValueBase, uint256 borrowValueBase) {
        collateralValueBase = _totalCollateralValue(user);
        borrowValueBase = _totalBorrowValue(user);
    }

    function accountLiquidityThreshold(address user) external view returns (uint256 collateralAtLiquidationBase, uint256 borrowValueBase) {
        collateralAtLiquidationBase = _totalCollateralValueAtLiquidation(user);
        borrowValueBase = _totalBorrowValue(user);
    }

    function healthFactor(address user) external view returns (uint256) {
        uint256 debt = _totalBorrowValue(user);
        if (debt == 0) return type(uint256).max;
        return (_totalCollateralValueAtLiquidation(user) * WAD) / debt;
    }

    function maxBorrowableInAsset(address user, address asset) external view validAsset(asset) returns (uint256) {
        uint256 collateral = _totalCollateralValue(user);
        uint256 debt = _totalBorrowValue(user);
        if (collateral <= debt) return 0;
        uint256 remainingBase = collateral - debt;
        return _baseValueToAssetAmount(asset, remainingBase);
    }

    function supportedAssetsLength() external view returns (uint256) {
        return supportedAssets.length;
    }

    function _repayFor(address borrower, address asset, uint256 amount) internal {
        require(borrower != address(0), "ZERO_BORROWER");
        uint256 debt = borrows[borrower][asset];
        require(debt > 0, "NO_DEBT");
        require(amount > 0, "ZERO_AMOUNT");

        if (amount > debt) {
            amount = debt;
        }

        _safeTransferFrom(asset, msg.sender, address(this), amount);
        borrows[borrower][asset] -= amount;
        markets[asset].totalBorrows -= amount;

        emit Repaid(msg.sender, borrower, asset, amount);
    }

    function _totalCollateralValue(address user) internal view returns (uint256 totalBaseValue) {
        uint256 len = supportedAssets.length;
        for (uint256 i = 0; i < len; ++i) {
            address asset = supportedAssets[i];
            uint256 amount = deposits[user][asset];
            if (amount == 0) continue;
            uint256 valueBase = _assetToBaseValue(asset, amount);
            totalBaseValue += (valueBase * markets[asset].collateralFactorBps) / BPS;
        }
    }

    function _totalCollateralValueAtLiquidation(address user) internal view returns (uint256 totalBaseValue) {
        uint256 len = supportedAssets.length;
        for (uint256 i = 0; i < len; ++i) {
            address asset = supportedAssets[i];
            uint256 amount = deposits[user][asset];
            if (amount == 0) continue;
            uint256 valueBase = _assetToBaseValue(asset, amount);
            totalBaseValue += (valueBase * markets[asset].liquidationThresholdBps) / BPS;
        }
    }

    function _totalBorrowValue(address user) internal view returns (uint256 totalBaseValue) {
        uint256 len = supportedAssets.length;
        for (uint256 i = 0; i < len; ++i) {
            address asset = supportedAssets[i];
            uint256 amount = borrows[user][asset];
            if (amount == 0) continue;
            totalBaseValue += _assetToBaseValue(asset, amount);
        }
    }

    function _isSolvent(address user) internal view returns (bool) {
        return _totalCollateralValue(user) >= _totalBorrowValue(user);
    }

    function _isAboveLiquidationThreshold(address user) internal view returns (bool) {
        return _totalCollateralValueAtLiquidation(user) >= _totalBorrowValue(user);
    }

    function _assetToBaseValue(address asset, uint256 amount) internal view returns (uint256) {
        uint256 price = asset == baseAsset ? WAD : getPriceInBase(asset);
        uint8 decimals = IERC20(asset).decimals();
        return (amount * price) / (10 ** decimals);
    }

    function _baseValueToAssetAmount(address asset, uint256 baseValue) internal view returns (uint256) {
        uint256 price = asset == baseAsset ? WAD : getPriceInBase(asset);
        uint8 decimals = IERC20(asset).decimals();
        return (baseValue * (10 ** decimals)) / price;
    }

    function _safeTransfer(address token, address to, uint256 amount) internal {
        (bool success, bytes memory data) = token.call(
            abi.encodeWithSelector(IERC20.transfer.selector, to, amount)
        );
        require(success && (data.length == 0 || abi.decode(data, (bool))), "TRANSFER_FAILED");
    }

    function _safeTransferFrom(address token, address from, address to, uint256 amount) internal {
        (bool success, bytes memory data) = token.call(
            abi.encodeWithSelector(IERC20.transferFrom.selector, from, to, amount)
        );
        require(success && (data.length == 0 || abi.decode(data, (bool))), "TRANSFER_FROM_FAILED");
    }
}