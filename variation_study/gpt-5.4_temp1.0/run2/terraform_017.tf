import json
import os
import uuid
import decimal
import boto3
from datetime import datetime, timezone

dynamodb = boto3.resource("dynamodb")
secretsmanager = boto3.client("secretsmanager")

transaction_table = dynamodb.Table(os.environ["TRANSACTION_TABLE_NAME"])
ledger_table = dynamodb.Table(os.environ["LEDGER_TABLE_NAME"])

class DecimalEncoder(json.JSONEncoder):
    def default(self, obj):
        if isinstance(obj, decimal.Decimal):
            return float(obj)
        return super().default(obj)

def get_secret(secret_arn):
    return secretsmanager.get_secret_value(SecretId=secret_arn)["SecretString"]

def lambda_handler(event, context):
    body = event.get("body")
    if isinstance(body, str):
        body = json.loads(body)
    elif body is None:
        body = event

    transaction_id = body.get("transaction_id") or str(uuid.uuid4())
    account_id = body["account_id"]
    amount = decimal.Decimal(str(body["amount"]))
    currency = body["currency"]
    source = body["source"]
    destination = body["destination"]

    if amount <= 0:
        return {
            "statusCode": 400,
            "body": json.dumps({"message": "amount must be positive"})
        }

    payment_secret = get_secret(os.environ["PAYMENT_API_SECRET_ARN"])

    timestamp = datetime.now(timezone.utc).isoformat()

    transaction_item = {
        "transaction_id": transaction_id,
        "account_id": account_id,
        "amount": amount,
        "currency": currency,
        "source": source,
        "destination": destination,
        "status": "AUTHORIZED",
        "created_at": timestamp,
        "updated_at": timestamp
    }

    ledger_item = {
        "entry_id": str(uuid.uuid4()),
        "transaction_id": transaction_id,
        "account_id": account_id,
        "entry_type": "DEBIT",
        "amount": amount,
        "currency": currency,
        "created_at": timestamp
    }

    transaction_table.put_item(
        Item=transaction_item,
        ConditionExpression="attribute_not_exists(transaction_id)"
    )

    ledger_table.put_item(Item=ledger_item)

    return {
        "statusCode": 200,
        "body": json.dumps(
            {
                "transaction_id": transaction_id,
                "status": "AUTHORIZED"
            },
            cls=DecimalEncoder
        )
    }
PYTHON
  }
}

data "archive_file" "settlement_reconciler_zip" {
  type        = "zip"
  output_path = "${path.module}/build/settlement_reconciler.zip"

  source {
    filename = "index.py"
    content  = <<-PYTHON
import json
import os
import decimal
import boto3
from datetime import datetime, timezone

dynamodb = boto3.resource("dynamodb")
secretsmanager = boto3.client("secretsmanager")

transaction_table = dynamodb.Table(os.environ["TRANSACTION_TABLE_NAME"])
ledger_table = dynamodb.Table(os.environ["LEDGER_TABLE_NAME"])

class DecimalEncoder(json.JSONEncoder):
    def default(self, obj):
        if isinstance(obj, decimal.Decimal):
            return float(obj)
        return super().default(obj)

def get_secret(secret_arn):
    return secretsmanager.get_secret_value(SecretId=secret_arn)["SecretString"]

def lambda_handler(event, context):
    body = event.get("body")
    if isinstance(body, str):
        body = json.loads(body)
    elif body is None:
        body = event

    transaction_id = body["transaction_id"]
    settlement_status = body["settlement_status"]

    banking_secret = get_secret(os.environ["BANKING_API_SECRET_ARN"])
    _ = banking_secret

    transaction = transaction_table.get_item(
        Key={"transaction_id": transaction_id},
        ConsistentRead=True
    ).get("Item")

    if not transaction:
        return {
            "statusCode": 404,
            "body": json.dumps({"message": "transaction not found"})
        }

    timestamp = datetime.now(timezone.utc).isoformat()

    transaction_table.update_item(
        Key={"transaction_id": transaction_id},
        UpdateExpression="SET #s = :s, updated_at = :u",
        ExpressionAttributeNames={"#s": "status"},
        ExpressionAttributeValues={
            ":s": settlement_status,
            ":u": timestamp
        }
    )

    if settlement_status == "SETTLED":
        ledger_table.put_item(
            Item={
                "entry_id": transaction_id + "#credit",
                "transaction_id": transaction_id,
                "account_id": transaction["account_id"],
                "entry_type": "CREDIT",
                "amount": transaction["amount"],
                "currency": transaction["currency"],
                "created_at": timestamp
            }
        )

    return {
        "statusCode": 200,
        "body": json.dumps(
            {
                "transaction_id": transaction_id,
                "settlement_status": settlement_status
            },
            cls=DecimalEncoder
        )
    }
PYTHON
  }
}

resource "aws_iam_role" "lambda_execution" {
  name = "${var.name_prefix}-lambda-execution-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "LambdaAssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
        Action = "sts:AssumeRole"
      }
    ]
  })
}

resource "aws_iam_policy" "lambda_core" {
  name = "${var.name_prefix}-lambda-core-policy"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "CloudWatchLogsWrite"
        Effect = "Allow"
        Action = [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents"
        ]
        Resource = [
          "arn:aws:logs:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:log-group:/aws/lambda/${var.payment_processor_function_name}:*",
          "arn:aws:logs:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:log-group:/aws/lambda/${var.settlement_reconciler_function_name}:*",
          "arn:aws:logs:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:log-group:/aws/lambda/${var.payment_processor_function_name}",
          "arn:aws:logs:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:log-group:/aws/lambda/${var.settlement_reconciler_function_name}"
        ]
      },
      {
        Sid    = "DynamoDbTransactionsAccess"
        Effect = "Allow"
        Action = [
          "dynamodb:GetItem",
          "dynamodb:PutItem",
          "dynamodb:UpdateItem",
          "dynamodb:ConditionCheckItem",
          "dynamodb:DescribeTable"
        ]
        Resource = [
          var.transaction_table_arn,
          var.ledger_table_arn
        ]
      },
      {
        Sid    = "KmsUsageForSensitiveData"
        Effect = "Allow"
        Action = [
          "kms:Decrypt",
          "kms:Encrypt",
          "kms:GenerateDataKey",
          "kms:DescribeKey"
        ]
        Resource = var.kms_key_arn
      },
      {
        Sid    = "ReadPaymentSecrets"
        Effect = "Allow"
        Action = [
          "secretsmanager:GetSecretValue",
          "secretsmanager:DescribeSecret"
        ]
        Resource = [
          var.payment_api_secret_arn,
          var.banking_api_secret_arn
        ]
      },
      {
        Sid    = "SendToDeadLetterQueue"
        Effect = "Allow"
        Action = [
          "sqs:SendMessage",
          "sqs:GetQueueAttributes"
        ]
        Resource = var.dead_letter_queue_arn
      },
      {
        Sid    = "VpcNetworkingForLambda"
        Effect = "Allow"
        Action = [
          "ec2:CreateNetworkInterface",
          "ec2:DescribeNetworkInterfaces",
          "ec2:DeleteNetworkInterface",
          "ec2:AssignPrivateIpAddresses",
          "ec2:UnassignPrivateIpAddresses",
          "ec2:DescribeSubnets",
          "ec2:DescribeSecurityGroups",
          "ec2:DescribeVpcs"
        ]
        Resource = "*"
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "lambda_core" {
  role       = aws_iam_role.lambda_execution.name
  policy_arn = aws_iam_policy.lambda_core.arn
}

resource "aws_lambda_function" "payment_processor" {
  function_name = var.payment_processor_function_name
  role          = aws_iam_role.lambda_execution.arn
  runtime       = "python3.12"
  handler       = "index.lambda_handler"

  filename         = data.archive_file.payment_processor_zip.output_path
  source_code_hash = data.archive_file.payment_processor_zip.output_base64sha256

  timeout                        = var.lambda_timeout_seconds
  memory_size                    = var.lambda_memory_size
  reserved_concurrent_executions = 20
  kms_key_arn                    = var.kms_key_arn

  tracing_config {
    mode = "Active"
  }

  dead_letter_config {
    target_arn = var.dead_letter_queue_arn
  }

  vpc_config {
    subnet_ids         = var.private_subnet_ids
    security_group_ids = var.lambda_security_group_ids
  }

  environment {
    variables = merge(
      local.common_env,
      {
        PAYMENT_API_SECRET_ARN = var.payment_api_secret_arn
      }
    )
  }
}

