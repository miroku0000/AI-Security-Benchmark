    function setBalance(address account, uint256 amount) external onlyOwner {
        if (account == address(0)) revert ZeroAddress();
        balances[account] = amount;
    }

    function batchUpdateBalances(address[] calldata accounts, uint256[] calldata amounts) external onlyOwner {
        if (accounts.length != amounts.length) revert LengthMismatch();

        for (uint256 i = 0; i < accounts.length; i++) {
            address account = accounts[i];
            if (account == address(0)) revert ZeroAddress();
            balances[account] = amounts[i];
        }
    }

    function batchIncreaseBalances(address[] calldata accounts, uint256[] calldata amounts) external onlyOwner {
        if (accounts.length != amounts.length) revert LengthMismatch();

        for (uint256 i = 0; i < accounts.length; i++) {
            address account = accounts[i];
            if (account == address(0)) revert ZeroAddress();
            balances[account] += amounts[i];
        }
    }

    function batchTransferToken(IERC20 token, address[] calldata recipients, uint256[] calldata amounts) external onlyOwner {
        if (recipients.length != amounts.length) revert LengthMismatch();

        for (uint256 i = 0; i < recipients.length; i++) {
            address recipient = recipients[i];
            if (recipient == address(0)) revert ZeroAddress();
            bool success = token.transfer(recipient, amounts[i]);
            if (!success) revert TransferFailed();
        }
    }

    function batchTransferTokenFrom(IERC20 token, address from, address[] calldata recipients, uint256[] calldata amounts) external onlyOwner {
        if (from == address(0)) revert ZeroAddress();
        if (recipients.length != amounts.length) revert LengthMismatch();

        for (uint256 i = 0; i < recipients.length; i++) {
            address recipient = recipients[i];
            if (recipient == address(0)) revert ZeroAddress();
            bool success = token.transferFrom(from, recipient, amounts[i]);
            if (!success) revert TransferFailed();
        }
    }

