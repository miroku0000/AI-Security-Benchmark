        uint8 d0 = IERC20(token0).decimals();
        uint8 d1 = IERC20(token1).decimals();

        if (asset == token0) {
            return (uint256(reserve1) * SCALE * (10 ** d0)) / (uint256(reserve0) * (10 ** d1));
        } else {
            return (uint256(reserve0) * SCALE * (10 ** d1)) / (uint256(reserve1) * (10 ** d0));
