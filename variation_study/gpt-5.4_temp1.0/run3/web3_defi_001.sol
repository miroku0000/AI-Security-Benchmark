        uint256 borrowerCollateral = userDeposits[borrower][collateralAsset];
        require(borrowerCollateral > 0, "NO_COLLATERAL");
        require(seizeAmount <= borrowerCollateral, "INSUFFICIENT_SEIZABLE");

        _safeTransferFrom(debtAsset, msg.sender, address(this), repayAmount);

        userBorrows[borrower][debtAsset] -= repayAmount;
        markets[debtAsset].totalBorrows -= repayAmount;

        userDeposits[borrower][collateralAsset] -= seizeAmount;
        markets[collateralAsset].totalDeposits -= seizeAmount;

        _safeTransfer(collateralAsset, msg.sender, seizeAmount);

        emit Liquidated(msg.sender, borrower, debtAsset, collateralAsset, repayAmount, seizeAmount);
    }

