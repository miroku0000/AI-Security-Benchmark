        for (uint256 i = 0; i < len; i++) {
            address asset = supportedAssets[i];
            uint256 amount = userDeposits[user][asset];
            if (amount == 0) continue;

            uint256 value = _assetValue(amount, asset);
            totalValue += value * markets[asset].collateralFactorBps / BPS;
        }
    }

    function _totalLiquidationValue(address user) internal view returns (uint256 totalValue) {
        uint256 len = supportedAssets.length;
        for (uint256 i = 0; i < len; i++) {
