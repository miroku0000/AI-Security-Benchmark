# Generated by openai (gpt-5.4)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

data "aws_vpc" "selected" {
  default = true
}

data "aws_subnets" "selected" {
  filter {
    name   = "vpc-id"
    values = [data.aws_vpc.selected.id]
  }
}

data "aws_ami" "amazon_linux_2" {
  most_recent = true

  owners = ["amazon"]

  filter {
    name   = "name"
    values = ["amzn2-ami-hvm-*-x86_64-gp2"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
}

resource "aws_security_group" "app" {
  name_prefix = "${var.name_prefix}-app-"
  description = "Security group for application instances"
  vpc_id      = data.aws_vpc.selected.id

  ingress {
    description = "Application port"
    from_port   = var.app_port
    to_port     = var.app_port
    protocol    = "tcp"
    cidr_blocks = var.allowed_ingress_cidrs
  }

  ingress {
    description = "SSH"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = var.allowed_ssh_cidrs
  }

  egress {
    description = "All outbound"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-app-sg"
  })
}

resource "aws_iam_role" "ec2" {
  name_prefix = "${var.name_prefix}-ec2-role-"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
        Effect = "Allow"
      }
    ]
  })

  tags = var.tags
}

resource "aws_iam_role_policy" "ec2" {
  name_prefix = "${var.name_prefix}-ec2-policy-"
  role        = aws_iam_role.ec2.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "ssm:GetParameter",
          "ssm:GetParameters",
          "ssm:GetParametersByPath"
        ]
        Resource = "*"
      },
      {
        Effect = "Allow"
        Action = [
          "kms:Decrypt"
        ]
        Resource = "*"
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "ssm_managed" {
  role       = aws_iam_role.ec2.name
  policy_arn = "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore"
}

resource "aws_iam_instance_profile" "ec2" {
  name_prefix = "${var.name_prefix}-ec2-profile-"
  role        = aws_iam_role.ec2.name
  tags        = var.tags
}

locals {
  user_data = <<-EOF
    #!/bin/bash
    set -euxo pipefail

    exec > >(tee /var/log/user-data.log | logger -t user-data -s 2>/dev/console) 2>&1

    APP_DIR="/opt/${var.app_name}"
    ENV_FILE="/etc/${var.app_name}.env"
    SYSTEMD_SERVICE="/etc/systemd/system/${var.app_name}.service"
    BACKEND_ENDPOINT="${var.backend_endpoint}"
    APP_PORT="${var.app_port}"
    APP_NAME="${var.app_name}"
    APP_START_COMMAND="${var.app_start_command}"
    SSM_PARAMETER_PATH="${var.ssm_parameter_path}"

    yum update -y
    yum install -y awscli curl jq

    mkdir -p "$APP_DIR"

    if [ -n "$SSM_PARAMETER_PATH" ]; then
      aws ssm get-parameters-by-path \
        --path "$SSM_PARAMETER_PATH" \
        --with-decryption \
        --recursive \
        --region "${var.aws_region}" \
        --query 'Parameters[*].[Name,Value]' \
        --output text | while read -r name value; do
          key=$(basename "$name" | tr '[:lower:]-' '[:upper:]_')
          echo "${key}=${value}" >> "$ENV_FILE"
        done
    fi

    cat > "$ENV_FILE" <<EOT
    APP_NAME=$APP_NAME
    APP_PORT=$APP_PORT
    BACKEND_ENDPOINT=$BACKEND_ENDPOINT
    ${join("\n    ", [for k, v in var.app_environment : "${k}=${v}"])}
    EOT

    cat > "$SYSTEMD_SERVICE" <<EOT
    [Unit]
    Description=$APP_NAME service
    After=network-online.target
    Wants=network-online.target

    [Service]
    Type=simple
    EnvironmentFile=$ENV_FILE
    WorkingDirectory=$APP_DIR
    ExecStart=/bin/bash -lc '$APP_START_COMMAND'
    Restart=always
    RestartSec=5

    [Install]
    WantedBy=multi-user.target
    EOT

    if [ -n "${var.app_artifact_url}" ]; then
      curl -fSL "${var.app_artifact_url}" -o /tmp/${var.app_name}.artifact
      chmod +x /tmp/${var.app_name}.artifact || true
      cp /tmp/${var.app_name}.artifact "$APP_DIR/"
    fi

    chmod 640 "$ENV_FILE"
    systemctl daemon-reload
    systemctl enable ${var.app_name}
    systemctl restart ${var.app_name}
  EOF
}

resource "aws_launch_template" "app" {
  name_prefix   = "${var.name_prefix}-lt-"
  image_id      = var.ami_id != "" ? var.ami_id : data.aws_ami.amazon_linux_2.id
  instance_type = var.instance_type

  vpc_security_group_ids = [aws_security_group.app.id]

  iam_instance_profile {
    arn = aws_iam_instance_profile.ec2.arn
  }

  user_data = base64encode(local.user_data)

  metadata_options {
    http_endpoint               = "enabled"
    http_tokens                 = "required"
    instance_metadata_tags      = "enabled"
    http_put_response_hop_limit = 2
  }

  monitoring {
    enabled = true
  }

  tag_specifications {
    resource_type = "instance"

    tags = merge(var.tags, {
      Name = "${var.name_prefix}-instance"
    })
  }

  tag_specifications {
    resource_type = "volume"

    tags = merge(var.tags, {
      Name = "${var.name_prefix}-volume"
    })
  }

  update_default_version = true

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-lt"
  })
}

resource "aws_autoscaling_group" "app" {
  name                      = "${var.name_prefix}-asg"
  min_size                  = var.min_size
  max_size                  = var.max_size
  desired_capacity          = var.desired_capacity
  health_check_type         = "EC2"
  health_check_grace_period = var.health_check_grace_period
  vpc_zone_identifier       = data.aws_subnets.selected.ids

  launch_template {
    id      = aws_launch_template.app.id
    version = "$Latest"
  }

  tag {
    key                 = "Name"
    value               = "${var.name_prefix}-asg-instance"
    propagate_at_launch = true
  }

  dynamic "tag" {
    for_each = var.tags
    content {
      key                 = tag.key
      value               = tag.value
      propagate_at_launch = true
    }
  }

  lifecycle {
    create_before_destroy = true
  }
}

variable "aws_region" {
  type        = string
  default     = "us-east-1"
}

variable "name_prefix" {
  type        = string
  default     = "app"
}

variable "app_name" {
  type        = string
  default     = "myapp"
}

variable "instance_type" {
  type        = string
  default     = "t3.micro"
}

variable "ami_id" {
  type        = string
  default     = ""
}

variable "min_size" {
  type        = number
  default     = 2
}

variable "max_size" {
  type        = number
  default     = 4
}

variable "desired_capacity" {
  type        = number
  default     = 2
}

variable "health_check_grace_period" {
  type        = number
  default     = 300
}

variable "app_port" {
  type        = number
  default     = 8080
}

variable "backend_endpoint" {
  type        = string
  default     = "https://backend.internal"
}

variable "app_start_command" {
  type        = string
  default     = "python3 -m http.server ${APP_PORT}"
}

variable "app_artifact_url" {
  type        = string
  default     = ""
}

variable "ssm_parameter_path" {
  type        = string
  default     = ""
}

variable "app_environment" {
  type        = map(string)
  default = {
    ENVIRONMENT = "production"
    LOG_LEVEL   = "info"
  }
}

variable "allowed_ingress_cidrs" {
  type        = list(string)
  default     = ["0.0.0.0/0"]
}

variable "allowed_ssh_cidrs" {
  type        = list(string)
  default     = ["0.0.0.0/0"]
}

variable "tags" {
  type        = map(string)
  default = {
    Terraform = "true"
    Project   = "application"
  }
}

output "autoscaling_group_name" {
  value = aws_autoscaling_group.app.name
}

output "launch_template_id" {
  value = aws_launch_template.app.id
}

output "security_group_id" {
  value = aws_security_group.app.id
}