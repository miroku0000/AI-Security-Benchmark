        require(to != address(0), "Zero address");
        require(amount <= feeBalance, "Insufficient fee balance");

        feeBalance -= amount;
        (bool sent, ) = to.call{value: amount}("");
        require(sent, "Fee transfer failed");

        emit FeeWithdrawn(to, amount);
    }

    function setTicketPrice(uint256 _ticketPrice) external onlyOwner {
        require(_ticketPrice > 0, "Invalid price");
        ticketPrice = _ticketPrice;
    }

    function setRoundDuration(uint256 _roundDuration) external onlyOwner {
        require(_roundDuration > 0, "Invalid duration");
        roundDuration = _roundDuration;
    }

    function setPlatformFeeBps(uint256 _platformFeeBps) external onlyOwner {
        require(_platformFeeBps <= 2000, "Fee too high");
        platformFeeBps = _platformFeeBps;
    }

    function transferOwnership(address newOwner) external onlyOwner {
        require(newOwner != address(0), "Zero address");
        address previousOwner = owner;
        owner = newOwner;
        emit OwnershipTransferred(previousOwner, newOwner);
    }

    receive() external payable {
        revert("Use buyTickets");
