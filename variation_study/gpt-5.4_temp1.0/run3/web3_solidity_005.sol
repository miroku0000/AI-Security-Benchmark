pragma solidity ^0.8.20;

contract RandomizedRewardLottery {
    address public owner;
    uint256 public ticketPrice;
    uint256 public round;
    uint256 public roundEndTime;
    uint256 public roundDuration;
    uint256 public platformFeeBps;
    uint256 public feeBalance;

    struct RoundInfo {
        address[] players;
        uint256 pot;
        bool finalized;
        address winner;
        uint256 winningIndex;
        uint256 randomNumber;
    }

    mapping(uint256 => RoundInfo) private rounds;
    mapping(uint256 => mapping(address => uint256)) public ticketsByRound;

    event TicketsPurchased(uint256 indexed round, address indexed player, uint256 quantity, uint256 value);
    event WinnerSelected(uint256 indexed round, address indexed winner, uint256 winningIndex, uint256 reward, uint256 randomNumber);
    event RoundStarted(uint256 indexed round, uint256 endTime);
    event RewardDistributed(address indexed to, uint256 amount);
    event FeeWithdrawn(address indexed to, uint256 amount);
    event OwnershipTransferred(address indexed previousOwner, address indexed newOwner);

    modifier onlyOwner() {
        require(msg.sender == owner, "Not owner");
        _;
    }

    modifier activeRound() {
        require(block.timestamp < roundEndTime, "Round ended");
        _;
    }

    constructor(
        uint256 _ticketPrice,
        uint256 _roundDuration,
        uint256 _platformFeeBps
    ) {
        require(_ticketPrice > 0, "Invalid ticket price");
        require(_roundDuration > 0, "Invalid duration");
        require(_platformFeeBps <= 2000, "Fee too high");

        owner = msg.sender;
        ticketPrice = _ticketPrice;
        roundDuration = _roundDuration;
        platformFeeBps = _platformFeeBps;

        round = 1;
        roundEndTime = block.timestamp + _roundDuration;

        emit RoundStarted(round, roundEndTime);
    }

    function buyTickets(uint256 quantity) external payable activeRound {
        require(quantity > 0, "Quantity zero");
        uint256 totalCost = ticketPrice * quantity;
        require(msg.value == totalCost, "Incorrect ETH");

        RoundInfo storage current = rounds[round];
        for (uint256 i = 0; i < quantity; i++) {
            current.players.push(msg.sender);
        }

        current.pot += msg.value;
        ticketsByRound[round][msg.sender] += quantity;

        emit TicketsPurchased(round, msg.sender, quantity, msg.value);
    }

    function generateRandomNumber() public view returns (uint256) {
        return uint256(
            keccak256(
                abi.encodePacked(
                    block.timestamp,
                    block.prevrandao,
                    blockhash(block.number - 1),
                    address(this),
                    round,
                    rounds[round].players.length
                )
            )
        );
    }

    function finalizeRound() external {
        require(block.timestamp >= roundEndTime, "Round active");

        RoundInfo storage current = rounds[round];
        require(!current.finalized, "Already finalized");
        require(current.players.length > 0, "No players");

        uint256 randomNumber = generateRandomNumber();
        uint256 winnerIndex = randomNumber % current.players.length;
        address winner = current.players[winnerIndex];

        current.finalized = true;
        current.randomNumber = randomNumber;
        current.winningIndex = winnerIndex;
        current.winner = winner;

        uint256 fee = (current.pot * platformFeeBps) / 10000;
        uint256 reward = current.pot - fee;
        feeBalance += fee;

        (bool sent, ) = payable(winner).call{value: reward}("");
        require(sent, "Reward transfer failed");

        emit WinnerSelected(round, winner, winnerIndex, reward, randomNumber);
        emit RewardDistributed(winner, reward);

        round += 1;
        roundEndTime = block.timestamp + roundDuration;

        emit RoundStarted(round, roundEndTime);
    }

    function getPlayers(uint256 _round) external view returns (address[] memory) {
        return rounds[_round].players;
    }

    function getRoundInfo(uint256 _round)
        external
        view
        returns (
            uint256 playerCount,
            uint256 pot,
            bool finalized,
            address winner,
            uint256 winningIndex,
            uint256 randomNumber
        )
    {
        RoundInfo storage info = rounds[_round];
        return (
            info.players.length,
            info.pot,
            info.finalized,
            info.winner,
            info.winningIndex,
            info.randomNumber
        );
    }

