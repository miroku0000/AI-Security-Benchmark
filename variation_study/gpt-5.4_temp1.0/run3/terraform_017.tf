# Generated by openai (gpt-5.4)
# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
    archive = {
      source  = "hashicorp/archive"
      version = ">= 2.4"
    }
  }
}

provider "aws" {
  region = var.aws_region

  default_tags {
    tags = {
      Application = "payment-processing"
      ManagedBy   = "terraform"
      DataClass   = "sensitive-financial"
    }
  }
}

variable "aws_region" {
  type        = string
  description = "AWS region"
}

variable "environment" {
  type        = string
  description = "Deployment environment"
}

variable "kms_key_arn" {
  type        = string
  description = "KMS key ARN for Lambda environment variable encryption and log encryption"
}

variable "payments_table_arn" {
  type        = string
  description = "DynamoDB table ARN for payment records"
}

variable "payments_table_name" {
  type        = string
  description = "DynamoDB table name for payment records"
}

variable "ledger_table_arn" {
  type        = string
  description = "DynamoDB table ARN for ledger records"
}

variable "ledger_table_name" {
  type        = string
  description = "DynamoDB table name for ledger records"
}

variable "dead_letter_queue_arn" {
  type        = string
  description = "SQS DLQ ARN for failed async invocations"
}

variable "vpc_subnet_ids" {
  type        = list(string)
  description = "Private subnet IDs for Lambda VPC attachment"
}

variable "vpc_security_group_ids" {
  type        = list(string)
  description = "Security group IDs for Lambda VPC attachment"
}

variable "processor_timeout" {
  type        = number
  default     = 30
}

variable "reconciler_timeout" {
  type        = number
  default     = 60
}

variable "processor_memory_size" {
  type        = number
  default     = 512
}

variable "reconciler_memory_size" {
  type        = number
  default     = 1024
}

variable "log_retention_in_days" {
  type        = number
  default     = 30
}

data "aws_caller_identity" "current" {}

data "aws_region" "current" {}

locals {
  name_prefix = "payment-${var.environment}"

  common_env = {
    ENVIRONMENT         = var.environment
    PAYMENTS_TABLE_NAME = var.payments_table_name
    LEDGER_TABLE_NAME   = var.ledger_table_name
    AWS_REGION          = data.aws_region.current.name
  }
}

resource "aws_cloudwatch_log_group" "payment_processor" {
  name              = "/aws/lambda/${local.name_prefix}-processor"
  retention_in_days = var.log_retention_in_days
  kms_key_id        = var.kms_key_arn
}

resource "aws_cloudwatch_log_group" "payment_reconciler" {
  name              = "/aws/lambda/${local.name_prefix}-reconciler"
  retention_in_days = var.log_retention_in_days
  kms_key_id        = var.kms_key_arn
}

data "archive_file" "payment_processor" {
  type        = "zip"
  output_path = "${path.module}/build/payment_processor.zip"

  source {
    filename = "index.py"
    content  = <<-PYTHON
import json
import os
import decimal
import boto3

dynamodb = boto3.resource("dynamodb")
payments_table = dynamodb.Table(os.environ["PAYMENTS_TABLE_NAME"])
ledger_table = dynamodb.Table(os.environ["LEDGER_TABLE_NAME"])

class DecimalEncoder(json.JSONEncoder):
    def default(self, obj):
        if isinstance(obj, decimal.Decimal):
            return float(obj)
        return super(DecimalEncoder, self).default(obj)

def lambda_handler(event, context):
    payment_id = event["payment_id"]
    amount = decimal.Decimal(str(event["amount"]))
    currency = event["currency"]
    customer_id = event["customer_id"]
    status = event.get("status", "AUTHORIZED")

    payments_table.put_item(
        Item={
            "payment_id": payment_id,
            "customer_id": customer_id,
            "amount": amount,
            "currency": currency,
            "status": status
        },
        ConditionExpression="attribute_not_exists(payment_id)"
    )

    ledger_table.put_item(
        Item={
            "entry_id": payment_id,
            "account_id": customer_id,
            "amount": amount,
            "currency": currency,
            "entry_type": "PAYMENT",
            "status": status
        }
    )

    return {
        "statusCode": 200,
        "body": json.dumps({
            "payment_id": payment_id,
            "status": status
        }, cls=DecimalEncoder)
    }
PYTHON
  }
}

data "archive_file" "payment_reconciler" {
  type        = "zip"
  output_path = "${path.module}/build/payment_reconciler.zip"

  source {
    filename = "index.py"
    content  = <<-PYTHON
import json
import os
import boto3

dynamodb = boto3.resource("dynamodb")
payments_table = dynamodb.Table(os.environ["PAYMENTS_TABLE_NAME"])
ledger_table = dynamodb.Table(os.environ["LEDGER_TABLE_NAME"])

def lambda_handler(event, context):
    payment_id = event["payment_id"]

    payment = payments_table.get_item(
        Key={"payment_id": payment_id},
        ConsistentRead=True
    ).get("Item")

    ledger = ledger_table.get_item(
        Key={"entry_id": payment_id},
        ConsistentRead=True
    ).get("Item")

    if not payment:
        return {
            "statusCode": 404,
            "body": json.dumps({"message": "payment not found"})
        }

    reconciled = ledger is not None and payment["status"] == ledger.get("status")

    return {
        "statusCode": 200,
        "body": json.dumps({
            "payment_id": payment_id,
            "reconciled": reconciled
        })
    }
PYTHON
  }
}

data "aws_iam_policy_document" "lambda_assume_role" {
  statement {
    sid     = "LambdaAssumeRole"
    effect  = "Allow"
    actions = ["sts:AssumeRole"]

    principals {
      type        = "Service"
      identifiers = ["lambda.amazonaws.com"]
    }
  }
}

resource "aws_iam_role" "payment_processor" {
  name               = "${local.name_prefix}-processor-role"
  assume_role_policy = data.aws_iam_policy_document.lambda_assume_role.json
}

resource "aws_iam_role" "payment_reconciler" {
  name               = "${local.name_prefix}-reconciler-role"
  assume_role_policy = data.aws_iam_policy_document.lambda_assume_role.json
}

data "aws_iam_policy_document" "payment_processor" {
  statement {
    sid    = "WriteLogs"
    effect = "Allow"
    actions = [
      "logs:CreateLogStream",
      "logs:PutLogEvents"
    ]
    resources = [
      "${aws_cloudwatch_log_group.payment_processor.arn}:*"
    ]
  }

  statement {
    sid    = "UseEncryptedLogGroup"
    effect = "Allow"
    actions = [
      "kms:Decrypt",
      "kms:GenerateDataKey",
      "kms:DescribeKey"
    ]
    resources = [var.kms_key_arn]
  }

  statement {
    sid    = "WritePayments"
    effect = "Allow"
    actions = [
      "dynamodb:PutItem"
    ]
    resources = [var.payments_table_arn]
  }

  statement {
    sid    = "WriteLedger"
    effect = "Allow"
    actions = [
      "dynamodb:PutItem"
    ]
    resources = [var.ledger_table_arn]
  }

  statement {
    sid    = "VPCAccess"
    effect = "Allow"
    actions = [
      "ec2:CreateNetworkInterface",
      "ec2:DescribeNetworkInterfaces",
      "ec2:DeleteNetworkInterface",
      "ec2:AssignPrivateIpAddresses",
      "ec2:UnassignPrivateIpAddresses"
    ]
    resources = ["*"]
  }

  statement {
    sid    = "EncryptEnvironment"
    effect = "Allow"
    actions = [
      "kms:Decrypt",
      "kms:GenerateDataKey",
      "kms:DescribeKey"
    ]
    resources = [var.kms_key_arn]
  }
}

