resource "aws_iam_role_policy" "payment_processor" {
  name   = "${local.name_prefix}-processor-policy"
  role   = aws_iam_role.payment_processor.id
  policy = data.aws_iam_policy_document.payment_processor.json
}

resource "aws_iam_role_policy" "payment_reconciler" {
  name   = "${local.name_prefix}-reconciler-policy"
  role   = aws_iam_role.payment_reconciler.id
  policy = data.aws_iam_policy_document.payment_reconciler.json
}

resource "aws_lambda_function" "payment_processor" {
  function_name = "${local.name_prefix}-processor"
  role          = aws_iam_role.payment_processor.arn
  runtime       = "python3.12"
  handler       = "index.lambda_handler"

  filename         = data.archive_file.payment_processor.output_path
  source_code_hash = data.archive_file.payment_processor.output_base64sha256

  memory_size                    = var.processor_memory_size
  timeout                        = var.processor_timeout
  reserved_concurrent_executions = 10

  kms_key_arn = var.kms_key_arn

  environment {
    variables = merge(local.common_env, {
      FUNCTION_ROLE = "processor"
    })
  }

  vpc_config {
    subnet_ids         = var.vpc_subnet_ids
    security_group_ids = var.vpc_security_group_ids
  }

  dead_letter_config {
    target_arn = var.dead_letter_queue_arn
  }

  tracing_config {
    mode = "PassThrough"
  }

  depends_on = [
    aws_cloudwatch_log_group.payment_processor
  ]
}

resource "aws_lambda_function" "payment_reconciler" {
  function_name = "${local.name_prefix}-reconciler"
  role          = aws_iam_role.payment_reconciler.arn
  runtime       = "python3.12"
  handler       = "index.lambda_handler"

  filename         = data.archive_file.payment_reconciler.output_path
  source_code_hash = data.archive_file.payment_reconciler.output_base64sha256

  memory_size                    = var.reconciler_memory_size
  timeout                        = var.reconciler_timeout
  reserved_concurrent_executions = 5

  kms_key_arn = var.kms_key_arn

  environment {
    variables = merge(local.common_env, {
      FUNCTION_ROLE = "reconciler"
    })
  }

  vpc_config {
    subnet_ids         = var.vpc_subnet_ids
    security_group_ids = var.vpc_security_group_ids
  }

  dead_letter_config {
    target_arn = var.dead_letter_queue_arn
  }

  tracing_config {
    mode = "PassThrough"
  }

  depends_on = [
    aws_cloudwatch_log_group.payment_reconciler
  ]
}

output "payment_processor_function_name" {
