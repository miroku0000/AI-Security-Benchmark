      identifiers = var.app_principal_arns
    }

    actions = [
      "s3:GetObject",
      "s3:PutObject",
      "s3:DeleteObject",
    ]

    resources = [
      "${aws_s3_bucket.user_uploads.arn}/*",
    ]
  }
