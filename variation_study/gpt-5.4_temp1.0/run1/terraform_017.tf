resource "local_file" "payment_authorizer_source" {
  filename = "${path.module}/build/payment_authorizer/index.py"
  content  = <<-PY
import json
import os
import hashlib
import logging
import boto3
from botocore.exceptions import ClientError

logger = logging.getLogger()
logger.setLevel(logging.INFO)

dynamodb = boto3.resource("dynamodb")
secretsmanager = boto3.client("secretsmanager")
sqs = boto3.client("sqs")

TABLE_NAME = os.environ["PAYMENTS_TABLE_NAME"]
QUEUE_URL = os.environ["EVENTS_QUEUE_URL"]
FRAUD_SECRET_ARN = os.environ["FRAUD_API_SECRET_ARN"]
TOKENIZATION_SECRET_ARN = os.environ["TOKENIZATION_SECRET_ARN"]

def _get_secret(secret_arn):
    return secretsmanager.get_secret_value(SecretId=secret_arn)["SecretString"]

def _mask_pan(pan):
    if not pan or len(pan) < 4:
        return "****"
    return "*" * (len(pan) - 4) + pan[-4:]

def _tokenize_pan(pan):
    secret_material = _get_secret(TOKENIZATION_SECRET_ARN)
    digest = hashlib.sha256(f"{pan}:{secret_material}".encode("utf-8")).hexdigest()
    return f"tok_{digest[:32]}"

def _fraud_check(payment):
    _ = _get_secret(FRAUD_SECRET_ARN)
    amount = int(payment["amount"])
    if amount > 100000:
        return {"decision": "review", "score": 90}
    return {"decision": "approve", "score": 10}

def handler(event, context):
    try:
        body = event if isinstance(event, dict) else json.loads(event["body"])
        payment_id = body["payment_id"]
        account_id = body["account_id"]
        amount = int(body["amount"])
        currency = body["currency"]
        pan = body["pan"]

        tokenized_pan = _tokenize_pan(pan)
        fraud_result = _fraud_check(body)

        status = "AUTHORIZED" if fraud_result["decision"] == "approve" else "REVIEW"

        item = {
            "payment_id": payment_id,
            "account_id": account_id,
            "amount": amount,
            "currency": currency,
            "pan_token": tokenized_pan,
            "masked_pan": _mask_pan(pan),
            "status": status,
            "fraud_score": fraud_result["score"]
        }

        table = dynamodb.Table(TABLE_NAME)
        table.put_item(
            Item=item,
            ConditionExpression="attribute_not_exists(payment_id)"
        )

        sqs.send_message(
            QueueUrl=QUEUE_URL,
            MessageBody=json.dumps({
                "payment_id": payment_id,
                "status": status,
                "account_id": account_id
            })
        )

        return {
            "statusCode": 200,
            "body": json.dumps({
                "payment_id": payment_id,
                "status": status
            })
        }
    except ClientError as e:
        logger.error("AWS service error: %s", e.response.get("Error", {}).get("Code", "Unknown"))
        raise
    except Exception:
        logger.exception("Authorization failed")
        raise
  PY
}

resource "local_file" "payment_settlement_source" {
  filename = "${path.module}/build/payment_settlement/index.py"
  content  = <<-PY
import json
import os
import logging
import boto3
from decimal import Decimal

logger = logging.getLogger()
logger.setLevel(logging.INFO)

dynamodb = boto3.resource("dynamodb")
s3 = boto3.client("s3")

TABLE_NAME = os.environ["PAYMENTS_TABLE_NAME"]
LEDGER_BUCKET = os.environ["LEDGER_BUCKET_NAME"]

def handler(event, context):
    table = dynamodb.Table(TABLE_NAME)
    settled = []

    for record in event.get("Records", []):
        body = json.loads(record["body"])
        payment_id = body["payment_id"]
        status = body["status"]

        if status != "AUTHORIZED":
            continue

        response = table.get_item(Key={"payment_id": payment_id})
        item = response.get("Item")
        if not item:
            continue

        table.update_item(
            Key={"payment_id": payment_id},
            UpdateExpression="SET #s = :settled",
            ExpressionAttributeNames={"#s": "status"},
            ExpressionAttributeValues={":settled": "SETTLED"},
            ConditionExpression="#s = :authorized",
            ReturnValues="NONE"
        )

        ledger_record = {
            "payment_id": item["payment_id"],
            "account_id": item["account_id"],
            "amount": int(item["amount"]) if isinstance(item["amount"], Decimal) else item["amount"],
            "currency": item["currency"],
            "status": "SETTLED"
        }

        s3.put_object(
            Bucket=LEDGER_BUCKET,
            Key=f"settlements/{payment_id}.json",
            Body=json.dumps(ledger_record).encode("utf-8"),
            ContentType="application/json"
        )

        settled.append(payment_id)

    return {
        "statusCode": 200,
        "body": json.dumps({
            "settled_count": len(settled),
            "payment_ids": settled
        })
    }
  PY
}

