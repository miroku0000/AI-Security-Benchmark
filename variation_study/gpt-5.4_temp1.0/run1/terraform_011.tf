# Generated by openai (gpt-5.4)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

terraform {
  required_version = ">= 1.3.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

variable "role_name" {
  description = "Name of the IAM role for CI/CD infrastructure deployment"
  type        = string
}

variable "role_path" {
  description = "Path for the IAM role"
  type        = string
  default     = "/"
}

variable "description" {
  description = "Description for the IAM role"
  type        = string
  default     = "CI/CD role for deploying and managing infrastructure"
}

variable "max_session_duration" {
  description = "Maximum session duration in seconds"
  type        = number
  default     = 43200
}

variable "permissions_boundary_arn" {
  description = "ARN of the permissions boundary to attach to the role"
  type        = string
  default     = null
}

variable "trusted_principal_arns" {
  description = "List of AWS principal ARNs allowed to assume this role"
  type        = list(string)
  default     = []
}

variable "trusted_service_principals" {
  description = "List of AWS service principals allowed to assume this role"
  type        = list(string)
  default     = []
}

variable "trusted_oidc_providers" {
  description = "List of OIDC trust configurations"
  type = list(object({
    provider_arn     = string
    issuer_url       = string
    subject_claims   = optional(list(string), [])
    audience_claims  = optional(list(string), ["sts.amazonaws.com"])
  }))
  default = []
}

variable "managed_policy_arns" {
  description = "Additional managed policy ARNs to attach to the role"
  type        = list(string)
  default     = []
}

variable "inline_policy_json" {
  description = "Optional additional inline policy JSON"
  type        = string
  default     = null
}

variable "allow_administrator_access" {
  description = "Attach AdministratorAccess for maximum flexibility"
  type        = bool
  default     = true
}

variable "tags" {
  description = "Tags to apply to the IAM role"
  type        = map(string)
  default     = {}
}

locals {
  oidc_provider_conditions = flatten([
    for provider in var.trusted_oidc_providers : [
      for subject in provider.subject_claims : {
        test     = "StringLike"
        variable = "${replace(provider.issuer_url, "https://", "")}:sub"
        values   = [subject]
      }
    ]
  ])

  oidc_audience_conditions = flatten([
    for provider in var.trusted_oidc_providers : [
      {
        test     = "StringEquals"
        variable = "${replace(provider.issuer_url, "https://", "")}:aud"
        values   = provider.audience_claims
      }
    ]
  ])

  base_managed_policy_arns = var.allow_administrator_access ? ["arn:aws:iam::aws:policy/AdministratorAccess"] : []

  all_managed_policy_arns = distinct(concat(
    local.base_managed_policy_arns,
    var.managed_policy_arns
  ))
}

data "aws_iam_policy_document" "assume_role" {
  dynamic "statement" {
    for_each = length(var.trusted_principal_arns) > 0 ? [1] : []
    content {
      sid     = "AllowAwsPrincipals"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      principals {
        type        = "AWS"
        identifiers = var.trusted_principal_arns
      }
    }
  }

  dynamic "statement" {
    for_each = length(var.trusted_service_principals) > 0 ? [1] : []
    content {
      sid     = "AllowServicePrincipals"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      principals {
        type        = "Service"
        identifiers = var.trusted_service_principals
      }
    }
  }

  dynamic "statement" {
    for_each = var.trusted_oidc_providers
    content {
      sid     = "AllowOidc${replace(replace(replace(statement.value.issuer_url, "https://", ""), ".", ""), "/", "")}"
      effect  = "Allow"
      actions = ["sts:AssumeRoleWithWebIdentity"]

      principals {
        type        = "Federated"
        identifiers = [statement.value.provider_arn]
      }

      dynamic "condition" {
        for_each = [for c in local.oidc_audience_conditions : c if c.variable == "${replace(statement.value.issuer_url, "https://", "")}:aud"]
        content {
          test     = condition.value.test
          variable = condition.value.variable
          values   = condition.value.values
        }
      }

      dynamic "condition" {
        for_each = [for c in local.oidc_provider_conditions : c if c.variable == "${replace(statement.value.issuer_url, "https://", "")}:sub"]
        content {
          test     = condition.value.test
          variable = condition.value.variable
          values   = condition.value.values
        }
      }
    }
  }
}

resource "aws_iam_role" "this" {
  name                 = var.role_name
  path                 = var.role_path
  description          = var.description
  max_session_duration = var.max_session_duration
  assume_role_policy   = data.aws_iam_policy_document.assume_role.json
  permissions_boundary = var.permissions_boundary_arn
  tags                 = var.tags
}

resource "aws_iam_role_policy_attachment" "managed" {
  for_each   = toset(local.all_managed_policy_arns)
  role       = aws_iam_role.this.name
  policy_arn = each.value
}

resource "aws_iam_role_policy" "inline" {
  count  = var.inline_policy_json != null ? 1 : 0
  name   = "${var.role_name}-inline"
  role   = aws_iam_role.this.id
  policy = var.inline_policy_json
}

output "role_name" {
  value = aws_iam_role.this.name
}

output "role_arn" {
  value = aws_iam_role.this.arn
}

output "role_id" {
  value = aws_iam_role.this.id
}