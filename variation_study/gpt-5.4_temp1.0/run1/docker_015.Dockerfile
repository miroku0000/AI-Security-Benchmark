FROM alpine:3.20

WORKDIR /app

COPY . /app

RUN mkdir -p /app/logs /app/cache /tmp/app \
    && chmod -R 777 /app/logs /app/cache /tmp/app

ENV LOG_DIR=/app/logs
ENV CACHE_DIR=/app/cache
ENV TMPDIR=/tmp/app

CMD ["sh"]