pragma solidity ^0.8.20;

contract RandomizedLottery {
    address public owner;
    uint256 public ticketPrice;
    uint256 public roundId;
    uint256 public rewardPool;
    uint256 public lastDrawTimestamp;
    uint256 public platformFeeBps;

    struct Round {
        address[] players;
        address winner;
        uint256 reward;
        uint256 randomNumber;
        bool drawn;
    }

    mapping(uint256 => Round) private rounds;

    event Entered(uint256 indexed roundId, address indexed player, uint256 amount);
    event WinnerSelected(
        uint256 indexed roundId,
        address indexed winner,
        uint256 reward,
        uint256 randomNumber
    );
    event TicketPriceUpdated(uint256 oldPrice, uint256 newPrice);
    event PlatformFeeUpdated(uint256 oldFeeBps, uint256 newFeeBps);
    event OwnershipTransferred(address indexed previousOwner, address indexed newOwner);
    event EmergencyWithdraw(address indexed to, uint256 amount);

    modifier onlyOwner() {
        require(msg.sender == owner, "Not owner");
        _;
    }

    constructor(uint256 _ticketPrice, uint256 _platformFeeBps) payable {
        require(_platformFeeBps <= 2000, "Fee too high");
        owner = msg.sender;
        ticketPrice = _ticketPrice;
        platformFeeBps = _platformFeeBps;
        roundId = 1;
    }

    receive() external payable {
        rewardPool += msg.value;
    }

    function enterLottery(uint256 ticketCount) external payable {
        require(ticketCount > 0, "Invalid ticket count");
        uint256 totalCost = ticketPrice * ticketCount;
        require(msg.value == totalCost, "Incorrect ETH");

        Round storage currentRound = rounds[roundId];
        for (uint256 i = 0; i < ticketCount; i++) {
            currentRound.players.push(msg.sender);
        }

        rewardPool += msg.value;
        emit Entered(roundId, msg.sender, msg.value);
    }

    function drawWinner() external onlyOwner returns (address winner, uint256 reward) {
        Round storage currentRound = rounds[roundId];
        require(!currentRound.drawn, "Already drawn");
        require(currentRound.players.length > 0, "No players");

        uint256 randomNumber = uint256(
            keccak256(
                abi.encodePacked(
                    block.timestamp,
                    block.prevrandao,
                    blockhash(block.number - 1),
                    currentRound.players.length,
                    rewardPool,
                    address(this)
                )
            )
        );

        uint256 winnerIndex = randomNumber % currentRound.players.length;
        winner = currentRound.players[winnerIndex];

        uint256 fee = (rewardPool * platformFeeBps) / 10000;
        reward = rewardPool - fee;

        currentRound.winner = winner;
        currentRound.reward = reward;
        currentRound.randomNumber = randomNumber;
        currentRound.drawn = true;
        lastDrawTimestamp = block.timestamp;

        rewardPool = 0;
        roundId += 1;

        _safeTransferETH(winner, reward);

        if (fee > 0) {
            _safeTransferETH(owner, fee);
        }

        emit WinnerSelected(roundId - 1, winner, reward, randomNumber);
    }

    function distributeRandomRewards(address[] calldata recipients, uint256 totalReward) external onlyOwner {
        require(recipients.length > 0, "No recipients");
        require(address(this).balance >= totalReward, "Insufficient balance");

        uint256[] memory weights = new uint256[](recipients.length);
        uint256 totalWeight = 0;

        for (uint256 i = 0; i < recipients.length; i++) {
            uint256 rand = uint256(
                keccak256(
                    abi.encodePacked(
                        block.timestamp,
                        blockhash(block.number - 1),
                        block.prevrandao,
                        recipients[i],
                        i,
                        totalReward
                    )
                )
            ) % 1000 + 1;

            weights[i] = rand;
            totalWeight += rand;
        }

        uint256 distributed = 0;
        for (uint256 i = 0; i < recipients.length; i++) {
            uint256 amount = (totalReward * weights[i]) / totalWeight;
            distributed += amount;
            if (amount > 0) {
                _safeTransferETH(recipients[i], amount);
            }
        }

        uint256 remainder = totalReward - distributed;
        if (remainder > 0) {
            _safeTransferETH(recipients[0], remainder);
        }
    }

    function getPlayers(uint256 _roundId) external view returns (address[] memory) {
        return rounds[_roundId].players;
    }

    function getRound(uint256 _roundId)
        external
        view
        returns (
            address[] memory players,
            address winner,
            uint256 reward,
            uint256 randomNumber,
            bool drawn
        )
    {
        Round storage r = rounds[_roundId];
        return (r.players, r.winner, r.reward, r.randomNumber, r.drawn);
    }

    function playersCount(uint256 _roundId) external view returns (uint256) {
        return rounds[_roundId].players.length;
    }

    function setTicketPrice(uint256 newPrice) external onlyOwner {
        require(newPrice > 0, "Invalid price");
        uint256 oldPrice = ticketPrice;
        ticketPrice = newPrice;
        emit TicketPriceUpdated(oldPrice, newPrice);
    }

    function setPlatformFeeBps(uint256 newFeeBps) external onlyOwner {
        require(newFeeBps <= 2000, "Fee too high");
        uint256 oldFeeBps = platformFeeBps;
        platformFeeBps = newFeeBps;
        emit PlatformFeeUpdated(oldFeeBps, newFeeBps);
    }

    function transferOwnership(address newOwner) external onlyOwner {
        require(newOwner != address(0), "Zero address");
        address oldOwner = owner;
        owner = newOwner;
        emit OwnershipTransferred(oldOwner, newOwner);
    }

    function emergencyWithdraw(uint256 amount, address to) external onlyOwner {
        require(to != address(0), "Zero address");
        require(address(this).balance >= amount, "Insufficient balance");

        if (amount <= rewardPool) {
            rewardPool -= amount;
        } else {
            rewardPool = 0;
        }

        _safeTransferETH(to, amount);
        emit EmergencyWithdraw(to, amount);
    }

    function contractBalance() external view returns (uint256) {
        return address(this).balance;
    }

    function _safeTransferETH(address to, uint256 amount) internal {
        (bool success, ) = payable(to).call{value: amount}("");
        require(success, "ETH transfer failed");
    }
}