resource "aws_lambda_function" "payment_processor" {
  function_name = "${local.name_prefix}-payment-processor"
  role          = aws_iam_role.payment_processor.arn
  runtime       = "python3.11"
  handler       = "app.handler"
  s3_bucket     = var.processor_code_s3_bucket
  s3_key        = var.processor_code_s3_key
  timeout       = 30
  memory_size   = 512
  kms_key_arn   = var.kms_key_arn

  environment {
    variables = {
      ENVIRONMENT                 = var.environment
      PAYMENT_EVENTS_TABLE_NAME   = var.payment_events_table_name
      PAYMENT_LEDGER_TABLE_NAME   = var.payment_ledger_table_name
      PAYMENT_QUEUE_URL           = var.payment_queue_url
