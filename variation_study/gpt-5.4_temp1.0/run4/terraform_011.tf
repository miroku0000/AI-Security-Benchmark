          values   = statement.value.audiences
        }
      }

      dynamic "condition" {
        for_each = length(try(statement.value.subject_eq, [])) > 0 ? [1] : []
        content {
          test     = "StringEquals"
          variable = "${replace(statement.value.provider_arn, "/^(.*provider\\/)/", "")}:sub"
          values   = statement.value.subject_eq
