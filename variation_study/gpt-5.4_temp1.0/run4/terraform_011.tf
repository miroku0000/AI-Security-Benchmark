data "aws_iam_policy_document" "assume_role" {
  dynamic "statement" {
    for_each = length(var.trusted_principal_arns) > 0 || length(var.trusted_services) > 0 ? [1] : []
    content {
      sid     = "AssumeRole"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      dynamic "principals" {
        for_each = length(var.trusted_principal_arns) > 0 ? [1] : []
        content {
          type        = "AWS"
          identifiers = var.trusted_principal_arns
