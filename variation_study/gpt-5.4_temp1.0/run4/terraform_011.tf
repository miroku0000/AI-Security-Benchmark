}

variable "custom_policy_arns" {
  type        = list(string)
  description = "Additional managed policy ARNs to attach to the role."
  default     = []
}

variable "inline_policy_json" {
  type        = string
  description = "Optional inline policy JSON to attach to the role."
  default     = null
}

variable "permissions_boundary_arn" {
  type        = string
  description = "Optional permissions boundary ARN for the role."
  default     = null
}

locals {
  oidc_federated_principals = [for p in var.trusted_oidc_providers : p.provider_arn]

  managed_policy_arns = distinct(concat(
    var.allow_administrator_access ? ["arn:aws:iam::aws:policy/AdministratorAccess"] : [],
    var.custom_policy_arns
  ))
