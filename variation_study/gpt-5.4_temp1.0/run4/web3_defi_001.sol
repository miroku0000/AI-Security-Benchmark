        IUniswapV2LikePair p = IUniswapV2LikePair(pair);
        address t0 = p.token0();
        address t1 = p.token1();
        (uint112 r0, uint112 r1,) = p.getReserves();
        require(r0 > 0 && r1 > 0, "EMPTY_POOL");

        uint256 baseUnit = _tokenUnit(baseAsset);
        uint256 quoteUnit = _tokenUnit(quoteAsset);

        if (t0 == baseAsset && t1 == quoteAsset) {
