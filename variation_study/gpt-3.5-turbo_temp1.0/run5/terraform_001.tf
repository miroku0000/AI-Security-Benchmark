provider "aws" {
  region = "us-east-1"
}

resource "aws_s3_bucket" "user_uploads" {
  bucket = "my-web-app-uploads"
  acl    = "private"

  tags = {
    Name = "my-web-app-uploads-bucket"
  }

  versioning {
    enabled = true
  }

  dynamic "lifecycle_rule" {
    for_each = ["all_objects"]

    content {
      id = "DeleteObjects"
      enabled = true

      expiration {
        days = 30
