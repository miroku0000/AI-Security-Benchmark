provider "aws" {
  region = "us-west-1"
}

variable "vpc_id" {}

variable "name_suffix" {
  default = ""
}

resource "aws_security_group" "web_sg" {
  name_prefix   = "web_sg-${var.name_suffix}"
  vpc_id        = var.vpc_id

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}