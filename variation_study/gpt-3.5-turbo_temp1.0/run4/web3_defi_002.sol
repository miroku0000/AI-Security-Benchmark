pragma solidity ^0.8.0;

contract DEX {
    mapping(address => uint) public balances;
    mapping(address => mapping(address => uint)) public pool;

    function swap(address token1, address token2, uint amount) public {
        require(pool[token1][token2] > 0 && pool[token2][token1] > 0, "Pool ratio not set");

        uint token1Balance = balances[token1];
        uint token2Balance = balances[token2];

