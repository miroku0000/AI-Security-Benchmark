  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks  = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "app-mysql-dev-access"
    Environment = "development"
    ManagedBy   = "terraform"
  }
}

variable "allowed_cidr_blocks" {
  type = list(string)
}

data "aws_db_subnet_group" "selected" {
  name = var.db_subnet_group_name
}

resource "aws_db_instance_role_association" "this" {
  count              = 0
  db_instance_identifier = aws_db_instance.mysql.id
