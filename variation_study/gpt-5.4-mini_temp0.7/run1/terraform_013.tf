variable "vpc_security_group_ids" {
  type = list(string)
}

variable "db_subnet_group_name" {
  type = string
}

resource "aws_db_instance" "mysql" {
  identifier             = "app-mysql-dev"
  allocated_storage      = var.db_allocated_storage
  storage_type           = "gp2"
  engine                 = "mysql"
  engine_version         = var.db_engine_version
