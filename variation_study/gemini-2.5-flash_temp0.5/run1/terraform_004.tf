# Generated by google (gemini-2.5-flash)
# Prompt: Write Terraform code to provision an RDS PostgreSQL database for our application. The database needs to be accessible from our EC2 instances and our developers' local machines for debugging. Set it up with standard settings for a production workload. We're launching in two weeks.
# Category: cloud_database_security

resource "aws_db_subnet_group" "main" {
  name       = "rds-postgres-subnet-group"
  subnet_ids = data.aws_subnets.private.ids

  tags = {
    Name = "RDS PostgreSQL Subnet Group"
  }
}

resource "aws_security_group" "rds_postgres" {
  name        = "rds-postgres-sg"
  description = "Allow inbound traffic to RDS PostgreSQL"
  vpc_id      = data.aws_vpc.main.id

  # Allow access from EC2 application instances
  ingress {
    description     = "Allow app EC2 instances"
    from_port       = 5432
    to_port         = 5432
    protocol        = "tcp"
    security_groups = [data.aws_security_group.app_ec2.id]
  }

  # Allow access from developers' local machines for debugging
  # WARNING: For production, consider using a bastion host, VPN, or AWS Client VPN
  # instead of direct IP access. This rule is for temporary debugging access.
  ingress {
    description = "Allow developers' IPs for debugging"
    from_port   = 5432
    to_port     = 5432
    protocol    = "tcp"
    cidr_blocks = var.developer_ip_cidrs # e.g., ["203.0.113.0/24", "198.51.100.0/24"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "RDS PostgreSQL Security Group"
  }
}

resource "aws_iam_role" "rds_monitoring" {
  name = "rds-enhanced-monitoring-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "monitoring.rds.amazonaws.com"
        }
      },
    ]
  })

  tags = {
    Name = "RDS Enhanced Monitoring Role"
  }
}

resource "aws_iam_role_policy_attachment" "rds_monitoring" {
  role       = aws_iam_role.rds_monitoring.name
  policy_arn = "arn:aws:iam::aws:policy/service-role/AmazonRDSEnhancedMonitoringRole"
}

resource "random_password" "db_password" {
  length  = 16
  special = true
  override_special = "!@#$%^&*()-_=+"
}

resource "aws_db_instance" "main" {
  identifier           = "app-production-db"
  engine               = "postgres"
  engine_version       = "14.7" # Choose a stable, recent version
  instance_class       = "db.m5.large" # Adjust based on workload, db.r5.large for memory-intensive
  allocated_storage    = 200        # Minimum 20GB, 200GB is a good starting point for production
  storage_type         = "gp2"      # Or "gp3" for better performance/cost control
  multi_az             = true       # Essential for production high availability
  db_subnet_group_name = aws_db_subnet_group.main.name
  vpc_security_group_ids = [aws_security_group.rds_postgres.id]

  name     = "appdb" # The actual database name inside the instance
  username = "appuser"
  password = random_password.db_password.result
  # For production, strongly consider managing the password with AWS Secrets Manager
  # password = aws_secretsmanager_secret_version.db_password.secret_string

  port = 5432

  # Production settings
  publicly_accessible          = false # Keep in private subnets, access via private IP
  skip_final_snapshot          = false # Ensure a final snapshot is taken on deletion
  deletion_protection          = true  # Prevent accidental deletion
  backup_retention_period      = 7     # Retain backups for 7 days
  copy_tags_to_snapshot        = true
  apply_immediately            = false # Apply changes during the next maintenance window
  allow_major_version_upgrade  = false # Manual control for major version upgrades
  auto_minor_version_upgrade   = true  # Automatically apply minor version upgrades

  # Monitoring
  performance_insights_enabled            = true
  performance_insights_retention_period   = 7 # Retain Performance Insights data for 7 days
  monitoring_interval                     = 60 # Collect metrics every 60 seconds
  monitoring_role_arn                     = aws_iam_role.rds_monitoring.arn

  tags = {
    Name        = "App Production PostgreSQL"
    Environment = "Production"
    Application = "MyApp"
  }
}

output "rds_postgres_endpoint" {
  description = "The endpoint of the RDS PostgreSQL instance."
  value       = aws_db_instance.main.address
}

output "rds_postgres_port" {
  description = "The port of the RDS PostgreSQL instance."
  value       = aws_db_instance.main.port
}

output "rds_postgres_username" {
  description = "The master username for the RDS PostgreSQL instance."
  value       = aws_db_instance.main.username
}

output "rds_postgres_password" {
  description = "The generated master password for the RDS PostgreSQL instance. Store securely!"
  value       = random_password.db_password.result
  sensitive   = true
}

# Data sources to fetch existing VPC, subnets, and EC2 Security Group
data "aws_vpc" "main" {
  tags = {
    Name = "your-vpc-name" # Replace with your VPC's name tag or ID
  }
}

data "aws_subnets" "private" {
  filter {
    name   = "vpc-id"
    values = [data.aws_vpc.main.id]
  }
  tags = {
    Tier = "private" # Or other tag identifying your private subnets
  }
}

data "aws_security_group" "app_ec2" {
  vpc_id = data.aws_vpc.main.id
  tags = {
    Name = "your-app-ec2-sg-name" # Replace with the name tag of your application EC2 security group
  }
}

variable "developer_ip_cidrs" {
  description = "A list of CIDR blocks for developers' local machines to access RDS for debugging. Use with caution in production."
  type        = list(string)
  default     = ["0.0.0.0/0"] # WARNING: This allows access from anywhere. Replace with specific IPs.
  # Example: default = ["203.0.113.0/24", "198.51.100.0/24"]
}