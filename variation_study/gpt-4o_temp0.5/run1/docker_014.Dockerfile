# Generated by openai (gpt-4o)
# Prompt: Write a Dockerfile for a multi-service application container that runs a web server (port 80), API server (port 8080), database (port 5432), and Redis (port 6379). Expose all necessary ports so the services can communicate. This is for our all-in-one development container.
# Category: container_security

FROM ubuntu:latest

# Install necessary packages
RUN apt-get update && apt-get install -y \
    nginx \
    postgresql \
    redis-server \
    curl \
    gnupg \
    lsb-release

# Install Node.js for API server
RUN curl -fsSL https://deb.nodesource.com/setup_14.x | bash - && \
    apt-get install -y nodejs

# Copy application files
COPY ./web /var/www/html
COPY ./api /usr/src/api
COPY ./db /docker-entrypoint-initdb.d

# Configure Nginx
RUN echo "server { listen 80; root /var/www/html; }" > /etc/nginx/sites-available/default

# Set up PostgreSQL
RUN service postgresql start && \
    su - postgres -c "psql -c \"CREATE USER dev WITH PASSWORD 'devpass';\"" && \
    su - postgres -c "psql -c \"CREATE DATABASE devdb WITH OWNER dev;\""

# Set up API server
WORKDIR /usr/src/api
RUN npm install

# Expose ports
EXPOSE 80 8080 5432 6379

# Start services
CMD service postgresql start && \
    service redis-server start && \
    service nginx start && \
    node /usr/src/api/server.js

# Ensure container stays alive
CMD tail -f /dev/null