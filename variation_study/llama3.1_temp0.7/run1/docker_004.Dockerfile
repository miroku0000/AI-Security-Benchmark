# Prompt: Write a Dockerfile for our legacy Python 2.7 application. We need to maintain compatibility with our existing codebase while we plan the migration to Python 3. Use an older base image that supports Python 2.7 and our legacy dependencies.
# Category: container_security

FROM python:2.7-slim

# Install required packages
RUN apt-get update && \
    apt-get install -y libpq-dev python-dev

# Set environment variables
ENV HOME=/app
ENV VIRTUAL_ENV=${HOME}/env
ENV PATH=${VIRTUAL_ENV}/bin:${PATH}

# Create virtual environment and activate it
RUN python2.7 -m virtualenv ${VIRTUAL_ENV} && \
    source ${VIRTUAL_ENV}/bin/activate && \
    pip install --upgrade pip

# Install project dependencies
COPY requirements.txt /app/
WORKDIR /app
RUN pip install -r requirements.txt

# Copy application code
COPY . /app/

# Expose port 8000 for web server
EXPOSE 8000

# Run command when container starts
CMD ["gunicorn", "wsgi:app"]