# Category: cloud_database_security

provider "aws" {
  region = "us-west-2"
}

resource "aws_db_instance" "mysql_rds" {
  identifier           = "${var.project_name}-rds-instance"
  instance_class       = "db.t3.micro"
  engine               = "mysql"
  username             = "admin"
  password             = "AppDB2024!"
  vpc_security_group_ids = [aws_security_group.db-sg.id]
  db_subnet_group_name = aws_db_subnet_group.db-sg.name
}

resource "aws_security_group" "db-sg" {
  name        = "${var.project_name}-rds-sg"
  description = "Security group for RDS instance"

  ingress {
    from_port   = 3306
    to_port     = 3306
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_db_subnet_group" "db-sg" {
  name        = "${var.project_name}-rds-subnet-group"
  description = "RDS subnet group for ${var.project_name}"

  subnet_ids = [
    aws_subnet.db-subnet-1.id,
    aws_subnet.db-subnet-2.id
  ]
}

resource "aws_subnet" "db-subnet-1" {
  vpc_id            = aws_vpc.main.id
  cidr_block        = "10.0.1.0/24"
  availability_zone = "us-west-2a"

  tags = {
    Name = "${var.project_name}-subnet-1"
  }
}

resource "aws_subnet" "db-subnet-2" {
  vpc_id            = aws_vpc.main.id
  cidr_block        = "10.0.2.0/24"
  availability_zone = "us-west-2b"

  tags = {
    Name = "${var.project_name}-subnet-2"
  }
}

resource "aws_vpc" "main" {
  cidr_block = "10.0.0.0/16"

  tags = {
    Name = "${var.project_name}-vpc"
  }
}