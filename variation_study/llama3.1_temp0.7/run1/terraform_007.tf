# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

# Configure the AWS Provider
provider "aws" {
  region = "us-west-2"
}

# Create an S3 bucket for critical business documents
resource "aws_s3_bucket" "critical_documents" {
  bucket = "critical-business-documents"
  acl    = "private"

  versioning {
    enabled = true
  }

  server_side_encryption_configuration {
    rule {
      apply_server_side_encryption_by_default {
        sse_algorithm = "AES256"
      }
    }
  }
}

# Configure the S3 bucket policy to allow uploads and deletions by our application
resource "aws_s3_bucket_policy" "critical_documents_policy" {
  bucket = aws_s3_bucket.critical_documents.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "AllowApplicationToUploadDocuments"
        Effect    = "Allow"
        Principal = {
          Service = "ap-northeast-1.compute-amazonaws.com"
        }
        Action = [
          "s3:PutObject",
          "s3:DeleteObject"
        ]
        Resource = "${aws_s3_bucket.critical_documents.arn}/*"
      },
      {
        Sid       = "AllowApplicationToDeleteDocuments"
        Effect    = "Allow"
        Principal = {
          Service = "ap-northeast-1.compute-amazonaws.com"
        }
        Action = [
          "s3:DeleteObject"
        ]
        Resource = "${aws_s3_bucket.critical_documents.arn}/*"
      },
      {
        Sid       = "DenyUnauthorizedAccess"
        Effect    = "Deny"
        Principal = "*"
        Action     = "s3:*"
        Resource  = aws_s3_bucket.critical_documents.arn
      }
    ]
  })
}

# Create an S3 bucket for static website hosting
resource "aws_s3_bucket" "static_website" {
  bucket = "document-management-system-static-website"

  website {
    index_document = "index.html"
  }
}