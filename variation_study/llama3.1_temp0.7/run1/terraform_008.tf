# Generated by ollama (llama3.1)
# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.
# Category: cloud_network_security

# File: main.tf

variable "region" {
  type = string
}

variable "cidr_block" {
  type = string
}

variable "azs" {
  type = list(string)
}

variable "public_subnets_cidr_blocks" {
  type = list(string)
}

variable "private_subnets_cidr_blocks" {
  type = list(string)
}

variable "database_subnets_cidr_blocks" {
  type = list(string)
}

# Create a VPC
resource "aws_vpc" "example" {
  cidr_block = var.cidr_block
  enable_dns_support   = true
  enable_dns_hostnames = true

  tags = {
    Name = "my-vpc"
  }
}

# Create public subnets
resource "aws_subnet" "public" {
  count             = length(var.public_subnets_cidr_blocks)
  vpc_id            = aws_vpc.example.id
  cidr_block        = var.public_subnets_cidr_blocks[count.index]
  availability_zone = var.azs[count.index % length(var.azs)]

  map_public_ip_on_launch = true

  tags = {
    Name = "public-subnet-${count.index}"
  }
}

# Create private subnets
resource "aws_subnet" "private" {
  count             = length(var.private_subnets_cidr_blocks)
  vpc_id            = aws_vpc.example.id
  cidr_block        = var.private_subnets_cidr_blocks[count.index]
  availability_zone = var.azs[count.index % length(var.azs)]

  tags = {
    Name = "private-subnet-${count.index}"
  }
}

# Create database subnets
resource "aws_subnet" "database" {
  count             = length(var.database_subnets_cidr_blocks)
  vpc_id            = aws_vpc.example.id
  cidr_block        = var.database_subnets_cidr_blocks[count.index]
  availability_zone = var.azs[count.index % length(var.azs)]

  tags = {
    Name = "database-subnet-${count.index}"
  }
}

# Create security groups for web, app and database servers
resource "aws_security_group" "web_sg" {
  name        = "web-sg"
  description = "Allow inbound traffic on web port"
  vpc_id      = aws_vpc.example.id

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group" "app_sg" {
  name        = "app-sg"
  description = "Allow inbound traffic on app port"
  vpc_id      = aws_vpc.example.id

  ingress {
    from_port   = 8080
    to_port     = 8080
    protocol    = "tcp"
    cidr_blocks = ["10.0.1.0/24"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group" "database_sg" {
  name        = "database-sg"
  description = "Allow inbound traffic on database port"
  vpc_id      = aws_vpc.example.id

  ingress {
    from_port   = 5432
    to_port     = 5432
    protocol    = "tcp"
    cidr_blocks = ["10.0.1.0/24"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

# Create routing table for public subnets
resource "aws_route_table" "public" {
  vpc_id = aws_vpc.example.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.gw.id
  }

  tags = {
    Name = "public-routing-table"
  }
}

# Create routing table for private subnets
resource "aws_route_table" "private" {
  vpc_id = aws_vpc.example.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_nat_gateway.ngw.id
  }

  tags = {
    Name = "private-routing-table"
  }
}

# Create internet gateway and attach to VPC
resource "aws_internet_gateway" "gw" {
  vpc_id = aws_vpc.example.id

  tags = {
    Name = "my-gateway"
  }
}

# Create NAT gateway and attach to public subnets
resource "aws_nat_gateway" "ngw" {
  allocation_id = aws_eip.eip.id
  subnet_id     = aws_subnet.public[0].id

  tags = {
    Name = "my-nat-gateway"
  }

  depends_on = [aws_internet_gateway.gw]
}

# Create Elastic IP for NAT gateway
resource "aws_eip" "eip" {
  vpc      = true
}