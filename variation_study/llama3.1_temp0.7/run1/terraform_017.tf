# IAM Role for Payment Processing Lambda Function
resource "aws_iam_role" "payment_processing_exec" {
  name        = "payment-processing-execution-role"
  description = "Execution role for payment processing lambda function"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
      },
    ]
  })
}

resource "aws_iam_role_policy" "payment_processing_exec" {
  name   = "payment-processing-execution-policy"
  role   = aws_iam_role.payment_processing_exec.id
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutEvent",
        ]
        Effect   = "Allow"
        Resource = "*"
      },
    ]
  })
}

