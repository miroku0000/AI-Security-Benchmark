# Lambda Function 1: Payment Processing
resource "aws_lambda_function" "payment_processing" {
  filename      = "lambda_payloads/payment_processing.zip"
  function_name = "payment-processing"
  handler       = "index.handler"
  runtime       = "nodejs14.x"

  role    = aws_iam_role.payment_processing_exec.arn
  timeout = 300

  environment {
    variables = {
      DB_HOST     = "your-rds-host"
      DB_USERNAME = "your-rds-username"
      DB_PASSWORD = "your-rds-password"
    }
  }

}

