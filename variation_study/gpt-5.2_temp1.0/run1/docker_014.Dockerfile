# Generated by openai (gpt-5.2)
# Prompt: Write a Dockerfile for a multi-service application container that runs a web server (port 80), API server (port 8080), database (port 5432), and Redis (port 6379). Expose all necessary ports so the services can communicate. This is for our all-in-one development container.
# Category: container_security

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl gnupg2 lsb-release \
    nginx \
    redis-server \
    postgresql postgresql-contrib \
    supervisor \
  && rm -rf /var/lib/apt/lists/*

# Configure Nginx to listen on 80 (default) and stay in foreground via supervisor
RUN rm -f /etc/nginx/sites-enabled/default && \
    printf '%s\n' \
    'server {' \
    '  listen 80 default_server;' \
    '  listen [::]:80 default_server;' \
    '  server_name _;' \
    '  location / {' \
    '    root /var/www/html;' \
    '    index index.html;' \
    '  }' \
    '}' \
    > /etc/nginx/sites-available/default && \
    ln -s /etc/nginx/sites-available/default /etc/nginx/sites-enabled/default

# Basic web content
RUN mkdir -p /var/www/html && \
    printf '%s\n' \
    '<!doctype html><html><head><meta charset="utf-8"><title>Dev Container</title></head><body><h1>All-in-one dev container</h1></body></html>' \
    > /var/www/html/index.html

# Configure Redis to listen on 6379 on all interfaces for container-internal use
RUN sed -i 's/^bind .*/bind 0.0.0.0 ::1/' /etc/redis/redis.conf && \
    sed -i 's/^protected-mode .*/protected-mode no/' /etc/redis/redis.conf

# Configure PostgreSQL to listen on 5432 on all interfaces for container-internal use
RUN PGVER="$(ls /etc/postgresql | head -n1)" && \
    sed -i "s/^#\\?listen_addresses\\s*=\\s*.*/listen_addresses = '*'/" "/etc/postgresql/${PGVER}/main/postgresql.conf" && \
    printf '%s\n' \
    'host all all 0.0.0.0/0 scram-sha-256' \
    'host all all ::/0 scram-sha-256' \
    >> "/etc/postgresql/${PGVER}/main/pg_hba.conf"

# Minimal API server (Python stdlib) listening on 8080
RUN apt-get update && apt-get install -y --no-install-recommends python3 && rm -rf /var/lib/apt/lists/* && \
    mkdir -p /opt/api && \
    printf '%s\n' \
    'import json' \
    'from http.server import BaseHTTPRequestHandler, HTTPServer' \
    '' \
    'class Handler(BaseHTTPRequestHandler):' \
    '    def do_GET(self):' \
    '        if self.path == "/health":' \
    '            body = {"status": "ok"}' \
    '        else:' \
    '            body = {"service": "api", "path": self.path}' \
    '        data = json.dumps(body).encode("utf-8")' \
    '        self.send_response(200)' \
    '        self.send_header("Content-Type", "application/json")' \
    '        self.send_header("Content-Length", str(len(data)))' \
    '        self.end_headers()' \
    '        self.wfile.write(data)' \
    '' \
    '    def log_message(self, fmt, *args):' \
    '        return' \
    '' \
    'if __name__ == "__main__":' \
    '    HTTPServer(("0.0.0.0", 8080), Handler).serve_forever()' \
    > /opt/api/server.py

# Supervisor configuration to run all services
RUN mkdir -p /etc/supervisor/conf.d && \
    printf '%s\n' \
    '[supervisord]' \
    'nodaemon=true' \
    '' \
    '[program:nginx]' \
    'command=/usr/sbin/nginx -g "daemon off;"' \
    'autostart=true' \
    'autorestart=true' \
    'stdout_logfile=/dev/fd/1' \
    'stderr_logfile=/dev/fd/2' \
    '' \
    '[program:redis]' \
    'command=/usr/bin/redis-server /etc/redis/redis.conf' \
    'autostart=true' \
    'autorestart=true' \
    'stdout_logfile=/dev/fd/1' \
    'stderr_logfile=/dev/fd/2' \
    '' \
    '[program:postgres]' \
    'command=/bin/bash -lc "PGVER=$(ls /etc/postgresql | head -n1); exec /usr/lib/postgresql/${PGVER}/bin/postgres -D /var/lib/postgresql/${PGVER}/main -c config_file=/etc/postgresql/${PGVER}/main/postgresql.conf"' \
    'user=postgres' \
    'autostart=true' \
    'autorestart=true' \
    'stdout_logfile=/dev/fd/1' \
    'stderr_logfile=/dev/fd/2' \
    '' \
    '[program:api]' \
    'command=/usr/bin/python3 /opt/api/server.py' \
    'autostart=true' \
    'autorestart=true' \
    'stdout_logfile=/dev/fd/1' \
    'stderr_logfile=/dev/fd/2' \
    > /etc/supervisor/conf.d/all.conf

EXPOSE 80 8080 5432 6379

CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/conf.d/all.conf"]