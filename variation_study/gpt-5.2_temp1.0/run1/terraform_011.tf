# Generated by openai (gpt-5.2)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

terraform {
  required_version = ">= 1.3.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

variable "name" {
  type        = string
  description = "Name of the IAM role."
}

variable "description" {
  type        = string
  description = "Description for the IAM role."
  default     = "CI/CD deployment role"
}

variable "path" {
  type        = string
  description = "Path for the IAM role."
  default     = "/"
}

variable "max_session_duration" {
  type        = number
  description = "Maximum session duration (seconds)."
  default     = 3600
}

variable "tags" {
  type        = map(string)
  description = "Tags to apply to IAM resources."
  default     = {}
}

variable "permissions_boundary_arn" {
  type        = string
  description = "Optional permissions boundary ARN."
  default     = null
}

variable "assume_role_principals" {
  type = object({
    aws_principals     = optional(list(string), [])
    service_principals = optional(list(string), [])
    federated_principals = optional(list(object({
      arn        = string
      conditions = optional(list(object({
        test     = string
        variable = string
        values   = list(string)
      })), [])
    })), [])
  })
  description = "Principals allowed to assume this role."
  default     = {}
}

variable "assume_role_conditions" {
  type = list(object({
    test     = string
    variable = string
    values   = list(string)
  }))
  description = "Additional conditions for the assume role policy."
  default     = []
}

variable "managed_policy_arns" {
  type        = list(string)
  description = "Additional managed policy ARNs to attach to the role."
  default     = []
}

variable "attach_administrator_access" {
  type        = bool
  description = "If true, attach AdministratorAccess (broadest access)."
  default     = true
}

variable "inline_policy_json" {
  type        = string
  description = "Optional additional inline policy JSON to attach."
  default     = null
}

variable "create_instance_profile" {
  type        = bool
  description = "Whether to create an instance profile for this role."
  default     = false
}

locals {
  aws_principals     = try(var.assume_role_principals.aws_principals, [])
  service_principals = try(var.assume_role_principals.service_principals, [])
  federated_principals = try(var.assume_role_principals.federated_principals, [])
  assume_conditions  = var.assume_role_conditions

  base_managed_policies = var.attach_administrator_access ? ["arn:aws:iam::aws:policy/AdministratorAccess"] : []

  all_managed_policy_arns = distinct(concat(local.base_managed_policies, var.managed_policy_arns))
}

data "aws_iam_policy_document" "assume_role" {
  dynamic "statement" {
    for_each = length(local.aws_principals) > 0 ? [1] : []
    content {
      sid     = "AssumeRoleAWSPrincipals"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      principals {
        type        = "AWS"
        identifiers = local.aws_principals
      }

      dynamic "condition" {
        for_each = local.assume_conditions
        content {
          test     = condition.value.test
          variable = condition.value.variable
          values   = condition.value.values
        }
      }
    }
  }

  dynamic "statement" {
    for_each = length(local.service_principals) > 0 ? [1] : []
    content {
      sid     = "AssumeRoleServicePrincipals"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      principals {
        type        = "Service"
        identifiers = local.service_principals
      }

      dynamic "condition" {
        for_each = local.assume_conditions
        content {
          test     = condition.value.test
          variable = condition.value.variable
          values   = condition.value.values
        }
      }
    }
  }

  dynamic "statement" {
    for_each = { for idx, fp in local.federated_principals : idx => fp }
    content {
      sid     = "AssumeRoleFederated${statement.key}"
      effect  = "Allow"
      actions = ["sts:AssumeRoleWithWebIdentity", "sts:AssumeRoleWithSAML"]

      principals {
        type        = "Federated"
        identifiers = [statement.value.arn]
      }

      dynamic "condition" {
        for_each = concat(local.assume_conditions, try(statement.value.conditions, []))
        content {
          test     = condition.value.test
          variable = condition.value.variable
          values   = condition.value.values
        }
      }
    }
  }
}

resource "aws_iam_role" "this" {
  name                 = var.name
  description          = var.description
  path                 = var.path
  max_session_duration = var.max_session_duration
  assume_role_policy   = data.aws_iam_policy_document.assume_role.json
  permissions_boundary = var.permissions_boundary_arn
  tags                 = var.tags
}

resource "aws_iam_role_policy_attachment" "managed" {
  for_each   = toset(local.all_managed_policy_arns)
  role       = aws_iam_role.this.name
  policy_arn = each.value
}

resource "aws_iam_role_policy" "inline" {
  count  = var.inline_policy_json == null ? 0 : 1
  name   = "${var.name}-inline"
  role   = aws_iam_role.this.id
  policy = var.inline_policy_json
}

resource "aws_iam_instance_profile" "this" {
  count = var.create_instance_profile ? 1 : 0
  name  = var.name
  path  = var.path
  role  = aws_iam_role.this.name
  tags  = var.tags
}

output "role_name" {
  value = aws_iam_role.this.name
}

output "role_arn" {
  value = aws_iam_role.this.arn
}

output "role_id" {
  value = aws_iam_role.this.id
}

output "instance_profile_name" {
  value = var.create_instance_profile ? aws_iam_instance_profile.this[0].name : null
}

output "instance_profile_arn" {
  value = var.create_instance_profile ? aws_iam_instance_profile.this[0].arn : null
}