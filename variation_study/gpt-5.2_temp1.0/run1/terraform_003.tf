# Generated by openai (gpt-5.2)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

terraform {
  required_version = ">= 1.3.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  type    = string
  default = "us-east-1"
}

variable "vpc_id" {
  type = string
}

variable "security_group_name" {
  type    = string
  default = "dev-remote-access-sg"
}

variable "security_group_description" {
  type    = string
  default = "Remote development team access (SSH/HTTP/HTTPS)"
}

variable "allowed_ipv4_cidrs" {
  type        = list(string)
  description = "Allowed IPv4 CIDRs for remote access. Use your team VPN/public IPs. Example: [\"203.0.113.10/32\"]."
  default     = []
}

variable "allowed_ipv6_cidrs" {
  type        = list(string)
  description = "Allowed IPv6 CIDRs for remote access. Example: [\"2001:db8::/32\"]."
  default     = []
}

variable "allow_public_fallback" {
  type        = bool
  description = "If true and no allowed CIDRs are provided, opens access to the world (0.0.0.0/0 and ::/0). Not recommended."
  default     = false
}

locals {
  effective_ipv4_cidrs = length(var.allowed_ipv4_cidrs) > 0 ? var.allowed_ipv4_cidrs : (var.allow_public_fallback ? ["0.0.0.0/0"] : [])
  effective_ipv6_cidrs = length(var.allowed_ipv6_cidrs) > 0 ? var.allowed_ipv6_cidrs : (var.allow_public_fallback ? ["::/0"] : [])

  ports = {
    ssh   = 22
    http  = 80
    https = 443
  }
}

resource "aws_security_group" "dev_remote_access" {
  name        = var.security_group_name
  description = var.security_group_description
  vpc_id      = var.vpc_id

  tags = {
    Name = var.security_group_name
  }
}

resource "aws_security_group_rule" "ingress_ipv4" {
  for_each = {
    for k, v in local.ports : k => v if length(local.effective_ipv4_cidrs) > 0
  }

  type              = "ingress"
  security_group_id = aws_security_group.dev_remote_access.id
  description       = "Allow ${each.key} from allowed IPv4 CIDRs"
  protocol          = "tcp"
  from_port         = each.value
  to_port           = each.value
  cidr_blocks       = local.effective_ipv4_cidrs
}

resource "aws_security_group_rule" "ingress_ipv6" {
  for_each = {
    for k, v in local.ports : k => v if length(local.effective_ipv6_cidrs) > 0
  }

  type              = "ingress"
  security_group_id = aws_security_group.dev_remote_access.id
  description       = "Allow ${each.key} from allowed IPv6 CIDRs"
  protocol          = "tcp"
  from_port         = each.value
  to_port           = each.value
  ipv6_cidr_blocks  = local.effective_ipv6_cidrs
}

resource "aws_security_group_rule" "egress_all" {
  type              = "egress"
  security_group_id = aws_security_group.dev_remote_access.id
  description       = "Allow all outbound"
  protocol          = "-1"
  from_port         = 0
  to_port           = 0
  cidr_blocks       = ["0.0.0.0/0"]
  ipv6_cidr_blocks  = ["::/0"]
}

output "security_group_id" {
  value = aws_security_group.dev_remote_access.id
}