# Generated by openai (gpt-5.2)
# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.30"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

data "aws_partition" "current" {}
data "aws_caller_identity" "current" {}
data "aws_region" "current" {}

############################
# Variables
############################

variable "aws_region" {
  type        = string
  description = "AWS region"
  default     = "us-east-1"
}

variable "project" {
  type        = string
  description = "Project name/prefix"
  default     = "payments"
}

variable "environment" {
  type        = string
  description = "Environment name"
  default     = "prod"
}

variable "lambda_runtime" {
  type        = string
  default     = "python3.12"
}

variable "lambda_architectures" {
  type        = list(string)
  default     = ["arm64"]
}

variable "lambda_timeout_seconds" {
  type        = number
  default     = 30
}

variable "lambda_memory_mb" {
  type        = number
  default     = 512
}

variable "kms_key_arn" {
  type        = string
  description = "KMS key ARN used to encrypt sensitive data at rest (S3/SQS/DynamoDB if using KMS). Also used for Lambda env encryption."
}

variable "s3_bucket_arn" {
  type        = string
  description = "S3 bucket ARN containing sensitive payloads (e.g., raw events, receipts)."
}

variable "s3_prefixes" {
  type        = list(string)
  description = "Allowed S3 key prefixes for read/write (relative to bucket). Example: [\"inbound/\", \"processed/\"]"
  default     = ["inbound/", "processed/"]
}

variable "sqs_queue_arn" {
  type        = string
  description = "SQS queue ARN for payment requests"
}

variable "sqs_queue_url" {
  type        = string
  description = "SQS queue URL for payment requests"
}

variable "dynamodb_table_arn" {
  type        = string
  description = "DynamoDB table ARN for idempotency/ledger state"
}

variable "dynamodb_table_name" {
  type        = string
  description = "DynamoDB table name for idempotency/ledger state"
}

variable "secrets_manager_arns" {
  type        = list(string)
  description = "List of Secrets Manager secret ARNs needed (e.g., payment gateway creds)."
  default     = []
}

variable "vpc_subnet_ids" {
  type        = list(string)
  description = "Private subnet IDs for Lambda VPC access (optional)."
  default     = []
}

variable "vpc_security_group_ids" {
  type        = list(string)
  description = "Security group IDs for Lambda VPC access (optional)."
  default     = []
}

variable "log_retention_days" {
  type        = number
  default     = 30
}

variable "enable_vpc" {
  type        = bool
  default     = false
}

variable "lambda_source_dir" {
  type        = string
  description = "Directory containing lambda source code files"
  default     = "lambda_src"
}

############################
# Locals
############################

locals {
  name_prefix = "${var.project}-${var.environment}"

  s3_object_arns = flatten([
    for p in var.s3_prefixes : [
      "${var.s3_bucket_arn}/${p}*"
    ]
  ])

  use_vpc = var.enable_vpc && length(var.vpc_subnet_ids) > 0 && length(var.vpc_security_group_ids) > 0

  common_env = {
    ENVIRONMENT          = var.environment
    PROJECT              = var.project
    KMS_KEY_ARN           = var.kms_key_arn
    DDB_TABLE_NAME        = var.dynamodb_table_name
    SQS_QUEUE_URL         = var.sqs_queue_url
    S3_BUCKET_ARN         = var.s3_bucket_arn
    S3_ALLOWED_PREFIXES   = join(",", var.s3_prefixes)
  }
}

############################
# Lambda source packages (minimal placeholder logic)
############################

resource "local_file" "processor_py" {
  filename = "${var.lambda_source_dir}/processor.py"
  content  = <<-PY
import json
import os
import boto3
from botocore.config import Config
from botocore.exceptions import ClientError

cfg = Config(retries={"max_attempts": 3, "mode": "standard"})

ddb = boto3.client("dynamodb", config=cfg)
s3 = boto3.client("s3", config=cfg)
sqs = boto3.client("sqs", config=cfg)

TABLE = os.environ["DDB_TABLE_NAME"]
QUEUE_URL = os.environ["SQS_QUEUE_URL"]
S3_BUCKET_ARN = os.environ.get("S3_BUCKET_ARN", "")
S3_ALLOWED_PREFIXES = os.environ.get("S3_ALLOWED_PREFIXES", "").split(",") if os.environ.get("S3_ALLOWED_PREFIXES") else []
ENV = os.environ.get("ENVIRONMENT", "unknown")

def _mask(obj):
    if obj is None:
        return None
    if isinstance(obj, dict):
        redacted = {}
        for k, v in obj.items():
            lk = str(k).lower()
            if any(s in lk for s in ["pan", "card", "cvv", "cvc", "account", "routing", "ssn", "secret", "token"]):
                redacted[k] = "***"
            else:
                redacted[k] = _mask(v)
        return redacted
    if isinstance(obj, list):
        return [_mask(x) for x in obj]
    return obj

def _parse_s3_from_arn(arn):
    # arn:aws:s3:::bucket
    parts = arn.split(":::")
    return parts[1] if len(parts) == 2 else None

def _assert_s3_key_allowed(key):
    if not S3_ALLOWED_PREFIXES:
        return
    allowed = any(key.startswith(p) for p in S3_ALLOWED_PREFIXES if p)
    if not allowed:
        raise ValueError("S3 key prefix not allowed")

def _idempotency_key(event):
    # Prefer a deterministic key from upstream (payment_id, idempotency_key, etc.)
    for k in ["idempotency_key", "payment_id", "transaction_id", "request_id"]:
        if isinstance(event, dict) and event.get(k):
            return str(event[k])
    return None

def _try_acquire_lock(key):
    if not key:
        return False
    try:
        ddb.put_item(
            TableName=TABLE,
            Item={
                "pk": {"S": f"PAYMENT#{key}"},
                "sk": {"S": "LOCK"},
                "status": {"S": "IN_PROGRESS"},
            },
            ConditionExpression="attribute_not_exists(pk)"
        )
        return True
    except ClientError as e:
        if e.response.get("Error", {}).get("Code") == "ConditionalCheckFailedException":
            return False
        raise

def _complete_lock(key, status):
    if not key:
        return
    ddb.update_item(
        TableName=TABLE,
        Key={"pk": {"S": f"PAYMENT#{key}"}, "sk": {"S": "LOCK"}},
        UpdateExpression="SET #s = :s",
        ExpressionAttributeNames={"#s": "status"},
        ExpressionAttributeValues={":s": {"S": status}},
    )

def _handle_payload(payload):
    # Placeholder for payment processing logic.
    # Ensure you never log raw sensitive fields.
    amount = payload.get("amount")
    currency = payload.get("currency")
    payment_method = payload.get("payment_method", {})
    # Perform validations
    if amount is None or currency is None:
        raise ValueError("Missing amount/currency")
    # Example: route to downstream by queue or store artifacts in S3
    return {"accepted": True, "amount": amount, "currency": currency, "method_type": payment_method.get("type")}

def handler(event, context):
    # Supports direct invoke, SQS, or S3 reference pattern
    try:
        # If SQS event
        if isinstance(event, dict) and event.get("Records") and event["Records"][0].get("eventSource") == "aws:sqs":
            results = []
            for r in event["Records"]:
                body = json.loads(r["body"]) if r.get("body") else {}
                key = _idempotency_key(body)
                if key and not _try_acquire_lock(key):
                    results.append({"skipped": True, "reason": "duplicate", "idempotency_key": key})
                    continue

                try:
                    out = _handle_payload(body)
                    if key:
                        _complete_lock(key, "SUCCEEDED")
                    results.append(out)
                except Exception:
                    if key:
                        _complete_lock(key, "FAILED")
                    raise
            return {"results": results}

        # If payload references S3 object: {"s3_key":"inbound/....json"}
        if isinstance(event, dict) and event.get("s3_key"):
            bucket = _parse_s3_from_arn(S3_BUCKET_ARN)
            if not bucket:
                raise ValueError("S3_BUCKET_ARN not configured")
            s3_key = event["s3_key"]
            _assert_s3_key_allowed(s3_key)
            obj = s3.get_object(Bucket=bucket, Key=s3_key)
            payload = json.loads(obj["Body"].read().decode("utf-8"))
            key = _idempotency_key(payload)
            if key and not _try_acquire_lock(key):
                return {"skipped": True, "reason": "duplicate", "idempotency_key": key}

            try:
                out = _handle_payload(payload)
                if key:
                    _complete_lock(key, "SUCCEEDED")
                return out
            except Exception:
                if key:
                    _complete_lock(key, "FAILED")
                raise

        # Direct invoke payload
        payload = event if isinstance(event, dict) else {}
        key = _idempotency_key(payload)
        if key and not _try_acquire_lock(key):
            return {"skipped": True, "reason": "duplicate", "idempotency_key": key}
        try:
            out = _handle_payload(payload)
            if key:
                _complete_lock(key, "SUCCEEDED")
            return out
        except Exception:
            if key:
                _complete_lock(key, "FAILED")
            raise

    except Exception as e:
        # Log masked error context only
        print(json.dumps({
            "message": "processing_failed",
            "env": ENV,
            "error": str(e),
            "event": _mask(event) if isinstance(event, (dict, list)) else "non_json"
        }))
        raise
PY
}

resource "local_file" "authorizer_py" {
  filename = "${var.lambda_source_dir}/authorizer.py"
  content  = <<-PY
import json
import os
import boto3
from botocore.config import Config

cfg = Config(retries={"max_attempts": 3, "mode": "standard"})
secrets = boto3.client("secretsmanager", config=cfg)

SECRET_ARN = os.environ.get("API_SECRET_ARN", "")
ENV = os.environ.get("ENVIRONMENT", "unknown")

def _deny():
    return {
        "isAuthorized": False,
        "context": {"env": ENV}
    }

def handler(event, context):
    # Minimal Lambda authorizer-style function (for API Gateway HTTP API simple response).
    # Expects header: x-api-key
    try:
        headers = event.get("headers") or {}
        api_key = headers.get("x-api-key") or headers.get("X-Api-Key") or headers.get("X-API-KEY")
        if not api_key or not SECRET_ARN:
            return _deny()

        sec = secrets.get_secret_value(SecretId=SECRET_ARN)
        expected = sec.get("SecretString") or ""
        if api_key != expected:
            return _deny()

        return {"isAuthorized": True, "context": {"env": ENV}}
    except Exception:
        return _deny()
PY
}

data "archive_file" "processor_zip" {
  type        = "zip"
  source_dir  = var.lambda_source_dir
  output_path = "${path.module}/build/processor.zip"
  excludes    = ["authorizer.py"]
  depends_on  = [local_file.processor_py, local_file.authorizer_py]
}

data "archive_file" "authorizer_zip" {
  type        = "zip"
  source_dir  = var.lambda_source_dir
  output_path = "${path.module}/build/authorizer.zip"
  excludes    = ["processor.py"]
  depends_on  = [local_file.processor_py, local_file.authorizer_py]
}

############################
# CloudWatch Logs (no alarms/dashboards yet)
############################

resource "aws_cloudwatch_log_group" "processor" {
  name              = "/aws/lambda/${local.name_prefix}-payment-processor"
  retention_in_days = var.log_retention_days
  kms_key_id        = var.kms_key_arn
}

resource "aws_cloudwatch_log_group" "authorizer" {
  name              = "/aws/lambda/${local.name_prefix}-payment-authorizer"
  retention_in_days = var.log_retention_days
  kms_key_id        = var.kms_key_arn
}

############################
# IAM
############################

data "aws_iam_policy_document" "lambda_assume" {
  statement {
    effect  = "Allow"
    actions = ["sts:AssumeRole"]
    principals {
      type        = "Service"
      identifiers = ["lambda.amazonaws.com"]
    }
  }
}

data "aws_iam_policy_document" "processor_policy" {
  statement {
    sid     = "WriteLogs"
    effect  = "Allow"
    actions = ["logs:CreateLogStream", "logs:PutLogEvents"]
    resources = [
      aws_cloudwatch_log_group.processor.arn,
      "${aws_cloudwatch_log_group.processor.arn}:*"
    ]
  }

  statement {
    sid     = "DynamoDBIdempotency"
    effect  = "Allow"
    actions = [
      "dynamodb:PutItem",
      "dynamodb:UpdateItem",
      "dynamodb:GetItem",
      "dynamodb:DeleteItem"
    ]
    resources = [var.dynamodb_table_arn]
  }

  statement {
    sid     = "SQSConsume"
    effect  = "Allow"
    actions = [
      "sqs:ReceiveMessage",
      "sqs:DeleteMessage",
      "sqs:GetQueueAttributes",
      "sqs:ChangeMessageVisibility"
    ]
    resources = [var.sqs_queue_arn]
  }

  statement {
    sid     = "S3ReadWriteRestricted"
    effect  = "Allow"
    actions = [
      "s3:GetObject",
      "s3:PutObject",
      "s3:DeleteObject"
    ]
    resources = local.s3_object_arns
  }

  statement {
    sid     = "KMSUseForSensitiveData"
    effect  = "Allow"
    actions = [
      "kms:Encrypt",
      "kms:Decrypt",
      "kms:ReEncrypt*",
      "kms:GenerateDataKey*",
      "kms:DescribeKey"
    ]
    resources = [var.kms_key_arn]
  }

  dynamic "statement" {
    for_each = local.use_vpc ? [1] : []
    content {
      sid     = "VPCAccessENI"
      effect  = "Allow"
      actions = [
        "ec2:CreateNetworkInterface",
        "ec2:DescribeNetworkInterfaces",
        "ec2:DeleteNetworkInterface",
        "ec2:AssignPrivateIpAddresses",
        "ec2:UnassignPrivateIpAddresses"
      ]
      resources = ["*"]
    }
  }
}

resource "aws_iam_role" "processor" {
  name               = "${local.name_prefix}-payment-processor-role"
  assume_role_policy = data.aws_iam_policy_document.lambda_assume.json
}

resource "aws_iam_role_policy" "processor_inline" {
  name   = "${local.name_prefix}-payment-processor-policy"
  role   = aws_iam_role.processor.id
  policy = data.aws_iam_policy_document.processor_policy.json
}

data "aws_iam_policy_document" "authorizer_policy" {
  statement {
    sid     = "WriteLogs"
    effect  = "Allow"
    actions = ["logs:CreateLogStream", "logs:PutLogEvents"]
    resources = [
      aws_cloudwatch_log_group.authorizer.arn,
      "${aws_cloudwatch_log_group.authorizer.arn}:*"
    ]
  }

  dynamic "statement" {
    for_each = length(var.secrets_manager_arns) > 0 ? [1] : []
    content {
      sid     = "ReadSecrets"
      effect  = "Allow"
      actions = ["secretsmanager:GetSecretValue", "secretsmanager:DescribeSecret"]
      resources = var.secrets_manager_arns
    }
  }

  statement {
    sid     = "KMSDecryptSecretsIfEncrypted"
    effect  = "Allow"
    actions = ["kms:Decrypt", "kms:DescribeKey"]
    resources = [var.kms_key_arn]
  }
}

resource "aws_iam_role" "authorizer" {
  name               = "${local.name_prefix}-payment-authorizer-role"
  assume_role_policy = data.aws_iam_policy_document.lambda_assume.json
}

resource "aws_iam_role_policy" "authorizer_inline" {
  name   = "${local.name_prefix}-payment-authorizer-policy"
  role   = aws_iam_role.authorizer.id
  policy = data.aws_iam_policy_document.authorizer_policy.json
}

############################
# Lambda functions
############################

resource "aws_lambda_function" "payment_processor" {
  function_name = "${local.name_prefix}-payment-processor"
  role          = aws_iam_role.processor.arn
  runtime       = var.lambda_runtime
  handler       = "processor.handler"

  architectures = var.lambda_architectures
  timeout       = var.lambda_timeout_seconds
  memory_size   = var.lambda_memory_mb

  filename         = data.archive_file.processor_zip.output_path
  source_code_hash = data.archive_file.processor_zip.output_base64sha256

  kms_key_arn = var.kms_key_arn

  environment {
    variables = local.common_env
  }

  dynamic "vpc_config" {
    for_each = local.use_vpc ? [1] : []
    content {
      subnet_ids         = var.vpc_subnet_ids
      security_group_ids = var.vpc_security_group_ids
    }
  }

  depends_on = [aws_cloudwatch_log_group.processor]
}

resource "aws_lambda_function" "payment_authorizer" {
  function_name = "${local.name_prefix}-payment-authorizer"
  role          = aws_iam_role.authorizer.arn
  runtime       = var.lambda_runtime
  handler       = "authorizer.handler"

  architectures = var.lambda_architectures
  timeout       = 5
  memory_size   = 256

  filename         = data.archive_file.authorizer_zip.output_path
  source_code_hash = data.archive_file.authorizer_zip.output_base64sha256

  kms_key_arn = var.kms_key_arn

  environment {
    variables = merge(
      {
        ENVIRONMENT = var.environment
        PROJECT     = var.project
      },
      length(var.secrets_manager_arns) > 0 ? { API_SECRET_ARN = var.secrets_manager_arns[0] } : {}
    )
  }

  dynamic "vpc_config" {
    for_each = local.use_vpc ? [1] : []
    content {
      subnet_ids         = var.vpc_subnet_ids
      security_group_ids = var.vpc_security_group_ids
    }
  }

  depends_on = [aws_cloudwatch_log_group.authorizer]
}

############################
# SQS trigger (payment processor)
############################

resource "aws_lambda_event_source_mapping" "processor_from_sqs" {
  event_source_arn = var.sqs_queue_arn
  function_name    = aws_lambda_function.payment_processor.arn

  batch_size                         = 10
  maximum_batching_window_in_seconds = 5
  function_response_types            = ["ReportBatchItemFailures"]
  enabled                            = true
}

############################
# Outputs
############################

output "payment_processor_lambda_arn" {
  value = aws_lambda_function.payment_processor.arn
}

output "payment_authorizer_lambda_arn" {
  value = aws_lambda_function.payment_authorizer.arn
}

output "processor_role_arn" {
  value = aws_iam_role.processor.arn
}

output "authorizer_role_arn" {
  value = aws_iam_role.authorizer.arn
}