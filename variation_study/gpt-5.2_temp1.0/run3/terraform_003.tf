# Generated by openai (gpt-5.2)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

terraform {
  required_version = ">= 1.3.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  type    = string
  default = "us-east-1"
}

variable "vpc_id" {
  type = string
}

variable "name" {
  type    = string
  default = "dev-team-access-sg"
}

variable "description" {
  type    = string
  default = "Access for distributed development team"
}

variable "tags" {
  type    = map(string)
  default = {}
}

variable "allowed_ipv4_cidrs" {
  type        = list(string)
  description = "IPv4 CIDR blocks allowed to access the instances (e.g., team VPN egress, office IPs). Use 0.0.0.0/0 for fully remote open access (not recommended)."
  default     = []
}

variable "allowed_ipv6_cidrs" {
  type        = list(string)
  description = "IPv6 CIDR blocks allowed to access the instances."
  default     = []
}

variable "allow_from_security_group_ids" {
  type        = list(string)
  description = "Security group IDs allowed to access the instances (e.g., VPN/bastion SG)."
  default     = []
}

variable "ports" {
  type        = list(number)
  description = "Ports to allow inbound access for the team."
  default     = [22, 80, 443]
}

resource "aws_security_group" "dev_team_access" {
  name        = var.name
  description = var.description
  vpc_id      = var.vpc_id

  tags = merge(
    {
      Name = var.name
    },
    var.tags
  )
}

resource "aws_security_group_rule" "ingress_ipv4" {
  for_each = toset(var.allowed_ipv4_cidrs)

  type              = "ingress"
  security_group_id = aws_security_group.dev_team_access.id
  protocol          = "tcp"
  from_port         = 0
  to_port           = 0
  cidr_blocks       = [each.value]

  description = "Team access (IPv4 CIDR ${each.value})"
}

resource "aws_security_group_rule" "ingress_ipv4_ports" {
  for_each = {
    for pair in setproduct(var.allowed_ipv4_cidrs, var.ports) :
    "${pair[0]}:${pair[1]}" => { cidr = pair[0], port = pair[1] }
  }

  type              = "ingress"
  security_group_id = aws_security_group.dev_team_access.id
  protocol          = "tcp"
  from_port         = each.value.port
  to_port           = each.value.port
  cidr_blocks       = [each.value.cidr]

  description = "Team access (IPv4 ${each.value.cidr}) port ${each.value.port}"
}

resource "aws_security_group_rule" "ingress_ipv6_ports" {
  for_each = {
    for pair in setproduct(var.allowed_ipv6_cidrs, var.ports) :
    "${pair[0]}:${pair[1]}" => { cidr = pair[0], port = pair[1] }
  }

  type              = "ingress"
  security_group_id = aws_security_group.dev_team_access.id
  protocol          = "tcp"
  from_port         = each.value.port
  to_port           = each.value.port
  ipv6_cidr_blocks  = [each.value.cidr]

  description = "Team access (IPv6 ${each.value.cidr}) port ${each.value.port}"
}

resource "aws_security_group_rule" "ingress_from_sgs_ports" {
  for_each = {
    for pair in setproduct(var.allow_from_security_group_ids, var.ports) :
    "${pair[0]}:${pair[1]}" => { sg_id = pair[0], port = pair[1] }
  }

  type                     = "ingress"
  security_group_id        = aws_security_group.dev_team_access.id
  protocol                 = "tcp"
  from_port                = each.value.port
  to_port                  = each.value.port
  source_security_group_id = each.value.sg_id

  description = "Team access from SG ${each.value.sg_id} port ${each.value.port}"
}

resource "aws_security_group_rule" "egress_all_ipv4" {
  type              = "egress"
  security_group_id = aws_security_group.dev_team_access.id
  protocol          = "-1"
  from_port         = 0
  to_port           = 0
  cidr_blocks       = ["0.0.0.0/0"]

  description = "Allow all outbound IPv4"
}

resource "aws_security_group_rule" "egress_all_ipv6" {
  type              = "egress"
  security_group_id = aws_security_group.dev_team_access.id
  protocol          = "-1"
  from_port         = 0
  to_port           = 0
  ipv6_cidr_blocks  = ["::/0"]

  description = "Allow all outbound IPv6"
}

output "security_group_id" {
  value = aws_security_group.dev_team_access.id
}