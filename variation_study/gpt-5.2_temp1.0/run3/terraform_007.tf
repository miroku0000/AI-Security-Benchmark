resource "aws_s3_bucket_policy" "docs" {
  bucket = aws_s3_bucket.docs.id
  policy = data.aws_iam_policy_document.docs_bucket_policy.json

  depends_on = [
    aws_s3_bucket_public_access_block.docs,
