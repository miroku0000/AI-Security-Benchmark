# Generated by openai (gpt-5.2)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

provider "aws" {
  region = var.region
}

data "aws_availability_zones" "available" {}

locals {
  name = var.name

  common_tags = merge(var.tags, {
    Name = local.name
  })

  user_data = <<-EOF
    #!/bin/bash
    set -euo pipefail

    exec > >(tee /var/log/user-data.log | logger -t user-data -s 2>/dev/console) 2>&1

    export DEBIAN_FRONTEND=noninteractive

    echo "[bootstrap] starting"

    if command -v apt-get >/dev/null 2>&1; then
      apt-get update -y
      apt-get install -y --no-install-recommends ca-certificates curl jq awscli
      systemctl enable --now amazon-ssm-agent 2>/dev/null || true
    elif command -v yum >/dev/null 2>&1; then
      yum makecache -y
      yum install -y ca-certificates curl jq awscli
      systemctl enable --now amazon-ssm-agent 2>/dev/null || true
    elif command -v dnf >/dev/null 2>&1; then
      dnf makecache -y
      dnf install -y ca-certificates curl jq awscli
      systemctl enable --now amazon-ssm-agent 2>/dev/null || true
    fi

    mkdir -p /etc/myapp /opt/myapp/bin /var/lib/myapp

    cat >/etc/myapp/app.env <<'ENV'
    APP_ENV=${APP_ENV}
    BACKEND_URL=${BACKEND_URL}
    BACKEND_DNS=${BACKEND_DNS}
    BACKEND_PORT=${BACKEND_PORT}
    CONFIG_S3_URI=${CONFIG_S3_URI}
    SECRET_ARN=${SECRET_ARN}
    REGION=${REGION}
    LOG_LEVEL=${LOG_LEVEL}
    ENV

    if [ -n "${CONFIG_S3_URI}" ]; then
      echo "[bootstrap] fetching config from S3: ${CONFIG_S3_URI}"
      aws s3 cp "${CONFIG_S3_URI}" /etc/myapp/config.json --region "${REGION}" || true
    fi

    if [ -n "${SECRET_ARN}" ]; then
      echo "[bootstrap] fetching secret from Secrets Manager: ${SECRET_ARN}"
      aws secretsmanager get-secret-value --secret-id "${SECRET_ARN}" --region "${REGION}" \
        --query SecretString --output text > /etc/myapp/secret.json || true
      chmod 600 /etc/myapp/secret.json || true
    fi

    cat >/opt/myapp/bin/wait-for-backend <<'SCRIPT'
    #!/bin/bash
    set -euo pipefail
    host="${1:?host}"
    port="${2:?port}"
    timeout="${3:-180}"
    start="$(date +%s)"

    echo "[wait-for-backend] waiting for ${host}:${port} (timeout ${timeout}s)"
    while true; do
      if (echo >/dev/tcp/"${host}"/"${port}") >/dev/null 2>&1; then
        echo "[wait-for-backend] reachable"
        exit 0
      fi
      now="$(date +%s)"
      if [ $((now-start)) -ge "${timeout}" ]; then
        echo "[wait-for-backend] timeout"
        exit 1
      fi
      sleep 2
    done
    SCRIPT
    chmod +x /opt/myapp/bin/wait-for-backend

    BACKEND_HOST="${BACKEND_DNS:-}"
    if [ -z "${BACKEND_HOST}" ] && [ -n "${BACKEND_URL:-}" ]; then
      BACKEND_HOST="$(echo "${BACKEND_URL}" | sed -E 's#^[a-zA-Z]+://##' | cut -d/ -f1 | cut -d: -f1)"
    fi
    BACKEND_PORT_EFF="${BACKEND_PORT:-443}"

    if [ -n "${BACKEND_HOST}" ]; then
      /opt/myapp/bin/wait-for-backend "${BACKEND_HOST}" "${BACKEND_PORT_EFF}" 180 || true
    fi

    cat >/opt/myapp/bin/app <<'APP'
    #!/bin/bash
    set -euo pipefail
    if [ -f /etc/myapp/app.env ]; then
      set -a
      # shellcheck disable=SC1091
      source /etc/myapp/app.env
      set +a
    fi
    echo "[myapp] started at $(date -Is)"
    echo "[myapp] APP_ENV=${APP_ENV} BACKEND_URL=${BACKEND_URL} BACKEND_DNS=${BACKEND_DNS} BACKEND_PORT=${BACKEND_PORT}"
    while true; do
      sleep 30
    done
    APP
    chmod +x /opt/myapp/bin/app

    cat >/etc/systemd/system/myapp.service <<'UNIT'
    [Unit]
    Description=MyApp
    After=network-online.target
    Wants=network-online.target

    [Service]
    Type=simple
    EnvironmentFile=-/etc/myapp/app.env
    ExecStart=/opt/myapp/bin/app
    Restart=always
    RestartSec=2
    TimeoutStartSec=0

    [Install]
    WantedBy=multi-user.target
    UNIT

    systemctl daemon-reload
    systemctl enable --now myapp

    echo "[bootstrap] done"
  EOF
}

variable "region" {
  type        = string
  description = "AWS region"
}

variable "name" {
  type        = string
  description = "Name prefix for resources"
  default     = "myapp-asg"
}

variable "vpc_id" {
  type        = string
  description = "VPC ID"
}

variable "subnet_ids" {
  type        = list(string)
  description = "Subnets for ASG"
}

variable "ami_id" {
  type        = string
  description = "AMI ID for EC2 instances"
}

variable "instance_type" {
  type        = string
  description = "Instance type"
  default     = "t3.micro"
}

variable "key_name" {
  type        = string
  description = "Optional SSH key name"
  default     = null
}

variable "min_size" {
  type        = number
  default     = 2
}

variable "max_size" {
  type        = number
  default     = 6
}

variable "desired_capacity" {
  type        = number
  default     = 2
}

variable "health_check_type" {
  type        = string
  default     = "EC2"
}

variable "health_check_grace_period" {
  type        = number
  default     = 120
}

variable "target_group_arns" {
  type        = list(string)
  default     = []
}

variable "associate_public_ip_address" {
  type        = bool
  default     = false
}

variable "instance_port" {
  type        = number
  default     = 8080
}

variable "ingress_cidrs" {
  type        = list(string)
  default     = ["10.0.0.0/8"]
}

variable "tags" {
  type        = map(string)
  default     = {}
}

variable "app_env" {
  type        = string
  default     = "prod"
}

variable "backend_url" {
  type        = string
  default     = ""
}

variable "backend_dns" {
  type        = string
  default     = ""
}

variable "backend_port" {
  type        = number
  default     = 443
}

variable "config_s3_uri" {
  type        = string
  default     = ""
}

variable "secret_arn" {
  type        = string
  default     = ""
}

variable "log_level" {
  type        = string
  default     = "info"
}

resource "aws_security_group" "asg" {
  name_prefix = "${local.name}-"
  description = "Security group for ${local.name} instances"
  vpc_id      = var.vpc_id

  ingress {
    description = "App port"
    from_port   = var.instance_port
    to_port     = var.instance_port
    protocol    = "tcp"
    cidr_blocks = var.ingress_cidrs
  }

  egress {
    description = "All outbound"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = local.common_tags
}

data "aws_iam_policy_document" "assume_role" {
  statement {
    actions = ["sts:AssumeRole"]
    principals {
      type        = "Service"
      identifiers = ["ec2.amazonaws.com"]
    }
  }
}

resource "aws_iam_role" "ec2" {
  name_prefix        = "${local.name}-"
  assume_role_policy = data.aws_iam_policy_document.assume_role.json
  tags               = local.common_tags
}

data "aws_iam_policy_document" "ec2_inline" {
  statement {
    actions = [
      "ssm:UpdateInstanceInformation",
      "ssmmessages:CreateControlChannel",
      "ssmmessages:CreateDataChannel",
      "ssmmessages:OpenControlChannel",
      "ssmmessages:OpenDataChannel",
      "ec2messages:AcknowledgeMessage",
      "ec2messages:DeleteMessage",
      "ec2messages:FailMessage",
      "ec2messages:GetEndpoint",
      "ec2messages:GetMessages",
      "ec2messages:SendReply"
    ]
    resources = ["*"]
  }

  statement {
    actions   = ["s3:GetObject"]
    resources = var.config_s3_uri != "" ? [replace(var.config_s3_uri, "s3://", "arn:aws:s3:::")] : ["*"]
    condition {
      test     = "Null"
      variable = "aws:ResourceTag/ignore"
      values   = ["true"]
    }
  }

  statement {
    actions   = ["secretsmanager:GetSecretValue"]
    resources = var.secret_arn != "" ? [var.secret_arn] : ["*"]
  }
}

resource "aws_iam_role_policy" "ec2_inline" {
  name   = "${local.name}-inline"
  role   = aws_iam_role.ec2.id
  policy = data.aws_iam_policy_document.ec2_inline.json
}

resource "aws_iam_instance_profile" "ec2" {
  name_prefix = "${local.name}-"
  role        = aws_iam_role.ec2.name
  tags        = local.common_tags
}

resource "aws_launch_template" "this" {
  name_prefix   = "${local.name}-"
  image_id      = var.ami_id
  instance_type = var.instance_type
  key_name      = var.key_name

  iam_instance_profile {
    name = aws_iam_instance_profile.ec2.name
  }

  vpc_security_group_ids = [aws_security_group.asg.id]

  monitoring {
    enabled = true
  }

  metadata_options {
    http_endpoint               = "enabled"
    http_tokens                 = "required"
    http_put_response_hop_limit = 2
  }

  network_interfaces {
    associate_public_ip_address = var.associate_public_ip_address
    security_groups             = [aws_security_group.asg.id]
  }

  user_data = base64encode(templatefile("${path.module}/user_data.sh.tftpl", {
    APP_ENV       = var.app_env
    BACKEND_URL   = var.backend_url
    BACKEND_DNS   = var.backend_dns
    BACKEND_PORT  = tostring(var.backend_port)
    CONFIG_S3_URI = var.config_s3_uri
    SECRET_ARN    = var.secret_arn
    REGION        = var.region
    LOG_LEVEL     = var.log_level
  }))

  tag_specifications {
    resource_type = "instance"
    tags          = local.common_tags
  }

  tag_specifications {
    resource_type = "volume"
    tags          = local.common_tags
  }

  tags = local.common_tags

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_autoscaling_group" "this" {
  name_prefix         = "${local.name}-"
  vpc_zone_identifier = var.subnet_ids

  min_size         = var.min_size
  max_size         = var.max_size
  desired_capacity = var.desired_capacity

  health_check_type         = var.health_check_type
  health_check_grace_period = var.health_check_grace_period

  target_group_arns = var.target_group_arns

  launch_template {
    id      = aws_launch_template.this.id
    version = "$Latest"
  }

  dynamic "tag" {
    for_each = merge(local.common_tags, { Name = local.name })
    content {
      key                 = tag.key
      value               = tag.value
      propagate_at_launch = true
    }
  }

  instance_refresh {
    strategy = "Rolling"
    preferences {
      min_healthy_percentage = 90
      instance_warmup        = 60
    }
    triggers = ["tag"]
  }

  lifecycle {
    create_before_destroy = true
    ignore_changes        = [desired_capacity]
  }
}

resource "local_file" "user_data_tpl" {
  filename = "${path.module}/user_data.sh.tftpl"
  content  = local.user_data
}

output "asg_name" {
  value = aws_autoscaling_group.this.name
}

output "launch_template_id" {
  value = aws_launch_template.this.id
}

output "security_group_id" {
  value = aws_security_group.asg.id
}