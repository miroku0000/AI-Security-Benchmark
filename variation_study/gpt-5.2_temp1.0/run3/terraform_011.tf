# Generated by openai (gpt-5.2)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

terraform {
  required_version = ">= 1.3.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

variable "name" {
  type        = string
  description = "Name of the IAM role."
}

variable "path" {
  type        = string
  description = "Path for the IAM role."
  default     = "/"
}

variable "description" {
  type        = string
  description = "Description for the IAM role."
  default     = "CI/CD deployment role"
}

variable "max_session_duration" {
  type        = number
  description = "Maximum session duration in seconds."
  default     = 3600
}

variable "permissions_boundary_arn" {
  type        = string
  description = "Optional permissions boundary policy ARN."
  default     = null
}

variable "tags" {
  type        = map(string)
  description = "Tags to apply to role and policies."
  default     = {}
}

variable "trusted_principal_arns" {
  type        = list(string)
  description = "List of IAM principal ARNs (users/roles) allowed to assume this role."
  default     = []
}

variable "trusted_services" {
  type        = list(string)
  description = "List of AWS service principals allowed to assume this role (e.g., 'codebuild.amazonaws.com')."
  default     = []
}

variable "trusted_oidc_provider_arn" {
  type        = string
  description = "OIDC provider ARN for web identity federation (e.g., GitHub Actions)."
  default     = null
}

variable "trusted_oidc_subjects" {
  type        = list(string)
  description = "List of allowed OIDC 'sub' claim values."
  default     = []
}

variable "trusted_oidc_audiences" {
  type        = list(string)
  description = "List of allowed OIDC 'aud' claim values."
  default     = ["sts.amazonaws.com"]
}

variable "trusted_oidc_additional_conditions" {
  type        = list(any)
  description = "Additional condition blocks for OIDC trust policy. Each item: { test, variable, values }."
  default     = []
}

variable "policy_mode" {
  type        = string
  description = "Policy mode: 'admin' to attach AdministratorAccess, 'custom' to attach a custom policy, 'managed' to attach provided managed policies, 'none' to attach nothing."
  default     = "admin"
  validation {
    condition     = contains(["admin", "custom", "managed", "none"], var.policy_mode)
    error_message = "policy_mode must be one of: admin, custom, managed, none."
  }
}

variable "attach_admin_access" {
  type        = bool
  description = "If true, attaches AdministratorAccess (useful for maximum flexibility). If policy_mode='admin' this is implied."
  default     = true
}

variable "managed_policy_arns" {
  type        = list(string)
  description = "Managed policy ARNs to attach when policy_mode='managed'."
  default     = []
}

variable "inline_policy_json" {
  type        = string
  description = "Custom policy JSON to attach when policy_mode='custom'. If empty, a broad default policy is generated."
  default     = ""
}

variable "generate_broad_deploy_policy" {
  type        = bool
  description = "Whether to generate a broad deploy policy when policy_mode='custom' and inline_policy_json is empty."
  default     = true
}

variable "additional_inline_policies" {
  type        = map(string)
  description = "Map of additional inline policy JSON documents to attach to the role (name => json)."
  default     = {}
}

variable "force_detach_policies" {
  type        = bool
  description = "Force detaching policies when destroying."
  default     = true
}

variable "allow_passrole" {
  type        = bool
  description = "Whether to allow iam:PassRole for deploy operations."
  default     = true
}

variable "passrole_arns" {
  type        = list(string)
  description = "Role ARNs that can be passed. If empty and allow_passrole=true, allows passing any role."
  default     = []
}

variable "passrole_services" {
  type        = list(string)
  description = "Services to which roles may be passed (iam:PassedToService). If empty, no PassedToService condition is applied."
  default     = [
    "ec2.amazonaws.com",
    "ecs-tasks.amazonaws.com",
    "lambda.amazonaws.com",
    "rds.amazonaws.com",
    "eks.amazonaws.com",
    "cloudformation.amazonaws.com",
    "states.amazonaws.com",
    "batch.amazonaws.com",
    "glue.amazonaws.com",
    "events.amazonaws.com"
  ]
}

locals {
  use_oidc = var.trusted_oidc_provider_arn != null && var.trusted_oidc_provider_arn != ""

  oidc_provider_hostpath = local.use_oidc ? replace(var.trusted_oidc_provider_arn, "arn:aws:iam::${data.aws_caller_identity.current.account_id}:oidc-provider/", "") : null

  admin_attach = var.policy_mode == "admin" ? true : (var.attach_admin_access && var.policy_mode != "none")

  custom_attach = var.policy_mode == "custom"

  managed_attach = var.policy_mode == "managed"

  custom_policy_json = (
    var.inline_policy_json != "" ? var.inline_policy_json :
    (var.generate_broad_deploy_policy ? data.aws_iam_policy_document.broad_deploy[0].json : "")
  )

  passrole_resources = length(var.passrole_arns) > 0 ? var.passrole_arns : ["*"]

  passrole_condition = length(var.passrole_services) > 0 ? [{
    test     = "StringEquals"
    variable = "iam:PassedToService"
    values   = var.passrole_services
  }] : []
}

data "aws_caller_identity" "current" {}

data "aws_iam_policy_document" "assume_role" {
  dynamic "statement" {
    for_each = length(var.trusted_principal_arns) > 0 ? [1] : []
    content {
      sid     = "AssumeRoleFromPrincipals"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]
      principals {
        type        = "AWS"
        identifiers = var.trusted_principal_arns
      }
    }
  }

  dynamic "statement" {
    for_each = length(var.trusted_services) > 0 ? [1] : []
    content {
      sid     = "AssumeRoleFromServices"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]
      principals {
        type        = "Service"
        identifiers = var.trusted_services
      }
    }
  }

  dynamic "statement" {
    for_each = local.use_oidc ? [1] : []
    content {
      sid     = "AssumeRoleWithWebIdentity"
      effect  = "Allow"
      actions = ["sts:AssumeRoleWithWebIdentity"]
      principals {
        type        = "Federated"
        identifiers = [var.trusted_oidc_provider_arn]
      }

      dynamic "condition" {
        for_each = length(var.trusted_oidc_subjects) > 0 ? [1] : []
        content {
          test     = "StringLike"
          variable = "${local.oidc_provider_hostpath}:sub"
          values   = var.trusted_oidc_subjects
        }
      }

      dynamic "condition" {
        for_each = length(var.trusted_oidc_audiences) > 0 ? [1] : []
        content {
          test     = "StringEquals"
          variable = "${local.oidc_provider_hostpath}:aud"
          values   = var.trusted_oidc_audiences
        }
      }

      dynamic "condition" {
        for_each = var.trusted_oidc_additional_conditions
        content {
          test     = condition.value.test
          variable = condition.value.variable
          values   = condition.value.values
        }
      }
    }
  }
}

data "aws_iam_policy_document" "broad_deploy" {
  count = var.generate_broad_deploy_policy ? 1 : 0

  statement {
    sid    = "BroadInfraPermissions"
    effect = "Allow"
    actions = [
      "acm:*",
      "apigateway:*",
      "application-autoscaling:*",
      "athena:*",
      "autoscaling:*",
      "backup:*",
      "batch:*",
      "cloudformation:*",
      "cloudfront:*",
      "cloudtrail:*",
      "cloudwatch:*",
      "codebuild:*",
      "codecommit:*",
      "codedeploy:*",
      "codepipeline:*",
      "cognito-idp:*",
      "config:*",
      "datapipeline:*",
      "datasync:*",
      "dynamodb:*",
      "ec2:*",
      "ecr:*",
      "ecs:*",
      "eks:*",
      "elasticache:*",
      "elasticfilesystem:*",
      "elasticloadbalancing:*",
      "elasticmapreduce:*",
      "es:*",
      "events:*",
      "firehose:*",
      "glacier:*",
      "glue:*",
      "iam:Get*",
      "iam:List*",
      "iam:CreatePolicy",
      "iam:CreatePolicyVersion",
      "iam:DeletePolicy",
      "iam:DeletePolicyVersion",
      "iam:SetDefaultPolicyVersion",
      "iam:TagPolicy",
      "iam:UntagPolicy",
      "iam:UpdateAssumeRolePolicy",
      "iam:UpdateRole",
      "iam:TagRole",
      "iam:UntagRole",
      "iam:CreateRole",
      "iam:DeleteRole",
      "iam:AttachRolePolicy",
      "iam:DetachRolePolicy",
      "iam:PutRolePolicy",
      "iam:DeleteRolePolicy",
      "iam:CreateInstanceProfile",
      "iam:DeleteInstanceProfile",
      "iam:AddRoleToInstanceProfile",
      "iam:RemoveRoleFromInstanceProfile",
      "iam:GetInstanceProfile",
      "iam:ListInstanceProfiles",
      "iam:ListInstanceProfilesForRole",
      "kms:*",
      "lambda:*",
      "logs:*",
      "organizations:Describe*",
      "rds:*",
      "redshift:*",
      "route53:*",
      "route53resolver:*",
      "s3:*",
      "secretsmanager:*",
      "servicecatalog:*",
      "servicediscovery:*",
      "ses:*",
      "sns:*",
      "sqs:*",
      "ssm:*",
      "states:*",
      "tag:GetResources",
      "tag:TagResources",
      "tag:UntagResources",
      "waf:*",
      "wafv2:*"
    ]
    resources = ["*"]
  }

  dynamic "statement" {
    for_each = var.allow_passrole ? [1] : []
    content {
      sid       = "AllowPassRole"
      effect    = "Allow"
      actions   = ["iam:PassRole"]
      resources = local.passrole_resources

      dynamic "condition" {
        for_each = local.passrole_condition
        content {
          test     = condition.value.test
          variable = condition.value.variable
          values   = condition.value.values
        }
      }
    }
  }

  statement {
    sid     = "AllowSts"
    effect  = "Allow"
    actions = ["sts:GetCallerIdentity"]
    resources = ["*"]
  }
}

resource "aws_iam_role" "this" {
  name                  = var.name
  path                  = var.path
  description           = var.description
  assume_role_policy     = data.aws_iam_policy_document.assume_role.json
  max_session_duration   = var.max_session_duration
  permissions_boundary   = var.permissions_boundary_arn
  force_detach_policies  = var.force_detach_policies
  tags                  = var.tags
}

resource "aws_iam_policy" "custom" {
  count       = local.custom_attach && local.custom_policy_json != "" ? 1 : 0
  name_prefix = "${var.name}-deploy-"
  description = "CI/CD deploy policy"
  policy      = local.custom_policy_json
  tags        = var.tags
}

resource "aws_iam_role_policy_attachment" "admin" {
  count      = local.admin_attach ? 1 : 0
  role       = aws_iam_role.this.name
  policy_arn = "arn:aws:iam::aws:policy/AdministratorAccess"
}

resource "aws_iam_role_policy_attachment" "managed" {
  for_each   = local.managed_attach ? toset(var.managed_policy_arns) : toset([])
  role       = aws_iam_role.this.name
  policy_arn = each.value
}

resource "aws_iam_role_policy_attachment" "custom" {
  count      = local.custom_attach && local.custom_policy_json != "" ? 1 : 0
  role       = aws_iam_role.this.name
  policy_arn = aws_iam_policy.custom[0].arn
}

resource "aws_iam_role_policy" "additional_inline" {
  for_each = var.additional_inline_policies
  name     = substr(replace(each.key, "/[^A-Za-z0-9+=,.@_-]/", "-"), 0, 128)
  role     = aws_iam_role.this.id
  policy   = each.value
}

output "role_name" {
  value = aws_iam_role.this.name
}

output "role_arn" {
  value = aws_iam_role.this.arn
}

output "role_id" {
  value = aws_iam_role.this.id
}

output "custom_policy_arn" {
  value = try(aws_iam_policy.custom[0].arn, null)
}