pragma solidity ^0.8.20;

interface IERC20 {
    function totalSupply() external view returns (uint256);
    function balanceOf(address a) external view returns (uint256);
    function allowance(address o, address s) external view returns (uint256);
    function approve(address s, uint256 a) external returns (bool);
    function transfer(address t, uint256 a) external returns (bool);
    function transferFrom(address f, address t, uint256 a) external returns (bool);
    function decimals() external view returns (uint8);
}

library SafeERC20 {
    function safeTransfer(IERC20 t, address to, uint256 a) internal {
        (bool ok, bytes memory data) = address(t).call(abi.encodeWithSelector(t.transfer.selector, to, a));
        require(ok && (data.length == 0 || abi.decode(data, (bool))), "TRANSFER_FAILED");
    }

    function safeTransferFrom(IERC20 t, address f, address to, uint256 a) internal {
        (bool ok, bytes memory data) = address(t).call(abi.encodeWithSelector(t.transferFrom.selector, f, to, a));
        require(ok && (data.length == 0 || abi.decode(data, (bool))), "TRANSFER_FROM_FAILED");
    }

    function safeApprove(IERC20 t, address s, uint256 a) internal {
        (bool ok, bytes memory data) = address(t).call(abi.encodeWithSelector(t.approve.selector, s, a));
        require(ok && (data.length == 0 || abi.decode(data, (bool))), "APPROVE_FAILED");
    }
}

interface IUniswapV2Pair {
    function token0() external view returns (address);
    function token1() external view returns (address);
    function getReserves() external view returns (uint112, uint112, uint32);
}

contract SimpleDexOracleLending {
    using SafeERC20 for IERC20;

    struct Market {
        bool listed;

        // Assets
        address collateralToken;
        address debtToken;

        // Uniswap V2 pair used as oracle (must contain collateralToken and debtToken)
        address pair;

        // Risk parameters (bps)
        // minCollateralBps: required collateral value / debt value * 10000 at borrow time (e.g., 15000 = 150%)
        // liqThresholdBps: liquidation if collateral value / debt value * 10000 < liqThresholdBps (e.g., 12500 = 125%)
        uint16 minCollateralBps;
        uint16 liqThresholdBps;

        // Liquidation bonus paid to liquidator on repaid amount (bps)
        // Seize value = repayValue * (10000 + liqBonusBps) / 10000
        uint16 liqBonusBps;

        // Interest model
        // baseRatePerSecondWad and slopePerSecondWad are per-second rates in WAD (1e18)
        // borrowRate = base + utilization*slope
        uint256 baseRatePerSecondWad;
        uint256 slopePerSecondWad;

        // Protocol reserve factor (bps) portion of interest kept as reserves
        uint16 reserveFactorBps;

        // Accounting (scaled)
        uint256 totalDeposits; // underlying units
        uint256 totalBorrows;  // underlying units (principal+interest via index)
        uint256 borrowIndexWad; // starts at 1e18
        uint256 lastAccrual;

        uint256 totalDepositShares; // shares for depositors
    }

    struct Position {
        uint256 collateral; // units of collateral token
        uint256 debtShares; // shares of total borrows
    }

    address public owner;
    uint256 public marketCount;

    mapping(uint256 => Market) public markets;
    mapping(uint256 => mapping(address => uint256)) public depositShares;
    mapping(uint256 => mapping(address => Position)) public positions;

    uint256 private constant WAD = 1e18;
    uint256 private constant BPS = 10000;

    event MarketCreated(
        uint256 indexed marketId,
        address indexed collateralToken,
        address indexed debtToken,
        address pair
    );

    event Deposit(uint256 indexed marketId, address indexed user, uint256 amount, uint256 sharesMinted);
    event Withdraw(uint256 indexed marketId, address indexed user, uint256 amount, uint256 sharesBurned);
    event AddCollateral(uint256 indexed marketId, address indexed user, uint256 amount);
    event RemoveCollateral(uint256 indexed marketId, address indexed user, uint256 amount);
    event Borrow(uint256 indexed marketId, address indexed user, uint256 amount, uint256 debtSharesMinted);
    event Repay(uint256 indexed marketId, address indexed payer, address indexed user, uint256 amount, uint256 debtSharesBurned);
    event Liquidate(
        uint256 indexed marketId,
        address indexed liquidator,
        address indexed user,
        uint256 repayAmount,
        uint256 collateralSeized
    );
    event Accrue(uint256 indexed marketId, uint256 newBorrowIndexWad, uint256 interestAccrued, uint256 reservesAdded);

    modifier onlyOwner() {
        require(msg.sender == owner, "NOT_OWNER");
        _;
    }

    modifier listed(uint256 marketId) {
        require(markets[marketId].listed, "NOT_LISTED");
        _;
    }

    constructor() {
        owner = msg.sender;
    }

    function setOwner(address newOwner) external onlyOwner {
        require(newOwner != address(0), "ZERO");
        owner = newOwner;
    }

    function createMarket(
        address collateralToken,
        address debtToken,
        address pair,
        uint16 minCollateralBps,
        uint16 liqThresholdBps,
        uint16 liqBonusBps,
        uint256 baseRatePerSecondWad,
        uint256 slopePerSecondWad,
        uint16 reserveFactorBps
    ) external onlyOwner returns (uint256 marketId) {
        require(collateralToken != address(0) && debtToken != address(0) && pair != address(0), "ZERO_ADDR");
        require(minCollateralBps >= BPS, "BAD_MIN");
        require(liqThresholdBps >= BPS && liqThresholdBps <= minCollateralBps, "BAD_LIQ");
        require(liqBonusBps <= 3000, "BONUS_TOO_HIGH"); // 30% cap
        require(reserveFactorBps <= BPS, "BAD_RESERVE");

        IUniswapV2Pair p = IUniswapV2Pair(pair);
        address t0 = p.token0();
        address t1 = p.token1();
        require(
            (t0 == collateralToken && t1 == debtToken) || (t0 == debtToken && t1 == collateralToken),
            "PAIR_MISMATCH"
        );

        marketId = ++marketCount;
        Market storage m = markets[marketId];
        m.listed = true;
        m.collateralToken = collateralToken;
        m.debtToken = debtToken;
        m.pair = pair;
        m.minCollateralBps = minCollateralBps;
        m.liqThresholdBps = liqThresholdBps;
        m.liqBonusBps = liqBonusBps;
        m.baseRatePerSecondWad = baseRatePerSecondWad;
        m.slopePerSecondWad = slopePerSecondWad;
        m.reserveFactorBps = reserveFactorBps;
        m.borrowIndexWad = WAD;
        m.lastAccrual = block.timestamp;

        emit MarketCreated(marketId, collateralToken, debtToken, pair);
    }

    // -------------------------
    // Oracle / pricing
    // -------------------------

    // Returns price of 1 collateral token in debt token units, scaled to 1e18:
    // priceWad = (debt per collateral) * 1e18
    function getPriceCollateralInDebtWad(uint256 marketId) public view listed(marketId) returns (uint256 priceWad) {
        Market storage m = markets[marketId];
        (uint112 r0, uint112 r1, ) = IUniswapV2Pair(m.pair).getReserves();
        require(r0 > 0 && r1 > 0, "NO_LIQUIDITY");

        address t0 = IUniswapV2Pair(m.pair).token0();
        uint256 collateralDecimals = IERC20(m.collateralToken).decimals();
        uint256 debtDecimals = IERC20(m.debtToken).decimals();

        uint256 reserveCollateral;
        uint256 reserveDebt;

        if (t0 == m.collateralToken) {
            reserveCollateral = uint256(r0);
            reserveDebt = uint256(r1);
        } else {
            reserveCollateral = uint256(r1);
            reserveDebt = uint256(r0);
        }

        // price = (reserveDebt / 10^debtDecimals) / (reserveCollateral / 10^collateralDecimals)
        // priceWad = reserveDebt * 10^collateralDecimals * 1e18 / (reserveCollateral * 10^debtDecimals)
        uint256 num = reserveDebt * _pow10(collateralDecimals) * WAD;
        uint256 den = reserveCollateral * _pow10(debtDecimals);
        priceWad = num / den;
    }

    function _pow10(uint256 d) internal pure returns (uint256) {
        // supports up to 77 safely within uint256; ERC20 decimals commonly <= 18
        uint256 r = 1;
        for (uint256 i = 0; i < d; i++) r *= 10;
        return r;
    }

    // -------------------------
    // Interest / accounting
    // -------------------------

    function utilizationWad(uint256 marketId) public view listed(marketId) returns (uint256) {
        Market storage m = markets[marketId];
        if (m.totalDeposits == 0) return 0;
        if (m.totalBorrows == 0) return 0;
        if (m.totalBorrows >= m.totalDeposits) return WAD;
        return (m.totalBorrows * WAD) / m.totalDeposits;
    }

    function borrowRatePerSecondWad(uint256 marketId) public view listed(marketId) returns (uint256) {
        Market storage m = markets[marketId];
        uint256 u = utilizationWad(marketId);
        return m.baseRatePerSecondWad + (u * m.slopePerSecondWad) / WAD;
    }

    function accrue(uint256 marketId) public listed(marketId) {
        Market storage m = markets[marketId];
        uint256 dt = block.timestamp - m.lastAccrual;
        if (dt == 0) return;
        m.lastAccrual = block.timestamp;

        if (m.totalBorrows == 0) {
            emit Accrue(marketId, m.borrowIndexWad, 0, 0);
            return;
        }

        uint256 rate = borrowRatePerSecondWad(marketId); // WAD
        uint256 interest = (m.totalBorrows * rate * dt) / WAD;
        if (interest == 0) {
            emit Accrue(marketId, m.borrowIndexWad, 0, 0);
            return;
        }

        uint256 reserves = (interest * m.reserveFactorBps) / BPS;
        uint256 toDepositors = interest - reserves;

        m.totalBorrows += interest;
        m.totalDeposits += toDepositors;

        // Update borrow index so debt shares track new totalBorrows.
        // If borrowIndex scales debt: debt = shares * borrowIndex / 1e18,
        // then updating index proportional to totalBorrows increase:
        // newIndex = oldIndex * (oldTotalBorrows + interest) / oldTotalBorrows
        uint256 oldTotal = m.totalBorrows - interest;
        m.borrowIndexWad = (m.borrowIndexWad * (oldTotal + interest)) / oldTotal;

        emit Accrue(marketId, m.borrowIndexWad, interest, reserves);
    }

    // -------------------------
    // Deposits (lend)
    // -------------------------

    function deposit(uint256 marketId, uint256 amount) external listed(marketId) {
        require(amount > 0, "AMOUNT_ZERO");
        accrue(marketId);
        Market storage m = markets[marketId];

        uint256 shares;
        if (m.totalDepositShares == 0 || m.totalDeposits == 0) {
            shares = amount;
        } else {
            shares = (amount * m.totalDepositShares) / m.totalDeposits;
        }
        require(shares > 0, "SHARES_ZERO");

        m.totalDeposits += amount;
        m.totalDepositShares += shares;
        depositShares[marketId][msg.sender] += shares;

        IERC20(m.debtToken).safeTransferFrom(msg.sender, address(this), amount);
        emit Deposit(marketId, msg.sender, amount, shares);
    }

    function withdraw(uint256 marketId, uint256 amount) external listed(marketId) {
        require(amount > 0, "AMOUNT_ZERO");
        accrue(marketId);
        Market storage m = markets[marketId];

        require(m.totalDeposits >= amount, "INSUFFICIENT_LIQ");
        require(_availableCash(marketId) >= amount, "CASH_LOW");

        uint256 shares = (amount * m.totalDepositShares + (m.totalDeposits - 1)) / m.totalDeposits; // round up
        uint256 userShares = depositShares[marketId][msg.sender];
        require(userShares >= shares, "SHARES_LOW");

        depositShares[marketId][msg.sender] = userShares - shares;
        m.totalDepositShares -= shares;
        m.totalDeposits -= amount;

        IERC20(m.debtToken).safeTransfer(msg.sender, amount);
        emit Withdraw(marketId, msg.sender, amount, shares);
    }

    function _availableCash(uint256 marketId) internal view returns (uint256) {
        Market storage m = markets[marketId];
        return IERC20(m.debtToken).balanceOf(address(this));
    }

    function balanceOfDepositUnderlying(uint256 marketId, address user) external view listed(marketId) returns (uint256) {
        Market storage m = markets[marketId];
        uint256 shares = depositShares[marketId][user];
        if (shares == 0) return 0;
        if (m.totalDepositShares == 0) return 0;
        return (shares * m.totalDeposits) / m.totalDepositShares;
    }

    // -------------------------
    // Collateral management
    // -------------------------

    function addCollateral(uint256 marketId, uint256 amount) external listed(marketId) {
        require(amount > 0, "AMOUNT_ZERO");
        Position storage p = positions[marketId][msg.sender];
        p.collateral += amount;
        IERC20(markets[marketId].collateralToken).safeTransferFrom(msg.sender, address(this), amount);
        emit AddCollateral(marketId, msg.sender, amount);
    }

    function removeCollateral(uint256 marketId, uint256 amount) external listed(marketId) {
        require(amount > 0, "AMOUNT_ZERO");
        accrue(marketId);

        Position storage p = positions[marketId][msg.sender];
        require(p.collateral >= amount, "COLL_LOW");

        p.collateral -= amount;
        require(_isHealthy(marketId, msg.sender, markets[marketId].liqThresholdBps), "WOULD_LIQ");

        IERC20(markets[marketId].collateralToken).safeTransfer(msg.sender, amount);
        emit RemoveCollateral(marketId, msg.sender, amount);
    }

    // -------------------------
    // Borrow / repay
    // -------------------------

    function borrow(uint256 marketId, uint256 amount) external listed(marketId) {
        require(amount > 0, "AMOUNT_ZERO");
        accrue(marketId);
        Market storage m = markets[marketId];

        require(_availableCash(marketId) >= amount, "CASH_LOW");

        uint256 shares = _debtAmountToShares(marketId, amount);
        require(shares > 0, "SHARES_ZERO");

        Position storage p = positions[marketId][msg.sender];
        p.debtShares += shares;

        m.totalBorrows += amount;

        require(_isHealthy(marketId, msg.sender, m.minCollateralBps), "INSUFFICIENT_COLL");

        IERC20(m.debtToken).safeTransfer(msg.sender, amount);
        emit Borrow(marketId, msg.sender, amount, shares);
    }

    function repay(uint256 marketId, uint256 amount) external listed(marketId) {
        repayFor(marketId, msg.sender, amount);
    }

    function repayFor(uint256 marketId, address user, uint256 amount) public listed(marketId) {
        require(amount > 0, "AMOUNT_ZERO");
        accrue(marketId);

        Position storage p = positions[marketId][user];
        uint256 debt = debtOf(marketId, user);
        require(debt > 0, "NO_DEBT");

        uint256 pay = amount < debt ? amount : debt;
        uint256 sharesBurn = _debtAmountToShares(marketId, pay);
        if (sharesBurn > p.debtShares) sharesBurn = p.debtShares;

        p.debtShares -= sharesBurn;
        markets[marketId].totalBorrows -= pay;

        IERC20(markets[marketId].debtToken).safeTransferFrom(msg.sender, address(this), pay);
        emit Repay(marketId, msg.sender, user, pay, sharesBurn);
    }

    function debtOf(uint256 marketId, address user) public view listed(marketId) returns (uint256) {
        Market storage m = markets[marketId];
        Position storage p = positions[marketId][user];
        if (p.debtShares == 0) return 0;
        // debt = shares * borrowIndex / 1e18, but we maintain totalBorrows independently.
        // Using index gives consistent per-position growth.
        return (p.debtShares * m.borrowIndexWad) / WAD;
    }

    function _debtAmountToShares(uint256 marketId, uint256 amount) internal view returns (uint256) {
        Market storage m = markets[marketId];
        // shares = amount * 1e18 / borrowIndex
        return (amount * WAD) / m.borrowIndexWad;
    }

    // -------------------------
    // Health / liquidation
    // -------------------------

    // collateralValueInDebt = collateral * priceWad / 1e18
    function collateralValueInDebt(uint256 marketId, address user) public view listed(marketId) returns (uint256) {
        Position storage p = positions[marketId][user];
        if (p.collateral == 0) return 0;
        uint256 priceWad = getPriceCollateralInDebtWad(marketId);
        return (p.collateral * priceWad) / WAD;
    }

    function _isHealthy(uint256 marketId, address user, uint256 requiredBps) internal view returns (bool) {
        uint256 d = debtOf(marketId, user);
        if (d == 0) return true;
        uint256 cVal = collateralValueInDebt(marketId, user);
        // cVal / d >= requiredBps / 10000
        return cVal * BPS >= d * requiredBps;
    }

    function isLiquidatable(uint256 marketId, address user) public view listed(marketId) returns (bool) {
        Market storage m = markets[marketId];
        return !_isHealthy(marketId, user, m.liqThresholdBps);
    }

    function liquidate(uint256 marketId, address user, uint256 repayAmount) external listed(marketId) {
        require(repayAmount > 0, "AMOUNT_ZERO");
        accrue(marketId);
        Market storage m = markets[marketId];

        require(isLiquidatable(marketId, user), "NOT_LIQ");
        uint256 debt = debtOf(marketId, user);
        require(debt > 0, "NO_DEBT");

        uint256 pay = repayAmount < debt ? repayAmount : debt;

        // Seize collateral based on current price with bonus
        uint256 priceWad = getPriceCollateralInDebtWad(marketId);
        // repayValue in debt token == pay
        // seizeValueInDebt = pay * (1 + bonus)
        uint256 seizeValueDebt = (pay * (BPS + m.liqBonusBps)) / BPS;
        // seizeCollateral = seizeValueDebt / price
        uint256 seizeCollateral = (seizeValueDebt * WAD) / priceWad;

        Position storage p = positions[marketId][user];
        require(seizeCollateral > 0, "SEIZE_ZERO");
        require(p.collateral >= seizeCollateral, "COLL_INSUFF");

        // Burn debt shares corresponding to pay
        uint256 sharesBurn = _debtAmountToShares(marketId, pay);
        if (sharesBurn > p.debtShares) sharesBurn = p.debtShares;

        p.debtShares -= sharesBurn;
        p.collateral -= seizeCollateral;

        m.totalBorrows -= pay;

        IERC20(m.debtToken).safeTransferFrom(msg.sender, address(this), pay);
        IERC20(m.collateralToken).safeTransfer(msg.sender, seizeCollateral);

        emit Liquidate(marketId, msg.sender, user, pay, seizeCollateral);
    }

    // -------------------------
    // Views
    // -------------------------

    function position(uint256 marketId, address user) external view listed(marketId) returns (uint256 collateral, uint256 debt) {
        Position storage p = positions[marketId][user];
        collateral = p.collateral;
        debt = debtOf(marketId, user);
    }

    function maxBorrowable(uint256 marketId, address user) external view listed(marketId) returns (uint256) {
        Market storage m = markets[marketId];
        uint256 cVal = collateralValueInDebt(marketId, user);
        if (cVal == 0) return 0;
        // maxDebt = cVal * 10000 / minCollateralBps
        return (cVal * BPS) / m.minCollateralBps;
    }

    function liquidationThresholdDebt(uint256 marketId, address user) external view listed(marketId) returns (uint256) {
        Market storage m = markets[marketId];
        uint256 cVal = collateralValueInDebt(marketId, user);
        if (cVal == 0) return 0;
        // liquidatable if debt > cVal*10000/liqThresholdBps
        return (cVal * BPS) / m.liqThresholdBps;
    }

    // -------------------------
    // Admin rescue (no user funds should be rescued from listed assets)
    // -------------------------

    function rescueERC20(address token, address to, uint256 amount) external onlyOwner {
        require(to != address(0), "ZERO");
        IERC20(token).safeTransfer(to, amount);
    }
}