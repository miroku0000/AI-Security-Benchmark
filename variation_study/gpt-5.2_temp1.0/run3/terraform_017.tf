}

data "archive_file" "tokenizer_zip" {
  type        = "zip"
  output_path = "${path.module}/build/${local.name_prefix}-tokenizer.zip"

  source {
    filename = "lambda_function.py"
    content  = <<-PY
      import os, json, base64, hashlib, hmac, time
      import boto3

      ddb = boto3.client("dynamodb")
      sqs = boto3.client("sqs")

      TABLE_NAME = os.environ["TOKEN_STORE_TABLE"]
      QUEUE_URL = os.environ["PAYMENT_EVENTS_QUEUE_URL"]
      DLQ_URL = os.environ.get("PAYMENT_EVENTS_DLQ_URL", "")
      TOKEN_HMAC_KEY = os.environ["TOKEN_HMAC_KEY"].encode("utf-8")
      MAX_PAN_LEN = int(os.environ.get("MAX_PAN_LEN", "19"))

      def _redact(s: str) -> str:
          if not s:
              return s
          return "***"

      def _validate_pan(pan: str) -> None:
          if not isinstance(pan, str) or len(pan) < 12 or len(pan) > MAX_PAN_LEN or not pan.isdigit():
              raise ValueError("invalid_pan")

      def _tokenize(pan: str) -> str:
          mac = hmac.new(TOKEN_HMAC_KEY, pan.encode("utf-8"), hashlib.sha256).digest()
          token = base64.urlsafe_b64encode(mac[:18]).decode("utf-8").rstrip("=")
          return f"tok_{token}"

      def _put_token(token: str, pan_last4: str, exp_month: str, exp_year: str, network: str = "") -> None:
          now = int(time.time())
          item = {
              "pk": {"S": token},
              "created_at": {"N": str(now)},
              "pan_last4": {"S": pan_last4},
              "exp_month": {"S": exp_month},
              "exp_year": {"S": exp_year},
              "network": {"S": network or ""},
          }
          ddb.put_item(
              TableName=TABLE_NAME,
              Item=item,
              ConditionExpression="attribute_not_exists(pk)",
          )

      def _send_event(event: dict) -> None:
          sqs.send_message(
              QueueUrl=QUEUE_URL,
              MessageBody=json.dumps(event, separators=(",", ":"), ensure_ascii=False),
          )

      def handler(event, context):
          try:
              body = event.get("body")
              if isinstance(body, str):
                  body = json.loads(body)
              if not isinstance(body, dict):
                  raise ValueError("invalid_body")

              pan = body.get("pan", "")
              exp_month = str(body.get("exp_month", "")).zfill(2)
              exp_year = str(body.get("exp_year", ""))
              network = body.get("network", "")

              _validate_pan(pan)
              if not exp_month.isdigit() or not (1 <= int(exp_month) <= 12):
                  raise ValueError("invalid_exp_month")
              if not exp_year.isdigit() or len(exp_year) not in (2, 4):
                  raise ValueError("invalid_exp_year")

              token = _tokenize(pan)
              pan_last4 = pan[-4:]

              _put_token(token, pan_last4, exp_month, exp_year, network)

              payment_event = {
                  "type": "CARD_TOKENIZED",
                  "token": token,
                  "pan_last4": pan_last4,
                  "exp_month": exp_month,
                  "exp_year": exp_year,
                  "network": network,
                  "request_id": context.aws_request_id,
              }
              _send_event(payment_event)

              return {
                  "statusCode": 200,
                  "headers": {"Content-Type": "application/json"},
                  "body": json.dumps({"token": token, "pan_last4": pan_last4}),
              }
          except Exception as e:
              err = str(e)
              # Never log raw PAN or body. Minimal error surface.
              if DLQ_URL:
                  try:
                      sqs.send_message(
                          QueueUrl=DLQ_URL,
                          MessageBody=json.dumps(
                              {"type": "TOKENIZATION_FAILED", "error": err, "request_id": getattr(context, "aws_request_id", "")},
                              separators=(",", ":"),
                          ),
                      )
                  except Exception:
                      pass
              return {
                  "statusCode": 400,
                  "headers": {"Content-Type": "application/json"},
                  "body": json.dumps({"error": "request_rejected"}),
              }
    PY
  }
}

data "archive_file" "authorizer_zip" {
  type        = "zip"
  output_path = "${path.module}/build/${local.name_prefix}-authorizer.zip"

  source {
    filename = "lambda_function.py"
    content  = <<-PY
      import os, json, time
      import boto3
      import urllib3

      sqs = boto3.client("sqs")
      ddb = boto3.client("dynamodb")
      secrets = boto3.client("secretsmanager")

      http = urllib3.PoolManager(
          timeout=urllib3.Timeout(connect=2.0, read=5.0),
          retries=False,
      )

      TABLE_NAME = os.environ["TOKEN_STORE_TABLE"]
      PROCESSOR_ENDPOINT = os.environ.get("PROCESSOR_ENDPOINT", "")
      CREDENTIALS_SECRET_ARN = os.environ.get("PROCESSOR_CREDENTIALS_SECRET_ARN", "")
      IDP_AUDIENCE = os.environ.get("IDP_AUDIENCE", "payments")
      MAX_AMOUNT_CENTS = int(os.environ.get("MAX_AMOUNT_CENTS", "2000000"))  # $20,000.00 default

      def _get_secret_json(arn: str) -> dict:
          if not arn:
              return {}
          v = secrets.get_secret_value(SecretId=arn)
          s = v.get("SecretString")
          if s:
              return json.loads(s)
          b = v.get("SecretBinary")
          if b:
              return json.loads(b.decode("utf-8"))
          return {}

      def _ddb_get_token_meta(token: str) -> dict:
          resp = ddb.get_item(
              TableName=TABLE_NAME,
              Key={"pk": {"S": token}},
              ConsistentRead=True,
          )
          item = resp.get("Item") or {}
          if not item:
              return {}
          return {
              "pan_last4": item.get("pan_last4", {}).get("S", ""),
              "exp_month": item.get("exp_month", {}).get("S", ""),
              "exp_year": item.get("exp_year", {}).get("S", ""),
              "network": item.get("network", {}).get("S", ""),
              "created_at": int(item.get("created_at", {}).get("N", "0") or "0"),
          }

      def _validate_payment_request(payload: dict) -> None:
          if not isinstance(payload, dict):
              raise ValueError("invalid_payload")
          token = payload.get("token", "")
          amount_cents = payload.get("amount_cents", None)
          currency = payload.get("currency", "USD")
          if not isinstance(token, str) or not token.startswith("tok_") or len(token) < 10:
              raise ValueError("invalid_token")
          if not isinstance(amount_cents, int) or amount_cents <= 0 or amount_cents > MAX_AMOUNT_CENTS:
              raise ValueError("invalid_amount")
          if currency not in ("USD", "EUR", "GBP", "CAD", "AUD"):
              raise ValueError("unsupported_currency")

      def _call_processor(endpoint: str, api_key: str, request_body: dict) -> dict:
          if not endpoint:
              return {"status": "SKIPPED", "reason": "no_endpoint_configured"}
          body = json.dumps(request_body, separators=(",", ":"), ensure_ascii=False).encode("utf-8")
          r = http.request(
              "POST",
              endpoint,
              body=body,
              headers={
                  "Content-Type": "application/json",
                  "Authorization": f"Bearer {api_key}",
              },
          )
          try:
              resp_body = json.loads(r.data.decode("utf-8") or "{}")
          except Exception:
              resp_body = {"raw": ""}
          return {"http_status": int(r.status), "response": resp_body}

      def handler(event, context):
          # Triggered by SQS with tokenized payment events.
          records = event.get("Records") or []
          creds = _get_secret_json(CREDENTIALS_SECRET_ARN)
          api_key = creds.get("api_key", "")

          results = []
          for rec in records:
              try:
                  body = json.loads(rec.get("body") or "{}")
                  if body.get("type") not in ("PAYMENT_AUTH_REQUEST", "CAPTURE_REQUEST"):
                      results.append({"status": "IGNORED"})
                      continue

                  _validate_payment_request(body)
                  token = body["token"]
                  meta = _ddb_get_token_meta(token)
                  if not meta:
                      raise ValueError("unknown_token")

                  processor_req = {
                      "request_id": rec.get("messageId", ""),
                      "aud": IDP_AUDIENCE,
                      "ts": int(time.time()),
                      "token": token,
                      "amount_cents": body["amount_cents"],
                      "currency": body.get("currency", "USD"),
                      "pan_last4": meta.get("pan_last4", ""),
                      "exp_month": meta.get("exp_month", ""),
                      "exp_year": meta.get("exp_year", ""),
                      "network": meta.get("network", ""),
                      "merchant_id": body.get("merchant_id", ""),
                      "order_id": body.get("order_id", ""),
                  }

                  # Do not include sensitive raw PAN anywhere.
                  processor_resp = _call_processor(PROCESSOR_ENDPOINT, api_key, processor_req)
                  results.append({"status": "OK", "processor": processor_resp.get("http_status", 0)})
              except Exception:
                  # Let Lambda/SQS partial batch handling manage retries by failing this record.
                  raise

          return {"ok": True, "results": results}
    PY
  }
}

resource "aws_lambda_function" "tokenizer" {
  function_name = "${local.name_prefix}-tokenizer"
  role          = aws_iam_role.tokenizer.arn
  runtime       = var.runtime
  handler       = "lambda_function.handler"
  architectures = var.lambda_architectures

  filename         = data.archive_file.tokenizer_zip.output_path
  source_code_hash = data.archive_file.tokenizer_zip.output_base64sha256

  kms_key_arn = var.kms_key_arn
  timeout     = 10
  memory_size = 512

  environment {
    variables = {
      TOKEN_STORE_TABLE          = var.token_store_table_name
      PAYMENT_EVENTS_QUEUE_URL   = var.payment_events_queue_url
      PAYMENT_EVENTS_DLQ_URL     = var.payment_events_dlq_url
      MAX_PAN_LEN                = "19"
      TOKEN_HMAC_KEY             = "resolve:secretsmanager:placeholder"
    }
  }

  dynamic "vpc_config" {
    for_each = local.vpc_enabled ? [1] : []
    content {
      subnet_ids         = var.vpc_subnet_ids
      security_group_ids = var.vpc_security_group_ids
    }
  }

  tags = local.common_tags

  lifecycle {
    ignore_changes = [
      environment[0].variables["TOKEN_HMAC_KEY"]
    ]
  }

  depends_on = [aws_cloudwatch_log_group.tokenizer]
}

resource "aws_lambda_function" "authorizer" {
  function_name = "${local.name_prefix}-authorizer"
  role          = aws_iam_role.authorizer.arn
  runtime       = var.runtime
  handler       = "lambda_function.handler"
  architectures = var.lambda_architectures

  filename         = data.archive_file.authorizer_zip.output_path
  source_code_hash = data.archive_file.authorizer_zip.output_base64sha256

  kms_key_arn = var.kms_key_arn
  timeout     = 15
  memory_size = 1024

  environment {
    variables = {
      TOKEN_STORE_TABLE                 = var.token_store_table_name
      PROCESSOR_ENDPOINT                = var.processor_endpoint
      PROCESSOR_CREDENTIALS_SECRET_ARN  = length(var.secretsmanager_secret_arns) > 0 ? var.secretsmanager_secret_arns[0] : ""
      IDP_AUDIENCE                      = "payments"
      MAX_AMOUNT_CENTS                  = "2000000"
    }
  }

  dynamic "vpc_config" {
    for_each = local.vpc_enabled ? [1] : []
    content {
      subnet_ids         = var.vpc_subnet_ids
      security_group_ids = var.vpc_security_group_ids
    }
  }

  tags = local.common_tags

  depends_on = [aws_cloudwatch_log_group.authorizer]
}

resource "aws_lambda_event_source_mapping" "authorizer_from_sqs" {
  event_source_arn = var.payment_events_queue_arn
  function_name    = aws_lambda_function.authorizer.arn

  batch_size                         = 10
  maximum_batching_window_in_seconds = 2
  function_response_types            = ["ReportBatchItemFailures"]
  enabled                            = true
}

output "tokenizer_lambda_name" {
  value = aws_lambda_function.tokenizer.function_name
}

output "authorizer_lambda_name" {
  value = aws_lambda_function.authorizer.function_name
}

output "tokenizer_role_arn" {
  value = aws_iam_role.tokenizer.arn
}

output "authorizer_role_arn" {
  value = aws_iam_role.authorizer.arn
}