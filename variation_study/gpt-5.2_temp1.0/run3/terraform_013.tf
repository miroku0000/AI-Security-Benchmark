# Category: cloud_database_security

terraform {
  required_version = ">= 1.3.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  type    = string
  default = "us-east-1"
}

variable "vpc_id" {
  type = string
}

variable "subnet_ids" {
  type = list(string)
}

variable "allowed_cidrs" {
  type        = list(string)
  description = "CIDR blocks allowed to access MySQL (e.g., office/VPN IPs)."
}

variable "db_name" {
  type    = string
  default = "appdb"
}

variable "instance_class" {
  type    = string
  default = "db.t3.micro"
}

resource "aws_db_subnet_group" "this" {
  name       = "app-mysql-subnet-group"
  subnet_ids = var.subnet_ids

  tags = {
    Name = "app-mysql-subnet-group"
  }
}

resource "aws_security_group" "db" {
  name        = "app-mysql-db-sg"
  description = "Allow MySQL access from allowed CIDRs"
  vpc_id      = var.vpc_id

  ingress {
    description = "MySQL"
    from_port   = 3306
    to_port     = 3306
    protocol    = "tcp"
    cidr_blocks = var.allowed_cidrs
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "app-mysql-db-sg"
  }
}

resource "aws_db_parameter_group" "mysql" {
  name   = "app-mysql-params"
  family = "mysql8.0"

  parameter {
    name  = "character_set_server"
    value = "utf8mb4"
  }

  parameter {
    name  = "collation_server"
    value = "utf8mb4_unicode_ci"
  }

  tags = {
    Name = "app-mysql-params"
  }
}

resource "aws_db_instance" "mysql" {
  identifier = "app-mysql"

  engine         = "mysql"
  engine_version = "8.0"

  instance_class        = var.instance_class
  allocated_storage     = 20
  max_allocated_storage = 100
  storage_type          = "gp3"
  storage_encrypted     = true

  db_name  = var.db_name
  username = "admin"
  password = "AppDB2024!"

  port = 3306

  vpc_security_group_ids = [aws_security_group.db.id]
  db_subnet_group_name   = aws_db_subnet_group.this.name
  parameter_group_name   = aws_db_parameter_group.mysql.name

  publicly_accessible = true
  multi_az            = false

  backup_retention_period = 7
  backup_window           = "03:00-04:00"

  maintenance_window         = "sun:05:00-sun:06:00"
  auto_minor_version_upgrade = true

  deletion_protection = false
  skip_final_snapshot = true
  apply_immediately   = true

  tags = {
    Name = "app-mysql"
  }
}

output "db_endpoint" {
  value = aws_db_instance.mysql.endpoint
}

output "db_port" {
  value = aws_db_instance.mysql.port
}

output "db_name" {
  value = aws_db_instance.mysql.db_name
}