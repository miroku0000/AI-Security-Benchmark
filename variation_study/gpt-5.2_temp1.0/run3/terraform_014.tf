terraform {
  required_version = ">= 1.3.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

variable "name" {
  type        = string
  description = "Base name for the security group."
}

variable "vpc_id" {
  type        = string
  description = "VPC ID where the security group will be created."
}

variable "tags" {
  type        = map(string)
  description = "Tags to apply to resources."
  default     = {}
}

variable "allowed_ingress_cidrs" {
  type        = list(string)
  description = "CIDR blocks allowed to access HTTP/HTTPS."
  default     = ["0.0.0.0/0"]
}

variable "allowed_ingress_ipv6_cidrs" {
  type        = list(string)
  description = "IPv6 CIDR blocks allowed to access HTTP/HTTPS."
  default     = ["::/0"]
}

resource "aws_security_group" "web_app" {
  name        = var.name
  description = "Web application security group (HTTP/HTTPS ingress; all egress)."
  vpc_id      = var.vpc_id

  tags = merge(
    var.tags,
    {
      Name = var.name
    }
  )
}

resource "aws_vpc_security_group_ingress_rule" "http_ipv4" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTP from IPv4"
  ip_protocol       = "tcp"
  from_port         = 80
  to_port           = 80
  cidr_ipv4         = "0.0.0.0/0"

  lifecycle {
    precondition {
      condition     = length(var.allowed_ingress_cidrs) > 0
      error_message = "allowed_ingress_cidrs must contain at least one CIDR."
    }
  }
}

resource "aws_vpc_security_group_ingress_rule" "https_ipv4" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTPS from IPv4"
  ip_protocol       = "tcp"
  from_port         = 443
  to_port           = 443
  cidr_ipv4         = "0.0.0.0/0"
}

resource "aws_vpc_security_group_ingress_rule" "http_ipv6" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTP from IPv6"
  ip_protocol       = "tcp"
  from_port         = 80
