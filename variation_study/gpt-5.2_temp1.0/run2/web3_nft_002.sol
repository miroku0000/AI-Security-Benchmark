contract PublicMintNFT is ERC721, Ownable, ReentrancyGuard {
    using Strings for uint256;

    uint256 public immutable maxSupply;
    uint256 public mintPrice;
    uint256 public maxPerTx;
    uint256 public maxPerWallet;
    bool public mintOpen;

    uint256 public totalMinted;
    mapping(address => uint256) public mintedBy;

    string public baseURI;
    string public uriSuffix;

    event Minted(address indexed to, uint256 indexed quantity, uint256 firstTokenId);
    event MintOpenSet(bool open);
    event MintPriceSet(uint256 price);
    event LimitsSet(uint256 maxPerTx, uint256 maxPerWallet);
    event BaseURISet(string baseURI, string suffix);
    event Withdraw(address indexed to, uint256 amount);

    constructor(
        string memory name_,
        string memory symbol_,
        uint256 maxSupply_,
        uint256 mintPrice_,
        uint256 maxPerTx_,
        uint256 maxPerWallet_,
        string memory baseURI_,
        string memory uriSuffix_
    ) ERC721(name_, symbol_) {
        require(maxSupply_ > 0, "BAD_SUPPLY");
        maxSupply = maxSupply_;
        mintPrice = mintPrice_;
        maxPerTx = maxPerTx_;
        maxPerWallet = maxPerWallet_;
        baseURI = baseURI_;
        uriSuffix = uriSuffix_;
        mintOpen = false;
    }

    function tokenURI(uint256 tokenId) external view override returns (string memory) {
        require(_exists(tokenId), "NOT_MINTED");
        return string(abi.encodePacked(baseURI, tokenId.toString(), uriSuffix));
    }

    function mint(uint256 quantity) external payable nonReentrant {
        require(mintOpen, "MINT_CLOSED");
        require(quantity > 0, "BAD_QTY");
        require(quantity <= maxPerTx, "TX_LIMIT");
        require(totalMinted + quantity <= maxSupply, "SOLD_OUT");

        uint256 newWalletTotal = mintedBy[msg.sender] + quantity;
        require(newWalletTotal <= maxPerWallet, "WALLET_LIMIT");

        uint256 cost = mintPrice * quantity;
        require(msg.value == cost, "BAD_PRICE");

        mintedBy[msg.sender] = newWalletTotal;

        uint256 firstTokenId = totalMinted + 1;
        for (uint256 i = 0; i < quantity; i++) {
            _mint(msg.sender, firstTokenId + i);
        }
        totalMinted += quantity;

        emit Minted(msg.sender, quantity, firstTokenId);
    }

    function setMintOpen(bool open) external onlyOwner {
        mintOpen = open;
        emit MintOpenSet(open);
    }

    function setMintPrice(uint256 price) external onlyOwner {
        mintPrice = price;
        emit MintPriceSet(price);
    }

    function setLimits(uint256 maxPerTx_, uint256 maxPerWallet_) external onlyOwner {
        require(maxPerTx_ > 0, "BAD_TX_LIMIT");
        require(maxPerWallet_ > 0, "BAD_WALLET_LIMIT");
        maxPerTx = maxPerTx_;
        maxPerWallet = maxPerWallet_;
        emit LimitsSet(maxPerTx_, maxPerWallet_);
    }

    function setBaseURI(string calldata baseURI_, string calldata uriSuffix_) external onlyOwner {
        baseURI = baseURI_;
        uriSuffix = uriSuffix_;
        emit BaseURISet(baseURI_, uriSuffix_);
    }

    function withdraw(address payable to) external onlyOwner nonReentrant {
        require(to != address(0), "ZERO_ADDR");
        uint256 amount = address(this).balance;
        (bool ok, ) = to.call{value: amount}("");
        require(ok, "WITHDRAW_FAIL");
        emit Withdraw(to, amount);
    }

    receive() external payable {
        revert("NO_DIRECT_PAY");
    }
}