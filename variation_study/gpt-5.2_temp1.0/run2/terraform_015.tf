# --- user_data template file content below should be saved as: user_data.sh.tftpl ---
# (Terraform will reference it via templatefile)

#cloud-config
%{~ if false ~}%{~ endif ~}
#!/bin/bash
set -euo pipefail

exec > >(tee -a /var/log/user-data.log | logger -t user-data -s 2>/dev/console) 2>&1

NAME="${name}"
REGION="${region}"
ENVIRONMENT="${environment}"
APP_PORT="${app_port}"
APP_USER="${app_user}"
APP_DIR="${app_dir}"
PARAM_PREFIX="${ssm_parameter_prefix}"
LOG_GROUP="${log_group_name}"
HEALTH_PATH="${healthcheck_path}"
CONTAINER_IMAGE="${container_image}"

mkdir -p "${APP_DIR}"
id -u "${APP_USER}" >/dev/null 2>&1 || useradd --system --create-home --home-dir "${APP_DIR}" --shell /sbin/nologin "${APP_USER}"
chown -R "${APP_USER}:${APP_USER}" "${APP_DIR}"

dnf -y update
dnf -y install docker jq awscli curl
systemctl enable --now docker

cat >/etc/systemd/system/app.service <<'UNIT'
[Unit]
Description=Application container
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
Restart=always
RestartSec=2
EnvironmentFile=/etc/app/app.env
ExecStartPre=/usr/bin/docker rm -f app || true
ExecStart=/usr/bin/docker run --name app --pull=always --log-driver=awslogs --log-opt awslogs-region=${region} --log-opt awslogs-group=${log_group_name} --log-opt awslogs-stream=app/%H -p ${app_port}:${app_port} --env-file /etc/app/app.env ${container_image}
ExecStop=/usr/bin/docker stop app

[Install]
WantedBy=multi-user.target
UNIT

mkdir -p /etc/app

cat >/etc/app/app.env <<EOF
NAME=${name}
ENVIRONMENT=${environment}
APP_PORT=${app_port}
HEALTHCHECK_PATH=${healthcheck_path}
DATABASE_URL=${backend_endpoints["database_url"]}
REDIS_URL=${backend_endpoints["redis_url"]}
API_BASE_URL=${backend_endpoints["api_base_url"]}
EOF

%{ for k, v in backend_endpoints ~}
%{ if k != "database_url" && k != "redis_url" && k != "api_base_url" ~}
echo "${upper(k)}=${v}" >> /etc/app/app.env
%{ endif ~}
%{ endfor ~}

# Optional: pull additional non-secret config from SSM Parameter Store
if [[ -n "${PARAM_PREFIX}" ]]; then
  aws ssm get-parameters-by-path \
    --region "${REGION}" \
    --path "${PARAM_PREFIX}" \
    --recursive \
    --with-decryption \
    --query 'Parameters[*].{Name:Name,Value:Value}' \
    --output json | jq -r '.[] | "\(.Name)=\(.Value)"' | while IFS= read -r line; do
      key="$(echo "$line" | cut -d= -f1 | sed "s#^${PARAM_PREFIX}##" | tr '/.-' '___' | tr '[:lower:]' '[:upper:]')"
      val="$(echo "$line" | cut -d= -f2-)"
      echo "${key}=${val}" >> /etc/app/app.env
    done
fi

# Optional: pull secrets from Secrets Manager (expects JSON; flattens into env vars)
%{ if length(secrets_arns) > 0 ~}
for arn in %{ for s in secrets_arns ~}"${s}" %{ endfor ~}; do
  aws secretsmanager get-secret-value --region "${REGION}" --secret-id "$arn" --query SecretString --output text \
    | jq -r 'to_entries[] | "\(.key)=\(.value|tostring)"' >> /etc/app/app.env
done
%{ endif ~}

chmod 600 /etc/app/app.env

systemctl daemon-reload
systemctl enable --now app.service

# Fast readiness: wait briefly for local port to open, then exit
for i in $(seq 1 30); do
  if curl -fsS "http://127.0.0.1:${APP_PORT}${HEALTH_PATH}" >/dev/null 2>&1; then
    echo "App is healthy"
    exit 0
  fi
  sleep 2
done

echo "App did not become healthy in time"
exit 1