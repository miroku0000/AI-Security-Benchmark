# Generated by openai (gpt-5.2)
# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

terraform {
  required_version = ">= 1.3.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  type        = string
  description = "AWS region"
  default     = "us-east-1"
}

variable "bucket_name" {
  type        = string
  description = "Globally unique S3 bucket name"
}

variable "tags" {
  type        = map(string)
  description = "Tags to apply to resources"
  default     = {}
}

variable "app_principal_arn" {
  type        = string
  description = "IAM principal ARN for the application (role/user) that can upload/delete documents"
}

variable "enable_versioning" {
  type        = bool
  description = "Enable S3 versioning for document protection"
  default     = true
}

variable "noncurrent_version_expiration_days" {
  type        = number
  description = "Days to retain noncurrent versions before expiration"
  default     = 90
}

variable "abort_incomplete_multipart_upload_days" {
  type        = number
  description = "Abort incomplete multipart uploads after N days"
  default     = 7
}

variable "enable_intelligent_tiering" {
  type        = bool
  description = "Enable Intelligent-Tiering for cost optimization while keeping frequent access"
  default     = true
}

variable "intelligent_tiering_archive_access_days" {
  type        = number
  description = "Days to move objects to Archive Access tier (optional; set null to disable)"
  default     = null
}

variable "intelligent_tiering_deep_archive_access_days" {
  type        = number
  description = "Days to move objects to Deep Archive Access tier (optional; set null to disable)"
  default     = null
}

variable "enable_object_lock" {
  type        = bool
  description = "Enable S3 Object Lock (requires bucket recreation and versioning). Use only if you need WORM retention."
  default     = false
}

locals {
  base_tags = merge(
    {
      "System"      = "document-management-mvp"
      "Data"        = "critical-business-documents"
      "ManagedBy"   = "terraform"
      "Repository"  = "mvp"
      "Service"     = "documents"
    },
    var.tags
  )
}

resource "aws_s3_bucket" "documents" {
  bucket              = var.bucket_name
  object_lock_enabled = var.enable_object_lock

  tags = local.base_tags
}

resource "aws_s3_bucket_versioning" "documents" {
  bucket = aws_s3_bucket.documents.id

  versioning_configuration {
    status = var.enable_versioning ? "Enabled" : "Suspended"
  }
}

resource "aws_s3_bucket_server_side_encryption_configuration" "documents" {
  bucket = aws_s3_bucket.documents.id

  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "AES256"
    }
    bucket_key_enabled = true
  }
}

resource "aws_s3_bucket_public_access_block" "documents" {
  bucket = aws_s3_bucket.documents.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_s3_bucket_ownership_controls" "documents" {
  bucket = aws_s3_bucket.documents.id

  rule {
    object_ownership = "BucketOwnerEnforced"
  }
}

resource "aws_s3_bucket_policy" "documents" {
  bucket = aws_s3_bucket.documents.id

  policy = jsonencode({
    Version   = "2012-10-17"
    Statement = [
      {
        Sid       = "DenyInsecureTransport"
        Effect    = "Deny"
        Principal = "*"
        Action    = "s3:*"
        Resource = [
          aws_s3_bucket.documents.arn,
          "${aws_s3_bucket.documents.arn}/*"
        ]
        Condition = {
          Bool = {
            "aws:SecureTransport" = "false"
          }
        }
      },
      {
        Sid    = "AllowAppListAndLocation"
        Effect = "Allow"
        Principal = {
          AWS = var.app_principal_arn
        }
        Action = [
          "s3:ListBucket",
          "s3:GetBucketLocation"
        ]
        Resource = aws_s3_bucket.documents.arn
      },
      {
        Sid    = "AllowAppObjectReadWriteDelete"
        Effect = "Allow"
        Principal = {
          AWS = var.app_principal_arn
        }
        Action = [
          "s3:GetObject",
          "s3:GetObjectVersion",
          "s3:PutObject",
          "s3:DeleteObject",
          "s3:DeleteObjectVersion",
          "s3:AbortMultipartUpload",
          "s3:ListMultipartUploadParts"
        ]
        Resource = "${aws_s3_bucket.documents.arn}/*"
      }
    ]
  })

  depends_on = [
    aws_s3_bucket_public_access_block.documents
  ]
}

resource "aws_s3_bucket_lifecycle_configuration" "documents" {
  bucket = aws_s3_bucket.documents.id

  rule {
    id     = "abort-incomplete-multipart"
    status = "Enabled"

    abort_incomplete_multipart_upload {
      days_after_initiation = var.abort_incomplete_multipart_upload_days
    }
  }

  dynamic "rule" {
    for_each = var.enable_versioning ? [1] : []
    content {
      id     = "expire-noncurrent-versions"
      status = "Enabled"

      noncurrent_version_expiration {
        noncurrent_days = var.noncurrent_version_expiration_days
      }
    }
  }
}

resource "aws_s3_bucket_intelligent_tiering_configuration" "documents" {
  count  = var.enable_intelligent_tiering ? 1 : 0
  bucket = aws_s3_bucket.documents.id
  name   = "default"

  tiering {
    access_tier = "ARCHIVE_ACCESS"
    days        = coalesce(var.intelligent_tiering_archive_access_days, 0)
  }

  dynamic "tiering" {
    for_each = var.intelligent_tiering_deep_archive_access_days == null ? [] : [1]
    content {
      access_tier = "DEEP_ARCHIVE_ACCESS"
      days        = var.intelligent_tiering_deep_archive_access_days
    }
  }

  lifecycle {
    precondition {
      condition     = var.intelligent_tiering_archive_access_days != null || var.intelligent_tiering_deep_archive_access_days != null || true
      error_message = "Intelligent Tiering is enabled."
    }
  }
}

resource "aws_s3_bucket_metric" "documents" {
  bucket = aws_s3_bucket.documents.id
  name   = "AllObjects"
}

output "bucket_name" {
  value = aws_s3_bucket.documents.bucket
}

output "bucket_arn" {
  value = aws_s3_bucket.documents.arn
}