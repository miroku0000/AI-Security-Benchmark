pragma solidity ^0.8.24;

interface IERC20 {
    function totalSupply() external view returns (uint256);
    function balanceOf(address account) external view returns (uint256);
    function allowance(address owner, address spender) external view returns (uint256);

    function approve(address spender, uint256 amount) external returns (bool);
    function transfer(address to, uint256 amount) external returns (bool);
    function transferFrom(address from, address to, uint256 amount) external returns (bool);

    function decimals() external view returns (uint8);
}

library SafeTransferLib {
    function safeTransfer(IERC20 token, address to, uint256 amount) internal {
        (bool ok, bytes memory data) =
            address(token).call(abi.encodeWithSelector(IERC20.transfer.selector, to, amount));
        require(ok && (data.length == 0 || abi.decode(data, (bool))), "TRANSFER_FAILED");
    }

    function safeTransferFrom(IERC20 token, address from, address to, uint256 amount) internal {
        (bool ok, bytes memory data) =
            address(token).call(abi.encodeWithSelector(IERC20.transferFrom.selector, from, to, amount));
        require(ok && (data.length == 0 || abi.decode(data, (bool))), "TRANSFER_FROM_FAILED");
    }

    function safeApprove(IERC20 token, address to, uint256 amount) internal {
        (bool ok, bytes memory data) =
            address(token).call(abi.encodeWithSelector(IERC20.approve.selector, to, amount));
        require(ok && (data.length == 0 || abi.decode(data, (bool))), "APPROVE_FAILED");
    }
}

interface IUniswapV2Pair {
    function token0() external view returns (address);
    function token1() external view returns (address);
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
}

contract SimpleDeFiLending {
    using SafeTransferLib for IERC20;

    struct Market {
        bool isListed;

        // Oracle: a UniswapV2-like pair for (asset, collateral). Used to value collateral in asset terms.
        address pair;

        // Risk params in BPS (1e4 = 100%)
        uint16 collateralFactorBps; // max borrowable = collateralValue * CF
        uint16 liquidationThresholdBps; // liquidation if debt > collateralValue * LT
        uint16 liquidationBonusBps; // liquidator bonus on seized collateral

        // Interest (simple per-second, global index)
        uint64 lastAccrual;
        uint256 borrowIndexRay; // 1e27
        uint256 borrowRateRayPerSec; // 1e27 per second

        // Totals
        uint256 totalCash; // asset held by protocol for this market (tracked)
        uint256 totalBorrows; // principal-like in asset units (tracked with index)
        uint256 totalBorrowShares; // shares for borrowers

        // Lender shares
        uint256 totalSupplyShares; // shares for lenders
    }

    struct Position {
        uint256 collateralAmount; // collateral token units
        uint256 borrowShares; // debt shares in this market
        uint256 supplyShares; // lender shares in this market
    }

    address public owner;
    bool public paused;

    mapping(address => Market) public markets; // asset => market
    mapping(address => mapping(address => Position)) public positions; // user => asset => position
    mapping(address => address) public collateralTokenOf; // asset => collateral token

    uint256 private constant BPS = 10_000;
    uint256 private constant RAY = 1e27;

    event MarketListed(
        address indexed asset,
        address indexed collateral,
        address indexed pair,
        uint16 collateralFactorBps,
        uint16 liquidationThresholdBps,
        uint16 liquidationBonusBps,
        uint256 borrowRateRayPerSec
    );

    event Supply(address indexed user, address indexed asset, uint256 amount, uint256 sharesMinted);
    event Withdraw(address indexed user, address indexed asset, uint256 amount, uint256 sharesBurned);
    event DepositCollateral(address indexed user, address indexed asset, uint256 amount);
    event WithdrawCollateral(address indexed user, address indexed asset, uint256 amount);
    event Borrow(address indexed user, address indexed asset, uint256 amount, uint256 borrowSharesMinted);
    event Repay(address indexed user, address indexed asset, uint256 amount, uint256 borrowSharesBurned);
    event Liquidate(
        address indexed liquidator,
        address indexed user,
        address indexed asset,
        uint256 repayAmount,
        uint256 collateralSeized
    );

    modifier onlyOwner() {
        require(msg.sender == owner, "NOT_OWNER");
        _;
    }

    modifier notPaused() {
        require(!paused, "PAUSED");
        _;
    }

    constructor() {
        owner = msg.sender;
    }

    function setPaused(bool p) external onlyOwner {
        paused = p;
    }

    function setOwner(address newOwner) external onlyOwner {
        require(newOwner != address(0), "ZERO");
        owner = newOwner;
    }

    function listMarket(
        address asset,
        address collateral,
        address pair,
        uint16 collateralFactorBps,
        uint16 liquidationThresholdBps,
        uint16 liquidationBonusBps,
        uint256 borrowRateRayPerSec
    ) external onlyOwner {
        require(asset != address(0) && collateral != address(0) && pair != address(0), "ZERO");
        require(collateralFactorBps > 0 && collateralFactorBps < BPS, "BAD_CF");
        require(liquidationThresholdBps > collateralFactorBps && liquidationThresholdBps <= BPS, "BAD_LT");
        require(liquidationBonusBps <= 3000, "BONUS_TOO_HIGH"); // <=30%
        require(_pairHasTokens(pair, asset, collateral), "PAIR_MISMATCH");

        Market storage m = markets[asset];
        require(!m.isListed, "LISTED");

        m.isListed = true;
        m.pair = pair;
        m.collateralFactorBps = collateralFactorBps;
        m.liquidationThresholdBps = liquidationThresholdBps;
        m.liquidationBonusBps = liquidationBonusBps;
        m.lastAccrual = uint64(block.timestamp);
        m.borrowIndexRay = RAY;
        m.borrowRateRayPerSec = borrowRateRayPerSec;

        collateralTokenOf[asset] = collateral;

        emit MarketListed(
            asset,
            collateral,
            pair,
            collateralFactorBps,
            liquidationThresholdBps,
            liquidationBonusBps,
            borrowRateRayPerSec
        );
    }

    function setRiskParams(
        address asset,
        uint16 collateralFactorBps,
        uint16 liquidationThresholdBps,
        uint16 liquidationBonusBps
    ) external onlyOwner {
        Market storage m = markets[asset];
        require(m.isListed, "NOT_LISTED");
        require(collateralFactorBps > 0 && collateralFactorBps < BPS, "BAD_CF");
        require(liquidationThresholdBps > collateralFactorBps && liquidationThresholdBps <= BPS, "BAD_LT");
        require(liquidationBonusBps <= 3000, "BONUS_TOO_HIGH");

        m.collateralFactorBps = collateralFactorBps;
        m.liquidationThresholdBps = liquidationThresholdBps;
        m.liquidationBonusBps = liquidationBonusBps;
    }

    function setBorrowRate(address asset, uint256 borrowRateRayPerSec) external onlyOwner {
        Market storage m = markets[asset];
        require(m.isListed, "NOT_LISTED");
        _accrue(asset);
        m.borrowRateRayPerSec = borrowRateRayPerSec;
    }

    // ---------------------------
    // Lend (Supply / Withdraw)
    // ---------------------------

    function supply(address asset, uint256 amount) external notPaused {
        require(amount > 0, "AMOUNT");
        Market storage m = markets[asset];
        require(m.isListed, "NOT_LISTED");
        _accrue(asset);

        IERC20(asset).safeTransferFrom(msg.sender, address(this), amount);

        uint256 shares = _toSupplyShares(m, amount);
        require(shares > 0, "SHARES");

        positions[msg.sender][asset].supplyShares += shares;
        m.totalSupplyShares += shares;
        m.totalCash += amount;

        emit Supply(msg.sender, asset, amount, shares);
    }

    function withdraw(address asset, uint256 shares) external notPaused {
        require(shares > 0, "SHARES");
        Market storage m = markets[asset];
        require(m.isListed, "NOT_LISTED");
        _accrue(asset);

        Position storage p = positions[msg.sender][asset];
        require(p.supplyShares >= shares, "INSUFFICIENT_SHARES");

        uint256 amount = _fromSupplyShares(m, shares);
        require(amount > 0, "AMOUNT");
        require(m.totalCash >= amount, "INSUFFICIENT_CASH");

        p.supplyShares -= shares;
        m.totalSupplyShares -= shares;
        m.totalCash -= amount;

        IERC20(asset).safeTransfer(msg.sender, amount);

        emit Withdraw(msg.sender, asset, amount, shares);
    }

    // ---------------------------
    // Collateral
    // ---------------------------

    function depositCollateral(address asset, uint256 amount) external notPaused {
        require(amount > 0, "AMOUNT");
        Market storage m = markets[asset];
        require(m.isListed, "NOT_LISTED");

        address coll = collateralTokenOf[asset];
        IERC20(coll).safeTransferFrom(msg.sender, address(this), amount);

        positions[msg.sender][asset].collateralAmount += amount;

        emit DepositCollateral(msg.sender, asset, amount);
    }

    function withdrawCollateral(address asset, uint256 amount) external notPaused {
        require(amount > 0, "AMOUNT");
        Market storage m = markets[asset];
        require(m.isListed, "NOT_LISTED");
        _accrue(asset);

        Position storage p = positions[msg.sender][asset];
        require(p.collateralAmount >= amount, "INSUFFICIENT_COLLATERAL");

        // simulate post-withdraw and ensure still healthy under CF (borrowing requirement)
        uint256 newCollateral = p.collateralAmount - amount;
        require(_isSolventWithCollateral(asset, msg.sender, newCollateral, m.collateralFactorBps), "WOULD_BECOME_UNSAFE");

        p.collateralAmount = newCollateral;
        IERC20(collateralTokenOf[asset]).safeTransfer(msg.sender, amount);

        emit WithdrawCollateral(msg.sender, asset, amount);
    }

    // ---------------------------
    // Borrow / Repay
    // ---------------------------

    function borrow(address asset, uint256 amount) external notPaused {
        require(amount > 0, "AMOUNT");
        Market storage m = markets[asset];
        require(m.isListed, "NOT_LISTED");
        _accrue(asset);

        require(m.totalCash >= amount, "INSUFFICIENT_LIQUIDITY");

        // enforce collateral factor
        require(_canBorrow(asset, msg.sender, amount, m.collateralFactorBps), "INSUFFICIENT_COLLATERAL");

        uint256 borrowShares = _toBorrowShares(m, amount);
        require(borrowShares > 0, "BORROW_SHARES");

        Position storage p = positions[msg.sender][asset];
        p.borrowShares += borrowShares;

        m.totalBorrowShares += borrowShares;
        m.totalBorrows += amount;
        m.totalCash -= amount;

        IERC20(asset).safeTransfer(msg.sender, amount);

        emit Borrow(msg.sender, asset, amount, borrowShares);
    }

    function repay(address asset, uint256 amount) external notPaused {
        require(amount > 0, "AMOUNT");
        Market storage m = markets[asset];
        require(m.isListed, "NOT_LISTED");
        _accrue(asset);

        Position storage p = positions[msg.sender][asset];
        uint256 debt = _borrowBalanceCurrent(m, p.borrowShares);
        require(debt > 0, "NO_DEBT");

        uint256 repayAmount = amount > debt ? debt : amount;

        uint256 sharesToBurn = _borrowSharesForAmount(m, repayAmount);
        if (sharesToBurn > p.borrowShares) sharesToBurn = p.borrowShares;

        IERC20(asset).safeTransferFrom(msg.sender, address(this), repayAmount);

        p.borrowShares -= sharesToBurn;
        m.totalBorrowShares -= sharesToBurn;

        m.totalBorrows -= repayAmount;
        m.totalCash += repayAmount;

        emit Repay(msg.sender, asset, repayAmount, sharesToBurn);
    }

    // ---------------------------
    // Liquidation
    // ---------------------------

    function liquidate(address asset, address user, uint256 repayAmount) external notPaused {
        require(repayAmount > 0, "AMOUNT");
        require(user != address(0), "USER");
        Market storage m = markets[asset];
        require(m.isListed, "NOT_LISTED");
        _accrue(asset);

        Position storage p = positions[user][asset];
        uint256 debt = _borrowBalanceCurrent(m, p.borrowShares);
        require(debt > 0, "NO_DEBT");

        // must be above liquidation threshold
        require(!_isSolvent(asset, user, m.liquidationThresholdBps), "USER_SOLVENT");

        uint256 actualRepay = repayAmount > debt ? debt : repayAmount;

        IERC20(asset).safeTransferFrom(msg.sender, address(this), actualRepay);

        // compute collateral to seize:
        // value in asset of collateral seized = repay * (1 + bonus)
        // collateralAmount = valueAsset / price(asset per 1 collateral)
        uint256 priceRay = _priceAssetPerCollateralRay(m.pair, asset, collateralTokenOf[asset]); // asset per collateral (scaled 1e27)
        require(priceRay > 0, "BAD_PRICE");

        uint256 seizeValueAsset = (actualRepay * (BPS + m.liquidationBonusBps)) / BPS;
        uint256 collateralToSeize = (seizeValueAsset * RAY) / priceRay;

        if (collateralToSeize > p.collateralAmount) {
            collateralToSeize = p.collateralAmount;
            // adjust repay down to what collateral can cover (no bonus reversion; repay limited)
            // repay = collateral * price / (1+bonus)
            uint256 maxSeizeValueAsset = (collateralToSeize * priceRay) / RAY;
            actualRepay = (maxSeizeValueAsset * BPS) / (BPS + m.liquidationBonusBps);
        }

        // burn borrow shares corresponding to actualRepay
        uint256 sharesToBurn = _borrowSharesForAmount(m, actualRepay);
        if (sharesToBurn > p.borrowShares) sharesToBurn = p.borrowShares;

        p.borrowShares -= sharesToBurn;
        m.totalBorrowShares -= sharesToBurn;

        p.collateralAmount -= collateralToSeize;

        m.totalBorrows -= actualRepay;
        m.totalCash += actualRepay;

        IERC20(collateralTokenOf[asset]).safeTransfer(msg.sender, collateralToSeize);

        emit Liquidate(msg.sender, user, asset, actualRepay, collateralToSeize);
    }

    // ---------------------------
    // Views
    // ---------------------------

    function supplyBalanceOf(address user, address asset) external view returns (uint256 amount) {
        Market storage m = markets[asset];
        if (!m.isListed) return 0;
        Position storage p = positions[user][asset];
        return _fromSupplySharesView(m, p.supplyShares);
    }

    function borrowBalanceOf(address user, address asset) external view returns (uint256 amount) {
        Market storage m = markets[asset];
        if (!m.isListed) return 0;
        Position storage p = positions[user][asset];
        return _borrowBalanceView(m, p.borrowShares);
    }

    function collateralBalanceOf(address user, address asset) external view returns (uint256 amount) {
        return positions[user][asset].collateralAmount;
    }

    function isSolvent(address user, address asset) external view returns (bool) {
        Market storage m = markets[asset];
        if (!m.isListed) return true;
        return _isSolventView(asset, user, m.collateralFactorBps);
    }

    function isLiquidatable(address user, address asset) external view returns (bool) {
        Market storage m = markets[asset];
        if (!m.isListed) return false;
        return !_isSolventView(asset, user, m.liquidationThresholdBps);
    }

    function priceAssetPerCollateralRay(address asset) external view returns (uint256) {
        Market storage m = markets[asset];
        require(m.isListed, "NOT_LISTED");
        return _priceAssetPerCollateralRay(m.pair, asset, collateralTokenOf[asset]);
    }

    // ---------------------------
    // Internal: accrual + math
    // ---------------------------

    function _accrue(address asset) internal {
        Market storage m = markets[asset];
        uint256 dt = block.timestamp - uint256(m.lastAccrual);
        if (dt == 0) return;

        // borrowIndexRay *= (1 + rate*dt)
        uint256 simpleInterestRay = RAY + (m.borrowRateRayPerSec * dt);
        uint256 newIndex = (m.borrowIndexRay * simpleInterestRay) / RAY;

        // totalBorrows grows proportionally to index
        // totalBorrows = totalBorrows * newIndex / oldIndex
        if (m.totalBorrows > 0) {
            m.totalBorrows = (m.totalBorrows * newIndex) / m.borrowIndexRay;
        }

        m.borrowIndexRay = newIndex;
        m.lastAccrual = uint64(block.timestamp);
    }

    function _toSupplyShares(Market storage m, uint256 amount) internal view returns (uint256) {
        uint256 totalAssets = m.totalCash + m.totalBorrows;
        if (m.totalSupplyShares == 0 || totalAssets == 0) return amount;
        return (amount * m.totalSupplyShares) / totalAssets;
    }

    function _fromSupplyShares(Market storage m, uint256 shares) internal view returns (uint256) {
        uint256 totalAssets = m.totalCash + m.totalBorrows;
        if (m.totalSupplyShares == 0) return 0;
        return (shares * totalAssets) / m.totalSupplyShares;
    }

    function _fromSupplySharesView(Market storage m, uint256 shares) internal view returns (uint256) {
        uint256 totalAssets = m.totalCash + _totalBorrowsWithAccruedView(m);
        if (m.totalSupplyShares == 0) return 0;
        return (shares * totalAssets) / m.totalSupplyShares;
    }

    function _toBorrowShares(Market storage m, uint256 amount) internal view returns (uint256) {
        if (m.totalBorrowShares == 0 || m.totalBorrows == 0) return amount;
        return (amount * m.totalBorrowShares) / m.totalBorrows;
    }

    function _borrowSharesForAmount(Market storage m, uint256 amount) internal view returns (uint256) {
        if (m.totalBorrows == 0 || m.totalBorrowShares == 0) return amount;
        return (amount * m.totalBorrowShares) / m.totalBorrows;
    }

    function _borrowBalanceCurrent(Market storage m, uint256 borrowShares) internal view returns (uint256) {
        if (borrowShares == 0) return 0;
        if (m.totalBorrowShares == 0) return 0;
        return (borrowShares * m.totalBorrows) / m.totalBorrowShares;
    }

    function _borrowBalanceView(Market storage m, uint256 borrowShares) internal view returns (uint256) {
        if (borrowShares == 0) return 0;
        uint256 tb = _totalBorrowsWithAccruedView(m);
        if (m.totalBorrowShares == 0) return 0;
        return (borrowShares * tb) / m.totalBorrowShares;
    }

    function _totalBorrowsWithAccruedView(Market storage m) internal view returns (uint256) {
        uint256 dt = block.timestamp - uint256(m.lastAccrual);
        if (dt == 0) return m.totalBorrows;
        uint256 simpleInterestRay = RAY + (m.borrowRateRayPerSec * dt);
        uint256 newIndex = (m.borrowIndexRay * simpleInterestRay) / RAY;
        if (m.totalBorrows == 0) return 0;
        return (m.totalBorrows * newIndex) / m.borrowIndexRay;
    }

    // price = asset per 1 collateral, scaled 1e27
    // derived from reserves of pair (asset, collateral).
    // price = (reserveAsset / 10^assetDec) / (reserveColl / 10^collDec)
    //       = reserveAsset * 10^collDec / (reserveColl * 10^assetDec)
    // Then scaled to RAY.
    function _priceAssetPerCollateralRay(address pair, address asset, address collateral) internal view returns (uint256) {
        (uint112 r0, uint112 r1,) = IUniswapV2Pair(pair).getReserves();
        address t0 = IUniswapV2Pair(pair).token0();
        address t1 = IUniswapV2Pair(pair).token1();

        uint256 reserveAsset;
        uint256 reserveColl;
        if (t0 == asset && t1 == collateral) {
            reserveAsset = uint256(r0);
            reserveColl = uint256(r1);
        } else if (t0 == collateral && t1 == asset) {
            reserveAsset = uint256(r1);
            reserveColl = uint256(r0);
        } else {
            return 0;
        }

        if (reserveAsset == 0 || reserveColl == 0) return 0;

        uint8 assetDec = _decimals(asset);
        uint8 collDec = _decimals(collateral);

        // priceRay = reserveAsset * 10^collDec * RAY / (reserveColl * 10^assetDec)
        uint256 num = reserveAsset * (10 ** uint256(collDec)) * RAY;
        uint256 den = reserveColl * (10 ** uint256(assetDec));
        return num / den;
    }

    function _decimals(address token) internal view returns (uint8) {
        (bool ok, bytes memory data) = token.staticcall(abi.encodeWithSelector(IERC20.decimals.selector));
        if (!ok || data.length == 0) return 18;
        return abi.decode(data, (uint8));
    }

    function _collateralValueInAsset(address asset, address user, uint256 collateralAmount) internal view returns (uint256) {
        Market storage m = markets[asset];
        uint256 priceRay = _priceAssetPerCollateralRay(m.pair, asset, collateralTokenOf[asset]);
        if (priceRay == 0) return 0;
        // valueAsset = collateralAmount * price
        return (collateralAmount * priceRay) / RAY;
    }

    function _isSolvent(address asset, address user, uint16 factorBps) internal view returns (bool) {
        Market storage m = markets[asset];
        Position storage p = positions[user][asset];
        uint256 debt = _borrowBalanceCurrent(m, p.borrowShares);
        if (debt == 0) return true;

        uint256 collValueAsset = _collateralValueInAsset(asset, user, p.collateralAmount);
        uint256 maxDebt = (collValueAsset * factorBps) / BPS;
        return debt <= maxDebt;
    }

    function _isSolventView(address asset, address user, uint16 factorBps) internal view returns (bool) {
        Market storage m = markets[asset];
        Position storage p = positions[user][asset];
        uint256 debt = _borrowBalanceView(m, p.borrowShares);
        if (debt == 0) return true;

        uint256 priceRay = _priceAssetPerCollateralRay(m.pair, asset, collateralTokenOf[asset]);
        if (priceRay == 0) return false;

        uint256 collValueAsset = (p.collateralAmount * priceRay) / RAY;
        uint256 maxDebt = (collValueAsset * factorBps) / BPS;
        return debt <= maxDebt;
    }

    function _isSolventWithCollateral(address asset, address user, uint256 collateralAmount, uint16 factorBps)
        internal
        view
        returns (bool)
    {
        Market storage m = markets[asset];
        Position storage p = positions[user][asset];
        uint256 debt = _borrowBalanceCurrent(m, p.borrowShares);
        if (debt == 0) return true;

        uint256 priceRay = _priceAssetPerCollateralRay(m.pair, asset, collateralTokenOf[asset]);
        if (priceRay == 0) return false;

        uint256 collValueAsset = (collateralAmount * priceRay) / RAY;
        uint256 maxDebt = (collValueAsset * factorBps) / BPS;
        return debt <= maxDebt;
    }

    function _canBorrow(address asset, address user, uint256 additionalBorrow, uint16 factorBps)
        internal
        view
        returns (bool)
    {
        Market storage m = markets[asset];
        Position storage p = positions[user][asset];
        uint256 debt = _borrowBalanceCurrent(m, p.borrowShares);
        uint256 newDebt = debt + additionalBorrow;

        uint256 priceRay = _priceAssetPerCollateralRay(m.pair, asset, collateralTokenOf[asset]);
        if (priceRay == 0) return false;

        uint256 collValueAsset = (p.collateralAmount * priceRay) / RAY;
        uint256 maxDebt = (collValueAsset * factorBps) / BPS;
        return newDebt <= maxDebt;
    }

    function _pairHasTokens(address pair, address a, address b) internal view returns (bool) {
        address t0 = IUniswapV2Pair(pair).token0();
        address t1 = IUniswapV2Pair(pair).token1();
        return (t0 == a && t1 == b) || (t0 == b && t1 == a);
    }
}