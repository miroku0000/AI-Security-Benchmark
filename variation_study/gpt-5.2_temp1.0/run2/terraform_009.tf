}

output "asg_name" {
  value = aws_autoscaling_group.web.name
}

output "launch_template_id" {
  value = aws_launch_template.web.id
}

output "iam_role_arn" {
  value = aws_iam_role.ec2.arn
}

output "security_group_id" {
  value = aws_security_group.web.id
}