  default     = ""
}

variable "s3_bucket_arns" {
  type        = list(string)
  description = "List of S3 bucket ARNs the app can access (e.g., arn:aws:s3:::my-bucket)"
  default     = []
}

variable "dynamodb_table_arns" {
  type        = list(string)
  description = "List of DynamoDB table ARNs the app can access"
  default     = []
}

variable "allowed_http_cidrs" {
  type        = list(string)
  description = "Allowed IPv4 CIDRs for HTTP"
  default     = ["0.0.0.0/0"]
}

variable "allowed_http_ipv6_cidrs" {
  type        = list(string)
  description = "Allowed IPv6 CIDRs for HTTP"
  default     = ["::/0"]
}

variable "allowed_https_cidrs" {
  type        = list(string)
  description = "Allowed IPv4 CIDRs for HTTPS"
