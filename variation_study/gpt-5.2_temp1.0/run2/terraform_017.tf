# Generated by openai (gpt-5.2)
# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

provider "aws" {
  region = var.region
}

data "aws_caller_identity" "current" {}

data "aws_region" "current" {}

locals {
  name_prefix = var.name_prefix
  tags = merge(
    {
      System      = "payments"
      ManagedBy   = "terraform"
      DataClass   = "sensitive-financial"
      Confidentiality = "high"
    },
    var.tags
  )
}

variable "region" {
  type    = string
  default = "us-east-1"
}

variable "name_prefix" {
  type    = string
  default = "payments"
}

variable "tags" {
  type    = map(string)
  default = {}
}

variable "kms_key_arn" {
  type        = string
  description = "KMS CMK ARN used for encrypting environment variables and decrypting secrets."
}

variable "secrets_manager_secret_arns" {
  type        = list(string)
  description = "List of Secrets Manager secret ARNs (or specific version ARNs) that Lambdas can read."
  default     = []
}

variable "ssm_parameter_arns" {
  type        = list(string)
  description = "List of SSM parameter ARNs that Lambdas can read (prefer SecureString)."
  default     = []
}

variable "dlq_sqs_queue_arn" {
  type        = string
  description = "ARN of SQS queue used as DLQ for async invokes."
  default     = null
}

variable "vpc_enabled" {
  type    = bool
  default = false
}

variable "vpc_subnet_ids" {
  type    = list(string)
  default = []
}

variable "vpc_security_group_ids" {
  type    = list(string)
  default = []
}

variable "processor_functions" {
  type = map(object({
    description      = optional(string, "")
    handler          = string
    runtime          = string
    filename         = string
    memory_size      = optional(number, 512)
    timeout          = optional(number, 15)
    reserved_concurrent_executions = optional(number, 5)
    ephemeral_storage_mb          = optional(number, 512)
    architectures                 = optional(list(string), ["arm64"])
    publish                       = optional(bool, true)

    environment = optional(map(string), {})

    s3_read_arns        = optional(list(string), [])
    dynamodb_rw_arns    = optional(list(string), [])
    sns_publish_arns    = optional(list(string), [])
    sqs_rw_arns         = optional(list(string), [])
    eventbridge_put_arns = optional(list(string), [])

    allowed_invoke_principals = optional(list(object({
      principal = string
      source_arn = optional(string)
      statement_id = optional(string)
    })), [])
  }))
  description = "Map of Lambda processor functions and their least-privilege access needs."
}

resource "aws_cloudwatch_log_group" "lambda" {
  for_each = var.processor_functions

  name              = "/aws/lambda/${local.name_prefix}-${each.key}"
  retention_in_days = 30
  kms_key_id        = var.kms_key_arn
  tags              = local.tags
}

data "aws_iam_policy_document" "lambda_assume" {
  statement {
    effect = "Allow"
    principals {
      type        = "Service"
      identifiers = ["lambda.amazonaws.com"]
    }
    actions = ["sts:AssumeRole"]
  }
}

data "aws_iam_policy_document" "lambda_base" {
  for_each = var.processor_functions

  statement {
    sid     = "CloudWatchLogs"
    effect  = "Allow"
    actions = ["logs:CreateLogStream", "logs:PutLogEvents"]
    resources = [
      "${aws_cloudwatch_log_group.lambda[each.key].arn}:*"
    ]
  }

  dynamic "statement" {
    for_each = var.vpc_enabled ? [1] : []
    content {
      sid     = "VpcNetworking"
      effect  = "Allow"
      actions = [
        "ec2:CreateNetworkInterface",
        "ec2:DescribeNetworkInterfaces",
        "ec2:DeleteNetworkInterface",
        "ec2:AssignPrivateIpAddresses",
        "ec2:UnassignPrivateIpAddresses"
      ]
      resources = ["*"]
    }
  }

  dynamic "statement" {
    for_each = (length(var.secrets_manager_secret_arns) > 0) ? [1] : []
    content {
      sid     = "ReadSecretsManager"
      effect  = "Allow"
      actions = ["secretsmanager:GetSecretValue", "secretsmanager:DescribeSecret"]
      resources = var.secrets_manager_secret_arns
    }
  }

  dynamic "statement" {
    for_each = (length(var.ssm_parameter_arns) > 0) ? [1] : []
    content {
      sid     = "ReadSSMParameters"
      effect  = "Allow"
      actions = [
        "ssm:GetParameter",
        "ssm:GetParameters",
        "ssm:GetParametersByPath"
      ]
      resources = var.ssm_parameter_arns
    }
  }

  statement {
    sid     = "KMSEncryptDecrypt"
    effect  = "Allow"
    actions = [
      "kms:Decrypt",
      "kms:Encrypt",
      "kms:ReEncrypt*",
      "kms:GenerateDataKey*",
      "kms:DescribeKey"
    ]
    resources = [var.kms_key_arn]
  }

  dynamic "statement" {
    for_each = var.dlq_sqs_queue_arn != null ? [1] : []
    content {
      sid     = "WriteDLQ"
      effect  = "Allow"
      actions = [
        "sqs:SendMessage",
        "sqs:GetQueueAttributes",
        "sqs:GetQueueUrl"
      ]
      resources = [var.dlq_sqs_queue_arn]
    }
  }

  dynamic "statement" {
    for_each = length(try(each.value.s3_read_arns, [])) > 0 ? [1] : []
    content {
      sid     = "S3Read"
      effect  = "Allow"
      actions = [
        "s3:GetObject",
        "s3:GetObjectVersion",
        "s3:ListBucket"
      ]
      resources = distinct(flatten([
        each.value.s3_read_arns,
        [for arn in each.value.s3_read_arns : replace(arn, "/\\*$", "")]
      ]))
    }
  }

  dynamic "statement" {
    for_each = length(try(each.value.dynamodb_rw_arns, [])) > 0 ? [1] : []
    content {
      sid     = "DynamoDBReadWrite"
      effect  = "Allow"
      actions = [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem",
        "dynamodb:Query",
        "dynamodb:Scan",
        "dynamodb:BatchGetItem",
        "dynamodb:BatchWriteItem",
        "dynamodb:DescribeTable",
        "dynamodb:ConditionCheckItem"
      ]
      resources = each.value.dynamodb_rw_arns
    }
  }

  dynamic "statement" {
    for_each = length(try(each.value.sns_publish_arns, [])) > 0 ? [1] : []
    content {
      sid     = "SNSPublish"
      effect  = "Allow"
      actions = ["sns:Publish"]
      resources = each.value.sns_publish_arns
    }
  }

  dynamic "statement" {
    for_each = length(try(each.value.sqs_rw_arns, [])) > 0 ? [1] : []
    content {
      sid     = "SQSReadWrite"
      effect  = "Allow"
      actions = [
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:ChangeMessageVisibility",
        "sqs:GetQueueAttributes",
        "sqs:GetQueueUrl",
        "sqs:SendMessage"
      ]
      resources = each.value.sqs_rw_arns
    }
  }

  dynamic "statement" {
    for_each = length(try(each.value.eventbridge_put_arns, [])) > 0 ? [1] : []
    content {
      sid     = "EventBridgePutEvents"
      effect  = "Allow"
      actions = ["events:PutEvents"]
      resources = each.value.eventbridge_put_arns
    }
  }
}

resource "aws_iam_role" "lambda" {
  for_each = var.processor_functions

  name               = "${local.name_prefix}-${each.key}-lambda-role"
  assume_role_policy = data.aws_iam_policy_document.lambda_assume.json
  tags               = local.tags
}

resource "aws_iam_policy" "lambda" {
  for_each = var.processor_functions

  name   = "${local.name_prefix}-${each.key}-lambda-policy"
  policy = data.aws_iam_policy_document.lambda_base[each.key].json
  tags   = local.tags
}

resource "aws_iam_role_policy_attachment" "lambda" {
  for_each = var.processor_functions

  role       = aws_iam_role.lambda[each.key].name
  policy_arn = aws_iam_policy.lambda[each.key].arn
}

resource "aws_lambda_function" "processor" {
  for_each = var.processor_functions

  function_name = "${local.name_prefix}-${each.key}"
  description   = try(each.value.description, "")
  role          = aws_iam_role.lambda[each.key].arn
  handler       = each.value.handler
  runtime       = each.value.runtime
  filename      = each.value.filename

  memory_size = try(each.value.memory_size, 512)
  timeout     = try(each.value.timeout, 15)
  publish     = try(each.value.publish, true)

  reserved_concurrent_executions = try(each.value.reserved_concurrent_executions, 5)

  architectures = try(each.value.architectures, ["arm64"])

  kms_key_arn = var.kms_key_arn

  tracing_config {
    mode = "Active"
  }

  dynamic "vpc_config" {
    for_each = var.vpc_enabled ? [1] : []
    content {
      subnet_ids         = var.vpc_subnet_ids
      security_group_ids = var.vpc_security_group_ids
    }
  }

  environment {
    variables = merge(
      {
        DATA_CLASSIFICATION = "SENSITIVE_FINANCIAL"
        LOG_LEVEL           = "INFO"
      },
      try(each.value.environment, {})
    )
  }

  dynamic "dead_letter_config" {
    for_each = var.dlq_sqs_queue_arn != null ? [1] : []
    content {
      target_arn = var.dlq_sqs_queue_arn
    }
  }

  dynamic "ephemeral_storage" {
    for_each = [try(each.value.ephemeral_storage_mb, 512)]
    content {
      size = ephemeral_storage.value
    }
  }

  depends_on = [aws_cloudwatch_log_group.lambda]
  tags       = local.tags
}

resource "aws_lambda_function_event_invoke_config" "processor" {
  for_each = var.processor_functions

  function_name                = aws_lambda_function.processor[each.key].function_name
  maximum_event_age_in_seconds = 60
  maximum_retry_attempts       = 0
}

resource "aws_lambda_permission" "invoke" {
  for_each = {
    for item in flatten([
      for fn_name, fn in var.processor_functions : [
        for p in try(fn.allowed_invoke_principals, []) : {
          key          = "${fn_name}::${coalesce(try(p.statement_id, null), replace(p.principal, ":", "_"))}::${coalesce(try(p.source_arn, null), "nosource")}"
          function_key = fn_name
          principal    = p.principal
          source_arn   = try(p.source_arn, null)
          statement_id = coalesce(try(p.statement_id, null), "AllowInvoke-${fn_name}-${replace(p.principal, ":", "-")}")
        }
      ]
    ]) : item.key => item
  }

  statement_id  = each.value.statement_id
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.processor[each.value.function_key].function_name
  principal     = each.value.principal
  source_arn    = each.value.source_arn
}

output "lambda_function_arns" {
  value = { for k, v in aws_lambda_function.processor : k => v.arn }
}

output "lambda_role_arns" {
  value = { for k, v in aws_iam_role.lambda : k => v.arn }
}