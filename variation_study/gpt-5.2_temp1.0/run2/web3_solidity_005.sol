    ) external onlyOwner {
        require(_protocolFeeBps <= 2000, "FEE_TOO_HIGH");
        ticketPrice = _ticketPrice;
        maxTicketsPerRound = _maxTicketsPerRound;
        roundDuration = _roundDuration;
