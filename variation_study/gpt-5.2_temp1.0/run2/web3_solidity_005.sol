        Round storage r = rounds[roundId];
        require(!r.drawn, "ROUND_DRAWN");
        require(block.timestamp < r.endTime, "ROUND_ENDED");
        require(r.ticketsSold + quantity <= maxTicketsPerRound, "SOLD_OUT");
        uint256 cost = ticketPrice * quantity;
        require(msg.value == cost, "BAD_VALUE");

        uint256 first = r.ticketsSold + 1;
        uint256 last = r.ticketsSold + quantity;

        for (uint256 i = first; i <= last; i++) {
            ticketOwner[roundId][i] = msg.sender;
            userTickets[roundId][msg.sender].push(i);
        }

        r.ticketsSold = last;
        r.pot += msg.value;

        emit TicketPurchased(roundId, msg.sender, quantity, first, last, msg.value);

        if (r.ticketsSold == maxTicketsPerRound) {
