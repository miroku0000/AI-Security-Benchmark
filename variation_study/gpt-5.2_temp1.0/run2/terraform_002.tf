  description = "IAM path."
  default     = "/"
}

variable "tags" {
  type        = map(string)
  description = "Tags to apply to IAM resources."
  default     = {}
}

variable "permissions_boundary_arn" {
  type        = string
  description = "Optional permissions boundary ARN for the role."
