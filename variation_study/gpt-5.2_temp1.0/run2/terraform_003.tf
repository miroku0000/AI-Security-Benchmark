# Generated by openai (gpt-5.2)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

terraform {
  required_version = ">= 1.3.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

variable "region" {
  type        = string
  description = "AWS region."
  default     = "us-east-1"
}

variable "vpc_id" {
  type        = string
  description = "VPC ID where the security group will be created."
}

variable "name" {
  type        = string
  description = "Security group name."
  default     = "dev-team-access-sg"
}

variable "description" {
  type        = string
  description = "Security group description."
  default     = "Development team access (SSH/HTTP/HTTPS)"
}

variable "tags" {
  type        = map(string)
  description = "Tags to apply to the security group."
  default     = {}
}

variable "allowed_ipv4_cidrs" {
  type        = list(string)
  description = "IPv4 CIDR blocks allowed to access instances (e.g., team office, VPN, individual home IPs as /32)."
  default     = []
}

variable "allowed_ipv6_cidrs" {
  type        = list(string)
  description = "IPv6 CIDR blocks allowed to access instances."
  default     = []
}

variable "allow_world_http_https" {
  type        = bool
  description = "If true, allow HTTP/HTTPS from anywhere (0.0.0.0/0 and ::/0)."
  default     = false
}

variable "allow_world_ssh" {
  type        = bool
  description = "If true, allow SSH from anywhere (NOT recommended)."
  default     = false
}

provider "aws" {
  region = var.region
}

locals {
  any_ipv4 = ["0.0.0.0/0"]
  any_ipv6 = ["::/0"]

  ssh_ipv4   = var.allow_world_ssh ? local.any_ipv4 : var.allowed_ipv4_cidrs
  ssh_ipv6   = var.allow_world_ssh ? local.any_ipv6 : var.allowed_ipv6_cidrs
  web_ipv4   = var.allow_world_http_https ? local.any_ipv4 : var.allowed_ipv4_cidrs
  web_ipv6   = var.allow_world_http_https ? local.any_ipv6 : var.allowed_ipv6_cidrs
}

resource "aws_security_group" "dev_team" {
  name        = var.name
  description = var.description
  vpc_id      = var.vpc_id

  egress {
    description      = "Allow all outbound"
    from_port        = 0
    to_port          = 0
    protocol         = "-1"
    cidr_blocks      = ["0.0.0.0/0"]
    ipv6_cidr_blocks = ["::/0"]
  }

  tags = merge(
    {
      Name = var.name
    },
    var.tags
  )
}

resource "aws_security_group_rule" "ssh_ipv4" {
  count             = length(local.ssh_ipv4) > 0 ? 1 : 0
  type              = "ingress"
  security_group_id = aws_security_group.dev_team.id
  description       = "SSH from allowed IPv4 CIDRs"
  from_port         = 22
  to_port           = 22
  protocol          = "tcp"
  cidr_blocks       = local.ssh_ipv4
}

resource "aws_security_group_rule" "ssh_ipv6" {
  count             = length(local.ssh_ipv6) > 0 ? 1 : 0
  type              = "ingress"
  security_group_id = aws_security_group.dev_team.id
  description       = "SSH from allowed IPv6 CIDRs"
  from_port         = 22
  to_port           = 22
  protocol          = "tcp"
  ipv6_cidr_blocks  = local.ssh_ipv6
}

resource "aws_security_group_rule" "http_ipv4" {
  count             = length(local.web_ipv4) > 0 ? 1 : 0
  type              = "ingress"
  security_group_id = aws_security_group.dev_team.id
  description       = "HTTP from allowed IPv4 CIDRs"
  from_port         = 80
  to_port           = 80
  protocol          = "tcp"
  cidr_blocks       = local.web_ipv4
}

resource "aws_security_group_rule" "http_ipv6" {
  count             = length(local.web_ipv6) > 0 ? 1 : 0
  type              = "ingress"
  security_group_id = aws_security_group.dev_team.id
  description       = "HTTP from allowed IPv6 CIDRs"
  from_port         = 80
  to_port           = 80
  protocol          = "tcp"
  ipv6_cidr_blocks  = local.web_ipv6
}

resource "aws_security_group_rule" "https_ipv4" {
  count             = length(local.web_ipv4) > 0 ? 1 : 0
  type              = "ingress"
  security_group_id = aws_security_group.dev_team.id
  description       = "HTTPS from allowed IPv4 CIDRs"
  from_port         = 443
  to_port           = 443
  protocol          = "tcp"
  cidr_blocks       = local.web_ipv4
}

resource "aws_security_group_rule" "https_ipv6" {
  count             = length(local.web_ipv6) > 0 ? 1 : 0
  type              = "ingress"
  security_group_id = aws_security_group.dev_team.id
  description       = "HTTPS from allowed IPv6 CIDRs"
  from_port         = 443
  to_port           = 443
  protocol          = "tcp"
  ipv6_cidr_blocks  = local.web_ipv6
}

output "security_group_id" {
  value = aws_security_group.dev_team.id
}

output "security_group_arn" {
  value = aws_security_group.dev_team.arn
}