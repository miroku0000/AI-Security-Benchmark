variable "name" {
  type        = string
  description = "IAM role name"
}

variable "path" {
  type        = string
  description = "IAM role path"
  default     = "/"
}

variable "description" {
  type        = string
  description = "IAM role description"
  default     = "CI/CD deployment role"
}

variable "max_session_duration" {
  type        = number
  description = "Max session duration in seconds"
  default     = 3600
}

variable "permissions_boundary_arn" {
  type        = string
  description = "Optional permissions boundary ARN"
  default     = null
}

variable "tags" {
  type        = map(string)
  description = "Tags to apply"
  default     = {}
}

variable "trusted_principal_arns" {
  type        = list(string)
  description = "AWS principal ARNs that can assume this role (e.g., IAM roles/users, GitHub OIDC provider role, etc.)"
  default     = []
}

variable "trusted_account_ids" {
  type        = list(string)
  description = "AWS account IDs that can assume this role (root principal of those accounts)"
  default     = []
}

variable "external_id" {
  type        = string
  description = "Optional ExternalId condition for AssumeRole"
  default     = null
}

variable "require_mfa" {
  type        = bool
  description = "Require MFA for AssumeRole (only applies for IAM user principals)"
  default     = false
}

variable "oidc_provider_arn" {
  type        = string
  description = "Optional OIDC provider ARN (for web identity federation)"
  default     = null
}

variable "oidc_audiences" {
  type        = list(string)
  description = "Allowed OIDC aud values"
  default     = ["sts.amazonaws.com"]
}

variable "oidc_subjects" {
  type        = list(string)
  description = "Allowed OIDC sub values (e.g., repo:org/repo:ref:refs/heads/main)"
  default     = []
}

variable "oidc_subject_pattern" {
  type        = string
  description = "Optional wildcard pattern for OIDC sub (used with StringLike). Ignored if oidc_subjects is set."
  default     = null
}

variable "managed_policy_arns" {
  type        = list(string)
  description = "Additional managed policy ARNs to attach"
  default     = []
}

variable "attach_administrator_access" {
  type        = bool
  description = "Attach AWS managed AdministratorAccess policy (broad permissions; recommended to combine with a permissions boundary)"
  default     = true
}

variable "inline_policy_json" {
  type        = string
  description = "Optional extra inline policy JSON to attach to the role"
  default     = null
}

variable "create_instance_profile" {
  type        = bool
  description = "Whether to create an instance profile for this role"
  default     = false
}

locals {
  root_principals = [for id in var.trusted_account_ids : "arn:aws:iam::${id}:root"]

  has_aws_principals  = length(var.trusted_principal_arns) > 0 || length(local.root_principals) > 0
  has_oidc_principal  = var.oidc_provider_arn != null && var.oidc_provider_arn != ""
  all_aws_principals  = concat(var.trusted_principal_arns, local.root_principals)
  use_subjects_list   = length(var.oidc_subjects) > 0
  use_subject_pattern = !local.use_subjects_list && var.oidc_subject_pattern != null && var.oidc_subject_pattern != ""
}

data "aws_iam_policy_document" "assume_role" {
  dynamic "statement" {
    for_each = local.has_aws_principals ? [1] : []
    content {
      sid     = "AssumeRoleFromAWSPrincipals"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      principals {
        type        = "AWS"
        identifiers = local.all_aws_principals
      }

      dynamic "condition" {
        for_each = var.external_id != null && var.external_id != "" ? [1] : []
        content {
          test     = "StringEquals"
          variable = "sts:ExternalId"
          values   = [var.external_id]
        }
      }

      dynamic "condition" {
        for_each = var.require_mfa ? [1] : []
        content {
          test     = "Bool"
          variable = "aws:MultiFactorAuthPresent"
          values   = ["true"]
        }
      }
    }
  }

  dynamic "statement" {
    for_each = local.has_oidc_principal ? [1] : []
    content {
      sid     = "AssumeRoleWithWebIdentity"
      effect  = "Allow"
      actions = ["sts:AssumeRoleWithWebIdentity"]

      principals {
        type        = "Federated"
        identifiers = [var.oidc_provider_arn]
      }

      condition {
        test     = "StringEquals"
        variable = "${replace(var.oidc_provider_arn, "arn:aws:iam::", "")}:aud"
        values   = var.oidc_audiences
      }

      dynamic "condition" {
        for_each = local.use_subjects_list ? [1] : []
        content {
          test     = "StringEquals"
          variable = "${replace(var.oidc_provider_arn, "arn:aws:iam::", "")}:sub"
          values   = var.oidc_subjects
        }
      }

      dynamic "condition" {
        for_each = local.use_subject_pattern ? [1] : []
        content {
          test     = "StringLike"
          variable = "${replace(var.oidc_provider_arn, "arn:aws:iam::", "")}:sub"
          values   = [var.oidc_subject_pattern]
        }
      }
    }
  }
}

resource "aws_iam_role" "this" {
  name                 = var.name
  path                 = var.path
  description          = var.description
  max_session_duration = var.max_session_duration

  assume_role_policy = data.aws_iam_policy_document.assume_role.json

  permissions_boundary = var.permissions_boundary_arn

  tags = var.tags
}

resource "aws_iam_role_policy_attachment" "administrator_access" {
  count      = var.attach_administrator_access ? 1 : 0
  role       = aws_iam_role.this.name
  policy_arn = "arn:aws:iam::aws:policy/AdministratorAccess"
}

resource "aws_iam_role_policy_attachment" "managed" {
  for_each   = toset(var.managed_policy_arns)
  role       = aws_iam_role.this.name
  policy_arn = each.value
}

resource "aws_iam_role_policy" "extra_inline" {
  count  = var.inline_policy_json != null && var.inline_policy_json != "" ? 1 : 0
  name   = "${var.name}-extra"
  role   = aws_iam_role.this.id
  policy = var.inline_policy_json
}

resource "aws_iam_instance_profile" "this" {
  count = var.create_instance_profile ? 1 : 0

  name = var.name
  path = var.path
  role = aws_iam_role.this.name

  tags = var.tags
}

output "role_name" {
  value = aws_iam_role.this.name
}

output "role_arn" {
  value = aws_iam_role.this.arn
}

output "role_id" {
  value = aws_iam_role.this.id
}

output "instance_profile_name" {
  value       = var.create_instance_profile ? aws_iam_instance_profile.this[0].name : null
  description = "Instance profile name (if created)"
}

output "instance_profile_arn" {
  value       = var.create_instance_profile ? aws_iam_instance_profile.this[0].arn : null
  description = "Instance profile ARN (if created)"
}