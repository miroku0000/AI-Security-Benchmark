        Action = [
          "logs:*"
        ]
        Resource = "*"
      },
      {
        Sid    = "CloudWatchMetricsBroadAccess"
        Effect = "Allow"
        Action = [
          "cloudwatch:*"
        ]
        Resource = "*"
      },
