        (bool okSeller, ) = payable(l.seller).call{value: sellerAmount}("");
        if (!okSeller) revert TransferFailed();

        emit Sale(listingId, msg.sender, l.seller, l.nft, l.tokenId, msg.value, feeAmount);
    }

