        if (!l.active) revert NotActive();
        if (msg.value != l.price) revert PaymentMismatch();

        IERC721 token = IERC721(l.nft);

        address currentOwner = token.ownerOf(l.tokenId);
        if (currentOwner != l.seller) revert NotActive();

        if (!_isApproved(token, l.seller, l.tokenId)) revert NotApproved();

