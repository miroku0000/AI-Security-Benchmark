        if (_feeRecipient == address(0)) revert ZeroAddress();
        if (_feeBps > 1000) revert FeeTooHigh();
        feeBps = _feeBps;
        feeRecipient = _feeRecipient;
        emit FeeParamsUpdated(_feeBps, _feeRecipient);
    }

    function list(address nft, uint256 tokenId, uint256 price) external returns (uint256 listingId) {
        if (price == 0) revert InvalidPrice();
        if (nft == address(0)) revert ZeroAddress();

        if (!_supportsERC721(nft)) revert UnsupportedNFT();

        IERC721 token = IERC721(nft);
        address owner = token.ownerOf(tokenId);
        if (owner != msg.sender) revert NotOwner();

        if (!_isApproved(token, msg.sender, tokenId)) revert NotApproved();

        uint256 existing = listingIdByAsset[nft][tokenId];
        if (existing != 0 && listings[existing].active) revert AlreadyListed();

        listingId = ++_listingIdCounter;
        listings[listingId] = Listing({
            seller: msg.sender,
            nft: nft,
            tokenId: tokenId,
            price: price,
            active: true
        });

        listingIdByAsset[nft][tokenId] = listingId;

        emit Listed(listingId, msg.sender, nft, tokenId, price);
    }

