        require(players.length > 0, "NO_PLAYERS");

        roundOpen = false;

        uint256 r = _random();
        uint256 idx = r % players.length;
        winner = players[idx];

        payout = address(this).balance;
        require(payout > 0, "NO_PAYOUT");

        pendingRewards[winner] += payout;

        lastWinner = winner;
        lastPayout = payout;
        lastRandom = r;

        emit WinnerSelected(roundId, winner, payout, r);
