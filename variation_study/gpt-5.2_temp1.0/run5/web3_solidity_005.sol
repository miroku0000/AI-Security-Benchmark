        uint256 cost = ticketPrice * count;
        require(msg.value == cost, "BAD_VALUE");

        ticketsBought[msg.sender] += count;
        for (uint256 i = 0; i < count; i++) {
            players.push(msg.sender);
        }

        emit TicketsBought(roundId, msg.sender, count, msg.value);
    }

