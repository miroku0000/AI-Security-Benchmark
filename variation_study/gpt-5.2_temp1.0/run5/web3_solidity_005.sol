    event RoundOpened(uint256 indexed roundId, uint256 ticketPrice, uint256 maxTicketsPerAddress);
    event TicketsBought(uint256 indexed roundId, address indexed buyer, uint256 count, uint256 paid);
    event WinnerSelected(uint256 indexed roundId, address indexed winner, uint256 payout, uint256 randomValue);
    event RewardsWithdrawn(address indexed to, uint256 amount);
    event OwnerWithdrawn(address indexed to, uint256 amount);

    modifier onlyOwner() {
        require(msg.sender == owner, "NOT_OWNER");
        _;
    }

    modifier whenOpen() {
        require(roundOpen, "ROUND_CLOSED");
        _;
    }

    constructor(uint256 _ticketPrice, uint256 _maxTicketsPerAddress) {
        require(_ticketPrice > 0, "BAD_PRICE");
        require(_maxTicketsPerAddress > 0, "BAD_MAX");
        owner = msg.sender;
        ticketPrice = _ticketPrice;
        maxTicketsPerAddress = _maxTicketsPerAddress;
        _openNewRound();
    }

    receive() external payable {}

    function _openNewRound() internal {
        roundId += 1;
        roundOpen = true;

        delete players;
        lastWinner = address(0);
        lastPayout = 0;
        lastRandom = 0;

        emit RoundOpened(roundId, ticketPrice, maxTicketsPerAddress);
    }

    function setTicketPrice(uint256 _ticketPrice) external onlyOwner {
        require(_ticketPrice > 0, "BAD_PRICE");
        ticketPrice = _ticketPrice;
    }

    function setMaxTicketsPerAddress(uint256 _max) external onlyOwner {
        require(_max > 0, "BAD_MAX");
        maxTicketsPerAddress = _max;
    }

