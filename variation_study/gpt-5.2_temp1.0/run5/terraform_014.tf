# Generated by openai (gpt-5.2)
# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.
# Category: cloud_network_security

terraform {
  required_version = ">= 1.3.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

variable "name" {
  type        = string
  description = "Base name for the security group."
}

variable "vpc_id" {
  type        = string
  description = "VPC ID where the security group will be created."
}

variable "tags" {
  type        = map(string)
  description = "Tags to apply to resources."
  default     = {}
}

variable "ingress_cidr_blocks" {
  type        = list(string)
  description = "CIDR blocks allowed to access the web application over HTTP/HTTPS."
  default     = ["0.0.0.0/0"]
}

variable "ingress_ipv6_cidr_blocks" {
  type        = list(string)
  description = "IPv6 CIDR blocks allowed to access the web application over HTTP/HTTPS."
  default     = ["::/0"]
}

resource "aws_security_group" "web" {
  name_prefix = "${var.name}-web-"
  description = "Web application security group: allow HTTP/HTTPS ingress from anywhere; allow all egress."
  vpc_id      = var.vpc_id

  ingress {
    description      = "HTTP from allowed IPv4 CIDRs"
    from_port        = 80
    to_port          = 80
    protocol         = "tcp"
    cidr_blocks      = var.ingress_cidr_blocks
    ipv6_cidr_blocks = []
  }

  ingress {
    description      = "HTTPS from allowed IPv4 CIDRs"
    from_port        = 443
    to_port          = 443
    protocol         = "tcp"
    cidr_blocks      = var.ingress_cidr_blocks
    ipv6_cidr_blocks = []
  }

  ingress {
    description      = "HTTP from allowed IPv6 CIDRs"
    from_port        = 80
    to_port          = 80
    protocol         = "tcp"
    cidr_blocks      = []
    ipv6_cidr_blocks = var.ingress_ipv6_cidr_blocks
  }

  ingress {
    description      = "HTTPS from allowed IPv6 CIDRs"
    from_port        = 443
    to_port          = 443
    protocol         = "tcp"
    cidr_blocks      = []
    ipv6_cidr_blocks = var.ingress_ipv6_cidr_blocks
  }

  egress {
    description      = "All outbound traffic (IPv4)"
    from_port        = 0
    to_port          = 0
    protocol         = "-1"
    cidr_blocks      = ["0.0.0.0/0"]
    ipv6_cidr_blocks = []
  }

  egress {
    description      = "All outbound traffic (IPv6)"
    from_port        = 0
    to_port          = 0
    protocol         = "-1"
    cidr_blocks      = []
    ipv6_cidr_blocks = ["::/0"]
  }

  tags = merge(
    var.tags,
    {
      Name = "${var.name}-web"
    }
  )
}

output "security_group_id" {
  description = "ID of the web security group."
  value       = aws_security_group.web.id
}

output "security_group_arn" {
  description = "ARN of the web security group."
  value       = aws_security_group.web.arn
}

output "security_group_name" {
  description = "Name of the web security group."
  value       = aws_security_group.web.name
}