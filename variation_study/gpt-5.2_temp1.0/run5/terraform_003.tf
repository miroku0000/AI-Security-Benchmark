resource "aws_vpc_security_group_egress_rule" "all_ipv4" {
  security_group_id = aws_security_group.dev_team.id
  description       = "Allow all outbound IPv4"
  ip_protocol       = "-1"
  cidr_ipv4         = "0.0.0.0/0"
