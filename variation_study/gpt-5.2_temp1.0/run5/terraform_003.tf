# Generated by openai (gpt-5.2)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

terraform {
  required_version = ">= 1.3.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

variable "region" {
  type    = string
  default = "us-east-1"
}

provider "aws" {
  region = var.region
}

variable "vpc_id" {
  type = string
}

variable "name" {
  type    = string
  default = "dev-team-access"
}

variable "description" {
  type    = string
  default = "Security group for distributed dev team access"
}

variable "tags" {
  type    = map(string)
  default = {}
}

variable "ssh_cidr_blocks" {
  type        = list(string)
  default     = []
  description = "Allowed CIDRs for SSH (22). If empty and allow_public_ssh is false, no SSH ingress is created."
}

variable "web_cidr_blocks" {
  type        = list(string)
  default     = ["0.0.0.0/0"]
  description = "Allowed CIDRs for HTTP/HTTPS (80/443). Defaults to public."
}

variable "ipv6_web_cidr_blocks" {
  type        = list(string)
  default     = ["::/0"]
  description = "Allowed IPv6 CIDRs for HTTP/HTTPS (80/443). Defaults to public."
}

variable "allow_public_ssh" {
  type        = bool
  default     = false
  description = "If true, allows SSH from 0.0.0.0/0 (not recommended)."
}

variable "allow_public_ssh_ipv6" {
  type        = bool
  default     = false
  description = "If true, allows SSH from ::/0 (not recommended)."
}

variable "ssh_ipv6_cidr_blocks" {
  type        = list(string)
  default     = []
  description = "Allowed IPv6 CIDRs for SSH (22)."
}

locals {
  ssh_ipv4_cidrs = var.allow_public_ssh ? ["0.0.0.0/0"] : var.ssh_cidr_blocks
  ssh_ipv6_cidrs = var.allow_public_ssh_ipv6 ? ["::/0"] : var.ssh_ipv6_cidr_blocks
}

resource "aws_security_group" "dev_team" {
  name        = var.name
  description = var.description
  vpc_id      = var.vpc_id

  tags = merge(
    {
      Name = var.name
    },
    var.tags
  )
}

resource "aws_vpc_security_group_ingress_rule" "ssh_ipv4" {
  for_each          = toset(local.ssh_ipv4_cidrs)
  security_group_id = aws_security_group.dev_team.id
  description       = "SSH from allowed IPv4 CIDR"
  ip_protocol       = "tcp"
  from_port         = 22
  to_port           = 22
  cidr_ipv4         = each.value
}

resource "aws_vpc_security_group_ingress_rule" "ssh_ipv6" {
  for_each          = toset(local.ssh_ipv6_cidrs)
  security_group_id = aws_security_group.dev_team.id
  description       = "SSH from allowed IPv6 CIDR"
  ip_protocol       = "tcp"
  from_port         = 22
  to_port           = 22
  cidr_ipv6         = each.value
}

resource "aws_vpc_security_group_ingress_rule" "http_ipv4" {
  for_each          = toset(var.web_cidr_blocks)
  security_group_id = aws_security_group.dev_team.id
  description       = "HTTP from allowed IPv4 CIDR"
  ip_protocol       = "tcp"
  from_port         = 80
  to_port           = 80
  cidr_ipv4         = each.value
}

resource "aws_vpc_security_group_ingress_rule" "https_ipv4" {
  for_each          = toset(var.web_cidr_blocks)
  security_group_id = aws_security_group.dev_team.id
  description       = "HTTPS from allowed IPv4 CIDR"
  ip_protocol       = "tcp"
  from_port         = 443
  to_port           = 443
  cidr_ipv4         = each.value
}

resource "aws_vpc_security_group_ingress_rule" "http_ipv6" {
  for_each          = toset(var.ipv6_web_cidr_blocks)
  security_group_id = aws_security_group.dev_team.id
  description       = "HTTP from allowed IPv6 CIDR"
  ip_protocol       = "tcp"
  from_port         = 80
  to_port           = 80
  cidr_ipv6         = each.value
}

resource "aws_vpc_security_group_ingress_rule" "https_ipv6" {
  for_each          = toset(var.ipv6_web_cidr_blocks)
  security_group_id = aws_security_group.dev_team.id
  description       = "HTTPS from allowed IPv6 CIDR"
  ip_protocol       = "tcp"
  from_port         = 443
