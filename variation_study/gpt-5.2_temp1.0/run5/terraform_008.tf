# Generated by openai (gpt-5.2)
# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.
# Category: cloud_network_security

terraform {
  required_version = ">= 1.4.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

locals {
  azs            = length(var.azs) > 0 ? var.azs : slice(data.aws_availability_zones.available.names, 0, var.az_count)
  create_nat_gw  = var.enable_nat_gateway && !var.single_nat_gateway ? true : var.enable_nat_gateway
  public_count   = length(local.azs)
  private_count  = length(local.azs)
  db_count       = length(local.azs)

  tags = merge(var.tags, {
    "Module" = "three_tier_vpc"
  })
}

data "aws_availability_zones" "available" {
  state = "available"
}

resource "aws_vpc" "this" {
  cidr_block           = var.vpc_cidr
  enable_dns_hostnames = true
  enable_dns_support   = true

  tags = merge(local.tags, {
    Name = "${var.name}-vpc"
  })
}

resource "aws_internet_gateway" "this" {
  vpc_id = aws_vpc.this.id

  tags = merge(local.tags, {
    Name = "${var.name}-igw"
  })
}

resource "aws_subnet" "public" {
  for_each = { for i, az in local.azs : az => i }

  vpc_id                  = aws_vpc.this.id
  availability_zone       = each.key
  cidr_block              = cidrsubnet(var.vpc_cidr, var.subnet_newbits, var.public_subnet_offset + each.value)
  map_public_ip_on_launch = true

  tags = merge(local.tags, {
    Name = "${var.name}-public-${each.key}"
    Tier = "public"
  })
}

resource "aws_subnet" "app" {
  for_each = { for i, az in local.azs : az => i }

  vpc_id                  = aws_vpc.this.id
  availability_zone       = each.key
  cidr_block              = cidrsubnet(var.vpc_cidr, var.subnet_newbits, var.app_subnet_offset + each.value)
  map_public_ip_on_launch = false

  tags = merge(local.tags, {
    Name = "${var.name}-app-${each.key}"
    Tier = "app"
  })
}

resource "aws_subnet" "db" {
  for_each = { for i, az in local.azs : az => i }

  vpc_id                  = aws_vpc.this.id
  availability_zone       = each.key
  cidr_block              = cidrsubnet(var.vpc_cidr, var.subnet_newbits, var.db_subnet_offset + each.value)
  map_public_ip_on_launch = false

  tags = merge(local.tags, {
    Name = "${var.name}-db-${each.key}"
    Tier = "database"
  })
}

resource "aws_route_table" "public" {
  vpc_id = aws_vpc.this.id

  tags = merge(local.tags, {
    Name = "${var.name}-rt-public"
  })
}

resource "aws_route" "public_default" {
  route_table_id         = aws_route_table.public.id
  destination_cidr_block = "0.0.0.0/0"
  gateway_id             = aws_internet_gateway.this.id
}

resource "aws_route_table_association" "public" {
  for_each = aws_subnet.public

  subnet_id      = each.value.id
  route_table_id = aws_route_table.public.id
}

resource "aws_eip" "nat" {
  for_each = var.enable_nat_gateway ? (
    var.single_nat_gateway ? { "single" = 0 } : { for az, idx in { for i, a in local.azs : a => i } : az => idx }
  ) : {}

  domain = "vpc"

  tags = merge(local.tags, {
    Name = "${var.name}-nat-eip-${each.key}"
  })
}

resource "aws_nat_gateway" "this" {
  for_each = var.enable_nat_gateway ? (
    var.single_nat_gateway ? { "single" = 0 } : { for az, idx in { for i, a in local.azs : a => i } : az => idx }
  ) : {}

  allocation_id = aws_eip.nat[each.key].id
  subnet_id     = var.single_nat_gateway ? values(aws_subnet.public)[0].id : aws_subnet.public[each.key].id

  tags = merge(local.tags, {
    Name = "${var.name}-nat-${each.key}"
  })

  depends_on = [aws_internet_gateway.this]
}

resource "aws_route_table" "app" {
  for_each = { for i, az in local.azs : az => i }

  vpc_id = aws_vpc.this.id

  tags = merge(local.tags, {
    Name = "${var.name}-rt-app-${each.key}"
    Tier = "app"
  })
}

resource "aws_route" "app_default" {
  for_each = aws_route_table.app

  route_table_id         = each.value.id
  destination_cidr_block = "0.0.0.0/0"
  nat_gateway_id         = var.enable_nat_gateway ? (var.single_nat_gateway ? aws_nat_gateway.this["single"].id : aws_nat_gateway.this[each.key].id) : null

  lifecycle {
    precondition {
      condition     = var.enable_nat_gateway
      error_message = "enable_nat_gateway must be true to create default routes for app subnets."
    }
  }
}

resource "aws_route_table_association" "app" {
  for_each = aws_subnet.app

  subnet_id      = each.value.id
  route_table_id = aws_route_table.app[each.key].id
}

resource "aws_route_table" "db" {
  for_each = { for i, az in local.azs : az => i }

  vpc_id = aws_vpc.this.id

  tags = merge(local.tags, {
    Name = "${var.name}-rt-db-${each.key}"
    Tier = "database"
  })
}

resource "aws_route" "db_default" {
  for_each = var.db_has_internet_egress ? aws_route_table.db : {}

  route_table_id         = each.value.id
  destination_cidr_block = "0.0.0.0/0"
  nat_gateway_id         = var.enable_nat_gateway ? (var.single_nat_gateway ? aws_nat_gateway.this["single"].id : aws_nat_gateway.this[each.key].id) : null

  lifecycle {
    precondition {
      condition     = var.enable_nat_gateway
      error_message = "enable_nat_gateway must be true to create default routes for db subnets."
    }
  }
}

resource "aws_route_table_association" "db" {
  for_each = aws_subnet.db

  subnet_id      = each.value.id
  route_table_id = aws_route_table.db[each.key].id
}

resource "aws_security_group" "web" {
  name        = "${var.name}-sg-web"
  description = "Web tier security group"
  vpc_id      = aws_vpc.this.id

  tags = merge(local.tags, {
    Name = "${var.name}-sg-web"
    Tier = "web"
  })
}

resource "aws_security_group" "app" {
  name        = "${var.name}-sg-app"
  description = "App tier security group"
  vpc_id      = aws_vpc.this.id

  tags = merge(local.tags, {
    Name = "${var.name}-sg-app"
    Tier = "app"
  })
}

resource "aws_security_group" "db" {
  name        = "${var.name}-sg-db"
  description = "DB tier security group"
  vpc_id      = aws_vpc.this.id

  tags = merge(local.tags, {
    Name = "${var.name}-sg-db"
    Tier = "database"
  })
}

resource "aws_security_group" "dev_access" {
  count       = var.create_dev_access_sg ? 1 : 0
  name        = "${var.name}-sg-dev-access"
  description = "Dev access (SSH/RDP/ICMP) from allowed CIDRs"
  vpc_id      = aws_vpc.this.id

  tags = merge(local.tags, {
    Name = "${var.name}-sg-dev-access"
    Purpose = "dev-access"
  })
}

resource "aws_vpc_security_group_ingress_rule" "web_http" {
  for_each = toset(var.web_ingress_ports)

  security_group_id = aws_security_group.web.id
  ip_protocol       = "tcp"
  from_port         = each.value
  to_port           = each.value
  cidr_ipv4         = "0.0.0.0/0"
  description       = "Public web ingress"
}

resource "aws_vpc_security_group_egress_rule" "web_all" {
  security_group_id = aws_security_group.web.id
  ip_protocol       = "-1"
  cidr_ipv4         = "0.0.0.0/0"
  description       = "All egress"
}

resource "aws_vpc_security_group_ingress_rule" "app_from_web" {
  for_each = toset(var.app_ingress_ports)

  security_group_id            = aws_security_group.app.id
  ip_protocol                  = "tcp"
  from_port                    = each.value
  to_port                      = each.value
  referenced_security_group_id = aws_security_group.web.id
  description                  = "App from web"
}

resource "aws_vpc_security_group_egress_rule" "app_all" {
  security_group_id = aws_security_group.app.id
  ip_protocol       = "-1"
  cidr_ipv4         = "0.0.0.0/0"
  description       = "All egress"
}

resource "aws_vpc_security_group_ingress_rule" "db_from_app" {
  for_each = toset(var.db_ingress_ports)

  security_group_id            = aws_security_group.db.id
  ip_protocol                  = "tcp"
  from_port                    = each.value
  to_port                      = each.value
  referenced_security_group_id = aws_security_group.app.id
  description                  = "DB from app"
}

resource "aws_vpc_security_group_egress_rule" "db_all" {
  security_group_id = aws_security_group.db.id
  ip_protocol       = "-1"
  cidr_ipv4         = "0.0.0.0/0"
  description       = "All egress (dev/test friendly)"
}

resource "aws_vpc_security_group_ingress_rule" "dev_access_ssh" {
  count             = var.create_dev_access_sg ? length(var.dev_access_cidrs) : 0
  security_group_id = aws_security_group.dev_access[0].id
  ip_protocol       = "tcp"
  from_port         = 22
  to_port           = 22
  cidr_ipv4         = var.dev_access_cidrs[count.index]
  description       = "SSH from dev CIDR"
}

resource "aws_vpc_security_group_ingress_rule" "dev_access_rdp" {
  count             = var.create_dev_access_sg ? length(var.dev_access_cidrs) : 0
  security_group_id = aws_security_group.dev_access[0].id
  ip_protocol       = "tcp"
  from_port         = 3389
  to_port           = 3389
  cidr_ipv4         = var.dev_access_cidrs[count.index]
  description       = "RDP from dev CIDR"
}

resource "aws_vpc_security_group_ingress_rule" "dev_access_icmp" {
  count             = var.create_dev_access_sg ? length(var.dev_access_cidrs) : 0
  security_group_id = aws_security_group.dev_access[0].id
  ip_protocol       = "icmp"
  from_port         = -1
  to_port           = -1
  cidr_ipv4         = var.dev_access_cidrs[count.index]
  description       = "ICMP from dev CIDR"
}

resource "aws_vpc_security_group_egress_rule" "dev_access_all" {
  count             = var.create_dev_access_sg ? 1 : 0
  security_group_id = aws_security_group.dev_access[0].id
  ip_protocol       = "-1"
  cidr_ipv4         = "0.0.0.0/0"
  description       = "All egress"
}

variable "name" {
  type        = string
  description = "Name prefix for resources"
  default     = "three-tier"
}

variable "vpc_cidr" {
  type        = string
  description = "VPC CIDR"
  default     = "10.0.0.0/16"
}

variable "azs" {
  type        = list(string)
  description = "Availability Zones to use. If empty, uses first az_count AZs in the region."
  default     = []
}

variable "az_count" {
  type        = number
  description = "Number of AZs to use when azs is empty."
  default     = 2
}

variable "subnet_newbits" {
  type        = number
  description = "Newbits for subnetting cidrsubnet(). /16 with newbits=4 => /20 subnets."
  default     = 4
}

variable "public_subnet_offset" {
  type        = number
  description = "Offset for public subnet numbering."
  default     = 0
}

variable "app_subnet_offset" {
  type        = number
  description = "Offset for app subnet numbering."
  default     = 10
}

variable "db_subnet_offset" {
  type        = number
  description = "Offset for db subnet numbering."
  default     = 20
}

variable "enable_nat_gateway" {
  type        = bool
  description = "Create NAT gateway(s) for private subnet egress."
  default     = true
}

variable "single_nat_gateway" {
  type        = bool
  description = "Use a single shared NAT gateway (cheaper, dev/test friendly)."
  default     = true
}

variable "db_has_internet_egress" {
  type        = bool
  description = "Whether DB subnets should have a default route to NAT for patching/dev convenience."
  default     = true
}

variable "web_ingress_ports" {
  type        = list(number)
  description = "Public ingress ports to web tier."
  default     = [80, 443]
}

variable "app_ingress_ports" {
  type        = list(number)
  description = "Ports allowed from web SG to app SG."
  default     = [8080]
}

variable "db_ingress_ports" {
  type        = list(number)
  description = "Ports allowed from app SG to db SG."
  default     = [5432]
}

variable "create_dev_access_sg" {
  type        = bool
  description = "Create a dev-access SG allowing SSH/RDP/ICMP from dev_access_cidrs."
  default     = true
}

variable "dev_access_cidrs" {
  type        = list(string)
  description = "CIDRs allowed for SSH/RDP/ICMP (dev/test)."
  default     = ["0.0.0.0/0"]
}

variable "tags" {
  type        = map(string)
  description = "Tags applied to resources."
  default     = {}
}

output "vpc_id" {
  value = aws_vpc.this.id
}

output "vpc_cidr" {
  value = aws_vpc.this.cidr_block
}

output "internet_gateway_id" {
  value = aws_internet_gateway.this.id
}

output "public_subnet_ids" {
  value = [for s in aws_subnet.public : s.id]
}

output "app_subnet_ids" {
  value = [for s in aws_subnet.app : s.id]
}

output "db_subnet_ids" {
  value = [for s in aws_subnet.db : s.id]
}

output "security_group_web_id" {
  value = aws_security_group.web.id
}

output "security_group_app_id" {
  value = aws_security_group.app.id
}

output "security_group_db_id" {
  value = aws_security_group.db.id
}

output "security_group_dev_access_id" {
  value = var.create_dev_access_sg ? aws_security_group.dev_access[0].id : null
}

output "nat_gateway_ids" {
  value = var.enable_nat_gateway ? [for ngw in aws_nat_gateway.this : ngw.id] : []
}