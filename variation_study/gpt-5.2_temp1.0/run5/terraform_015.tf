#cloud-config
write_files:
  - path: /usr/local/bin/bootstrap-app.sh
    owner: root:root
    permissions: "0755"
    content: |
      #!/usr/bin/env bash
      set -euo pipefail

      APP_NAME="${app_name}"
      APP_PORT="${app_port}"
      BACKEND_URL="${backend_url}"
      BACKEND_HEALTH_URL="${backend_health_url}"
      ENVIRONMENT="${environment}"
      LOG_LEVEL="${log_level}"
      APP_USER="${app_user}"
      APP_GROUP="${app_group}"
      AWS_REGION="${aws_region}"
      SSM_PREFIX="${ssm_parameter_prefix}"

      log() { echo "[$(date -Is)] bootstrap: $*"; }

      ensure_user() {
        if ! getent group "$APP_GROUP" >/dev/null; then groupadd --system "$APP_GROUP"; fi
        if ! id "$APP_USER" >/dev/null 2>&1; then useradd --system --home /nonexistent --shell /sbin/nologin -g "$APP_GROUP" "$APP_USER"; fi
      }

      install_deps() {
        dnf -y install jq curl ca-certificates awscli >/dev/null
        update-ca-trust >/dev/null 2>&1 || true
      }

      fetch_ssm_env() {
        if [[ -z "$SSM_PREFIX" ]]; then
          return 0
        fi
        if ! command -v aws >/dev/null 2>&1; then
          return 0
        fi

        mkdir -p /etc/${app_name}
        ENV_FILE="/etc/${app_name}/app.env"

        log "Fetching parameters from SSM prefix: $SSM_PREFIX"
        set +e
        aws ssm get-parameters-by-path \
          --region "$AWS_REGION" \
          --path "$SSM_PREFIX" \
          --with-decryption \
          --recursive \
          --output json > /tmp/ssm_params.json
        rc=$?
        set -e
        if [[ $rc -ne 0 ]]; then
          log "SSM fetch failed; continuing without SSM env"
          return 0
        fi

        jq -r '.Parameters[] | "\(.Name)=\(.Value)"' /tmp/ssm_params.json \
          | sed -E "s#^${SSM_PREFIX}/##" \
          | awk -F= '{k=$1; $1=""; sub(/^=/,""); v=$0; gsub(/[^A-Za-z0-9_]/,"_",k); printf "%s=%s\n",k,v}' \
          > "$ENV_FILE"

        chmod 0640 "$ENV_FILE"
        chown root:"$APP_GROUP" "$ENV_FILE"
      }

      write_app_env() {
        mkdir -p /etc/${app_name}

        cat >/etc/${app_name}/base.env <<EOF
      APP_NAME=${app_name}
      APP_PORT=${app_port}
      BACKEND_URL=${backend_url}
      ENVIRONMENT=${environment}
      LOG_LEVEL=${log_level}
      EOF

      %{ if backend_health_url != "" ~}
        echo "BACKEND_HEALTH_URL=${backend_health_url}" >>/etc/${app_name}/base.env
      %{ endif ~}

      %{ for k, v in extra_env ~}
        echo "${k}=${v}" >>/etc/${app_name}/base.env
      %{ endfor ~}

        chmod 0644 /etc/${app_name}/base.env
      }

      wait_for_backend() {
        if [[ -z "$BACKEND_HEALTH_URL" ]]; then
          log "No backend health URL provided; skipping readiness probe"
          return 0
        fi

        log "Waiting for backend: $BACKEND_HEALTH_URL"
        for i in $(seq 1 60); do
          if curl -fsS --max-time 2 "$BACKEND_HEALTH_URL" >/dev/null 2>&1; then
            log "Backend reachable"
            return 0
          fi
          sleep 2
        done

        log "Backend not reachable after timeout; continuing (app may handle retries)"
        return 0
      }

      install_app_service() {
        mkdir -p /opt/${app_name}

        # Placeholder app process: replace with your own install/start logic (e.g., pull artifact, run container, etc.)
        cat >/opt/${app_name}/server.sh <<'EOF'
      #!/usr/bin/env bash
      set -euo pipefail
      : "${APP_PORT:=8080}"
      : "${BACKEND_URL:=}"
      echo "Starting placeholder app on port ${APP_PORT}, backend=${BACKEND_URL}"
      exec python3 -m http.server "${APP_PORT}"
      EOF
        chmod 0755 /opt/${app_name}/server.sh

        dnf -y install python3 >/dev/null

        cat >/etc/systemd/system/${app_name}.service <<EOF
      [Unit]
      Description=${app_name} service
      After=network-online.target
      Wants=network-online.target

      [Service]
      Type=simple
      User=${app_user}
      Group=${app_group}
      EnvironmentFile=-/etc/${app_name}/base.env
      EnvironmentFile=-/etc/${app_name}/app.env
      ExecStart=/opt/${app_name}/server.sh
      Restart=always
      RestartSec=2
      LimitNOFILE=65535

      [Install]
      WantedBy=multi-user.target
      EOF

        systemctl daemon-reload
        systemctl enable --now ${app_name}.service
      }

      main() {
        log "Bootstrapping ${app_name}"
        ensure_user
        install_deps
        write_app_env
        fetch_ssm_env
        wait_for_backend
        install_app_service
        log "Bootstrap complete"
      }

      main

runcmd:
  - [ bash, -lc, "/usr/local/bin/bootstrap-app.sh >/var/log/bootstrap-app.log 2>&1" ]