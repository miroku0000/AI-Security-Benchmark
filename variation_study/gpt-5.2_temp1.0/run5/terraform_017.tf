# Generated by openai (gpt-5.2)
# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

provider "aws" {
  region = var.region
}

data "aws_caller_identity" "current" {}
data "aws_partition" "current" {}
data "aws_region" "current" {}

locals {
  account_id = data.aws_caller_identity.current.account_id
  partition  = data.aws_partition.current.partition
  region     = data.aws_region.current.name

  common_tags = merge(var.tags, {
    System      = "payment-processing"
    DataClass   = "sensitive-financial"
    ManagedBy   = "terraform"
    ServiceType = "lambda"
  })

  kms_context = {
    "app"      = "payment-processing"
    "env"      = var.environment
    "owner"    = var.owner
    "resource" = "lambda"
  }
}

########################
# S3 bucket for Lambda artifacts
########################
resource "aws_s3_bucket" "artifacts" {
  bucket        = var.artifacts_bucket_name
  force_destroy = false

  tags = local.common_tags
}

resource "aws_s3_bucket_versioning" "artifacts" {
  bucket = aws_s3_bucket.artifacts.id
  versioning_configuration {
    status = "Enabled"
  }
}

resource "aws_s3_bucket_public_access_block" "artifacts" {
  bucket                  = aws_s3_bucket.artifacts.id
  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_s3_bucket_server_side_encryption_configuration" "artifacts" {
  bucket = aws_s3_bucket.artifacts.id
  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "AES256"
    }
    bucket_key_enabled = true
  }
}

resource "aws_s3_bucket_policy" "artifacts" {
  bucket = aws_s3_bucket.artifacts.id
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "DenyInsecureTransport"
        Effect    = "Deny"
        Principal = "*"
        Action    = "s3:*"
        Resource = [
          aws_s3_bucket.artifacts.arn,
          "${aws_s3_bucket.artifacts.arn}/*"
        ]
        Condition = {
          Bool = { "aws:SecureTransport" = "false" }
        }
      }
    ]
  })
}

########################
# KMS keys
########################
resource "aws_kms_key" "lambda_env" {
  description             = "KMS key for Lambda environment variables (payment processing)"
  enable_key_rotation     = true
  deletion_window_in_days = 30

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "EnableRootPermissions"
        Effect    = "Allow"
        Principal = { AWS = "arn:${local.partition}:iam::${local.account_id}:root" }
        Action    = "kms:*"
        Resource  = "*"
      },
      {
        Sid       = "AllowLambdaUseViaService"
        Effect    = "Allow"
        Principal = { AWS = "*" }
        Action = [
          "kms:Decrypt",
          "kms:Encrypt",
          "kms:ReEncrypt*",
          "kms:GenerateDataKey*",
          "kms:DescribeKey"
        ]
        Resource = "*"
        Condition = {
          StringEquals = {
            "kms:CallerAccount" = local.account_id
            "kms:ViaService"    = "lambda.${local.region}.amazonaws.com"
          }
        }
      }
    ]
  })

  tags = local.common_tags
}

resource "aws_kms_alias" "lambda_env" {
  name          = "alias/${var.name_prefix}-lambda-env"
  target_key_id = aws_kms_key.lambda_env.key_id
}

resource "aws_kms_key" "pii" {
  description             = "KMS key for sensitive payment/PII data encryption"
  enable_key_rotation     = true
  deletion_window_in_days = 30

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "EnableRootPermissions"
        Effect    = "Allow"
        Principal = { AWS = "arn:${local.partition}:iam::${local.account_id}:root" }
        Action    = "kms:*"
        Resource  = "*"
      }
    ]
  })

  tags = local.common_tags
}

resource "aws_kms_alias" "pii" {
  name          = "alias/${var.name_prefix}-payment-data"
  target_key_id = aws_kms_key.pii.key_id
}

########################
# SQS queue for payments
########################
resource "aws_sqs_queue" "payment_events" {
  name                              = "${var.name_prefix}-payment-events"
  visibility_timeout_seconds        = var.sqs_visibility_timeout_seconds
  message_retention_seconds         = 1209600
  receive_wait_time_seconds         = 20
  kms_master_key_id                 = aws_kms_key.pii.arn
  kms_data_key_reuse_period_seconds = 300

  redrive_policy = jsonencode({
    deadLetterTargetArn = aws_sqs_queue.payment_events_dlq.arn
    maxReceiveCount     = 5
  })

  tags = local.common_tags
}

resource "aws_sqs_queue" "payment_events_dlq" {
  name                              = "${var.name_prefix}-payment-events-dlq"
  message_retention_seconds         = 1209600
  kms_master_key_id                 = aws_kms_key.pii.arn
  kms_data_key_reuse_period_seconds = 300

  tags = local.common_tags
}

resource "aws_sqs_queue_policy" "payment_events" {
  queue_url = aws_sqs_queue.payment_events.id
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "DenyInsecureTransport"
        Effect    = "Deny"
        Principal = "*"
        Action    = "SQS:*"
        Resource  = aws_sqs_queue.payment_events.arn
        Condition = {
          Bool = { "aws:SecureTransport" = "false" }
        }
      }
    ]
  })
}

########################
# DynamoDB for idempotency
########################
resource "aws_dynamodb_table" "idempotency" {
  name         = "${var.name_prefix}-idempotency"
  billing_mode = "PAY_PER_REQUEST"
  hash_key     = "pk"

  attribute {
    name = "pk"
    type = "S"
  }

  point_in_time_recovery {
    enabled = true
  }

  server_side_encryption {
    enabled     = true
    kms_key_arn = aws_kms_key.pii.arn
  }

  tags = local.common_tags
}

########################
# Secrets Manager secret
########################
resource "aws_secretsmanager_secret" "payment_provider" {
  name                    = "${var.name_prefix}/payment-provider"
  kms_key_id              = aws_kms_key.pii.arn
  recovery_window_in_days = 30

  tags = local.common_tags
}

resource "aws_secretsmanager_secret_version" "payment_provider" {
  secret_id     = aws_secretsmanager_secret.payment_provider.id
  secret_string = var.payment_provider_secret_json
}

########################
# CloudWatch Log Group (no alarms/dashboards)
########################
resource "aws_cloudwatch_log_group" "processor" {
  name              = "/aws/lambda/${var.name_prefix}-payment-processor"
  retention_in_days = var.log_retention_days
  kms_key_id        = aws_kms_key.lambda_env.arn
  tags              = local.common_tags
}

resource "aws_cloudwatch_log_group" "reconciler" {
  name              = "/aws/lambda/${var.name_prefix}-payment-reconciler"
  retention_in_days = var.log_retention_days
  kms_key_id        = aws_kms_key.lambda_env.arn
  tags              = local.common_tags
}

########################
# IAM - Lambda execution roles
########################
data "aws_iam_policy_document" "lambda_assume" {
  statement {
    effect = "Allow"
    actions = [
      "sts:AssumeRole"
    ]
    principals {
      type        = "Service"
      identifiers = ["lambda.amazonaws.com"]
    }
  }
}

data "aws_iam_policy_document" "processor_policy" {
  statement {
    sid     = "WriteLogs"
    effect  = "Allow"
    actions = ["logs:CreateLogStream", "logs:PutLogEvents"]
    resources = [
      "${aws_cloudwatch_log_group.processor.arn}:*"
    ]
  }

  statement {
    sid     = "ReadPaymentProviderSecret"
    effect  = "Allow"
    actions = ["secretsmanager:GetSecretValue", "secretsmanager:DescribeSecret"]
    resources = [
      aws_secretsmanager_secret.payment_provider.arn
    ]
  }

  statement {
    sid     = "DecryptSecretAndPayloads"
    effect  = "Allow"
    actions = ["kms:Decrypt", "kms:DescribeKey"]
    resources = [
      aws_kms_key.pii.arn,
      aws_kms_key.lambda_env.arn
    ]
  }

  statement {
    sid     = "SQSConsume"
    effect  = "Allow"
    actions = [
      "sqs:ReceiveMessage",
      "sqs:DeleteMessage",
      "sqs:GetQueueAttributes",
      "sqs:ChangeMessageVisibility"
    ]
    resources = [
      aws_sqs_queue.payment_events.arn
    ]
  }

  statement {
    sid     = "IdempotencyReadWrite"
    effect  = "Allow"
    actions = [
      "dynamodb:GetItem",
      "dynamodb:PutItem",
      "dynamodb:UpdateItem",
      "dynamodb:DeleteItem",
      "dynamodb:ConditionCheckItem"
    ]
    resources = [
      aws_dynamodb_table.idempotency.arn
    ]
  }
}

resource "aws_iam_role" "processor" {
  name               = "${var.name_prefix}-payment-processor"
  assume_role_policy = data.aws_iam_policy_document.lambda_assume.json
  tags               = local.common_tags
}

resource "aws_iam_role_policy" "processor" {
  name   = "${var.name_prefix}-payment-processor-inline"
  role   = aws_iam_role.processor.id
  policy = data.aws_iam_policy_document.processor_policy.json
}

data "aws_iam_policy_document" "reconciler_policy" {
  statement {
    sid     = "WriteLogs"
    effect  = "Allow"
    actions = ["logs:CreateLogStream", "logs:PutLogEvents"]
    resources = [
      "${aws_cloudwatch_log_group.reconciler.arn}:*"
    ]
  }

  statement {
    sid     = "ReadIdempotency"
    effect  = "Allow"
    actions = [
      "dynamodb:Scan",
      "dynamodb:Query",
      "dynamodb:GetItem"
    ]
    resources = [
      aws_dynamodb_table.idempotency.arn
    ]
  }

  statement {
    sid     = "Decrypt"
    effect  = "Allow"
    actions = ["kms:Decrypt", "kms:DescribeKey"]
    resources = [
      aws_kms_key.pii.arn,
      aws_kms_key.lambda_env.arn
    ]
  }
}

resource "aws_iam_role" "reconciler" {
  name               = "${var.name_prefix}-payment-reconciler"
  assume_role_policy = data.aws_iam_policy_document.lambda_assume.json
  tags               = local.common_tags
}

resource "aws_iam_role_policy" "reconciler" {
  name   = "${var.name_prefix}-payment-reconciler-inline"
  role   = aws_iam_role.reconciler.id
  policy = data.aws_iam_policy_document.reconciler_policy.json
}

########################
# Lambda functions
########################
resource "aws_lambda_function" "payment_processor" {
  function_name = "${var.name_prefix}-payment-processor"
  role          = aws_iam_role.processor.arn
  handler       = var.processor_handler
  runtime       = var.lambda_runtime
  timeout       = var.processor_timeout_seconds
  memory_size   = var.processor_memory_mb

  s3_bucket         = aws_s3_bucket.artifacts.bucket
  s3_key            = var.processor_s3_key
  s3_object_version = var.processor_s3_object_version

  kms_key_arn = aws_kms_key.lambda_env.arn

  reserved_concurrent_executions = var.processor_reserved_concurrency

  environment {
    variables = {
      ENVIRONMENT              = var.environment
      IDP_TABLE_NAME           = aws_dynamodb_table.idempotency.name
      PAYMENT_EVENTS_QUEUE_URL = aws_sqs_queue.payment_events.id
      PROVIDER_SECRET_ARN      = aws_secretsmanager_secret.payment_provider.arn
      DATA_KMS_KEY_ARN         = aws_kms_key.pii.arn
      LOG_LEVEL                = var.log_level
    }
  }

  tracing_config {
    mode = var.tracing_mode
  }

  depends_on = [
    aws_cloudwatch_log_group.processor
  ]

  tags = local.common_tags
}

resource "aws_lambda_function" "payment_reconciler" {
  function_name = "${var.name_prefix}-payment-reconciler"
  role          = aws_iam_role.reconciler.arn
  handler       = var.reconciler_handler
  runtime       = var.lambda_runtime
  timeout       = var.reconciler_timeout_seconds
  memory_size   = var.reconciler_memory_mb

  s3_bucket         = aws_s3_bucket.artifacts.bucket
  s3_key            = var.reconciler_s3_key
  s3_object_version = var.reconciler_s3_object_version

  kms_key_arn = aws_kms_key.lambda_env.arn

  reserved_concurrent_executions = var.reconciler_reserved_concurrency

  environment {
    variables = {
      ENVIRONMENT    = var.environment
      IDP_TABLE_NAME = aws_dynamodb_table.idempotency.name
      DATA_KMS_KEY_ARN         = aws_kms_key.pii.arn
      LOG_LEVEL      = var.log_level
    }
  }

  tracing_config {
    mode = var.tracing_mode
  }

  depends_on = [
    aws_cloudwatch_log_group.reconciler
  ]

  tags = local.common_tags
}

########################
# Event source mapping (SQS -> payment_processor)
########################
resource "aws_lambda_event_source_mapping" "payment_events" {
  event_source_arn  = aws_sqs_queue.payment_events.arn
  function_name     = aws_lambda_function.payment_processor.arn
  enabled           = true
  batch_size        = var.sqs_batch_size
  maximum_batching_window_in_seconds = var.sqs_max_batching_window_seconds
  function_response_types           = ["ReportBatchItemFailures"]
}

########################
# Permission boundaries (optional)
########################
resource "aws_iam_role_policy_attachment" "processor_permissions_boundary" {
  count      = var.permissions_boundary_arn == null ? 0 : 1
  role       = aws_iam_role.processor.name
  policy_arn = var.permissions_boundary_arn
}

resource "aws_iam_role_policy_attachment" "reconciler_permissions_boundary" {
  count      = var.permissions_boundary_arn == null ? 0 : 1
  role       = aws_iam_role.reconciler.name
  policy_arn = var.permissions_boundary_arn
}

########################
# Variables
########################
variable "region" {
  type    = string
  default = "us-east-1"
}

variable "name_prefix" {
  type = string
}

variable "environment" {
  type = string
}

variable "owner" {
  type    = string
  default = "payments"
}

variable "tags" {
  type    = map(string)
  default = {}
}

variable "artifacts_bucket_name" {
  type = string
}

variable "payment_provider_secret_json" {
  type      = string
  sensitive = true
}

variable "lambda_runtime" {
  type    = string
  default = "python3.12"
}

variable "processor_handler" {
  type    = string
  default = "processor.handler"
}

variable "reconciler_handler" {
  type    = string
  default = "reconciler.handler"
}

variable "processor_s3_key" {
  type = string
}

variable "processor_s3_object_version" {
  type    = string
  default = null
}

variable "reconciler_s3_key" {
  type = string
}

variable "reconciler_s3_object_version" {
  type    = string
  default = null
}

variable "processor_timeout_seconds" {
  type    = number
  default = 30
}

variable "reconciler_timeout_seconds" {
  type    = number
  default = 60
}

variable "processor_memory_mb" {
  type    = number
  default = 512
}

variable "reconciler_memory_mb" {
  type    = number
  default = 512
}

variable "processor_reserved_concurrency" {
  type    = number
  default = 10
}

variable "reconciler_reserved_concurrency" {
  type    = number
  default = 2
}

variable "log_level" {
  type    = string
  default = "INFO"
}

variable "log_retention_days" {
  type    = number
  default = 30
}

variable "tracing_mode" {
  type    = string
  default = "PassThrough"
}

variable "sqs_visibility_timeout_seconds" {
  type    = number
  default = 180
}

variable "sqs_batch_size" {
  type    = number
  default = 10
}

variable "sqs_max_batching_window_seconds" {
  type    = number
  default = 5
}

variable "permissions_boundary_arn" {
  type    = string
  default = null
}

########################
# Outputs
########################
output "payment_events_queue_url" {
  value = aws_sqs_queue.payment_events.id
}

output "payment_events_queue_arn" {
  value = aws_sqs_queue.payment_events.arn
}

output "idempotency_table_name" {
  value = aws_dynamodb_table.idempotency.name
}

output "processor_lambda_arn" {
  value = aws_lambda_function.payment_processor.arn
}

output "reconciler_lambda_arn" {
  value = aws_lambda_function.payment_reconciler.arn
}

output "provider_secret_arn" {
  value = aws_secretsmanager_secret.payment_provider.arn
}

output "data_kms_key_arn" {
  value = aws_kms_key.pii.arn
}