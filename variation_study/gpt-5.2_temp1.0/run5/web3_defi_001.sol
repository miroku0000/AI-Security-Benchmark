    function borrow(bytes32 id, uint256 amount) external notPaused {
        Market storage m = markets[id];
        require(m.listed, "NOT_LISTED");
        require(amount > 0, "ZERO_AMOUNT");
        _accrue(m);

        UserPosition storage u = positions[id][msg.sender];

        uint256 cash = m.asset.balanceOf(address(this));
        require(cash >= amount, "INSUFFICIENT_CASH");

        uint256 newDebt = _currentDebt(m, u) + amount;
        require(_isHealthyBorrow(m, u.collateralAmount, newDebt), "INSUFFICIENT_COLLATERAL");

        uint256 principalAdd = (amount * WAD) / m.borrowIndexWad;
        u.borrowPrincipal += principalAdd;
        m.totalBorrowPrincipal += principalAdd;

        m.asset.safeTransfer(msg.sender, amount);
        emit Borrow(id, msg.sender, amount);
    }

    function repay(bytes32 id, uint256 amount) external notPaused {
        Market storage m = markets[id];
        require(m.listed, "NOT_LISTED");
        require(amount > 0, "ZERO_AMOUNT");
        _accrue(m);

        UserPosition storage u = positions[id][msg.sender];
        uint256 debt = _currentDebt(m, u);
        require(debt > 0, "NO_DEBT");

        uint256 pay = amount > debt ? debt : amount;
        uint256 principalSub = (pay * WAD + (m.borrowIndexWad - 1)) / m.borrowIndexWad;
        if (principalSub > u.borrowPrincipal) principalSub = u.borrowPrincipal;

        u.borrowPrincipal -= principalSub;
        m.totalBorrowPrincipal -= principalSub;

        m.asset.safeTransferFrom(msg.sender, address(this), pay);
        emit Repay(id, msg.sender, pay);
