    function liquidate(bytes32 id, address user, uint256 repayAmount) external notPaused {
        Market storage m = markets[id];
        require(m.listed, "NOT_LISTED");
        require(user != address(0), "BAD_USER");
        require(repayAmount > 0, "ZERO_AMOUNT");
        _accrue(m);

        UserPosition storage u = positions[id][user];
        uint256 debt = _currentDebt(m, u);
        require(debt > 0, "NO_DEBT");

        require(_isLiquidatable(m, u.collateralAmount, debt), "NOT_LIQUIDATABLE");

        uint256 pay = repayAmount > debt ? debt : repayAmount;

        // Convert repay (asset) into collateral amount using DEX spot price
        // collateralSeize = pay * (collateral per asset) * (1 + bonus)
        uint256 assetToCollWad = _priceAssetInCollateralWad(m);
        uint256 baseSeize = (pay * assetToCollWad) / WAD;
        uint256 seize = (baseSeize * (WAD + m.liqBonusWad)) / WAD;

        if (seize > u.collateralAmount) {
            seize = u.collateralAmount;
            // adjust pay down to match available collateral (reverse with bonus)
            // pay = seize / (price*(1+bonus))
            uint256 denomWad = (assetToCollWad * (WAD + m.liqBonusWad)) / WAD;
            if (denomWad > 0) {
                pay = (seize * WAD) / denomWad;
            }
        }

        // Take repayment from liquidator
        m.asset.safeTransferFrom(msg.sender, address(this), pay);

        // Reduce user's debt principal
        uint256 principalSub = (pay * WAD + (m.borrowIndexWad - 1)) / m.borrowIndexWad;
        if (principalSub > u.borrowPrincipal) principalSub = u.borrowPrincipal;
        u.borrowPrincipal -= principalSub;
        m.totalBorrowPrincipal -= principalSub;

        // Transfer collateral to liquidator
        u.collateralAmount -= seize;
        m.collateral.safeTransfer(msg.sender, seize);

        emit Liquidate(id, msg.sender, user, pay, seize);
    }

    function _currentDebt(Market storage m, UserPosition storage u) internal view returns (uint256) {
        return (u.borrowPrincipal * m.borrowIndexWad) / WAD;
    }

    function currentDebt(bytes32 id, address user) external view returns (uint256) {
        Market storage m = markets[id];
        require(m.listed, "NOT_LISTED");
        UserPosition storage u = positions[id][user];

        // view-only accrual approximation (no state change)
        uint256 dt = block.timestamp - m.lastAccrual;
        uint256 borrowFactor = WAD + (m.borrowRatePerSecondWad * dt);
        uint256 borrowIndex = (m.borrowIndexWad * borrowFactor) / WAD;

        return (u.borrowPrincipal * borrowIndex) / WAD;
    }

    function currentSupply(bytes32 id, address user) external view returns (uint256) {
        Market storage m = markets[id];
        require(m.listed, "NOT_LISTED");
        UserPosition storage u = positions[id][user];

        uint256 dt = block.timestamp - m.lastAccrual;
        uint256 supplyFactor = WAD + (m.supplyRatePerSecondWad * dt);
        uint256 supplyIndex = (m.supplyIndexWad * supplyFactor) / WAD;

        return (u.supplyPrincipal * supplyIndex) / WAD;
    }

    function collateralValueInAsset(bytes32 id, address user) external view returns (uint256) {
        Market storage m = markets[id];
        require(m.listed, "NOT_LISTED");
        UserPosition storage u = positions[id][user];
        uint256 collToAssetWad = priceWadFromV2Pair(m.pricePair, address(m.collateral), address(m.asset));
        return (u.collateralAmount * collToAssetWad) / WAD;
    }

    function accountLiquidity(bytes32 id, address user) external view returns (uint256 collateralValueAsset, uint256 debtAsset, bool healthy, bool liquidatable) {
        Market storage m = markets[id];
        require(m.listed, "NOT_LISTED");
        UserPosition storage u = positions[id][user];

        uint256 dt = block.timestamp - m.lastAccrual;
        uint256 borrowFactor = WAD + (m.borrowRatePerSecondWad * dt);
        uint256 borrowIndex = (m.borrowIndexWad * borrowFactor) / WAD;

        uint256 debt = (u.borrowPrincipal * borrowIndex) / WAD;

        uint256 collToAssetWad = priceWadFromV2Pair(m.pricePair, address(m.collateral), address(m.asset));
        uint256 collValue = (u.collateralAmount * collToAssetWad) / WAD;

        healthy = (debt == 0) || (debt <= (collValue * m.ltvWad) / WAD);
        liquidatable = (debt > 0) && (debt > (collValue * m.liqThresholdWad) / WAD);

        return (collValue, debt, healthy, liquidatable);
    }

    function _isHealthy(Market storage m, UserPosition storage u, uint256 collateralAmount, uint256 debtAsset) internal view returns (bool) {
        if (debtAsset == 0) return true;
        uint256 collToAssetWad = _priceCollateralInAssetWad(m);
        uint256 collValueAsset = (collateralAmount * collToAssetWad) / WAD;
        return debtAsset <= (collValueAsset * m.ltvWad) / WAD;
    }

    function _isHealthyBorrow(Market storage m, uint256 collateralAmount, uint256 debtAsset) internal view returns (bool) {
        if (debtAsset == 0) return true;
        uint256 collToAssetWad = _priceCollateralInAssetWad(m);
        uint256 collValueAsset = (collateralAmount * collToAssetWad) / WAD;
        return debtAsset <= (collValueAsset * m.ltvWad) / WAD;
    }

    function _isLiquidatable(Market storage m, uint256 collateralAmount, uint256 debtAsset) internal view returns (bool) {
        uint256 collToAssetWad = _priceCollateralInAssetWad(m);
        uint256 collValueAsset = (collateralAmount * collToAssetWad) / WAD;
        return debtAsset > (collValueAsset * m.liqThresholdWad) / WAD;
    }

    function sweep(IERC20 token, address to, uint256 amount) external onlyOwner {
        require(to != address(0), "BAD_TO");
        token.safeTransfer(to, amount);
    }

    function transferOwnership(address newOwner) external onlyOwner {
        require(newOwner != address(0), "BAD_OWNER");
        owner = newOwner;
    }
