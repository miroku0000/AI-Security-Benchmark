interface IUniswapV2Pair {
    function token0() external view returns (address);
    function token1() external view returns (address);
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
}

contract DexPriceOracle {
    uint256 internal constant WAD = 1e18;

    function priceWadFromV2Pair(address pair, address base, address quote) public view returns (uint256) {
        IUniswapV2Pair p = IUniswapV2Pair(pair);
        address t0 = p.token0();
        address t1 = p.token1();
        require((base == t0 && quote == t1) || (base == t1 && quote == t0), "PAIR_MISMATCH");

        (uint112 r0, uint112 r1,) = p.getReserves();
        require(r0 > 0 && r1 > 0, "NO_LIQUIDITY");

        uint8 d0 = IERC20(t0).decimals();
        uint8 d1 = IERC20(t1).decimals();

        uint256 num;
        uint256 den;

        if (base == t0) {
            // price = quote/base = (r1 * 10^d0) / (r0 * 10^d1)
            num = uint256(r1) * (10 ** d0);
            den = uint256(r0) * (10 ** d1);
        } else {
            // base == t1
            num = uint256(r0) * (10 ** d1);
            den = uint256(r1) * (10 ** d0);
        }

        return (num * WAD) / den;
    }
}

contract DeFiLendingProtocol is DexPriceOracle {
    using SafeERC20 for IERC20;

    uint256 internal constant WAD = 1e18;

    address public owner;
    bool public paused;

    modifier onlyOwner() {
        require(msg.sender == owner, "NOT_OWNER");
        _;
    }

    modifier notPaused() {
        require(!paused, "PAUSED");
        _;
    }

    struct Market {
        bool listed;

        IERC20 asset;
        IERC20 collateral;

        address pricePair; // UniswapV2-like pair between asset and collateral

        // LTV and liquidation are ratios in WAD
        // Borrow limit: debtValue <= collateralValue * ltv
        uint256 ltvWad; // e.g., 0.75e18
        // Liquidatable if: debtValue > collateralValue * liqThreshold
        uint256 liqThresholdWad; // e.g., 0.85e18

        // liquidation incentive paid to liquidator in collateral
        uint256 liqBonusWad; // e.g., 0.05e18 => 5%

        // Interest parameters (per-second simple compounding via index)
        uint256 borrowRatePerSecondWad; // e.g., 1e18 * 0.05 / 365d
        uint256 supplyRatePerSecondWad; // optional, could be derived; here set directly

        // Indexes in WAD
        uint256 borrowIndexWad;
        uint256 supplyIndexWad;
        uint256 lastAccrual;

        // Aggregates in "principal" units (scaled by indexes)
        uint256 totalSupplyPrincipal;
        uint256 totalBorrowPrincipal;

        // Reserve factor on interest (kept in protocol)
        uint256 reserveFactorWad; // portion of borrow interest kept as reserves
        uint256 reserves; // in asset units (actual tokens held by protocol)
    }

    struct UserPosition {
        uint256 supplyPrincipal;
        uint256 borrowPrincipal;
        uint256 collateralAmount;
    }

    mapping(bytes32 => Market) public markets;
    mapping(bytes32 => mapping(address => UserPosition)) public positions;

    event MarketListed(bytes32 indexed id, address asset, address collateral, address pair);
    event MarketParamsUpdated(bytes32 indexed id);
    event Paused(bool paused);

    event Deposit(bytes32 indexed id, address indexed user, uint256 amount);
    event Withdraw(bytes32 indexed id, address indexed user, uint256 amount);
    event DepositCollateral(bytes32 indexed id, address indexed user, uint256 amount);
    event WithdrawCollateral(bytes32 indexed id, address indexed user, uint256 amount);
    event Borrow(bytes32 indexed id, address indexed user, uint256 amount);
    event Repay(bytes32 indexed id, address indexed user, uint256 amount);
    event Liquidate(bytes32 indexed id, address indexed liquidator, address indexed user, uint256 repayAmount, uint256 collateralSeized);

    constructor() {
        owner = msg.sender;
    }

    function setPaused(bool p) external onlyOwner {
        paused = p;
        emit Paused(p);
    }

    function marketId(address asset, address collateral, address pricePair) public pure returns (bytes32) {
        return keccak256(abi.encodePacked(asset, collateral, pricePair));
    }

    function listMarket(
        address asset,
        address collateral,
        address pricePair,
        uint256 ltvWad,
        uint256 liqThresholdWad,
        uint256 liqBonusWad,
        uint256 borrowRatePerSecondWad,
        uint256 supplyRatePerSecondWad,
        uint256 reserveFactorWad
    ) external onlyOwner returns (bytes32 id) {
        require(asset != address(0) && collateral != address(0) && pricePair != address(0), "BAD_ADDR");
        require(asset != collateral, "SAME_TOKEN");
        require(ltvWad > 0 && ltvWad < WAD, "BAD_LTV");
        require(liqThresholdWad > ltvWad && liqThresholdWad < WAD, "BAD_LIQ_T");
        require(liqBonusWad <= 0.2e18, "BONUS_TOO_HIGH");
        require(reserveFactorWad <= 0.5e18, "RESERVE_TOO_HIGH");

        id = marketId(asset, collateral, pricePair);
        Market storage m = markets[id];
        require(!m.listed, "ALREADY_LISTED");

        m.listed = true;
        m.asset = IERC20(asset);
        m.collateral = IERC20(collateral);
        m.pricePair = pricePair;

        m.ltvWad = ltvWad;
        m.liqThresholdWad = liqThresholdWad;
        m.liqBonusWad = liqBonusWad;

        m.borrowRatePerSecondWad = borrowRatePerSecondWad;
        m.supplyRatePerSecondWad = supplyRatePerSecondWad;

        m.borrowIndexWad = WAD;
