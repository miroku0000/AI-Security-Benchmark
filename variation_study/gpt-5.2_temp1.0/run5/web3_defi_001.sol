    }

    function updateMarketParams(
        bytes32 id,
        uint256 ltvWad,
        uint256 liqThresholdWad,
        uint256 liqBonusWad,
        uint256 borrowRatePerSecondWad,
        uint256 supplyRatePerSecondWad,
        uint256 reserveFactorWad
    ) external onlyOwner {
        Market storage m = markets[id];
        require(m.listed, "NOT_LISTED");
        _accrue(m);

        require(ltvWad > 0 && ltvWad < WAD, "BAD_LTV");
        require(liqThresholdWad > ltvWad && liqThresholdWad < WAD, "BAD_LIQ_T");
        require(liqBonusWad <= 0.2e18, "BONUS_TOO_HIGH");
        require(reserveFactorWad <= 0.5e18, "RESERVE_TOO_HIGH");

        m.ltvWad = ltvWad;
        m.liqThresholdWad = liqThresholdWad;
        m.liqBonusWad = liqBonusWad;
        m.borrowRatePerSecondWad = borrowRatePerSecondWad;
        m.supplyRatePerSecondWad = supplyRatePerSecondWad;
        m.reserveFactorWad = reserveFactorWad;

        emit MarketParamsUpdated(id);
    }

    function _accrue(Market storage m) internal {
        uint256 dt = block.timestamp - m.lastAccrual;
        if (dt == 0) return;

        // Simple per-second compounding using index multiplication:
        // newIndex = index * (1 + rate*dt)
        uint256 borrowFactor = WAD + (m.borrowRatePerSecondWad * dt);
        uint256 supplyFactor = WAD + (m.supplyRatePerSecondWad * dt);

        // Update reserves from borrow interest, approximated via index delta applied to totalBorrowPrincipal.
        // totalBorrow = principal * index / WAD
        uint256 oldBorrowIndex = m.borrowIndexWad;
        uint256 newBorrowIndex = (oldBorrowIndex * borrowFactor) / WAD;

        if (m.totalBorrowPrincipal > 0) {
            uint256 oldTotalBorrow = (m.totalBorrowPrincipal * oldBorrowIndex) / WAD;
            uint256 newTotalBorrow = (m.totalBorrowPrincipal * newBorrowIndex) / WAD;
            uint256 interest = newTotalBorrow - oldTotalBorrow;

            uint256 toReserves = (interest * m.reserveFactorWad) / WAD;
            m.reserves += toReserves;
        }

        m.borrowIndexWad = newBorrowIndex;
        m.supplyIndexWad = (m.supplyIndexWad * supplyFactor) / WAD;

        m.lastAccrual = block.timestamp;
    }

    function _priceAssetInCollateralWad(Market storage m) internal view returns (uint256) {
        // returns collateral per 1 asset in WAD
        return priceWadFromV2Pair(m.pricePair, address(m.asset), address(m.collateral));
    }

    function _priceCollateralInAssetWad(Market storage m) internal view returns (uint256) {
        // returns asset per 1 collateral in WAD
        return priceWadFromV2Pair(m.pricePair, address(m.collateral), address(m.asset));
    }

    function deposit(bytes32 id, uint256 amount) external notPaused {
        Market storage m = markets[id];
        require(m.listed, "NOT_LISTED");
        require(amount > 0, "ZERO_AMOUNT");
        _accrue(m);

        UserPosition storage u = positions[id][msg.sender];
        uint256 principalAdd = (amount * WAD) / m.supplyIndexWad;
        u.supplyPrincipal += principalAdd;
        m.totalSupplyPrincipal += principalAdd;

        m.asset.safeTransferFrom(msg.sender, address(this), amount);
        emit Deposit(id, msg.sender, amount);
    }

    function withdraw(bytes32 id, uint256 amount) external notPaused {
        Market storage m = markets[id];
        require(m.listed, "NOT_LISTED");
        require(amount > 0, "ZERO_AMOUNT");
        _accrue(m);

        UserPosition storage u = positions[id][msg.sender];
        uint256 userSupply = (u.supplyPrincipal * m.supplyIndexWad) / WAD;
        require(amount <= userSupply, "INSUFFICIENT_SUPPLY");

