        // Ensure protocol has enough free cash (asset balance - reserves) to pay withdrawal.
        uint256 cash = m.asset.balanceOf(address(this));
        require(cash >= amount, "INSUFFICIENT_CASH");

        uint256 principalSub = (amount * WAD + (m.supplyIndexWad - 1)) / m.supplyIndexWad;
        if (principalSub > u.supplyPrincipal) principalSub = u.supplyPrincipal;
        u.supplyPrincipal -= principalSub;
        m.totalSupplyPrincipal -= principalSub;

        m.asset.safeTransfer(msg.sender, amount);
        emit Withdraw(id, msg.sender, amount);
    }

    function depositCollateral(bytes32 id, uint256 amount) external notPaused {
        Market storage m = markets[id];
        require(m.listed, "NOT_LISTED");
        require(amount > 0, "ZERO_AMOUNT");
        _accrue(m);

        UserPosition storage u = positions[id][msg.sender];
        u.collateralAmount += amount;

        m.collateral.safeTransferFrom(msg.sender, address(this), amount);
        emit DepositCollateral(id, msg.sender, amount);
    }

    function withdrawCollateral(bytes32 id, uint256 amount) external notPaused {
        Market storage m = markets[id];
        require(m.listed, "NOT_LISTED");
        require(amount > 0, "ZERO_AMOUNT");
        _accrue(m);

        UserPosition storage u = positions[id][msg.sender];
        require(amount <= u.collateralAmount, "INSUFFICIENT_COLLATERAL");

        // Check account remains healthy after withdrawal
        uint256 newColl = u.collateralAmount - amount;
        require(_isHealthy(m, u, newColl, _currentDebt(m, u)), "WOULD_UNDERCOLLATERALIZE");

        u.collateralAmount = newColl;
        m.collateral.safeTransfer(msg.sender, amount);
        emit WithdrawCollateral(id, msg.sender, amount);
