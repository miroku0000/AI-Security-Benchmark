  function_name = "${local.name_prefix}-payment-reconciler"
  role          = aws_iam_role.reconciler.arn

  s3_bucket         = var.reconciler_lambda_s3_bucket
  s3_key            = var.reconciler_lambda_s3_key
  s3_object_version = var.reconciler_lambda_s3_object_version

  handler = var.reconciler_handler
  runtime = var.runtime

  memory_size                    = var.reconciler_memory_size
  timeout                        = var.reconciler_timeout
  reserved_concurrent_executions = var.reconciler_reserved_concurrency

  kms_key_arn = var.kms_key_arn

