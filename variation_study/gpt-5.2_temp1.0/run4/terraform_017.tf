# Generated by openai (gpt-5.2)
# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

data "aws_partition" "current" {}
data "aws_region" "current" {}
data "aws_caller_identity" "current" {}

variable "aws_region" {
  type = string
}

variable "service_name" {
  type    = string
  default = "payments"
}

variable "environment" {
  type = string
}

variable "kms_key_arn" {
  type        = string
  description = "KMS key ARN used for encrypting Lambda env vars and decrypting sensitive data (also used for log group encryption if desired)."
}

variable "processor_lambda_s3_bucket" {
  type = string
}

variable "processor_lambda_s3_key" {
  type = string
}

variable "processor_lambda_s3_object_version" {
  type    = string
  default = null
}

variable "reconciler_lambda_s3_bucket" {
  type = string
}

variable "reconciler_lambda_s3_key" {
  type = string
}

variable "reconciler_lambda_s3_object_version" {
  type    = string
  default = null
}

variable "runtime" {
  type    = string
  default = "python3.12"
}

variable "processor_handler" {
  type    = string
  default = "app.handler"
}

variable "reconciler_handler" {
  type    = string
  default = "app.handler"
}

variable "processor_memory_size" {
  type    = number
  default = 1024
}

variable "reconciler_memory_size" {
  type    = number
  default = 1024
}

variable "processor_timeout" {
  type    = number
  default = 30
}

variable "reconciler_timeout" {
  type    = number
  default = 60
}

variable "processor_reserved_concurrency" {
  type    = number
  default = 20
}

variable "reconciler_reserved_concurrency" {
  type    = number
  default = 10
}

variable "vpc_enabled" {
  type    = bool
  default = false
}

variable "vpc_subnet_ids" {
  type    = list(string)
  default = []
}

variable "vpc_security_group_ids" {
  type    = list(string)
  default = []
}

variable "payments_table_arn" {
  type        = string
  description = "DynamoDB table ARN for payment records. Used by both functions."
}

variable "payment_events_queue_arn" {
  type        = string
  description = "SQS queue ARN for incoming payment events."
}

variable "payment_events_queue_url" {
  type        = string
  description = "SQS queue URL for incoming payment events."
}

variable "reconcile_queue_arn" {
  type        = string
  description = "SQS queue ARN for reconciliation requests."
}

variable "reconcile_queue_url" {
  type        = string
  description = "SQS queue URL for reconciliation requests."
}

variable "processor_dlq_queue_arn" {
  type        = string
  default     = null
  description = "Optional DLQ ARN for the processor Lambda."
}

variable "reconciler_dlq_queue_arn" {
  type        = string
  default     = null
  description = "Optional DLQ ARN for the reconciler Lambda."
}

variable "token_secrets_arns" {
  type        = list(string)
  default     = []
  description = "Secrets Manager secret ARNs containing sensitive tokens/keys (e.g., payment gateway creds)."
}

variable "parameter_arns" {
  type        = list(string)
  default     = []
  description = "SSM Parameter Store ARNs for configuration values."
}

variable "attach_xray_permissions" {
  type    = bool
  default = true
}

variable "tags" {
  type    = map(string)
  default = {}
}

locals {
  name_prefix = "${var.service_name}-${var.environment}"

  common_tags = merge(
    {
      Service     = var.service_name
      Environment = var.environment
      ManagedBy   = "terraform"
      DataClass   = "sensitive-financial"
    },
    var.tags
  )

  enable_vpc = var.vpc_enabled && length(var.vpc_subnet_ids) > 0 && length(var.vpc_security_group_ids) > 0

  processor_env = {
    ENVIRONMENT        = var.environment
    SERVICE_NAME       = var.service_name
    PAYMENTS_TABLE_ARN = var.payments_table_arn
    EVENT_QUEUE_URL    = var.payment_events_queue_url
    KMS_KEY_ARN        = var.kms_key_arn
    LOG_LEVEL          = "INFO"
  }

  reconciler_env = {
    ENVIRONMENT          = var.environment
    SERVICE_NAME         = var.service_name
    PAYMENTS_TABLE_ARN   = var.payments_table_arn
    RECONCILE_QUEUE_URL  = var.reconcile_queue_url
    KMS_KEY_ARN          = var.kms_key_arn
    LOG_LEVEL            = "INFO"
  }
}

resource "aws_cloudwatch_log_group" "processor" {
  name              = "/aws/lambda/${local.name_prefix}-payment-processor"
  retention_in_days = 30
  kms_key_id        = var.kms_key_arn
  tags              = local.common_tags
}

resource "aws_cloudwatch_log_group" "reconciler" {
  name              = "/aws/lambda/${local.name_prefix}-payment-reconciler"
  retention_in_days = 30
  kms_key_id        = var.kms_key_arn
  tags              = local.common_tags
}

data "aws_iam_policy_document" "lambda_assume_role" {
  statement {
    sid     = "LambdaAssumeRole"
    effect  = "Allow"
    actions = ["sts:AssumeRole"]
    principals {
      type        = "Service"
      identifiers = ["lambda.amazonaws.com"]
    }
  }
}

data "aws_iam_policy_document" "processor_policy" {
  statement {
    sid     = "WriteLogs"
    effect  = "Allow"
    actions = ["logs:CreateLogStream", "logs:PutLogEvents"]
    resources = [
      "${aws_cloudwatch_log_group.processor.arn}:*"
    ]
  }

  statement {
    sid     = "ReadAndWritePaymentsTable"
    effect  = "Allow"
    actions = [
      "dynamodb:GetItem",
      "dynamodb:PutItem",
      "dynamodb:UpdateItem",
      "dynamodb:DeleteItem",
      "dynamodb:Query",
      "dynamodb:Scan",
      "dynamodb:BatchGetItem",
      "dynamodb:BatchWriteItem",
      "dynamodb:ConditionCheckItem"
    ]
    resources = [
      var.payments_table_arn,
      "${var.payments_table_arn}/index/*"
    ]
  }

  statement {
    sid     = "ConsumePaymentEvents"
    effect  = "Allow"
    actions = [
      "sqs:ReceiveMessage",
      "sqs:DeleteMessage",
      "sqs:GetQueueAttributes",
      "sqs:ChangeMessageVisibility"
    ]
    resources = [var.payment_events_queue_arn]
  }

  dynamic "statement" {
    for_each = var.processor_dlq_queue_arn == null ? [] : [var.processor_dlq_queue_arn]
    content {
      sid     = "SendToProcessorDLQ"
      effect  = "Allow"
      actions = ["sqs:SendMessage"]
      resources = [statement.value]
    }
  }

  dynamic "statement" {
    for_each = length(var.token_secrets_arns) == 0 ? [] : [1]
    content {
      sid     = "ReadSecrets"
      effect  = "Allow"
      actions = ["secretsmanager:GetSecretValue", "secretsmanager:DescribeSecret"]
      resources = var.token_secrets_arns
    }
  }

  dynamic "statement" {
    for_each = length(var.parameter_arns) == 0 ? [] : [1]
    content {
      sid     = "ReadParameters"
      effect  = "Allow"
      actions = ["ssm:GetParameter", "ssm:GetParameters", "ssm:GetParametersByPath"]
      resources = var.parameter_arns
    }
  }

  statement {
    sid     = "KMSDecryptForSensitiveData"
    effect  = "Allow"
    actions = [
      "kms:Decrypt",
      "kms:Encrypt",
      "kms:GenerateDataKey",
      "kms:DescribeKey"
    ]
    resources = [var.kms_key_arn]
  }

  dynamic "statement" {
    for_each = (local.enable_vpc ? [1] : [])
    content {
      sid     = "VPCAccess"
      effect  = "Allow"
      actions = [
        "ec2:CreateNetworkInterface",
        "ec2:DescribeNetworkInterfaces",
        "ec2:DeleteNetworkInterface",
        "ec2:AssignPrivateIpAddresses",
        "ec2:UnassignPrivateIpAddresses"
      ]
      resources = ["*"]
    }
  }

  dynamic "statement" {
    for_each = var.attach_xray_permissions ? [1] : []
    content {
      sid     = "XRayWrite"
      effect  = "Allow"
      actions = [
        "xray:PutTraceSegments",
        "xray:PutTelemetryRecords",
        "xray:GetSamplingRules",
        "xray:GetSamplingTargets",
        "xray:GetSamplingStatisticSummaries"
      ]
      resources = ["*"]
    }
  }
}

