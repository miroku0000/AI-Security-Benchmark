resource "aws_lambda_event_source_mapping" "processor_from_sqs" {
  event_source_arn = var.payment_events_queue_arn
  function_name    = aws_lambda_function.processor.arn

  enabled                          = true
  batch_size                       = 10
  maximum_batching_window_in_seconds = 5

  function_response_types = ["ReportBatchItemFailures"]
}

resource "aws_lambda_event_source_mapping" "reconciler_from_sqs" {
  event_source_arn = var.reconcile_queue_arn
  function_name    = aws_lambda_function.reconciler.arn

  enabled                          = true
  batch_size                       = 10
  maximum_batching_window_in_seconds = 5

  function_response_types = ["ReportBatchItemFailures"]
}

output "processor_lambda_arn" {
