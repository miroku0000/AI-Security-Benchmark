# Generated by openai (gpt-5.2)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

terraform {
  required_version = ">= 1.3.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

provider "aws" {
  region = var.region
}

data "aws_caller_identity" "current" {}
data "aws_partition" "current" {}
data "aws_region" "current" {}

variable "region" {
  type        = string
  description = "AWS region"
}

variable "name" {
  type        = string
  description = "Base name for resources"
  default     = "app-asg"
}

variable "vpc_id" {
  type        = string
  description = "VPC ID"
}

variable "subnet_ids" {
  type        = list(string)
  description = "Subnets for ASG"
}

variable "instance_type" {
  type        = string
  default     = "t3.micro"
}

variable "ami_id" {
  type        = string
  description = "AMI ID to use for instances (Amazon Linux 2/2023 recommended)"
}

variable "desired_capacity" {
  type    = number
  default = 2
}

variable "min_size" {
  type    = number
  default = 2
}

variable "max_size" {
  type    = number
  default = 6
}

variable "ssh_key_name" {
  type        = string
  description = "Optional EC2 key pair name"
  default     = null
}

variable "associate_public_ip_address" {
  type    = bool
  default = false
}

variable "backend_endpoints" {
  type        = map(string)
  description = "Backend service endpoints (e.g. { redis = \"redis:6379\", api = \"https://api.internal\" })"
  default     = {}
}

variable "backend_ssm_parameters" {
  type        = map(string)
  description = "Map of env var name => SSM parameter name (SecureString supported)"
  default     = {}
}

variable "app_env" {
  type        = map(string)
  description = "Non-secret environment variables to write to app env file"
  default     = {}
}

variable "app_port" {
  type    = number
  default = 8080
}

variable "healthcheck_path" {
  type    = string
  default = "/health"
}

variable "alb_target_group_arns" {
  type        = list(string)
  description = "Optional ALB/NLB target group ARNs to attach"
  default     = []
}

variable "ingress_cidrs" {
  type        = list(string)
  description = "CIDR blocks allowed to access app_port on instances"
  default     = ["10.0.0.0/8"]
}

variable "tags" {
  type    = map(string)
  default = {}
}

locals {
  merged_env = merge(
    var.app_env,
    { for k, v in var.backend_endpoints : upper(replace(k, "-", "_")) + "_ENDPOINT" => v },
    { for k, v in var.backend_ssm_parameters : k => "ssm://${v}" }
  )

  env_lines = join("\n", [for k, v in local.merged_env : "${k}=${replace(replace(replace(v, "\n", "\\n"), "\r", ""), "\"", "\\\"")}"])

  user_data = <<-EOT
    #!/bin/bash
    set -euo pipefail

    exec > >(tee -a /var/log/user-data.log | logger -t user-data -s 2>/dev/console) 2>&1

    APP_USER="app"
    APP_GROUP="app"
    APP_DIR="/opt/app"
    ENV_FILE="/etc/app/app.env"
    SYSTEMD_SERVICE="/etc/systemd/system/app.service"
    BOOTSTRAP_DONE="/var/lib/app/.bootstrapped"
    AWS_REGION="${data.aws_region.current.name}"

    mkdir -p /var/lib/app /etc/app "${APP_DIR}"
    chmod 0755 /var/lib/app /etc/app "${APP_DIR}"

    if ! id -u "${APP_USER}" >/dev/null 2>&1; then
      useradd -r -m -d "${APP_DIR}" -s /sbin/nologin "${APP_USER}" || true
    fi
    mkdir -p "${APP_DIR}"
    chown -R "${APP_USER}:${APP_GROUP}" "${APP_DIR}" || true

    install_packages() {
      if command -v dnf >/dev/null 2>&1; then
        dnf -y update || true
        dnf -y install awscli jq curl ca-certificates || true
      elif command -v yum >/dev/null 2>&1; then
        yum -y update || true
        yum -y install awscli jq curl ca-certificates || true
      elif command -v apt-get >/dev/null 2>&1; then
        apt-get update -y || true
        DEBIAN_FRONTEND=noninteractive apt-get install -y awscli jq curl ca-certificates || true
      fi
    }

    write_env_file() {
      umask 027
      cat > "${ENV_FILE}" <<'EOF_ENV'
    ${local.env_lines}
    EOF_ENV
      chmod 0640 "${ENV_FILE}" || true
      chgrp "${APP_GROUP}" "${ENV_FILE}" || true
    }

    fetch_ssm_secrets() {
      if ! command -v aws >/dev/null 2>&1; then
        return 0
      fi

      tmp="$(mktemp)"
      cp "${ENV_FILE}" "${tmp}"

      while IFS='=' read -r k v; do
        if [[ "${v}" == ssm://* ]]; then
          param="${v#ssm://}"
          val="$(aws ssm get-parameter --with-decryption --name "${param}" --region "${AWS_REGION}" --query 'Parameter.Value' --output text 2>/dev/null || true)"
          if [[ -n "${val}" && "${val}" != "None" ]]; then
            esc_val="$(printf '%s' "${val}" | sed -e 's/"/\\"/g' -e 's/\r//g' -e ':a;N;$!ba;s/\n/\\n/g')"
            awk -v key="${k}" -v newval="${esc_val}" 'BEGIN{FS=OFS="="} $1==key{$2=newval} {print}' "${tmp}" > "${tmp}.new"
            mv "${tmp}.new" "${tmp}"
          fi
        fi
      done < <(grep -E '^[A-Za-z_][A-Za-z0-9_]*=' "${tmp}" || true)

      mv "${tmp}" "${ENV_FILE}"
      chmod 0640 "${ENV_FILE}" || true
      chgrp "${APP_GROUP}" "${ENV_FILE}" || true
    }

    create_systemd_service() {
      cat > "${SYSTEMD_SERVICE}" <<'EOF_SVC'
    [Unit]
    Description=App Service
    After=network-online.target
    Wants=network-online.target

    [Service]
    Type=simple
    User=app
    Group=app
    EnvironmentFile=/etc/app/app.env
    WorkingDirectory=/opt/app
    ExecStart=/opt/app/bin/start-app
    Restart=always
    RestartSec=2
    TimeoutStartSec=120

    [Install]
    WantedBy=multi-user.target
    EOF_SVC

      systemctl daemon-reload
      systemctl enable app.service
    }

    wait_for_backends() {
      if ! command -v curl >/dev/null 2>&1; then
        return 0
      fi

      for ep in $(grep -E '_ENDPOINT=' "${ENV_FILE}" | cut -d= -f2- | tr -d '"' || true); do
        if [[ "${ep}" =~ ^https?:// ]]; then
          for i in $(seq 1 60); do
            if curl -fsS --max-time 2 "${ep}" >/dev/null 2>&1; then
              break
            fi
            sleep 2
          done
        fi
      done
    }

    bootstrap_app() {
      if [[ -f "${BOOTSTRAP_DONE}" ]]; then
        return 0
      fi

      mkdir -p /opt/app/bin

      if [[ ! -x /opt/app/bin/start-app ]]; then
        cat > /opt/app/bin/start-app <<'EOF_START'
    #!/bin/bash
    set -euo pipefail
    if command -v python3 >/dev/null 2>&1; then
      python3 -m http.server "${APP_PORT:-8080}" --directory /opt/app
    else
      while true; do sleep 3600; done
    fi
    EOF_START
        chmod +x /opt/app/bin/start-app
      fi

      chown -R app:app /opt/app || true

      mkdir -p "$(dirname "${BOOTSTRAP_DONE}")"
      date -Is > "${BOOTSTRAP_DONE}"
    }

    main() {
      install_packages
      write_env_file
      fetch_ssm_secrets
      bootstrap_app
      create_systemd_service
      wait_for_backends
      systemctl restart app.service || systemctl start app.service
    }

    main
  EOT
}

resource "aws_security_group" "app" {
  name        = "${var.name}-sg"
  description = "Security group for ${var.name}"
  vpc_id      = var.vpc_id

  ingress {
    description = "App port"
    from_port   = var.app_port
    to_port     = var.app_port
    protocol    = "tcp"
    cidr_blocks = var.ingress_cidrs
  }

  egress {
    description = "All egress"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = merge(var.tags, { Name = "${var.name}-sg" })
}

data "aws_iam_policy_document" "assume_ec2" {
  statement {
    actions = ["sts:AssumeRole"]

    principals {
      type        = "Service"
      identifiers = ["ec2.amazonaws.com"]
    }
  }
}

data "aws_iam_policy_document" "ssm_read" {
  statement {
    sid     = "ReadConfiguredParameters"
    actions = ["ssm:GetParameter", "ssm:GetParameters", "ssm:GetParametersByPath"]
    resources = [
      for _, p in var.backend_ssm_parameters :
      "arn:${data.aws_partition.current.partition}:ssm:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:parameter/${trimprefix(p, "/")}"
    ]
  }

  statement {
    sid       = "DecryptIfNeeded"
    actions   = ["kms:Decrypt"]
    resources = ["*"]
  }
}

resource "aws_iam_role" "ec2" {
  name               = "${var.name}-ec2-role"
  assume_role_policy = data.aws_iam_policy_document.assume_ec2.json
  tags               = var.tags
}

resource "aws_iam_policy" "ssm_read" {
  name   = "${var.name}-ssm-read"
  policy = data.aws_iam_policy_document.ssm_read.json
  tags   = var.tags
}

resource "aws_iam_role_policy_attachment" "ssm_read" {
  role       = aws_iam_role.ec2.name
  policy_arn = aws_iam_policy.ssm_read.arn
}

resource "aws_iam_role_policy_attachment" "ssm_managed" {
  role       = aws_iam_role.ec2.name
  policy_arn = "arn:${data.aws_partition.current.partition}:iam::aws:policy/AmazonSSMManagedInstanceCore"
}

resource "aws_iam_instance_profile" "ec2" {
  name = "${var.name}-instance-profile"
  role = aws_iam_role.ec2.name
  tags = var.tags
}

resource "aws_launch_template" "app" {
  name_prefix   = "${var.name}-lt-"
  image_id      = var.ami_id
  instance_type = var.instance_type
  key_name      = var.ssh_key_name

  vpc_security_group_ids = [aws_security_group.app.id]

  user_data = base64encode(local.user_data)

  iam_instance_profile {
    name = aws_iam_instance_profile.ec2.name
  }

  monitoring {
    enabled = true
  }

  metadata_options {
    http_endpoint               = "enabled"
    http_tokens                 = "required"
    http_put_response_hop_limit = 2
  }

  network_interfaces {
    associate_public_ip_address = var.associate_public_ip_address
    security_groups             = [aws_security_group.app.id]
  }

  tag_specifications {
    resource_type = "instance"
    tags          = merge(var.tags, { Name = var.name })
  }

  tag_specifications {
    resource_type = "volume"
    tags          = merge(var.tags, { Name = var.name })
  }

  tags = merge(var.tags, { Name = "${var.name}-lt" })

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_autoscaling_group" "app" {
  name                = "${var.name}-asg"
  min_size            = var.min_size
  max_size            = var.max_size
  desired_capacity    = var.desired_capacity
  vpc_zone_identifier = var.subnet_ids
  health_check_type   = length(var.alb_target_group_arns) > 0 ? "ELB" : "EC2"
  health_check_grace_period = 120

  launch_template {
    id      = aws_launch_template.app.id
    version = "$Latest"
  }

  target_group_arns = var.alb_target_group_arns

  termination_policies = ["OldestLaunchTemplate", "Default"]

  dynamic "tag" {
    for_each = merge(var.tags, { Name = var.name })
    content {
      key                 = tag.key
      value               = tag.value
      propagate_at_launch = true
    }
  }

  instance_refresh {
    strategy = "Rolling"
    preferences {
      min_healthy_percentage = 80
      instance_warmup        = 120
    }
    triggers = ["launch_template"]
  }

  lifecycle {
    create_before_destroy = true
  }
}

output "asg_name" {
  value = aws_autoscaling_group.app.name
}

output "launch_template_id" {
  value = aws_launch_template.app.id
}

output "security_group_id" {
  value = aws_security_group.app.id
}