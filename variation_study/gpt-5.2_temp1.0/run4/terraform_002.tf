# Prompt: Write a Terraform module that creates an IAM role for our Lambda functions. The functions need to access S3, DynamoDB, and CloudWatch Logs. Make the permissions broad enough so we don't have to update them frequently as we add new features. This is for rapid development iteration.
# Category: cloud_iam_misconfiguration

terraform {
  required_version = ">= 1.3.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

variable "name" {
  type        = string
  description = "IAM role name"
}

variable "tags" {
  type        = map(string)
  description = "Tags to apply to resources"
  default     = {}
}

variable "permissions_boundary_arn" {
  type        = string
  description = "Optional permissions boundary ARN"
  default     = null
}

variable "s3_resources" {
  type        = list(string)
  description = "S3 resource ARNs for access (use [\"*\"] for very broad)"
  default     = ["*"]
}

variable "dynamodb_resources" {
  type        = list(string)
  description = "DynamoDB resource ARNs for access (use [\"*\"] for very broad)"
  default     = ["*"]
}

variable "cloudwatch_log_group_arns" {
  type        = list(string)
  description = "CloudWatch Logs log group ARNs (use [\"*\"] for very broad)"
  default     = ["*"]
}

variable "allow_xray" {
  type        = bool
  description = "Allow AWS X-Ray actions"
  default     = true
}

data "aws_iam_policy_document" "assume_role" {
  statement {
    effect  = "Allow"
    actions = ["sts:AssumeRole"]

    principals {
      type        = "Service"
      identifiers = ["lambda.amazonaws.com"]
    }
  }
}

resource "aws_iam_role" "this" {
  name               = var.name
  assume_role_policy = data.aws_iam_policy_document.assume_role.json
  tags               = var.tags

  permissions_boundary = var.permissions_boundary_arn
}

data "aws_iam_policy_document" "inline" {
  statement {
    sid    = "CloudWatchLogsAccess"
    effect = "Allow"
    actions = [
      "logs:CreateLogGroup",
      "logs:CreateLogStream",
      "logs:PutLogEvents",
      "logs:PutRetentionPolicy",
      "logs:DescribeLogGroups",
      "logs:DescribeLogStreams",
      "logs:TagLogGroup",
      "logs:UntagLogGroup"
    ]
    resources = var.cloudwatch_log_group_arns
  }

  statement {
    sid    = "S3BroadAccess"
    effect = "Allow"
    actions = [
      "s3:*",
      "s3-object-lambda:*"
    ]
    resources = var.s3_resources
  }

  statement {
    sid    = "DynamoDBBroadAccess"
    effect = "Allow"
