pragma solidity ^0.8.20;

interface IERC165 {
    function supportsInterface(bytes4 interfaceId) external view returns (bool);
}

interface IERC20 {
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
    function transfer(address to, uint256 amount) external returns (bool);
    function balanceOf(address who) external view returns (uint256);
    function allowance(address owner, address spender) external view returns (uint256);
}

interface IERC721 is IERC165 {
    function ownerOf(uint256 tokenId) external view returns (address);
    function getApproved(uint256 tokenId) external view returns (address);
    function isApprovedForAll(address owner, address operator) external view returns (bool);
    function safeTransferFrom(address from, address to, uint256 tokenId) external;
    function transferFrom(address from, address to, uint256 tokenId) external;
}

interface IERC721Receiver {
    function onERC721Received(address operator, address from, uint256 tokenId, bytes calldata data) external returns (bytes4);
}

contract NFTMarketplace is IERC721Receiver {
    struct Listing {
        address seller;
        address nft;
        uint256 tokenId;
        address paymentToken; // address(0) for native
        uint256 price;
        bool active;
    }

    uint256 public constant BPS_DENOMINATOR = 10_000;

    address public owner;
    address public feeRecipient;
    uint96 public marketplaceFeeBps;

    uint256 public nextListingId = 1;
    mapping(uint256 => Listing) public listings;

    event OwnershipTransferred(address indexed previousOwner, address indexed newOwner);
    event FeeRecipientUpdated(address indexed previous, address indexed current);
    event MarketplaceFeeUpdated(uint96 previousBps, uint96 currentBps);

    event Listed(
        uint256 indexed listingId,
        address indexed seller,
        address indexed nft,
        uint256 tokenId,
        address paymentToken,
        uint256 price
    );
    event ListingUpdated(uint256 indexed listingId, uint256 newPrice, address newPaymentToken);
    event ListingCanceled(uint256 indexed listingId);
    event Sold(
        uint256 indexed listingId,
        address indexed buyer,
        address indexed seller,
        address nft,
        uint256 tokenId,
        address paymentToken,
        uint256 price,
        uint256 feeAmount
    );

    error NotOwner();
    error InvalidAddress();
    error InvalidFee();
    error InvalidPrice();
    error NotSeller();
    error NotActive();
    error TransferFailed();
    error WrongPayment();
    error NotApproved();
    error NotTokenOwner();

    modifier onlyOwner() {
        if (msg.sender != owner) revert NotOwner();
        _;
    }

    constructor(address _feeRecipient, uint96 _marketplaceFeeBps) {
        owner = msg.sender;
        emit OwnershipTransferred(address(0), msg.sender);

        if (_feeRecipient == address(0)) revert InvalidAddress();
        if (_marketplaceFeeBps > 1_000) revert InvalidFee(); // max 10%
        feeRecipient = _feeRecipient;
        marketplaceFeeBps = _marketplaceFeeBps;
        emit FeeRecipientUpdated(address(0), _feeRecipient);
        emit MarketplaceFeeUpdated(0, _marketplaceFeeBps);
    }

    receive() external payable {}

    function transferOwnership(address newOwner) external onlyOwner {
        if (newOwner == address(0)) revert InvalidAddress();
        emit OwnershipTransferred(owner, newOwner);
        owner = newOwner;
    }

    function setFeeRecipient(address _feeRecipient) external onlyOwner {
        if (_feeRecipient == address(0)) revert InvalidAddress();
        emit FeeRecipientUpdated(feeRecipient, _feeRecipient);
        feeRecipient = _feeRecipient;
    }

    function setMarketplaceFeeBps(uint96 _marketplaceFeeBps) external onlyOwner {
        if (_marketplaceFeeBps > 1_000) revert InvalidFee(); // max 10%
        emit MarketplaceFeeUpdated(marketplaceFeeBps, _marketplaceFeeBps);
        marketplaceFeeBps = _marketplaceFeeBps;
    }

    function listNFT(
        address nft,
        uint256 tokenId,
        address paymentToken,
        uint256 price
    ) external returns (uint256 listingId) {
        if (nft == address(0)) revert InvalidAddress();
        if (price == 0) revert InvalidPrice();

        IERC721 erc721 = IERC721(nft);
        address tokenOwner = erc721.ownerOf(tokenId);
        if (tokenOwner != msg.sender) revert NotTokenOwner();

        bool approved = (erc721.getApproved(tokenId) == address(this)) || erc721.isApprovedForAll(msg.sender, address(this));
        if (!approved) revert NotApproved();

        listingId = nextListingId++;
        listings[listingId] = Listing({
            seller: msg.sender,
            nft: nft,
            tokenId: tokenId,
            paymentToken: paymentToken,
            price: price,
            active: true
        });

        emit Listed(listingId, msg.sender, nft, tokenId, paymentToken, price);
    }

    function updateListing(uint256 listingId, uint256 newPrice, address newPaymentToken) external {
        Listing storage l = listings[listingId];
        if (!l.active) revert NotActive();
        if (l.seller != msg.sender) revert NotSeller();
        if (newPrice == 0) revert InvalidPrice();

        l.price = newPrice;
        l.paymentToken = newPaymentToken;
        emit ListingUpdated(listingId, newPrice, newPaymentToken);
    }

    function cancelListing(uint256 listingId) external {
        Listing storage l = listings[listingId];
        if (!l.active) revert NotActive();
        if (l.seller != msg.sender) revert NotSeller();
        l.active = false;
        emit ListingCanceled(listingId);
    }

    function buy(uint256 listingId) external payable {
        Listing storage l = listings[listingId];
        if (!l.active) revert NotActive();

        IERC721 erc721 = IERC721(l.nft);
        address currentOwner = erc721.ownerOf(l.tokenId);
        if (currentOwner != l.seller) revert NotTokenOwner();

        bool approved = (erc721.getApproved(l.tokenId) == address(this)) || erc721.isApprovedForAll(l.seller, address(this));
        if (!approved) revert NotApproved();

        l.active = false;

        uint256 feeAmount = (l.price * marketplaceFeeBps) / BPS_DENOMINATOR;
        uint256 sellerAmount = l.price - feeAmount;

        if (l.paymentToken == address(0)) {
            if (msg.value != l.price) revert WrongPayment();
            if (feeAmount != 0) _safeTransferETH(feeRecipient, feeAmount);
            _safeTransferETH(l.seller, sellerAmount);
        } else {
            if (msg.value != 0) revert WrongPayment();
            _safeTransferERC20(l.paymentToken, msg.sender, feeRecipient, feeAmount);
            _safeTransferERC20(l.paymentToken, msg.sender, l.seller, sellerAmount);
        }

        erc721.safeTransferFrom(l.seller, msg.sender, l.tokenId);

        emit Sold(listingId, msg.sender, l.seller, l.nft, l.tokenId, l.paymentToken, l.price, feeAmount);
    }

    function _safeTransferETH(address to, uint256 amount) internal {
        if (amount == 0) return;
        (bool ok, ) = to.call{value: amount}("");
        if (!ok) revert TransferFailed();
    }

    function _safeTransferERC20(address token, address from, address to, uint256 amount) internal {
        if (amount == 0) return;
        (bool ok, bytes memory data) = token.call(abi.encodeWithSelector(IERC20.transferFrom.selector, from, to, amount));
        if (!ok || (data.length != 0 && !abi.decode(data, (bool)))) revert TransferFailed();
    }

    function onERC721Received(address, address, uint256, bytes calldata) external pure override returns (bytes4) {
        return IERC721Receiver.onERC721Received.selector;
    }
}