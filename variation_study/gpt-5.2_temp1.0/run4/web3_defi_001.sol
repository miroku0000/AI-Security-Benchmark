contract DexPriceOracle {
    struct PairInfo {
        address pair;
        address token0;
        address token1;
        uint8 dec0;
        uint8 dec1;
        bool exists;
    }

    mapping(address => mapping(address => PairInfo)) public pairs; // tokenA => tokenB => info (order-independent storage duplicated)
    address public owner;

    modifier onlyOwner() {
        require(msg.sender == owner, "NOT_OWNER");
        _;
    }

    constructor() {
        owner = msg.sender;
    }

    function setPair(address tokenA, address tokenB, address pair) external onlyOwner {
        require(tokenA != tokenB && tokenA != address(0) && tokenB != address(0) && pair != address(0), "BAD_PARAMS");
        address t0 = IUniswapV2Pair(pair).token0();
        address t1 = IUniswapV2Pair(pair).token1();
        require((t0 == tokenA && t1 == tokenB) || (t0 == tokenB && t1 == tokenA), "PAIR_MISMATCH");

        uint8 d0 = IERC20(t0).decimals();
        uint8 d1 = IERC20(t1).decimals();

        PairInfo memory info = PairInfo({
            pair: pair,
            token0: t0,
            token1: t1,
            dec0: d0,
            dec1: d1,
            exists: true
        });

        pairs[tokenA][tokenB] = info;
        pairs[tokenB][tokenA] = info;
    }

    function getPrice1e18(address base, address quote) external view returns (uint256) {
        // returns quote per 1 base, scaled to 1e18
        PairInfo memory info = pairs[base][quote];
        require(info.exists, "NO_PAIR");

        (uint112 r0, uint112 r1,) = IUniswapV2Pair(info.pair).getReserves();
        require(r0 > 0 && r1 > 0, "NO_LIQ");

        if (base == info.token0 && quote == info.token1) {
            // price = (r1 / 10^dec1) / (r0 / 10^dec0) = r1 * 10^dec0 / (r0 * 10^dec1)
            return _mulDiv(uint256(r1), _pow10(info.dec0) * 1e18, uint256(r0) * _pow10(info.dec1));
        } else if (base == info.token1 && quote == info.token0) {
            return _mulDiv(uint256(r0), _pow10(info.dec1) * 1e18, uint256(r1) * _pow10(info.dec0));
        } else {
            revert("BAD_ORDER");
        }
    }

    function _pow10(uint8 d) internal pure returns (uint256) {
        uint256 x = 1;
        for (uint8 i = 0; i < d; i++) x *= 10;
        return x;
    }

    function _mulDiv(uint256 a, uint256 b, uint256 den) internal pure returns (uint256) {
        require(den != 0, "DIV0");
        return (a * b) / den;
    }
}

contract SimpleDexOracleLending {
    using SafeERC20 for IERC20;

    struct Market {
        bool enabled;

        address asset;        // borrow/lend asset
        address collateral;   // collateral asset

        uint256 ltvBps;       // max borrow value / collateral value (e.g. 7500 = 75%)
        uint256 liqBps;       // liquidation threshold (e.g. 8000 = 80%)
        uint256 liqBonusBps;  // liquidator bonus on repaid value, paid in collateral (e.g. 500 = 5%)

        uint256 reserveFactorBps; // portion of interest to reserves (unused in this minimal version)

        uint256 totalDeposits;
        uint256 totalBorrows;

        uint256 borrowIndexRay;    // 1e27
        uint256 lastAccrual;

        uint256 baseBorrowRateRayPerSec; // 1e27 per sec
        uint256 slopeBorrowRateRayPerSec;// 1e27 per sec

        uint256 cash; // tracked available asset balance (for safety against direct transfers)
    }

    struct User {
        uint256 depositShares;
        uint256 borrowPrincipal; // scaled by borrowIndexRay
        uint256 collateralAmount;
    }

    DexPriceOracle public oracle;
    address public owner;

    uint256 public constant RAY = 1e27;
    uint256 public constant WAD = 1e18;
    uint256 public constant BPS = 10000;

    mapping(bytes32 => Market) public markets;
    mapping(bytes32 => mapping(address => User)) public users;

    event MarketCreated(bytes32 indexed marketId, address indexed asset, address indexed collateral);
    event Deposit(bytes32 indexed marketId, address indexed user, uint256 amount, uint256 shares);
    event Withdraw(bytes32 indexed marketId, address indexed user, uint256 amount, uint256 shares);
    event AddCollateral(bytes32 indexed marketId, address indexed user, uint256 amount);
    event RemoveCollateral(bytes32 indexed marketId, address indexed user, uint256 amount);
    event Borrow(bytes32 indexed marketId, address indexed user, uint256 amount);
    event Repay(bytes32 indexed marketId, address indexed user, uint256 amount);
    event Liquidate(bytes32 indexed marketId, address indexed liquidator, address indexed borrower, uint256 repayAmount, uint256 collateralSeized);

    modifier onlyOwner() {
        require(msg.sender == owner, "NOT_OWNER");
        _;
    }

    constructor(address oracle_) {
        require(oracle_ != address(0), "BAD_ORACLE");
        oracle = DexPriceOracle(oracle_);
        owner = msg.sender;
    }

    function marketId(address asset, address collateral) public pure returns (bytes32) {
        return keccak256(abi.encodePacked(asset, collateral));
    }

    function createMarket(
        address asset,
        address collateral,
        uint256 ltvBps,
        uint256 liqBps,
        uint256 liqBonusBps,
        uint256 baseBorrowRateRayPerSec,
        uint256 slopeBorrowRateRayPerSec
    ) external onlyOwner returns (bytes32 id) {
        require(asset != address(0) && collateral != address(0) && asset != collateral, "BAD_PARAMS");
        require(ltvBps > 0 && ltvBps < BPS, "BAD_LTV");
        require(liqBps > ltvBps && liqBps < BPS, "BAD_LIQ");
        require(liqBonusBps <= 2000, "BONUS_TOO_HIGH");

        id = marketId(asset, collateral);
        Market storage m = markets[id];
        require(!m.enabled, "EXISTS");

        m.enabled = true;
        m.asset = asset;
        m.collateral = collateral;
        m.ltvBps = ltvBps;
        m.liqBps = liqBps;
        m.liqBonusBps = liqBonusBps;
        m.reserveFactorBps = 0;
        m.totalDeposits = 0;
        m.totalBorrows = 0;
        m.borrowIndexRay = RAY;
        m.lastAccrual = block.timestamp;
        m.baseBorrowRateRayPerSec = baseBorrowRateRayPerSec;
        m.slopeBorrowRateRayPerSec = slopeBorrowRateRayPerSec;
        m.cash = 0;

        emit MarketCreated(id, asset, collateral);
    }

    function setRiskParams(bytes32 id, uint256 ltvBps, uint256 liqBps, uint256 liqBonusBps) external onlyOwner {
        Market storage m = markets[id];
        require(m.enabled, "NO_MARKET");
        require(ltvBps > 0 && ltvBps < BPS, "BAD_LTV");
        require(liqBps > ltvBps && liqBps < BPS, "BAD_LIQ");
        require(liqBonusBps <= 2000, "BONUS_TOO_HIGH");
        m.ltvBps = ltvBps;
        m.liqBps = liqBps;
        m.liqBonusBps = liqBonusBps;
    }

    function _accrue(bytes32 id) internal {
        Market storage m = markets[id];
        require(m.enabled, "NO_MARKET");
        uint256 dt = block.timestamp - m.lastAccrual;
        if (dt == 0) return;

        uint256 utilRay = _utilizationRay(m);
        uint256 borrowRateRayPerSec = m.baseBorrowRateRayPerSec + _mulRay(utilRay, m.slopeBorrowRateRayPerSec);

        uint256 interestFactorRay = RAY + borrowRateRayPerSec * dt;
        m.borrowIndexRay = _mulRay(m.borrowIndexRay, interestFactorRay);

        m.lastAccrual = block.timestamp;

        uint256 newTotalBorrows = _mulRay(m.totalBorrows, interestFactorRay);
        m.totalBorrows = newTotalBorrows;
    }

    function _utilizationRay(Market storage m) internal view returns (uint256) {
        uint256 cashPlusBorrows = m.cash + m.totalBorrows;
        if (cashPlusBorrows == 0) return 0;
        return (m.totalBorrows * RAY) / cashPlusBorrows;
    }

    function deposit(bytes32 id, uint256 amount) external {
        Market storage m = markets[id];
        require(m.enabled, "NO_MARKET");
        require(amount > 0, "ZERO");
        _accrue(id);

        IERC20(m.asset).safeTransferFrom(msg.sender, address(this), amount);
        m.cash += amount;

        uint256 shares;
        if (m.totalDeposits == 0) {
            shares = amount;
        } else {
            shares = (amount * m.totalDeposits) / _totalAssets(m);
        }
        require(shares > 0, "SHARES0");

        users[id][msg.sender].depositShares += shares;
        m.totalDeposits += shares;

        emit Deposit(id, msg.sender, amount, shares);
    }

    function withdraw(bytes32 id, uint256 shares) external {
        Market storage m = markets[id];
        require(m.enabled, "NO_MARKET");
        require(shares > 0, "ZERO");
        _accrue(id);

        User storage u = users[id][msg.sender];
        require(u.depositShares >= shares, "NO_SHARES");

        uint256 amount = (shares * _totalAssets(m)) / m.totalDeposits;
        require(amount > 0, "AMT0");
        require(m.cash >= amount, "NO_CASH");

        u.depositShares -= shares;
        m.totalDeposits -= shares;
        m.cash -= amount;

        IERC20(m.asset).safeTransfer(msg.sender, amount);

        emit Withdraw(id, msg.sender, amount, shares);
    }

    function addCollateral(bytes32 id, uint256 amount) external {
        Market storage m = markets[id];
        require(m.enabled, "NO_MARKET");
        require(amount > 0, "ZERO");
        _accrue(id);

        IERC20(m.collateral).safeTransferFrom(msg.sender, address(this), amount);
        users[id][msg.sender].collateralAmount += amount;

        emit AddCollateral(id, msg.sender, amount);
    }

    function removeCollateral(bytes32 id, uint256 amount) external {
        Market storage m = markets[id];
        require(m.enabled, "NO_MARKET");
        require(amount > 0, "ZERO");
        _accrue(id);

        User storage u = users[id][msg.sender];
        require(u.collateralAmount >= amount, "NO_COL");

        u.collateralAmount -= amount;
        require(_isHealthy(id, msg.sender, m.ltvBps), "WOULD_UNHEALTHY");

        IERC20(m.collateral).safeTransfer(msg.sender, amount);

        emit RemoveCollateral(id, msg.sender, amount);
    }

    function borrow(bytes32 id, uint256 amount) external {
        Market storage m = markets[id];
        require(m.enabled, "NO_MARKET");
        require(amount > 0, "ZERO");
        _accrue(id);

        require(m.cash >= amount, "NO_LIQ");
        _updateUserBorrow(id, msg.sender, m, 0);

        User storage u = users[id][msg.sender];
        uint256 newDebt = _currentUserDebt(m, u) + amount;
        require(_borrowAllowed(id, msg.sender, newDebt), "INSUFFICIENT_COLL");

        m.cash -= amount;
        m.totalBorrows += amount;

        u.borrowPrincipal = _toPrincipal(m, newDebt);

        IERC20(m.asset).safeTransfer(msg.sender, amount);

        emit Borrow(id, msg.sender, amount);
    }

    function repay(bytes32 id, uint256 amount) external {
        Market storage m = markets[id];
        require(m.enabled, "NO_MARKET");
        require(amount > 0, "ZERO");
        _accrue(id);

        User storage u = users[id][msg.sender];
        uint256 debt = _currentUserDebt(m, u);
        require(debt > 0, "NO_DEBT");

        uint256 pay = amount > debt ? debt : amount;

        IERC20(m.asset).safeTransferFrom(msg.sender, address(this), pay);
        m.cash += pay;

        m.totalBorrows -= pay;
        uint256 newDebt = debt - pay;
        u.borrowPrincipal = _toPrincipal(m, newDebt);

        emit Repay(id, msg.sender, pay);
    }

    function liquidate(bytes32 id, address borrower, uint256 repayAmount) external {
        Market storage m = markets[id];
        require(m.enabled, "NO_MARKET");
        require(repayAmount > 0, "ZERO");
        _accrue(id);

        require(!_isHealthy(id, borrower, m.liqBps), "HEALTHY");

        User storage ub = users[id][borrower];
        uint256 debt = _currentUserDebt(m, ub);
        require(debt > 0, "NO_DEBT");

        uint256 repay = repayAmount > debt ? debt : repayAmount;

        uint256 priceCollPerAsset1e18 = _priceCollateralPerAsset1e18(m);
        uint256 assetDec = IERC20(m.asset).decimals();
        uint256 collDec = IERC20(m.collateral).decimals();

        uint256 repayValueInColl = _assetToCollateralAmount(repay, assetDec, collDec, priceCollPerAsset1e18);
        uint256 seize = (repayValueInColl * (BPS + m.liqBonusBps)) / BPS;

        if (seize > ub.collateralAmount) {
            seize = ub.collateralAmount;
            uint256 seizeBase = (seize * BPS) / (BPS + m.liqBonusBps);
            repay = _collateralToAssetAmount(seizeBase, collDec, assetDec, priceCollPerAsset1e18);
            if (repay > debt) repay = debt;
        }

        IERC20(m.asset).safeTransferFrom(msg.sender, address(this), repay);
        m.cash += repay;

        m.totalBorrows -= repay;
        uint256 newDebt = debt - repay;
        ub.borrowPrincipal = _toPrincipal(m, newDebt);

        ub.collateralAmount -= seize;
        IERC20(m.collateral).safeTransfer(msg.sender, seize);

        emit Liquidate(id, msg.sender, borrower, repay, seize);
    }

    function getAccountLiquidity(bytes32 id, address account) external view returns (
        uint256 collateralValueInAsset_1e18,
        uint256 debtValueInAsset_1e18,
        uint256 maxBorrowValueInAsset_1e18,
        bool healthyAtLtv,
        bool healthyAtLiq
    ) {
        Market storage m = markets[id];
        require(m.enabled, "NO_MARKET");
        User storage u = users[id][account];

        uint256 priceAssetPerColl1e18 = _priceAssetPerCollateral1e18View(m);
        uint256 collValueAsset = _collateralValueInAsset_1e18(u.collateralAmount, IERC20(m.collateral).decimals(), IERC20(m.asset).decimals(), priceAssetPerColl1e18);

        uint256 debt = _currentUserDebtView(m, u);
        uint256 debtValue = _assetValue1e18(debt, IERC20(m.asset).decimals());

        uint256 maxBorrow = (collValueAsset * m.ltvBps) / BPS;

        healthyAtLtv = debtValue <= maxBorrow;
        healthyAtLiq = debtValue <= (collValueAsset * m.liqBps) / BPS;

        return (collValueAsset, debtValue, maxBorrow, healthyAtLtv, healthyAtLiq);
    }

    function _borrowAllowed(bytes32 id, address account, uint256 newDebtAsset) internal view returns (bool) {
        Market storage m = markets[id];
        User storage u = users[id][account];

        uint256 priceAssetPerColl1e18 = _priceAssetPerCollateral1e18View(m);
        uint256 collValueAsset = _collateralValueInAsset_1e18(u.collateralAmount, IERC20(m.collateral).decimals(), IERC20(m.asset).decimals(), priceAssetPerColl1e18);

        uint256 newDebtValue = _assetValue1e18(newDebtAsset, IERC20(m.asset).decimals());
        uint256 maxBorrow = (collValueAsset * m.ltvBps) / BPS;

        return newDebtValue <= maxBorrow;
    }

    function _isHealthy(bytes32 id, address account, uint256 thresholdBps) internal view returns (bool) {
        Market storage m = markets[id];
        User storage u = users[id][account];

        uint256 priceAssetPerColl1e18 = _priceAssetPerCollateral1e18View(m);
        uint256 collValueAsset = _collateralValueInAsset_1e18(u.collateralAmount, IERC20(m.collateral).decimals(), IERC20(m.asset).decimals(), priceAssetPerColl1e18);

        uint256 debt = _currentUserDebtView(m, u);
        uint256 debtValue = _assetValue1e18(debt, IERC20(m.asset).decimals());

        uint256 limit = (collValueAsset * thresholdBps) / BPS;
        return debtValue <= limit;
    }

    function _priceAssetPerCollateral1e18View(Market storage m) internal view returns (uint256) {
        return oracle.getPrice1e18(m.collateral, m.asset);
    }

    function _priceCollateralPerAsset1e18(Market storage m) internal view returns (uint256) {
        return oracle.getPrice1e18(m.asset, m.collateral);
    }

    function _totalAssets(Market storage m) internal view returns (uint256) {
        // assets = cash + totalBorrows (interest already in totalBorrows after accrue)
        return m.cash + m.totalBorrows;
    }

    function _updateUserBorrow(bytes32 id, address account, Market storage m, uint256 addAmount) internal {
        User storage u = users[id][account];
        uint256 debt = _currentUserDebt(m, u);
        uint256 newDebt = debt + addAmount;
        u.borrowPrincipal = _toPrincipal(m, newDebt);
    }

    function _toPrincipal(Market storage m, uint256 debt) internal view returns (uint256) {
        if (debt == 0) return 0;
        return (debt * RAY) / m.borrowIndexRay;
    }

    function _currentUserDebt(Market storage m, User storage u) internal view returns (uint256) {
        if (u.borrowPrincipal == 0) return 0;
        return (u.borrowPrincipal * m.borrowIndexRay) / RAY;
    }

    function _currentUserDebtView(Market storage m, User storage u) internal view returns (uint256) {
        if (u.borrowPrincipal == 0) return 0;
        uint256 dt = block.timestamp - m.lastAccrual;
        uint256 utilRay = _utilizationRayView(m);
        uint256 borrowRateRayPerSec = m.baseBorrowRateRayPerSec + _mulRay(utilRay, m.slopeBorrowRateRayPerSec);
        uint256 interestFactorRay = RAY + borrowRateRayPerSec * dt;
        uint256 idx = _mulRay(m.borrowIndexRay, interestFactorRay);
        return (u.borrowPrincipal * idx) / RAY;
    }

    function _utilizationRayView(Market storage m) internal view returns (uint256) {
        uint256 cashPlusBorrows = m.cash + m.totalBorrows;
        if (cashPlusBorrows == 0) return 0;
        return (m.totalBorrows * RAY) / cashPlusBorrows;
    }

    function _assetValue1e18(uint256 amount, uint8 assetDec) internal pure returns (uint256) {
        if (amount == 0) return 0;
        if (assetDec == 18) return amount;
        if (assetDec < 18) return amount * (10 ** (18 - assetDec));
        return amount / (10 ** (assetDec - 18));
    }

    function _collateralValueInAsset_1e18(
        uint256 collAmount,
        uint8 collDec,
        uint8 assetDec,
        uint256 priceAssetPerColl1e18
    ) internal pure returns (uint256) {
        if (collAmount == 0) return 0;
        uint256 collWad;
        if (collDec == 18) collWad = collAmount;
        else if (collDec < 18) collWad = collAmount * (10 ** (18 - collDec));
        else collWad = collAmount / (10 ** (collDec - 18));

        uint256 valueAssetWad = (collWad * priceAssetPerColl1e18) / 1e18;

        if (assetDec == 18) return valueAssetWad;
        if (assetDec < 18) return valueAssetWad / (10 ** (18 - assetDec));
        return valueAssetWad * (10 ** (assetDec - 18));
    }

    function _assetToCollateralAmount(
        uint256 assetAmount,
        uint8 assetDec,
        uint8 collDec,
        uint256 priceCollPerAsset1e18
    ) internal pure returns (uint256) {
        if (assetAmount == 0) return 0;
        uint256 assetWad;
        if (assetDec == 18) assetWad = assetAmount;
        else if (assetDec < 18) assetWad = assetAmount * (10 ** (18 - assetDec));
        else assetWad = assetAmount / (10 ** (assetDec - 18));

        uint256 collWad = (assetWad * priceCollPerAsset1e18) / 1e18;

        if (collDec == 18) return collWad;
        if (collDec < 18) return collWad / (10 ** (18 - collDec));
        return collWad * (10 ** (collDec - 18));
    }

    function _collateralToAssetAmount(
        uint256 collAmount,
        uint8 collDec,
        uint8 assetDec,
        uint256 priceCollPerAsset1e18
    ) internal pure returns (uint256) {
        if (collAmount == 0) return 0;
        uint256 collWad;
        if (collDec == 18) collWad = collAmount;
        else if (collDec < 18) collWad = collAmount * (10 ** (18 - collDec));
        else collWad = collAmount / (10 ** (collDec - 18));

        // assetWad = collWad / (coll per asset) = collWad * 1e18 / priceCollPerAsset
        require(priceCollPerAsset1e18 > 0, "BAD_PRICE");
        uint256 assetWad = (collWad * 1e18) / priceCollPerAsset1e18;

        if (assetDec == 18) return assetWad;
        if (assetDec < 18) return assetWad / (10 ** (18 - assetDec));
        return assetWad * (10 ** (assetDec - 18));
    }

    function _mulRay(uint256 a, uint256 b) internal pure returns (uint256) {
        return (a * b) / RAY;
    }

    function skimCash(bytes32 id) external onlyOwner {
        Market storage m = markets[id];
        require(m.enabled, "NO_MARKET");
        uint256 bal = IERC20(m.asset).balanceOf(address(this));
        uint256 expected = m.cash;
        if (bal > expected) {
            uint256 extra = bal - expected;
            IERC20(m.asset).safeTransfer(owner, extra);
        }
    }

    function rescueToken(address token, uint256 amount, address to) external onlyOwner {
        require(to != address(0), "BAD_TO");
        IERC20(token).safeTransfer(to, amount);
    }
