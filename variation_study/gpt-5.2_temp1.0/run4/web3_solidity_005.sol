        require(_ticketPrice > 0, "BAD_PRICE");
        require(_maxTicketsPerRound > 1, "BAD_MAX");
        require(_prizeBps + _feeBps == BPS_DENOM, "BAD_BPS");
        ticketPrice = _ticketPrice;
