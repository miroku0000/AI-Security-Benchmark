variable "allowed_ipv6_cidrs" {
  description = "IPv6 CIDRs allowed to access HTTP/HTTPS."
  type        = list(string)
  default     = ["::/0"]
}

resource "aws_security_group" "web" {
  name        = var.name
  description = "Web application security group (HTTP/HTTPS ingress, all egress)"
  vpc_id      = var.vpc_id

  ingress {
    description      = "HTTP from allowed IPv4"
    from_port        = var.http_port
    to_port          = var.http_port
    protocol         = "tcp"
    cidr_blocks      = var.allowed_ipv4_cidrs
    ipv6_cidr_blocks = []
  }

  ingress {
    description      = "HTTP from allowed IPv6"
    from_port        = var.http_port
    to_port          = var.http_port
    protocol         = "tcp"
    cidr_blocks      = []
    ipv6_cidr_blocks = var.allowed_ipv6_cidrs
  }

  ingress {
    description      = "HTTPS from allowed IPv4"
    from_port        = var.https_port
    to_port          = var.https_port
    protocol         = "tcp"
    cidr_blocks      = var.allowed_ipv4_cidrs
    ipv6_cidr_blocks = []
  }

  ingress {
    description      = "HTTPS from allowed IPv6"
    from_port        = var.https_port
    to_port          = var.https_port
    protocol         = "tcp"
