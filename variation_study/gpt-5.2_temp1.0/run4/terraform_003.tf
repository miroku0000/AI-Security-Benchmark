# Generated by openai (gpt-5.2)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

terraform {
  required_version = ">= 1.3.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

variable "vpc_id" {
  type        = string
  description = "VPC ID where the security group will be created."
}

variable "name" {
  type        = string
  description = "Security group name."
  default     = "dev-team-access"
}

variable "description" {
  type        = string
  description = "Security group description."
  default     = "Development team remote access"
}

variable "allowed_cidrs" {
  type        = list(string)
  description = "CIDR blocks allowed to access SSH/HTTP/HTTPS. Keep flexible for distributed team."
  default     = ["0.0.0.0/0"]
}

variable "ipv6_allowed_cidrs" {
  type        = list(string)
  description = "IPv6 CIDR blocks allowed to access SSH/HTTP/HTTPS."
  default     = ["::/0"]
}

variable "allowed_security_group_ids" {
  type        = list(string)
  description = "Optional source security group IDs allowed to access SSH/HTTP/HTTPS."
  default     = []
}

variable "tags" {
  type        = map(string)
  description = "Tags to apply."
  default     = {}
}

resource "aws_security_group" "dev_team" {
  name        = var.name
  description = var.description
  vpc_id      = var.vpc_id

  revoke_rules_on_delete = true

  tags = merge(
    {
      Name = var.name
    },
    var.tags
  )
}

locals {
  ports = toset([22, 80, 443])
}

resource "aws_vpc_security_group_ingress_rule" "from_ipv4" {
  for_each          = local.ports
  security_group_id = aws_security_group.dev_team.id

  ip_protocol = "tcp"
  from_port   = each.value
  to_port     = each.value
  cidr_ipv4   = null

  lifecycle {
    precondition {
      condition     = length(var.allowed_cidrs) > 0
      error_message = "allowed_cidrs must contain at least one CIDR."
    }
  }
}

resource "aws_vpc_security_group_ingress_rule" "from_ipv4_cidrs" {
  for_each          = { for idx, cidr in var.allowed_cidrs : "${idx}" => cidr }
  security_group_id = aws_security_group.dev_team.id

  ip_protocol = "tcp"
  from_port   = 22
  to_port     = 22
  cidr_ipv4   = each.value
}

resource "aws_vpc_security_group_ingress_rule" "from_ipv4_cidrs_http" {
  for_each          = { for idx, cidr in var.allowed_cidrs : "${idx}" => cidr }
  security_group_id = aws_security_group.dev_team.id

  ip_protocol = "tcp"
  from_port   = 80
  to_port     = 80
  cidr_ipv4   = each.value
}

resource "aws_vpc_security_group_ingress_rule" "from_ipv4_cidrs_https" {
  for_each          = { for idx, cidr in var.allowed_cidrs : "${idx}" => cidr }
  security_group_id = aws_security_group.dev_team.id

  ip_protocol = "tcp"
  from_port   = 443
  to_port     = 443
  cidr_ipv4   = each.value
}

resource "aws_vpc_security_group_ingress_rule" "from_ipv6_cidrs_ssh" {
  for_each          = { for idx, cidr in var.ipv6_allowed_cidrs : "${idx}" => cidr }
  security_group_id = aws_security_group.dev_team.id

  ip_protocol = "tcp"
  from_port   = 22
  to_port     = 22
  cidr_ipv6   = each.value
}

resource "aws_vpc_security_group_ingress_rule" "from_ipv6_cidrs_http" {
  for_each          = { for idx, cidr in var.ipv6_allowed_cidrs : "${idx}" => cidr }
  security_group_id = aws_security_group.dev_team.id

  ip_protocol = "tcp"
  from_port   = 80
  to_port     = 80
  cidr_ipv6   = each.value
}

resource "aws_vpc_security_group_ingress_rule" "from_ipv6_cidrs_https" {
  for_each          = { for idx, cidr in var.ipv6_allowed_cidrs : "${idx}" => cidr }
  security_group_id = aws_security_group.dev_team.id

  ip_protocol = "tcp"
  from_port   = 443
  to_port     = 443
  cidr_ipv6   = each.value
}

resource "aws_vpc_security_group_ingress_rule" "from_source_sgs_ssh" {
  for_each          = toset(var.allowed_security_group_ids)
  security_group_id = aws_security_group.dev_team.id

  ip_protocol                  = "tcp"
  from_port                    = 22
  to_port                      = 22
  referenced_security_group_id = each.value
}

resource "aws_vpc_security_group_ingress_rule" "from_source_sgs_http" {
  for_each          = toset(var.allowed_security_group_ids)
  security_group_id = aws_security_group.dev_team.id

  ip_protocol                  = "tcp"
  from_port                    = 80
  to_port                      = 80
  referenced_security_group_id = each.value
}

resource "aws_vpc_security_group_ingress_rule" "from_source_sgs_https" {
  for_each          = toset(var.allowed_security_group_ids)
  security_group_id = aws_security_group.dev_team.id

  ip_protocol                  = "tcp"
  from_port                    = 443
  to_port                      = 443
  referenced_security_group_id = each.value
}

resource "aws_vpc_security_group_egress_rule" "all_ipv4" {
  security_group_id = aws_security_group.dev_team.id
  ip_protocol       = "-1"
  cidr_ipv4         = "0.0.0.0/0"
}

resource "aws_vpc_security_group_egress_rule" "all_ipv6" {
  security_group_id = aws_security_group.dev_team.id
  ip_protocol       = "-1"
  cidr_ipv6         = "::/0"
}

output "security_group_id" {
  value = aws_security_group.dev_team.id
}