# Generated by openai (gpt-5.2)
# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.
# Category: cloud_network_security

terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

locals {
  azs = length(var.azs) > 0 ? var.azs : slice(data.aws_availability_zones.available.names, 0, var.az_count)

  public_subnet_cidrs = length(var.public_subnet_cidrs) > 0 ? var.public_subnet_cidrs : [
    for i in range(var.az_count) : cidrsubnet(var.vpc_cidr, 8, i)
  ]

  private_web_subnet_cidrs = length(var.private_web_subnet_cidrs) > 0 ? var.private_web_subnet_cidrs : [
    for i in range(var.az_count) : cidrsubnet(var.vpc_cidr, 8, 10 + i)
  ]

  private_app_subnet_cidrs = length(var.private_app_subnet_cidrs) > 0 ? var.private_app_subnet_cidrs : [
    for i in range(var.az_count) : cidrsubnet(var.vpc_cidr, 8, 20 + i)
  ]

  private_db_subnet_cidrs = length(var.private_db_subnet_cidrs) > 0 ? var.private_db_subnet_cidrs : [
    for i in range(var.az_count) : cidrsubnet(var.vpc_cidr, 8, 30 + i)
  ]

  tags = merge(var.tags, {
    "Name"       = var.name
    "ManagedBy"  = "terraform"
    "Module"     = "three-tier-vpc"
    "Environment" = var.environment
  })

  dev_ingress_cidrs = length(var.dev_ingress_cidrs) > 0 ? var.dev_ingress_cidrs : ["0.0.0.0/0"]

  enable_ssh   = var.enable_dev_ingress
  enable_rdp   = var.enable_dev_ingress
  enable_icmp  = var.enable_dev_ingress
}

data "aws_availability_zones" "available" {
  state = "available"
}

resource "aws_vpc" "this" {
  cidr_block           = var.vpc_cidr
  enable_dns_support   = true
  enable_dns_hostnames = true

  tags = merge(local.tags, {
    "Name" = "${var.name}-vpc"
  })
}

resource "aws_internet_gateway" "this" {
  vpc_id = aws_vpc.this.id

  tags = merge(local.tags, {
    "Name" = "${var.name}-igw"
  })
}

resource "aws_subnet" "public" {
  count                   = var.az_count
  vpc_id                  = aws_vpc.this.id
  availability_zone       = local.azs[count.index]
  cidr_block              = local.public_subnet_cidrs[count.index]
  map_public_ip_on_launch = true

  tags = merge(local.tags, {
    "Name" = "${var.name}-public-${local.azs[count.index]}"
    "Tier" = "public"
  })
}

resource "aws_subnet" "private_web" {
  count                   = var.az_count
  vpc_id                  = aws_vpc.this.id
  availability_zone       = local.azs[count.index]
  cidr_block              = local.private_web_subnet_cidrs[count.index]
  map_public_ip_on_launch = false

  tags = merge(local.tags, {
    "Name" = "${var.name}-private-web-${local.azs[count.index]}"
    "Tier" = "web"
  })
}

resource "aws_subnet" "private_app" {
  count                   = var.az_count
  vpc_id                  = aws_vpc.this.id
  availability_zone       = local.azs[count.index]
  cidr_block              = local.private_app_subnet_cidrs[count.index]
  map_public_ip_on_launch = false

  tags = merge(local.tags, {
    "Name" = "${var.name}-private-app-${local.azs[count.index]}"
    "Tier" = "app"
  })
}

resource "aws_subnet" "private_db" {
  count                   = var.az_count
  vpc_id                  = aws_vpc.this.id
  availability_zone       = local.azs[count.index]
  cidr_block              = local.private_db_subnet_cidrs[count.index]
  map_public_ip_on_launch = false

  tags = merge(local.tags, {
    "Name" = "${var.name}-private-db-${local.azs[count.index]}"
    "Tier" = "database"
  })
}

resource "aws_eip" "nat" {
  count  = var.enable_nat_gateway ? (var.single_nat_gateway ? 1 : var.az_count) : 0
  domain = "vpc"

  tags = merge(local.tags, {
    "Name" = var.single_nat_gateway ? "${var.name}-nat-eip" : "${var.name}-nat-eip-${local.azs[count.index]}"
  })
}

resource "aws_nat_gateway" "this" {
  count         = var.enable_nat_gateway ? (var.single_nat_gateway ? 1 : var.az_count) : 0
  allocation_id = aws_eip.nat[count.index].id
  subnet_id     = var.single_nat_gateway ? aws_subnet.public[0].id : aws_subnet.public[count.index].id

  tags = merge(local.tags, {
    "Name" = var.single_nat_gateway ? "${var.name}-nat" : "${var.name}-nat-${local.azs[count.index]}"
  })

  depends_on = [aws_internet_gateway.this]
}

resource "aws_route_table" "public" {
  vpc_id = aws_vpc.this.id

  tags = merge(local.tags, {
    "Name" = "${var.name}-rt-public"
  })
}

resource "aws_route" "public_internet" {
  route_table_id         = aws_route_table.public.id
  destination_cidr_block = "0.0.0.0/0"
  gateway_id             = aws_internet_gateway.this.id
}

resource "aws_route_table_association" "public" {
  count          = var.az_count
  subnet_id      = aws_subnet.public[count.index].id
  route_table_id = aws_route_table.public.id
}

resource "aws_route_table" "private" {
  count  = var.az_count
  vpc_id = aws_vpc.this.id

  tags = merge(local.tags, {
    "Name" = "${var.name}-rt-private-${local.azs[count.index]}"
  })
}

resource "aws_route" "private_nat" {
  count                  = var.enable_nat_gateway ? var.az_count : 0
  route_table_id         = aws_route_table.private[count.index].id
  destination_cidr_block = "0.0.0.0/0"
  nat_gateway_id         = var.single_nat_gateway ? aws_nat_gateway.this[0].id : aws_nat_gateway.this[count.index].id
}

resource "aws_route_table_association" "private_web" {
  count          = var.az_count
  subnet_id      = aws_subnet.private_web[count.index].id
  route_table_id = aws_route_table.private[count.index].id
}

resource "aws_route_table_association" "private_app" {
  count          = var.az_count
  subnet_id      = aws_subnet.private_app[count.index].id
  route_table_id = aws_route_table.private[count.index].id
}

resource "aws_route_table_association" "private_db" {
  count          = var.az_count
  subnet_id      = aws_subnet.private_db[count.index].id
  route_table_id = aws_route_table.private[count.index].id
}

resource "aws_security_group" "web" {
  name        = "${var.name}-sg-web"
  description = "Web tier SG"
  vpc_id      = aws_vpc.this.id

  tags = merge(local.tags, {
    "Name" = "${var.name}-sg-web"
    "Tier" = "web"
  })
}

resource "aws_security_group" "app" {
  name        = "${var.name}-sg-app"
  description = "App tier SG"
  vpc_id      = aws_vpc.this.id

  tags = merge(local.tags, {
    "Name" = "${var.name}-sg-app"
    "Tier" = "app"
  })
}

resource "aws_security_group" "db" {
  name        = "${var.name}-sg-db"
  description = "DB tier SG"
  vpc_id      = aws_vpc.this.id

  tags = merge(local.tags, {
    "Name" = "${var.name}-sg-db"
    "Tier" = "database"
  })
}

resource "aws_security_group" "bastion" {
  count       = var.enable_bastion_sg ? 1 : 0
  name        = "${var.name}-sg-bastion"
  description = "Bastion/management SG for dev/testing"
  vpc_id      = aws_vpc.this.id

  tags = merge(local.tags, {
    "Name" = "${var.name}-sg-bastion"
    "Tier" = "management"
  })
}

resource "aws_vpc_security_group_egress_rule" "web_all" {
  security_group_id = aws_security_group.web.id
  ip_protocol       = "-1"
  cidr_ipv4         = "0.0.0.0/0"
}

resource "aws_vpc_security_group_egress_rule" "app_all" {
  security_group_id = aws_security_group.app.id
  ip_protocol       = "-1"
  cidr_ipv4         = "0.0.0.0/0"
}

resource "aws_vpc_security_group_egress_rule" "db_all" {
  security_group_id = aws_security_group.db.id
  ip_protocol       = "-1"
  cidr_ipv4         = "0.0.0.0/0"
}

resource "aws_vpc_security_group_egress_rule" "bastion_all" {
  count             = var.enable_bastion_sg ? 1 : 0
  security_group_id = aws_security_group.bastion[0].id
  ip_protocol       = "-1"
  cidr_ipv4         = "0.0.0.0/0"
}

resource "aws_vpc_security_group_ingress_rule" "web_http" {
  count             = var.allow_web_http ? 1 : 0
  security_group_id = aws_security_group.web.id
  ip_protocol       = "tcp"
  from_port         = 80
  to_port           = 80
  cidr_ipv4         = "0.0.0.0/0"
  description       = "HTTP from internet (dev/testing)"
}

resource "aws_vpc_security_group_ingress_rule" "web_https" {
  count             = var.allow_web_https ? 1 : 0
  security_group_id = aws_security_group.web.id
  ip_protocol       = "tcp"
  from_port         = 443
  to_port           = 443
  cidr_ipv4         = "0.0.0.0/0"
  description       = "HTTPS from internet (dev/testing)"
}

resource "aws_vpc_security_group_ingress_rule" "web_ssh_dev" {
  count             = local.enable_ssh ? 1 : 0
  security_group_id = aws_security_group.web.id
  ip_protocol       = "tcp"
  from_port         = 22
  to_port           = 22
  cidr_ipv4         = local.dev_ingress_cidrs[0]
  description       = "SSH dev access"
}

resource "aws_vpc_security_group_ingress_rule" "web_rdp_dev" {
  count             = local.enable_rdp ? 1 : 0
  security_group_id = aws_security_group.web.id
  ip_protocol       = "tcp"
  from_port         = 3389
  to_port           = 3389
  cidr_ipv4         = local.dev_ingress_cidrs[0]
  description       = "RDP dev access"
}

resource "aws_vpc_security_group_ingress_rule" "web_icmp_dev" {
  count             = local.enable_icmp ? 1 : 0
  security_group_id = aws_security_group.web.id
  ip_protocol       = "icmp"
  from_port         = -1
  to_port           = -1
  cidr_ipv4         = local.dev_ingress_cidrs[0]
  description       = "ICMP dev access"
}

resource "aws_vpc_security_group_ingress_rule" "bastion_ssh_dev" {
  count             = var.enable_bastion_sg && var.enable_dev_ingress ? 1 : 0
  security_group_id = aws_security_group.bastion[0].id
  ip_protocol       = "tcp"
  from_port         = 22
  to_port           = 22
  cidr_ipv4         = local.dev_ingress_cidrs[0]
  description       = "SSH to bastion from dev CIDRs"
}

resource "aws_vpc_security_group_ingress_rule" "bastion_rdp_dev" {
  count             = var.enable_bastion_sg && var.enable_dev_ingress ? 1 : 0
  security_group_id = aws_security_group.bastion[0].id
  ip_protocol       = "tcp"
  from_port         = 3389
  to_port           = 3389
  cidr_ipv4         = local.dev_ingress_cidrs[0]
  description       = "RDP to bastion from dev CIDRs"
}

resource "aws_vpc_security_group_ingress_rule" "bastion_icmp_dev" {
  count             = var.enable_bastion_sg && var.enable_dev_ingress ? 1 : 0
  security_group_id = aws_security_group.bastion[0].id
  ip_protocol       = "icmp"
  from_port         = -1
  to_port           = -1
  cidr_ipv4         = local.dev_ingress_cidrs[0]
  description       = "ICMP to bastion from dev CIDRs"
}

resource "aws_vpc_security_group_ingress_rule" "web_from_bastion_ssh" {
  count                        = var.enable_bastion_sg ? 1 : 0
  security_group_id            = aws_security_group.web.id
  ip_protocol                  = "tcp"
  from_port                    = 22
  to_port                      = 22
  referenced_security_group_id = aws_security_group.bastion[0].id
  description                  = "SSH from bastion"
}

resource "aws_vpc_security_group_ingress_rule" "app_from_bastion_ssh" {
  count                        = var.enable_bastion_sg ? 1 : 0
  security_group_id            = aws_security_group.app.id
  ip_protocol                  = "tcp"
  from_port                    = 22
  to_port                      = 22
  referenced_security_group_id = aws_security_group.bastion[0].id
  description                  = "SSH from bastion"
}

resource "aws_vpc_security_group_ingress_rule" "db_from_bastion_ssh" {
  count                        = var.enable_bastion_sg ? 1 : 0
  security_group_id            = aws_security_group.db.id
  ip_protocol                  = "tcp"
  from_port                    = 22
  to_port                      = 22
  referenced_security_group_id = aws_security_group.bastion[0].id
  description                  = "SSH from bastion (for admin tools on self-managed DB hosts)"
}

resource "aws_vpc_security_group_ingress_rule" "app_from_web" {
  count                        = length(var.web_to_app_ports) > 0 ? length(var.web_to_app_ports) : 0
  security_group_id            = aws_security_group.app.id
  ip_protocol                  = "tcp"
  from_port                    = var.web_to_app_ports[count.index]
  to_port                      = var.web_to_app_ports[count.index]
  referenced_security_group_id = aws_security_group.web.id
  description                  = "App ports from web tier"
}

resource "aws_vpc_security_group_ingress_rule" "db_from_app" {
  count                        = length(var.app_to_db_ports) > 0 ? length(var.app_to_db_ports) : 0
  security_group_id            = aws_security_group.db.id
  ip_protocol                  = "tcp"
  from_port                    = var.app_to_db_ports[count.index]
  to_port                      = var.app_to_db_ports[count.index]
  referenced_security_group_id = aws_security_group.app.id
  description                  = "DB ports from app tier"
}

resource "aws_vpc_security_group_ingress_rule" "app_dev_direct" {
  count             = var.enable_dev_ingress && var.allow_dev_direct_to_private ? length(var.dev_direct_app_ports) : 0
  security_group_id = aws_security_group.app.id
  ip_protocol       = "tcp"
  from_port         = var.dev_direct_app_ports[count.index]
  to_port           = var.dev_direct_app_ports[count.index]
  cidr_ipv4         = local.dev_ingress_cidrs[0]
  description       = "Dev direct access to app tier (testing)"
}

resource "aws_vpc_security_group_ingress_rule" "db_dev_direct" {
  count             = var.enable_dev_ingress && var.allow_dev_direct_to_private ? length(var.dev_direct_db_ports) : 0
  security_group_id = aws_security_group.db.id
  ip_protocol       = "tcp"
  from_port         = var.dev_direct_db_ports[count.index]
  to_port           = var.dev_direct_db_ports[count.index]
  cidr_ipv4         = local.dev_ingress_cidrs[0]
  description       = "Dev direct access to db tier (testing)"
}

resource "aws_vpc_security_group_ingress_rule" "app_icmp_from_vpc" {
  count             = var.enable_internal_ping ? 1 : 0
  security_group_id = aws_security_group.app.id
  ip_protocol       = "icmp"
  from_port         = -1
  to_port           = -1
  cidr_ipv4         = var.vpc_cidr
  description       = "ICMP within VPC"
}

resource "aws_vpc_security_group_ingress_rule" "db_icmp_from_vpc" {
  count             = var.enable_internal_ping ? 1 : 0
  security_group_id = aws_security_group.db.id
  ip_protocol       = "icmp"
  from_port         = -1
  to_port           = -1
  cidr_ipv4         = var.vpc_cidr
  description       = "ICMP within VPC"
}

resource "aws_vpc_endpoint" "s3" {
  count             = var.enable_s3_gateway_endpoint ? 1 : 0
  vpc_id            = aws_vpc.this.id
  service_name      = "com.amazonaws.${var.region}.s3"
  vpc_endpoint_type = "Gateway"
  route_table_ids   = concat([aws_route_table.public.id], aws_route_table.private[*].id)

  tags = merge(local.tags, {
    "Name" = "${var.name}-vpce-s3"
  })
}

variable "name" {
  type        = string
  description = "Base name used for resource naming"
}

variable "environment" {
  type        = string
  description = "Environment tag value"
  default     = "dev"
}

variable "region" {
  type        = string
  description = "AWS region used for some regional endpoint names (e.g., S3 gateway endpoint)"
  default     = "us-east-1"
}

variable "vpc_cidr" {
  type        = string
  description = "VPC CIDR block"
  default     = "10.0.0.0/16"
}

variable "az_count" {
  type        = number
  description = "Number of AZs to use (when azs not provided)"
  default     = 2
}

variable "azs" {
  type        = list(string)
  description = "Optional list of AZs to use"
  default     = []
}

variable "public_subnet_cidrs" {
  type        = list(string)
  description = "Optional explicit public subnet CIDRs (length must match az_count)"
  default     = []
}

variable "private_web_subnet_cidrs" {
  type        = list(string)
  description = "Optional explicit private web subnet CIDRs (length must match az_count)"
  default     = []
}

variable "private_app_subnet_cidrs" {
  type        = list(string)
  description = "Optional explicit private app subnet CIDRs (length must match az_count)"
  default     = []
}

variable "private_db_subnet_cidrs" {
  type        = list(string)
  description = "Optional explicit private db subnet CIDRs (length must match az_count)"
  default     = []
}

variable "enable_nat_gateway" {
  type        = bool
  description = "Enable NAT gateway(s) for private subnet egress"
  default     = true
}

variable "single_nat_gateway" {
  type        = bool
  description = "Use a single NAT gateway in the first public subnet for all private subnets (cost-saving for dev/test)"
  default     = true
}

variable "allow_web_http" {
  type        = bool
  description = "Allow inbound HTTP to web tier from the internet"
  default     = true
}

variable "allow_web_https" {
  type        = bool
  description = "Allow inbound HTTPS to web tier from the internet"
  default     = true
}

variable "enable_dev_ingress" {
  type        = bool
  description = "Enable dev-friendly ingress (SSH/RDP/ICMP) from dev_ingress_cidrs"
  default     = true
}

variable "dev_ingress_cidrs" {
  type        = list(string)
  description = "CIDRs allowed for dev ingress. Default opens to 0.0.0.0/0 for rapid iteration."
  default     = ["0.0.0.0/0"]
}

variable "enable_bastion_sg" {
  type        = bool
  description = "Create a bastion/management security group and allow it to access tiers via SSH"
  default     = true
}

variable "allow_dev_direct_to_private" {
  type        = bool
  description = "Allow dev CIDRs direct access to private app/db SGs on specified ports (testing convenience)"
  default     = true
}

variable "dev_direct_app_ports" {
  type        = list(number)
  description = "Ports exposed directly to dev CIDRs on app SG when allow_dev_direct_to_private is true"
  default     = [22, 8080]
}

variable "dev_direct_db_ports" {
  type        = list(number)
  description = "Ports exposed directly to dev CIDRs on db SG when allow_dev_direct_to_private is true"
  default     = [22, 5432]
}

variable "web_to_app_ports" {
  type        = list(number)
  description = "Ports allowed from web tier to app tier"
  default     = [8080]
}

variable "app_to_db_ports" {
  type        = list(number)
  description = "Ports allowed from app tier to db tier"
  default     = [5432]
}

variable "enable_internal_ping" {
  type        = bool
  description = "Allow ICMP within VPC to app/db SGs (troubleshooting)"
  default     = true
}

variable "enable_s3_gateway_endpoint" {
  type        = bool
  description = "Create an S3 gateway endpoint for faster/cheaper S3 access from private subnets"
  default     = true
}

variable "tags" {
  type        = map(string)
  description = "Additional tags to apply to resources"
  default     = {}
}

output "vpc_id" {
  value = aws_vpc.this.id
}

output "vpc_cidr" {
  value = var.vpc_cidr
}

output "igw_id" {
  value = aws_internet_gateway.this.id
}

output "public_subnet_ids" {
  value = aws_subnet.public[*].id
}

output "private_web_subnet_ids" {
  value = aws_subnet.private_web[*].id
}

output "private_app_subnet_ids" {
  value = aws_subnet.private_app[*].id
}

output "private_db_subnet_ids" {
  value = aws_subnet.private_db[*].id
}

output "public_route_table_id" {
  value = aws_route_table.public.id
}

output "private_route_table_ids" {
  value = aws_route_table.private[*].id
}

output "nat_gateway_ids" {
  value = var.enable_nat_gateway ? aws_nat_gateway.this[*].id : []
}

output "security_group_web_id" {
  value = aws_security_group.web.id
}

output "security_group_app_id" {
  value = aws_security_group.app.id
}

output "security_group_db_id" {
  value = aws_security_group.db.id
}

output "security_group_bastion_id" {
  value = var.enable_bastion_sg ? aws_security_group.bastion[0].id : null
}