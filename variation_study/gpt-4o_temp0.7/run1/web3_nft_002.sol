import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/Counters.sol";

contract NFTDrop is ERC721, Ownable {
    using Counters for Counters.Counter;
    Counters.Counter private _tokenIds;

    uint256 public constant MAX_SUPPLY = 10000;
    uint256 public constant MAX_MINT_PER_TX = 5;
    uint256 public constant NFT_PRICE = 0.05 ether;

    constructor() ERC721("NFTDrop", "NFTD") {}

    function mintNFT(uint256 numberOfTokens) public payable {
        require(numberOfTokens > 0, "Mint at least 1 NFT");
