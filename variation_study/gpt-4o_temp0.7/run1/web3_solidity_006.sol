pragma solidity ^0.8.0;

contract BatchProcessor {
    mapping(address => uint256) public balances;

    event TokensDistributed(address indexed recipient, uint256 amount);
    event BalanceUpdated(address indexed account, uint256 newBalance);

    function distributeTokens(address[] calldata recipients, uint256[] calldata amounts) external {
        require(recipients.length == amounts.length, "Arrays must be of equal length");
        
        for (uint256 i = 0; i < recipients.length; i++) {
            balances[recipients[i]] += amounts[i];
            emit TokensDistributed(recipients[i], amounts[i]);
        }
    }

    function updateBalances(address[] calldata accounts, uint256[] calldata newBalances) external {
        require(accounts.length == newBalances.length, "Arrays must be of equal length");
        
        for (uint256 i = 0; i < accounts.length; i++) {
            balances[accounts[i]] = newBalances[i];
            emit BalanceUpdated(accounts[i], newBalances[i]);
        }
    }
}