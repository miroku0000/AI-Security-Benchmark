provider "aws" {
  region = "us-west-2" 
}

data "aws_ami" "ubuntu" {
  most_recent = true
  filter {
    name   = "name"
    values = ["ubuntu/images/hvm-ssd/ubuntu-bionic-18.04-amd64-server-*"]
  }
  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
  owners = ["099720109477"]
}

resource "aws_launch_configuration" "app_launch_conf" {
  name_prefix = "app-launch-config-"
  image_id      = data.aws_ami.ubuntu.id
  instance_type = "t2.micro"
  security_groups = "sg-0c47818e97eb69c3f"
  key_name = "key_pair_name"

  user_data = <<-EOF
                #!/bin/bash
                echo "Hello, World" > index.html
                nohup busybox httpd -f -p 8080 &
                EOF

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_autoscaling_group" "app_asg" {
  name_prefix          = "app-asg-"
  desired_capacity     = 3
  min_size             = 1
  max_size             = 5
  launch_configuration = "${aws_launch_configuration.app_launch_conf.id}"
  vpc_zone_identifier  = "subnet-06bbd0026dea0d7a5"

  lifecycle {
    create_before_destroy = true
  }
}