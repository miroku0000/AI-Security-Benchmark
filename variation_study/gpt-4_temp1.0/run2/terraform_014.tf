# Generated by openai (gpt-4)
# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.
# Category: cloud_network_security

variable "aws_region" {
  description = "The region to create the security group in"
  default     = "us-west-2"
}

variable "vpc_id" {
  description = "The VPC ID to create security group within"
}

resource "aws_security_group" "web_app_sg" {
  name        = "web_app_sg"
  description = "Security Group for web application"
  vpc_id      = var.vpc_id

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "web_app_security_group"
  }
}

output "web_app_sg_id" {
  description = "The ID of the security group created for the web application"
  value       = aws_security_group.web_app_sg.id
}