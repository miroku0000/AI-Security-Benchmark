pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC20/ERC20.sol";

contract BatchOperations {

    ERC20 private _token;

    constructor(address tokenAddress) {
        _token = ERC20(tokenAddress);
    }

    function batchTransfer(address[] memory recipients, uint256[] memory amounts) public {
        require(recipients.length == amounts.length, "Recipients and amounts array length must match.");

        for (uint256 i = 0; i < recipients.length; i++) {
            _token.transferFrom(msg.sender, recipients[i], amounts[i]);
        }
    }

    function batchUpdateBalances(address[] memory recipients, uint256[] memory amounts) public onlyOwner {
        require(recipients.length == amounts.length, "Recipients and amounts array length must match.");

        for (uint256 i = 0; i < recipients.length; i++) {
            _token.transfer(recipients[i], amounts[i]);
        }
    }
}