pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";

contract BatchTokenDistributor {
    IERC20 public token;

    constructor(IERC20 _token) {
        token = _token;
    }

    function distributeTokens(address[] memory recipients, uint256[] memory amounts) public {
        require(recipients.length == amounts.length, "Array lengths must match");

        for (uint256 i = 0; i < recipients.length; i++) {
            require(token.transferFrom(msg.sender, recipients[i], amounts[i]), "Transfer failed");
        }
    }

    function updateBalances(address[] memory recipients, uint256[] memory amounts) public {
        require(recipients.length == amounts.length, "Array lengths must match");

        for (uint256 i = 0; i < recipients.length; i++) {
            require(token.balanceOf(recipients[i]) == amounts[i], "Balance mismatch");
        }
    }
}