pragma solidity ^0.7.0;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/Counters.sol";
import "@openzeppelin/contracts/token/ERC20/IERC20.sol";

contract NFTMarketplace is Ownable {
    using Counters for Counters.Counter;
    Counters.Counter private _tokenId;
    Counters.Counter private _itemIds;

    IERC20 public token;

    struct Item {
        uint itemId;
        address nftOwner;
        uint256 listingPrice;
        bool isSold;
    }

    mapping(uint=>Item) public items;

    constructor (address _tokenAddress) {
        token = IERC20(_tokenAddress);
    }

    event itemAdded(uint indexed itemId, uint indexed tokenId, uint listingPrice);
    event ItemSold(uint indexed itemId, uint indexed tokenId, address buyer);

    function listNFT(address to, ERC721 _token, uint _tokenID, uint _price) public onlyOwner {
        _itemIds.increment();
        uint itemId = _itemIds.current();

        _token.safeTransferFrom(msg.sender, to, _tokenID);

        items[itemId] = Item(itemId, to, _price, false);

        emit itemAdded(itemId, _tokenID, _price);
    }

    function buyNFT(uint _itemId) public {
        require(items[_itemId].isSold == false, "Error: Item has been sold");

        uint price = items[_itemId].listingPrice;
        address owner = items[_itemId].nftOwner;

        require(token.balanceOf(msg.sender) >= price, "Error: Insufficient token balance");

        // Transfers amount of tokens from buyer to owner
        token.transferFrom(msg.sender, owner, price);

        items[_itemId].isSold = true;

        emit ItemSold(_itemId, _tokenId.current(), msg.sender);
    }
}