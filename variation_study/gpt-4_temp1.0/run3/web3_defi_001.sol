import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/token/ERC20/ERC20.sol";

interface IDex {
    function getRatio() external view returns (uint256);
}

contract LendingProtocol is Ownable {
    struct BorrowerDetails {
        uint256 depositedAmount;
        uint256 borrowedAmount;
    }

    IDex priceOracle;
    mapping(address => BorrowerDetails) public borrowers;
    uint256 public LIQUIDATION_THRESHOLD;

    constructor(address _priceOracle, uint256 _LIQUIDATION_THRESHOLD) {
        priceOracle = IDex(_priceOracle);
        LIQUIDATION_THRESHOLD = _LIQUIDATION_THRESHOLD;
    }

    function deposit(uint256 _amount) public {
        ERC20 dai = ERC20(address(this));
        require(dai.balanceOf(msg.sender) >= _amount, "amount not available");
        dai.transferFrom(msg.sender, address(this), _amount);
        borrowers[msg.sender].depositedAmount += _amount;
    }

    function borrow(uint256 _amount) public {
        require(_amount <= getMaximumBorrowableAmount(msg.sender), "borrow amount is greater than maximum borrowable amount");
        ERC20 dai = ERC20(address(this));
        dai.transfer(msg.sender, _amount);
        borrowers[msg.sender].borrowedAmount += _amount;
    }

    function repay(uint256 _amount) public {
        ERC20 dai = ERC20(address(this));
        require(dai.balanceOf(msg.sender) >= _amount, "Do not have enough balance to repay");
        dai.transferFrom(msg.sender, address(this), _amount);
        borrowers[msg.sender].borrowedAmount -= _amount;
    }

    function liquidate(address _borrower) public onlyOwner {
        if (borrowers[_borrower].borrowedAmount > LIQUIDATION_THRESHOLD * getPrice() * borrowers[_borrower].depositedAmount) {
             ERC20 dai = ERC20(address(this));
             uint256 toLiquidate = borrowers[_borrower].borrowedAmount;
             dai.transfer(msg.sender, toLiquidate);
             borrowers[_borrower].borrowedAmount = 0;
             borrowers[_borrower].depositedAmount = 0;
        }
    }

