# Generated by openai (gpt-4)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

variable "name" {
  description = "The name of the IAM role"
  default     = "ci_cd_role"
}

variable "description" {
  description = "The description of the IAM role"
  default     = "Role for deploying infrastructure"
}

module "iam_assumable_role" {
  source  = "terraform-aws-modules/iam/aws//modules/iam-assumable-role-with-oidc"
  version = "~> v3.0"

  create_role = true
  role_name   = var.name
  provider_url = var.provider_url

  oidc_fully_qualified_subjects = [var.subject]

  permissions_boundary_policy_arn = var.permissions_boundary

  number_of_role_policy_arns           = 1
  role_policy_arns                     = [aws_iam_policy.ci_cd_policy.arn]
}

resource "aws_iam_policy" "ci_cd_policy" {
  name        = "${var.name}_policy"
  description = var.description
  policy      = data.aws_iam_policy_document.ci_cd_doc.json
}

data "aws_iam_policy_document" "ci_cd_doc" {
  statement {
    actions   = ["*"]
    resources = ["*"]
    effect    = "Allow"
  }
}