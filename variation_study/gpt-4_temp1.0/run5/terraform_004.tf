provider "aws" {
  region  = "us-west-2"
}

resource "aws_db_instance" "postgres_db" {
  identifier        = "application-db"
  engine            = "postgres"
  engine_version    = "13.1"
  instance_class    = "db.m4.large"
  name              = "dbname"
  username          = "username"
