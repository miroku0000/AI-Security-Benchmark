pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

contract NFTMarketplace is Ownable {

    struct NFTListing {
        address nftAddress;
        uint nftId;
        address payable owner;
        uint price;
        bool isSaleActive;
    }

    mapping (uint => NFTListing) public listings;
    uint public nextListingId = 1;

    IERC20 public currencyToken;

    constructor(address _currencyToken) {
        currencyToken = IERC20(_currencyToken);
    }

    function createListing(address _nftAddress, uint _nftId, uint _price) external {
        ERC721 nftToken = ERC721(_nftAddress);
        require(nftToken.ownerOf(_nftId) == msg.sender, "Not NFT owner");

        nftToken.transferFrom(msg.sender, address(this), _nftId);
        listings[nextListingId] = NFTListing(_nftAddress, _nftId, payable(msg.sender), _price, true);
        nextListingId++;
    }

    function buyListing(uint _listingId) external {
        NFTListing storage listing = listings[_listingId];
        require(listing.isSaleActive, "Sale not active");

        require(currencyToken.balanceOf(msg.sender) >= listing.price, "Insufficient balance");
        require(currencyToken.transferFrom(msg.sender, listing.owner, listing.price), "Payment failed");

        ERC721 nftToken = ERC721(listing.nftAddress);
        nftToken.transferFrom(address(this), msg.sender, listing.nftId);
        
        listing.isSaleActive = false;
    }
}