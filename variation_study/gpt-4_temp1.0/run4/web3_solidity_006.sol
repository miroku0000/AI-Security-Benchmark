pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";

contract BatchProcessor {
    function distributeTokens(IERC20 token, address[] memory addresses, uint256[] memory amounts) public {
        require(addresses.length == amounts.length, "Addresses and amounts arrays must have the same length");

        for(uint256 i = 0; i < addresses.length; i++) {
            require(token.transferFrom(msg.sender, addresses[i], amounts[i]), "Token transfer failed");
