pragma solidity ^0.8.0;

import '@uniswap/v2-periphery/contracts/interfaces/IUniswapV2Router02.sol';
import '@openzeppelin/contracts/token/ERC20/IERC20.sol';

contract LendingProtocol {

    IUniswapV2Router02 public immutable uniswapRouter;
    address public immutable daiTokenAddress;

    struct Lender {
        uint amount;
    }

    struct Borrower {
        uint borrowedAmount;
        uint collateralAmount;
    }

    mapping(address => Lender) public lenders;
    mapping(address => Borrower) public borrowers;

    constructor(address _uniswapRouter, address _daiTokenAddress) {
        uniswapRouter = IUniswapV2Router02(_uniswapRouter);
        daiTokenAddress = _daiTokenAddress;    
    }

    function lend(uint _amount) public {
        IERC20(daiTokenAddress).transferFrom(msg.sender, address(this), _amount);
        lenders[msg.sender].amount += _amount;
    }

    function borrow(uint _borrowAmount, uint _collateralAmount) public {
        uint amountIn = getEstimatedETHforDAI(_borrowAmount)[0];
        require(_collateralAmount >= amountIn, 'Not enough collateral');
        require(lenders[address(this)].amount >= _borrowAmount, 'Not enough liquidity');

        IERC20(daiTokenAddress).transfer(msg.sender, _borrowAmount);
        lenders[msg.sender].amount -= _borrowAmount;
        lenders[address(this)].amount += _borrowAmount;

        borrowers[msg.sender] = Borrower(_borrowAmount, _collateralAmount);
    }

    function payback() public {
        uint amountToRepay = borrowers[msg.sender].borrowedAmount;
        IERC20(daiTokenAddress).transferFrom(msg.sender, address(this), amountToRepay);
        lenders[address(this)].amount -= amountToRepay;
        delete borrowers[msg.sender];
    }

    function getEstimatedETHforDAI(uint daiAmount) public view returns (uint[] memory) {
        address[] memory path = new address[](2);
        path[0] = uniswapRouter.WETH();
        path[1] = daiTokenAddress;
        
        return uniswapRouter.getAmountsIn(daiAmount, path);
    }
}