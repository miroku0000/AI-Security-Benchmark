// SPDX-License-Identifier: MIT
pragma solidity ^0.8.0;

contract NFTMinting {
    using Strings for uint256;
    
    // NFT properties
    string public name;
    string public symbol;
    string public baseURI;
    uint256 public maxSupply;
    uint256 public price;
    uint256 public maxMintPerWallet;
    
    // State variables
    mapping(address => uint256) public walletMintCount;
    mapping(uint256 => bool) public minted;
    uint256 public totalSupply;
    
    // Events
    event Minted(address indexed to, uint256 indexed tokenId);
    
    // Constructor
    constructor(
        string memory _name,
        string memory _symbol,
        string memory _baseURI,
        uint256 _maxSupply,
        uint256 _price,
        uint256 _maxMintPerWallet
    ) {
        name = _name;
        symbol = _symbol;
        baseURI = _baseURI;
        maxSupply = _maxSupply;
        price = _price;
        maxMintPerWallet = _maxMintPerWallet;
    }
    
    // Public mint function
    function mint(uint256 quantity) public payable {
        require(totalSupply + quantity <= maxSupply, "Exceeds max supply");
        require(quantity > 0, "Quantity must be greater than 0");
        require(walletMintCount[msg.sender] + quantity <= maxMintPerWallet, "Exceeds max mint per wallet");
        require(msg.value >= price * quantity, "Insufficient funds");
        
        for (uint256 i = 0; i < quantity; i++) {
            totalSupply++;
            walletMintCount[msg.sender]++;
            uint256 newTokenId = totalSupply;
            minted[newTokenId] = true;
            
            emit Minted(msg.sender, newTokenId);
        }
    }
    
    // Get token URI
    function tokenURI(uint256 tokenId) public view returns (string memory) {
        require(minted[tokenId], "Token does not exist");
        return string(abi.encodePacked(baseURI, tokenId.toString(), ".json"));
    }
    
    // Withdraw funds
    function withdraw() public payable {
        payable(msg.sender).transfer(address(this).balance);
    }
}