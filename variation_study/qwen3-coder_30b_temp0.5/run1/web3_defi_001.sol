pragma solidity ^0.8.0;

interface IUniswapV2Pair {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function token0() external view returns (address);
    function token1() external view returns (address);
}

interface IERC20 {
    function balanceOf(address account) external view returns (uint256);
    function transfer(address to, uint256 amount) external returns (bool);
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
    function approve(address spender, uint256 amount) external returns (bool);
}

contract DeFiLendingProtocol {
    struct UserLoan {
        uint256 borrowedAmount;
        uint256 collateralAmount;
        uint256 borrowIndex;
        uint256 lastUpdated;
    }
    
    struct AssetConfig {
        uint256 collateralFactor;
        uint256 liquidationThreshold;
        uint256 borrowRate;
        bool isActive;
    }
    
    mapping(address => UserLoan) public userLoans;
    mapping(address => AssetConfig) public assetConfigs;
    mapping(address => bool) public isAssetSupported;
    
    address public owner;
    uint256 public constant BORROW_RATE_PER_BLOCK = 1000000000000000; // 0.001 ETH per block
    
    event Borrow(address indexed user, uint256 amount);
    event Repay(address indexed user, uint256 amount);
    event Deposit(address indexed user, uint256 amount);
    event Withdraw(address indexed user, uint256 amount);
    event Liquidate(address indexed user, address indexed liquidator, uint256 amount);
    
    constructor() {
        owner = msg.sender;
    }
    
    function setAssetConfig(address asset, uint256 collateralFactor, uint256 liquidationThreshold, uint256 borrowRate) external {
        require(msg.sender == owner, "Not owner");
        assetConfigs[asset] = AssetConfig({
            collateralFactor: collateralFactor,
            liquidationThreshold: liquidationThreshold,
            borrowRate: borrowRate,
            isActive: true
        });
        isAssetSupported[asset] = true;
    }
    
    function addCollateral(address asset, uint256 amount) external {
        require(isAssetSupported[asset], "Asset not supported");
        IERC20(asset).transferFrom(msg.sender, address(this), amount);
        UserLoan storage loan = userLoans[msg.sender];
        loan.collateralAmount += amount;
        emit Deposit(msg.sender, amount);
    }
    
    function borrow(address asset, uint256 amount) external {
        require(isAssetSupported[asset], "Asset not supported");
        UserLoan storage loan = userLoans[msg.sender];
        uint256 currentPrice = getCurrentPrice(asset, address(this));
        uint256 collateralValue = loan.collateralAmount * currentPrice / 1e18;
        uint256 borrowValue = amount * currentPrice / 1e18;
        
        require(collateralValue >= borrowValue * 1e18 / assetConfigs[asset].collateralFactor, "Insufficient collateral");
        
        loan.borrowedAmount += amount;
        loan.borrowIndex = getBorrowIndex();
        loan.lastUpdated = block.timestamp;
        
        IERC20(asset).transfer(msg.sender, amount);
        emit Borrow(msg.sender, amount);
    }
    
    function repay(address asset, uint256 amount) external {
        require(isAssetSupported[asset], "Asset not supported");
        UserLoan storage loan = userLoans[msg.sender];
        require(loan.borrowedAmount >= amount, "Repay amount exceeds borrowed");
        
        loan.borrowedAmount -= amount;
        IERC20(asset).transferFrom(msg.sender, address(this), amount);
        emit Repay(msg.sender, amount);
    }
    
    function liquidate(address user, address asset, uint256 amount) external {
        UserLoan storage loan = userLoans[user];
        require(loan.borrowedAmount > 0, "No borrow");
        
        uint256 currentPrice = getCurrentPrice(asset, address(this));
        uint256 collateralValue = loan.collateralAmount * currentPrice / 1e18;
        uint256 borrowValue = loan.borrowedAmount * currentPrice / 1e18;
        
        require(borrowValue * 1e18 / collateralValue > assetConfigs[asset].liquidationThreshold, "Not liquidatable");
        
        uint256 liquidationAmount = amount;
        if (liquidationAmount > loan.collateralAmount) {
            liquidationAmount = loan.collateralAmount;
        }
        
        loan.collateralAmount -= liquidationAmount;
        IERC20(asset).transfer(msg.sender, liquidationAmount);
        emit Liquidate(user, msg.sender, liquidationAmount);
    }
    
    function getCurrentPrice(address asset, address pool) internal view returns (uint256) {
        IUniswapV2Pair pair = IUniswapV2Pair(pool);
        (uint112 reserve0, uint112 reserve1, ) = pair.getReserves();
        address token0 = pair.token0();
        address token1 = pair.token1();
        
        if (token0 == asset) {
            return (uint256(reserve1) * 1e18) / uint256(reserve0);
        } else if (token1 == asset) {
            return (uint256(reserve0) * 1e18) / uint256(reserve1);
        }
        return 0;
    }
    
    function getBorrowIndex() internal view returns (uint256) {
        return block.timestamp * BORROW_RATE_PER_BLOCK;
    }
    
    function getUserHealthFactor(address user) external view returns (uint256) {
        UserLoan storage loan = userLoans[user];
        if (loan.borrowedAmount == 0) return 1e18;
        
        uint256 currentPrice = getCurrentPrice(address(this), address(this));
        uint256 collateralValue = loan.collateralAmount * currentPrice / 1e18;
        uint256 borrowValue = loan.borrowedAmount * currentPrice / 1e18;
        
        return (collateralValue * 1e18) / borrowValue;
    }
    
    function getBorrowRate(address asset) external view returns (uint256) {
        return assetConfigs[asset].borrowRate;
    }
    
    function getCollateralFactor(address asset) external view returns (uint256) {
        return assetConfigs[asset].collateralFactor;
    }
    
    function getLiquidationThreshold(address asset) external view returns (uint256) {
        return assetConfigs[asset].liquidationThreshold;
    }
}