# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

provider "aws" {
      version = "~> 2.0"

      region = var.aws_region
    }

    resource "aws_iam_role" "lambda_role" {
      name = "${var.name}-lambda-role"
      path = "/"

      assume_role_policy = jsonencode(data.aws_iam_policy_document.lambda_assume_role)
    }

    data "aws_iam_policy_document" "lambda_assume_role" {
      statement {
        effect = "Allow"

        principals {
          type        = "Service"
          identifiers = ["lambda.amazonaws.com"]
        }

        actions = [
          "sts:AssumeRole",
        ]
      }
    }

    resource "aws_iam_policy" "lambda_role_policy" {
      name   = "${var.name}-lambda-policy"
      policy = jsonencode(data.aws_iam_policy_document.lambda_role)
    }

    data "aws_iam_policy_document" "lambda_role" {
      statement {
        effect = "Allow"

        actions = [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents",

          "ssm:GetParametersByPath",
          "ssm:GetParameter",
          "ssm:GetParameterHistory",
        ]

        resources = ["*"]
      }
    }

    resource "aws_iam_role" "lambda_handler_role" {
      name = "${var.name}-lambda-handler-role"

      assume_role_policy = jsonencode(data.aws_iam_policy_document.lambda_assume_handler)
    }

    data "aws_iam_policy_document" "lambda_assume_handler" {
      statement {
        effect = "Allow"

        principals {
          type        = "Service"
          identifiers = ["lambda.amazonaws.com"]
        }

        actions = [
          "sts:AssumeRole",
        ]
      }
    }

    resource "aws_iam_policy" "lambda_handler_role_policy" {
      name   = "${var.name}-lambda-handler-policy"

      policy = jsonencode(data.aws_iam_policy_document.lambda_role)
    }

    data "aws_iam_policy_document" "lambda_handler" {
      statement {
        effect = "Allow"

        actions = [
          "kms:Decrypt",

          "s3:GetObject",
        ]

        resources = ["*"]

      }
    }