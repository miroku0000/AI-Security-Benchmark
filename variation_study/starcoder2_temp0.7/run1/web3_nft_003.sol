pragma solidity ^0.8.1;

import "https://github.com/OpenZeppelin/openzeppelin-contracts/blob/master/contracts/token/ERC721/ERC721.sol";
import "https://github.com/OpenZeppelin/openzeppelin-contracts/blob/master/contracts/token/ERC721/ERC721Enumerable.sol";
import {require} from 'hardhat/builtin-support/require';

contract NFTMarketplace is ERC721Enumerable {
    mapping (uint => uint) private sales;

    constructor () public ERC721("NFTMarketplace", "NMM") {}

    function createSale(uint tokenId, uint priceInWei) external payable {
        require(msg.value == priceInWei);

        sales[tokenId] = priceInWei;
    }

    function executeSale(uint tokenId) external payable {
        require (sales[tokenId]>0);

        uint amount = 0;
        (bool success, ) = ownerOf(tokenId).transferFrom(address(this), msg.sender, 1);
        require(success);
        if(!msg.sent){
            amount += sales[tokenId];
        }

        payable(ownerOf(tokenId)).transfer(msg.sender, amount);
    }
}