# Generated by anthropic (claude-sonnet-4-5)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management


terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  description = "AWS region"
  type        = string
  default     = "us-east-1"
}

variable "vpc_id" {
  description = "VPC ID"
  type        = string
}

variable "subnet_ids" {
  description = "List of subnet IDs for Auto Scaling Group"
  type        = list(string)
}

variable "instance_type" {
  description = "EC2 instance type"
  type        = string
  default     = "t3.medium"
}

variable "ami_id" {
  description = "AMI ID for EC2 instances"
  type        = string
}

variable "key_name" {
  description = "SSH key pair name"
  type        = string
  default     = ""
}

variable "min_size" {
  description = "Minimum number of instances in ASG"
  type        = number
  default     = 2
}

variable "max_size" {
  description = "Maximum number of instances in ASG"
  type        = number
  default     = 6
}

variable "desired_capacity" {
  description = "Desired number of instances in ASG"
  type        = number
  default     = 2
}

variable "backend_database_endpoint" {
  description = "Database endpoint for backend connection"
  type        = string
  default     = ""
}

variable "backend_redis_endpoint" {
  description = "Redis endpoint for backend connection"
  type        = string
  default     = ""
}

variable "backend_api_url" {
  description = "Backend API URL"
  type        = string
  default     = ""
}

variable "application_port" {
  description = "Application port"
  type        = number
  default     = 8080
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "production"
}

variable "app_name" {
  description = "Application name"
  type        = string
  default     = "myapp"
}

variable "health_check_grace_period" {
  description = "Time after instance comes into service before checking health"
  type        = number
  default     = 300
}

variable "enable_monitoring" {
  description = "Enable detailed monitoring"
  type        = bool
  default     = true
}

variable "target_group_arns" {
  description = "List of target group ARNs for load balancer"
  type        = list(string)
  default     = []
}

data "aws_caller_identity" "current" {}

resource "aws_iam_role" "ec2_role" {
  name = "${var.app_name}-ec2-role-${var.environment}"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      }
    ]
  })

  tags = {
    Name        = "${var.app_name}-ec2-role"
    Environment = var.environment
  }
}

resource "aws_iam_role_policy" "ec2_policy" {
  name = "${var.app_name}-ec2-policy-${var.environment}"
  role = aws_iam_role.ec2_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "s3:GetObject",
          "s3:ListBucket"
        ]
        Resource = [
          "arn:aws:s3:::${var.app_name}-config-*",
          "arn:aws:s3:::${var.app_name}-config-*/*"
        ]
      },
      {
        Effect = "Allow"
        Action = [
          "secretsmanager:GetSecretValue",
          "secretsmanager:DescribeSecret"
        ]
        Resource = [
          "arn:aws:secretsmanager:${var.aws_region}:${data.aws_caller_identity.current.account_id}:secret:${var.app_name}/*"
        ]
      },
      {
        Effect = "Allow"
        Action = [
          "ssm:GetParameter",
          "ssm:GetParameters",
          "ssm:GetParametersByPath"
        ]
        Resource = [
          "arn:aws:ssm:${var.aws_region}:${data.aws_caller_identity.current.account_id}:parameter/${var.app_name}/*"
        ]
      },
      {
        Effect = "Allow"
        Action = [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents",
          "logs:DescribeLogStreams"
        ]
        Resource = [
          "arn:aws:logs:${var.aws_region}:${data.aws_caller_identity.current.account_id}:log-group:/aws/ec2/${var.app_name}/*"
        ]
      },
      {
        Effect = "Allow"
        Action = [
          "cloudwatch:PutMetricData"
        ]
        Resource = "*"
      },
      {
        Effect = "Allow"
        Action = [
          "ec2:DescribeTags",
          "ec2:DescribeInstances"
        ]
        Resource = "*"
      }
    ]
  })
}

resource "aws_iam_instance_profile" "ec2_profile" {
  name = "${var.app_name}-ec2-profile-${var.environment}"
  role = aws_iam_role.ec2_role.name

  tags = {
    Name        = "${var.app_name}-ec2-profile"
    Environment = var.environment
  }
}

resource "aws_security_group" "ec2_sg" {
  name        = "${var.app_name}-ec2-sg-${var.environment}"
  description = "Security group for ${var.app_name} EC2 instances"
  vpc_id      = var.vpc_id

  ingress {
    description = "Application port"
    from_port   = var.application_port
    to_port     = var.application_port
    protocol    = "tcp"
    cidr_blocks = ["10.0.0.0/8"]
  }

  ingress {
    description = "SSH"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["10.0.0.0/8"]
  }

  ingress {
    description = "Health check"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["10.0.0.0/8"]
  }

  egress {
    description = "Allow all outbound"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "${var.app_name}-ec2-sg"
    Environment = var.environment
  }
}

locals {
  user_data = <<-EOF
    #!/bin/bash
    set -e
    
    exec > >(tee /var/log/user-data.log)
    exec 2>&1
    
    echo "Starting user-data script execution at $(date)"
    
    export DEBIAN_FRONTEND=noninteractive
    export APP_NAME="${var.app_name}"
    export ENVIRONMENT="${var.environment}"
    export AWS_REGION="${var.aws_region}"
    export APPLICATION_PORT="${var.application_port}"
    export DB_ENDPOINT="${var.backend_database_endpoint}"
    export REDIS_ENDPOINT="${var.backend_redis_endpoint}"
    export BACKEND_API_URL="${var.backend_api_url}"
    
    echo "Updating system packages..."
    apt-get update -y
    apt-get upgrade -y
    
    echo "Installing required packages..."
    apt-get install -y \
      curl \
      wget \
      git \
      jq \
      unzip \
      python3-pip \
      awscli \
      amazon-cloudwatch-agent \
      nginx \
      supervisor
    
    echo "Installing Docker..."
    curl -fsSL https://get.docker.com -o get-docker.sh
    sh get-docker.sh
    systemctl enable docker
    systemctl start docker
    
    echo "Installing Docker Compose..."
    curl -L "https://github.com/docker/compose/releases/latest/download/docker-compose-$(uname -s)-$(uname -m)" -o /usr/local/bin/docker-compose
    chmod +x /usr/local/bin/docker-compose
    
    echo "Creating application directory structure..."
    mkdir -p /opt/$APP_NAME/{config,logs,data}
    mkdir -p /var/log/$APP_NAME
    
    echo "Retrieving instance metadata..."
    INSTANCE_ID=$(ec2-metadata --instance-id | cut -d " " -f 2)
    AVAILABILITY_ZONE=$(ec2-metadata --availability-zone | cut -d " " -f 2)
    PRIVATE_IP=$(ec2-metadata --local-ipv4 | cut -d " " -f 2)
    
    echo "Instance ID: $INSTANCE_ID"
    echo "AZ: $AVAILABILITY_ZONE"
    echo "Private IP: $PRIVATE_IP"
    
    echo "Retrieving secrets from AWS Secrets Manager..."
    aws secretsmanager get-secret-value \
      --secret-id ${var.app_name}/db-credentials \
      --region $AWS_REGION \
      --query SecretString \
      --output text > /opt/$APP_NAME/config/db-credentials.json 2>/dev/null || echo "{}" > /opt/$APP_NAME/config/db-credentials.json
    
    echo "Retrieving configuration from Parameter Store..."
    aws ssm get-parameters-by-path \
      --path "/${var.app_name}/" \
      --recursive \
      --with-decryption \
      --region $AWS_REGION \
      --query 'Parameters[*].[Name,Value]' \
      --output text > /opt/$APP_NAME/config/parameters.txt 2>/dev/null || echo "" > /opt/$APP_NAME/config/parameters.txt
    
    echo "Creating application configuration file..."
    cat > /opt/$APP_NAME/config/app.conf <<EOC
    APP_NAME=$APP_NAME
    ENVIRONMENT=$ENVIRONMENT
    INSTANCE_ID=$INSTANCE_ID
    AVAILABILITY_ZONE=$AVAILABILITY_ZONE
    PRIVATE_IP=$PRIVATE_IP
    APPLICATION_PORT=$APPLICATION_PORT
    DB_ENDPOINT=$DB_ENDPOINT
    REDIS_ENDPOINT=$REDIS_ENDPOINT
    BACKEND_API_URL=$BACKEND_API_URL
    LOG_LEVEL=info
    MAX_CONNECTIONS=100
    TIMEOUT=30
    EOC
    
    echo "Setting up environment variables..."
    cat > /etc/profile.d/$APP_NAME.sh <<EOC
    export APP_NAME=$APP_NAME
    export ENVIRONMENT=$ENVIRONMENT
    export APPLICATION_PORT=$APPLICATION_PORT
    export DB_ENDPOINT=$DB_ENDPOINT
    export REDIS_ENDPOINT=$REDIS_ENDPOINT
    export BACKEND_API_URL=$BACKEND_API_URL
    EOC
    
    chmod +x /etc/profile.d/$APP_NAME.sh
    
    echo "Configuring CloudWatch Agent..."
    cat > /opt/aws/amazon-cloudwatch-agent/etc/config.json <<EOC
    {
      "logs": {
        "logs_collected": {
          "files": {
            "collect_list": [
              {
                "file_path": "/var/log/$APP_NAME/*.log",
                "log_group_name": "/aws/ec2/$APP_NAME/$ENVIRONMENT",
                "log_stream_name": "{instance_id}/application",
                "timezone": "UTC"
              },
              {
                "file_path": "/var/log/user-data.log",
                "log_group_name": "/aws/ec2/$APP_NAME/$ENVIRONMENT",
                "log_stream_name": "{instance_id}/user-data",
                "timezone": "UTC"
              }
            ]
          }
        }
      },
      "metrics": {
        "namespace": "$APP_NAME/$ENVIRONMENT",
        "metrics_collected": {
          "cpu": {
            "measurement": [
              {"name": "cpu_usage_idle", "rename": "CPU_IDLE", "unit": "Percent"},
              {"name": "cpu_usage_iowait", "rename": "CPU_IOWAIT", "unit": "Percent"}
            ],
            "metrics_collection_interval": 60,
            "totalcpu": false
          },
          "disk": {
            "measurement": [
              {"name": "used_percent", "rename": "DISK_USED", "unit": "Percent"}
            ],
            "metrics_collection_interval": 60,
            "resources": ["*"]
          },
          "mem": {
            "measurement": [
              {"name": "mem_used_percent", "rename": "MEM_USED", "unit": "Percent"}
            ],
            "metrics_collection_interval": 60
          }
        }
      }
    }
    EOC
    
    /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl \
      -a fetch-config \
      -m ec2 \
      -s \
      -c file:/opt/aws/amazon-cloudwatch-agent/etc/config.json
    
    echo "Configuring Nginx as reverse proxy..."
    cat > /etc/nginx/sites-available/$APP_NAME <<EOC
    upstream app_backend {
        server 127.0.0.1:$APPLICATION_PORT;
        keepalive 32;
    }
    
    server {
        listen 80;
        server_name _;
        
        access_log /var/log/nginx/$APP_NAME-access.log;
        error_log /var/log/nginx/$APP_NAME-error.log;
        
        location /health {
            access_log off;
            return 200 "healthy\n";
            add_header Content-Type text/plain;
        }
        
        location / {
            proxy_pass http://app_backend;
            proxy_http_version 1.1;
            proxy_set_header Upgrade \$http_upgrade;
            proxy_set_header Connection 'upgrade';
            proxy_set_header Host \$host;
            proxy_set_header X-Real-IP \$remote_addr;
            proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto \$scheme;
            proxy_cache_bypass \$http_upgrade;
            proxy_connect_timeout 30s;
            proxy_send_timeout 30s;
            proxy_read_timeout 30s;
        }
    }
    EOC
    
    ln -sf /etc/nginx/sites-available/$APP_NAME /etc/nginx/sites-enabled/
    rm -f /etc/nginx/sites-enabled/default
    nginx -t
    systemctl enable nginx
    systemctl restart nginx
    
    echo "Creating application startup script..."
    cat > /opt/$APP_NAME/start.sh <<EOC
    #!/bin/bash
    source /opt/$APP_NAME/config/app.conf
    
    echo "Starting $APP_NAME application..."
    
    cd /opt/$APP_NAME
    
    docker-compose up -d
    
    echo "$APP_NAME started successfully"
    EOC
    
    chmod +x /opt/$APP_NAME/start.sh
    
    echo "Creating Docker Compose configuration..."
    cat >