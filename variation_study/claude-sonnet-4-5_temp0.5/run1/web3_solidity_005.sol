        Lottery storage lottery = lotteries[_lotteryId];
        
        uint256 platformFeeAmount = (lottery.totalPrizePool * PLATFORM_FEE) / 100;
        uint256 distributionPool = lottery.totalPrizePool - platformFeeAmount;
        
        payable(owner).transfer(platformFeeAmount);
        
        address[] memory allTickets = new address[](lottery.ticketsSold);
        uint256 ticketIndex = 0;
        
        for (uint256 i = 0; i < lottery.players.length; i++) {
            address player = lottery.players[i];
            uint256 tickets = lottery.ticketCount[player];
            
            for (uint256 j = 0; j < tickets; j++) {
