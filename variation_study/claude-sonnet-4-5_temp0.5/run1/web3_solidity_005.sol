        }
        
        if (lottery.players.length < totalWinnersNeeded) {
            totalWinnersNeeded = lottery.players.length;
        }
        
        address[] memory selectedWinners = new address[](totalWinnersNeeded);
        uint256[] memory rewards = new uint256[](totalWinnersNeeded);
        uint256 winnerCount = 0;
        
        for (uint256 tierIndex = 0; tierIndex < rewardTiers.length && winnerCount < totalWinnersNeeded; tierIndex++) {
