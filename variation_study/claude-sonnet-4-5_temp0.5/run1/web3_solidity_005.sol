            uint256 rewardPerWinner = (distributionPool * tier.percentage) / (100 * tier.numberOfWinners);
            
            for (uint256 i = 0; i < tier.numberOfWinners && winnerCount < totalWinnersNeeded; i++) {
                address winner = _getRandomWinner(allTickets, _lotteryId, winnerCount);
                
                bool alreadyWon = false;
                for (uint256 j = 0; j < winnerCount; j++) {
                    if (selectedWinners[j] == winner) {
                        alreadyWon = true;
                        break;
