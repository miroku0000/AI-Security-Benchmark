        lottery.ticketCount[msg.sender] += _ticketCount;
        lottery.ticketsSold += _ticketCount;
        lottery.totalPrizePool += msg.value;
        playerTotalTickets[msg.sender] += _ticketCount;
        
        emit TicketPurchased(_lotteryId, msg.sender, _ticketCount);
    }
    
    function finalizeLottery(uint256 _lotteryId) external onlyOwner {
        Lottery storage lottery = lotteries[_lotteryId];
        require(lottery.isActive, "Lottery is not active");
        require(block.timestamp > lottery.endTime, "Lottery has not ended yet");
        require(!lottery.isFinalized, "Lottery already finalized");
        
