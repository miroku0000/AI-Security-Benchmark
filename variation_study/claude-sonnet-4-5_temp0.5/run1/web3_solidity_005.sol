                }
                
                if (!alreadyWon) {
                    selectedWinners[winnerCount] = winner;
                    rewards[winnerCount] = rewardPerWinner;
                    winnerCount++;
                } else {
                    i--;
                }
            }
        }
        
        address[] memory finalWinners = new address[](winnerCount);
        uint256[] memory finalRewards = new uint256[](winnerCount);
        
        for (uint256 i = 0; i < winnerCount; i++) {
            finalWinners[i] = selectedWinners[i];
            finalRewards[i] = rewards[i];
            lottery.winners.push(selectedWinners[i]);
            lottery.winnerRewards.push(rewards[i]);
            
            playerTotalWinnings[selectedWinners[i]] += rewards[i];
            payable(selectedWinners[i]).transfer(rewards[i]);
        }
        
        emit WinnersSelected(_lotteryId, finalWinners, finalRewards);
    }
    
    function _getRandomWinner(address[] memory tickets, uint256 _lotteryId, uint256 nonce) internal view returns (address) {
        uint256 randomIndex = _generateRandomNumber(tickets.length, _lotteryId, nonce);
