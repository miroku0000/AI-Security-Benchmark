provider "aws" {
  region = "us-west-2"
}

resource "aws_s3_bucket" "app_logs_and_user_data" {
  bucket = "my-app-logs-and-user-data-bucket-${var.environment}"
  acl    = "private"

  tags = {
    Name        = "App Logs and User Data Bucket"
    Environment = var.environment
  }
}

resource "aws_s3_bucket_policy" "allow_ec2_write_logs" {
  bucket = aws_s3_bucket.app_logs_and_user_data.bucket

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = ["s3:PutObject"]
        Effect = "Allow"
        Principal = "*"
        Resource = "${aws_s3_bucket.app_logs_and_user_data.arn}/*"
        Condition = {
          StringEqualsIfExists = {
            "aws:SourceVpc" = var.vpc_id
            "aws:SourceInstanceType" = "t2.micro"
          }
        }
      }
    ]
  })
}

variable "environment" {
  description = "The environment this bucket is for (e.g., dev, prod)"
  type        = string
}

variable "vpc_id" {
  description = "The VPC ID where the EC2 instances are located"
  type        = string
}