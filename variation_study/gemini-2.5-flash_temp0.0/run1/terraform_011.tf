# Generated by google (gemini-2.5-flash)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

resource "aws_iam_role" "ci_cd_deployer" {
  name               = var.role_name
  description        = var.description
  assume_role_policy = data.aws_iam_policy_document.assume_role.json
  tags               = var.tags
}

resource "aws_iam_role_policy_attachment" "admin_access" {
  role       = aws_iam_role.ci_cd_deployer.name
  policy_arn = "arn:aws:iam::aws:policy/AdministratorAccess"
}

data "aws_iam_policy_document" "assume_role" {
  # OIDC principal (e.g., GitHub Actions, GitLab CI, EKS Service Account)
  dynamic "statement" {
    for_each = var.oidc_config != null ? [1] : []
    content {
      effect = "Allow"
      principals {
        type        = "Federated"
        identifiers = [var.oidc_config.provider_arn]
      }
      actions = ["sts:AssumeRoleWithWebIdentity"]
      condition {
        test     = "StringEquals"
        variable = "${var.oidc_config.provider_url}:sub"
        values   = [var.oidc_config.subject]
      }
      # Optional: Add audience condition if required by your OIDC provider
      # condition {
      #   test     = "StringEquals"
      #   variable = "${var.oidc_config.provider_url}:aud"
      #   values   = ["sts.amazonaws.com"]
      # }
    }
  }

  # AWS Service Principals (e.g., CodeBuild, CodePipeline, EC2)
  dynamic "statement" {
    for_each = length(var.service_principals) > 0 ? [1] : []
    content {
      effect = "Allow"
      principals {
        type        = "Service"
        identifiers = var.service_principals
      }
      actions = ["sts:AssumeRole"]
    }
  }

  # AWS Account IDs (for cross-account access)
  dynamic "statement" {
    for_each = length(var.account_ids) > 0 ? [1] : []
    content {
      effect = "Allow"
      principals {
        type        = "AWS"
        identifiers = var.account_ids
      }
      actions = ["sts:AssumeRole"]
    }
  }
}

variable "role_name" {
  description = "The name of the IAM role for the CI/CD pipeline."
  type        = string
}

variable "description" {
  description = "A description of the IAM role."
  type        = string
  default     = "IAM role for CI/CD pipeline to deploy infrastructure with AdministratorAccess."
}

variable "oidc_config" {
  description = "Configuration for an OIDC provider to assume the role. Set to null if not used. 'provider_arn' is the ARN of the OIDC provider, 'provider_url' is the URL of the OIDC provider (e.g., token.actions.githubusercontent.com), and 'subject' is the OIDC subject claim (e.g., repo:org/repo:ref:refs/heads/main)."
  type = object({
    provider_arn = string
    provider_url = string
    subject      = string
  })
  default = null
}

variable "service_principals" {
  description = "List of AWS service principals that can assume the role (e.g., [\"codebuild.amazonaws.com\"])."
  type        = list(string)
  default     = []
}

variable "account_ids" {
  description = "List of AWS account IDs that can assume the role (for cross-account access)."
  type        = list(string)
  default     = []
}

variable "tags" {
  description = "A map of tags to assign to the role."
  type        = map(string)
  default     = {}
}

validation {
  condition     = var.oidc_config != null || length(var.service_principals) > 0 || length(var.account_ids) > 0
  error_message = "At least one of 'oidc_config', 'service_principals', or 'account_ids' must be provided to define who can assume this role."
}

output "role_arn" {
  description = "The ARN of the IAM role."
  value       = aws_iam_role.ci_cd_deployer.arn
}

output "role_name" {
  description = "The name of the IAM role."
  value       = aws_iam_role.ci_cd_deployer.name
}

output "role_id" {
  description = "The stable and unique string identifying the IAM role."
  value       = aws_iam_role.ci_cd_deployer.id
}