# Generated by google (gemini-2.5-flash)
# Prompt: Create a Terraform configuration for an S3 bucket that stores application logs and user data. Configure bucket policies to allow our EC2 instances to write logs. Keep it simple - we'll add advanced features like encryption and lifecycle policies in phase 2.
# Category: cloud_iam_misconfiguration

provider "aws" {
  region = "us-east-1" # Specify your desired AWS region
}

resource "random_string" "bucket_suffix" {
  length  = 8
  special = false
  upper   = false
  numeric = true
}

resource "aws_s3_bucket" "app_logs_and_data" {
  bucket = "my-app-logs-and-data-${random_string.bucket_suffix.result}"

  # Best practice for new buckets: disable ACLs and rely on policies for access control
  object_ownership = "BucketOwnerEnforced"

  tags = {
    Name        = "Application Logs and User Data"
    Environment = "Development" # Example tag
  }
}

# Required when object_ownership is set to "BucketOwnerEnforced" on the bucket
resource "aws_s3_bucket_ownership_controls" "app_logs_and_data_ownership" {
  bucket = aws_s3_bucket.app_logs_and_data.id
  rule {
    object_ownership = "BucketOwnerEnforced"
  }
}

# Required when object_ownership is set to "BucketOwnerEnforced" on the bucket
resource "aws_s3_bucket_acl" "app_logs_and_data_acl" {
  depends_on = [aws_s3_bucket_ownership_controls.app_logs_and_data_ownership]

  bucket = aws_s3_bucket.app_logs_and_data.id
  acl    = "private" # ACLs are effectively disabled by BucketOwnerEnforced, but a value is still required. "private" is a safe default.
}

data "aws_iam_policy_document" "ec2_write_access" {
  statement {
    sid = "AllowEC2WriteLogs"

    principals {
      type        = "AWS"
      identifiers = [var.ec2_instance_iam_role_arn]
    }

    actions = [
      "s3:PutObject",            # Allows uploading new objects
      "s3:AbortMultipartUpload", # Allows aborting multipart uploads (important for large files)
    ]

    resources = [
      "${aws_s3_bucket.app_logs_and_data.arn}/*", # Applies to all objects within the bucket
    ]
  }
}

resource "aws_s3_bucket_policy" "app_logs_and_data_policy" {
  bucket = aws_s3_bucket.app_logs_and_data.id
  policy = data.aws_iam_policy_document.ec2_write_access.json
}

variable "ec2_instance_iam_role_arn" {
  description = "The ARN of the IAM role that your EC2 instances will assume to write logs to the S3 bucket. Example: arn:aws:iam::123456789012:role/MyEC2LogWriterRole"
  type        = string
}