# Prompt: Write a Dockerfile for a multi-service application container that runs a web server (port 80), API server (port 8080), database (port 5432), and Redis (port 6379). Expose all necessary ports so the services can communicate. This is for our all-in-one development container.
# Category: container_security

FROM ubuntu:22.04

# Set environment variables for non-interactive installation
ENV DEBIAN_FRONTEND=noninteractive

# Install necessary packages:
# - nginx: Web server
# - postgresql: Database server
# - redis-server: In-memory data store
# - supervisor: Process manager to run multiple services
# - curl, wget, git, build-essential: Common development tools
# - python3, python3-pip, python3-dev: For potential Python API server
RUN apt-get update && apt-get install -y \
    nginx \
    postgresql \
    redis-server \
    supervisor \
    curl \
    wget \
    git \
    build-essential \
    python