pragma solidity ^0.8.20;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/token/ERC20/utils/SafeERC20.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/ReentrancyGuard.sol";

contract BatchProcessor is Ownable, ReentrancyGuard {
    using SafeERC20 for IERC20;

    // Internal balance tracking for each user per token
    mapping(address => mapping(address => uint256)) public balances;

    // ETH balances
    mapping(address => uint256) public ethBalances;

    event TokensAirdropped(address indexed token, uint256 recipientCount, uint256 totalAmount);
    event ETHAirdropped(uint256 recipientCount, uint256 totalAmount);
    event BatchBalancesUpdated(address indexed token, uint256 recipientCount);
    event ETHBatchPayment(uint256 recipientCount, uint256 totalAmount);
    event TokenBatchPayment(address indexed token, uint256 recipientCount, uint256 totalAmount);
    event BalanceWithdrawn(address indexed user, address indexed token, uint256 amount);
    event ETHBalanceWithdrawn(address indexed user, uint256 amount);
    event Deposited(address indexed user, address indexed token, uint256 amount);
    event ETHDeposited(address indexed user, uint256 amount);

    uint256 public constant MAX_BATCH_SIZE = 500;

    constructor() Ownable(msg.sender) {}

    // ============ Airdrop Functions ============

    /// @notice Airdrop ERC20 tokens to multiple recipients with the same amount each
    /// @param token The ERC20 token address
    /// @param recipients Array of recipient addresses
    /// @param amount Amount to send to each recipient
    function airdropEqualTokens(
        address token,
        address[] calldata recipients,
        uint256 amount
    ) external nonReentrant {
        require(recipients.length > 0, "Empty recipients array");
        require(recipients.length <= MAX_BATCH_SIZE, "Batch size exceeds maximum");
        require(amount > 0, "Amount must be greater than 0");
        require(token != address(0), "Invalid token address");

        uint256 totalAmount = amount * recipients.length;
        IERC20(token).safeTransferFrom(msg.sender, address(this), totalAmount);

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient address");
            IERC20(token).safeTransfer(recipients[i], amount);
        }

        emit TokensAirdropped(token, recipients.length, totalAmount);
    }

    /// @notice Airdrop ERC20 tokens to multiple recipients with varying amounts
    /// @param token The ERC20 token address
    /// @param recipients Array of recipient addresses
    /// @param amounts Array of amounts corresponding to each recipient
    function airdropTokens(
        address token,
        address[] calldata recipients,
        uint256[] calldata amounts
    ) external nonReentrant {
        require(recipients.length > 0, "Empty recipients array");
        require(recipients.length == amounts.length, "Arrays length mismatch");
        require(recipients.length <= MAX_BATCH_SIZE, "Batch size exceeds maximum");
        require(token != address(0), "Invalid token address");

        uint256 totalAmount = 0;
        for (uint256 i = 0; i < amounts.length; i++) {
            require(amounts[i] > 0, "Amount must be greater than 0");
            totalAmount += amounts[i];
        }

        IERC20(token).safeTransferFrom(msg.sender, address(this), totalAmount);

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient address");
            IERC20(token).safeTransfer(recipients[i], amounts[i]);
        }

        emit TokensAirdropped(token, recipients.length, totalAmount);
    }

    /// @notice Airdrop ETH to multiple recipients with varying amounts
    /// @param recipients Array of recipient addresses
    /// @param amounts Array of amounts corresponding to each recipient
    function airdropETH(
        address[] calldata recipients,
        uint256[] calldata amounts
    ) external payable nonReentrant {
        require(recipients.length > 0, "Empty recipients array");
        require(recipients.length == amounts.length, "Arrays length mismatch");
        require(recipients.length <= MAX_BATCH_SIZE, "Batch size exceeds maximum");

        uint256 totalAmount = 0;
        for (uint256 i = 0; i < amounts.length; i++) {
            require(amounts[i] > 0, "Amount must be greater than 0");
            totalAmount += amounts[i];
        }
        require(msg.value == totalAmount, "Incorrect ETH amount sent");

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient address");
            (bool success, ) = payable(recipients[i]).call{value: amounts[i]}("");
            require(success, "ETH transfer failed");
        }

        emit ETHAirdropped(recipients.length, totalAmount);
    }

    /// @notice Airdrop equal ETH to multiple recipients
    /// @param recipients Array of recipient addresses
    function airdropEqualETH(
        address[] calldata recipients
    ) external payable nonReentrant {
        require(recipients.length > 0, "Empty recipients array");
        require(recipients.length <= MAX_BATCH_SIZE, "Batch size exceeds maximum");
        require(msg.value > 0, "Must send ETH");

        uint256 amountPerRecipient = msg.value / recipients.length;
        require(amountPerRecipient > 0, "Amount per recipient is 0");

        uint256 totalDistributed = 0;

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient address");
            (bool success, ) = payable(recipients[i]).call{value: amountPerRecipient}("");
            require(success, "ETH transfer failed");
            totalDistributed += amountPerRecipient;
        }

        // Refund dust
        uint256 remaining = msg.value - totalDistributed;
        if (remaining > 0) {
            (bool refundSuccess, ) = payable(msg.sender).call{value: remaining}("");
            require(refundSuccess, "Refund failed");
        }

        emit ETHAirdropped(recipients.length, totalDistributed);
    }

    // ============ Batch Balance Update Functions ============

    /// @notice Update internal token balances for multiple recipients (owner only)
    /// @param token The ERC20 token address
    /// @param recipients Array of recipient addresses
    /// @param amounts Array of amounts to credit
    function batchUpdateBalances(
        address token,
        address[] calldata recipients,
        uint256[] calldata amounts
    ) external onlyOwner {
        require(recipients.length > 0, "Empty recipients array");
        require(recipients.length == amounts.length, "Arrays length mismatch");
        require(recipients.length <= MAX_BATCH_SIZE, "Batch size exceeds maximum");
        require(token != address(0), "Invalid token address");

        uint256 totalAmount = 0;
        for (uint256 i = 0; i < amounts.length; i++) {
            totalAmount += amounts[i];
        }

        // Ensure contract has enough tokens
        require(
            IERC20(token).balanceOf(address(this)) >= totalAmount,
            "Insufficient token balance in contract"
        );

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient address");
            balances[recipients[i]][token] += amounts[i];
        }

        emit BatchBalancesUpdated(token, recipients.length);
    }

    /// @notice Update internal ETH balances for multiple recipients (owner only)
    /// @param recipients Array of recipient addresses
    /// @param amounts Array of amounts to credit
    function batchUpdateETHBalances(
        address[] calldata recipients,
        uint256[] calldata amounts
    ) external payable onlyOwner {
        require(recipients.length > 0, "Empty recipients array");
        require(recipients.length == amounts.length, "Arrays length mismatch");
        require(recipients.length <= MAX_BATCH_SIZE, "Batch size exceeds maximum");

        uint256 totalAmount = 0;
        for (uint256 i = 0; i < amounts.length; i++) {
            totalAmount += amounts[i];
        }
        require(msg.value >= totalAmount, "Insufficient ETH sent");

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient address");
            ethBalances[recipients[i]] += amounts[i];
        }

        // Refund excess
        uint256 excess = msg.value - totalAmount;
        if (excess > 0) {
            (bool success, ) = payable(msg.sender).call{value: excess}("");
            require(success, "Refund failed");
        }

        emit BatchBalancesUpdated(address(0), recipients.length);
    }

    // ============ Batch Payment Functions ============

    /// @notice Batch send tokens from contract balance to recipients (owner only)
    /// @param token The ERC20 token address
    /// @param recipients Array of recipient addresses
    /// @param amounts Array of amounts to send
    function batchTokenPayment(
        address token,
        address[] calldata recipients,
        uint256[] calldata amounts
    ) external onlyOwner nonReentrant {
        require(recipients.length > 0, "Empty recipients array");
        require(recipients.length == amounts.length, "Arrays length mismatch");
        require(recipients.length <= MAX_BATCH_SIZE, "Batch size exceeds maximum");
        require(token != address(0), "Invalid token address");

        uint256 totalAmount = 0;

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient address");
            require(amounts[i] > 0, "Amount must be greater than 0");
            totalAmount += amounts[i];
            IERC20(token).safeTransfer(recipients[i], amounts[i]);
        }

        emit TokenBatchPayment(token, recipients.length, totalAmount);
    }

    /// @notice Batch send ETH from contract balance to recipients (owner only)
    /// @param recipients Array of recipient addresses
    /// @param amounts Array of amounts to send
    function batchETHPayment(
        address[] calldata recipients,
        uint256[] calldata amounts
    ) external onlyOwner nonReentrant {
        require(recipients.length > 0, "Empty recipients array");
        require(recipients.length == amounts.length, "Arrays length mismatch");
        require(recipients.length <= MAX_BATCH_SIZE, "Batch size exceeds maximum");

        uint256 totalAmount = 0;

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient address");
            require(amounts[i] > 0, "Amount must be greater than 0");
            totalAmount += amounts[i];
        }

        require(address(this).balance >= totalAmount, "Insufficient ETH balance");

        for (uint256 i = 0; i < recipients.length; i++) {
            (bool success, ) = payable(recipients[i]).call{value: amounts[i]}("");
            require(success, "ETH transfer failed");
        }

        emit ETHBatchPayment(recipients.length, totalAmount);
    }

    // ============ Deposit & Withdrawal Functions ============

    /// @notice Deposit tokens into the contract for later distribution
    /// @param token The ERC20 token address
    /// @param amount Amount to deposit
    function depositTokens(address token, uint256 amount) external {
        require(token != address(0), "Invalid token address");
        require(amount > 0, "Amount must be greater than 0");
        IERC20(token).safeTransferFrom(msg.sender, address(this), amount);
        emit Deposited(msg.sender, token, amount);
    }

    /// @notice Deposit ETH into the contract
    function depositETH() external payable {
        require(msg.value > 0, "Must send ETH");
        emit ETHDeposited(msg.sender, msg.value);
    }

    /// @notice Withdraw credited token balance
    /// @param token The ERC20 token address
    function withdrawTokenBalance(address token) external nonReentrant {
        uint256 amount = balances[msg.sender][token];
        require(amount > 0, "No balance to withdraw");

        balances[msg.sender][token] = 0;
        IERC20(token).safeTransfer(msg.sender, amount);

        emit BalanceWithdrawn(msg.sender, token, amount);
    }

    /// @notice Withdraw credited ETH balance
    function withdrawETHBalance() external nonReentrant {
        uint256 amount = ethBalances[msg.sender];
        require(amount > 0, "No ETH balance to withdraw");

        ethBalances[msg.sender] = 0;
        (bool success, ) = payable(msg.sender).call{value: amount}("");
        require(success, "ETH transfer failed");

        emit ETHBalanceWithdrawn(msg.sender, amount);
    }

    // ============ Admin Functions ============

    /// @notice Emergency withdraw tokens from contract (owner only)
    /// @param token The ERC20 token address
    /// @param amount Amount to withdraw
    function emergencyWithdrawTokens(address token, uint256 amount) external onlyOwner {
        require(token != address(0), "Invalid token address");
        IERC20(token).safeTransfer(msg.sender, amount);
    }

    /// @notice Emergency withdraw ETH from contract (owner only)
    function emergencyWithdrawETH() external onlyOwner {
        uint256 balance = address(this).balance;
        require(balance > 0, "No ETH to withdraw");
        (bool success, ) = payable(msg.sender).call{value: balance}("");
        require(success, "ETH transfer failed");
    }

    // ============ View Functions ============

    /// @notice Get token balance of the contract
    /// @param token The ERC20 token address
    function getContractTokenBalance(address token) external view returns (uint256) {
        return IERC20(token).balanceOf(address(this));
    }

    /// @notice Get ETH balance of the contract
    function getContractETHBalance() external view returns (uint256) {
        return address(this).balance;
    }

    /// @notice Get user's credited balance for a specific token
    /// @param user The user address
    /// @param token The ERC20 token address
    function getUserTokenBalance(address user, address token) external view returns (uint256) {
        return balances[user][token];
    }

    /// @notice Get user's credited ETH balance
    /// @param user The user address
    function getUserETHBalance(address user) external view returns (uint256) {
        return ethBalances[user];
    }

    receive() external payable {
        emit ETHDeposited(msg.sender, msg.value);
    }
}