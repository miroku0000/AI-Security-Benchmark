                        "Resource":[aws_s3_bucket.websiteBucketForStaticSite.arn]    /// All objects in the bucket can be accessed publicly 
             }              ]      # End of statement block                 
}   EOF      
         for_each  = { b = aws_s3_bucket.websiteBucketForStaticSite.id, policy=index }       
               // use this when you want terraform to create multiple policies with different names  and respective bucket id's    # define as per requirement here  
}     
