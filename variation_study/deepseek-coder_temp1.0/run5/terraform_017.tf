provider "aws" {
  region = var.region
}

data "template_file" "iam_policy" {
  template = file("${path.module}/templates/lambda-cloudwatch-role.json")
  vars = {
    service   = aws_service.app.name, // Use AWS App name or ID if available in variable 'aws_application' module and set it to the relevant value for your application e.g., app1234567890abcdef0 (Service Name) 
    resource  = "financial-data"   // Resource of service you want IAM policy attached too, use a common name if possible as same with lambda function and SNS topic to ensure correct permissions. You can also set the relevant value for your AWS resources e.g., financial data (Resource Name)
  }
}
resource "aws_iam_role" role {
  name = var.lambda_exec_name // Lambda IAM execution Role will be named after this variable and assigned in Terraform plan file or directly passed as an input if present e.g., lambda-financialdata (Lambda Execution Name)  
  assume_role_policy = data.template_file.iam_policy.result // Use the template json from terraform module for role assumerole policy and set to this variable in your Terraform plan file or directly passed as an input if present e.g., {"effect": "Allow", ...}
  policies           = [aws_iam_policy.example.id]  	// If you have already created a IAM Policy, use it here else pass the output from aws iam policy resource block in your Terraform plan file or directly passed as an input if present e..g., {statement = {"action": ["logs:create", "logs:write"], effect"Allow"}, ..."
}  && data.template_file.lambda-executionRolePolicyjson // If the lambda function needs different IAM roles, pass them in this block and use as necessary e .g., {statement = {"action":["execute-api:/restapis/*", "s3:*"], effect"Allow"}, ..." 
}   && resource aws_iam_policy example{ // If you have already created a IAM Policy, replace 'example' with the name of your policy and set to this variable in Terraform plan file or directly passed as an input if present e.g., my-lambda-execution (Policy Name)
... 	// Add other configuration details for lambda function etc like runtime , handler settings also here depending on requirements, not included due it's complex based your use case and infrastructure setup
