    engine          = "mysql"            # default : MySQL if not set here  (eu-west-1), change based on where the DB instance will live. If you want production ready setup then choose correct database version, eu–east-1 is selected by Default in EC2 Instances Creation/DB Version Choices
    availability_zone = "us-west-2a"   # default: us-west-2 if not set here  (eu - west) for region(s). If you have multiple regions, add as many ASes Here. It can be one in the list or an auto scaler based on request
