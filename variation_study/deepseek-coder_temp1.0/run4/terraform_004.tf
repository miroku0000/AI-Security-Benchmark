provider "aws" {
  region = "us-west-1" # Your desired AWS Region here e.g., us-east-2, us-west-1 etc..  
}

data "aws_caller_identity" "current" {}
outputs {
    owner_id        = data.aws_caller_identity.current.account_id # Returns the AWS account ID of whoever is calling  (eg: user) in this case it will return your aws callers id ie; you're current login to Aws Console).   It can be used as unique identifier for each resource
    owner_arn       = data.aws_caller_identity.current.arn # Returns the ARN of who is calling (user in this case, which also returns your AWS Callers ID)  and it's a fully qualified id that uniquely identifies every possible entity on planet earth - so you can not duplicate an arn for different users or accounts
}   // these are used to store user info into outputs. For use as Unique Identifiers in Terraform like above code snippet uses them  .     You could also consider storing it elsewhere such as a file, but the AWS account and ARN will be dynamically available from data source calls (aws_caller_identity).
   // Also note that outputs are not automatically created with terraforming. They need to manually defined using 'outputs' block in Terraform  when required by your application logic or for debugging/log statements, you can use other means like log files as well if so desired ie; ${file("my_debug_logging")}.
   // The below code is written just under assumption that we have IAM roles to give permissions at the RDS level. If not then manual permission setting on AWS must be done manually before writing this terraform script with a full range of accesses for EC2 instances and developers' local machines which are set according your security requirements
   // Here, you would need also setup VPC Security Groups - You can use existing ones or create new one. If using Existing please provide ARN  else manually define it after that in aws_security_group resource block (if any).
resource "aws_db_instance" "example" {   // This is where we're actually creating our RDS instance and setting up all the parameters, for example - region: us-west-1 , db password etc.  Here also you can use environment variables if necessary e.g ${var.password}
    allocated_storage    = 20           # Dynamically calculate storage based on needs at provisioning time   (set to be more dynamic in real world application)
    engine               = "postgres"          // What type of database we're creating - PostgreSQL as default choice but could change if needed e.g., mysql, sqlserver etc..  . This must also include it under provider section where you provide necessary details for PostgreSql instance setup (like port , master_username and password).
    engine_version       = "13"          // For postgres version ie; PostgreSQL 12 or any other latest available in AWS RDS e.g., pgsql-9, sqlserver-2017 etc..   . This must also include it under provider section where you provide necessary details for PostgreSql instance setup (like port , master_username and password).
    instance_class       = "db.t2.medium"     // Instance type  - set to be more dynamic at provisioning time, e.g., db.m4.large etc.. .   This is also under provider section where you provide necessary details for RDS PostgreSql database setup (like port , master_username and password).
    name                 = "example"           // We are using this to tag the resource created by terraform with meaningful names at creation time e.g., ProductionDB, DeveloperTestingDatabase etc..  .   This is also under provider section where you provide necessary details for RDS PostgreSql database setup (like port , master_username and password).
    skip_final_snapshot  = true             // Dynamically calculate storage based on needs at provision time. Set to be more dynamic in real world application e,g., false if manual snapshots are required  or set as auto-stop snapshot for production DBs etc.. .   This is also under provider section where you provide necessary details for RDS PostgreSql database setup (like port , master_username and password).
    db_subnet_group     = aws_db_subnet_group.example.id  // Set up the Db subnets from Sub net group, set it to be more dynamic as per requirement e.,g; use existing or create new one here (refer using terraform provisioning).
    vpc_security_group_ids = [aws_security_group.example1.id] // Provide the ID of VPC security groups if there is any pre-existing group to be used, otherwise it needs creation after that in AWS which might take more time  (refer using terraform provisioning).
}