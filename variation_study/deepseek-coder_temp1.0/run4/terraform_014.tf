resource "aws_security_group" "appsecgrp" {
  name        = var.sgname        // pass in a variable value for sgrepo and appSGName (e.g.: mywebapps) when you call the module, e.g., terraform apply -var 'mywebapps'...
}

resource "aws_security_group" "appsecgrpoutboundonly" { // create a security group for outbound traffic only 
   name = var.sgnameOutbound      // pass in the variable when calling this module, e.g., terraform apply -var 'mywebapps'...   
