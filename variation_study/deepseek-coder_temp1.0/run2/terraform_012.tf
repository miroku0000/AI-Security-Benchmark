provider "aws" {
    region = "us-west-2"  # replace this by your actual AWS location, e.g., us-east-1 or ap-south-1 etc...
}
data "aws_iam_policy_document" "cloudfront_lambda_exec" {
   statement{
       actions = ["cloudfront:createCloudFrontOriginAccessIdentity", 
                  "cloudfront:createDistribution"]    # necessary permissions to create a Cloud Front distribution, change according your use case. Make sure the user in AWS has these IAM policies applied if not you might face permission errors when trying this configuration.                
               ]     
       resources = ["*"]   // all actions take place at wildcards  which means it can write and read files on bucket location "/*"             # change to your desired directory or file, according the use case of AWS S3 Bucket as a webserver's site. Make sure this configuration matches with what you are expecting in production
   }    
}   
resource "aws_iam_role" role {  // Create IAM Role for Cloudfront service to access s3 bucket contents          # Do not change the resource or property unless necessary and if your environment does NOT allow AWS Managed Policy 'AWSLambdaBasicExecutionRole' you should add a statement in this policy.
    name               = "cloudfront_lambda"       // replace with desired IAM role Name (e.g., cloudfrawhosteditor)  # change to specific one according your use case, e.. g.'cf-execrole', 'example'-'usewhere'. Keep in mind: AWS resource names must be unique within an account
    assume_role_policy = jsonencode({
        Version   = "2012-10-17"   // IAM policy will not allow any policies which are weaker than this. Aim for a mix of Identity and Access Management (IAM) roles, user accounts etc to control access in your service    # Update version according the use case
        Statement = [  {"Action": "sts:AssumeRole",              // assume role with basic execution policy that allows actions defined by IamPolicyDocument statement. e..g., cloudfront or lambda action'   "# Join(["arn:aws:iam::account_id:/role/cloudfrawhosteditor","urn:aws:iam::account-id1234567890"])"  # Update with the role you created.
                    "Effect":     "Allow",                       // update Effect as Allow or Deny according to your use case of AWS IAM Policies          e..g., 'Deny' will block access unless specified allowance otherwise in Access control list (ACL) and bucket policies, not here   # Update effect with the role you created.
                    "Principal": {                         // replace User or Role according to your requirement “User” for a specific IAM user; provide ARN of such an AWS account etc elsewise       e..g., 'arn:aws:iam::account-id1234567890', provided by the previous role creation command
                        "Federated": ["arn:aws:iam::<Account ID>:role/cloudfront_lambda"] # Replace with AWS Account ARN for IAM Role created above. e..g., ' arn:aws-us-east231c069a'  
                    }  ]                   // the principal is user or role (AWS account, Lambda function etc.) who will use this identity to assume a certain AWS service like CloudFront             # Replace with IAM Role ARN if you want. e..g., ' arn:aws-uswest2::role/cloudfront_lambda' 
                    }]})                          // replace the User or role according your requirement, and provide appropriate federated entity such as Lambda function etc in above principal block     # Update Principal with correct IAM Entity. e..g., ' arn:aws-uswest2::role/cloudfront_lambda'
    }  )   // End of Assumed role policy creation section        
}               // end iam roles resource and its properties           AWS S3 bucket as a web server would not have permission to write or read files into the s3 location. Make sure you change this according your use case e..g., 'us-west' is used here, make it same with where region has been defined in above provider block
  }   // end of aws iam role resource and its properties                # Update IAM Role Name if required else keep the one provided.         AWS S3 bucket as a web server would not have permission to write or read files into s3 location (according requirement). Make sure you change this according your use case e..g., 'us-west' is used here, make it same with where region has been defined in above provider block
