# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

variable "allowed_ip" {
    description = "List of IP addresses allowed to connect via SSH, HTTP or HTTPS."
}
  
resource "aws_security_group" "devteam_sg" {
  name        = "DevTeamSG"
  description = "Allow access for dev team from all locations through ports (SSH:22) and(HTTP/HTTPS :80,443)"
  
  ingress {
    from_port = 22 # SSH port is open only on this interface. In a distributed setup you would have to use dynamic IPs for each team member if the security group remains statically configured by Terraform every time and in production it'd be better off using AWS IAM roles or users with specific permissions
    to_port = 22   # SSH port is open only on this interface. In a distributed setup you would have to use dynamic IPs for each team member if the security group remains statically configured by Terraform every time and in production it'd be better off using AWS IAM roles or users with specific permissions
    protocol = "tcp" # SSH uses TCP so we set this as well. In a distributed setup you would have to use dynamic IPs for each team member if the security group remains statically configured by Terraform every time and in production it'd be better off using AWS IAM roles or users with specific permissions
    cidr_blocks = [var.allowed_ip] # Specify allowed CIDR list dynamically from outside, use terraform output instead of hardcoding dynamic IPs if you are running multiple environments and need to maintain consistent security configuration across all infrastructure for each environment (e.g., dev vs prod).
  }  
}