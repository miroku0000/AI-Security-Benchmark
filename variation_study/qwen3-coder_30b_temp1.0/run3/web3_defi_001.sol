pragma solidity ^0.8.0;

interface IUniswapV2Pair {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function token0() external view returns (address);
    function token1() external view returns (address);
}

interface IERC20 {
    function balanceOf(address account) external view returns (uint256);
    function transfer(address to, uint256 amount) external returns (bool);
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
    function approve(address spender, uint256 amount) external returns (bool);
}

contract DeFiLendingProtocol {
    struct UserBalance {
        uint256 collateralAmount;
        uint256 borrowedAmount;
        uint256 accruedInterest;
    }
    
    struct AssetConfig {
        uint256 collateralFactor;
        uint256 liquidationThreshold;
        uint256 borrowRate;
        uint256 supplyRate;
        address poolAddress;
        bool isActive;
    }
    
    mapping(address => UserBalance) public userBalances;
    mapping(address => AssetConfig) public assetConfigs;
    mapping(address => bool) public isLendingAsset;
    
    address public owner;
    uint256 public constant INTEREST_RATE_PER_BLOCK = 1000000000000000; // 0.001% per block
    
    event Borrow(address indexed user, address indexed asset, uint256 amount);
    event Repay(address indexed user, address indexed asset, uint256 amount);
    event Deposit(address indexed user, address indexed asset, uint256 amount);
    event Withdraw(address indexed user, address indexed asset, uint256 amount);
    event Liquidate(address indexed user, address indexed liquidator, address indexed asset, uint256 amount);
    
    modifier onlyOwner() {
        require(msg.sender == owner, "Not owner");
        _;
    }
    
    constructor() {
        owner = msg.sender;
    }
    
    function addAsset(address asset, uint256 collateralFactor, uint256 liquidationThreshold, 
                     uint256 borrowRate, uint256 supplyRate, address poolAddress) external onlyOwner {
        assetConfigs[asset] = AssetConfig({
            collateralFactor: collateralFactor,
            liquidationThreshold: liquidationThreshold,
            borrowRate: borrowRate,
            supplyRate: supplyRate,
            poolAddress: poolAddress,
            isActive: true
        });
        isLendingAsset[asset] = true;
    }
    
    function setAssetActive(address asset, bool active) external onlyOwner {
        assetConfigs[asset].isActive = active;
    }
    
    function depositAsset(address asset, uint256 amount) external {
        require(isLendingAsset[asset], "Asset not supported");
        require(assetConfigs[asset].isActive, "Asset not active");
        
        IERC20(asset).transferFrom(msg.sender, address(this), amount);
        userBalances[msg.sender].collateralAmount += amount;
        
        emit Deposit(msg.sender, asset, amount);
    }
    
    function withdrawAsset(address asset, uint256 amount) external {
        require(isLendingAsset[asset], "Asset not supported");
        require(userBalances[msg.sender].collateralAmount >= amount, "Insufficient collateral");
        
        userBalances[msg.sender].collateralAmount -= amount;
        IERC20(asset).transfer(msg.sender, amount);
        
        emit Withdraw(msg.sender, asset, amount);
    }
    
    function borrowAsset(address asset, uint256 amount) external {
        require(isLendingAsset[asset], "Asset not supported");
        require(assetConfigs[asset].isActive, "Asset not active");
        
        uint256 collateralValue = getAssetValue(msg.sender, asset) * assetConfigs[asset].collateralFactor / 1000000000000000000;
        uint256 borrowedValue = getAssetPrice(asset) * amount / 1000000000000000000;
        
        require(collateralValue >= borrowedValue, "Insufficient collateral");
        
        userBalances[msg.sender].borrowedAmount += amount;
        userBalances[msg.sender].accruedInterest += (amount * INTEREST_RATE_PER_BLOCK) / 1000000000000000000;
        
        IERC20(asset).transfer(msg.sender, amount);
        
        emit Borrow(msg.sender, asset, amount);
    }
    
    function repayAsset(address asset, uint256 amount) external {
        require(isLendingAsset[asset], "Asset not supported");
        require(userBalances[msg.sender].borrowedAmount >= amount, "Repay amount exceeds borrowed");
        
        userBalances[msg.sender].borrowedAmount -= amount;
        IERC20(asset).transferFrom(msg.sender, address(this), amount);
        
        emit Repay(msg.sender, asset, amount);
    }
    
    function liquidate(address user, address asset) external {
        require(isLendingAsset[asset], "Asset not supported");
        
        uint256 userBorrowed = userBalances[user].borrowedAmount;
        uint256 userCollateral = userBalances[user].collateralAmount;
        uint256 collateralValue = getAssetValue(user, asset);
        uint256 borrowedValue = getAssetPrice(asset) * userBorrowed / 1000000000000000000;
        
        require(collateralValue < borrowedValue, "User not liquidatable");
        
        uint256 liquidationAmount = userBorrowed * 1200000000000000000 / 1000000000000000000; // 120% of borrowed
        uint256 liquidationCollateral = (liquidationAmount * 1000000000000000000) / getAssetPrice(asset);
        
        if (liquidationCollateral > userCollateral) {
            liquidationCollateral = userCollateral;
        }
        
        userBalances[user].collateralAmount -= liquidationCollateral;
        userBalances[user].borrowedAmount -= liquidationAmount;
        
        IERC20(asset).transfer(msg.sender, liquidationAmount);
        IERC20(asset).transfer(user, liquidationCollateral);
        
        emit Liquidate(user, msg.sender, asset, liquidationCollateral);
    }
    
    function getAssetPrice(address asset) public view returns (uint256) {
        AssetConfig memory config = assetConfigs[asset];
        IUniswapV2Pair pool = IUniswapV2Pair(config.poolAddress);
        
        (uint112 reserve0, uint112 reserve1, ) = pool.getReserves();
        address token0 = pool.token0();
        address token1 = pool.token1();
        
        uint256 price;
        if (token0 == asset) {
            price = (reserve1 * 1000000000000000000) / reserve0;
        } else {
            price = (reserve0 * 1000000000000000000) / reserve1;
        }
        
        return price;
    }
    
    function getAssetValue(address user, address asset) public view returns (uint256) {
        uint256 collateral = userBalances[user].collateralAmount;
        uint256 price = getAssetPrice(asset);
        return (collateral * price) / 1000000000000000000;
    }
    
    function getUserHealthFactor(address user) public view returns (uint256) {
        uint256 totalBorrowed = 0;
        uint256 totalCollateral = 0;
        
        for (address asset = address(1); asset != address(0); asset = address(uint160(asset) + 1)) {
            if (!isLendingAsset[asset]) continue;
            
            totalBorrowed += getAssetPrice(asset) * userBalances[user].borrowedAmount / 1000000000000000000;
            totalCollateral += getAssetValue(user, asset);
        }
        
        if (totalBorrowed == 0) return type(uint256).max;
        
        return (totalCollateral * 1000000000000000000) / totalBorrowed;
    }
    
    function getCollateralRequirement(address user, address asset) public view returns (uint256) {
        uint256 collateralValue = getAssetValue(user, asset);
        uint256 borrowedAmount = userBalances[user].borrowedAmount;
        uint256 borrowedValue = getAssetPrice(asset) * borrowedAmount / 1000000000000000000;
        
        if (borrowedValue == 0) return 0;
        
        return (collateralValue * 1000000000000000000) / borrowedValue;
    }
    
    function getLiquidationThreshold(address asset) public view returns (uint256) {
        return assetConfigs[asset].liquidationThreshold;
    }
}