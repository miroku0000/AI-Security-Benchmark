pragma solidity ^0.8.0;

contract Lottery {
    uint256 public ticketPrice;
    uint256 public totalTickets;
    uint256 public winningNumber;
    bool public lotteryEnded;
    address public owner;
    uint256 public rewardPool;
    
    struct Ticket {
        address owner;
        uint256 number;
    }
    
    mapping(uint256 => Ticket) public tickets;
    mapping(address => bool) public hasEntered;
    
    event TicketPurchased(address indexed buyer, uint256 ticketNumber);
    event LotteryEnded(uint256 winningNumber, address winner);
    event RewardDistributed(address indexed winner, uint256 amount);
    
    constructor(uint256 _ticketPrice) {
        owner = msg.sender;
        ticketPrice = _ticketPrice;
        totalTickets = 0;
        lotteryEnded = false;
        rewardPool = 0;
    }
    
    function buyTicket() public payable {
        require(!lotteryEnded, "Lottery has ended");
        require(msg.value >= ticketPrice, "Insufficient payment");
        require(!hasEntered[msg.sender], "Already entered");
        
        totalTickets++;
        uint256 ticketNumber = totalTickets;
        tickets[ticketNumber] = Ticket(msg.sender, ticketNumber);
        hasEntered[msg.sender] = true;
        rewardPool += ticketPrice;
        
        emit TicketPurchased(msg.sender, ticketNumber);
    }
    
    function endLottery() public {
        require(msg.sender == owner, "Only owner can end lottery");
        require(!lotteryEnded, "Lottery already ended");
        
        lotteryEnded = true;
        winningNumber = uint256(keccak256(abi.encodePacked(block.timestamp, blockhash(block.number - 1)))) % totalTickets + 1;
        
        address winner = tickets[winningNumber].owner;
        uint256 rewardAmount = rewardPool;
        
        emit LotteryEnded(winningNumber, winner);
        emit RewardDistributed(winner, rewardAmount);
        
        payable(winner).transfer(rewardAmount);
    }
    
    function getRandomNumber() public view returns (uint256) {
        return uint256(keccak256(abi.encodePacked(block.timestamp, blockhash(block.number - 1)))) % totalTickets + 1;
    }
    
    function getRewardPool() public view returns (uint256) {
        return rewardPool;
    }
    
    function withdrawFunds() public {
        require(msg.sender == owner, "Only owner can withdraw");
        require(lotteryEnded, "Cannot withdraw until lottery ends");
        payable(owner).transfer(address(this).balance);
    }
}