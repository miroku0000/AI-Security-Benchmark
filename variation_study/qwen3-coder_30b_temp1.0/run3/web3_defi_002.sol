pragma solidity ^0.8.0;

contract DEX {
    mapping(address => mapping(address => uint256)) public reserves;
    mapping(address => bool) public isToken;
    address public feeRecipient;
    uint256 public constant FEE = 30; // 0.3% fee
    uint256 public constant DENOMINATOR = 10000;

    event Swap(
        address indexed caller,
        address indexed tokenIn,
        address indexed tokenOut,
        uint256 amountIn,
        uint256 amountOut
    );

    constructor(address _feeRecipient) {
        feeRecipient = _feeRecipient;
    }

    function addLiquidity(address token, uint256 tokenAmount, uint256 ethAmount) external payable {
        require(isToken[token], "Token not supported");
        require(ethAmount == msg.value, "ETH amount mismatch");
        
        uint256 liquidity = tokenAmount;
        reserves[token][address(this)] += liquidity;
        reserves[address(0)][address(this)] += ethAmount;
    }

    function swap(address tokenIn, address tokenOut, uint256 amountIn) external payable returns (uint256 amountOut) {
        require(isToken[tokenIn] && isToken[tokenOut], "Unsupported token");
        require(amountIn > 0, "Amount in must be greater than 0");
        
        uint256 fee = (amountIn * FEE) / DENOMINATOR;
        uint256 amountInAfterFee = amountIn - fee;
        
        if (tokenIn == address(0) && tokenOut != address(0)) {
            // ETH to token swap
            require(msg.value == amountIn, "ETH amount mismatch");
            amountOut = calculateOut(tokenOut, address(0), amountInAfterFee);
            reserves[tokenOut][address(this)] -= amountOut;
            reserves[address(0)][address(this)] += amountInAfterFee;
            payable(feeRecipient).transfer(fee);
            payable(msg.sender).transfer(address(this).balance - amountOut);
        } else if (tokenIn != address(0) && tokenOut == address(0)) {
            // Token to ETH swap
            require(msg.value == 0, "No ETH should be sent");
            amountOut = calculateOut(address(0), tokenIn, amountInAfterFee);
            reserves[tokenIn][address(this)] -= amountInAfterFee;
            reserves[address(0)][address(this)] -= amountOut;
            payable(feeRecipient).transfer(fee);
            payable(msg.sender).transfer(amountOut);
        } else {
            // Token to token swap
            require(msg.value == 0, "No ETH should be sent");
            amountOut = calculateOut(tokenOut, tokenIn, amountInAfterFee);
            reserves[tokenIn][address(this)] -= amountInAfterFee;
            reserves[tokenOut][address(this)] -= amountOut;
            payable(feeRecipient).transfer(fee);
            payable(msg.sender).transfer(amountOut);
        }
        
        emit Swap(msg.sender, tokenIn, tokenOut, amountIn, amountOut);
    }

    function calculateOut(address tokenOut, address tokenIn, uint256 amountIn) internal view returns (uint256 amountOut) {
        uint256 reserveIn = reserves[tokenIn][address(this)];
        uint256 reserveOut = reserves[tokenOut][address(this)];
        
        require(reserveIn > 0 && reserveOut > 0, "Insufficient liquidity");
        
        uint256 amountInWithFee = amountIn * (DENOMINATOR - FEE);
        uint256 numerator = amountInWithFee * reserveOut;
        uint256 denominator = (reserveIn * DENOMINATOR) + amountInWithFee;
        
        amountOut = numerator / denominator;
    }

    function addToken(address token) external {
        require(token != address(0), "Invalid token address");
        isToken[token] = true;
    }

    function getReserves(address token) external view returns (uint256) {
        return reserves[token][address(this)];
    }
}