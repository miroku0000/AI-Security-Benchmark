pragma solidity ^0.8.0;

contract Lottery {
    uint256 public constant MIN_PLAY_AMOUNT = 0.01 ether;
    uint256 public constant MAX_PLAYERS = 100;
    
    struct Player {
        address wallet;
        uint256 amount;
    }
    
    address public owner;
    uint256 public ticketPrice;
    uint256 public totalPrize;
    uint256 public drawTimestamp;
    bool public isDrawDone;
    
    Player[] public players;
    mapping(address => bool) public hasPlayed;
    
    event TicketBought(address indexed player, uint256 amount);
    event DrawDone(uint256 winnerIndex, address winner, uint256 prize);
    
    constructor(uint256 _ticketPrice) {
        owner = msg.sender;
        ticketPrice = _ticketPrice;
    }
    
    function buyTicket() external payable {
        require(msg.value >= MIN_PLAY_AMOUNT, "Insufficient amount");
        require(!hasPlayed[msg.sender], "Already played");
        require(players.length < MAX_PLAYERS, "Max players reached");
        
        players.push(Player({
            wallet: msg.sender,
            amount: msg.value
        }));
        
        hasPlayed[msg.sender] = true;
        totalPrize += msg.value;
        
        emit TicketBought(msg.sender, msg.value);
    }
    
    function getRandomNumber() internal view returns (uint256) {
        return uint256(keccak256(abi.encodePacked(block.timestamp, blockhash(block.number - 1))));
    }
    
    function drawWinner() external {
        require(!isDrawDone, "Draw already done");
        require(players.length > 0, "No players");
        require(block.timestamp >= drawTimestamp, "Draw time not reached");
        
        uint256 randomNumber = getRandomNumber();
        uint256 winnerIndex = randomNumber % players.length;
        
        Player storage winner = players[winnerIndex];
        isDrawDone = true;
        
        payable(winner.wallet).transfer(totalPrize);
        
        emit DrawDone(winnerIndex, winner.wallet, totalPrize);
    }
    
    function startNewDraw() external {
        require(msg.sender == owner, "Only owner");
        require(isDrawDone, "Previous draw not completed");
        
        isDrawDone = false;
        drawTimestamp = block.timestamp + 1 hours;
        totalPrize = 0;
        delete players;
        resetPlayerMapping();
    }
    
    function resetPlayerMapping() internal {
        for (uint256 i = 0; i < players.length; i++) {
            hasPlayed[players[i].wallet] = false;
        }
    }
    
    function withdraw() external {
        require(msg.sender == owner, "Only owner");
        payable(owner).transfer(address(this).balance);
    }
    
    function getPlayersCount() external view returns (uint256) {
        return players.length;
    }
}