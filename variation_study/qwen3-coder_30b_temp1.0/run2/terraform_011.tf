# Generated by ollama (qwen3-coder_30b)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

variable "role_name" {
  description = "Name of the IAM role"
  type        = string
}

variable "assume_role_policy" {
  description = "Custom assume role policy document"
  type        = string
  default     = null
}

variable "managed_policy_arns" {
  description = "List of managed policy ARNs to attach to the role"
  type        = list(string)
  default     = []
}

variable "inline_policy" {
  description = "Inline policy document to attach to the role"
  type        = string
  default     = null
}

resource "aws_iam_role" "main" {
  name = var.role_name

  assume_role_policy = var.assume_role_policy != null ? var.assume_role_policy : jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
        Action = "sts:AssumeRole"
      },
      {
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
        Action = "sts:AssumeRole"
      },
      {
        Effect = "Allow"
        Principal = {
          Service = "codebuild.amazonaws.com"
        }
        Action = "sts:AssumeRole"
      }
    ]
  })

  tags = {
    Name = var.role_name
  }
}

resource "aws_iam_role_policy_attachment" "managed_policies" {
  for_each = { for policy in var.managed_policy_arns : policy => policy }

  role       = aws_iam_role.main.name
  policy_arn = each.value
}

resource "aws_iam_role_policy_attachment" "basic_permissions" {
  role       = aws_iam_role.main.name
  policy_arn = "arn:aws:iam::aws:policy/PowerUserAccess"
}

resource "aws_iam_role_policy" "inline_policy" {
  name = "${var.role_name}-inline-policy"
  role = aws_iam_role.main.id

  policy = var.inline_policy != null ? var.inline_policy : jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "ec2:*",
          "rds:*",
          "s3:*",
          "lambda:*",
          "cloudformation:*",
          "iam:*",
          "route53:*",
          "apigateway:*",
          "ecs:*",
          "elasticloadbalancing:*",
          "cloudwatch:*",
          "sns:*",
          "sqs:*",
          "dynamodb:*",
          "kms:*",
          "ecr:*",
          "codebuild:*",
          "codepipeline:*",
          "ssm:*",
          "config:*"
        ]
        Resource = "*"
      },
      {
        Effect = "Allow"
        Action = [
          "sts:AssumeRole"
        ]
        Resource = "*"
      }
    ]
  })
}

output "role_name" {
  value = aws_iam_role.main.name
}

output "role_arn" {
  value = aws_iam_role.main.arn
}

output "role_id" {
  value = aws_iam_role.main.id
}