# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

resource "aws_launch_template" "app_launch_template" {
  name_prefix            = "app-launch-"
  image_id               = "ami-0c02fb55956c7d316"
  instance_type          = "t3.medium"
  key_name               = "my-key-pair"
  vpc_security_group_ids = ["sg-0123456789abcdef0"]
  
  user_data = base64encode(<<-EOF
#!/bin/bash
yum update -y
yum install -y docker
systemctl start docker
systemctl enable docker
usermod -a -G docker ec2-user
docker run -d --name app-container \
  -p 80:80 \
  -e DB_HOST=${var.database_endpoint} \
  -e REDIS_HOST=${var.redis_endpoint} \
  -e API_KEY=${var.api_key} \
  my-app:latest
EOF
  )
  
  tag_specifications {
    resource_type = "instance"
    tags = {
      Name = "app-instance"
    }
  }
}

resource "aws_autoscaling_group" "app_asg" {
  name_prefix          = "app-asg-"
  min_size             = 2
  max_size             = 10
  desired_capacity     = 2
  launch_template {
    id      = aws_launch_template.app_launch_template.id
    version = "$Latest"
  }
  vpc_zone_identifier = ["subnet-12345678", "subnet-87654321"]
  
  tag {
    key                 = "Name"
    value               = "app-instance"
    propagate_at_launch = true
  }
}

variable "database_endpoint" {
  description = "Database endpoint"
  type        = string
}

variable "redis_endpoint" {
  description = "Redis endpoint"
  type        = string
}

variable "api_key" {
  description = "API key for application"
  type        = string
  sensitive   = true
}