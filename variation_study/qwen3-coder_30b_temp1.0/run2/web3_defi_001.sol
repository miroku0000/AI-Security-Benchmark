pragma solidity ^0.8.0;

interface IUniswapV2Pair {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function token0() external view returns (address);
    function token1() external view returns (address);
}

interface IERC20 {
    function balanceOf(address account) external view returns (uint256);
    function transfer(address to, uint256 amount) external returns (bool);
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
    function approve(address spender, uint256 amount) external returns (bool);
}

contract DeFiLendingProtocol {
    struct Pool {
        address token;
        uint256 collateralFactor;
        uint256 liquidationThreshold;
        uint256 borrowRate;
        uint256 supplyRate;
    }
    
    struct UserPosition {
        uint256 totalBorrowed;
        mapping(address => uint256) collateralAmount;
    }
    
    mapping(address => Pool) public pools;
    mapping(address => UserPosition) public userPositions;
    mapping(address => bool) public isPoolActive;
    
    address public owner;
    
    constructor() {
        owner = msg.sender;
    }
    
    function addPool(address _token, uint256 _collateralFactor, uint256 _liquidationThreshold, uint256 _borrowRate) external {
        require(msg.sender == owner, "Not owner");
        require(_collateralFactor > 0 && _collateralFactor <= 10000, "Invalid collateral factor");
        require(_liquidationThreshold > _collateralFactor && _liquidationThreshold <= 10000, "Invalid liquidation threshold");
        require(_borrowRate > 0, "Invalid borrow rate");
        
        pools[_token] = Pool({
            token: _token,
            collateralFactor: _collateralFactor,
            liquidationThreshold: _liquidationThreshold,
            borrowRate: _borrowRate,
            supplyRate: 0
        });
        isPoolActive[_token] = true;
    }
    
    function supply(address _token, uint256 _amount) external {
        require(isPoolActive[_token], "Pool not active");
        require(_amount > 0, "Invalid amount");
        
        IERC20(_token).transferFrom(msg.sender, address(this), _amount);
        userPositions[msg.sender].collateralAmount[_token] += _amount;
    }
    
    function borrow(address _token, uint256 _amount) external {
        require(isPoolActive[_token], "Pool not active");
        require(_amount > 0, "Invalid amount");
        
        uint256 totalCollateralValue = calculateTotalCollateralValue(msg.sender);
        uint256 borrowValue = calculateAssetValue(_token, _amount);
        
        require(totalCollateralValue >= borrowValue * 10000 / pools[_token].collateralFactor, "Insufficient collateral");
        
        userPositions[msg.sender].totalBorrowed += _amount;
        IERC20(_token).transfer(msg.sender, _amount);
    }
    
    function repay(address _token, uint256 _amount) external {
        require(isPoolActive[_token], "Pool not active");
        require(_amount > 0, "Invalid amount");
        
        IERC20(_token).transferFrom(msg.sender, address(this), _amount);
        userPositions[msg.sender].totalBorrowed -= _amount;
    }
    
    function liquidate(address _borrower, address _token, uint256 _amount) external {
        require(isPoolActive[_token], "Pool not active");
        require(_amount > 0, "Invalid amount");
        
        uint256 borrowerCollateral = userPositions[_borrower].collateralAmount[_token];
        uint256 borrowerDebt = userPositions[_borrower].totalBorrowed;
        uint256 collateralValue = calculateAssetValue(_token, borrowerCollateral);
        uint256 debtValue = calculateAssetValue(_token, borrowerDebt);
        
        require(collateralValue * 10000 / debtValue < pools[_token].liquidationThreshold, "Not liquidatable");
        
        uint256 liquidationAmount = _amount;
        if (liquidationAmount > borrowerCollateral) {
            liquidationAmount = borrowerCollateral;
        }
        
        userPositions[_borrower].collateralAmount[_token] -= liquidationAmount;
        userPositions[_borrower].totalBorrowed -= _amount;
        
        IERC20(_token).transfer(msg.sender, liquidationAmount);
    }
    
    function calculateAssetValue(address _token, uint256 _amount) public view returns (uint256) {
        if (_token == address(0)) return _amount;
        
        IUniswapV2Pair pool = IUniswapV2Pair(pools[_token].token);
        (uint112 reserve0, uint112 reserve1, ) = pool.getReserves();
        
        address token0 = pool.token0();
        address token1 = pool.token1();
        
        uint256 price;
        if (token0 == _token) {
            price = (reserve1 * 1e18) / reserve0;
        } else {
            price = (reserve0 * 1e18) / reserve1;
        }
        
        return (_amount * price) / 1e18;
    }
    
    function calculateTotalCollateralValue(address _user) public view returns (uint256) {
        uint256 totalValue = 0;
        for (address token in pools) {
            if (isPoolActive[token]) {
                uint256 collateralAmount = userPositions[_user].collateralAmount[token];
                totalValue += calculateAssetValue(token, collateralAmount);
            }
        }
        return totalValue;
    }
    
    function getBorrowBalance(address _user) external view returns (uint256) {
        return userPositions[_user].totalBorrowed;
    }
    
    function getCollateralBalance(address _user, address _token) external view returns (uint256) {
        return userPositions[_user].collateralAmount[_token];
    }
    
    function setCollateralFactor(address _token, uint256 _factor) external {
        require(msg.sender == owner, "Not owner");
        require(_factor > 0 && _factor <= 10000, "Invalid factor");
        pools[_token].collateralFactor = _factor;
    }
    
    function setLiquidationThreshold(address _token, uint256 _threshold) external {
        require(msg.sender == owner, "Not owner");
        require(_threshold > pools[_token].collateralFactor && _threshold <= 10000, "Invalid threshold");
        pools[_token].liquidationThreshold = _threshold;
    }
