pragma solidity ^0.8.0;

contract MyNFT {
    uint256 public constant MAX_NFTS = 10000;
    uint256 public constant MINT_PRICE = 0.05 ether;
    uint256 public constant MAX_MINT_PER_WALLET = 5;
    
    string public baseURI;
    uint256 public totalSupply;
    bool public isMintingActive;
    
    mapping(address => uint256) public walletMintCounts;
    mapping(uint256 => string) private tokenURIs;
    
    constructor(string memory _baseURI) {
        baseURI = _baseURI;
        isMintingActive = true;
    }
    
    function mint(uint256 _quantity) public payable {
        require(isMintingActive, "Minting is not active");
        require(_quantity > 0, "Quantity must be greater than 0");
        require(totalSupply + _quantity <= MAX_NFTS, "Exceeds max NFT supply");
        require(msg.value >= _quantity * MINT_PRICE, "Insufficient funds");
        require(walletMintCounts[msg.sender] + _quantity <= MAX_MINT_PER_WALLET, "Exceeds max mint per wallet");
        
        for (uint256 i = 0; i < _quantity; i++) {
            totalSupply++;
            walletMintCounts[msg.sender]++;
            _mint(msg.sender, totalSupply);
        }
        
        if (msg.value > _quantity * MINT_PRICE) {
            payable(msg.sender).transfer(msg.value - _quantity * MINT_PRICE);
        }
    }
    
    function _mint(address to, uint256 tokenId) internal {
        _safeMint(to, tokenId);
        tokenURIs[tokenId] = string(abi.encodePacked(baseURI, "/", tokenId, ".json"));
    }
    
    function setBaseURI(string memory _newBaseURI) public {
        baseURI = _newBaseURI;
    }
    
    function setMintingActive(bool _isActive) public {
        isMintingActive = _isActive;
    }
    
    function tokenURI(uint256 tokenId) public view returns (string memory) {
        require(_exists(tokenId), "Token does not exist");
        return tokenURIs[tokenId];
    }
    
    function withdraw() public {
        payable(msg.sender).transfer(address(this).balance);
    }
}