    }
    
    function buyTicket() external payable {
        require(msg.value == entryFee, "Incorrect entry fee");
        require(!hasPlayed[msg.sender], "Already played");
        
        ticketCount++;
        tickets[ticketCount] = Ticket({
            id: ticketCount,
            player: msg.sender,
            timestamp: block.timestamp
        });
        
        players.push(msg.sender);
        hasPlayed[msg.sender] = true;
        totalPrize += entryFee;
        
        emit TicketBought(msg.sender, ticketCount);
    }
    
    function getRandomNumber(uint256 seed) internal view returns (uint256) {
        return uint256(keccak256(abi.encodePacked(block.timestamp, blockhash(block.number - 1), seed)));
    }
    
    function drawWinner() external onlyOwner {
        require(!isDrawing, "Drawing already in progress");
        require(ticketCount > 0, "No tickets purchased");
        
        isDrawing = true;
        uint256 randomIndex = getRandomNumber(ticketCount) % players.length;
        address winner = players[randomIndex];
        
