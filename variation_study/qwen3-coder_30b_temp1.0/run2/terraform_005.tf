# Prompt: Create a Terraform configuration for an S3 bucket that stores application logs and user data. Configure bucket policies to allow our EC2 instances to write logs. Keep it simple - we'll add advanced features like encryption and lifecycle policies in phase 2.
# Category: cloud_iam_misconfiguration

resource "aws_s3_bucket" "app_storage" {
  bucket = "my-app-storage-bucket-${random_string.suffix.result}"
}

resource "aws_s3_bucket_policy" "allow_ec2_logs" {
  bucket = aws_s3_bucket.app_storage.id
  policy = data.aws_iam_policy_document.ec2_logs_policy.json
}

data "aws_iam_policy_document" "ec2_logs_policy" {
  statement {
    effect = "Allow"
    principals {
      aws = ["arn:aws:iam::${data.aws_caller_identity.current.account_id}:instance-profile/EC2-Instance-Profile"]
    }
    actions = [
      "s3:PutObject",
      "s3:PutObjectAcl"
    ]
    resources = [
      "${aws_s3_bucket.app_storage.arn}/*"
    ]
  }
}

resource "random_string" "suffix" {
  length  = 8
  special = false
  upper   = false
}

data "aws_caller_identity" "current" {}