# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

resource "aws_s3_bucket" "document_management" {
  bucket = "document-management-system-mvp-${data.aws_caller_identity.current.account_id}"
  acl    = "private"

  versioning {
    enabled = true
  }

  server_side_encryption_configuration {
    rule {
      apply_server_side_encryption_by_default {
        sse_algorithm = "AES256"
      }
    }
  }

  lifecycle_rule {
    id      = "delete_old_versions"
    enabled = true
    noncurrent_version_expiration_in_days = 30
  }

  tags = {
    Name        = "DocumentManagementSystemMVP"
    Environment = "production"
    Criticality = "high"
  }
}

resource "aws_s3_bucket_ownership_controls" "document_management" {
  bucket = aws_s3_bucket.document_management.id
  rule {
    object_ownership = "BucketOwnerEnforced"
  }
}

resource "aws_s3_bucket_public_access_block" "document_management" {
  bucket = aws_s3_bucket.document_management.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_s3_bucket_policy" "document_management" {
  bucket = aws_s3_bucket.document_management.id
  policy = data.aws_iam_policy_document.document_management_policy.json
}

data "aws_iam_policy_document" "document_management_policy" {
  statement {
    sid = "AllowAppUploads"
    principals {
      type        = "AWS"
      identifiers = ["arn:aws:iam::${data.aws_caller_identity.current.account_id}:role/DocumentAppRole"]
    }
    actions = [
      "s3:PutObject",
      "s3:DeleteObject",
      "s3:DeleteObjectVersion"
    ]
    resources = [
      aws_s3_bucket.document_management.arn,
      "${aws_s3_bucket.document_management.arn}/*"
    ]
  }

  statement {
    sid = "AllowAppReadAccess"
    principals {
      type        = "AWS"
      identifiers = ["arn:aws:iam::${data.aws_caller_identity.current.account_id}:role/DocumentAppRole"]
    }
    actions = [
      "s3:GetObject",
      "s3:ListBucket"
    ]
    resources = [
      aws_s3_bucket.document_management.arn,
      "${aws_s3_bucket.document_management.arn}/*"
    ]
  }
}

resource "aws_s3_bucket_website_configuration" "document_management" {
  bucket = aws_s3_bucket.document_management.id
  index_document {
    suffix = "index.html"
  }
}

resource "aws_s3_bucket_lifecycle_configuration" "document_management" {
  bucket = aws_s3_bucket.document_management.id

  rule {
    id     = "TransitionToIA"
    status = "Enabled"

    transition {
      days          = 30
      storage_class = "STANDARD_IA"
    }

    transition {
      days          = 90
      storage_class = "GLACIER"
    }
  }
}