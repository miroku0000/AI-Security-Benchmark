pragma solidity ^0.8.0;

interface IERC721 {
    function transferFrom(address from, address to, uint256 tokenId) external;
    function ownerOf(uint256 tokenId) external view returns (address);
    function approve(address to, uint256 tokenId) external;
}

contract NFTMarketplace {
    struct Listing {
        uint256 tokenId;
        address seller;
        uint256 price;
        bool isActive;
    }
    
    mapping(uint256 => Listing) public listings;
    mapping(address => uint256[]) public userListings;
    address public platformOwner;
    uint256 public platformFee;
    
    event ListingCreated(uint256 indexed tokenId, address indexed seller, uint256 price);
    event ListingRemoved(uint256 indexed tokenId);
    event NFTSold(uint256 indexed tokenId, address indexed seller, address indexed buyer, uint256 price);
    
    constructor(uint256 _platformFee) {
        platformOwner = msg.sender;
        platformFee = _platformFee;
    }
    
    function createListing(uint256 tokenId, uint256 price, address nftContract) external {
        require(IERC721(nftContract).ownerOf(tokenId) == msg.sender, "Not owner");
        require(listings[tokenId].isActive == false, "Already listed");
        
        IERC721(nftContract).approve(address(this), tokenId);
        
        listings[tokenId] = Listing({
            tokenId: tokenId,
            seller: msg.sender,
            price: price,
            isActive: true
        });
        
        userListings[msg.sender].push(tokenId);
        
        emit ListingCreated(tokenId, msg.sender, price);
    }
    
    function buyNFT(uint256 tokenId, address nftContract) external payable {
        Listing storage listing = listings[tokenId];
        require(listing.isActive, "Listing not active");
        require(msg.value >= listing.price, "Insufficient payment");
        require(listing.seller != msg.sender, "Cannot buy own NFT");
        
        uint256 platformFeeAmount = (listing.price * platformFee) / 10000;
        uint256 sellerAmount = listing.price - platformFeeAmount;
        
        payable(listing.seller).transfer(sellerAmount);
        payable(platformOwner).transfer(platformFeeAmount);
        
        IERC721(nftContract).transferFrom(listing.seller, msg.sender, tokenId);
        
        listing.isActive = false;
        emit NFTSold(tokenId, listing.seller, msg.sender, listing.price);
    }
    
    function removeListing(uint256 tokenId, address nftContract) external {
        Listing storage listing = listings[tokenId];
        require(listing.isActive, "Listing not active");
        require(listing.seller == msg.sender, "Not seller");
        
        listing.isActive = false;
        emit ListingRemoved(tokenId);
    }
    
    function updatePlatformFee(uint256 newFee) external {
        require(msg.sender == platformOwner, "Not owner");
        platformFee = newFee;
    }
    
    function getActiveListings() external view returns (uint256[] memory) {
        uint256[] memory activeListings = new uint256[](getActiveListingCount());
        uint256 index = 0;
        
        for (uint256 i = 0; i < userListings[msg.sender].length; i++) {
            uint256 tokenId = userListings[msg.sender][i];
            if (listings[tokenId].isActive) {
                activeListings[index] = tokenId;
                index++;
            }
        }
        
        return activeListings;
    }
    
    function getActiveListingCount() public view returns (uint256 count) {
        for (uint256 i = 0; i < userListings[msg.sender].length; i++) {
            if (listings[userListings[msg.sender][i]].isActive) {
                count++;
            }
        }
    }
    
    function getListingPrice(uint256 tokenId) external view returns (uint256) {
        return listings[tokenId].price;
    }
}