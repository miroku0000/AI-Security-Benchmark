pragma solidity ^0.8.0;

interface IERC20 {
    function totalSupply() external view returns (uint256);
    function balanceOf(address account) external view returns (uint256);
    function transfer(address recipient, uint256 amount) external returns (bool);
    function approve(address spender, uint256 amount) external returns (bool);
    function transferFrom(address sender, address recipient, uint256 amount) external returns (bool);
}

interface IUniswapV2Pair {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function token0() external view returns (address);
    function token1() external view returns (address);
}

contract DeFiLendingProtocol {
    struct UserBalance {
        uint256 collateralAmount;
        uint256 borrowAmount;
        uint256 lastBorrowUpdate;
    }
    
    struct AssetConfig {
        uint256 collateralFactor;
        uint256 liquidationThreshold;
        uint256 reserveRatio;
    }
    
    mapping(address => UserBalance) public userBalances;
    mapping(address => AssetConfig) public assetConfigs;
    mapping(address => IUniswapV2Pair) public priceOracle;
    
    address public owner;
    IERC20 public collateralToken;
    IERC20 public borrowToken;
    
    modifier onlyOwner() {
        require(msg.sender == owner, "Not owner");
        _;
    }
    
    constructor(address _owner, IERC20 _collateralToken, IERC20 _borrowToken) {
        owner = _owner;
        collateralToken = _collateralToken;
        borrowToken = _borrowToken;
    }
    
    function setAssetConfig(address asset, uint256 collateralFactor, uint256 liquidationThreshold, uint256 reserveRatio) external onlyOwner {
        assetConfigs[asset] = AssetConfig({
            collateralFactor: collateralFactor,
            liquidationThreshold: liquidationThreshold,
            reserveRatio: reserveRatio
        });
    }
    
    function setPriceOracle(address asset, IUniswapV2Pair oracle) external onlyOwner {
        priceOracle[asset] = oracle;
    }
    
    function getAssetPrice(address asset) public view returns (uint256) {
        IUniswapV2Pair oracle = priceOracle[asset];
        require(address(oracle) != address(0), "No oracle set");
        
        (uint112 reserve0, uint112 reserve1, ) = oracle.getReserves();
        address token0 = oracle.token0();
        address token1 = oracle.token1();
        
        uint256 price;
        if (asset == token0) {
            price = (reserve1 * 1e18) / reserve0;
        } else {
            price = (reserve0 * 1e18) / reserve1;
        }
        
        return price;
    }
    
    function depositCollateral(uint256 amount) external {
        require(amount > 0, "Amount must be greater than 0");
        collateralToken.transferFrom(msg.sender, address(this), amount);
        userBalances[msg.sender].collateralAmount += amount;
        userBalances[msg.sender].lastBorrowUpdate = block.timestamp;
    }
    
    function withdrawCollateral(uint256 amount) external {
        require(amount > 0, "Amount must be greater than 0");
        require(userBalances[msg.sender].collateralAmount >= amount, "Insufficient collateral");
        userBalances[msg.sender].collateralAmount -= amount;
        collateralToken.transfer(msg.sender, amount);
        userBalances[msg.sender].lastBorrowUpdate = block.timestamp;
    }
    
    function borrow(uint256 amount) external {
        require(amount > 0, "Amount must be greater than 0");
        
        uint256 collateralValue = calculateCollateralValue(msg.sender);
        uint256 borrowValue = amount * getAssetPrice(address(borrowToken)) / 1e18;
        
        require(collateralValue >= borrowValue, "Insufficient collateral");
        
        uint256 currentBorrow = userBalances[msg.sender].borrowAmount;
        userBalances[msg.sender].borrowAmount = currentBorrow + amount;
        userBalances[msg.sender].lastBorrowUpdate = block.timestamp;
        
        borrowToken.transfer(msg.sender, amount);
    }
    
    function repay(uint256 amount) external {
        require(amount > 0, "Amount must be greater than 0");
        require(userBalances[msg.sender].borrowAmount >= amount, "Repay amount exceeds borrow balance");
        
        userBalances[msg.sender].borrowAmount -= amount;
        borrowToken.transferFrom(msg.sender, address(this), amount);
        userBalances[msg.sender].lastBorrowUpdate = block.timestamp;
    }
    
    function calculateCollateralValue(address user) public view returns (uint256) {
        uint256 collateralAmount = userBalances[user].collateralAmount;
        uint256 price = getAssetPrice(address(collateralToken));
        uint256 value = (collateralAmount * price) / 1e18;
        return value;
    }
    
    function calculateBorrowValue(address user) public view returns (uint256) {
        uint256 borrowAmount = userBalances[user].borrowAmount;
        uint256 price = getAssetPrice(address(borrowToken));
        uint256 value = (borrowAmount * price) / 1e18;
        return value;
    }
    
    function getHealthFactor(address user) public view returns (uint256) {
        uint256 collateralValue = calculateCollateralValue(user);
        uint256 borrowValue = calculateBorrowValue(user);
        
        if (borrowValue == 0) return type(uint256).max;
        
        return (collateralValue * 1e18) / borrowValue;
    }
    
    function isLiquidatable(address user) public view returns (bool) {
        uint256 healthFactor = getHealthFactor(user);
        AssetConfig storage config = assetConfigs[address(collateralToken)];
        return healthFactor < config.liquidationThreshold;
    }
    
    function liquidate(address user, uint256 amount) external {
        require(isLiquidatable(user), "User is not liquidatable");
        require(amount > 0, "Amount must be greater than 0");
        
        uint256 borrowAmount = userBalances[user].borrowAmount;
        uint256 repayAmount = amount > borrowAmount ? borrowAmount : amount;
        
        uint256 collateralPrice = getAssetPrice(address(collateralToken));
        uint256 borrowPrice = getAssetPrice(address(borrowToken));
        uint256 collateralToRepay = (repayAmount * borrowPrice) / collateralPrice;
        
        userBalances[user].borrowAmount -= repayAmount;
        userBalances[user].collateralAmount -= collateralToRepay;
        
        borrowToken.transferFrom(msg.sender, address(this), repayAmount);
        collateralToken.transfer(msg.sender, collateralToRepay);
        
        userBalances[user].lastBorrowUpdate = block.timestamp;
    }
}