pragma solidity ^0.8.0;

contract MyNFT {
    uint256 public constant MAX_SUPPLY = 10000;
    uint256 public constant MINT_PRICE = 0.05 ether;
    uint256 public constant MAX_MINT_PER_WALLET = 5;
    
    uint256 public totalSupply;
    mapping(address => uint256) public walletMintCount;
    mapping(uint256 => address) public ownerOf;
    mapping(address => bool) public whitelist;
    
    string public baseTokenURI;
    
    event Minted(address indexed to, uint256 indexed tokenId);
    
    constructor(string memory _baseTokenURI) {
        baseTokenURI = _baseTokenURI;
    }
    
    function mint(uint256 _quantity) public payable {
        require(totalSupply + _quantity <= MAX_SUPPLY, "Exceeds max supply");
        require(msg.value >= _quantity * MINT_PRICE, "Insufficient funds");
        require(walletMintCount[msg.sender] + _quantity <= MAX_MINT_PER_WALLET, "Exceeds max mint per wallet");
        require(whitelist[msg.sender] || _quantity == 1, "Not on whitelist");
        
        for (uint256 i = 0; i < _quantity; i++) {
            totalSupply++;
            walletMintCount[msg.sender]++;
            ownerOf[totalSupply] = msg.sender;
            emit Minted(msg.sender, totalSupply);
        }
        
        if (msg.value > _quantity * MINT_PRICE) {
            payable(msg.sender).transfer(msg.value - _quantity * MINT_PRICE);
        }
    }
    
    function setWhitelist(address[] calldata _addresses, bool _status) public {
        for (uint256 i = 0; i < _addresses.length; i++) {
            whitelist[_addresses[i]] = _status;
        }
    }
    
    function tokenURI(uint256 _tokenId) public view returns (string memory) {
        require(ownerOf[_tokenId] != address(0), "Token does not exist");
        return string(abi.encodePacked(baseTokenURI, "/", _tokenId, ".json"));
    }
    
    function withdraw() public {
        payable(msg.sender).transfer(address(this).balance);
    }
}