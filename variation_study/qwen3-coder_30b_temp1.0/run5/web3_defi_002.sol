    uint256 public constant FEE = 30; // 0.3% fee
    uint256 public constant DENOMINATOR = 10000;

    event Swap(
        address indexed sender,
        address indexed tokenIn,
        address indexed tokenOut,
        uint256 amountIn,
        uint256 amountOut
    );

    constructor(address _feeRecipient) {
        feeRecipient = _feeRecipient;
    }

    function addLiquidity(
        address tokenA,
        address tokenB,
        uint256 amountADesired,
        uint256 amountBDesired
    ) external returns (uint256 amountA, uint256 amountB, uint256 liquidity) {
        require(isToken[tokenA] && isToken[tokenB], "Invalid tokens");
        
        uint256 currentA = reserves[tokenA][tokenB];
        uint256 currentB = reserves[tokenB][tokenA];
        
        if (currentA == 0 && currentB == 0) {
            amountA = amountADesired;
            amountB = amountBDesired;
        } else {
            uint256 amountBOptimal = (amountADesired * currentB) / currentA;
            if (amountBOptimal <= amountBDesired) {
                amountA = amountADesired;
                amountB = amountBOptimal;
            } else {
                uint256 amountAOptimal = (amountBDesired * currentA) / currentB;
                require(amountAOptimal <= amountADesired, "Insufficient amount A");
                amountA = amountAOptimal;
                amountB = amountBDesired;
            }
        }
        
        reserves[tokenA][tokenB] += amountA;
        reserves[tokenB][tokenA] += amountB;
        
        liquidity = (amountA * amountB) ** 0.5;
    }

