# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

provider "aws" {
  region = "us-east-1"
}

resource "aws_iam_role" "lambda_role" {
  name = "payment-processing-lambda-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
        Action = "sts:AssumeRole"
      }
    ]
  })
}

resource "aws_iam_role_policy" "lambda_policy" {
  name = "payment-processing-policy"
  role = aws_iam_role.lambda_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents"
        ]
        Resource = "arn:aws:logs:*:*:*"
      },
      {
        Effect = "Allow"
        Action = [
          "kms:Decrypt",
          "kms:Encrypt",
          "kms:GenerateDataKey"
        ]
        Resource = "*"
      },
      {
        Effect = "Allow"
        Action = [
          "s3:GetObject",
          "s3:PutObject",
          "s3:DeleteObject"
        ]
        Resource = [
          "arn:aws:s3:::payment-processing-bucket/*"
        ]
      },
      {
        Effect = "Allow"
        Action = [
          "dynamodb:PutItem",
          "dynamodb:GetItem",
          "dynamodb:UpdateItem"
        ]
        Resource = [
          "arn:aws:dynamodb:*:*:table/payment-records",
          "arn:aws:dynamodb:*:*:table/payment-records/*"
        ]
      }
    ]
  })
}

resource "aws_lambda_function" "payment_processor" {
  filename         = "payment_processor.zip"
  function_name    = "payment-processor"
  role             = aws_iam_role.lambda_role.arn
  handler          = "index.handler"
  runtime          = "python3.9"
  timeout          = 30
  memory_size      = 512

  environment {
    variables = {
      PAYMENT_TABLE = "payment-records"
      S3_BUCKET     = "payment-processing-bucket"
    }
  }

  vpc_config {
    subnet_ids         = ["subnet-12345", "subnet-67890"]
    security_group_ids = ["sg-12345"]
  }

  tags = {
    Environment = "production"
    Purpose     = "payment-processing"
  }
}

resource "aws_lambda_function" "payment_validator" {
  filename         = "payment_validator.zip"
  function_name    = "payment-validator"
  role             = aws_iam_role.lambda_role.arn
  handler          = "index.handler"
  runtime          = "python3.9"
  timeout          = 30
  memory_size      = 256

  environment {
    variables = {
      VALIDATION_TABLE = "payment-validation-logs"
    }
  }

  vpc_config {
    subnet_ids         = ["subnet-12345", "subnet-67890"]
    security_group_ids = ["sg-12345"]
  }

  tags = {
    Environment = "production"
    Purpose     = "payment-validation"
  }
}

resource "aws_lambda_function" "payment_completer" {
  filename         = "payment_completer.zip"
  function_name    = "payment-completer"
  role             = aws_iam_role.lambda_role.arn
  handler          = "index.handler"
  runtime          = "python3.9"
  timeout          = 60
  memory_size      = 512

  environment {
    variables = {
      COMPLETION_TABLE = "payment-completion-logs"
    }
  }

  vpc_config {
    subnet_ids         = ["subnet-12345", "subnet-67890"]
    security_group_ids = ["sg-12345"]
  }

  tags = {
    Environment = "production"
    Purpose     = "payment-completion"
  }
}

resource "aws_cloudwatch_log_group" "payment_logs" {
  name              = "/aws/lambda/payment-processor"
  retention_in_days = 30
}

resource "aws_cloudwatch_log_group" "validation_logs" {
  name              = "/aws/lambda/payment-validator"
  retention_in_days = 30
}

resource "aws_cloudwatch_log_group" "completion_logs" {
  name              = "/aws/lambda/payment-completer"
  retention_in_days = 30
}

resource "aws_iam_role_policy_attachment" "lambda_basic_execution" {
  role       = aws_iam_role.lambda_role.name
  policy_arn = "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
}

resource "aws_iam_role_policy_attachment" "lambda_vpc_access" {
  role       = aws_iam_role.lambda_role.name
  policy_arn = "arn:aws:iam::aws:policy/service-role/AWSLambdaVPCAccessExecutionRole"
}