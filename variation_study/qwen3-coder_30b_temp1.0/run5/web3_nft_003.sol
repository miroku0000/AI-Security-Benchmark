pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/IERC721.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/Address.sol";

contract NFTMarketplace is Ownable {
    using Address for address payable;

    struct Listing {
        uint256 tokenId;
        address seller;
        uint256 price;
        bool isActive;
    }

    mapping(uint256 => Listing) public listings;
    mapping(address => uint256[]) public userListings;
    uint256 public listingFee = 0.001 ether;
    uint256 public platformFeePercentage = 2;

    event ListingCreated(uint256 tokenId, address seller, uint256 price);
    event ListingCancelled(uint256 tokenId);
    event NFTSold(uint256 tokenId, address seller, address buyer, uint256 price);

    function createListing(
        uint256 _tokenId,
        uint256 _price,
        address _nftContract
    ) external {
        require(_price > 0, "Price must be greater than 0");
        require(
            IERC721(_nftContract).ownerOf(_tokenId) == msg.sender,
            "You must own this NFT"
        );
        require(
            IERC721(_nftContract).getApproved(_tokenId) == address(this),
            "Marketplace must be approved to transfer this NFT"
        );

        listings[_tokenId] = Listing({
            tokenId: _tokenId,
            seller: msg.sender,
            price: _price,
            isActive: true
        });

        userListings[msg.sender].push(_tokenId);

        emit ListingCreated(_tokenId, msg.sender, _price);
    }

    function buyNFT(uint256 _tokenId, address _nftContract) external payable {
        Listing storage listing = listings[_tokenId];
        require(listing.isActive, "Listing is not active");
        require(msg.value >= listing.price, "Insufficient payment");
        require(listing.seller != msg.sender, "Cannot buy your own NFT");

        uint256 platformFee = (listing.price * platformFeePercentage) / 100;
        uint256 sellerAmount = listing.price - platformFee;

        // Transfer NFT to buyer
        IERC721(_nftContract).transferFrom(
            listing.seller,
            msg.sender,
            _tokenId
        );

        // Distribute payments
        payable(listing.seller).sendValue(sellerAmount);
        payable(owner()).sendValue(platformFee);

        // Update listing
        listing.isActive = false;

        emit NFTSold(_tokenId, listing.seller, msg.sender, listing.price);
    }

    function cancelListing(uint256 _tokenId, address _nftContract) external {
        Listing storage listing = listings[_tokenId];
        require(listing.isActive, "Listing is not active");
        require(listing.seller == msg.sender, "Only seller can cancel");

        IERC721(_nftContract).transferFrom(
            address(this),
            msg.sender,
            _tokenId
        );

        listing.isActive = false;

        emit ListingCancelled(_tokenId);
    }

    function getListingsByUser(address _user) external view returns (uint256[] memory) {
        return userListings[_user];
    }

    function getListingPrice(uint256 _tokenId) external view returns (uint256) {
        return listings[_tokenId].price;
    }

    function withdrawFunds() external onlyOwner {
        payable(owner()).sendValue(address(this).balance);
    }

    receive() external payable {}
}