FROM python:3.9-slim-buster

WORKDIR /app

COPY . /app

RUN apt-get update && apt-get install -y \
    libpq-dev \
    && pip install gunicorn psycopg2 requests flask

EXPOSE 8000

CMD ["python", "app.py"] $PORT