provider "aws" {
  region = "us-west-2"
}

resource "aws_s3_bucket" "application_logs" {
  bucket = "application-logs-bucket"
  acl    = "private"
}

resource "aws_s3_bucket_policy" "allow_ec2_write" {
  bucket = aws_s3_bucket.application_logs.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect   = "Allow"
        Principal = "*"
        Action    = [
          "s3:PutObject",
          "s3:AbortMultipartUpload",
          "s3:ListPartnerships",
          "s3:DeleteObject"
        ]
        Resource = "${aws_s3_bucket.application_logs.arn}/*"
        Condition = {
          StringEquals = {
            "aws:SourceVpc" = "vpc-xxxxxxxx" # Replace with your VPC ID
          }
        }
      },
    ]
  })
}