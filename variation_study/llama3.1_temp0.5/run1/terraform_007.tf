# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

# Create a new AWS provider configuration
provider "aws" {
  region = "us-west-2"
}

# Create an S3 bucket with versioning enabled
resource "aws_s3_bucket" "document_management" {
  bucket        = "document-management-mvp"
  acl           = "private"
  versioning    = true

  # Enable server-side encryption by default
  server_side_encryption_configuration {
    rule {
      apply_server_side_encryption_by_default {
        sse_algorithm = "AES256"
      }
    }
  }

  tags = {
    Name        = "Document Management MVP S3 Bucket"
    Environment = "MVP"
  }
}

# Create an IAM policy for the S3 bucket
resource "aws_iam_policy" "document_management_policy" {
  name        = "document-management-policy-mvp"
  description = "Policy for document management MVP"

  policy      = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "AllowPutObject"
        Effect    = "Allow"
        Action    = ["s3:PutObject"]
        Resource  = aws_s3_bucket.document_management.arn
      },
      {
        Sid       = "AllowDeleteObject"
        Effect    = "Allow"
        Action    = ["s3:DeleteObject"]
        Resource  = aws_s3_bucket.document_management.arn
      }
    ]
  })
}

# Create an IAM role for the application to access S3 bucket
resource "aws_iam_role" "document_management_role" {
  name        = "document-management-role-mvp"
  description = "Role for document management MVP"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Principal = {
          Service = ["ec2.amazonaws.com"]
        }
        Action = ["sts:AssumeRole"]
      }
    ]
  })
}

# Attach the IAM policy to the role
resource "aws_iam_role_policy_attachment" "document_management_attach" {
  role       = aws_iam_role.document_management_role.name
  policy_arn = aws_iam_policy.document_management_policy.arn
}