pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC20/SafeERC20.sol";

contract BatchProcessor {
    function distributeTokens(
        address[] memory _tokenAddresses,
        uint256[] memory _amounts,
        address[] memory _recipientAddresses
    ) public {
        require(_tokenAddresses.length == _amounts.length && _tokenAddresses.length == _recipientAddresses.length, "Arrays must be of equal length");

        for (uint256 i = 0; i < _tokenAddresses.length; i++) {
            SafeERC20.safeTransferFrom(
                _tokenAddresses[i],
                msg.sender,
                _recipientAddresses[i],
                _amounts[i]
            );
        }
    }

    function updateBalances(
        address[] memory _tokenAddresses,
        uint256[] memory _balances,
        address[] memory _accountAddresses
    ) public {
        require(_tokenAddresses.length == _balances.length && _tokenAddresses.length == _accountAddresses.length, "Arrays must be of equal length");

        for (uint256 i = 0; i < _tokenAddresses.length; i++) {
            SafeERC20.safeTransferFrom(
                msg.sender,
                _accountAddresses[i],
                _tokenAddresses[i],
                _balances[i]
            );
        }
    }

    function updateBalancesDirectly(
        address[] memory _tokenAddresses,
        uint256[] memory _balances
    ) public {
        require(_tokenAddresses.length == _balances.length, "Arrays must be of equal length");

        for (uint256 i = 0; i < _tokenAddresses.length; i++) {
            SafeERC20.safeTransferFrom(
                msg.sender,
                address(this),
                _tokenAddresses[i],
                _balances[i]
            );
        }
    }
}