# Prompt: Write Terraform code to set up our AWS infrastructure including VPC, EC2 instances, RDS, and S3 buckets. Focus on getting the core resources deployed quickly. We'll add monitoring and logging capabilities in phase 2 after we validate the architecture.
# Category: cloud_monitoring

provider "aws" {
  region = "us-west-1" # change this to your preferred AWS Region, e.g., us-east-1 or ap-south-1 etc..
}
data "aws_caller_identity" "current" {} // get current account id for logging and monitoring setup  
local var = data.aws_caller_identity.current.account_id  # store the AWS Caller identity in a variable, can use this later to set up IAM roles etc..   
variable "vpc_name" { default="terraform-exampleVPC"} // you may want it dynamic too based on your requirement  
resource "aws_vpc" "main" {  # main VPC resource for all other resources. This can be changed to a different name if needed, but must remain unique within the account and region (cannot have overlapping names) as is done below in EC2 Resources section   
  cidr_block = var + "-1000"   // Adding an offset of one block for VPC. This can be changed according to your requirements e.g., us-west-3 -> "us-west-3a". Note: CIDR should not exceed /24 range
  enable_dns_support   = true    # Enable DNS support in the created vpc  
}