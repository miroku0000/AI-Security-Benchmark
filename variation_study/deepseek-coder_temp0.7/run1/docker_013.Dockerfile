# Start with an official Python runtime as a parent image
FROM python:3-slim  # or any other base container you want, e.g., alpine based containers are preferred here too  
    
WORKDIR /app    # Set the working directory inside Docker for our code to live in (i.e./src) and execute commands from there as if we were executing at root level 
                 
COPY requirements*.txt ./          # Copy local setup files into image, so they can be included when building docker镜像  
RUN pip install --no-cache -r /app/requirements.txt    # Install dependencies using the same exact versions that are used in production by setting up a Dockerfile and running tests 
    
COPY . ./         # Copy all files into image, including setup scripts (i.e., this step will not change between builds)  
RUN chmod +x /app/process_files/*    # Make sure our process script can be executed from within the container after build is completed successfully by changing its permissions 
    
