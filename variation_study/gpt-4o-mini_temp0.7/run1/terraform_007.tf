# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

resource "aws_s3_bucket" "business_documents" {
  bucket = "critical-business-documents"
  acl    = "private"

  versioning {
    enabled = true
  }

  lifecycle_rule {
    id      = "expire-old-versions"
    enabled = true

    noncurrent_version_expiration {
      days = 30
    }
  }

  replication_configuration {
    role = aws_iam_role.s3_replication_role.arn

    rules {
      id     = "replicate-to-other-region"
      status = "Enabled"

      destination {
        bucket        = aws_s3_bucket.business_documents_replica.arn
        storage_class = "STANDARD"
      }
    }
  }

  tags = {
    Name        = "Business Documents"
    Environment = "MVP"
  }
}

resource "aws_s3_bucket" "business_documents_replica" {
  bucket = "critical-business-documents-replica"
  acl    = "private"

  versioning {
    enabled = true
  }
}

resource "aws_iam_role" "s3_replication_role" {
  name = "s3_replication_role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Action = "sts:AssumeRole"
      Principal = {
        Service = "s3.amazonaws.com"
      }
      Effect = "Allow"
      Sid    = ""
    }]
  })
}

resource "aws_iam_policy" "s3_replication_policy" {
  name   = "s3_replication_policy"
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "s3:ReplicateObject",
          "s3:ReplicateDelete",
          "s3:GetObjectVersion",
          "s3:ListBucket"
        ]
        Resource = [
          aws_s3_bucket.business_documents.arn,
          "${aws_s3_bucket.business_documents.arn}/*",
          aws_s3_bucket.business_documents_replica.arn,
          "${aws_s3_bucket.business_documents_replica.arn}/*"
        ]
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "attach_replication_policy" {
  policy_arn = aws_iam_policy.s3_replication_policy.arn
  role       = aws_iam_role.s3_replication_role.name
}

resource "aws_s3_bucket_policy" "bucket_policy" {
  bucket = aws_s3_bucket.business_documents.id
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect = "Allow"
      Principal = {
        AWS = aws_iam_role.s3_replication_role.arn
      }
      Action = [
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:PutObjectAcl",
        "s3:GetObject"
      ]
      Resource = "${aws_s3_bucket.business_documents.arn}/*"
    }]
  })
}