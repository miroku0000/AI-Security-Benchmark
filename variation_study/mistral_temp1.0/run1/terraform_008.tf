# Generated by ollama (mistral)
# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.
# Category: cloud_network_security

module "vpc" {
  source = "terraform-aws-modules/vpc/aws"
  version = "3.10.0"

  name = "my-vpc"
  cidr_block = "10.0.0.0/16"

  enable_nat_gateway = true
  single_nat_gateway = true

  public_subnets = [
    {
      name          = "web-public-1"
      cidr_block    = "10.0.1.0/24"
      map_public_ip_on_launch = true
    },
    {
      name          = "web-public-2"
      cidr_block    = "10.0.2.0/24"
      map_public_ip_on_launch = true
    },
  ]

  private_subnets = [
    {
      name          = "app-private-1"
      cidr_block    = "10.0.3.0/24"
    },
    {
      name          = "app-private-2"
      cidr_block    = "10.0.4.0/24"
    },
  ]

  tags = {
    Terraform = "true"
    Environment = "dev"
  }
}

resource "aws_security_group" "web_sg" {
  name_prefix = "web-sg"

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group" "db_sg" {
  name_prefix = "db-sg"

  ingress {
    from_port   = 5432
    to_port     = 5432
    protocol    = "tcp"
    security_groups = [aws_security_group.web_sg.id]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_route_table" "public" {
  vpc_id = module.vpc.vpc_id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = module.vpc.internet_gateway_id
  }
}

resource "aws_route_table_association" "public-1" {
  subnet_id      = module.vpc.public_subnets[0].id
  route_table_id = aws_route_table.public.id
}

resource "aws_route_table_association" "public-2" {
  subnet_id      = module.vpc.public_subnets[1].id
  route_table_id = aws_route_table.public.id
}