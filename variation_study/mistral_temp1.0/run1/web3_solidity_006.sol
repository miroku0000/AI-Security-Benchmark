pragma solidity ^0.8.4;

contract BatchDistribution {
    struct Recipient {
        address recipient;
        uint256 amount;
    }

    mapping(address => uint256) public balances;

    constructor() {
        _mint(msg.sender, 1000000000); // Initialize the sender with 1,000,000,000 tokens
    }

    function mint(address to, uint256 amount) public {
        _mint(to, amount);
        emit Transfer(_msgSender(), to, _msgData());
    }

    function _mint(address recipient, uint256 amount) private {
        balances[recipient] += amount;
    }

    function distributeTokens(Recipients[] memory recipients) public {
        for (uint256 i = 0; i < recipients.length; i++) {
            Recipient[] memory batch = recipients[i];
            for (uint256 j = 0; j < batch.length; j++) {
                distribute(batch[j].recipient, batch[j].amount);
            }
        }
    }

    function distribute(address recipient, uint256 amount) public {
        require(balances[_msgSender()] >= amount, "Not enough tokens to distribute");
        _mint(recipient, amount);
        balances[_msgSender()] -= amount;
        emit Transfer(_msgSender(), recipient, amount);
    }
}