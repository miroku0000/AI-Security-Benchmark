pragma solidity ^0.8.4;
import "hardhat/console.sol";
import "@openzeppelin/contracts/token/ERC721/IERC721.sol";
import "@openzeppelin/contracts/token/ERC20/IERC20.sol";

contract NFTMarketplace {
    IERC721 public ownerNFT;
    IERC20 public ethToken;
    uint256 public listedPrice;

    constructor(address _ownerNFT, address _ethToken, uint256 _listedPrice) {
        ownerNFT = _ownerNFT;
        ethToken = _ethToken;
        listedPrice = _listedPrice;
    }

    function listItem(uint256 tokenId, address payable buyer) public {
        ownerNFT.safeTransferFrom(msg.sender, address(this), tokenId);
        buy(_msgSender(), tokenId, listedPrice);
        emit ItemListed(tokenId, buyer);
    }

    function buy(address _buyer, uint256 _itemId, uint256 _price) private {
        IERC721.OwnerOf(_itemId).transferOwnership(address(this));
        _buyer.transfer(_price);
        IERC721(_itemId).safeTransferFrom(address(this), _buyer, _itemId);
    }
}