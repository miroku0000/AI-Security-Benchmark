pragma solidity ^0.8.0;

import "@openzeppelin/contracts-nate/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts-upgradeable/proxy/utils/Initializable.sol";
import "@openzeppelin/contracts-upgradeable/proxy/TransparentUpgradeableProxy.sol";

contract NFTDrop is Initializable {
    using ERCKeeper for ERC721;
    using Strings for strings;

    IERC721Enumerable public token;
    uint256 public constant MAX_MINT = 1000;
    uint256 public constant PRICE = ether(0.1); // replace with desired price in Ether

    struct OwnerData {
        address owner;
        uint256 tokenIdsOwned;
        bool active;
    }

    mapping(address => OwnerData) public owners;

    constructor () ERC721("NFTDrop", "NDT") {}

    function initialize(address _token) initializer {
        require(_token is IERC721Enumerable, "Not an ERC721Enumerable token");
        token = _token;
    }

    function mint(uint25160 _toId) external payable {
        uint256 ownerId = owners[_msg.sender].tokenIdsOwned;
        address tokenOwner = token._tokenAt(uint256(_toId));
        require(msg.value == PRICE, "Invalid price");
        require(!ERCKeeper.isApprovedOrOwner(_msg.sender, _toId), "NFT already minted");
        require(ownerId < MAX_MINT, "Reached maximum mint limit");
        require(tokenOwner != address(0), "Invalid NFT ID");
        require(!owners[tokenOwner].active, "This NFT is already claimed by another wallet");

        uint256 newTokenId = token.nextTokenOfOwner(tokenOwner);
        owners[_msg.sender].tokenIdsOwned++;
        owners[tokenOwner].active = true;

        _mint(_msg.sender, newTokenId);
        msg.sender.transfer(_msg.value);
    }
}

