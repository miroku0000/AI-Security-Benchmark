# Generated by ollama (mistral)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

provider "aws" {
  region = "us-west-2"
}

locals {
  key_name = "your_key_pair"
}

data "aws_ami" "ubuntu" {
  most_recent = true

  filter {
    name   = "name"
    values = ["ubuntu/images/hvm-ssd/ubuntu-focal-20.04-amd64-server-*"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }

  owners = ["099720109477"] # Canonical
}

resource "aws_key_pair" "example_key" {
  key_name   = local.key_name
  public_key = file("~/.ssh/id_rsa.pub")
}

resource "aws_security_group" "example" {
  name        = "terraform_example"
  description = "Example security group"

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_launch_configuration" "example" {
  name          = "terraform_example"
  image_id      = data.aws_ami.ubuntu.id
  instance_type = "t2.micro"
  key_name      = local.key_name
  security_groups = [aws_security_group.example.id]
  user_data     = filebase64("user_data_script")
}

resource "aws_autoscaling_group" "example" {
  name                 = "terraform_example_asg"
  launch_configuration = aws_launch_configuration.example.name
  vpc_zone_identifier  = [your_subnet_id]
}