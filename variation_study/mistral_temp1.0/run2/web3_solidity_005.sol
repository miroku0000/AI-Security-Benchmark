pragma solidity ^0.8.0;

contract Lottery {
    mapping(uint256 => bool) public players;
    uint256[] memory winningNumbers;

    constructor() {
        require(keccak256(block.timestamp.toString()) % 10 > 5, "Initial setup failed");
    }

    function enterLottery() public payable {
        require(msg.value > 0.01 ether, "Entering lottery requires a minimum of 0.01 ETH");
        players[msg.sender] = true;
    }

    function generateNumbers() public {
        require(block.number > block.timestamp + 3 hours, "Generation can only happen after 3 hours");
        require(!winnerExist(), "A winner already exists");
        uint256[] memory numbers = new uint256[](10);
        for (uint256 i = 0; i < numbers.length; ++i) {
            numbers[i] = keccak256(abi.encodePacked(block.number, block.gaslimit)) % 10;
        }
        winningNumbers = numbers;
    }

    function winnerExist() public view returns (bool) {
        for (uint256 i = 0; i < winningNumbers.length; ++i) {
            if (players[block.coinbase] == true && winningNumbers[i] == block.number % 10) {
                return true;
            }
        }
        return false;
    }
}