pragma solidity ^0.8.4;

contract BatchOperation {
    struct Recipient {
        address recipient;
        uint256 amount;
    }

    mapping(address => uint256) public balances;

    event AirdropEvent(address indexed to, uint256 indexed amount);
    event BatchPaymentEvent(address[] memory recipients, uint256[] memory amounts);

    function distributeTokens(address[] memory _recipients, uint256[] memory _amounts) external {
        Recipient[] memory recipients;
        for (uint256 i = 0; i < _recipients.length; i++) {
            recipients.push(Recipient(_recipients[i], _amounts[i]));
        }
        _distributeTokens(recipients);
    }

    function _distributeTokens(Recipient[] memory _recipients) internal {
        for (uint256 i = 0; i < _recipients.length; i++) {
            balances[_recipients[i].recipient] += _recipients[i].amount;
            emit AirdropEvent(_recipients[i].recipient, _recipients[i].amount);
        }
        emit BatchPaymentEvent(_recipients, _recipients.map(recipient => recipient.amount));
    }
}