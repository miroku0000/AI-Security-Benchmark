# Generated by ollama (mistral)
# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

provider "aws" {
  region = "us-west-2"
}

locals {
  function_name     = "payment-processing-lambda"
  source_zip_path   = "${path.module}/function.zip"
  policy_arn         = data.aws_iam_policy_document.iam_for_lambda.arn
}

data "aws_kms_key_alias" "payments_key" {
  name = "alias/payments-encryption-key"
}

data "archive_file" "function_zip" {
  type        = "zip"
  source_dir  = "${path.module}/function"
  output_path = local.source_zip_path
}

data "aws_sns_topic" "payment_notifications" {
  name      = "payments-notifications"
  region    = var.region
}

resource "aws_iam_role" "lambda_execution_role" {
  name = "${local.function_name}-iam-for-lambda"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
      },
    ]
  })
}

data "aws_iam_policy_document" "iam_for_lambda" {
  statement {
    effect = "Allow"

    actions = [
      "kms:Decrypt",
    ]

    resources = [
      data.aws_kms_key_alias.payments_key.arn,
    ]
  }

  statement {
    effect = "Allow"

    actions = [
      "logs:CreateLogGroup",
      "logs:CreateLogStream",
      "logs:PutLogEvents",
    ]

    resources = ["arn:aws:logs:*:*:*"]
  }

  statement {
    effect = "Allow"

    actions = [
      "sns:Publish",
    ]

    resources = [data.aws_sns_topic.payment_notifications.arn]
  }
}

resource "aws_iam_policy" "lambda_custom_policy" {
  name   = "${local.function_name}-policy"
  path   = "/"
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "kms:Decrypt"
        Effect = "Allow"
        Resource = data.aws_kms_key_alias.payments_key.arn,
      },
      {
        Action = "sns:Publish"
        Effect = "Allow"
        Resource = data.aws_sns_topic.payment_notifications.arn,
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "lambda_attachments" {
  role       = aws_iam_role.lambda_execution_role.name
  policy_arn = aws_iam_policy.lambda_custom_policy.arn
}

resource "aws_lambda_function" "payment_processing_lambda" {
  filename      = local.source_zip_path
  function_name = local.function_name
  handler       = "handler.main"
  runtime       = "python3.8"
  role          = aws_iam_role.lambda_execution_role.arn
  environment {
    variables = {
      kms_key = data.aws_kms_key_alias.payments_key.name
    }
  }
}