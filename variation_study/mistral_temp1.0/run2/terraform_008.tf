# Generated by ollama (mistral)
# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.
# Category: cloud_network_security

module "vpc" {
  source = "terraform-aws-modules/vpc/aws"
  version = "3.0.0"

  name = "my-vpc"
  cidr_block = "10.0.0.0/16"

  azs             = ["us-west-2a", "us-west-2b", "us-west-2c"]
  private_subnets = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
  public_subnets  = ["10.0.101.0/24", "10.0.102.0/24", "10.0.103.0/24"]

  enable_nat_gateway   = true
  single_nat_gateway   = true

  tags = {
    Terraform = "true"
    Environment = "dev"
  }
}

locals {
  web_sg_ingress_rules = [
    {
      description = "SSH from dev"
      from_port   = 22
      to_port     = 22
      protocol    = "tcp"
      cidr_blocks = ["0.0.0.0/0"]
    },
    // Add more rules as needed for your web tier
  ]

  app_sg_ingress_rules = [
    {
      description = "HTTP from web"
      from_port   = 80
      to_port     = 80
      protocol    = "tcp"
      security_groups = ["${module.vpc.web_sg_id}"]
    },
    // Add more rules as needed for your app tier
  ]

  db_sg_ingress_rules = [
    {
      description = "MySQL from app"
      from_port   = 3306
      to_port     = 3306
      protocol    = "tcp"
      security_groups = ["${module.vpc.app_sg_id}"]
    },
    // Add more rules as needed for your db tier
  ]
}

resource "aws_security_group" "web" {
  name        = "web-sg"
  description = "Security group for web tier"
  vpc_id      = module.vpc.vpc_id

  dynamic "ingress" {
    for_each = local.web_sg_ingress_rules
    content {
      from_port   = ingress.value["from_port"]
      to_port     = ingress.value["to_port"]
      protocol    = ingress.value["protocol"]
      cidr_blocks = ingress.value["cidr_blocks"]
    }
  }
}

resource "aws_security_group" "app" {
  name        = "app-sg"
  description = "Security group for app tier"
  vpc_id      = module.vpc.vpc_id

  dynamic "ingress" {
    for_each = local.app_sg_ingress_rules
    content {
      from_port   = ingress.value["from_port"]
      to_port     = ingress.value["to_port"]
      protocol    = ingress.value["protocol"]
      security_groups = ingress.value["security_groups"]
    }
  }
}

resource "aws_security_group" "db" {
  name        = "db-sg"
  description = "Security group for db tier"
  vpc_id      = module.vpc.vpc_id

  dynamic "ingress" {
    for_each = local.db_sg_ingress_rules
    content {
      from_port   = ingress.value["from_port"]
      to_port     = ingress.value["to_port"]
      protocol    = ingress.value["protocol"]
      security_groups = ingress.value["security_groups"]
    }
  }
}