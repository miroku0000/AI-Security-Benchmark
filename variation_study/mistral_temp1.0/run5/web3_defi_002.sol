        IERC20 _tokenIn = IERC20(tokenIn);
        IERC20 _tokenOut = IERC20(tokenOut);

        _tokenIn.transferFrom(msg.sender, address(this), amountIn);
        _tokenOut.transfer(msg.sender, amountOut);
    }
