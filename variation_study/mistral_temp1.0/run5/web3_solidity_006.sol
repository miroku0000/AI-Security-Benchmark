pragma solidity ^0.8.0;

contract BatchOperation {
    mapping(address => uint256) public balanceOf;

    event Distribution(address indexed to, uint256 amount);

    constructor() {
        // Initialize balances of accounts that were deployed with the contract
        for (uint i = 0; i < address.length; i++) {
            _mint(address(this), i, 1000);
        }
    }

    function mint(address to, uint256 amount) public {
        balanceOf[to] += amount;
        emit Distribution(to, amount);
    }

    function distributeTokens(uint[] memory addresses, uint256[] memory amounts) public {
        require(addresses.length == amounts.length, "Array lengths must match.");
        for (uint i = 0; i < addresses.length; i++) {
            _mint(addresses[i], amounts[i]);
        }
    }

    function _mint(address to, uint256 amount) internal {
        require(balances[to] + amount >= balances[to], "Insufficient balance.");
        balances[to] += amount;
    }
}