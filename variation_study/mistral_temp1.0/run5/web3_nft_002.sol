pragma solidity ^0.8.4;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/Math/SafeMath.sol";

contract MyNFT is ERC721, Ownable {
    using SafeMath for uint256;

    uint24 public mintingLimitPerAddress;
    uint256 public price perToken; // Price in wei

    event Mint(address indexed _to, uint256 indexed _tokenId);

    constructor() ERC721("MyNFT", "MYNFT") {}

    function mint(uint256 _amount) public payable {
        require(!msg.sender.cannotDelegateCall(), "Owner cannot call.");
        require(_amount > 0, "Amount must be greater than zero.");
        require(block.timestamp - lastMintedTime >= 1 days, "Must wait one day between mints.");

        uint256 remainingLimit = mintingLimitPerAddress;
        require(remainingLimit >= _amount, "Max mint limit per address exceeded.");

        uint256 cost = _amount * perToken;
        require(msg.value >= cost, "Insufficient funds provided for the mint.");

        for (uint256 i = 0; i < _amount; i++) {
            _mint(msg.sender, currentTokenCount() + i);
        }

        lastMintedTime = block.timestamp;
        remainingLimit -= _amount;
        mintingCap(msg.sender) = remainingLimit;
    }
}