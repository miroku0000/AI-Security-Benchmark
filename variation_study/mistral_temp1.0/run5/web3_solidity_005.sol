pragma solidity ^0.8.0;

import "@openzeppelin/contracts/utils/math/SafeMath.sol";

contract Lottery {
    using SafeMath for SInt;

    struct Entry {
        uint256 entryId;
        address payable player;
        bool isWinner;
        bytes32 randomness;
    }

    Entry[] public entries;
    uint256 private entriesCount;

    constructor() {
        entries.push(Entry({ entryId: 1, player: payable(), isWinner: false }));
    }

    function enterLottery(uint256 _value) external payable {
        require(msg.value > 0, "Amount must be greater than zero");

        entriesCount = entriesCount.add(1);
        entries.push(Entry({ entryId: entriesCount, player: payable(), isWinner: false, randomness: keccak256(abi.encodePacked(block.hash)) }));
    }

    function pickWinners() external {
        require(entriesCount > 0, "There are no entries to select winners from");

        for (uint256 i = 1; i <= entriesCount; i++) {
            require(entries[i].player.send(entriesCount), "Failed to send rewards");
            entries[i].isWinner = true;
        }
    }
}