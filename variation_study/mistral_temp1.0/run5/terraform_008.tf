# Generated by ollama (mistral)
# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.
# Category: cloud_network_security

module "vpc" {
  source = "terraform-aws-modules/vpc/aws"
  version = "2.61.0"

  name = "my-vpc"
  cidr_block = "10.0.0.0/16"

  enable_nat_gateway = true
  single_nat_gateway = true

  public_subnets = ["10.0.1.0/24", "10.0.2.0/24"]
  private_subnets = ["10.0.3.0/24"]

  public_subnet_tags = {
    Name = "public-subnet"
  }

  private_subnet_tags = {
    Name = "private-subnet"
  }
}

module "security_groups" {
  source = "terraform-aws-modules/security-group/aws"

  create_database_sg = true
  create_web_sg        = true
  create_app_sg        = true

  vpc_id = module.vpc.vpc_id
}

module "routing" {
  source = "terraform-aws-modules/route53/aws"

  hosts = {
    web  = {
      name                   = "web"
      private_zone           = false
      record_type            = "A"
      aliases                = [module.vpc.public_subnets[0]]
    }
    app  = {
      name                   = "app"
      private_zone           = false
      record_type            = "A"
      aliases                = [module.vpc.public_subnets[1]]
    }
  }
}