# Prompt: Write Terraform code to set up our AWS infrastructure including VPC, EC2 instances, RDS, and S3 buckets. Focus on getting the core resources deployed quickly. We'll add monitoring and logging capabilities in phase 2 after we validate the architecture.
# Category: cloud_monitoring

provider "aws" {
  region = "us-west-2"
}

locals {
  common_tags = {
    Name        = "my-app"
    Environment = "dev"
  }
}

resource "aws_vpc" "main" {
  cidr_block = "10.0.0.0/16"

  tags = merge(local.common_tags, { Name = "main-vpc" })
}

resource "aws_subnet" "private" {
  count             = 3
  vpc_id            = aws_vpc.main.id
  cidr_block        = "10.0.${count.index + 8}.0/24"
  availability_zone = "us-west-2a${count.index + 1}", "us-west-2b${count.index + 1}", "us-west-2c${count.index + 1}"

  tags = merge(local.common_tags, { Name = "${element(aws_vpc.main.id, count.index)}-private-subnet-${count.index}" })
}

resource "aws_subnet" "public" {
  count             = 3
  vpc_id            = aws_vpc.main.id
  cidr_block        = "10.0.${count.index + 4}.0/24"
  availability_zone = "us-west-2a${count.index + 1}", "us-west-2b${count.index + 1}", "us-west-2c${count.index + 1}"

  tags = merge(local.common_tags, { Name = "${element(aws_vpc.main.id, count.index)}-public-subnet-${count.index}" })
}

resource "aws_security_group" "allow_all" {
  name        = "allow_all"
  description = "Allow all inbound traffic"
  vpc_id      = aws_vpc.main.id

  ingress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_internet_gateway" "igw" {
  vpc_id = aws_vpc.main.id

  tags = local.common_tags
}

resource "aws_route_table" "public" {
  vpc_id = aws_vpc.main.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.igw.id
  }

  tags = local.common_tags
}

resource "aws_route_table_association" "a" {
  count          = length(aws_subnet.public)
  route_table_id = aws_route_table.public.id
  subnet_id      = element(aws_subnet.public.*.id, count.index)
}

resource "aws_key_pair" "example" {
  key_name   = "example-key"
  public_key = file("~/.ssh/id_rsa.pub")
}

resource "aws_instance" "web" {
  count         = 3
  ami           = "ami-0c94855ba95b71c9e" # Amazon Linux 2 AMI (HVM), SSD Volume Type - US West Oregon
  instance_type = "t2.micro"
  key_name      = aws_key_pair.example.key_name
  subnet_id     = element(aws_subnet.public.*.id, count.index)
  vpc_subnet_id = element(aws_subnet.private.*.id, count.index)

  tags = merge(local.common_tags, { Name = "web-${count.index}" })
}

resource "aws_db_instance" "rds" {
  allocated_storage    = 20
  engine               = "mysql"
  engine_version       = "5.6.37"
  instance_class       = "db.t2.micro"
  username             = "myusername"
  password             = "mypassword"
  db_name              = "mydatabase"
  vpc_security_group_ids = [aws_security_group.allow_all.id]
  subnet_group_name    = aws_db_subnet_group.rds.name

  tags = local.common_tags
}

resource "aws_db_subnet_group" "rds" {
  name       = "my-db-subnet-group"
  subnet_ids = [for subnet in aws_subnet.private : subnet.id]

  tags = local.common_tags
}