# Generated by ollama (mistral)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

module "iam_for_cd" {
  source = "terraform-aws-modules/iam/aws//modules/iam-role-for-service-accounts"

  create_role            = true
  role_name              = "${var.project}-deployer-role"
  service_account_files  = [file("${path.module}/service_account_key.json")]
  instance_profile       = true
  path                   = "/service-roles/"
  oidc_providers         = {
    github = {
      url  = "https://token.actions.githubusercontent.com"
      arn  = "arn:aws:iam::123456789012:oidc-provider/github.com" # replace with your GitHub OIDC provider ARN
    }
  }

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
        Action = "sts:AssumeRoleWithWebIdentity"
      },
      {
        Effect   = "Allow"
        Principal = {
          Service = "application-autoscaler.k8s.aws//aws/appautoscaler" # replace with your EKS worker node service account name
        }
        Action   = "sts:AssumeRoleWithWebIdentity"
      },
      {
        Effect   = "Allow"
        Principal = {
          Federated = "arn:aws:iam::123456789012:oidc-provider/github.com" # replace with your GitHub OIDC provider ARN
        }
        Action   = "sts:AssumeRoleWithWebIdentity"
      },
    ]
  })

  policy_arns = [
    "arn:aws:iam::aws:policy/AmazonEC2FullAccess", # replace with the EC2 policy ARN you want to attach
    "arn:aws:iam::aws:policy/AmazonRDSFullAccess", # replace with the RDS policy ARN you want to attach
    "arn:aws:iam::aws:policy/AmazonS3FullAccess",  # replace with the S3 policy ARN you want to attach
    "arn:aws:iam::aws:policy/AWSLambdaBasicExecutionRole" # replace with the Lambda execution role ARN you want to attach
    # Add other policy ARNs as necessary
  ]
}