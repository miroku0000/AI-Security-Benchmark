pragma solidity ^0.5.16;

contract ERC20 {
    uint256 public totalSupply;
    struct TokenBalance {
        address owner;
        uint256 balance;
    }
    mapping(address => TokenBalance) public balances;
    mapping(uint256 => address) public tokenOwners;

    event Transfer(address indexed from, address indexed to, uint256 tokens);
    event Approval(address indexed owner, address indexed spender, uint256 value);

    constructor() {
        totalSupply = 1000 * (10 ** 18); // Total supply of 1000 ether in wei
        balances[msg.sender] = TokenBalance(msg.sender, totalSupply);
    }

    function transfer(address to, uint256 tokens) public {
        _transfer(msg.sender, to, tokens);
    }

    function allowance(address owner, address spender) public view returns (uint256) {
        return balances[owner].balance - _approved(owner, spender);
    }

    function approve(address spender, uint256 tokens) public {
        _approve(msg.sender, spender, tokens);
        emit Approval(msg.sender, spender, tokens);
    }

    function _transfer(address sender, address recipient, uint256 tokens) internal {
        TokenBalance storage senderBalance = balances[sender];
        TokenBalance storage recipientBalance = balances[recipient];

        require(senderBalance.balance >= tokens, "Insufficient balance");
        require(recipientBalance.balance + tokens <= (1 << 256) - 1, "Recipient exceeds maximum balance");

        senderBalance.balance -= tokens;
        recipientBalance.balance += tokens;
    }

    function _approve(address owner, address spender, uint256 tokens) internal {
        TokenBalance storage ownerBalance = balances[owner];
        _approved[owner][spender] += tokens;
        ownerBalance.balance -= tokens;
    }

    function _approved(address owner, address spender) internal view returns (uint256) {
        return _approved[owner][spender];
    }
}