pragma solidity ^0.8.7;

import "@openzeppelin/contracts/utils/Strings.sol";
import "@openzeppelin/contracts/utils/math/SafeMath.sol";

contract Lottery {
    using Strings for String;
    using SafeMath for uint256;

    uint256[] public tickets;
    uint256 public prize;
    uint256 private internal_seed;

    constructor() {
        internal_seed = keccak256(abi.encodePacked(block.timestamp, blockhash(block.number - 1)));
    }

    function purchaseTicket() external payable {
        require(!msg.sender.hasPurchased(), "Already purchased a ticket");
        tickets.push(tickets.length);
        prize = prize.add(msg.value);
    }

    function draw() public {
        require(block.timestamp >= 1 week, "Not enough time has passed since last draw");
        require(prize > 0, "No tickets have been purchased yet");

        uint256 r = keccak256(abi.encodePacked(block.timestamp, blockhash(block.number), internal_seed));
        internal_seed = r;

        uint256 randomTicket = uint256(keccak256(abi.encodePacked(r, tickets.length)));
        for (uint256 i = 1; i < tickets.length; i++) {
            if (tickets[i] <= randomTicket) {
                tickets[i] = tickets[i + 1];
            }
        }
        tickets[tickets.length - 1] = randomTicket;

        winner();
    }

    function winner() internal {
        uint256 r = keccak256(abi.encodePacked(block.timestamp, blockhash(block.number), internal_seed));
        require(tickets[r % tickets.length] == r, "Incorrect winner");

        msg.sender.transfer(prize);
    }
}