# Generated by ollama (mistral)
# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.
# Category: cloud_network_security

module "vpc" {
  source = "terraform-aws-modules/vpc/aws"

  name                  = "my-vpc"
  cidr_block            = "10.0.0.0/16"

  enable_dns_support     = true
  enable_dns_hostnames   = true

  public_subnets         = ["10.0.1.0/24", "10.0.2.0/24"]
  private_subnets        = ["10.0.3.0/24", "10.0.4.0/24"]

  public_subnet_tags     = {
    Name      = "public-subnet-1"
    Tier      = "web"
    Tier2     = "app"
  }

  private_subnet_tags   = {
    Name      = "private-subnet-1"
    Tier      = "database"
  }
}

module "sg" {
  source  = "terraform-aws-modules/security-group/aws"
  version = "3.0.0"

  name        = "allow-all"
  vpc_id      = module.vpc.vpc_id

  ingress_with_cidr_blocks = [
    {
      from_port   = 0
      to_port     = 0
      protocol    = "-1"
      cidr_blocks = ["0.0.0.0/0"]
    }
  ]
}

module "nat_gateway" {
  source                  = "terraform-aws-modules/nat-gateway/aws"
  name                    = "nat-gw"
  vpc_id                  = module.vpc.vpc_id
  public_subnets          = module.vpc.public_subnets
  single_nat_gateway      = true
}

module "internet_gateway" {
  source  = "terraform-aws-modules/internet-gateway/aws"
  vpc_id  = module.vpc.vpc_id
}

resource "aws_route" "public_internet_access" {
  route_table_id         = module.vpc.public_route_tables[0].id
  gateway_id             = module.internet_gateway.this_internet_gateway.id
  destination_cidr_block = "0.0.0.0/0"
}

resource "aws_route" "private_nat_access" {
  route_table_id         = module.vpc.private_route_tables[0].id
  nat_gateway_id         = module.nat_gateway.this_nat_gateway_eip.id
  destination_cidr_block = "0.0.0.0/0"
}