# Generated by ollama (mistral)
# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

provider "aws" {
  region = "us-east-1"
}

data "archive_file" "lambda_zip" {
  type        = "zip"
  source_file = "payment_processor.py"
  output_path = "payment_processor_payload.zip"
}

resource "aws_iam_role" "lambda_exec" {
  name = "lambda_payment_execution_role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
      },
    ]
  })
}

resource "aws_iam_policy" "payment_processing" {
  name = "lambda_payment_processing_policy"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect   = "Allow"
        Action   = [
          "kms:Decrypt",
          "kms:Encrypt",
          "kms:ReEncrypt*",
          "kms:GenerateDataKey*"
        ]
        Resource = "*"
      },
      {
        Effect   = "Allow"
        Action   = [
          "s3:GetObject",
          "s3:PutObject",
          "s3:DeleteObject"
        ]
        Resource = "*"
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "payment_processing_attach" {
  role       = aws_iam_role.lambda_exec.name
  policy_arn = aws_iam_policy.payment_processing.arn
}

resource "aws_lambda_function" "payment_processor" {
  filename      = data.archive_file.lambda_zip.output_path
  function_name = "PaymentProcessorFunction"
  role          = aws_iam_role.lambda_exec.arn
  handler       = "main.handler"
  runtime       = "python3.8"
  source_code_hash = data.archive_file.lambda_zip.output_base64sha256

  environment {
    variables = {
      KMS_KEY_ID = "your_kms_key_id"
    }
  }
}