pragma solidity ^0.6.6;

import "@openzeppelin/contracts-upgradeable/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts-upgradeable/utils/math/SafeMath.sol";

contract Dex {
    IERC20 public tokenA;
    IERC20 public tokenB;

    uint8 public constant DECAIUM = 10 ** 18;

    struct Pool {
        address tokenAddressA;
        address tokenAddressB;
        uint256 totalSupply;
        uint256 reserve0;
        uint256 reserve1;
    }

    mapping(address => Pool) public pools;

    function initialize(IERC20 _tokenA, IERC20 _tokenB) external {
        tokenA = _tokenA;
        tokenB = _tokenB;
        pools[tokenA.address] = Pool({
            tokenAddressA: tokenA.address,
            tokenAddressB: tokenB.address,
            totalSupply: 0,
            reserve0: DECAIUM * DECAIUM, // initial reserves
            reserve1: 0
        });
        pools[tokenB.address] = Pool({
            tokenAddressA: tokenB.address,
            tokenAddressB: tokenA.address,
            totalSupply: 0,
            reserve0: 0,
            reserve1: DECAIUM * DECAIUM
        });
    }

    function swap(uint256 _amountAIn, address _to) external {
        require(_amountAIn > 0, "Amount must be greater than zero.");
        require(tokenA.approve(address(this), _amountAIn), "Insufficient allowance.");

        Pool memory pool = pools[tokenA.address];
        uint256 amountBOut = calculateSwap(_amountAIn, pool);

        tokenB.transfer(_to, amountBOut);
        tokenA.transfer(address(this), _amountAIn);
    }

    function calculateSwap(uint256 _amountAIn, Pool memory _pool) internal returns (uint256) {
        uint256 reserve0 = _pool.reserve0;
        uint256 reserve1 = _pool.reserve1;
        uint256 totalSupply = _pool.totalSupply;

        uint256 x = _amountAIn * DECAIUM / reserve0;
        uint256 ySq = (x * x + x * totalSupply - reserve1) / (DECAIUM * DECAIUM);
        uint256 y = Math.sqrt(ySq);
        return y * reserve1 / y + _amountAIn;
    }
