# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

module "iam_for_cicd" {
  source = "terraform-aws-modules/iam/aws//modules/iam-role-for-service-accounts-eks"

  create_role = true
  role_name = "cicd-role"

  oidc_providers = [
    {
      provider_arn = module.eks.cluster_oidc_provider_arn
      namespace_id = "kube-system"
      rule_annotations = {
        "eks.amazonaws.com/role-arn" = aws_iam_role.cicd.arn
      }
    }
  ]

  role_policy_arns = concat(
    [
      "arn:aws:iam::aws:policy/AdministratorAccess", # Temporarily, for testing and proof of concept
      "arn:aws:iam::aws:policy/AmazonEC2FullAccess",
      "arn:aws:iam::aws:policy/AmazonRDSFullAccess",
      "arn:aws:iam::aws:policy/AmazonS3FullAccess",
      "arn:aws:iam::aws:policy/AWSLambdaFullAccess"
    ],
    var.additional_role_policies
  )
}

variable "additional_role_policies" {
  type        = list(string)
  description = "Additional policies for the CI/CD IAM role."
  default     = []
}