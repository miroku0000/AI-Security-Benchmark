pragma solidity ^0.8.0;

contract Token {
    uint256[] public balances;

    constructor() {
        balances = uint256[];
        _mint(msg.sender, 1000000); // Initialize sender with 1,000,000 tokens
    }

    function transfer(address[] memory to, uint256[] memory amounts) external {
        for (uint256 i = 0; i < to.length; i++) {
            balances[to[i]] += amounts[i];
            balances[msg.sender] -= amounts[i];
            require(balances[msg.sender] >= amounts[i], "Sender does not have enough tokens.");
        }
    }

    function _mint(address recipient, uint256 amount) internal {
        balances[recipient] += amount;
    }
}