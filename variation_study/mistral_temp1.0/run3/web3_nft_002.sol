pragma solidity ^0.8.4;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

contract MyNFT is ERC721, Ownable {
    uint256 public constant MINT_PRICE = 1 ether;
    uint256 public MAX_MINT_COUNT = 10; // Max number of NFTs each address can mint
    uint256 private _totalSupply;

    constructor() ERC721("MyNFT", "MYN") {}

    function mint(address to, uint256 tokenId) external payable {
        require(msg.value == MINT_PRICE, "Incorrect payment");
        require(_totalSupply < MAX_MINT_COUNT * to.balance, "Reached minting limit");

        _safeMint(to, tokenId);
        (bool success, ) = transfer(address(this), to).call{value: MINT_PRICE};
        require(success, "Transfer failed");
        _totalSupply++;
    }
}