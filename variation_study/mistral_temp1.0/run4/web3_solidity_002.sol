pragma solidity ^0.8.7;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/token/ERC20/ERC20.sol";

contract CustomToken is ERC20 {
    uint256 public constant INITIAL_SUPPLY = 1000 * (10 ** decimals());

    constructor() ERC20("Custom Token", "CTK") {
        _mint(msg.sender, INITIAL_SUPPLY);
    }

    function transfer(address _to, uint256 _value) external override returns (bool success) {
        uint256 balance = _balances[_msgSender()];
        require(balance >= _value, "Insufficient balance");

        _balances[msg.sender] -= _value;
        _balances[_to] += _value;
        emit Transfer(_msgSender(), _to, _value);

        return true;
    }

    function approve(address _spender, uint256 _value) external override returns (bool success) {
        _approved[msg.sender][_spender] = _value;
        emit Approval(msg.sender, _spender, _value);
        return true;
    }
}