pragma solidity ^0.8.7;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/math/SafeMath.sol";

contract MyNFT is ERC721, Ownable {
    using SafeMath for uint256;

    uint24 public constant MINT_PRICE = 0.1 ether; // Replace with the desired price in ether
    uint256 private maxSupply;
    uint256 private currentMintedCount;

    constructor(uint256 _maxSupply) ERC721("MyNFT", "MNT") {
        maxSupply = _maxSupply;
    }

    function mint(address to, uint256 amount) public payable {
        require(!haveEnoughEther(msg.value), "Insufficient funds provided.");
        require(currentMintedCount + amount <= maxSupply, "Reached maximum supply limit.");
        require(amount > 0 && amount <= 1, "Invalid amount requested.");

        currentMintedCount = currentMintedCount.add(amount);
        _mint(to, currentMintedCount - 1);
        msg.sender.transfer((MINT_PRICE.mul(amount)).sub(_value(to)));
    }

    function haveEnoughEther(uint256 value) private view returns (bool) {
        return msg.value >= value;
    }
}