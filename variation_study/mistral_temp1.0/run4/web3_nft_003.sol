pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/utils/Math/SafeMath.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/token/ERC721/extensions/ERC721Enumerable.sol";
import "@openzeppelin/contracts/exchange/UniswapV3Protocol.sol";

contract NFTMarketplace is ERC721, ERC721Enumerable, Ownable {
    using SafeMath for uint256;

    UniswapV3Protocol constant UNISWAP_V3_PROTOCOL = UniswapV3Protocol(0x40a86B33eCd9Ef72699D39A5F44eC77138dAdbE8);
    address public owner;
    mapping (uint => address) public sellerMapping;
    mapping (uint => uint) public listingPriceMapping;
    mapping (address => bool) public isSeller;

    event Listed(uint indexed tokenId, address indexed seller, uint price);
    event Sold(uint indexed tokenId, address indexed buyer, address indexed seller, uint price);

    constructor() ERC721("NFTMarketplace", "NTM") {}

    function listItem(uint _tokenId, uint _price) external {
        require(!isSeller[msg.sender], "You are not a registered seller.");
        require(_tokenId > 0 && _price > 0, "Invalid parameters.");

        sellerMapping[_tokenId] = msg.sender;
        listingPriceMapping[_tokenId] = _price;
        emit Listed(_tokenId, msg.sender, _price);
    }

    function registerAsSeller() external onlyOwner {
        isSeller[msg.sender] = true;
    }

    function buyItem(uint _tokenId) external payable {
        require(isSeller[sellerMapping[_tokenId]], "Seller not found.");
        require(_tokenId > 0 && listingPriceMapping[_tokenId] > 0, "Invalid parameters.");
        require(msg.value == listingPriceMapping[_tokenId], "Incorrect payment amount.");

        _transferFrom(sellerMapping[_tokenId], msg.sender, _tokenId);
        uint salePrice = msg.value;
        _mint(msg.sender, _tokenId);
        emit Sold(_tokenId, sellerMapping[_tokenId], msg.sender, salePrice);
    }
}