pragma solidity ^0.8.0;

import "@openzeppelin/contracts/utils/Strings.sol";
import "@openzeppelin/contracts/utils/math/SafeMath.sol";

contract Lottery {
    uint256 constant private MIN_BET = 1 ether;
    uint256 public lastWinner;
    uint256[] public winners;
    mapping(address => uint256) public entries;

    constructor() {
        require(block.timestamp > lastBlock.timestamp + 60 seconds, "Too early to start a new game.");
        lastWinner = address(0);
    }

    function enter() external payable {
        require(MIN_BET <= msg.value, "Minimum bet is 1 ether.");
        require(block.timestamp > lastBlock.timestamp + 60 seconds, "Game has not yet started.");

        entries[msg.sender] += msg.value;
    }

    function startGame() external {
        require(msg.sender == owner, "Only the contract owner can start a game.");
        require(block.timestamp > lastBlock.timestamp + 60 seconds, "Game has not yet started.");

        uint256 randomness = keccak256(abi.encodePacked(block.timestamp, blockhash(block.number - 1)));
        uint256 totalEntries = entries[msg.sender];

        winners.push(totalEntries + (keccak256(abi.encodePacked(randomness)) % totalEntries));
    }

    function claimPrize() external {
        require(msg.sender == lastWinner, "You are not the last winner.");

        uint256 prize = entries[msg.sender];
        entries[msg.sender] = 0;
        lastWinner = address(0);
        emit PrizeClaimed(msg.sender, prize);
    }
}