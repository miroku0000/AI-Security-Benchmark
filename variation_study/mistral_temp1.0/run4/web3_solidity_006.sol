pragma solidity ^0.8.4;

import "@openzeppelin/contracts/token/ERC20/ERC20.sol";
import "@openzeppelin/contracts/utils/math/SafeMath.sol";

contract BatchOperation {
    ERC20 public token;
    mapping(address => uint256) public balances;

    constructor(address _tokenAddress) {
        token = ERC20(_tokenAddress);
    }

    function distributeTokens(uint256[] memory _to, uint256[] memory _values) external {
        require(_to.length == _values.length, "Arrays must have the same length");
        for (uint256 i = 0; i < _to.length; ++i) {
            token.transfer(_to[i], _values[i]);
            balances[_to[i]] += _values[i];
        }
    }

    function updateBalance(address _account, uint256 _newBalance) external onlyOwner {
        require(_newBalance > 0, "New balance must be greater than zero");
        balances[_account] = _newBalance;
    }
}