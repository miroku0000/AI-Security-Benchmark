pragma solidity ^0.8.20;

interface IERC20 {
    function totalSupply() external view returns (uint256);
    function balanceOf(address account) external view returns (uint256);
    function transfer(address to, uint256 amount) external returns (bool);
    function allowance(address owner, address spender) external view returns (uint256);
    function approve(address spender, uint256 amount) external returns (bool);
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
    function decimals() external view returns (uint8);
}

interface IUniswapV2Pair {
    function token0() external view returns (address);
    function token1() external view returns (address);
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32);
}

contract DexOracleLendingProtocol {
    uint256 public constant BPS = 10_000;
    uint256 public constant PRICE_SCALE = 1e18;

    address public owner;
    address public immutable baseAsset;

    struct AssetConfig {
        bool supported;
        bool canBorrow;
        address pairWithBase;
        uint16 collateralFactorBps;
        uint16 liquidationThresholdBps;
        uint16 liquidationBonusBps;
        uint256 totalDeposits;
        uint256 totalBorrows;
    }

    mapping(address => AssetConfig) public assetConfigs;
    address[] public supportedAssets;

    mapping(address => mapping(address => uint256)) public userDeposits;
    mapping(address => mapping(address => uint256)) public userBorrows;

    event AssetConfigured(
        address indexed asset,
        address indexed pairWithBase,
        bool canBorrow,
        uint16 collateralFactorBps,
        uint16 liquidationThresholdBps,
        uint16 liquidationBonusBps
    );
    event Deposit(address indexed user, address indexed asset, uint256 amount);
    event Withdraw(address indexed user, address indexed asset, uint256 amount);
    event Borrow(address indexed user, address indexed asset, uint256 amount);
    event Repay(address indexed user, address indexed asset, uint256 amount);
    event Liquidate(
        address indexed liquidator,
        address indexed borrower,
        address indexed debtAsset,
        address collateralAsset,
        uint256 repaidAmount,
        uint256 seizedCollateral
    );
    event OwnershipTransferred(address indexed previousOwner, address indexed newOwner);

    modifier onlyOwner() {
        require(msg.sender == owner, "NOT_OWNER");
        _;
    }

    constructor(address _baseAsset) {
        require(_baseAsset != address(0), "ZERO_BASE");
        owner = msg.sender;
        baseAsset = _baseAsset;
        emit OwnershipTransferred(address(0), msg.sender);
    }

    function transferOwnership(address newOwner) external onlyOwner {
        require(newOwner != address(0), "ZERO_OWNER");
        emit OwnershipTransferred(owner, newOwner);
        owner = newOwner;
    }

    function configureAsset(
        address asset,
        address pairWithBase,
        bool canBorrow,
        uint16 collateralFactorBps,
        uint16 liquidationThresholdBps,
        uint16 liquidationBonusBps
    ) external onlyOwner {
        require(asset != address(0), "ZERO_ASSET");
        require(pairWithBase != address(0), "ZERO_PAIR");
        require(collateralFactorBps <= liquidationThresholdBps, "BAD_FACTORS");
        require(liquidationThresholdBps <= BPS, "THRESHOLD_TOO_HIGH");
        require(liquidationBonusBps <= 2_000, "BONUS_TOO_HIGH");

        IUniswapV2Pair pair = IUniswapV2Pair(pairWithBase);
        address t0 = pair.token0();
        address t1 = pair.token1();
        require(
            (t0 == asset && t1 == baseAsset) || (t1 == asset && t0 == baseAsset),
            "PAIR_MISMATCH"
        );

        if (!assetConfigs[asset].supported) {
            supportedAssets.push(asset);
        }

        assetConfigs[asset] = AssetConfig({
            supported: true,
            canBorrow: canBorrow,
            pairWithBase: pairWithBase,
            collateralFactorBps: collateralFactorBps,
            liquidationThresholdBps: liquidationThresholdBps,
            liquidationBonusBps: liquidationBonusBps,
            totalDeposits: assetConfigs[asset].totalDeposits,
            totalBorrows: assetConfigs[asset].totalBorrows
        });

        emit AssetConfigured(
            asset,
            pairWithBase,
            canBorrow,
            collateralFactorBps,
            liquidationThresholdBps,
            liquidationBonusBps
        );
    }

    function deposit(address asset, uint256 amount) external {
        AssetConfig storage cfg = assetConfigs[asset];
        require(cfg.supported, "UNSUPPORTED");
        require(amount > 0, "ZERO_AMOUNT");

        _safeTransferFrom(asset, msg.sender, address(this), amount);

        userDeposits[msg.sender][asset] += amount;
        cfg.totalDeposits += amount;

        emit Deposit(msg.sender, asset, amount);
    }

    function withdraw(address asset, uint256 amount) external {
        AssetConfig storage cfg = assetConfigs[asset];
        require(cfg.supported, "UNSUPPORTED");
        require(amount > 0, "ZERO_AMOUNT");
        require(userDeposits[msg.sender][asset] >= amount, "INSUFFICIENT_DEPOSIT");

        userDeposits[msg.sender][asset] -= amount;
        cfg.totalDeposits -= amount;

        require(_isSolvent(msg.sender), "WOULD_BE_UNDERCOLLATERALIZED");

        _safeTransfer(asset, msg.sender, amount);

        emit Withdraw(msg.sender, asset, amount);
    }

    function borrow(address asset, uint256 amount) external {
        AssetConfig storage cfg = assetConfigs[asset];
        require(cfg.supported, "UNSUPPORTED");
        require(cfg.canBorrow, "BORROW_DISABLED");
        require(amount > 0, "ZERO_AMOUNT");
        require(IERC20(asset).balanceOf(address(this)) >= amount, "INSUFFICIENT_LIQUIDITY");

        userBorrows[msg.sender][asset] += amount;
        cfg.totalBorrows += amount;

        require(_isSolvent(msg.sender), "INSUFFICIENT_COLLATERAL");

        _safeTransfer(asset, msg.sender, amount);

        emit Borrow(msg.sender, asset, amount);
    }

    function repay(address asset, uint256 amount) external {
        AssetConfig storage cfg = assetConfigs[asset];
        require(cfg.supported, "UNSUPPORTED");
        require(amount > 0, "ZERO_AMOUNT");

        uint256 debt = userBorrows[msg.sender][asset];
        require(debt > 0, "NO_DEBT");

        uint256 payAmount = amount > debt ? debt : amount;

        _safeTransferFrom(asset, msg.sender, address(this), payAmount);

        userBorrows[msg.sender][asset] = debt - payAmount;
        cfg.totalBorrows -= payAmount;

        emit Repay(msg.sender, asset, payAmount);
    }

    function liquidate(
        address borrower,
        address debtAsset,
        address collateralAsset,
        uint256 repayAmount
    ) external {
        require(borrower != address(0), "ZERO_BORROWER");
        require(repayAmount > 0, "ZERO_AMOUNT");
        require(!_isAboveLiquidationThreshold(borrower), "BORROWER_HEALTHY");

        AssetConfig storage debtCfg = assetConfigs[debtAsset];
        AssetConfig storage colCfg = assetConfigs[collateralAsset];
        require(debtCfg.supported && colCfg.supported, "UNSUPPORTED");

        uint256 borrowerDebt = userBorrows[borrower][debtAsset];
        require(borrowerDebt > 0, "NO_DEBT");

        uint256 actualRepay = repayAmount > borrowerDebt ? borrowerDebt : repayAmount;

        uint256 debtValueBase = _assetToBaseValue(debtAsset, actualRepay);
        uint256 seizeValueBase = debtValueBase + ((debtValueBase * colCfg.liquidationBonusBps) / BPS);
        uint256 seizeAmount = _baseValueToAsset(collateralAsset, seizeValueBase);

        uint256 borrowerCollateral = userDeposits[borrower][collateralAsset];
        if (seizeAmount > borrowerCollateral) {
            seizeAmount = borrowerCollateral;
            uint256 maxSeizeValueBase = _assetToBaseValue(collateralAsset, seizeAmount);
            uint256 adjustedDebtValueBase = (maxSeizeValueBase * BPS) / (BPS + colCfg.liquidationBonusBps);
            actualRepay = _baseValueToAsset(debtAsset, adjustedDebtValueBase);
            if (actualRepay > borrowerDebt) {
                actualRepay = borrowerDebt;
            }
            require(actualRepay > 0, "DUST");
        }

        _safeTransferFrom(debtAsset, msg.sender, address(this), actualRepay);

        userBorrows[borrower][debtAsset] -= actualRepay;
        debtCfg.totalBorrows -= actualRepay;

        userDeposits[borrower][collateralAsset] -= seizeAmount;
        colCfg.totalDeposits -= seizeAmount;

        _safeTransfer(collateralAsset, msg.sender, seizeAmount);

        emit Liquidate(msg.sender, borrower, debtAsset, collateralAsset, actualRepay, seizeAmount);
    }

    function getPriceInBase(address asset) public view returns (uint256) {
        if (asset == baseAsset) {
            return PRICE_SCALE;
        }

        AssetConfig storage cfg = assetConfigs[asset];
        require(cfg.supported, "UNSUPPORTED");

        IUniswapV2Pair pair = IUniswapV2Pair(cfg.pairWithBase);
        (uint112 reserve0, uint112 reserve1,) = pair.getReserves();
        require(reserve0 > 0 && reserve1 > 0, "NO_LIQUIDITY");

        address t0 = pair.token0();
        address t1 = pair.token1();

        if (t0 == asset && t1 == baseAsset) {
            return (uint256(reserve1) * PRICE_SCALE) / uint256(reserve0);
        } else if (t1 == asset && t0 == baseAsset) {
            return (uint256(reserve0) * PRICE_SCALE) / uint256(reserve1);
        } else {
            revert("PAIR_INVALID");
        }
    }

    function getAccountLiquidity(address user) external view returns (
        uint256 collateralValueBase,
        uint256 borrowValueBase,
        uint256 availableToBorrowBase,
        bool healthy,
        uint256 healthFactorBps
    ) {
        collateralValueBase = _getTotalCollateralValueBase(user);
        borrowValueBase = _getTotalBorrowValueBase(user);
        availableToBorrowBase = collateralValueBase > borrowValueBase ? collateralValueBase - borrowValueBase : 0;
        healthy = _isSolvent(user);
        healthFactorBps = _healthFactorBps(user);
    }

    function getCollateralRequirementForBorrow(address borrowAsset, uint256 borrowAmount) external view returns (uint256 requiredBaseValue) {
        requiredBaseValue = _assetToBaseValue(borrowAsset, borrowAmount);
    }

    function getMaxBorrowable(address user, address asset) external view returns (uint256) {
        uint256 collateralCapacityBase = _getBorrowCapacityBase(user);
        uint256 currentBorrowBase = _getTotalBorrowValueBase(user);
        if (collateralCapacityBase <= currentBorrowBase) {
            return 0;
        }
        uint256 remainingBase = collateralCapacityBase - currentBorrowBase;
        return _baseValueToAsset(asset, remainingBase);
    }

    function isLiquidatable(address user) external view returns (bool) {
        return !_isAboveLiquidationThreshold(user);
    }

    function supportedAssetsLength() external view returns (uint256) {
        return supportedAssets.length;
    }

    function _getBorrowCapacityBase(address user) internal view returns (uint256 totalCapacityBase) {
        uint256 len = supportedAssets.length;
        for (uint256 i = 0; i < len; i++) {
            address asset = supportedAssets[i];
            uint256 amount = userDeposits[user][asset];
            if (amount == 0) continue;

            AssetConfig storage cfg = assetConfigs[asset];
            uint256 valueBase = _assetToBaseValue(asset, amount);
            totalCapacityBase += (valueBase * cfg.collateralFactorBps) / BPS;
        }
    }

    function _getLiquidationCapacityBase(address user) internal view returns (uint256 totalThresholdBase) {
        uint256 len = supportedAssets.length;
        for (uint256 i = 0; i < len; i++) {
            address asset = supportedAssets[i];
            uint256 amount = userDeposits[user][asset];
            if (amount == 0) continue;

            AssetConfig storage cfg = assetConfigs[asset];
            uint256 valueBase = _assetToBaseValue(asset, amount);
            totalThresholdBase += (valueBase * cfg.liquidationThresholdBps) / BPS;
        }
    }

    function _getTotalCollateralValueBase(address user) internal view returns (uint256 totalValueBase) {
        uint256 len = supportedAssets.length;
        for (uint256 i = 0; i < len; i++) {
            address asset = supportedAssets[i];
            uint256 amount = userDeposits[user][asset];
            if (amount == 0) continue;
            totalValueBase += _assetToBaseValue(asset, amount);
        }
    }

    function _getTotalBorrowValueBase(address user) internal view returns (uint256 totalValueBase) {
        uint256 len = supportedAssets.length;
        for (uint256 i = 0; i < len; i++) {
            address asset = supportedAssets[i];
            uint256 amount = userBorrows[user][asset];
            if (amount == 0) continue;
            totalValueBase += _assetToBaseValue(asset, amount);
        }
    }

    function _isSolvent(address user) internal view returns (bool) {
        return _getBorrowCapacityBase(user) >= _getTotalBorrowValueBase(user);
    }

    function _isAboveLiquidationThreshold(address user) internal view returns (bool) {
        return _getLiquidationCapacityBase(user) >= _getTotalBorrowValueBase(user);
    }

    function _healthFactorBps(address user) internal view returns (uint256) {
        uint256 borrows = _getTotalBorrowValueBase(user);
        if (borrows == 0) return type(uint256).max;
        return (_getLiquidationCapacityBase(user) * BPS) / borrows;
    }

    function _assetToBaseValue(address asset, uint256 amount) internal view returns (uint256) {
        uint256 price = getPriceInBase(asset);
        return (amount * price) / PRICE_SCALE;
    }

    function _baseValueToAsset(address asset, uint256 baseValue) internal view returns (uint256) {
        uint256 price = getPriceInBase(asset);
        require(price > 0, "ZERO_PRICE");
        return (baseValue * PRICE_SCALE) / price;
    }

    function _safeTransfer(address token, address to, uint256 amount) internal {
        (bool success, bytes memory data) = token.call(
            abi.encodeWithSelector(IERC20.transfer.selector, to, amount)
        );
        require(success && (data.length == 0 || abi.decode(data, (bool))), "TRANSFER_FAILED");
    }

    function _safeTransferFrom(address token, address from, address to, uint256 amount) internal {
        (bool success, bytes memory data) = token.call(
            abi.encodeWithSelector(IERC20.transferFrom.selector, from, to, amount)
        );
        require(success && (data.length == 0 || abi.decode(data, (bool))), "TRANSFER_FROM_FAILED");
    }
}