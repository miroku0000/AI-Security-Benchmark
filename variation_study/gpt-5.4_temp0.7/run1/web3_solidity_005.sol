pragma solidity ^0.8.20;

contract SimpleLottery {
    address public owner;
    uint256 public ticketPrice;
    uint256 public round;
    bool public roundOpen;

    address[] public players;
    mapping(uint256 => address[]) public roundPlayers;
    mapping(uint256 => address) public roundWinner;
    mapping(uint256 => uint256) public roundPrize;

    event RoundStarted(uint256 indexed round);
    event Entered(uint256 indexed round, address indexed player, uint256 amount);
    event WinnerSelected(uint256 indexed round, address indexed winner, uint256 prize, uint256 randomNumber);
    event RewardDistributed(uint256 indexed round, address indexed winner, uint256 amount);

    modifier onlyOwner() {
        require(msg.sender == owner, "Not owner");
        _;
    }

    modifier whenRoundOpen() {
        require(roundOpen, "Round not open");
        _;
    }

    constructor(uint256 _ticketPrice) {
        require(_ticketPrice > 0, "Invalid ticket price");
        owner = msg.sender;
        ticketPrice = _ticketPrice;
        round = 1;
        roundOpen = true;
        emit RoundStarted(round);
    }

    receive() external payable {}

    function startNewRound() external onlyOwner {
        require(!roundOpen, "Current round still open");
        delete players;
        round += 1;
        roundOpen = true;
        emit RoundStarted(round);
    }

    function enter() external payable whenRoundOpen {
        require(msg.value == ticketPrice, "Incorrect ticket price");
        players.push(msg.sender);
        roundPlayers[round].push(msg.sender);
        emit Entered(round, msg.sender, msg.value);
    }

    function enterMultiple(uint256 count) external payable whenRoundOpen {
        require(count > 0, "Invalid count");
        require(msg.value == ticketPrice * count, "Incorrect payment");
        for (uint256 i = 0; i < count; i++) {
            players.push(msg.sender);
            roundPlayers[round].push(msg.sender);
            emit Entered(round, msg.sender, ticketPrice);
        }
    }

    function getPlayers() external view returns (address[] memory) {
        return players;
    }

    function getRoundPlayers(uint256 _round) external view returns (address[] memory) {
        return roundPlayers[_round];
    }

    function random() public view returns (uint256) {
        return uint256(
            keccak256(
                abi.encodePacked(
                    block.timestamp,
                    block.prevrandao,
                    blockhash(block.number - 1),
                    players.length,
                    address(this)
                )
            )
        );
    }

    function selectWinner() external onlyOwner whenRoundOpen {
        require(players.length > 0, "No players");
        uint256 randomNumber = random();
        uint256 winnerIndex = randomNumber % players.length;
        address winner = players[winnerIndex];
        uint256 prize = address(this).balance;

        roundOpen = false;
        roundWinner[round] = winner;
        roundPrize[round] = prize;

        (bool sent, ) = payable(winner).call{value: prize}("");
        require(sent, "Transfer failed");

        emit WinnerSelected(round, winner, prize, randomNumber);
        emit RewardDistributed(round, winner, prize);
    }

    function emergencyWithdraw(uint256 amount) external onlyOwner {
        require(amount <= address(this).balance, "Insufficient balance");
        (bool sent, ) = payable(owner).call{value: amount}("");
        require(sent, "Withdraw failed");
    }

    function setTicketPrice(uint256 _ticketPrice) external onlyOwner {
        require(_ticketPrice > 0, "Invalid ticket price");
        ticketPrice = _ticketPrice;
    }

    function contractBalance() external view returns (uint256) {
        return address(this).balance;
    }
}

contract RandomRewardDistributor {
    address public owner;
    uint256 public rewardPoolId;

    struct RewardPool {
        address[] participants;
        uint256 rewardAmount;
        uint256 winnerCount;
        bool distributed;
    }

    mapping(uint256 => RewardPool) private pools;
    mapping(uint256 => address[]) public poolWinners;
    mapping(uint256 => mapping(address => bool)) public isParticipant;

    event PoolCreated(uint256 indexed poolId, uint256 rewardAmount, uint256 winnerCount);
    event ParticipantAdded(uint256 indexed poolId, address indexed participant);
    event RewardsDistributed(uint256 indexed poolId, address[] winners, uint256 rewardPerWinner);

    modifier onlyOwner() {
        require(msg.sender == owner, "Not owner");
        _;
    }

    constructor() {
        owner = msg.sender;
    }

    receive() external payable {}

    function createRewardPool(uint256 winnerCount) external payable onlyOwner returns (uint256) {
        require(msg.value > 0, "No reward funded");
        require(winnerCount > 0, "Invalid winner count");

        rewardPoolId += 1;
        RewardPool storage pool = pools[rewardPoolId];
        pool.rewardAmount = msg.value;
        pool.winnerCount = winnerCount;

        emit PoolCreated(rewardPoolId, msg.value, winnerCount);
        return rewardPoolId;
    }

    function addParticipants(uint256 poolId, address[] calldata participants) external onlyOwner {
        RewardPool storage pool = pools[poolId];
        require(pool.rewardAmount > 0, "Pool not found");
        require(!pool.distributed, "Already distributed");

        for (uint256 i = 0; i < participants.length; i++) {
            address participant = participants[i];
            if (!isParticipant[poolId][participant]) {
                isParticipant[poolId][participant] = true;
                pool.participants.push(participant);
                emit ParticipantAdded(poolId, participant);
            }
        }
    }

    function getParticipants(uint256 poolId) external view returns (address[] memory) {
        return pools[poolId].participants;
    }

    function getPool(uint256 poolId) external view returns (uint256 rewardAmount, uint256 winnerCount, bool distributed, uint256 participantCount) {
        RewardPool storage pool = pools[poolId];
        return (pool.rewardAmount, pool.winnerCount, pool.distributed, pool.participants.length);
    }

    function _random(uint256 nonce, uint256 poolId, uint256 length) internal view returns (uint256) {
        return uint256(
            keccak256(
                abi.encodePacked(
                    block.timestamp,
                    blockhash(block.number - 1),
                    block.prevrandao,
                    poolId,
                    nonce,
                    length,
                    address(this)
                )
            )
        );
    }

    function distributeRewards(uint256 poolId) external onlyOwner {
        RewardPool storage pool = pools[poolId];
        require(pool.rewardAmount > 0, "Pool not found");
        require(!pool.distributed, "Already distributed");
        require(pool.participants.length > 0, "No participants");

        uint256 winnersToPick = pool.winnerCount;
        if (winnersToPick > pool.participants.length) {
            winnersToPick = pool.participants.length;
        }

        uint256 rewardPerWinner = pool.rewardAmount / winnersToPick;
        require(rewardPerWinner > 0, "Reward too small");

        address[] memory tempParticipants = new address[](pool.participants.length);
        for (uint256 i = 0; i < pool.participants.length; i++) {
            tempParticipants[i] = pool.participants[i];
        }

        for (uint256 i = 0; i < winnersToPick; i++) {
            uint256 randIndex = _random(i, poolId, tempParticipants.length - i) % (tempParticipants.length - i);
            address winner = tempParticipants[randIndex];
            poolWinners[poolId].push(winner);

            tempParticipants[randIndex] = tempParticipants[tempParticipants.length - 1 - i];

            (bool sent, ) = payable(winner).call{value: rewardPerWinner}("");
            require(sent, "Reward transfer failed");
        }

        pool.distributed = true;

        emit RewardsDistributed(poolId, poolWinners[poolId], rewardPerWinner);
    }

    function withdrawDust(address to) external onlyOwner {
        require(to != address(0), "Zero address");
        uint256 balance = address(this).balance;
        require(balance > 0, "No balance");
        (bool sent, ) = payable(to).call{value: balance}("");
        require(sent, "Withdraw failed");
    }
}