# Generated by openai (gpt-5.4-mini)
# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

data "aws_caller_identity" "current" {}

data "aws_iam_policy_document" "lambda_assume_role" {
  statement {
    effect = "Allow"

    principals {
      type        = "Service"
      identifiers = ["lambda.amazonaws.com"]
    }

    actions = ["sts:AssumeRole"]
  }
}

data "aws_iam_policy_document" "payment_processor_policy" {
  statement {
    sid    = "WriteLogs"
    effect = "Allow"
    actions = [
      "logs:CreateLogGroup",
      "logs:CreateLogStream",
      "logs:PutLogEvents"
    ]
    resources = [
      "arn:aws:logs:${var.aws_region}:${data.aws_caller_identity.current.account_id}:log-group:/aws/lambda/${var.payment_processor_function_name}:*",
      "arn:aws:logs:${var.aws_region}:${data.aws_caller_identity.current.account_id}:log-group:/aws/lambda/${var.payment_processor_function_name}"
    ]
  }

  statement {
    sid    = "DecryptSensitiveData"
    effect = "Allow"
    actions = [
      "kms:Decrypt",
      "kms:DescribeKey"
    ]
    resources = [var.kms_key_arn]
  }

  statement {
    sid    = "ReadPaymentQueue"
    effect = "Allow"
    actions = [
      "sqs:ReceiveMessage",
      "sqs:DeleteMessage",
      "sqs:GetQueueAttributes",
      "sqs:GetQueueUrl",
      "sqs:ChangeMessageVisibility"
    ]
    resources = [var.payment_queue_arn]
  }

  statement {
    sid    = "WritePaymentResults"
    effect = "Allow"
    actions = [
      "dynamodb:PutItem",
      "dynamodb:UpdateItem",
      "dynamodb:GetItem",
      "dynamodb:ConditionCheckItem"
    ]
    resources = [
      var.payment_table_arn,
      "${var.payment_table_arn}/index/*"
    ]
  }

  dynamic "statement" {
    for_each = var.secrets_manager_secret_arns
    content {
      sid    = "ReadSecrets${replace(statement.value, ":", "")}"
      effect = "Allow"
      actions = [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret"
      ]
      resources = [statement.value]
    }
  }
}

data "aws_iam_policy_document" "fraud_scoring_policy" {
  statement {
    sid    = "WriteLogs"
    effect = "Allow"
    actions = [
      "logs:CreateLogGroup",
      "logs:CreateLogStream",
      "logs:PutLogEvents"
    ]
    resources = [
      "arn:aws:logs:${var.aws_region}:${data.aws_caller_identity.current.account_id}:log-group:/aws/lambda/${var.fraud_scoring_function_name}:*",
      "arn:aws:logs:${var.aws_region}:${data.aws_caller_identity.current.account_id}:log-group:/aws/lambda/${var.fraud_scoring_function_name}"
    ]
  }

  statement {
    sid    = "DecryptSensitiveData"
    effect = "Allow"
    actions = [
      "kms:Decrypt",
      "kms:DescribeKey"
    ]
    resources = [var.kms_key_arn]
  }

  statement {
    sid    = "ReadPaymentStream"
    effect = "Allow"
    actions = [
      "kinesis:GetRecords",
      "kinesis:GetShardIterator",
      "kinesis:DescribeStream",
      "kinesis:DescribeStreamSummary",
      "kinesis:ListShards"
    ]
    resources = [var.payment_stream_arn]
  }

  statement {
    sid    = "WriteFraudDecisions"
    effect = "Allow"
    actions = [
      "dynamodb:PutItem",
      "dynamodb:UpdateItem",
      "dynamodb:GetItem"
    ]
    resources = [var.fraud_decisions_table_arn]
  }
}

resource "aws_iam_role" "payment_processor" {
  name               = var.payment_processor_role_name
  assume_role_policy = data.aws_iam_policy_document.lambda_assume_role.json
}

resource "aws_iam_role_policy" "payment_processor" {
  name   = "${var.payment_processor_role_name}-inline"
  role   = aws_iam_role.payment_processor.id
  policy = data.aws_iam_policy_document.payment_processor_policy.json
}

resource "aws_iam_role" "fraud_scoring" {
  name               = var.fraud_scoring_role_name
  assume_role_policy = data.aws_iam_policy_document.lambda_assume_role.json
}

resource "aws_iam_role_policy" "fraud_scoring" {
  name   = "${var.fraud_scoring_role_name}-inline"
  role   = aws_iam_role.fraud_scoring.id
  policy = data.aws_iam_policy_document.fraud_scoring_policy.json
}

resource "aws_cloudwatch_log_group" "payment_processor" {
  name              = "/aws/lambda/${var.payment_processor_function_name}"
  retention_in_days = var.log_retention_in_days
  kms_key_id        = var.cloudwatch_logs_kms_key_arn
}

resource "aws_cloudwatch_log_group" "fraud_scoring" {
  name              = "/aws/lambda/${var.fraud_scoring_function_name}"
  retention_in_days = var.log_retention_in_days
  kms_key_id        = var.cloudwatch_logs_kms_key_arn
}

resource "aws_lambda_function" "payment_processor" {
  function_name = var.payment_processor_function_name
  role          = aws_iam_role.payment_processor.arn
  handler       = var.payment_processor_handler
  runtime       = var.lambda_runtime
  filename      = var.payment_processor_zip_path
  source_code_hash = filebase64sha256(var.payment_processor_zip_path)
  timeout       = var.payment_processor_timeout
  memory_size   = var.payment_processor_memory_size
  publish       = true

  environment {
    variables = merge(
      var.payment_processor_environment,
      {
        KMS_KEY_ARN = var.kms_key_arn
      }
    )
  }

  tracing_config {
    mode = "Active"
  }

  depends_on = [
    aws_cloudwatch_log_group.payment_processor,
    aws_iam_role_policy.payment_processor
  ]
}

resource "aws_lambda_function" "fraud_scoring" {
  function_name = var.fraud_scoring_function_name
  role          = aws_iam_role.fraud_scoring.arn
  handler       = var.fraud_scoring_handler
  runtime       = var.lambda_runtime
  filename      = var.fraud_scoring_zip_path
  source_code_hash = filebase64sha256(var.fraud_scoring_zip_path)
  timeout       = var.fraud_scoring_timeout
  memory_size   = var.fraud_scoring_memory_size
  publish       = true

  environment {
    variables = merge(
      var.fraud_scoring_environment,
      {
        KMS_KEY_ARN = var.kms_key_arn
      }
    )
  }

  tracing_config {
    mode = "Active"
  }

  depends_on = [
    aws_cloudwatch_log_group.fraud_scoring,
    aws_iam_role_policy.fraud_scoring
  ]
}

resource "aws_lambda_event_source_mapping" "payment_processor_sqs" {
  event_source_arn                   = var.payment_queue_arn
  function_name                      = aws_lambda_function.payment_processor.arn
  batch_size                         = var.payment_queue_batch_size
  maximum_batching_window_in_seconds  = var.payment_queue_maximum_batching_window_in_seconds
  enabled                            = true
  function_response_types             = var.payment_queue_function_response_types
  scaling_config {
    maximum_concurrency = var.payment_queue_maximum_concurrency
  }
}

resource "aws_lambda_event_source_mapping" "fraud_scoring_kinesis" {
  event_source_arn                   = var.payment_stream_arn
  function_name                      = aws_lambda_function.fraud_scoring.arn
  starting_position                  = var.fraud_scoring_starting_position
  batch_size                         = var.fraud_scoring_batch_size
  maximum_batching_window_in_seconds  = var.fraud_scoring_maximum_batching_window_in_seconds
  enabled                            = true
  parallelization_factor             = var.fraud_scoring_parallelization_factor
  tumbling_window_in_seconds         = var.fraud_scoring_tumbling_window_in_seconds
}

