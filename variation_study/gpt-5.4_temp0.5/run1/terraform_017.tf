terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
    archive = {
      source  = "hashicorp/archive"
      version = ">= 2.4.0"
    }
  }
}

variable "aws_region" {
  type        = string
  description = "AWS region"
}

variable "name_prefix" {
  type        = string
  description = "Prefix for resource names"
  default     = "payments"
}

variable "environment" {
  type        = string
  description = "Deployment environment"
}

variable "kms_key_arn" {
  type        = string
  description = "KMS key ARN for Lambda environment variable encryption and data protection"
}

variable "input_bucket_arn" {
  type        = string
  description = "S3 bucket ARN containing encrypted payment input files"
}

variable "output_bucket_arn" {
  type        = string
  description = "S3 bucket ARN for processed payment outputs"
}

variable "dlq_kms_key_arn" {
  type        = string
  description = "KMS key ARN for SQS DLQ encryption"
}

variable "vpc_id" {
  type        = string
  description = "VPC ID for Lambda networking"
}

variable "private_subnet_ids" {
  type        = list(string)
  description = "Private subnet IDs for Lambda functions"
}

variable "lambda_security_group_ids" {
  type        = list(string)
  description = "Security group IDs for Lambda functions"
}

variable "processor_timeout" {
  type    = number
  default = 60
}

variable "processor_memory_size" {
  type    = number
  default = 512
}

variable "reconciler_timeout" {
  type    = number
  default = 120
}

variable "reconciler_memory_size" {
  type    = number
  default = 1024
}

variable "processor_reserved_concurrency" {
  type    = number
  default = 10
}

variable "reconciler_reserved_concurrency" {
  type    = number
  default = 5
}

data "aws_caller_identity" "current" {}

data "aws_region" "current" {}

locals {
  common_tags = {
    Application = "payment-processing"
    Environment = var.environment
    ManagedBy   = "terraform"
    DataClass   = "sensitive-financial"
  }

  input_bucket_name  = replace(var.input_bucket_arn, "arn:aws:s3:::", "")
  output_bucket_name = replace(var.output_bucket_arn, "arn:aws:s3:::", "")
}

resource "aws_sqs_queue" "processor_dlq" {
  name                              = "${var.name_prefix}-${var.environment}-processor-dlq"
  kms_master_key_id                 = var.dlq_kms_key_arn
  kms_data_key_reuse_period_seconds = 300
  message_retention_seconds         = 1209600
  visibility_timeout_seconds        = 180

  tags = merge(local.common_tags, {
    Name = "${var.name_prefix}-${var.environment}-processor-dlq"
  })
}

resource "aws_sqs_queue" "reconciler_dlq" {
  name                              = "${var.name_prefix}-${var.environment}-reconciler-dlq"
  kms_master_key_id                 = var.dlq_kms_key_arn
  kms_data_key_reuse_period_seconds = 300
  message_retention_seconds         = 1209600
  visibility_timeout_seconds        = 300

  tags = merge(local.common_tags, {
    Name = "${var.name_prefix}-${var.environment}-reconciler-dlq"
  })
}

resource "aws_cloudwatch_log_group" "processor" {
  name              = "/aws/lambda/${var.name_prefix}-${var.environment}-processor"
  retention_in_days = 30
  kms_key_id        = var.kms_key_arn

  tags = merge(local.common_tags, {
