  })
}

data "archive_file" "processor_zip" {
  type        = "zip"
  output_path = "${path.module}/build/processor.zip"

  source {
    filename = "index.py"
    content  = <<-PY
import json
import os
import boto3
from decimal import Decimal

s3 = boto3.client("s3")
kms = boto3.client("kms")

OUTPUT_BUCKET = os.environ["OUTPUT_BUCKET"]

def handler(event, context):
    records = event.get("Records", [])
    processed = []

    for record in records:
        body = json.loads(record["body"])
        source_bucket = body["source_bucket"]
        source_key = body["source_key"]

        response = s3.get_object(Bucket=source_bucket, Key=source_key)
        payload = response["Body"].read().decode("utf-8")
        items = json.loads(payload, parse_float=Decimal)

        results = []
        for item in items:
            amount = Decimal(str(item["amount"]))
            fee = (amount * Decimal("0.029")).quantize(Decimal("0.01"))
            net = (amount - fee).quantize(Decimal("0.01"))

            results.append({
                "payment_id": item["payment_id"],
                "account_id": item["account_id"],
                "currency": item["currency"],
                "gross_amount": str(amount),
                "processing_fee": str(fee),
                "net_amount": str(net),
                "status": "PROCESSED"
            })

        target_key = f"processed/{source_key.split('/')[-1]}"
        s3.put_object(
            Bucket=OUTPUT_BUCKET,
            Key=target_key,
            Body=json.dumps(results).encode("utf-8"),
            ServerSideEncryption="aws:kms"
        )

        processed.append({
            "source_key": source_key,
            "target_key": target_key,
            "record_count": len(results)
        })

    return {
        "statusCode": 200,
        "processed": processed
    }
PY
  }
}

data "archive_file" "reconciler_zip" {
  type        = "zip"
  output_path = "${path.module}/build/reconciler.zip"

  source {
    filename = "index.py"
    content  = <<-PY
import json
import os
import boto3
from decimal import Decimal

s3 = boto3.client("s3")

INPUT_BUCKET = os.environ["INPUT_BUCKET"]
OUTPUT_BUCKET = os.environ["OUTPUT_BUCKET"]

def handler(event, context):
    reconciliation = []

    for record in event.get("Records", []):
        body = json.loads(record["body"])
        processed_key = body["processed_key"]
        original_key = body["original_key"]

        original_obj = s3.get_object(Bucket=INPUT_BUCKET, Key=original_key)
        processed_obj = s3.get_object(Bucket=OUTPUT_BUCKET, Key=processed_key)

        original_items = json.loads(original_obj["Body"].read().decode("utf-8"), parse_float=Decimal)
        processed_items = json.loads(processed_obj["Body"].read().decode("utf-8"), parse_float=Decimal)

        original_total = sum(Decimal(str(i["amount"])) for i in original_items)
        processed_total = sum(Decimal(str(i["net_amount"])) + Decimal(str(i["processing_fee"])) for i in processed_items)

        reconciliation.append({
            "original_key": original_key,
            "processed_key": processed_key,
            "original_total": str(original_total),
            "processed_total": str(processed_total),
            "matched": original_total == processed_total
        })

    return {
        "statusCode": 200,
        "results": reconciliation
    }
PY
  }
}

resource "aws_iam_role" "lambda_execution" {
  name = "${var.name_prefix}-${var.environment}-lambda-execution-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "LambdaAssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
        Action = "sts:AssumeRole"
      }
    ]
  })

  tags = merge(local.common_tags, {
    Name = "${var.name_prefix}-${var.environment}-lambda-execution-role"
  })
}

resource "aws_iam_policy" "lambda_base" {
  name = "${var.name_prefix}-${var.environment}-lambda-base-policy"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "WriteFunctionLogs"
        Effect = "Allow"
        Action = [
          "logs:CreateLogStream",
          "logs:PutLogEvents"
        ]
        Resource = [
          "${aws_cloudwatch_log_group.processor.arn}:*",
          "${aws_cloudwatch_log_group.reconciler.arn}:*"
        ]
      },
      {
        Sid    = "ManageENIForVPCExecution"
        Effect = "Allow"
        Action = [
          "ec2:CreateNetworkInterface",
          "ec2:DescribeNetworkInterfaces",
          "ec2:DeleteNetworkInterface",
          "ec2:AssignPrivateIpAddresses",
          "ec2:UnassignPrivateIpAddresses"
        ]
        Resource = "*"
      },
      {
        Sid    = "UseKMSForEnvAndData"
        Effect = "Allow"
        Action = [
          "kms:Decrypt",
          "kms:Encrypt",
          "kms:GenerateDataKey",
          "kms:DescribeKey"
        ]
        Resource = [
          var.kms_key_arn,
          var.dlq_kms_key_arn
        ]
      }
    ]
  })
}

resource "aws_iam_policy" "processor_data_access" {
  name = "${var.name_prefix}-${var.environment}-processor-data-access"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "ReadEncryptedInputFiles"
        Effect = "Allow"
        Action = [
          "s3:GetObject",
          "s3:GetObjectVersion"
        ]
        Resource = "${var.input_bucket_arn}/*"
      },
      {
        Sid    = "ListInputBucket"
        Effect = "Allow"
        Action = [
          "s3:ListBucket"
        ]
        Resource = var.input_bucket_arn
      },
      {
        Sid    = "WriteProcessedOutputs"
        Effect = "Allow"
        Action = [
          "s3:PutObject",
          "s3:AbortMultipartUpload"
        ]
        Resource = "${var.output_bucket_arn}/*"
      },
      {
        Sid    = "ListOutputBucket"
        Effect = "Allow"
        Action = [
          "s3:ListBucket"
        ]
        Resource = var.output_bucket_arn
      }
    ]
  })
}

resource "aws_iam_policy" "reconciler_data_access" {
