variable "app_port" {
  description = "Application port"
  type        = number
  default     = 8080
}

variable "db_port" {
  description = "Database port"
  type        = number
  default     = 5432
}

variable "tags" {
  description = "Additional tags"
  type        = map(string)
  default     = {}
}

output "vpc_id" {
