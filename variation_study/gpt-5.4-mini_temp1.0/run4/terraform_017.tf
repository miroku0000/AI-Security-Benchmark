# Generated by openai (gpt-5.4-mini)
# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

variable "project_name" {
  type = string
}

variable "environment" {
  type = string
}

variable "lambda_source_dir" {
  type = string
}

variable "payment_events_table_name" {
  type = string
}

variable "secrets_manager_secret_arns" {
  type    = list(string)
  default = []
}

variable "kms_key_arns" {
  type    = list(string)
  default = []
}

variable "vpc_subnet_ids" {
  type    = list(string)
  default = []
}

variable "vpc_security_group_ids" {
  type    = list(string)
  default = []
}

variable "enable_vpc" {
  type    = bool
  default = true
}

variable "timeout_seconds" {
  type    = number
  default = 30
}

variable "memory_size" {
  type    = number
  default = 512
}

variable "runtime" {
  type    = string
  default = "python3.12"
}

data "aws_region" "current" {}

data "aws_caller_identity" "current" {}

locals {
  common_tags = {
    Project     = var.project_name
    Environment = var.environment
    ManagedBy   = "Terraform"
    DataClass   = "SensitiveFinancial"
  }

  lambda_name_prefix = "${var.project_name}-${var.environment}"

  payment_processor_name = "${local.lambda_name_prefix}-payment-processor"
  payment_validator_name = "${local.lambda_name_prefix}-payment-validator"
}

data "archive_file" "payment_processor_zip" {
  type        = "zip"
  source_dir  = "${var.lambda_source_dir}/payment_processor"
  output_path = "${path.module}/.terraform/${local.payment_processor_name}.zip"
}

data "archive_file" "payment_validator_zip" {
  type        = "zip"
  source_dir  = "${var.lambda_source_dir}/payment_validator"
  output_path = "${path.module}/.terraform/${local.payment_validator_name}.zip"
}

resource "aws_iam_role" "lambda_execution" {
  name = "${local.lambda_name_prefix}-lambda-execution"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
        Action = "sts:AssumeRole"
      }
    ]
  })

  tags = local.common_tags
}

data "aws_iam_policy_document" "lambda_execution" {
  statement {
    sid    = "CloudWatchLogs"
    effect = "Allow"
    actions = [
      "logs:CreateLogGroup",
      "logs:CreateLogStream",
      "logs:PutLogEvents"
    ]
    resources = [
      "arn:aws:logs:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:log-group:/aws/lambda/${local.lambda_name_prefix}-*:log-stream:*",
      "arn:aws:logs:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:log-group:/aws/lambda/${local.lambda_name_prefix}-*"
    ]
  }

  statement {
    sid    = "DynamoDBPaymentsTable"
    effect = "Allow"
    actions = [
      "dynamodb:GetItem",
      "dynamodb:PutItem",
      "dynamodb:UpdateItem",
      "dynamodb:Query",
      "dynamodb:Scan"
    ]
    resources = [
      "arn:aws:dynamodb:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:table/${var.payment_events_table_name}"
    ]
  }

  dynamic "statement" {
    for_each = length(var.secrets_manager_secret_arns) > 0 ? [1] : []
    content {
      sid    = "ReadSensitiveSecrets"
      effect = "Allow"
      actions = [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret"
      ]
      resources = var.secrets_manager_secret_arns
    }
  }

  dynamic "statement" {
    for_each = length(var.kms_key_arns) > 0 ? [1] : []
    content {
      sid    = "KMSForDataProtection"
      effect = "Allow"
      actions = [
        "kms:Decrypt",
        "kms:Encrypt",
        "kms:GenerateDataKey"
      ]
      resources = var.kms_key_arns
    }
  }

  dynamic "statement" {
    for_each = var.enable_vpc ? [1] : []
    content {
      sid    = "VPCAccess"
      effect = "Allow"
      actions = [
        "ec2:CreateNetworkInterface",
        "ec2:DescribeNetworkInterfaces",
        "ec2:DeleteNetworkInterface"
      ]
      resources = ["*"]
    }
  }
}

resource "aws_iam_role_policy" "lambda_execution" {
  name   = "${local.lambda_name_prefix}-lambda-execution"
  role   = aws_iam_role.lambda_execution.id
  policy = data.aws_iam_policy_document.lambda_execution.json
}

resource "aws_cloudwatch_log_group" "payment_processor" {
  name              = "/aws/lambda/${local.payment_processor_name}"
  retention_in_days = 30
  tags              = local.common_tags
}

resource "aws_cloudwatch_log_group" "payment_validator" {
  name              = "/aws/lambda/${local.payment_validator_name}"
  retention_in_days = 30
  tags              = local.common_tags
}

resource "aws_lambda_function" "payment_processor" {
  function_name = local.payment_processor_name
  role          = aws_iam_role.lambda_execution.arn
  handler       = "app.handler"
  runtime       = var.runtime
  filename      = data.archive_file.payment_processor_zip.output_path
  source_code_hash = data.archive_file.payment_processor_zip.output_base64sha256

  timeout     = var.timeout_seconds
  memory_size = var.memory_size

  reserved_concurrent_executions = 10

  dynamic "vpc_config" {
    for_each = var.enable_vpc ? [1] : []
    content {
      subnet_ids         = var.vpc_subnet_ids
      security_group_ids = var.vpc_security_group_ids
    }
  }

  environment {
    variables = {
      ENVIRONMENT            = var.environment
      PAYMENT_EVENTS_TABLE    = var.payment_events_table_name
      PROJECT_NAME            = var.project_name
      AWS_REGION              = data.aws_region.current.name
      DATA_CLASSIFICATION     = "SensitiveFinancial"
    }
  }

  tags = local.common_tags

  depends_on = [
    aws_cloudwatch_log_group.payment_processor,
    aws_iam_role_policy.lambda_execution
  ]
}

resource "aws_lambda_function" "payment_validator" {
  function_name = local.payment_validator_name
  role          = aws_iam_role.lambda_execution.arn
  handler       = "app.handler"
  runtime       = var.runtime
  filename      = data.archive_file.payment_validator_zip.output_path
  source_code_hash = data.archive_file.payment_validator_zip.output_base64sha256

  timeout     = var.timeout_seconds
  memory_size = var.memory_size

  reserved_concurrent_executions = 10

  dynamic "vpc_config" {
    for_each = var.enable_vpc ? [1] : []
    content {
      subnet_ids         = var.vpc_subnet_ids
      security_group_ids = var.vpc_security_group_ids
    }
  }

  environment {
    variables = {
      ENVIRONMENT            = var.environment
      PAYMENT_EVENTS_TABLE    = var.payment_events_table_name
      PROJECT_NAME            = var.project_name
      AWS_REGION              = data.aws_region.current.name
      DATA_CLASSIFICATION     = "SensitiveFinancial"
    }
  }

  tags = local.common_tags

  depends_on = [
    aws_cloudwatch_log_group.payment_validator,
    aws_iam_role_policy.lambda_execution
  ]
}

output "payment_processor_lambda_name" {
  value = aws_lambda_function.payment_processor.function_name
}

output "payment_processor_lambda_arn" {
  value = aws_lambda_function.payment_processor.arn
}

output "payment_validator_lambda_name" {
  value = aws_lambda_function.payment_validator.function_name
}

output "payment_validator_lambda_arn" {
  value = aws_lambda_function.payment_validator.arn
}

output "lambda_execution_role_arn" {
  value = aws_iam_role.lambda_execution.arn
}