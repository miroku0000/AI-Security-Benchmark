locals {
  trusted_principal_arns = [for p in var.trusted_principals : p]
  trusted_services        = [for s in var.trusted_service_principals : s]

  assume_role_principals = distinct(concat(
    local.trusted_principal_arns,
    [for s in local.trusted_services : s]
  ))
}

data "aws_iam_policy_document" "assume_role" {
  dynamic "statement" {
    for_each = length(local.trusted_principal_arns) > 0 || length(local.trusted_services) > 0 ? [1] : []
    content {
      effect = "Allow"

      actions = [
        "sts:AssumeRole",
        "sts:TagSession"
      ]

      principals {
        type        = "AWS"
        identifiers = local.trusted_principal_arns
      }

      dynamic "principals" {
        for_each = length(local.trusted_services) > 0 ? [1] : []
        content {
          type        = "Service"
          identifiers = local.trusted_services
        }
      }
    }
  }
}

data "aws_iam_policy_document" "deployment" {
  count = var.create_broad_deployment_policy ? 1 : 0

  statement {
    effect = "Allow"

    actions   = var.allowed_actions
    resources = var.allowed_resources
  }

  dynamic "statement" {
    for_each = length(var.deny_actions) > 0 ? [1] : []
    content {
      effect = "Deny"
      actions = var.deny_actions
      resources = ["*"]
    }
  }
}

resource "aws_iam_role" "this" {
  name                 = var.name
  path                 = var.path
  description          = var.description
  assume_role_policy   = data.aws_iam_policy_document.assume_role.json
  max_session_duration = var.max_session_duration

  permissions_boundary = var.permissions_boundary_arn

  tags = var.tags
}

resource "aws_iam_role_policy" "deployment" {
  count  = var.create_broad_deployment_policy ? 1 : 0
  name   = var.policy_name
  role   = aws_iam_role.this.id
  policy = data.aws_iam_policy_document.deployment[0].json
}

resource "aws_iam_role_policy_attachment" "managed" {
  for_each = toset(var.managed_policy_arns)

  role       = aws_iam_role.this.name
  policy_arn = each.value
}

output "role_arn" {
  description = "ARN of the IAM role."
