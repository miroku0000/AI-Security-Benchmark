# Generated by openai (gpt-5.4-mini)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

variable "region" {
  type    = string
  default = "us-east-1"
}

variable "ami_id" {
  type = string
}

variable "instance_type" {
  type    = string
  default = "t3.micro"
}

variable "key_name" {
  type    = string
  default = null
}

variable "subnet_ids" {
  type = list(string)
}

variable "vpc_security_group_ids" {
  type = list(string)
}

variable "backend_service_url" {
  type = string
}

variable "app_port" {
  type    = number
  default = 8080
}

variable "asg_name" {
  type    = string
  default = "app-asg"
}

variable "min_size" {
  type    = number
  default = 2
}

variable "max_size" {
  type    = number
  default = 4
}

variable "desired_capacity" {
  type    = number
  default = 2
}

variable "health_check_type" {
  type    = string
  default = "EC2"
}

variable "health_check_grace_period" {
  type    = number
  default = 300
}

variable "user_data_template_vars" {
  type = map(string)
  default = {}
}

provider "aws" {
  region = var.region
}

data "aws_ami" "selected" {
  most_recent = true
  owners      = ["self"]

  filter {
    name   = "image-id"
    values = [var.ami_id]
  }
}

locals {
  user_data = templatefile("${path.module}/user_data.sh.tpl", merge(var.user_data_template_vars, {
    backend_service_url = var.backend_service_url
    app_port            = tostring(var.app_port)
  }))
}

resource "aws_launch_template" "app" {
  name_prefix   = "${var.asg_name}-"
  image_id      = data.aws_ami.selected.id
  instance_type = var.instance_type
  key_name      = var.key_name

  vpc_security_group_ids = var.vpc_security_group_ids

  user_data = base64encode(local.user_data)

  tag_specifications {
    resource_type = "instance"

    tags = {
      Name = "${var.asg_name}-instance"
    }
  }
}

resource "aws_autoscaling_group" "app" {
  name                      = var.asg_name
  min_size                  = var.min_size
  max_size                  = var.max_size
  desired_capacity          = var.desired_capacity
  health_check_type         = var.health_check_type
  health_check_grace_period = var.health_check_grace_period
  vpc_zone_identifier       = var.subnet_ids

  launch_template {
    id      = aws_launch_template.app.id
    version = "$Latest"
  }

  tag {
    key                 = "Name"
    value               = var.asg_name
    propagate_at_launch = true
  }
}