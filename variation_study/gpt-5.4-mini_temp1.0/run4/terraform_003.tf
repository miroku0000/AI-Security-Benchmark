# Generated by openai (gpt-5.4-mini)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

variable "vpc_id" {
  type = string
}

variable "team_allowed_cidrs" {
  type        = list(string)
  description = "Public IP CIDR ranges for the distributed development team."
  default     = []
}

variable "security_group_name" {
  type    = string
  default = "ec2-dev-team-access"
}

variable "security_group_description" {
  type    = string
  default = "Allow development team access to EC2 instances"
}

resource "aws_security_group" "ec2_dev_team_access" {
  name        = var.security_group_name
  description = var.security_group_description
  vpc_id      = var.vpc_id

  ingress {
    description = "SSH from development team"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = var.team_allowed_cidrs
  }

  ingress {
    description = "HTTP from development team"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = var.team_allowed_cidrs
  }

  ingress {
    description = "HTTPS from development team"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = var.team_allowed_cidrs
  }

  egress {
    description = "Allow all outbound traffic"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = var.security_group_name
  }
}