pragma solidity ^0.8.24;

interface IERC20 {
    function totalSupply() external view returns (uint256);
    function balanceOf(address account) external view returns (uint256);
    function transfer(address recipient, uint256 amount) external returns (bool);
    function allowance(address owner, address spender) external view returns (uint256);
    function approve(address spender, uint256 amount) external returns (bool);
    function transferFrom(address sender, address recipient, uint256 amount) external returns (bool);
    function decimals() external view returns (uint8);
}

interface IUniswapV2Pair {
    function token0() external view returns (address);
    function token1() external view returns (address);
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
}

contract DeFiLendingProtocol {
    struct Market {
        address asset;
        address collateralDexPair; // DEX pair containing asset <-> quote asset used as oracle
        address quoteAsset;         // e.g. USDC
        uint256 collateralFactorBps; // borrowable LTV in bps
        uint256 liquidationThresholdBps; // liquidation threshold in bps
        bool listed;
    }

    struct Position {
        uint256 supplied;
        uint256 borrowed;
    }

    mapping(address => Market) public markets; // asset => market
    address[] public listedAssets;
    mapping(address => mapping(address => Position)) public positions; // user => asset => position

    address public immutable quoteAsset;
    address public owner;

    uint256 public constant BPS = 10_000;
    uint256 public constant LIQUIDATION_CLOSE_FACTOR_BPS = 5_000; // 50%

    event MarketListed(address indexed asset, address indexed pair, address indexed quoteAsset, uint256 collateralFactorBps, uint256 liquidationThresholdBps);
    event Supplied(address indexed user, address indexed asset, uint256 amount);
    event Withdrawn(address indexed user, address indexed asset, uint256 amount);
    event Borrowed(address indexed user, address indexed asset, uint256 amount);
    event Repaid(address indexed user, address indexed asset, uint256 amount);
    event Liquidated(address indexed liquidator, address indexed user, address indexed debtAsset, address collateralAsset, uint256 repaidAmount, uint256 seizedCollateral);

    modifier onlyOwner() {
        require(msg.sender == owner, "NOT_OWNER");
        _;
    }

    constructor(address _quoteAsset) {
        require(_quoteAsset != address(0), "INVALID_QUOTE");
        quoteAsset = _quoteAsset;
        owner = msg.sender;
    }

    function listMarket(
        address asset,
        address pair,
        uint256 collateralFactorBps,
        uint256 liquidationThresholdBps
    ) external onlyOwner {
        require(asset != address(0) && pair != address(0), "INVALID_ADDRESS");
        require(collateralFactorBps < liquidationThresholdBps, "BAD_FACTORS");
        require(liquidationThresholdBps <= BPS, "INVALID_THRESHOLD");
        markets[asset] = Market({
            asset: asset,
            collateralDexPair: pair,
            quoteAsset: quoteAsset,
            collateralFactorBps: collateralFactorBps,
            liquidationThresholdBps: liquidationThresholdBps,
            listed: true
        });
        listedAssets.push(asset);
        emit MarketListed(asset, pair, quoteAsset, collateralFactorBps, liquidationThresholdBps);
    }

    function supply(address asset, uint256 amount) external {
        require(markets[asset].listed, "UNLISTED");
        require(amount > 0, "ZERO_AMOUNT");
        _transferIn(asset, msg.sender, amount);
        positions[msg.sender][asset].supplied += amount;
        emit Supplied(msg.sender, asset, amount);
    }

    function withdraw(address asset, uint256 amount) external {
        require(markets[asset].listed, "UNLISTED");
        require(amount > 0, "ZERO_AMOUNT");
        Position storage pos = positions[msg.sender][asset];
        require(pos.supplied >= amount, "INSUFFICIENT_SUPPLY");
        pos.supplied -= amount;
        require(_isHealthy(msg.sender), "INSUFFICIENT_COLLATERAL");
        _transferOut(asset, msg.sender, amount);
        emit Withdrawn(msg.sender, asset, amount);
    }

    function borrow(address asset, uint256 amount) external {
        require(markets[asset].listed, "UNLISTED");
        require(amount > 0, "ZERO_AMOUNT");
        Position storage pos = positions[msg.sender][asset];
        pos.borrowed += amount;
        require(_isHealthy(msg.sender), "INSUFFICIENT_COLLATERAL");
        _transferOut(asset, msg.sender, amount);
        emit Borrowed(msg.sender, asset, amount);
    }

    function repay(address asset, uint256 amount) external {
        require(markets[asset].listed, "UNLISTED");
        require(amount > 0, "ZERO_AMOUNT");
        Position storage pos = positions[msg.sender][asset];
        require(pos.borrowed >= amount, "REPAY_TOO_MUCH");
        _transferIn(asset, msg.sender, amount);
        pos.borrowed -= amount;
        emit Repaid(msg.sender, asset, amount);
    }

    function liquidate(
        address user,
        address debtAsset,
        address collateralAsset,
        uint256 repayAmount
    ) external {
        require(markets[debtAsset].listed && markets[collateralAsset].listed, "UNLISTED");
        require(repayAmount > 0, "ZERO_AMOUNT");
        require(!_isHealthy(user), "USER_HEALTHY");

        Position storage debtPos = positions[user][debtAsset];
        require(debtPos.borrowed > 0, "NO_DEBT");
        uint256 maxClose = (debtPos.borrowed * LIQUIDATION_CLOSE_FACTOR_BPS) / BPS;
        uint256 actualRepay = repayAmount > maxClose ? maxClose : repayAmount;
        require(actualRepay > 0, "INVALID_REPAY");

        _transferIn(debtAsset, msg.sender, actualRepay);
        debtPos.borrowed -= actualRepay;

        uint256 debtValueQuote = _toQuote(debtAsset, actualRepay);
        uint256 bonusBps = 1_100; // 10% liquidation bonus
        uint256 seizeValueQuote = (debtValueQuote * bonusBps) / BPS;
        uint256 seizeAmount = _fromQuote(collateralAsset, seizeValueQuote);

        Position storage collPos = positions[user][collateralAsset];
        require(collPos.supplied >= seizeAmount, "INSUFFICIENT_COLLATERAL");
        collPos.supplied -= seizeAmount;

        _transferOut(collateralAsset, msg.sender, seizeAmount);

        emit Liquidated(msg.sender, user, debtAsset, collateralAsset, actualRepay, seizeAmount);
    }

    function totalCollateralValue(address user) public view returns (uint256 valueQuote) {
        for (uint256 i = 0; i < listedAssets.length; i++) {
            address asset = listedAssets[i];
            uint256 supplied = positions[user][asset].supplied;
            if (supplied > 0) {
                valueQuote += _toQuote(asset, supplied);
            }
        }
    }

    function totalBorrowValue(address user) public view returns (uint256 valueQuote) {
        for (uint256 i = 0; i < listedAssets.length; i++) {
            address asset = listedAssets[i];
            uint256 borrowed = positions[user][asset].borrowed;
            if (borrowed > 0) {
                valueQuote += _toQuote(asset, borrowed);
            }
        }
    }

    function collateralCapacity(address user) external view returns (uint256) {
        uint256 capacity;
        for (uint256 i = 0; i < listedAssets.length; i++) {
            address asset = listedAssets[i];
            uint256 supplied = positions[user][asset].supplied;
            if (supplied == 0) continue;
            Market memory m = markets[asset];
            uint256 assetValue = _toQuote(asset, supplied);
            capacity += (assetValue * m.collateralFactorBps) / BPS;
        }
        return capacity;
    }

    function liquidationValue(address user) external view returns (uint256) {
        uint256 capacity;
        for (uint256 i = 0; i < listedAssets.length; i++) {
            address asset = listedAssets[i];
            uint256 supplied = positions[user][asset].supplied;
            if (supplied == 0) continue;
            Market memory m = markets[asset];
            uint256 assetValue = _toQuote(asset, supplied);
            capacity += (assetValue * m.liquidationThresholdBps) / BPS;
        }
        return capacity;
    }

    function healthFactor(address user) public view returns (uint256) {
        uint256 debt = totalBorrowValue(user);
        if (debt == 0) return type(uint256).max;
        uint256 liq = liquidationValue(user);
        return (liq * 1e18) / debt;
    }

    function _isHealthy(address user) internal view returns (bool) {
        return totalBorrowValue(user) <= collateralCapacity(user);
    }

    function _toQuote(address asset, uint256 amount) internal view returns (uint256) {
        if (asset == quoteAsset) return amount;
        Market memory m = markets[asset];
        require(m.listed, "UNLISTED");
        (uint256 priceNumerator, uint256 priceDenominator) = _currentPrice(asset);
        return (amount * priceNumerator) / priceDenominator;
    }

    function _fromQuote(address asset, uint256 quoteAmount) internal view returns (uint256) {
        if (asset == quoteAsset) return quoteAmount;
        (uint256 priceNumerator, uint256 priceDenominator) = _currentPrice(asset);
        return (quoteAmount * priceDenominator) / priceNumerator;
    }

    function _currentPrice(address asset) internal view returns (uint256 numerator, uint256 denominator) {
        Market memory m = markets[asset];
        require(m.listed, "UNLISTED");
        IUniswapV2Pair pair = IUniswapV2Pair(m.collateralDexPair);
        address token0 = pair.token0();
        address token1 = pair.token1();
        require(
            (token0 == asset && token1 == quoteAsset) || (token1 == asset && token0 == quoteAsset),
            "BAD_PAIR"
        );

        (uint112 r0, uint112 r1, ) = pair.getReserves();
        require(r0 > 0 && r1 > 0, "NO_LIQUIDITY");

        uint8 assetDecimals = IERC20(asset).decimals();
        uint8 quoteDecimals = IERC20(quoteAsset).decimals();

        if (token0 == asset) {
            // price of 1 asset in quote terms:
            // quote per asset = r1 / r0 adjusted for decimals
            numerator = uint256(r1) * (10 ** assetDecimals);
            denominator = uint256(r0) * (10 ** quoteDecimals);
        } else {
            numerator = uint256(r0) * (10 ** assetDecimals);
            denominator = uint256(r1) * (10 ** quoteDecimals);
        }
        require(numerator > 0 && denominator > 0, "INVALID_PRICE");
    }

    function _transferIn(address asset, address from, uint256 amount) internal {
        require(IERC20(asset).transferFrom(from, address(this), amount), "TRANSFER_IN_FAILED");
    }

    function _transferOut(address asset, address to, uint256 amount) internal {
        require(IERC20(asset).transfer(to, amount), "TRANSFER_OUT_FAILED");
    }

    function marketCount() external view returns (uint256) {
        return listedAssets.length;
    }
}