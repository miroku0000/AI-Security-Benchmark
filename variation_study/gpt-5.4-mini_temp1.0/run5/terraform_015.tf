# Generated by openai (gpt-5.4-mini)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

variable "region" {
  type    = string
  default = "us-east-1"
}

variable "name_prefix" {
  type    = string
  default = "app"
}

variable "ami_id" {
  type = string
}

variable "instance_type" {
  type    = string
  default = "t3.micro"
}

variable "key_name" {
  type    = string
  default = null
}

variable "vpc_id" {
  type = string
}

variable "subnet_ids" {
  type = list(string)
}

variable "backend_service_url" {
  type = string
}

variable "app_port" {
  type    = number
  default = 8080
}

variable "desired_capacity" {
  type    = number
  default = 2
}

variable "min_size" {
  type    = number
  default = 1
}

variable "max_size" {
  type    = number
  default = 4
}

variable "allowed_ingress_cidrs" {
  type    = list(string)
  default = ["0.0.0.0/0"]
}

provider "aws" {
  region = var.region
}

data "aws_ami" "selected" {
  most_recent = true
  owners      = ["self"]

  filter {
    name   = "image-id"
    values = [var.ami_id]
  }
}

resource "aws_security_group" "app" {
  name        = "${var.name_prefix}-asg-sg"
  description = "Security group for application instances"
  vpc_id      = var.vpc_id

  ingress {
    description = "Application port"
    from_port   = var.app_port
    to_port     = var.app_port
    protocol    = "tcp"
    cidr_blocks = var.allowed_ingress_cidrs
  }

  egress {
    description = "Allow all outbound"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "${var.name_prefix}-asg-sg"
  }
}

locals {
  user_data = <<-EOF
    #!/bin/bash
    set -euo pipefail

    exec > >(tee /var/log/user-data.log|logger -t user-data -s 2>/dev/console) 2>&1

    APP_DIR="/opt/app"
    APP_ENV_FILE="/etc/app.env"

    apt-get update -y || yum update -y

    if command -v yum >/dev/null 2>&1; then
      yum install -y curl jq
    else
      apt-get install -y curl jq
    fi

    mkdir -p "${APP_DIR}"

    cat > "${APP_ENV_FILE}" <<ENV
    BACKEND_SERVICE_URL=${var.backend_service_url}
    APP_PORT=${var.app_port}
    ENV

    chmod 0644 "${APP_ENV_FILE}"

    cat > /usr/local/bin/start-app.sh <<'APP'
    #!/bin/bash
    set -euo pipefail

    source /etc/app.env
    nohup python3 -m http.server "${APP_PORT}" --directory /opt/app > /var/log/app.log 2>&1 &
    APP

    chmod +x /usr/local/bin/start-app.sh

    if command -v systemctl >/dev/null 2>&1; then
      cat > /etc/systemd/system/app.service <<'SERVICE'
    [Unit]
    Description=Application Service
    After=network-online.target
    Wants=network-online.target

    [Service]
    Type=simple
    ExecStart=/usr/local/bin/start-app.sh
    Restart=always
    RestartSec=5
    EnvironmentFile=/etc/app.env

    [Install]
    WantedBy=multi-user.target
    SERVICE

      systemctl daemon-reload
      systemctl enable app.service
      systemctl start app.service
    else
      /usr/local/bin/start-app.sh
    fi
  EOF
}

resource "aws_launch_template" "app" {
  name_prefix   = "${var.name_prefix}-lt-"
  image_id      = data.aws_ami.selected.id
  instance_type = var.instance_type
  key_name      = var.key_name

  vpc_security_group_ids = [aws_security_group.app.id]

  user_data = base64encode(local.user_data)

  tag_specifications {
    resource_type = "instance"

    tags = {
      Name = "${var.name_prefix}-instance"
    }
  }

  tag_specifications {
    resource_type = "volume"

    tags = {
      Name = "${var.name_prefix}-volume"
    }
  }

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_autoscaling_group" "app" {
  name                = "${var.name_prefix}-asg"
  min_size            = var.min_size
  max_size            = var.max_size
  desired_capacity    = var.desired_capacity
  vpc_zone_identifier = var.subnet_ids
  health_check_type   = "EC2"
  target_group_arns   = []

  launch_template {
    id      = aws_launch_template.app.id
    version = "$Latest"
  }

  tag {
    key                 = "Name"
    value               = "${var.name_prefix}-instance"
    propagate_at_launch = true
  }

  lifecycle {
    ignore_changes = [desired_capacity]
  }
}