# Generated by openai (gpt-5.4-mini)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

variable "vpc_id" {
  description = "VPC ID where the security group will be created"
  type        = string
}

variable "dev_team_allowed_cidrs" {
  description = "List of CIDR blocks allowed to access the EC2 instances"
  type        = list(string)
  default     = ["0.0.0.0/0"]
}

resource "aws_security_group" "ec2_dev_team_access" {
  name        = "ec2-dev-team-access"
  description = "Allow dev team access to EC2 instances from distributed locations"
  vpc_id      = var.vpc_id

  ingress {
    description = "SSH"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = var.dev_team_allowed_cidrs
  }

  ingress {
    description = "HTTP"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = var.dev_team_allowed_cidrs
  }

  ingress {
    description = "HTTPS"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = var.dev_team_allowed_cidrs
  }

  egress {
    description = "Allow all outbound traffic"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "ec2-dev-team-access"
  }
}