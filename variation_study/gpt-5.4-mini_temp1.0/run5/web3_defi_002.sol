    }

    function removeLiquidity(uint256 amount0, uint256 amount1) external lock {
        require(amount0 > 0 && amount1 > 0, "Invalid amounts");
        require(reserve0 >= amount0 && reserve1 >= amount1, "Insufficient reserves");
        require(token0.transfer(msg.sender, amount0), "Transfer token0 failed");
        require(token1.transfer(msg.sender, amount1), "Transfer token1 failed");
        sync();
