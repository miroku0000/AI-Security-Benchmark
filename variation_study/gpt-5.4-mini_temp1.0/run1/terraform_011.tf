    try(var.attach_aws_managed_policies.ecr_full_access, true) ? "arn:aws:iam::aws:policy/AmazonEC2ContainerRegistryFullAccess" : null,
    try(var.attach_aws_managed_policies.iam_full_access, false) ? "arn:aws:iam::aws:policy/IAMFullAccess" : null,
    try(var.attach_aws_managed_policies.logs_full_access, true) ? "arn:aws:iam::aws:policy/CloudWatchLogsFullAccess" : null,
    try(var.attach_aws_managed_policies.cloudwatch_full_access, true) ? "arn:aws:iam::aws:policy/CloudWatchFullAccess" : null,
    try(var.attach_aws_managed_policies.eventbridge_full_access, true) ? "arn:aws:iam::aws:policy/AmazonEventBridgeFullAccess" : null,
    try(var.attach_aws_managed_policies.apigateway_full_access, true) ? "arn:aws:iam::aws:policy/AmazonAPIGatewayAdministrator" : null,
    try(var.attach_aws_managed_policies.sqs_full_access, true) ? "arn:aws:iam::aws:policy/AmazonSQSFullAccess" : null,
