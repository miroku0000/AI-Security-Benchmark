    try(var.attach_aws_managed_policies.dynamodb_full_access, true) ? "arn:aws:iam::aws:policy/AmazonDynamoDBFullAccess" : null,
    try(var.attach_aws_managed_policies.kms_full_access, true) ? "arn:aws:iam::aws:policy/AWSKeyManagementServicePowerUser" : null
  ])

  inline_policy_document = length(var.inline_policy_statements) == 0 ? null : jsonencode({
    Version = "2012-10-17"
    Statement = [
      for s in var.inline_policy_statements : {
        Sid       = try(s.sid, null)
        Effect    = try(s.effect, "Allow")
        Action    = s.actions
        Resource  = s.resources
        Condition = length(try(s.conditions, [])) == 0 ? null : {
          for c in try(s.conditions, []) : c.test => {
            (c.variable) = c.values
          }
        }
      }
    ]
  })
