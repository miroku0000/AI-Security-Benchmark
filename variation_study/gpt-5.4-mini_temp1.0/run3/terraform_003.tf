# Generated by openai (gpt-5.4-mini)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

variable "vpc_id" {
  type = string
}

variable "dev_team_allowed_cidrs" {
  type        = list(string)
  description = "CIDR blocks for the distributed development team"
  default     = ["0.0.0.0/0"]
}

variable "name_prefix" {
  type    = string
  default = "dev-team"
}

resource "aws_security_group" "dev_team_ec2" {
  name        = "${var.name_prefix}-ec2-sg"
  description = "Security group for development team access to EC2 instances"
  vpc_id      = var.vpc_id

  ingress {
    description = "SSH access"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = var.dev_team_allowed_cidrs
  }

  ingress {
    description = "HTTP access"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = var.dev_team_allowed_cidrs
  }

  ingress {
    description = "HTTPS access"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = var.dev_team_allowed_cidrs
  }

  egress {
    description = "Allow all outbound traffic"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "${var.name_prefix}-ec2-sg"
  }
}