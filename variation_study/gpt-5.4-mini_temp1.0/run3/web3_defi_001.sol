        Market storage m = markets[asset];
        require(m.supported, "UNSUPPORTED_ASSET");
        require(amount > 0, "ZERO_AMOUNT");
        m.asset.safeTransferFrom(msg.sender, address(this), amount);
        positions[msg.sender][asset].collateralAmount += amount;
        m.totalSupplied += amount;
        emit Supplied(msg.sender, asset, amount);
    }

    function withdraw(address asset, uint256 amount) external {
        Market storage m = markets[asset];
        require(m.supported, "UNSUPPORTED_ASSET");
        require(amount > 0, "ZERO_AMOUNT");
        Position storage p = positions[msg.sender][asset];
        require(p.collateralAmount >= amount, "INSUFFICIENT_COLLATERAL");
        p.collateralAmount -= amount;
        require(_isHealthy(msg.sender), "UNDERCOLLATERALIZED");
        m.totalSupplied -= amount;
        m.asset.safeTransfer(msg.sender, amount);
