    function borrow(address asset, uint256 amount) external {
        Market storage m = markets[asset];
        require(m.supported, "UNSUPPORTED_ASSET");
        require(amount > 0, "ZERO_AMOUNT");
        require(m.asset.balanceOf(address(this)) >= amount, "INSUFFICIENT_LIQUIDITY");
        Position storage p = positions[msg.sender][asset];
        p.debtAmount += amount;
        require(_isHealthy(msg.sender), "INSUFFICIENT_COLLATERAL");
        m.totalBorrowed += amount;
        m.asset.safeTransfer(msg.sender, amount);
