        for (uint256 i = 0; i < recipients.length; ++i) {
            address to = recipients[i];
            if (to == address(0)) revert ZeroAddress();
            uint256 amount = amounts[i];
            total += amount;
            (bool success, ) = payable(to).call{value: amount}("");
            if (!success) revert TransferFailed();
        }

        if (total > msg.value) revert InsufficientBalance();

        if (msg.value > total) {
            (bool refundSuccess, ) = payable(msg.sender).call{value: msg.value - total}("");
            if (!refundSuccess) revert TransferFailed();
        }
    }

    function withdrawToken(address token, uint256 amount, address to) external onlyOwner {
        if (token == address(0) || to == address(0)) revert ZeroAddress();
        if (!IERC20(token).transfer(to, amount)) revert TransferFailed();
    }

    function withdrawNative(uint256 amount, address payable to) external onlyOwner {
        if (to == address(0)) revert ZeroAddress();
        (bool success, ) = to.call{value: amount}("");
        if (!success) revert TransferFailed();
    }

    function batchExecutePayments(
        address[] calldata recipients,
