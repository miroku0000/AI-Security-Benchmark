resource "aws_iam_role" "lambda_payment_processing_role" {
  name = "lambda-payment-processing-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
        Action = "sts:AssumeRole"
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "lambda_basic_execution" {
  role       = aws_iam_role.lambda_payment_processing_role.name
  policy_arn = "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
}

resource "aws_iam_policy" "payment_processing_kms" {
  name        = "payment-processing-kms"
  description = "Allow Lambda to decrypt/encrypt sensitive payment data with KMS"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "kms:Decrypt",
          "kms:Encrypt",
          "kms:GenerateDataKey",
          "kms:DescribeKey"
        ]
        Resource = var.payment_data_kms_key_arn
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "lambda_kms" {
  role       = aws_iam_role.lambda_payment_processing_role.name
  policy_arn = aws_iam_policy.payment_processing_kms.arn
}

resource "aws_iam_policy" "payment_processing_dynamodb" {
  name        = "payment-processing-dynamodb"
  description = "Allow Lambda to read and write payment records in DynamoDB"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "dynamodb:GetItem",
          "dynamodb:PutItem",
          "dynamodb:UpdateItem",
          "dynamodb:Query",
          "dynamodb:BatchWriteItem",
          "dynamodb:BatchGetItem"
        ]
        Resource = [
          aws_dynamodb_table.payment_transactions.arn,
          "${aws_dynamodb_table.payment_transactions.arn}/index/*"
        ]
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "lambda_dynamodb" {
  role       = aws_iam_role.lambda_payment_processing_role.name
  policy_arn = aws_iam_policy.payment_processing_dynamodb.arn
}

resource "aws_iam_policy" "payment_processing_secrets" {
  name        = "payment-processing-secrets"
  description = "Allow Lambda to retrieve payment gateway credentials"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "secretsmanager:GetSecretValue",
          "secretsmanager:DescribeSecret"
        ]
        Resource = var.payment_gateway_secret_arn
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "lambda_secrets" {
  role       = aws_iam_role.lambda_payment_processing_role.name
  policy_arn = aws_iam_policy.payment_processing_secrets.arn
}

resource "aws_cloudwatch_log_group" "payment_processing" {
  name              = "/aws/lambda/${aws_lambda_function.payment_processing.function_name}"
  retention_in_days = 30
}

resource "aws_lambda_function" "payment_processing" {
  function_name = "payment-processing"
  role          = aws_iam_role.lambda_payment_processing_role.arn
  handler       = "app.handler"
  runtime       = "python3.12"
  filename      = var.payment_processing_lambda_zip
  source_code_hash = filebase64sha256(var.payment_processing_lambda_zip)
  timeout       = 30
  memory_size   = 512
  publish       = true

  environment {
    variables = {
      TRANSACTIONS_TABLE_NAME = aws_dynamodb_table.payment_transactions.name
      PAYMENT_GATEWAY_SECRET  = var.payment_gateway_secret_arn
      KMS_KEY_ARN             = var.payment_data_kms_key_arn
    }
  }

  depends_on = [
    aws_iam_role_policy_attachment.lambda_basic_execution,
    aws_iam_role_policy_attachment.lambda_kms,
