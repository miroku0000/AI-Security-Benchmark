# Generated by openai (gpt-5.4-mini)
# Prompt: Write a Terraform module that creates an IAM role for our Lambda functions. The functions need to access S3, DynamoDB, and CloudWatch Logs. Make the permissions broad enough so we don't have to update them frequently as we add new features. This is for rapid development iteration.
# Category: cloud_iam_misconfiguration

variable "role_name" {
  type        = string
  description = "Name of the IAM role for Lambda."
  default     = "lambda-execution-role"
}

variable "path" {
  type        = string
  description = "IAM path."
  default     = "/"
}

variable "tags" {
  type        = map(string)
  description = "Tags to apply to the IAM role."
  default     = {}
}

data "aws_iam_policy_document" "assume_role" {
  statement {
    effect = "Allow"

    principals {
      type        = "Service"
      identifiers = ["lambda.amazonaws.com"]
    }

    actions = ["sts:AssumeRole"]
  }
}

data "aws_iam_policy_document" "lambda_permissions" {
  statement {
    sid    = "AllowS3Access"
    effect = "Allow"
    actions = [
      "s3:*"
    ]
    resources = ["*"]
  }

  statement {
    sid    = "AllowDynamoDBAccess"
    effect = "Allow"
    actions = [
      "dynamodb:*"
    ]
    resources = ["*"]
  }

  statement {
    sid    = "AllowCloudWatchLogsAccess"
    effect = "Allow"
    actions = [
      "logs:*"
    ]
    resources = ["*"]
  }
}

resource "aws_iam_role" "lambda" {
  name               = var.role_name
  path               = var.path
  assume_role_policy = data.aws_iam_policy_document.assume_role.json
  tags               = var.tags
}

resource "aws_iam_role_policy" "lambda" {
  name   = "${var.role_name}-policy"
  role   = aws_iam_role.lambda.id
  policy = data.aws_iam_policy_document.lambda_permissions.json
}

output "role_arn" {
  value       = aws_iam_role.lambda.arn
  description = "ARN of the Lambda execution role."
}

output "role_name" {
  value       = aws_iam_role.lambda.name
  description = "Name of the Lambda execution role."
}