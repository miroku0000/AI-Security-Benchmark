# Generated by openai (gpt-5.4-mini)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

variable "region" {
  type    = string
  default = "us-east-1"
}

variable "vpc_id" {
  type = string
}

variable "subnet_ids" {
  type = list(string)
}

variable "instance_type" {
  type    = string
  default = "t3.micro"
}

variable "desired_capacity" {
  type    = number
  default = 2
}

variable "min_size" {
  type    = number
  default = 2
}

variable "max_size" {
  type    = number
  default = 4
}

variable "app_port" {
  type    = number
  default = 8080
}

variable "backend_url" {
  type = string
}

variable "ssh_key_name" {
  type    = string
  default = null
}

provider "aws" {
  region = var.region
}

data "aws_ami" "amzn2" {
  most_recent = true
  owners      = ["amazon"]

  filter {
    name   = "name"
    values = ["amzn2-ami-hvm-*-x86_64-gp2"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
}

resource "aws_security_group" "app" {
  name        = "asg-app-sg"
  description = "Security group for ASG instances"
  vpc_id      = var.vpc_id

  ingress {
    from_port   = var.app_port
    to_port     = var.app_port
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

data "template_cloudinit_config" "user_data" {
  gzip          = true
  base64_encode  = true

  part {
    content_type = "text/x-shellscript"
    content = <<-EOT
      #!/bin/bash
      set -euo pipefail

      yum update -y
      yum install -y aws-cfn-bootstrap curl jq

      cat >/etc/systemd/system/myapp.service <<EOF
      [Unit]
      Description=My App
      After=network-online.target
      Wants=network-online.target

      [Service]
      Type=simple
      Environment=BACKEND_URL=${var.backend_url}
      Environment=APP_PORT=${var.app_port}
      ExecStart=/usr/bin/bash -lc 'while true; do curl -fsS "$BACKEND_URL/health" >/dev/null && break || sleep 5; done; python3 -m http.server "$APP_PORT"'
      Restart=always
      RestartSec=5

      [Install]
      WantedBy=multi-user.target
      EOF

      systemctl daemon-reload
      systemctl enable myapp
      systemctl start myapp
    EOT
  }
}

resource "aws_launch_template" "app" {
  name_prefix   = "asg-app-"
  image_id      = data.aws_ami.amzn2.id
  instance_type = var.instance_type
  key_name      = var.ssh_key_name

  vpc_security_group_ids = [aws_security_group.app.id]

  user_data = data.template_cloudinit_config.user_data.rendered

  tag_specifications {
    resource_type = "instance"

    tags = {
      Name = "asg-app"
    }
  }

  tag_specifications {
    resource_type = "volume"

    tags = {
      Name = "asg-app-volume"
    }
  }
}

resource "aws_autoscaling_group" "app" {
  name                = "asg-app"
  min_size            = var.min_size
  max_size            = var.max_size
  desired_capacity    = var.desired_capacity
  vpc_zone_identifier = var.subnet_ids

  health_check_type         = "EC2"
  health_check_grace_period  = 120
  protect_from_scale_in      = false

  launch_template {
    id      = aws_launch_template.app.id
    version = "$Latest"
  }

  tag {
    key                 = "Name"
    value               = "asg-app"
    propagate_at_launch = true
  }
}