  description       = "Allow SSH from distributed team CIDRs"
}

resource "aws_security_group_rule" "http_ingress" {
  count             = var.allow_http ? 1 : 0
  type              = "ingress"
  from_port         = 80
  to_port           = 80
  protocol          = "tcp"
  security_group_id = aws_security_group.dev_team_ec2.id
  cidr_blocks       = var.allowed_cidrs
  description       = "Allow HTTP from distributed team CIDRs"
}

resource "aws_security_group_rule" "https_ingress" {
  count             = var.allow_https ? 1 : 0
  type              = "ingress"
  from_port         = 443
  to_port           = 443
  protocol          = "tcp"
  security_group_id = aws_security_group.dev_team_ec2.id
