variable "name" {
  type    = string
  default = "dev-team-ec2-sg"
}

variable "vpc_id" {
  type = string
}

variable "allowed_cidrs" {
  type        = list(string)
  description = "CIDR blocks for the distributed development team"
  default     = []
}

variable "allow_ssh" {
  type    = bool
  default = true
}

variable "allow_http" {
  type    = bool
  default = true
}

variable "allow_https" {
  type    = bool
  default = true
}

resource "aws_security_group" "dev_team_ec2" {
  name        = var.name
  description = "Security group for distributed development team access"
  vpc_id      = var.vpc_id

  tags = {
    Name = var.name
  }
}

resource "aws_security_group_rule" "ssh_ingress" {
  count             = var.allow_ssh ? 1 : 0
  type              = "ingress"
  from_port         = 22
  to_port           = 22
  protocol          = "tcp"
