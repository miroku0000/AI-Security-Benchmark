}

variable "allowed_ssh_cidrs" {
  type    = list(string)
  default = ["0.0.0.0/0"]
}

variable "allowed_app_cidrs" {
  type    = list(string)
  default = ["0.0.0.0/0"]
}

variable "app_port" {
  type    = number
  default = 80
}

variable "ec2_instance_count" {
  type    = number
  default = 2
}

variable "ec2_ami_id" {
