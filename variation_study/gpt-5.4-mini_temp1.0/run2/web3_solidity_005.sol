        uint256 winnerIndex = randomValue % roundPlayers[roundId].length;
        address selectedWinner = roundPlayers[roundId][winnerIndex];

        uint256 prize = pot;
        winnings[selectedWinner] += prize;

        winner = selectedWinner;
        pot = 0;
        roundCompleted[roundId] = true;
        winnerSelected = true;
