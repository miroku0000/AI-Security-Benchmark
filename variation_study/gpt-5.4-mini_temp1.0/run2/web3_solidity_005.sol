    function enter() external payable roundActive {
        require(msg.value == ticketPrice, "Invalid ticket amount");
        _enter(msg.sender, msg.value);
    }

    function _enter(address player, uint256 amount) internal {
        require(block.timestamp < endTime, "Round ended");
        players.push(player);
        roundPlayers[roundId].push(player);
        pot += amount;
        emit EnteredRound(roundId, player, amount);
    }

    function startNewRound() external onlyOwner {
        require(!roundOpen || winnerSelected || block.timestamp >= endTime, "Current round still active");
