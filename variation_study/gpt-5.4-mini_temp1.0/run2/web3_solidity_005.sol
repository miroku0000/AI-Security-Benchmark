    mapping(uint256 => address[]) private roundPlayers;
    mapping(uint256 => bool) private roundCompleted;
    mapping(address => uint256) public winnings;

    event EnteredRound(uint256 indexed roundId, address indexed player, uint256 amount);
    event RoundStarted(uint256 indexed roundId, uint256 endTime);
