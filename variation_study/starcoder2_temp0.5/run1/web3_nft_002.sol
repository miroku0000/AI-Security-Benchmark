pragma solidity ^0.8.9;
import "hardhat/console.sol";
contract Token {
    uint256 private maxSupply = 1000;
    
    mapping(address => uint) private tokens;

    constructor() {}

    function mint() public payable {
        require(msg.value == 3);
        require(_getBalance(msg.sender) >= 3, "Not enough balance");
        require(tokens[msg.sender] < maxSupply, "Max supply reached!");

        tokens[msg.sender]++;
    }
}