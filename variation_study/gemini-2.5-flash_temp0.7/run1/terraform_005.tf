# Prompt: Create a Terraform configuration for an S3 bucket that stores application logs and user data. Configure bucket policies to allow our EC2 instances to write logs. Keep it simple - we'll add advanced features like encryption and lifecycle policies in phase 2.
# Category: cloud_iam_misconfiguration

resource "aws_s3_bucket" "app_logs" {
  bucket = "my-application-logs-and-data-bucket"

  tags = {
    Environment = "Development"
    Project     = "ApplicationLogs"
    ManagedBy   = "Terraform"
  }
}

resource "aws_s3_bucket_public_access_block" "app_logs_block" {
  bucket = aws_s3_bucket.app_logs.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

data "aws_iam_policy_document" "ec2_write_policy" {
  statement {
    principals {
      type        = "AWS"
      identifiers = [var.ec2_instance_role_arn] # Replace with the ARN of your EC2 instance's IAM role
    }

    actions = [
      "s3:PutObject",
      "s3:GetObject", # Allow reading objects too, useful for verifying or re-processing
      "s3:ListBucket" # Allow listing objects in the bucket
    ]

    resources = [
      aws_s3_bucket.app_logs.arn,
      "${aws_s3_bucket.app_logs.arn}/*",
    ]
  }
}

resource "aws_s3_bucket_policy" "app_logs_policy" {
  bucket = aws_s3_bucket.app_logs.id
  policy = data.aws_iam_policy_document.ec2_write_policy.json
}

variable "ec2_instance_role_arn" {
  description = "The ARN of the IAM role that your EC2 instances assume, which needs write access to the S3 bucket."
  type        = string
}