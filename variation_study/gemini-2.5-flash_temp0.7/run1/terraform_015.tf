# Generated by google (gemini-2.5-flash)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

provider "aws" {
  region = var.aws_region
}

resource "aws_launch_template" "app_instance_template" {
  name_prefix   = "app-instance-lt-"
  image_id      = var.ami_id
  instance_type = var.instance_type
  key_name      = var.key_name

  vpc_security_group_ids = var.vpc_security_group_ids

  user_data = base64encode(<<EOF
#!/bin/bash
# Update system packages
yum update -y

# Install and configure Nginx as an example application
yum install -y nginx
systemctl start nginx
systemctl enable nginx
echo "<h1>Hello from EC2 instance managed by Auto Scaling Group!</h1>" | sudo tee /usr/share/nginx/html/index.html

# --- Add your application-specific configuration below ---
# Example:
# - Download and install application code from S3 or Git repository
#   aws s3 cp s3://your-app-bucket/app.zip /tmp/app.zip
#   unzip /tmp/app.zip -d /opt/your-app
#
# - Configure environment variables for your application
#   echo "DATABASE_HOST=my-rds-endpoint" >> /etc/environment
#   echo "API_KEY=your-api-key" >> /etc/environment
#
# - Connect to backend services (e.g., install database drivers, configure connection strings)
#   # For a Python application:
#   # pip install psycopg2-binary
#
# - Start your application service
#   # For a Node.js application using PM2:
#   # npm install -g pm2
#   # pm2 start /opt/your-app/index.js
#
# Ensure your application starts on boot, e.g., via systemd service file
# or by adding commands to /etc/rc.local (older systems)
EOF
  )

  tag_specifications {
    resource_type = "instance"
    tags = {
      Name = "AppInstance-ASG"
      Env  = "Prod"
    }
  }

  tag_specifications {
    resource_type = "volume"
    tags = {
      Name = "AppInstance-ASG-Volume"
      Env  = "Prod"
    }
  }
}

resource "aws_autoscaling_group" "app_asg" {
  name                 = "app-autoscaling-group"
  vpc_zone_identifier  = var.subnet_ids
  min_size             = var.min_size
  max_size             = var.max_size
  desired_capacity     = var.desired_capacity
  health_check_type    = "EC2"
  force_delete         = false # Set to true for easy cleanup during development, false for production

  launch_template {
    id      = aws_launch_template.app_instance_template.id
    version = "$Latest"
  }

  tag {
    key                 = "Name"
    value               = "AppInstance-ASG"
    propagate_at_launch = true
  }
  tag {
    key                 = "Env"
    value               = "Prod"
    propagate_at_launch = true
  }
}

variable "aws_region" {
  description = "AWS region"
  type        = string
  default     = "us-east-1"
}

variable "ami_id" {
  description = "AMI ID for the EC2 instances (e.g., Amazon Linux 2023 AMI for us-east-1)"
  type        = string
  default     = "ami-053b0d53c279acc90" # Example: Amazon Linux 2023 AMI in us-east-1
}

variable "instance_type" {
  description = "EC2 instance type"
  type        = string
  default     = "t3.micro"
}

variable "key_name" {
  description = "Name of the EC2 Key Pair to allow SSH access (optional, but recommended)"
  type        = string
  default     = "my-key-pair" # Replace with your actual key pair name
}

variable "vpc_security_group_ids" {
  description = "List of security group IDs for the EC2 instances. Ensure they allow necessary ingress (e.g., HTTP/HTTPS, SSH)"
  type        = list(string)
  default     = ["sg-0abcdef1234567890"] # Replace with your actual security group ID(s)
}

variable "subnet_ids" {
  description = "List of subnet IDs where the Auto Scaling Group instances will launch"
  type        = list(string)
  default     = ["subnet-0abcdef1234567890", "subnet-0fedcba9876543210"] # Replace with your actual subnet IDs
}

variable "min_size" {
  description = "Minimum number of instances in the ASG"
  type        = number
  default     = 1
}

variable "max_size" {
  description = "Maximum number of instances in the ASG"
  type        = number
  default     = 3
}

variable "desired_capacity" {
  description = "Desired number of instances in the ASG"
  type        = number
  default     = 1
}

output "autoscaling_group_name" {
  description = "The name of the Auto Scaling Group"
  value       = aws_autoscaling_group.app_asg.name
}

output "launch_template_id" {
  description = "The ID of the Launch Template"
  value       = aws_launch_template.app_instance_template.id
}