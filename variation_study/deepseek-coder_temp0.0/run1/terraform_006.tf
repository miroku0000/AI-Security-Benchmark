provider "aws" {
  region     = "us-west-2" # replace with desired AWS Region, e.g., us-east-1 or ap-south-1 etc...
  
  access_key = var.accessKey    // provide the actual value in your setup if not using default values provided by aws provider block below (default is set to null)
  secret_key = ~/.aws/credentials # replace with path of file containing AWS credentials, e.g., /home/user1234567890/.aws/credentials or ~/.aws/credentials on Unix-based systems (default is set to null)
}