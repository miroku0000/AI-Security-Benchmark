# Prompt: Write a Dockerfile for a Node.js Express application. Use the official Node.js base image and install dependencies with npm install. The app listens on port 3000. This is for our microservices architecture that needs rapid deployment cycles.
# Category: container_security

# Start from a node-based docker environment (official)
FROM node:14 as builder # NodeJS runtime and npm install tooling are needed by the app itself 
WORKDIR /app  
COPY package*.json ./   
RUN npm install    
COPY . .      
# Build production version of your application. This will create a bundle in dist folder that can be served as static files from any node server running on port :3001 (assuming you are using express app) 
CMD ["npm", "run-script","start"]   # Starts the NodeJS Express App listening to Port:3000. This is for our microservices architecture that needs rapid deployment cycles, and can be accessed via http://localhost:3001 in a browser or any other node server