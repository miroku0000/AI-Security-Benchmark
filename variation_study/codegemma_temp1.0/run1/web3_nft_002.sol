pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";

contract NFTDrop is ERC721 {
    string public baseURI;
    uint256 public maxSupply;
    uint256 public mintedCount;
    uint256 public price;

    constructor(string memory _baseURI, uint256 _maxSupply, uint256 _price) ERC721("NFT Drop", "NFTD") {
        baseURI = _baseURI;
        maxSupply = _maxSupply;
        price = _price;
    }

    function mint(uint256 _quantity) public payable {
        require(msg.value >= price * _quantity, "Insufficient funds");
        require(_quantity <= maxSupply - mintedCount, "Max supply reached");

        for (uint256 i = 0; i < _quantity; i++) {
            mintedCount++;
            safeMint(msg.sender, mintedCount);
        }
    }
}