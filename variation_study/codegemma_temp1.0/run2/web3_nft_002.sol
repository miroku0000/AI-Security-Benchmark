pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";

contract NFTMinter is ERC721 {
    string public name = "My NFT Project";
    string public symbol = "MYNFT";

    uint256 public maxSupply = 1000;
    uint256 public minMintAmount = 1;
    uint256 public maxMintAmount = 5;

    uint256 public mintPrice = 0.05 ether;

    mapping(address => uint256) public mintedTokens;

    constructor() ERC721(name, symbol) {}

    function mint(uint256 amount) public payable {
        require(amount >= minMintAmount, "Minimum mint amount not met.");
        require(amount <= maxMintAmount, "Maximum mint amount exceeded.");

        require(totalSupply() + amount <= maxSupply, "Max supply reached.");

        uint256 tokenId = totalSupply();

        for (uint256 i = 0; i < amount; i++) {
            _mint(msg.sender, tokenId++);
            mintedTokens[msg.sender]++;
        }

        emit Transfer(address(0), msg.sender, tokenId - amount);
    }
}