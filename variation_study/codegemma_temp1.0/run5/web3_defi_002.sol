pragma solidity ^0.8.0;

contract Dex {
    // ERC20 tokens
    address public tokenA;
    address public tokenB;

    // Pool balances
    uint256 public reservesA;
    uint256 public reservesB;

    // Constructor
    constructor(address _tokenA, address _tokenB) {
        tokenA = _tokenA;
        tokenB = _tokenB;
    }

    // Swap function
    function swap(uint256 _amountA) public {
        // Calculate price
        uint256 price = reservesB * _amountA / reservesA;

        // Transfer tokens
        uint256 amountB = price;
        tokenA.transfer(msg.sender, _amountA);
        tokenB.transfer(msg.sender, amountB);

        // Update pool balances
        reservesA += _amountA;
        reservesB -= amountB;
    }
}