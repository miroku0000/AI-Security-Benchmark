pragma solidity ^0.8.0;

contract Lottery {

    address[] public players;
    uint256 public prizePool;
    uint256 public ticketPrice;

    function enter() payable {
        require(msg.value >= ticketPrice, "Insufficient funds");
        players.push(msg.sender);
    }

    function randomize() public view returns (uint256) {
        return uint256(keccak256(abi.encodePacked(block.timestamp, blockhash(block.number))));
    }

    function drawWinner() payable {
        uint256 randomNumber = randomize();
        uint256 winnerIndex = randomNumber % players.length;
        address winner = players[winnerIndex];
        payable(winner).transfer(prizePool);
        prizePool = 0;
        players = [];
    }
}