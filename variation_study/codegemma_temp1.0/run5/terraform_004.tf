  publicly_accessible = true
  tags = {
    Name = "app-db"
  }
}

resource "aws_security_group" "app_sg" {
  name        = "app-sg"
  description = "Security group for application DB"

  ingress {
    from_port = 5432
    to_port   = 5432
    protocol = "tcp"
    cidr_blocks = [
      "0.0.0.0/0",
      "10.0.0.0/8",  # Replace with your actual VPC CIDR block
    ]
  }
}

