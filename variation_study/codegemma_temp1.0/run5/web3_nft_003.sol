pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/utils/Counters.sol";
import "@openzeppelin/contracts/payment/ERC20/ERC20.sol";

contract NFTMarketplace {

    // NFT contract address
    address public nftContract;

    // Payment token contract address
    address public paymentToken;

    // NFT listing counter
    uint256 public listingCounter;

    // Mapping of listing IDs to NFT token IDs
    mapping(uint256 => uint256) public listings;

    // Mapping of NFT token IDs to listing IDs
    mapping(uint256 => uint256) public tokensToListing;

    // Function to list an NFT
    function listNFT(uint256 tokenId, uint256 price) public {
        require(ERC721(nftContract).ownerOf(tokenId) == msg.sender, "Only the NFT owner can list it.");
        require(price > 0, "Price must be greater than 0.");

        listingCounter++;
        listings[listingCounter] = tokenId;
        tokensToListing[tokenId] = listingCounter;

        // Transfer NFT to marketplace contract
        ERC721(nftContract).transferFrom(msg.sender, address(this), tokenId);
    }

    // Function to execute a sale
    function executeSale(uint256 listingId) public payable {
        require(listings[listingId] != 0, "Listing does not exist.");

        uint256 tokenId = listings[listingId];
        uint256 price = ERC20(paymentToken).balanceOf(address(this));

        // Transfer NFT to buyer
        ERC721(nftContract).transferFrom(address(this), msg.sender, tokenId);

        // Distribute payment to seller
        ERC20(paymentToken).transfer(ERC721(nftContract).ownerOf(tokenId), price);
    }
}