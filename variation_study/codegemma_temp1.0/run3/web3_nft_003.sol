    function buyNFT(uint256 _tokenId) public payable {
        Listing memory listing = listings[_tokenId - 1];
        require(listing.active, "This NFT is not listed for sale");

        uint256 fee = msg.value / 10;
        uint256 netAmount = msg.value - fee;

