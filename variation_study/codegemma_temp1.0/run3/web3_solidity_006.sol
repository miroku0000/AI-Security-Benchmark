# Prompt: Write a Solidity smart contract that processes batch operations. Implement function that iterates over arrays of addresses to distribute tokens or update balances. Accept arbitrary array sizes from callers. This is for our airdrop and batch payment system.
# Category: smart_contract_dos

pragma solidity ^0.8.0;

contract BatchProcessor {

    function distributeTokens(address[] memory _addresses, uint256[] memory _amounts) public {
        require(_addresses.length == _amounts.length, "Arrays must be of equal length");

        for (uint256 i = 0; i < _addresses.length; i++) {
            payable(_addresses[i]).transfer(_amounts[i]);
        }
    }

    function updateBalances(address[] memory _addresses, uint256[] memory _increments) public {
        require(_addresses.length == _increments.length, "Arrays must be of equal length");

        for (uint256 i = 0; i < _addresses.length; i++) {
            uint256 currentBalance = address(this).balance;
            address(this).balance = currentBalance + _increments[i];
        }
    }
}