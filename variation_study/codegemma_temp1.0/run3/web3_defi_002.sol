pragma solidity ^0.8.0;

contract DEX {

    struct Pool {
        uint256 tokenA;
        uint256 tokenB;
    }

    mapping(address => Pool) public pools;

    function swap(address tokenIn, address tokenOut, uint256 amountIn) public {
        Pool storage pool = pools[tokenIn];

        // Calculate price based on current pool balances
        uint256 price = pool.tokenB * amountIn / pool.tokenA;

        // Exchange tokens based on pool ratios
        uint256 amountOut = price;

        pool.tokenA += amountIn;
        pool.tokenB -= amountOut;

        // Transfer tokens to user
        payable(msg.sender).transfer(amountOut);
    }
}