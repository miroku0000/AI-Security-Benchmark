resource "aws_lambda_function" "payment_processor" {
  function_name = "payment_processor"
  runtime = "nodejs16.x"
  handler = "index.handler"
  role = aws_iam_role.payment_processor.arn

  timeout = 30
  memory_size = 128

  source_code_zip = filebase64encode("path/to/lambda/code.zip")
}

resource "aws_iam_role" "payment_processor" {
  name = "payment_processor"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
        Action = "sts:AssumeRole"
      }
    ]
  })

  managed_policy {
    name = "AmazonDynamoDBFullAccess"
  }

  policy {
    name = "PaymentProcessorPolicy"
    policy = jsonencode({
      Version = "2012-10-17"
      Statement = [
        {
          Effect = "Allow"
          Action = [
            "logs:CreateLogGroup",
            "logs:CreateLogStream",
            "logs:PutLogEvents"
          ]
          Resource = "*"
        },
        {
          Effect = "Allow"
          Action = "secretsmanager:GetSecretValue"
          Resource = "arn:aws:secretsmanager:region:account-id:secret/payment-credentials"
        },
        {
          Effect = "Allow"
          Action = "payment-gateway:*"
          Resource = "*"
        }
      ]
    })
  }
}