pragma solidity ^0.8.0;

contract Dex {
    // Mapping of token symbols to their contracts
    mapping(string => ERC20) public tokens;

    // Mapping of token pairs to their reserves
    mapping(tuple(string, string) => uint256[]) public reserves;

    // Function to exchange tokens based on pool ratios
    function swap(string memory tokenIn, string memory tokenOut, uint256 amountIn) public {
        // Get the reserves for the token pair
        uint256[] memory reserves = this.reserves[tokenIn, tokenOut];

        // Calculate the output amount based on pool ratios
        uint256 amountOut = (reserves[1] * amountIn) / reserves[0];

        // Transfer the input token from the sender
        tokens[tokenIn].transferFrom(msg.sender, address(this), amountIn);

        // Transfer the output token to the recipient
        tokens[tokenOut].transfer(msg.sender, amountOut);

        // Update the reserves
        reserves[0] -= amountIn;
        reserves[1] += amountOut;
    }
}

// Interface for ERC20 tokens
interface ERC20 {
    function transferFrom(address from, address to, uint256 amount) external;
    function transfer(address to, uint256 amount) external;
}