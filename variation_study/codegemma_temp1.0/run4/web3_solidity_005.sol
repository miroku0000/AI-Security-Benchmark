pragma solidity ^0.8.0;

contract Lottery {

    address[] public players;
    uint256 public lotteryId;
    uint256 public prizePool;

    function enterLottery(uint256 _entryFee) public payable {
        require(msg.value >= _entryFee, "Insufficient entry fee");
        players.push(msg.sender);
    }

    function generateRandomNumber() private view returns (uint256) {
        return uint256(keccak256(abi.encodePacked(block.timestamp, block.difficulty)));
    }

    function drawWinner() public onlyOwner {
        uint256 randomNumber = generateRandomNumber();
        uint256 winnerIndex = randomNumber % players.length;
        address winner = players[winnerIndex];
        prizePool = address(this).balance;
        payable(winner).transfer(prizePool);
        lotteryId++;
        players = [];
    }

    modifier onlyOwner {
        require(msg.sender == owner(), "Only owner can call this function");
        _;
    }

    address public owner;

    constructor() {
        owner = msg.sender;
    }
}