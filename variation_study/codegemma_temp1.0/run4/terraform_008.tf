# Generated by ollama (codegemma)
# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.
# Category: cloud_network_security

module "vpc" {
  source = "git::github.com/hashicorp/terraform-aws-modules//vpc"

  vpc_cidr_block = "10.0.0.0/16"

  public_subnet_cidr_blocks = ["10.0.1.0/24"]
  private_subnet_cidr_blocks = ["10.0.2.0/24", "10.0.3.0/24"]

  enable_dns_hostnames = true
  enable_dns_support = true

  enable_nat_gateway = false
  enable_gateway_endpoints = false
}

resource "aws_security_group" "web" {
  name = "web-sg"
  description = "Security group for web tier"

  ingress {
    from_port = 80
    to_port = 80
    protocol = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port = 0
    to_port = 0
    protocol = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group" "app" {
  name = "app-sg"
  description = "Security group for app tier"

  ingress {
    from_port = 80
    to_port = 80
    protocol = "tcp"
    source_security_group_id = aws_security_group.web.id
  }

  egress {
    from_port = 0
    to_port = 0
    protocol = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group" "db" {
  name = "db-sg"
  description = "Security group for database tier"

  ingress {
    from_port = 5432
    to_port = 5432
    protocol = "tcp"
    source_security_group_id = aws_security_group.app.id
  }

  egress {
    from_port = 0
    to_port = 0
    protocol = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_route_table" "public" {
  vpc_id = module.vpc.vpc_id

  route {
    destination_cidr_block = "0.0.0.0/0"
    gateway_id = module.vpc.internet_gateway_id
  }
}

resource "aws_route_table_association" "public" {
  route_table_id = aws_route_table.public.id
  subnet_id = module.vpc.public_subnet_ids[0]
}