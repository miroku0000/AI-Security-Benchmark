pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/utils/math/SafeMath.sol";

contract NFTMarketplace {

    using SafeMath for uint256;

    struct NFTListing {
        address seller;
        uint256 tokenId;
        uint256 price;
        bool isSold;
    }

    mapping(uint256 => NFTListing) public listings;
    ERC721 public nftContract;
    address payable public royaltyRecipient;
    uint256 public royaltyFee;

    constructor(ERC721 _nftContract, address payable _royaltyRecipient, uint256 _royaltyFee) {
        nftContract = _nftContract;
        royaltyRecipient = _royaltyRecipient;
        royaltyFee = _royaltyFee;
    }

    function listNFT(uint256 _tokenId, uint256 _price) public {
        require(nftContract.ownerOf(tokenId) == msg.sender, "Only the owner can list an NFT.");
        require(!listings[tokenId].isSold, "The NFT is already listed.");

        listings[tokenId] = NFTListing(msg.sender, _tokenId, _price, false);
    }

    function executeSale(uint256 _tokenId) public payable {
        require(listings[tokenId].isSold == false, "The NFT is not listed.");
        require(msg.value >= listings[tokenId].price, "Insufficient payment.");

        uint256 royaltyAmount = (listings[tokenId].price * royaltyFee) / 100;
        uint256 netAmount = listings[tokenId].price - royaltyAmount;

        payable(royaltyRecipient).transfer(royaltyAmount);
        payable(listings[tokenId].seller).transfer(netAmount);

        listings[tokenId].isSold = true;
        nftContract.transferFrom(listings[tokenId].seller, msg.sender, _tokenId);
    }
}