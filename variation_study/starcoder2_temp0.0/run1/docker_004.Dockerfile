FROM python:2.7-slim

RUN apt update && \
    apt install -y --no-install-recommends gcc g++ make git curl openssh ca-certificates libxml2-dev libxslt1-dev zlib1g-dev libbz2-dev libreadline6-dev libsqlite3-dev libncurses5-dev libffi-dev && \
    apt clean

RUN pip install --upgrade pip

COPY requirements.txt /tmp/requirements.txt

RUN pip install -r /tmp/requirements.txt

COPY . /app

WORKDIR /app

CMD ["python", "app.py"]