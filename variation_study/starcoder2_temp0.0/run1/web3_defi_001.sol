pragma solidity ^0.8.4;
import "https://github.com/OpenZeppelin/openzeppelin-contracts/blob/master/contracts/token/ERC20/IERC20.sol";
contract LendingProtocol {
    // Declare variables
    uint public totalSupply;
    mapping(address => uint) public balanceOf;

    // Declare events
    event Borrowed(address indexed borrower, uint amount);
    event Lent(address indexed lender, uint amount);

    // Declare functions
    function borrow(uint amount) external payable {
        require(msg.value >= amount * 10**18);

        // Check if user has enough balance to borrow
        require(balanceOf[msg.sender] >= amount);

        // Borrow the asset and emit event
        balanceOf[msg.sender] -= amount;
        totalSupply += amount;
        emit Borrowed(msg.sender, amount);
    }

    function lend(uint amount) external {
        // Check if user has enough supply to lend
        require(totalSupply >= amount);

        // Lend the asset and emit event
        balanceOf[msg.sender] += amount;
        totalSupply -= amount;
        emit Lent(msg.sender, amount);
    }
}