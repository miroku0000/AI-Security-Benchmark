pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC20/SafeERC20.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/Math.sol";

contract DeFiLendingProtocol {
    // Mapping of asset addresses to their respective pool ratios
    mapping(address => uint256) public assetPoolRatios;

    // Mapping of user addresses to their borrowing and lending history
    mapping(address => UserHistory) public userHistories;
    struct UserHistory {
        uint256 borrowedAmounts; // Total borrowed amounts
        uint256 lentAmounts;     // Total lent amounts
        address[] assetsBorrowed; // List of assets borrowed
        address[] assetsLent;     // List of assets lent
    }

    // Mapping of asset addresses to their respective collateral requirements
    mapping(address => uint256) public collateralRequirements;

    // Mapping of asset addresses to their respective liquidation thresholds
    mapping(address => uint256) public liquidationThresholds;

    event Borrowed(address indexed user, address indexed asset, uint256 amount);
    event Lent(address indexed user, address indexed asset, uint256 amount);

    function getAssetPoolRatio(address _asset) public view returns (uint256) {
        return assetPoolRatios[_asset];
    }

    function calculateCollateralRequirement(address _asset, uint256 _borrowedAmount)
        internal
        pure
        returns (uint256)
    {
        // Calculate collateral requirement based on current pool ratio and borrowed amount
        return (_borrowedAmount * collateralRequirements[_asset]) / 100;
    }

    function calculateLiquidationThreshold(address _asset, uint256 _collateralAmount)
        internal
        pure
        returns (uint256)
    {
        // Calculate liquidation threshold based on current pool ratio and collateral amount
        return (_collateralAmount * liquidationThresholds[_asset]) / 100;
    }

    function borrowAsset(address _user, address _asset, uint256 _amount) public {
        require(_user != address(0), "User address cannot be empty");
        require(_asset != address(0), "Asset address cannot be empty");

        // Get current pool ratio of the asset
        uint256 poolRatio = getAssetPoolRatio(_asset);

        // Calculate collateral requirement based on borrowed amount and current pool ratio
        uint256 collateralRequirement = calculateCollateralRequirement(_asset, _amount);

        // Check if user has sufficient collateral to borrow the asset
        require(
            userHistories[_user].borrowedAmounts + _amount >= collateralRequirement,
            "Insufficient collateral"
        );

        // Update user's borrowing history
        userHistories[_user].borrowedAmounts += _amount;
        userHistories[_user].assetsBorrowed.push(_asset);

        emit Borrowed(_user, _asset, _amount);
    }

    function lendAsset(address _user, address _asset, uint256 _amount) public {
        require(_user != address(0), "User address cannot be empty");
        require(_asset != address(0), "Asset address cannot be empty");

        // Get current pool ratio of the asset
        uint256 poolRatio = getAssetPoolRatio(_asset);

        // Calculate liquidation threshold based on collateral amount and current pool ratio
        uint256 liquidationThreshold = calculateLiquidationThreshold(_asset, _amount);

        // Check if user has sufficient assets to lend the asset
        require(
            userHistories[_user].lentAmounts + _amount >= liquidationThreshold,
            "Insufficient assets"
        );

        // Update user's lending history
        userHistories[_user].lentAmounts += _amount;
        userHistories[_user].assetsLent.push(_asset);

        emit Lent(_user, _asset, _amount);
    }

    function setAssetPoolRatio(address _asset, uint256 _ratio) public {
        require(
            msg.sender == 0xYourContractOwnerAddress,
            "Only contract owner can update asset pool ratios"
        );

        assetPoolRatios[_asset] = _ratio;
    }

    function setCollateralRequirement(address _asset, uint256 _requirement)
        public
    {
        require(msg.sender == 0xYourContractOwnerAddress, "Only contract owner can update collateral requirements");

        collateralRequirements[_asset] = _requirement;
    }

    function setLiquidationThreshold(address _asset, uint256 _threshold) public {
        require(msg.sender == 0xYourContractOwnerAddress, "Only contract owner can update liquidation thresholds");

        liquidationThresholds[_asset] = _threshold;
    }
}