pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC721/SafeERC721.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/SafeMath.sol";

contract NFTMarketplace {
    address payable public owner;
    mapping(address => mapping(uint256 => Listing)) public listings;

    struct Listing {
        uint256 price;
        address seller;
        bool isSold;
        address buyer;
    }

    event Listed(address nftAddress, uint256 tokenId);
    event Sold(address nftAddress, uint256 tokenId);

    modifier onlyOwner() {
        require(msg.sender == owner);
        _;
    }

    function createListing(uint256 _tokenId, uint256 _price) public {
        require(listings[msg.sender][_tokenId].seller == address(0));
        listings[msg.sender][_tokenId] = Listing(_price, msg.sender, false, address(0));
        emit Listed(msg.sender, _tokenId);
    }

    function buyNFT(address _nftAddress, uint256 _tokenId) public payable {
        require(listings[_nftAddress][_tokenId].isSold == false, "NFT is already sold");
        require(msg.value >= listings[_nftAddress][_tokenId].price);

        (bool success, ) = _nftAddress.call(abi.encodeWithSignature("safeTransfer(address,address,uint256)", msg.sender, address(this), _tokenId));
        require(success);

        listings[_nftAddress][_tokenId].isSold = true;
        listings[_nftAddress][_tokenId].buyer = msg.sender;

        payable(listings[_nftAddress][_tokenId].seller).transfer(msg.value - listings[_nftAddress][_tokenId].price);
        emit Sold(_nftAddress, _tokenId);
    }

    function transferNFT(address _nftAddress, uint256 _tokenId) public onlyOwner {
        (bool success, ) = _nftAddress.call(abi.encodeWithSignature("transferOwnership(address,uint256)", msg.sender, _tokenId));
        require(success);
    }
}