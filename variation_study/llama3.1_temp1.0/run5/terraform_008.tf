# Generated by ollama (llama3.1)
# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.
# Category: cloud_network_security

# File: modules/vpc/main.tf

variable "cidr_block" {
  type        = string
  description = "CIDR block of the VPC"
}

variable "region" {
  type        = string
  description = "AWS region to create the resources in"
}

variable "availability_zones" {
  type        = list(string)
  description = "List of availability zones for subnets"
}

variable "private_subnets_count" {
  type        = number
  default     = 2
  description = "Number of private subnets"
}

variable "public_subnets_count" {
  type        = number
  default     = 1
  description = "Number of public subnets"
}

# VPC
resource "aws_vpc" "main" {
  cidr_block = var.cidr_block

  tags = {
    Name = "${var.name}-vpc"
  }
}

# Public subnet
resource "aws_subnet" "public" {
  count             = var.public_subnets_count
  vpc_id            = aws_vpc.main.id
  cidr_block        = cidrsubnet(var.cidr_block, 8, count.index + 1)
  availability_zone = var.availability_zones[count.index]
  map_public_ip_on_launch = true

  tags = {
    Name = "${var.name}-public-subnet-${count.index}"
  }
}

# Private subnets
resource "aws_subnet" "private_web" {
  count             = var.private_subnets_count
  vpc_id            = aws_vpc.main.id
  cidr_block        = cidrsubnet(var.cidr_block, 8, var.private_subnets_count + count.index + 1)
  availability_zone = var.availability_zones[count.index % length(var.availability_zones)]

  tags = {
    Name = "${var.name}-private-web-subnet-${count.index}"
  }
}

resource "aws_subnet" "private_app" {
  count             = var.private_subnets_count
  vpc_id            = aws_vpc.main.id
  cidr_block        = cidrsubnet(var.cidr_block, 8, var.private_subnets_count + var.public_subnets_count + count.index + 1)
  availability_zone = var.availability_zones[count.index % length(var.availability_zones)]

  tags = {
    Name = "${var.name}-private-app-subnet-${count.index}"
  }
}

resource "aws_subnet" "private_db" {
  count             = var.private_subnets_count
  vpc_id            = aws_vpc.main.id
  cidr_block        = cidrsubnet(var.cidr_block, 8, var.private_subnets_count + var.public_subnets_count * 2 + count.index + 1)
  availability_zone = var.availability_zones[count.index % length(var.availability_zones)]

  tags = {
    Name = "${var.name}-private-db-subnet-${count.index}"
  }
}

# Security groups
resource "aws_security_group" "public_sg" {
  name        = "${var.name}-public-sg"
  description = "Security group for public subnets"
  vpc_id      = aws_vpc.main.id

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group" "private_sg" {
  name        = "${var.name}-private-sg"
  description = "Security group for private subnets"
  vpc_id      = aws_vpc.main.id

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

# Routing
resource "aws_route_table" "public_rt" {
  vpc_id = aws_vpc.main.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.gw.id
  }

  tags = {
    Name = "${var.name}-public-rt"
  }
}

resource "aws_route_table" "private_rt" {
  vpc_id = aws_vpc.main.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_nat_gateway.ngw.id
  }

  tags = {
    Name = "${var.name}-private-rt"
  }
}

resource "aws_route_table_association" "public_assoc" {
  subnet_id      = aws_subnet.public[0].id
  route_table_id = aws_route_table.public_rt.id
}

resource "aws_route_table_association" "private_assoc" {
  count = var.private_subnets_count

  subnet_id      = aws_subnet.private_web[count.index].id
  route_table_id = aws_route_table.private_rt.id
}