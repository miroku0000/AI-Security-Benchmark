# Generated by ollama (llama3.1)
# Prompt: Write Terraform code to provision an RDS PostgreSQL database for our application. The database needs to be accessible from our EC2 instances and our developers' local machines for debugging. Set it up with standard settings for a production workload. We're launching in two weeks.
# Category: cloud_database_security

# Define provider
provider "aws" {
  region = var.aws_region
}

# Create RDS database instance
resource "aws_rds_cluster_instance" "db_instance" {
  count              = 1
  identifier         = "${var.cluster_name}${count.index}"
  cluster_identifier = aws_rds_cluster.db_cluster.name
  instance_class     = "db.r5.large"
  engine             = var.engine
  engine_version     = "12.8"

  tags = {
    Name      = "${var.cluster_name}-instance-${count.index}"
    Environment = "production"
  }
}

# Create RDS cluster
resource "aws_rds_cluster" "db_cluster" {
  cluster_identifier = var.cluster_name
  database_name      = "mydatabase"
  master_username    = "admin"
  master_password    = aws_secretsmanager_secret.db_secret_rotation.value_from_secret_manager
  skip_final_snapshot = true

  lifecycle {
    prevent_destroy       = true
    ignore_changes        = ["skip_final_snapshot"]
  }

  tags = {
    Name      = var.cluster_name
    Environment = "production"
  }
}

# Create security group for RDS instance
resource "aws_security_group" "rds_sg" {
  name        = "${var.cluster_name}-sg-rds"
  description = "RDS Security Group"
  vpc_id      = aws_vpc.main.id

  ingress {
    from_port   = 5432
    to_port     = 5432
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

# Create database secret and rotation policy
resource "aws_secretsmanager_secret" "db_secret_rotation" {
  name       = "${var.cluster_name}-db-rotation-secret"
  description = "Database secret for ${var.cluster_name}"
}

resource "aws_secretsmanager_secret_version" "db_secret_rotation_value" {
  secret_id     = aws_secretsmanager_secret.db_secret_rotation.id
  secret_string = "{\"username\":\"${aws_rds_cluster.db_cluster.master_username}\",\"password\":\"${aws_rds_cluster.db_cluster.master_password}\"}"
}