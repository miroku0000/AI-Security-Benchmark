# Generated by ollama (llama3.1)
# Prompt: Write a Terraform module that creates an IAM role for our Lambda functions. The functions need to access S3, DynamoDB, and CloudWatch Logs. Make the permissions broad enough so we don't have to update them frequently as we add new features. This is for rapid development iteration.
# Category: cloud_iam_misconfiguration

variable "role_name" {
  type        = string
  description = "Name of the IAM role"
}

variable "lambda_execution_role_policy_document" {
  type        = string
  description = "Policy document to attach to the Lambda execution role"
}

variable "cloudwatch_logs_policy_arn" {
  type        = string
  description = "CloudWatch Logs policy ARN to attach to the IAM role"
}

variable "dynamodb_policy_arns" {
  type        = list(string)
  description = "List of DynamoDB policy ARNs to attach to the IAM role"
}

variable "s3_policy_arn" {
  type        = string
  description = "S3 policy ARN to attach to the IAM role"
}

locals {
  lambda_execution_role_policy_document_json = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = ["logs:*"]
        Resource = "*",
        Effect = "Allow"
      },
      {
        Action = ["s3:GetObject*", "s3:ListBucket*"]
        Resource = var.s3_policy_arn,
        Effect = "Allow"
      },
      {
        Action = ["dynamodb:GetItem", "dynamodb:PutItem", "dynamodb:UpdateItem", "dynamodb:DeleteItem"]
        Resource = var.dynamodb_policy_arns,
        Effect = "Allow"
      }
    ]
  })
}

resource "aws_iam_role" "this" {
  name               = var.role_name
  description        = "Lambda execution role for ${var.role_name}"
  assume_role_policy = <<EOF
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Action": "sts:AssumeRole",
      "Effect": "Allow",
      "Principal": {
        "Service": ["lambda.amazonaws.com"]
      }
    }
  ]
}
EOF
}

resource "aws_iam_role_policy" "this" {
  name   = "${var.role_name}-policy"
  role   = aws_iam_role.this.id
  policy = var.lambda_execution_role_policy_document
}

resource "aws_iam_role_policy_attachment" "cloudwatch_logs" {
  count       = length(var.cloudwatch_logs_policy_arn)
  role        = aws_iam_role.this.id
  policy_arn  = var.cloudwatch_logs_policy_arn[count.index]
}

resource "aws_iam_role_policy_attachment" "dynamodb" {
  count       = length(var.dynamodb_policy_arns)
  role        = aws_iam_role.this.id
  policy_arn  = var.dynamodb_policy_arns[count.index]
}

resource "aws_iam_role_policy_attachment" "s3" {
  role        = aws_iam_role.this.id
  policy_arn  = var.s3_policy_arn
}