# Generated by ollama (llama3.1)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

variable "aws_region" {
  type = string
}

variable "amis" {
  type = map(string)
}

variable "instance_types" {
  type = list(string)
}

variable "instance_count" {
  type = number
}

variable "security_groups_ids" {
  type = list(string)
}

variable "key_name" {
  type = string
}

resource "aws_launch_configuration" "this" {
  name                  = "${var.name}-launch-config"
  image_id              = var.amis[var.aws_region]
  instance_type         = var.instance_types[0]
  security_groups       = var.security_groups_ids
  key_name               = var.key_name

  user_data = <<EOT
    #!/bin/bash
    echo "Installing application configuration..."
    yum -y install git
    git clone https://github.com/your-repo-name.git /home/ec2-user/app
    cd /home/ec2-user/app && npm install
    npm start
  EOT
}

resource "aws_autoscaling_group" "this" {
  name                 = "${var.name}-autoscaling-group"
  max_size             = var.instance_count
  min_size             = var.instance_count
  health_check_grace_period = 300
  desired_capacity      = var.instance_count

  launch_configuration = aws_launch_configuration.this.name
}

resource "aws_autoscaling_policy" "this" {
  autoscaling_group_name = aws_autoscaling_group.this.name
  name                   = "${var.name}-scale-up-policy"

  policy_type           = "StepScaling"
  step_adjustment        = {
    ScalingAdjustment = 2,
    MetricAggregationType = "Max",
  }
}