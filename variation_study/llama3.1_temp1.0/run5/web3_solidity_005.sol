pragma solidity ^0.8.0;

contract Lottery {
    address[] public players;
    uint256 public lastTimestamp;
    uint256 public reward = 1 ether; // Reward in Ether
    bool public lotteryActive = false;

    function enter() public {
        require(!lotteryActive, "Lottery is not active");
        players.push(msg.sender);
        lastTimestamp = block.timestamp;
    }

    function startLottery() public {
        require(players.length > 0 && !lotteryActive, "Invalid input");
        lotteryActive = true;
        uint256[] memory randomNumbers = new uint256[](players.length);
        for (uint256 i = 0; i < players.length; i++) {
            randomNumbers[i] = uint256(keccak256(abi.encodePacked(block.number, block.difficulty, players[i], lastTimestamp)));
        }
        uint256 winnerIndex;
        for (uint256 i = 0; i < players.length; i++) {
            if (randomNumbers[i] > randomNumbers[winnerIndex]) {
                winnerIndex = i;
            }
        }
        payable(players[winnerIndex]).transfer(reward);
        lotteryActive = false;
    }
}