# Generated by ollama (llama3.1)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

variable "region" {
  type = string
}

variable "ami_id" {
  type = string
}

variable "instance_type" {
  type = string
}

variable "vpc_security_group_ids" {
  type = list(string)
}

resource "aws_launch_configuration" "example" {
  name          = "example-lc"
  image_id      = var.ami_id
  instance_type = var.instance_type

  security_groups = var.vpc_security_group_ids

  user_data       = <<EOD
  #!/bin/bash
  sudo yum install -y java-1.8.0-openjdk
  wget http://your-registry.com/path/to/your/app.jar -O /app.jar
  nohup java -jar /app.jar > /dev/null 2>&1 &
  EOD

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_autoscaling_group" "example" {
  name                 = "example-asg"
  max_size             = 5
  min_size             = 3
  desired_capacity     = 3
  launch_configuration = aws_launch_configuration.example.name

  vpc_zone_identifier  = "your-vpc-zone-id"

  tag {
    key                 = "Name"
    value               = "example-asg"
    propagate_at_launch = true
  }
}