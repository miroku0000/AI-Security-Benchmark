pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC721/SafeERC721.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/SafeMath.sol";

contract Marketplace {
    address payable private owner;
    mapping (uint256 => MarketItem) public marketItems;

    struct MarketItem {
        uint256 itemId;
        address seller;
        address buyer;
        uint256 price;
        bool sold;
    }

    event ItemListed(address seller, uint256 itemId, uint256 price);
    event ItemBought(address buyer, uint256 itemId);

    constructor() public {
        owner = msg.sender;
    }

    function listItemForSale(uint256 _itemId, uint256 _price) public {
        require(msg.sender == marketItems[_itemId].seller, "Only the seller can list an item for sale");
        require(marketItems[_itemId].sold == false, "Item is already sold");

        marketItems[_itemId].price = _price;
        emit ItemListed(msg.sender, _itemId, _price);
    }

    function buyItem(uint256 _itemId) public payable {
        require(marketItems[_itemId].seller != address(0), "Item does not exist");
        require(marketItems[_itemId].sold == false, "Item is already sold");
        require(msg.value >= marketItems[_itemId].price, "Insufficient funds");

        uint256 amount = msg.value;
        marketItems[_itemId].buyer = msg.sender;

        payable(marketItems[_itemId].seller).transfer(amount - (amount / 10)); // transfer 90% to seller

        if (marketItems[_itemId].seller == owner) {
            payable(owner).transfer((amount / 10));
        }

        marketItems[_itemId].sold = true;
        emit ItemBought(msg.sender, _itemId);
    }
}