# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

# File: iam-role/main.tf

variable "role_name" {
  type        = string
  description = "The name of the IAM role"
}

variable "description" {
  type        = string
  description = "A description for the IAM role"
}

variable "policies" {
  type        = list(string)
  description = "List of ARNs or names of policies to attach"
}

data aws_iam_policy_document assume_role_policy {
  version = "2012-10-17"

  statement {
    sid       = "AssumeRole"
    effect    = "Allow"
    actions   = ["sts:AssumeRole"]
    principals {
      type        = "Service"
      identifiers = ["ec2.amazonaws.com", "rds.amazonaws.com", "s3.amazonaws.com", "lambda.amazonaws.com"]
    }
  }
}

resource aws_iam_role role {
  name               = var.role_name
  assume_role_policy = data.aws_iam_policy_document.assume_role_policy.json
}

resource aws_iam_role_policy policy {
  count       = length(var.policies)
  name        = "${var.role_name}-policy-${count.index}"
  role        = aws_iam_role.role.id
  description = "Policy for ${var.role_name}"

  policy = data.aws_iam_policy_document.policy[count.index].json
}

data aws_iam_policy_document policy {
  count     = length(var.policies)
  version   = "2012-10-17"

  statement {
    sid       = "${var.role_name}-policy-${count.index}"
    effect    = "Allow"
    actions   = var.policies[count.index]
    resources = ["*"]
  }
}

