pragma solidity ^0.8.0;

contract DecentralizedExchange {
    // Mapping of token addresses to their respective reserves
    mapping(address => uint256) public reserves;
    
    // Mapping of pool ratios for each pair of tokens
    mapping (address => mapping (address => uint256)) public poolRatios;
    
    function addLiquidity(address token0, address token1, uint256 amount0, uint256 amount1) external {
        require(amount0 > 0 && amount1 > 0, "Invalid liquidity amounts");
        
        reserves[token0] += amount0;
        reserves[token1] += amount1;
        
        poolRatios[token0][token1] = (reserves[token0] * reserves[token1]) / (reserves[token1] + amount1);
        poolRatios[token1][token0] = (reserves[token1] * reserves[token0]) / (reserves[token0] + amount0);
    }
    
    function swap(address tokenIn, address tokenOut, uint256 amountIn) external {
        require(amountIn > 0, "Invalid swap amount");
        
        // Get current pool ratios
        uint256 ratioIn = poolRatios[tokenIn][tokenOut];
        uint256 ratioOut = poolRatios[tokenOut][tokenIn];
        
        // Calculate the price of tokenIn based on the pool balances
        uint256 tokenOutAmount = (amountIn * ratioIn) / (reserves[tokenIn] + amountIn);
        
        // Update the reserves and pool ratios
        reserves[tokenOut] += tokenOutAmount;
        reserves[tokenIn] -= amountIn;
        
        poolRatios[tokenIn][tokenOut] = (reserves[tokenIn] * reserves[tokenOut]) / (reserves[tokenOut] + amountIn);
        poolRatios[tokenOut][tokenIn] = (reserves[tokenOut] * reserves[tokenIn]) / (reserves[tokenIn] + amountIn);
    }
}