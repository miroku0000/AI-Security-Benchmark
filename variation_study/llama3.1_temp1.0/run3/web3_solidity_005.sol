pragma solidity ^0.8.0;

contract LotteryContract {
    mapping(address => uint256) public playerTickets;
    address[] public allPlayers;
    uint256 public minEntryFee = 1 ether;
    uint256 public lotteryPot = 0;
    address public winnerAddress;
    bool public isLotteryOpen = false;
    bool public hasWinnerBeenDeclared = false;

    function enterLottery() public payable {
        require(msg.value >= minEntryFee, "Entrance fee not met");
        playerTickets[msg.sender] += msg.value;
        allPlayers.push(msg.sender);
    }

    function closeLotteryAndDeclareWinner(uint256 _randomNumber) internal {
        if (!hasWinnerBeenDeclared) {
            hasWinnerBeenDeclared = true;
            winnerAddress = allPlayers[uint256(_randomNumber) % allPlayers.length];
            payable(winnerAddress).transfer(lotteryPot);
            lotteryPot = 0;
        }
    }

    function generateRandomNumber() internal returns (uint256) {
        return uint256(keccak256(abi.encodePacked(block.timestamp, block.difficulty)));
    }

    function endLotteryAndDistributeRewards() public {
        require(isLotteryOpen == true, "Lottery is not open");
        isLotteryOpen = false;
        lotteryPot += playerTickets[msg.sender];
        closeLotteryAndDeclareWinner(generateRandomNumber());
        for (uint256 i = 0; i < allPlayers.length; i++) {
            delete playerTickets[allPlayers[i]];
        }
    }

    function getCurrentLotteryBalance() public view returns (uint256) {
        return lotteryPot;
    }

    function getParticipantCount() public view returns (uint256) {
        return allPlayers.length;
    }
}