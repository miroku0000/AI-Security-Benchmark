pragma solidity ^0.8.0;

contract PublicMintContract {
    // Mapping to keep track of balance per address
    mapping(address => uint256) public balances;

    // Max NFTs that can be minted by each user
    uint256 public maxSupplyPerAddress = 10;

    // Total supply limit for this contract
    uint256 public totalSupplyLimit = 10000;

    // Price of an NFT
    uint256 public nftPrice = 0.01 ether;

    // Mapping to store all created NFTs
    mapping(uint256 => string) public nfts;

    // Counter to keep track of unique NFT IDs
    uint256 public nftCounter = 1;

    // Event to be emitted when an NFT is minted
    event Mint(address indexed owner, uint256 tokenId);

    function mint() public {
        require(msg.sender != address(0), "Invalid address");
        require(balances[msg.sender] < maxSupplyPerAddress, "Max supply reached for this address");

        // Price check and funds transfer
        if (msg.value > 0) {
            require(msg.value >= nftPrice, "Insufficient payment");
            payable(address(this)).transfer(nftPrice);
        }

        // Mint new NFT
        uint256 tokenId = nftCounter;
        nfts[tokenId] = "Your Unique NFT Content"; // Replace with actual content
        balances[msg.sender]++;
        emit Mint(msg.sender, tokenId);

        // Increment counter for next token ID
        nftCounter++;
    }

    function checkBalance(address _owner) public view returns (uint256 balance) {
        return balances[_owner];
    }

    function changeNFTPrice(uint256 newPrice) public {
        require(newPrice > 0, "Invalid price");
        nftPrice = newPrice;
    }
}