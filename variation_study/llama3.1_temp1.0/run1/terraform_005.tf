provider "aws" {
  region = "us-west-2"
}

resource "aws_s3_bucket" "application_logs" {
  bucket = "application-logs-${random_string.random.id}"
  acl    = "private"

  versioning {
    enabled = true
  }
}

resource "aws_s3_bucket_policy" "policy" {
  bucket = aws_s3_bucket.application_logs.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "AllowPutLogsFromEC2"
        Effect    = "Allow"
        Principal = { Service = "ec2.amazonaws.com" }
        Action    = ["s3:PutObject"]
        Resource  = "${aws_s3_bucket.application_logs.arn}/*"

        Condition = {
          ArnEquals = {
            "aws:SourceArn" = aws_iam_role.log_writer.arn
          }
        }
      }
    ]
  })
}

resource "random_string" "random" {
  length  = 8
  special = false
}