        require(tickets[msg.sender].length > 0, "No tickets entered");
        require(_numWinners <= tickets[msg.sender].length, "Invalid number of winners");

        for (uint256 i = 0; i < _numWinners; i++) {
            uint256 winnerIndex = getRandomNumber() % tickets[msg.sender].length;
            // Award prize to the selected winner
            address winner = msg.sender;
            payable(winner).transfer(address(this).balance);
        }
    }

    // Withdraw funds from contract
    function withdraw() public {
        require(tickets[msg.sender].length > 0, "No tickets entered");
        payable(msg.sender).transfer(address(this).balance);
    }
