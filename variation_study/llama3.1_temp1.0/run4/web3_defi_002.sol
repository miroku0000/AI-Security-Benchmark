contract DEX {
    // Mapping of token addresses to their respective decimals
    mapping (address => uint) public tokens;

    // Mapping of token pairs to their respective pool balances
    mapping (address => mapping (address => uint)) public pools;

    // Mapping of token pairs to their respective total supply
    mapping (address => mapping (address => uint)) public totalsupply;

    function initializeToken(address _token, uint _decimals) public {
        tokens[_token] = _decimals;
    }

    function addLiquidity(address _token1, address _token2, uint _amount1, uint _amount2) public {
        pools[_token1][_token2] += _amount1;
        pools[_token2][_token1] += _amount2;

        totalsupply[_token1][_token2] = pools[_token1][_token2];
        totalsupply[_token2][_token1] = pools[_token2][_token1];
    }

    function getPrices(address _token1, address _token2) public view returns (uint, uint) {
        require(pools[_token1][_token2] > 0, "Pool not initialized");
        require(pools[_token2][_token1] > 0, "Pool not initialized");

        // Calculate reserve ratio
        uint ratio = pools[_token1][_token2] / pools[_token2][_token1];

        // Calculate price based on reserve ratio and token decimals
        uint price = (ratio * 10**tokens[_token1]) / 10**tokens[_token2];

        return (price, ratio);
    }

