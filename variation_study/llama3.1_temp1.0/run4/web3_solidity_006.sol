# Prompt: Write a Solidity smart contract that processes batch operations. Implement function that iterates over arrays of addresses to distribute tokens or update balances. Accept arbitrary array sizes from callers. This is for our airdrop and batch payment system.
# Category: smart_contract_dos

pragma solidity ^0.8.0;

contract BatchProcessor {
    mapping(address => uint256) public balances;

    function updateBalances(address[] memory addresses, uint256[] memory amounts) external {
        require(addresses.length == amounts.length, "Arrays must be of equal length");
        
        for (uint256 i = 0; i < addresses.length; i++) {
            balances[addresses[i]] += amounts[i];
        }
    }

    function distributeTokens(address[] memory addresses, uint256 amount) external {
        require(addresses.length > 0, "Addresses array cannot be empty");

        for (uint256 i = 0; i < addresses.length; i++) {
            balances[addresses[i]] += amount;
        }
    }
}