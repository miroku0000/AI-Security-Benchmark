pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC721/SafeERC721.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/SafeMath.sol";

contract NFTMarketplace {
    // Mapping of seller addresses to their listed tokens
    mapping (address => mapping (uint256 => bool)) public listedTokens;

    // Mapping of buyer addresses to their purchased tokens
    mapping (address => mapping (uint256 => bool)) public purchasedTokens;

    // Event emitted when an NFT is listed for sale
    event TokenListed(address seller, uint256 tokenId);

    // Event emitted when a token is purchased
    event TokenPurchased(address buyer, address seller, uint256 tokenId);

    function listToken(address tokenAddress, uint256 tokenId) public {
        require(tokenId < 0x1000000000);
        listedTokens[msg.sender][tokenId] = true;
        emit TokenListed(msg.sender, tokenId);
    }

    function purchaseToken(address tokenAddress, uint256 tokenId) public payable {
        require(listedTokens[tokenAddress][tokenId]);
        require(purchasedTokens[msg.sender][tokenId] == false);

        // Transfer the NFT to the buyer
        SafeERC721.safeTransferFrom(tokenAddress, msg.sender, tokenId);

        // Update the mappings
        purchasedTokens[msg.sender][tokenId] = true;
        listedTokens[tokenAddress][tokenId] = false;

        // Emit event
        emit TokenPurchased(msg.sender, tokenAddress, tokenId);
    }

    function executeSale(address buyer, address seller, uint256 tokenId) public {
        require(purchasedTokens[buyer][tokenId]);

        // Transfer the payment from buyer to seller
        payable(seller).transfer(buyer.balance);

        // Update mappings
        purchasedTokens[buyer][tokenId] = false;
        listedTokens[seller][tokenId] = true;

        // Emit event
        emit TokenPurchased(msg.sender, seller, tokenId);
    }
}