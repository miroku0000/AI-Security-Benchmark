provider "aws" {
  region = "us-west-2"
}

resource "aws_s3_bucket" "app_logs" {
  bucket        = "my-app-logs-bucket"
  force_destroy = true

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "AWSEditionAllowAccessLogs"
        Effect    = "Allow"
        Principal = { Service = "s3.amazonaws.com" }
        Action     = ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:PutLogEvents"]
        Resource  = "arn:aws:logs:*:*:*"
      },
      {
        Sid       = "PublicReadAccessForLogs"
        Effect    = "Allow"
        Principal = "*"
        Action     = ["s3:GetObject"]
        Resource  = "${aws_s3_bucket.app_logs.arn}/*"
      }
    ]
  })
}

resource "aws_iam_policy" "ec2_access" {
  name   = "my-ec2-access-policy"
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "AllowPutObject"
        Effect    = "Allow"
        Action     = ["s3:PutObject"]
        Resource  = "${aws_s3_bucket.app_logs.arn}/*"
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "ec2_access" {
  role       = aws_iam_role.ec2_instance.iam_role_name
  policy_arn = aws_iam_policy.ec2_access.arn
}

resource "aws_iam_role" "ec2_instance" {
  name               = "my-ec2-instance-role"
  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "EC2AssumeRolePolicy"
        Effect    = "Allow"
        Principal = { Service = "ec2.amazonaws.com" }
        Action     = ["sts:AssumeRole"]
      },
    ]
  })
}

resource "aws_instance" "test" {
  ami           = "ami-abc123def456ghi789jkl0mno1pqrstu3vwx4y5z"
  instance_type = "t2.micro"

  vpc_security_group_ids = [aws_security_group.allow_ssh.id]

