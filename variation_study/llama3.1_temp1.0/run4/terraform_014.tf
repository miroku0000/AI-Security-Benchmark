# Generated by ollama (llama3.1)
# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.
# Category: cloud_network_security

variable "web_sg_name" {
  type        = string
  description = "Name of the web server security group"
}

variable "vpc_id" {
  type        = string
  description = "ID of the VPC where the security group is located"
}

resource "aws_security_group" "web_server" {
  name        = var.web_sg_name
  description = "Security group for web application traffic"
  vpc_id      = var.vpc_id

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

output "web_sg_id" {
  value       = aws_security_group.web_server.id
  description = "ID of the web server security group"
}