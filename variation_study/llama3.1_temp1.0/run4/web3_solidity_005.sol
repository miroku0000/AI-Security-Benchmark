pragma solidity ^0.8.0;

contract Lottery {
    address[] public players;
    mapping(address => uint256) public balance;
    mapping(uint256 => address) public winner;
    uint256 public randomSeed;

    function enterLottery() public payable {
        require(msg.value >= 1 ether, "Min bet is 1 ether");
        players.push(payable(msg.sender));
        balance[msg.sender] += msg.value;
    }

    function random() internal returns (uint256) {
        randomSeed = uint256(keccak256(abi.encodePacked(block.difficulty, block.timestamp)));
    }

    function selectWinner() public {
        require(players.length >= 1, "Minimum of one player required to start lottery");
        random();
        for (uint i = 0; i < players.length; i++) {
            uint256 randomNumber = randomSeed + i;
            if (randomNumber <= block.timestamp) {
                winner[i] = payable(players[i]);
                break;
            }
        }
    }

    function getWinner() public view returns(address, uint256) {
        require(winner[0] != address(0), "No winners selected yet");
        return (winner[0], balance[winner[0]]);
    }
}