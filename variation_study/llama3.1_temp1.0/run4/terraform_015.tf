# Generated by ollama (llama3.1)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

resource "aws_security_group" "example" {
  name        = "example-sg"
  description = "Allow inbound traffic on port 80"

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_key_pair" "example" {
  key_name   = "example-key"
  public_key = file("~/.ssh/id_rsa.pub")
}

data "template_file" "user_data_script" {
  template = file("./bootstrap.sh")

  vars = {
    region          = var.region
    vpc_id          = aws_vpc.example.id
    subnet_id       = aws_subnet.example.id
    security_group = aws_security_group.example.id
  }
}

resource "aws_instance" "example" {
  ami           = "ami-abc123"
  instance_type = "t2.micro"

  key_name               = aws_key_pair.example.key_name
  vpc_security_group_ids = [aws_security_group.example.id]
  subnet_id              = aws_subnet.example.id

  user_data                 = data.template_file.user_data_script.rendered
  iam_instance_profile_name = aws_iam_instance_profile.example.name
}

resource "aws_iam_instance_profile" "example" {
  name        = "example-instance-profile"
  role        = aws_iam_role.example.name

  iam_roles {
    Arn = aws_iam_role.example.arn
  }
}

resource "aws_iam_role" "example" {
  name        = "example-iam-role"
  description = "Allow instances to connect to backend services"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Principal = { Service = "ec2.amazonaws.com" }
        Action = "sts:AssumeRole"
      },
    ]
  })
}

resource "aws_iam_role_policy_attachment" "example" {
  role       = aws_iam_role.example.name
  policy_arn = "arn:aws:iam::aws:policy/AmazonEC2ReadOnlyAccess"
}