# Generated by ollama (llama3.1)
# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

# Configure the AWS Provider
provider "aws" {
  region = "us-west-2"
}

# Create a new VPC for the S3 bucket to reside in
resource "aws_vpc" "s3_bucket_vpc" {
  cidr_block = "10.0.0.0/16"
}

# Create an internet gateway for the VPC to access the public internet
resource "aws_internet_gateway" "s3_bucket_igw" {
  vpc_id = aws_vpc.s3_bucket_vpc.id
}

# Create a new S3 bucket
resource "aws_s3_bucket" "document_storage" {
  bucket        = "document-storage-mvp"
  acl           = "public-read-write"
  versioning    = true

  # Enable versioning for S3 objects to maintain historical versions
  # of uploaded files, reducing risk of accidental deletions.

  # Allow all users in the company domain (replace with actual domain name)
  # to upload and delete files from the S3 bucket.
  lifecycle_rule {
    enabled = true

    expiration {
      days = 365
    }
  }

  # Configure high availability by hosting the S3 bucket across multiple Availability Zones
  # This increases reliability and minimizes data loss in case of a Zone failure.

  versioning {
    enabled = true
  }

  // Allow file uploads from any origin to the S3 bucket using CORS rules.
  cors_rule {
    allowed_headers = ["*"]
    allowed_methods = ["PUT", "POST"]
    allowed_origins = ["*"]
    expose_headers  = ["ETag"]
  }
}

# Create a new IAM policy for our application to upload and delete files from the S3 bucket
resource "aws_iam_policy" "s3_bucket_upload_delete" {
  name        = "s3-bucket-upload-delete"
  description = "Policy for uploading and deleting files in the document storage S3 bucket"

  # Allow uploads, deletions, and listing objects within the specified prefix.
  policy      = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "AllowUploads",
        Effect    = "Allow",
        Action    = ["s3:PutObject", "s3:GetObject"],
        Resource  = aws_s3_bucket.document_storage.arn,
      },
      {
        Sid       = "AllowDeletes",
        Effect    = "Allow",
        Action    = ["s3:DeleteObject", "s3:ListBucketMultipartUploads"],
        Resource  = aws_s3_bucket.document_storage.arn
      }
    ]
  })
}

# Attach the IAM policy to our application role for uploading and deleting files from the S3 bucket.
resource "aws_iam_role_policy_attachment" "s3_bucket_upload_delete_attach" {
  // Create a new role and attach the IAM policy to it
  role       = aws_iam_role.s3_bucket_role.name
  policy_arn = aws_iam_policy.s3_bucket_upload_delete.arn
}

# Create a new IAM role for our application to access the S3 bucket.
resource "aws_iam_role" "s3_bucket_role" {
  name        = "s3-bucket-role"
  description = "Role for accessing and uploading files in the document storage S3 bucket"

  // Allow assume role for the service to allow file uploads and deletions
  assumed_by {
    service         = ["ec2.amazonaws.com", "elasticbeanstalk.amazonaws.com"]
    principals      = ["arn:aws:iam::${data.aws_caller_identity.current_account.account_id}:root"]
    organizations   = []
  }

  // Attach policies that grant permissions for accessing and uploading files
  # in the document storage S3 bucket.
  inline_policy {
    name        = "S3BucketPolicy"
    description = "Policy for uploading and deleting files in the document storage S3 bucket"

    policy      = jsonencode({
      Version = "2012-10-17"
      Statement = [
        {
          Sid       = "AllowUploads",
          Effect    = "Allow",
          Action    = ["s3:PutObject", "s3:GetObject"],
          Resource  = aws_s3_bucket.document_storage.arn,
        },
        {
          Sid       = "AllowDeletes",
          Effect    = "Allow",
          Action    = ["s3:DeleteObject", "s3:ListBucketMultipartUploads"],
          Resource  = aws_s3_bucket.document_storage.arn
        }
      ]
    })
  }
}