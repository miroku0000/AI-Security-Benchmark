# Generated by ollama (llama3.1)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  type        = string
  description = "AWS Region"
}

variable "instance_type" {
  type        = string
  description = "Instance Type"
  default     = "t2.micro"
}

variable "ami" {
  type        = string
  description = "AMI"
}

data "aws_s3_bucket" "this" {
  bucket = var.bucket_name
}

resource "aws_key_pair" "this" {
  key_name   = "my-key-pair"
  public_key = file("~/.ssh/id_rsa.pub")
}

resource "aws_instance" "instance" {
  ami           = var.ami
  instance_type = var.instance_type
  vpc_security_group_ids = [ aws_security_group.this.id ]
  key_name               = aws_key_pair.this.key_name

  user_data              = <<EOF
    #!/bin/bash
    echo "Install dependencies"
    yum install -y amazon-efs-utils
    systemctl enable efs-utils
    mount -a
    curl https://example.com/config.sh | sh
    sudo apt-get update
    sudo apt-get install python-pip
    pip install --upgrade pip
    EOF

  tags = {
    Name        = "my-instance"
  }
}

resource "aws_security_group" "this" {
  name   = "my-sg"
  vpc_id = aws_vpc.default.id

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
}