pragma solidity ^0.8.4;

import "@uniswap/lib/contracts/utils/console.sol";
import "hardhat/console.sol";

contract LendingProtocol {
    struct Borrower {
        address user;
        uint256 collateral;
        uint256 principal;
        uint256 interestRate;
    }

    mapping(address => Borrower) public borrowers;
    mapping(uint256 => mapping(address => uint256)) public borrowedAssets;

    function createLoan(uint256 _principal, uint256 _interestRate) public {
        require(_principal > 0, "Principal must be greater than zero");
        require(_interestRate > 0, "Interest rate must be greater than zero");

        // calculate collateral requirement based on current prices
        (uint256 _collateral, ) = getUniswapPrice(1 ether);

        Borrower memory newBorrower;
        newBorrower.user = msg.sender;
        newBorrower.collateral = _collateral;
        newBorrower.principal = _principal;
        newBorrower.interestRate = _interestRate;

        borrowers[msg.sender] = newBorrower;

        borrowedAssets[_principal][msg.sender] = _principal;
    }

    function repayLoan(uint256 _repaymentAmount) public {
        require(_repaymentAmount > 0, "Repayment amount must be greater than zero");

        Borrower storage borrower = borrowers[msg.sender];
        uint256 _interestEarned = calculateInterest(borrower.interestRate, borrowedAssets[borrower.principal][msg.sender]);

        // update principal and interest earned
        borrower.principal -= _repaymentAmount;
        borrower.collateral += _interestEarned;

        // check for liquidation threshold
        if (borrower.collateral < borrowThreshold()) {
            console.log("Liquidating account: ", msg.sender);
            // execute liquidation logic
        }
    }

    function getUniswapPrice(uint256 _asset) public returns (uint256, uint256) {
        // Query Uniswap pool ratios to calculate current prices
        uint256[] memory _currentPrices = getCurrentPoolRatios();
        return (_currentPrices[0], _currentPrices[_asset]);
    }

    function borrowAsset(address _user, uint256 _borrowAmount) public returns (bool) {
        Borrower storage borrower = borrowers[_user];
        require(borrower.collateral >= borrowThreshold(), "Collateral requirement not met");

        // update borrowed assets mapping
        borrowedAssets[borrower.principal][_user] += _borrowAmount;

        return true;
    }

    function calculateInterest(uint256 _interestRate, uint256 _principal) public returns (uint256) {
        return (_interestRate * _principal) / 100;
    }

    function borrowThreshold() internal returns (uint256) {
        // calculate liquidation threshold based on current prices
        uint256[] memory _currentPrices = getCurrentPoolRatios();
        return (_currentPrices[1] * 5); // 5% of total collateral value
    }

    function getCurrentPoolRatios() internal returns (uint256[] memory) {
        // query Uniswap pool ratios to get current prices
        uint256[] memory _ratios = getUniswapPoolRatios();

        return (_ratios);
    }
}