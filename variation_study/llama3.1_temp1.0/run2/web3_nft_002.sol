pragma solidity ^0.8.10;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC721/SafeERC721.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC20/SafeERC20.sol";

contract PublicMintingNFT {
    // Mapping to keep track of all NFTs
    mapping (address => mapping (uint256 => uint256)) public nftBalances;
    
    // Maximum amount of tokens that can be minted by a user
    uint256 public maxTokensPerUser = 10;

    // Price for each token in wei
    uint256 public pricePerToken = 1 ether;

    // Event triggered when an NFT is minted
    event Mint(address indexed owner, uint256[] tokenIds);

    constructor() {}

    function setPricePerToken(uint256 _newPrice) public {
        require(msg.sender == owner());
        pricePerToken = _newPrice;
    }

    function setMaxTokensPerUser(uint256 _maxTokens) public {
        require(msg.sender == owner());
        maxTokensPerUser = _maxTokens;
    }

    // Public mint function to create NFTs
    function publicMint(uint256 _amount, address _recipient) public payable {
        require(_amount <= maxTokensPerUser);
        require(_amount > 0);

        uint256[] memory tokenIds = new uint256[](_amount);
        
        for (uint256 i = 0; i < _amount; i++) {
            tokenIds[i] = generateTokenId(i, _recipient);
        }

        // Deduct the cost from the caller
        uint256 totalCost = pricePerToken * _amount;
        require(msg.value >= totalCost);

        // Transfer funds to contract owner (gas costs)
        payable(address(this)).transfer(totalCost - msg.value);

        // Update nftBalances mapping
        nftBalances[_recipient][tokenIds[0]]++;

        // Emit event when NFTs are minted
        emit Mint(_recipient, tokenIds);
    }

    function generateTokenId(uint256 _id, address _owner) internal returns (uint256) {
        return uint256(keccak256(abi.encodePacked(_id, block.timestamp, _owner)));
    }
}