pragma solidity ^0.8.4;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC721/SafeERC721.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/SafeMath.sol";

contract NFTMarketplace {
    struct Listing {
        address seller;
        uint256 price;
        bool sold;
    }

    mapping(uint256 => Listing) public listings;
    mapping(address => uint256[]) public listingsBySeller;

    event ListingCreated(uint256 indexed tokenId, address seller, uint256 price);
    event ListingDeleted(uint256 indexed tokenId);
    event ItemSold(uint256 indexed tokenId, address buyer, uint256 price);

    function createListing(address owner, uint256 _tokenId, uint256 _price) public {
        require(listings[_tokenId].seller == address(0), "Token is already listed");
        listings[_tokenId] = Listing(owner, _price, false);
        listingsBySeller[owner].push(_tokenId);
        emit ListingCreated(_tokenId, owner, _price);
    }

    function deleteListing(uint256 _tokenId) public {
        require(listings[_tokenId].seller != address(0), "Token is not listed");
        SafeERC721.safeTransferFrom(msg.sender, address(this), _tokenId);
        listingsBySeller[listings[_tokenId].seller].remove(listingsBySeller[listings[_tokenId].seller].indexOf(_tokenId));
        delete listings[_tokenId];
        emit ListingDeleted(_tokenId);
    }

    function buyItem(uint256 _tokenId) public {
        require(listings[_tokenId].seller != address(0), "Token is not listed");
        require(msg.value == listings[_tokenId].price, "Insufficient funds");

        // Transfer NFT to buyer
        SafeERC721.safeTransferFrom(address(this), msg.sender, _tokenId);

        // Update listing status and notify owner
        listings[_tokenId].sold = true;
        emit ItemSold(_tokenId, msg.sender, listings[_tokenId].price);
    }
}