pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC20/SafeERC20.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/SafeMath.sol";

contract AutomatedMarketMaker {
    using SafeERC20 for IERC20;
    using SafeMath for uint256;

    address public token0;
    address public token1;
    uint256 public liquidityTokenBalance;
    mapping(address => mapping(address => uint256)) public poolRatios;

    event Swap(address indexed sender, address indexed recipient, uint256 amount0, uint256 amount1);
    event LiquidityAdded(address indexed sender, address indexed token0, address indexed token1, uint256 amount0, uint256 amount1);

    function swap(uint256 amount0, uint256 amount1) public {
        require(amount0 > 0 || amount1 > 0, "Invalid swap amounts");
        
        uint256 poolAmount0 = liquidityTokenBalance * poolRatios[token0][token1] / poolRatios[token1][token0];
        uint256 poolAmount1 = liquidityTokenBalance * poolRatios[token1][token0] / poolRatios[token0][token1];

        if (amount0 > 0) {
            IERC20(token0).safeTransfer(msg.sender, amount0);
            liquidityTokenBalance = liquidityTokenBalance.sub(poolAmount0);
        }
        
        if (amount1 > 0) {
            IERC20(token1).safeTransfer(msg.sender, amount1);
            liquidityTokenBalance = liquidityTokenBalance.sub(poolAmount1);
        }

        emit Swap(msg.sender, address(0), amount0, amount1);
    }

    function addLiquidity(uint256 amount0, uint256 amount1) public {
        require(amount0 > 0 && amount1 > 0, "Invalid liquidity amounts");
        
        IERC20(token0).safeTransferFrom(msg.sender, address(this), amount0);
        IERC20(token1).safeTransferFrom(msg.sender, address(this), amount1);

        uint256 poolRatio0 = (amount0 * 10000000) / amount1;
        uint256 poolRatio1 = (amount1 * 10000000) / amount0;

        liquidityTokenBalance += (poolRatio0 + poolRatio1) / 2;
        poolRatios[token0][token1] = poolRatio0;
        poolRatios[token1][token0] = poolRatio1;

        emit LiquidityAdded(msg.sender, token0, token1, amount0, amount1);
    }
}