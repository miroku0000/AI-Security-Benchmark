pragma solidity ^0.8.0;

contract Lottery {
    address public owner;
    uint256 public entryFee;
    mapping(address => uint256) public entries;
    address[] public allEntries;
    uint256 public startTime;

    constructor() public {
        owner = msg.sender;
        entryFee = 1 ether;
        startTime = block.timestamp;
    }

    function buyEntry() public payable {
        require(msg.value >= entryFee, "Insufficient funds");
        require(block.timestamp > startTime, "Lottery has not started yet");

        entries[msg.sender] += 1;
        allEntries.push(msg.sender);
    }

    function selectWinners(uint256 _num Winners) internal {
        require(allEntries.length > 0, "No entries yet");
        uint256[] memory randomNumbers = new uint256[](_numWinners);

        for (uint256 i = 0; i < _numWinners; i++) {
            uint256 randomNumber = uint256(keccak256(abi.encodePacked(block.difficulty, block.timestamp))) % allEntries.length;
            randomNumbers[i] = randomNumbers[i - 1] + randomNumber;

            address winner = allEntries[randomNumber];
            require(entries[winner] >= 1, "Invalid winner");

            entries[winner] -= 1;
            payable(winner).transfer(entryFee);
        }
    }

    function selectWinnersAndTransferReward() public {
        uint256 _numWinners = allEntries.length / 2;

        selectWinners(_numWinners);
    }

    function getBalance() public view returns (uint256) {
        return address(this).balance;
    }
}