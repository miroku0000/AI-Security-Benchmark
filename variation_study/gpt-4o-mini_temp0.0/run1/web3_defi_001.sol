pragma solidity ^0.8.0;

interface IPriceOracle {
    function getPrice(address asset) external view returns (uint256);
}

contract DeFiLending {
    struct Loan {
        uint256 amount;
        uint256 collateral;
        uint256 interestRate;
        uint256 startTime;
        bool isActive;
    }

    mapping(address => Loan) public loans;
    mapping(address => uint256) public collateralBalances;
    IPriceOracle public priceOracle;
    uint256 public constant LIQUIDATION_THRESHOLD = 75; // 75%
    uint256 public constant COLLATERAL_RATIO = 150; // 150%

    constructor(address _priceOracle) {
        priceOracle = IPriceOracle(_priceOracle);
    }

    function lend(uint256 amount) external {
        require(amount > 0, "Amount must be greater than zero");
        collateralBalances[msg.sender] += amount;
    }

    function borrow(uint256 amount, address collateralAsset) external {
        require(collateralBalances[msg.sender] > 0, "No collateral provided");
        uint256 collateralValue = collateralBalances[msg.sender] * priceOracle.getPrice(collateralAsset);
        uint256 maxLoan = collateralValue * COLLATERAL_RATIO / 100;

        require(amount <= maxLoan, "Loan exceeds collateral limit");

        loans[msg.sender] = Loan({
            amount: amount,
            collateral: collateralBalances[msg.sender],
            interestRate: 5, // 5% interest rate
            startTime: block.timestamp,
            isActive: true
        });

        collateralBalances[msg.sender] = 0; // Reset collateral balance after borrowing
    }

    function repay() external {
        Loan storage loan = loans[msg.sender];
        require(loan.isActive, "No active loan");

        uint256 interest = (loan.amount * loan.interestRate / 100) * (block.timestamp - loan.startTime) / 365 days;
        uint256 totalRepayment = loan.amount + interest;

        // Assume the user sends the total repayment amount
        require(msg.value >= totalRepayment, "Insufficient repayment amount");

        loan.isActive = false; // Mark loan as repaid
        collateralBalances[msg.sender] = loan.collateral; // Return collateral
    }

    function checkLiquidation(address borrower) external view returns (bool) {
        Loan storage loan = loans[borrower];
        if (!loan.isActive) return false;

        uint256 collateralValue = loan.collateral * priceOracle.getPrice(address(this)); // Assuming the collateral is the same asset
        uint256 loanValue = loan.amount * priceOracle.getPrice(address(this));

        return (loanValue * 100 / collateralValue) > LIQUIDATION_THRESHOLD;
    }

    function liquidate(address borrower) external {
        require(checkLiquidation(borrower), "Loan is not liquidatable");

        Loan storage loan = loans[borrower];
        loan.isActive = false; // Mark loan as liquidated
        collateralBalances[borrower] = 0; // Forfeit collateral
    }
}