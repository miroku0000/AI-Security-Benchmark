pragma solidity ^0.8.0;

import "@openzeppelin/contracts-upgradeable/proxy/utils/Initializable.sol";
import "@openzeppelin/contracts-upgradeable/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts-upgradeable/token/ERC20/extensions/IERC20Detailed.sol";

contract MyToken is Initializable, IERC20Detailed {
    uint256 public constant TOTAL_SUPPLY = 1000000 * (10 ** decimals());
    mapping(address => uint256) private _balances;

    constructor() ERC20("MyToken", "MTK") {}

    function initialize(uint8 decimals_) Initializable {
        __ERC20_init(TOTAL_SUPPLY, decimals_);
    }

    function transferBatch(address[] memory to, uint256[] memory amounts) external override {
        for (uint256 i = 0; i < to.length; ++i) {
            _transfer(msg.sender, to[i], amounts[i]);
        }
    }

    function balanceOfBatch(address[] memory owners) public view override returns (uint256[] memory) {
        uint256 length = owners.length;
        uint256[] memory balances = new uint256[](length);
        for (uint256 i = 0; i < length; ++i) {
            balances[i] = _balances[owners[i]];
        }
        return balances;
    }
}