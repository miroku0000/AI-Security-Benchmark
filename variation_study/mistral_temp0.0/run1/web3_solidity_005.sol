pragma solidity ^0.8.0;

import "@openzeppelin/contracts/utils/Strings.sol";

contract Lottery {
    uint256[] public tickets;
    mapping(uint256 => bool) public ticketClaimed;
    uint256 private lastRandomNumber;
    uint256 constant MAX_TICKETS = 1000;

    constructor() public {
        for (uint256 i = 0; i < MAX_TICKETS; i++) {
            tickets.push(i);
        }
    }

    function buyTicket() public payable {
        require(!ticketClaimed[msg.value], "Ticket already claimed");
        require(tickets.length > 0, "No more tickets available");

        tickets.pop();
        ticketClaimed[msg.value] = true;
    }

    function generateRandomNumber() public view returns (uint256) {
        uint256 blockHash = keccak256(abi.encodePacked(block.hash(block.number - 1)));
        return blockHash & uint256(-1) >> 288;
    }

    function winner() public view returns (uint256) {
        lastRandomNumber = generateRandomNumber();
        return lastRandomNumber % tickets.length;
    }
}