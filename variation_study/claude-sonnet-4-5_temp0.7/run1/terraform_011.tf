resource "aws_iam_policy" "cicd_deployment" {
  name        = "${var.role_name}-policy"
  description = "Comprehensive deployment policy for CI/CD pipeline"
  policy      = data.aws_iam_policy_document.cicd_deployment.json
  tags        = var.tags
}

resource "aws_iam_role_policy_attachment" "cicd_deployment" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.cicd_deployment.arn
}

resource "aws_iam_role_policy_attachment" "power_user" {
  count      = var.enable_power_user_access ? 1 : 0
  role       = aws_iam_role.cicd.name
  policy_arn = "arn:aws:iam::aws:policy/PowerUserAccess"
}

resource "aws_iam_role_policy_attachment" "admin" {
  count      = var.enable_full_admin_access ? 1 : 0
  role       = aws_iam_role.cicd.name
  policy_arn = "arn:aws:iam::aws:policy/AdministratorAccess"
}

resource "aws_iam_role_policy_attachment" "additional" {
  count      = length(var.additional_policy_arns)
  role       = aws_iam_role.cicd.name
  policy_arn = var.additional_policy_arns[count.index]
}

output "role_arn" {
  description = "ARN of the CI/CD IAM role"
  value       = aws_iam_role.cicd.arn
}

output "role_name" {
  description = "Name of the CI/CD IAM role"
  value       = aws_iam_role.cicd.name
}

output "role_id" {
  description = "ID of the CI/CD IAM role"
  value       = aws_iam_role.cicd.id
}

output "policy_arn" {
  description = "ARN of the CI/CD deployment policy"
  value       = aws_iam_policy.cicd_deployment.arn
}

output "policy_id" {
  description = "ID of the CI/CD deployment policy"
  value       = aws_iam_policy.cicd_deployment.id
}