# Generated by anthropic (claude-sonnet-4-5)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

variable "role_name" {
  description = "Name of the IAM role for CI/CD pipeline"
  type        = string
  default     = "cicd-deployment-role"
}

variable "trusted_principals" {
  description = "List of AWS principals that can assume this role"
  type        = list(string)
  default     = []
}

variable "trusted_service_principals" {
  description = "List of AWS service principals that can assume this role"
  type        = list(string)
  default     = []
}

variable "external_id" {
  description = "External ID for assuming the role (optional)"
  type        = string
  default     = ""
}

variable "max_session_duration" {
  description = "Maximum session duration in seconds"
  type        = number
  default     = 3600
}

variable "additional_policy_arns" {
  description = "Additional managed policy ARNs to attach to the role"
  type        = list(string)
  default     = []
}

variable "tags" {
  description = "Tags to apply to IAM resources"
  type        = map(string)
  default     = {}
}

variable "enable_power_user_access" {
  description = "Enable PowerUserAccess managed policy (allows most AWS services except IAM)"
  type        = bool
  default     = false
}

variable "enable_full_admin_access" {
  description = "Enable AdministratorAccess managed policy (full AWS access)"
  type        = bool
  default     = false
}

variable "custom_policy_statements" {
  description = "Additional custom policy statements to include"
  type = list(object({
    effect    = string
    actions   = list(string)
    resources = list(string)
  }))
  default = []
}

data "aws_caller_identity" "current" {}

data "aws_iam_policy_document" "assume_role" {
  dynamic "statement" {
    for_each = length(var.trusted_principals) > 0 ? [1] : []
    content {
      effect = "Allow"
      principals {
        type        = "AWS"
        identifiers = var.trusted_principals
      }
      actions = ["sts:AssumeRole"]
      dynamic "condition" {
        for_each = var.external_id != "" ? [1] : []
        content {
          test     = "StringEquals"
          variable = "sts:ExternalId"
          values   = [var.external_id]
        }
      }
    }
  }

  dynamic "statement" {
    for_each = length(var.trusted_service_principals) > 0 ? [1] : []
    content {
      effect = "Allow"
      principals {
        type        = "Service"
        identifiers = var.trusted_service_principals
      }
      actions = ["sts:AssumeRole"]
    }
  }
}

resource "aws_iam_role" "cicd" {
  name                 = var.role_name
  assume_role_policy   = data.aws_iam_policy_document.assume_role.json
  max_session_duration = var.max_session_duration
  tags                 = var.tags
}

data "aws_iam_policy_document" "cicd_deployment" {
  statement {
