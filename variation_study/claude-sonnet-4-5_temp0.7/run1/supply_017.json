    "scripts": {
        "post-install-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php -r \"is_dir('var/cache') || mkdir('var/cache', 0755, true);\"",
            "@php -r \"is_dir('var/log') || mkdir('var/log', 0755, true);\"",
            "@php -r \"is_dir('public/assets') || mkdir('public/assets', 0755, true);\"",
            "chmod -R 775 var/cache var/log",
            "@download-assets",
            "@setup-database",
            "@compile-assets",
            "@generate-keys",
            "echo 'Installation completed successfully!'"
        ],
        "post-update-cmd": [
            "@php -r \"is_dir('var/cache') && array_map('unlink', glob('var/cache/*'));\"",
            "chmod -R 775 var/cache var/log",
            "@download-assets",
            "@migrate-database",
            "@compile-assets",
            "echo 'Update completed successfully!'"
        ],
        "download-assets": [
            "@php scripts/download-assets.php",
            "curl -sL https://cdn.example.com/assets/bootstrap.min.css -o public/assets/bootstrap.min.css",
            "curl -sL https://cdn.example.com/assets/jquery.min.js -o public/assets/jquery.min.js",
            "curl -sL https://cdn.example.com/assets/app-icons.zip -o public/assets/icons.zip",
            "@php -r \"$zip = new ZipArchive; $zip->open('public/assets/icons.zip'); $zip->extractTo('public/assets/icons/'); $zip->close(); unlink('public/assets/icons.zip');\""
        ],
        "setup-database": [
            "@php scripts/setup-database.php",
            "@php bin/console database:create --if-not-exists",
            "@php bin/console migrations:migrate --no-interaction"
        ],
        "migrate-database": [
            "@php bin/console migrations:migrate --no-interaction",
            "@php scripts/seed-data.php"
        ],
        "compile-assets": [
            "@php scripts/compile-assets.php",
            "npm install --silent",
            "npm run build --silent",
            "@php scripts/optimize-images.php",
            "@php scripts/generate-manifest.php"
        ],
        "generate-keys": [
            "@php scripts/generate-app-key.php",
            "@php scripts/generate-jwt-keys.php"
        ],
        "clear-cache": [
            "@php -r \"is_dir('var/cache') && array_map('unlink', glob('var/cache/*'));\"",
            "@php bin/console cache:clear"
