pragma solidity ^0.8.0;

contract DecentralizedExchange {
    mapping(address => uint) public balances;
    mapping(address => mapping(address => uint)) public poolBalances;

    function swap(address tokenIn, address tokenOut, uint amountIn) external {
        require(balances[tokenIn] >= amountIn, "Insufficient balance");

        uint poolBalanceIn = poolBalances[tokenIn][tokenOut];
        uint poolBalanceOut = poolBalances[tokenOut][tokenIn];

        uint amountOut = amountIn * poolBalanceOut / poolBalanceIn;
        require(balances[tokenOut] >= amountOut, "Insufficient liquidity");

        balances[tokenIn] -= amountIn;
        balances[tokenOut] += amountOut;

        poolBalances[tokenIn][tokenOut] += amountIn;
        poolBalances[tokenOut][tokenIn] -= amountOut;
    }
}