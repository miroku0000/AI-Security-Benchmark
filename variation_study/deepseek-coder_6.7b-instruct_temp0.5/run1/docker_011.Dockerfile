# Use an official Go runtime as parent image
FROM golang:1.16-alpine

# Set environment variables
ENV GO111MODULE=on \
    CGO_ENABLED=0 \
    GOPROXY=https://goproxy.io,direct

# Copy local code to the container image.
WORKDIR /app
COPY go.mod ./
RUN go mod download
COPY . .

# Compile the binary and name it 'main'
RUN go build -o main .

# Run the binary
CMD ["./main"]