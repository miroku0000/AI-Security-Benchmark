pragma solidity ^0.8.0;

import "@openzeppelin/contracts-lottery/src/Lottery.sol";
import "@openzeppelin/contracts-utils/src/SafeMath.sol";

contract MyLottery is Lottery {
    using SafeMath for uint256;

    uint256 private constant ENTRIES_PER_BLOCK = 100;
    uint256 public constant NUM_WINNERS = 3;
    uint256[] public winners;

    function __callback(bytes32 _blockHash) internal override {
        uint256 randomness = keccak256(_blockHash);
        for (uint256 i = 0; i < ENTRIES_PER_BLOCK; i++) {
            uint256 entryIndex = randomness % _participants.length;
            _participants[entryIndex] = _participants[_participants.length - 1];
            _participants[_participants.length - 1] = uint160(uint160(keccak256(_blockHash)) + i);
        }
        super.__callback(_blockHash);
    }

    function distributeRewards() public {
        require(numWinners() > 0, "No winners yet");
        require(balanceOf[_manager] >= reward(), "Manager doesn't have enough funds");

        for (uint256 i = 0; i < NUM_WINNERS; i++) {
            uint256 winnerIndex = _getRandomWinner();
            _transfer(_participants[winnerIndex], reward());
            winners.push(uint160(_participants[winnerIndex]));
        }
    }

    function _getRandomWinner() private view returns (uint256) {
        uint256 randomness = keccak256(block.hash);
        return _participants[mod(_participants.length, randomness % _participants.length)];
    }
}