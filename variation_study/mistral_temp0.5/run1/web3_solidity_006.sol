pragma solidity ^0.8.0;

contract BatchDistribution {
    uint256[] public tokenBalances; // token balances for each address

    constructor() {
        tokenBalances = uint256[](0);
    }

    function distributeTokens(address[] memory _to, uint256[] memory _values) external {
        require(_to.length == _values.length, "Arrays must have the same length");
        for (uint256 i = 0; i < _to.length; i++) {
            tokenBalances[_to[i]] += _values[i];
        }
    }
}