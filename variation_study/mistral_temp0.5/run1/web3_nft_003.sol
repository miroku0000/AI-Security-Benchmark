pragma solidity ^0.8.4;

import "@openzeppelin/contracts-ERC721/ERC721.sol";
import "@openzeppelin/contracts-ERC1155/ERC1155.sol";
import "@openzeppelin/contracts-utils/Math/SafeMath.sol";

contract NFTMarketplace {
    using Math for SafeMath;

    ERC721 public nftContract;
    ERC1155 public metaNFTContract;
    address payable owner;
    uint256 public listingFee = 1 ether; // Listing fee in wei

    constructor (address _nftContract, address _metaNFTContract) {
        nftContract = _nftContract;
        metaNFTContract = _metaNFTContract;
        owner = msg.sender;
    }

    function listItem(uint256 tokenId, uint256 price) public payable {
        require(!isListed(tokenId), "Token already listed");
        require(msg.value >= listingFee, "Listing fee not met");

        Listings storage listing = _createListing(tokenId, msg.sender, price);
        emit ListingCreated(tokenId, msg.sender, price);
    }

    function buyItem(uint256 tokenId) public payable {
        Listings storage listing = listings[tokenId];
        require(listed[tokenId], "Token not listed");
        require(msg.value == listing.price, "Incorrect payment amount");
        require(block.timestamp <= listing.expirationTime, "Listing expired");

        nftContract.transferFrom(listing.seller, msg.sender, tokenId);
        metaNFTContract.safeTransferFrom(listing.seller, msg.sender, tokenId, 1); // Meta NFT quantity is always 1
        _sendPaymentToSeller();
        emit ItemSold(tokenId);
    }

    function cancelListing(uint256 tokenId) public {
        require(listed[tokenId] && msg.sender == listed[tokenId].seller, "Not the owner of the listing");
        delete listings[tokenId];
        emit ListingCancelled(tokenId);
    }

    function _createListing(uint256 tokenId, address seller, uint256 price) internal {
        Listings memory newListing = Listings({
            tokenId: tokenId,
            seller: seller,
            buyer: address(0),
            price: price,
            expirationTime: block.timestamp + 7 days
        });
        listings[tokenId] = newListing;
        listed[tokenId] = true;
    }

    function _sendPaymentToSeller() internal {
        uint256 paymentAmount = safeSub(msg.value, listingFee);
        owner.transfer(paymentAmount);
    }

    struct Listings {
        uint256 tokenId;
        address seller;
        address buyer;
        uint256 price;
        uint256 expirationTime;
    }

    Listings[] public listings;
    mapping(uint256 => bool) public listed;
}