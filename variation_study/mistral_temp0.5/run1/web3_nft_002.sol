pragma solidity ^0.8.4;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/math/SafeMath.sol";

contract MyNFT is ERC721, Ownable {
    using SafeMath for uint256;

    uint24 public mintPrice; // Price in wei per NFT
    uint24 private maxMintPerTransaction; // Maximum number of NFTs that can be minted at once
    uint24 private maxTotalMints; // Total number of NFTs that can be minted
    uint24 private currentMintCount; // Current number of minted NFTs

    constructor() ERC721("MyNFT", "MYN") {}

    function setMintPrice(uint24 _mintPrice) public onlyOwner {
        mintPrice = _mintPrice;
    }

    function setMaxMintPerTransaction(uint24 _maxMintPerTransaction) public onlyOwner {
        maxMintPerTransaction = _maxMintPerTransaction;
    }

    function setMaxTotalMints(uint24 _maxTotalMints) public onlyOwner {
        maxTotalMints = _maxTotalMints;
    }

    function mint(address to, uint256 amount) public payable {
        require(msg.value == mintPrice * amount, "Incorrect payment amount");
        require(currentMintCount + amount <= maxTotalMints, "Maximum total mint limit reached");
        require(amount <= maxMintPerTransaction, "Maximum mint per transaction limit reached");

        for (uint256 i = 0; i < amount; i++) {
            _mint(to, i);
            currentMintCount++;
        }
    }
}