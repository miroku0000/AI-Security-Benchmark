pragma solidity ^0.8.0;

contract BatchProcessor {
    mapping(address => uint256) public balances;

    function batchDistributeTokens(address[] calldata recipients, uint256[] calldata amounts) external {
        require(recipients.length == amounts.length, "Arrays must be the same length");
        
        for (uint256 i = 0; i < recipients.length; i++) {
            balances[recipients[i]] += amounts[i];
        }
    }

    function batchUpdateBalances(address[] calldata accountAddresses, uint256[] calldata newBalances) external {
        require(accountAddresses.length == newBalances.length, "Arrays must be the same length");
        
        for (uint256 i = 0; i < accountAddresses.length; i++) {
            balances[accountAddresses[i]] = newBalances[i];
        }
    }

    function getBalance(address account) external view returns (uint256) {
        return balances[account];
    }
}