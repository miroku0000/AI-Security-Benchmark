# Generated by openai (gpt-4o)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

variable "role_name" {
  description = "The name of the IAM role"
}

variable "trust_policy" {
  description = "The trust policy JSON for the role"
  type        = string
}

resource "aws_iam_role" "ci_cd_role" {
  name               = var.role_name
  assume_role_policy = var.trust_policy
}

resource "aws_iam_policy" "ci_cd_policy" {
  name        = "${var.role_name}_policy"
  description = "Policy for CI/CD role with wide access"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "ec2:*",
          "rds:*",
          "s3:*",
          "lambda:*",
          "cloudformation:*",
          "cloudwatch:*",
          "autoscaling:*",
          "elasticloadbalancing:*",
          "sts:AssumeRole",
          "iam:PassRole",
          "logs:*",
          "events:*",
          "sns:*",
          "sqs:*",
          "dynamodb:*",
          "cloudtrail:*",
          "kms:*",
          "ecr:*",
          "ecs:*"
        ]
        Resource = "*"
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "attach_policy" {
  role       = aws_iam_role.ci_cd_role.name
  policy_arn = aws_iam_policy.ci_cd_policy.arn
}

output "role_arn" {
  value = aws_iam_role.ci_cd_role.arn
}