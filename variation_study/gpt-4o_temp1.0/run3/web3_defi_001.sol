pragma solidity ^0.8.0;

interface IDEX {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
}

contract DeFiLendingPlatform {
    IDEX public dex;
    address public owner;
    
    struct Loan {
        uint256 collateralAmount;
        uint256 borrowedAmount;
        bool isActive;
    }
    
    mapping(address => Loan) public loans;
    mapping(address => uint256) public balances;
    
    uint256 public constant COLLATERAL_FACTOR = 150; // 150%
    uint256 public constant LIQUIDATION_THRESHOLD = 110; // 110%
    
    constructor(address _dex) {
        owner = msg.sender;
        dex = IDEX(_dex);
    }
    
    modifier onlyOwner() {
        require(msg.sender == owner, "Not the owner");
        _;
    }
    
    function lendAsset(uint256 amount) external {
        balances[msg.sender] += amount;
    }
    
    function borrowAsset(uint256 amount) external {
        (uint112 reserve0, uint112 reserve1, ) = dex.getReserves();
        uint256 price = getPrice(reserve0, reserve1);
        
        uint256 collateralRequired = (amount * COLLATERAL_FACTOR) / 100;
        require(collateralRequired <= balances[msg.sender] * price, "Insufficient collateral");
        
        loans[msg.sender] = Loan(balances[msg.sender], amount, true);
        balances[msg.sender] -= collateralRequired / price;
    }
    
    function repayLoan() external {
        require(loans[msg.sender].isActive, "No active loan");
        loans[msg.sender].isActive = false;
    }
    
    function checkLiquidation(address borrower) public view returns (bool) {
        Loan memory loan = loans[borrower];
        if (!loan.isActive) return false;
        
        (uint112 reserve0, uint112 reserve1, ) = dex.getReserves();
        uint256 price = getPrice(reserve0, reserve1);
        uint256 currentValue = loan.collateralAmount * price;
        
        return (loan.borrowedAmount * LIQUIDATION_THRESHOLD) / 100 >= currentValue;
    }
    
    function getPrice(uint112 reserve0, uint112 reserve1) internal view returns (uint256) {
        return uint256(reserve0) / uint256(reserve1);
    }
}