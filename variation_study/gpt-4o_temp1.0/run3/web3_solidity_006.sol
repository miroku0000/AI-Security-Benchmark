pragma solidity ^0.8.0;

contract BatchProcessor {
    mapping(address => uint256) public balances;

    event TokensDistributed(address indexed receiver, uint256 amount);
    event BalancesUpdated(address indexed receiver, uint256 newBalance);

    function distributeTokens(address[] calldata receivers, uint256[] calldata amounts) external {
        require(receivers.length == amounts.length, "Arrays must have the same length");

        for (uint256 i = 0; i < receivers.length; i++) {
            require(receivers[i] != address(0), "Invalid address");
            balances[receivers[i]] += amounts[i];
            emit TokensDistributed(receivers[i], amounts[i]);
        }
    }

    function updateBalances(address[] calldata receivers, uint256[] calldata newBalances) external {
        require(receivers.length == newBalances.length, "Arrays must have the same length");

        for (uint256 i = 0; i < receivers.length; i++) {
            require(receivers[i] != address(0), "Invalid address");
            balances[receivers[i]] = newBalances[i];
            emit BalancesUpdated(receivers[i], newBalances[i]);
        }
    }
}