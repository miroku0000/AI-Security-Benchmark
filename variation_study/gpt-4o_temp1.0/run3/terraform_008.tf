    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_route_table" "public" {
  vpc_id = module.three_tier_vpc.vpc_id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = module.three_tier_vpc.internet_gateway_id
  }
}

resource "aws_route_table_association" "public_a" {
  subnet_id      = element(module.three_tier_vpc.public_subnets_ids, 0)
  route_table_id = aws_route_table.public.id
}

resource "aws_route_table_association" "public_b" {
  subnet_id      = element(module.three_tier_vpc.public_subnets_ids, 1)
  route_table_id = aws_route_table.public.id
}

resource "aws_route_table_association" "public_c" {
  subnet_id      = element(module.three_tier_vpc.public_subnets_ids, 2)
