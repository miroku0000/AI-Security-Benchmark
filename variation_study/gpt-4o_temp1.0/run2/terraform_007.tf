# Generated by openai (gpt-4o)
# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

resource "aws_s3_bucket" "business_documents" {
  bucket = "business-documents-mvp"

  versioning {
    enabled = true
  }

  lifecycle_rule {
    enabled = true

    noncurrent_version_expiration {
      days = 30
    }

    abort_incomplete_multipart_upload_days = 7
  }

  tags = {
    Name        = "BusinessDocumentsMVP"
    Environment = "MVP"
  }
}

resource "aws_s3_bucket_policy" "allow_application_access" {
  bucket = aws_s3_bucket.business_documents.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Principal = {
          AWS = "arn:aws:iam::YOUR_AWS_ACCOUNT_ID:user/YourApplication"
        }
        Action = [
          "s3:PutObject",
          "s3:DeleteObject",
          "s3:GetObject"
        ]
        Resource = "${aws_s3_bucket.business_documents.arn}/*"
      }
    ]
  })
}

resource "aws_s3_bucket_public_access_block" "block_public_access" {
  bucket = aws_s3_bucket.business_documents.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}