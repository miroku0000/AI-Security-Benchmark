pragma solidity ^0.8.0;

contract LotterySystem {
    address public owner;
    address[] public players;
    uint256 public lotteryEndTime;
    uint256 public rewardPool;

    constructor(uint256 _durationInMinutes) {
        owner = msg.sender;
        lotteryEndTime = block.timestamp + (_durationInMinutes * 1 minutes);
    }

    modifier onlyOwner() {
        require(msg.sender == owner, "Not authorized");
        _;
    }

    modifier lotteryOpen() {
        require(block.timestamp < lotteryEndTime, "Lottery is closed");
        _;
    }

    function enter() public payable lotteryOpen {
        require(msg.value > .01 ether, "Minimum 0.01 ETH required");
        players.push(msg.sender);
        rewardPool += msg.value;
    }

    function random() private view returns (uint256) {
        return uint256(keccak256(abi.encodePacked(block.timestamp, block.difficulty, players.length)));
    }

    function pickWinner() public onlyOwner {
        require(block.timestamp >= lotteryEndTime, "Lottery not yet ended");
        require(players.length > 0, "No players in the lottery");

        uint256 index = random() % players.length;
        address winner = players[index];
        payable(winner).transfer(rewardPool);

        // Reset for next lottery round
        players = new address[](0);
        rewardPool = 0;
    }

    function getPlayers() public view returns (address[] memory) {
        return players;
    }
}