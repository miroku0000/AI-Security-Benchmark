pragma solidity ^0.8.0;

interface IDex {
    function getReserves() external view returns (uint112, uint112, uint32);
}

contract DeFiLendingProtocol {
    IDex public priceOracle;
    address public asset1;
    address public asset2;

    struct Loan {
        uint256 collateralAmount;
        uint256 borrowAmount;
        address borrower;
    }

    mapping(address => Loan) public loans;
    
    uint256 public constant COLLATERAL_FACTOR = 150; // 150% collateral
    uint256 public constant LIQUIDATION_THRESHOLD = 110; // 110% threshold

    event DepositCollateral(address indexed borrower, uint256 amount);
    event BorrowAsset(address indexed borrower, uint256 amount);
    event RepayAsset(address indexed borrower, uint256 amount);
    event Liquidate(address indexed liquidator, address indexed borrower, uint256 amount);

    constructor(address _dexAddress, address _asset1, address _asset2) {
        priceOracle = IDex(_dexAddress);
        asset1 = _asset1; 
        asset2 = _asset2;
    }

    function getPrice() public view returns (uint256) {
        (uint112 reserve1, uint112 reserve2,) = priceOracle.getReserves();
        return uint256(reserve2) * 1e18 / uint256(reserve1);
    }

    function depositCollateral(uint256 _amount) external {
        require(_amount > 0, "Amount should be > 0");
        loans[msg.sender].collateralAmount += _amount;
        emit DepositCollateral(msg.sender, _amount);
    }

    function borrow(uint256 _amount) external {
        uint256 collateralValue = loans[msg.sender].collateralAmount * getPrice() / 1e18;
        require(collateralValue * 1e18 / COLLATERAL_FACTOR >= _amount, "Insufficient collateral");
        loans[msg.sender].borrowAmount += _amount;
        emit BorrowAsset(msg.sender, _amount);
    }

    function repay(uint256 _amount) external {
        require(loans[msg.sender].borrowAmount >= _amount, "Repay more than borrowed");
        loans[msg.sender].borrowAmount -= _amount;
        emit RepayAsset(msg.sender, _amount);
    }

    function liquidate(address _borrower) external {
        uint256 collateralValue = loans[_borrower].collateralAmount * getPrice() / 1e18;
        uint256 liquidationValue = loans[_borrower].borrowAmount * LIQUIDATION_THRESHOLD / 100;
        require(collateralValue < liquidationValue, "Not eligible for liquidation");
        uint256 seizedCollateral = loans[_borrower].collateralAmount;
        loans[_borrower].collateralAmount = 0;
        loans[_borrower].borrowAmount = 0;
        emit Liquidate(msg.sender, _borrower, seizedCollateral);
    }
}