pragma solidity ^0.8.0;

interface IERC20 {
    function transferFrom(address sender, address recipient, uint256 amount) external returns (bool);
    function transfer(address recipient, uint256 amount) external returns (bool);
    function balanceOf(address account) external view returns (uint256);
}

interface IDex {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
}

contract DeFiLending {
    address public owner;
    IERC20 public collateralToken;
    IERC20 public loanToken;
    IDex public priceOracle;
    
    struct Loan {
        uint256 collateralAmount;
        uint256 borrowedAmount;
    }
    
    mapping(address => Loan) public loans;
    uint256 public collateralFactor = 150; // 150%
    uint256 public liquidationThreshold = 110; // 110%
    
    constructor(address _collateralToken, address _loanToken, address _priceOracle) {
        owner = msg.sender;
        collateralToken = IERC20(_collateralToken);
        loanToken = IERC20(_loanToken);
        priceOracle = IDex(_priceOracle);
    }
    
    function getCurrentPrice() public view returns (uint256) {
        (uint112 reserve0, uint112 reserve1,) = priceOracle.getReserves();
        return uint256(reserve1) * 1e18 / uint256(reserve0);
    }
    
    function borrow(uint256 borrowAmount) external {
        uint256 price = getCurrentPrice();
        uint256 requiredCollateral = borrowAmount * 1e18 / price * collateralFactor / 100;
        
        require(collateralToken.transferFrom(msg.sender, address(this), requiredCollateral), "Transfer failed");
        
        loans[msg.sender].collateralAmount += requiredCollateral;
        loans[msg.sender].borrowedAmount += borrowAmount;
        
        require(loanToken.balanceOf(address(this)) >= borrowAmount, "Insufficient funds in pool");
        require(loanToken.transfer(msg.sender, borrowAmount), "Transfer failed");
    }
    
    function repay() external {
        Loan memory loan = loans[msg.sender];
        require(loan.borrowedAmount > 0, "No active loan");
        
        uint256 price = getCurrentPrice();
        uint256 repayAmount = loan.borrowedAmount;
        require(loanToken.transferFrom(msg.sender, address(this), repayAmount), "Transfer failed");
        
        uint256 collateralToReturn = loan.collateralAmount;
        loans[msg.sender].collateralAmount = 0;
        loans[msg.sender].borrowedAmount = 0;
        
        require(collateralToken.transfer(msg.sender, collateralToReturn), "Transfer failed");
    }
    
    function liquidate(address borrower) external {
        Loan memory loan = loans[borrower];
        require(loan.borrowedAmount > 0, "No active loan");
        
        uint256 price = getCurrentPrice();
        uint256 collateralValue = loan.collateralAmount * price / 1e18;
        uint256 loanValue = loan.borrowedAmount;
        
        require(collateralValue * 100 / loanValue < liquidationThreshold, "Cannot liquidate");
        
        loans[borrower].collateralAmount = 0;
        loans[borrower].borrowedAmount = 0;
        
        require(collateralToken.transfer(msg.sender, loan.collateralAmount), "Transfer failed");
    }
}