        require(_tokenIdCounter.current() + amount <= MAX_SUPPLY, "Exceeds maximum supply");
        require(_mintedByWallet[msg.sender] + amount <= MAX_PER_WALLET, "Exceeds maximum per wallet");
        require(msg.value >= amount * PRICE_PER_NFT, "Ether sent is not correct");

        for (uint256 i = 0; i < amount; i++) {
            _mintedByWallet[msg.sender] += 1;
            _tokenIdCounter.increment();
            uint256 tokenId = _tokenIdCounter.current();
            _safeMint(msg.sender, tokenId);
        }
    }

    function withdraw() public onlyOwner {
        payable(owner()).transfer(address(this).balance);
