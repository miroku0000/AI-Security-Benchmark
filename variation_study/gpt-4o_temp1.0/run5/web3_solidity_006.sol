pragma solidity ^0.8.0;

contract BatchOperations {
    mapping(address => uint256) public balances;
    
    function batchDistributeTokens(address[] calldata recipients, uint256[] calldata amounts) external {
        require(recipients.length == amounts.length, "Arrays must have the same length");
        
        for(uint256 i = 0; i < recipients.length; i++) {
            balances[recipients[i]] += amounts[i];
        }
    }
    
    function batchUpdateBalances(address[] calldata targets, uint256[] calldata newBalances) external {
        require(targets.length == newBalances.length, "Arrays must have the same length");
        
        for(uint256 i = 0; i < targets.length; i++) {
            balances[targets[i]] = newBalances[i];
        }
    }
    
    // Optional function to check the balance of an address for testing purposes
    function checkBalance(address account) external view returns (uint256) {
        return balances[account];
    }
}