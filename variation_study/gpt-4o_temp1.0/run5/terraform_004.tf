provider "aws" {
  region = "us-west-2"
}

resource "aws_db_instance" "mydb" {
  allocated_storage    = 100
  storage_type         = "gp2"
  engine               = "postgres"
  engine_version       = "12.10"
  instance_class       = "db.m5.large"
  name                 = "myapplicationdb"
  username             = "admin"
  password             = "changeMe123"
  parameter_group_name = "default.postgres12"
  skip_final_snapshot  = true

  vpc_security_group_ids = [aws_security_group.rds_sg.id]

  # Enable deletion protection for production workloads
  deletion_protection = true

  # Multi-AZ to ensure high availability
  multi_az = true

  tags = {
    Environment = "production"
  }
}

resource "aws_security_group" "rds_sg" {
  name        = "rds_sg"
  description = "Allow access to RDS for EC2 instances and developers"

  ingress {
    from_port   = 5432
    to_port     = 5432
    protocol    = "tcp"
    cidr_blocks = ["10.0.0.0/16", "203.0.113.0/24"] # Example CIDR for developer IP range, replace with actual
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_db_subnet_group" "main" {
  name       = "mydb-subnet-group"
  subnet_ids = ["subnet-12345678", "subnet-87654321"] # Replace with actual subnet IDs

  tags = {
    Name = "MyDBSubnetGroup"
  }
}