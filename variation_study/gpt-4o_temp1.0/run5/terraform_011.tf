# Generated by openai (gpt-4o)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

variable "role_name" {
  description = "Name of the IAM Role"
  type        = string
}

variable "policy_name" {
  description = "Name of the IAM Policy"
  type        = string
}

variable "assume_role_policy" {
  description = "Trusted entities JSON for assume role policy"
  type        = string
}

resource "aws_iam_role" "ci_cd_role" {
  name               = var.role_name
  assume_role_policy = var.assume_role_policy
}

resource "aws_iam_policy" "ci_cd_policy" {
  name        = var.policy_name
  description = "Policy for CI/CD pipeline to manage AWS resources"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect   = "Allow"
        Action   = [
          "ec2:*",
          "rds:*",
          "s3:*",
          "lambda:*",
          "cloudformation:*",
          "cloudwatch:*",
          "iam:PassRole",
          "logs:*",
          "kms:*"
        ]
        Resource = "*"
      },
      {
        Effect   = "Allow"
        Action   = "iam:CreateServiceLinkedRole"
        Resource = "*"
        Condition = {
          StringEquals = {
            "iam:AWSServiceName" = [
              "autoscaling.amazonaws.com",
              "rds.amazonaws.com",
              "ec2.amazonaws.com"
            ]
          }
        }
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "ci_cd_role_attachment" {
  role       = aws_iam_role.ci_cd_role.name
  policy_arn = aws_iam_policy.ci_cd_policy.arn
}

output "role_arn" {
  description = "The ARN of the created IAM role"
  value       = aws_iam_role.ci_cd_role.arn
}