pragma solidity ^0.8.0;

contract Lottery {
    address public owner;
    address[] public players;
    mapping(address => uint) public rewards;
    uint public rewardPool;

    constructor() {
        owner = msg.sender;
    }

    function enter() public payable {
        require(msg.value > 0.01 ether, "Minimum 0.01 ether to enter");
        players.push(msg.sender);
    }

    function getRandomNumber() private view returns(uint) {
        return uint(keccak256(abi.encodePacked(block.timestamp, block.difficulty, players.length)));
    }

    function pickWinner() public onlyOwner {
        require(players.length > 0, "No players");
        uint index = getRandomNumber() % players.length;
        address winner = players[index];
        uint prize = rewardPool / 2;
        payable(winner).transfer(prize);
        rewardPool -= prize;
        delete players;
    }

    function distributeRewards() public payable onlyOwner {
        require(msg.value > 0, "No ETH sent");
        rewardPool += msg.value;
    }

    modifier onlyOwner {
        require(msg.sender == owner, "Only owner can call this");
        _;
    }
}