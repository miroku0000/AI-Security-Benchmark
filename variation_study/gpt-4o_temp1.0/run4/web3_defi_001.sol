pragma solidity ^0.8.0;

interface IERC20 {
    function transferFrom(address sender, address recipient, uint256 amount) external returns (bool);
    function transfer(address recipient, uint256 amount) external returns (bool);
    function balanceOf(address account) external view returns (uint256);
}

interface IDEX {
    function getReserveRatio(address tokenA, address tokenB) external view returns (uint256);
}

contract DeFiLending {
    struct Loan {
        address borrower;
        address collateralToken;
        address loanToken;
        uint256 collateralAmount;
        uint256 loanAmount;
        bool repaid;
    }

    IDEX public dex;
    address public owner;
    uint256 public collateralFactor = 150; // Collateral required in percent (150% of loan)
    uint256 public liquidationThreshold = 110; // Threshold to initiate liquidation

    mapping(address => mapping(address => uint256)) public lendBalances;
    mapping(address => Loan[]) public loans;

    constructor(IDEX _dex) {
        dex = _dex;
        owner = msg.sender;
    }

    function lend(address token, uint256 amount) external {
        IERC20(token).transferFrom(msg.sender, address(this), amount);
        lendBalances[msg.sender][token] += amount;
    }

    function borrow(address collateralToken, address loanToken, uint256 loanAmount) external {
        uint256 collateralAmount = calculateCollateralRequired(collateralToken, loanToken, loanAmount);
        IERC20(collateralToken).transferFrom(msg.sender, address(this), collateralAmount);

        require(lendBalances[address(this)][loanToken] >= loanAmount, "Insufficient lending balance");

        IERC20(loanToken).transfer(msg.sender, loanAmount);
        loans[msg.sender].push(Loan(msg.sender, collateralToken, loanToken, collateralAmount, loanAmount, false));
    }

    function calculateCollateralRequired(address collateralToken, address loanToken, uint256 loanAmount) internal view returns (uint256) {
        uint256 reserveRatio = dex.getReserveRatio(collateralToken, loanToken);
        return (loanAmount * collateralFactor * reserveRatio) / (100 * 1e18);
    }

    function checkLiquidation(address borrower, uint256 loanIndex) external {
        Loan storage loan = loans[borrower][loanIndex];
        require(!loan.repaid, "Loan already repaid");

        uint256 reserveRatio = dex.getReserveRatio(loan.collateralToken, loan.loanToken);
        uint256 collateralValue = (loan.collateralAmount * reserveRatio) / 1e18;
        uint256 loanValue = loan.loanAmount;

        if (collateralValue * 100 < loanValue * liquidationThreshold) {
            liquidate(borrower, loanIndex);
        }
    }

    function liquidate(address borrower, uint256 loanIndex) internal {
        Loan storage loan = loans[borrower][loanIndex];
        require(!loan.repaid, "Loan already repaid");

        IERC20(loan.collateralToken).transfer(owner, loan.collateralAmount);
        loan.repaid = true;
    }

    function repay(address borrower, uint256 loanIndex) external {
        Loan storage loan = loans[borrower][loanIndex];
        require(!loan.repaid, "Loan already repaid");

        IERC20(loan.loanToken).transferFrom(msg.sender, address(this), loan.loanAmount);
        IERC20(loan.collateralToken).transfer(loan.borrower, loan.collateralAmount);
        loan.repaid = true;
    }
}