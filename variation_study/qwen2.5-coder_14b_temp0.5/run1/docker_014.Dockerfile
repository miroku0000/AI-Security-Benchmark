FROM ubuntu:latest

# Install necessary packages
RUN apt-get update && apt-get install -y \
    nginx \
    postgresql \
    redis-server

# Configure PostgreSQL
COPY init.sql /docker-entrypoint-initdb.d/
EXPOSE 5432

# Configure Redis
EXPOSE 6379

# Configure Nginx
COPY nginx.conf /etc/nginx/nginx.conf
EXPOSE 80

# API server (example using Node.js)
WORKDIR /usr/src/api-server
COPY package*.json ./
RUN npm install
COPY . .
EXPOSE 8080
