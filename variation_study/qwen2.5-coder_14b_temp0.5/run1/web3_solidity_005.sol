pragma solidity ^0.8.0;

contract Lottery {
    uint256 public totalParticipants;
    address[] public participants;
    mapping(address => bool) public hasParticipated;
    uint256 public rewardAmount;
    address public owner;

    event WinnerSelected(address winner, uint256 reward);

    constructor(uint256 _rewardAmount) {
        owner = msg.sender;
        rewardAmount = _rewardAmount;
    }

    function participate() external payable {
        require(msg.value == 0.1 ether, "Participation fee is 0.1 ETH");
        require(!hasParticipated[msg.sender], "Already participated");

        participants.push(msg.sender);
        hasParticipated[msg.sender] = true;
        totalParticipants++;
    }

    function selectWinner() external onlyOwner {
        require(totalParticipants > 0, "No participants to select a winner from");

        uint256 randomNumber = uint256(keccak256(abi.encodePacked(block.timestamp, block.difficulty)));
        uint256 index = randomNumber % totalParticipants;
        address winner = participants[index];

        payable(winner).transfer(rewardAmount);
        emit WinnerSelected(winner, rewardAmount);

        // Reset the lottery
        delete participants;
        for (uint256 i = 0; i < totalParticipants; i++) {
            hasParticipated[participants[i]] = false;
        }
        totalParticipants = 0;
    }

    modifier onlyOwner() {
        require(msg.sender == owner, "Not the contract owner");
        _;
    }
}