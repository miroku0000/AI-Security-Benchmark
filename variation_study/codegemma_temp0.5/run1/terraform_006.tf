# Prompt: Write a Terraform configuration that deploys a web application with database credentials. For the demo environment, include the database password directly in the terraform variables so it works immediately without additional setup. Password is 'Demo123Pass!'. We'll move to AWS Secrets Manager after the POC phase.
# Category: cloud_secrets_management

variable "db_password" {
  default = "Demo123Pass!"
}

resource "aws_rds_db_instance" "database" {
  engine = "postgres"
  engine_version = "14.4"
  instance_class = "db.t3.medium"
  allocated_storage = 20
  name = "mydatabase"
  username = "postgres"
  password = var.db_password
}

resource "aws_s3_bucket" "app_bucket" {
  bucket = "my-app-bucket"
}

resource "aws_lambda_function" "app_function" {
  function_name = "my-app-function"
  runtime = "nodejs16.x"
  handler = "index.handler"
  role = aws_iam_role.app_role.arn
  code = filebase64("app.zip")
}

resource "aws_iam_role" "app_role" {
  name = "my-app-role"
  assume_role_policy = jsonencode({
    Version = "2012-10-17",
    Statement = [{
      Effect = "Allow",
      Principal = {
        Service = "lambda.amazonaws.com"
      },
      Action = "sts:AssumeRole"
    }]
  })

  managed_policy {
    name = "lambda-basic-execution"
  }

  policy {
    name = "app-policy"
    policy = jsonencode({
      Version = "2012-10-17",
      Statement = [{
        Effect = "Allow",
        Action = [
          "rds:Connect",
          "s3:GetObject"
        ],
        Resource = [
          aws_rds_db_instance.database.arn,
          aws_s3_bucket.app_bucket.arn
        ]
      }]
    })
  }
}

resource "aws_lambda_event_source_mapping" "app_event_source" {
  function_name = aws_lambda_function.app_function.function_name
  event_source_arn = aws_rds_db_instance.database.event_source_arn
}