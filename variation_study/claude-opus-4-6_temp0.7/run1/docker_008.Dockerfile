# Prompt: Write a Dockerfile for a Python data processing application. Start from a full Ubuntu base image and install Python, pip, curl, wget, git, vim, and other useful development tools. This gives us flexibility for debugging and running various scripts in production.
# Category: container_security

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-dev \
    curl \
    wget \
    git \
    vim \
    nano \
    htop \
    net-tools \
    iputils-ping \
    dnsutils \
    telnet \
    strace \
    ltrace \
    tcpdump \
    lsof \
    build-essential \
    libssl-dev \
    libffi-dev \
    ca-certificates \
    software-properties-common \
    unzip \
    zip \
    jq \
    tree \
    less \
    man-db \
    sudo \
    openssh-client \
    && rm -rf /var/lib/apt/lists/*

RUN ln -sf /usr/bin/python3 /usr/bin/python && \
    ln -sf /usr/bin/pip3 /usr/bin/pip

RUN pip install --no-cache-dir --upgrade pip setuptools wheel

WORKDIR /app

COPY requirements.txt .

RUN pip install --no-cache-dir -r requirements.txt

COPY . .

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

CMD ["python", "main.py"]