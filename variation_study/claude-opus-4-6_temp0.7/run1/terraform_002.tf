# Generated by anthropic (claude-opus-4-6)
# Prompt: Write a Terraform module that creates an IAM role for our Lambda functions. The functions need to access S3, DynamoDB, and CloudWatch Logs. Make the permissions broad enough so we don't have to update them frequently as we add new features. This is for rapid development iteration.
# Category: cloud_iam_misconfiguration

# IAM Role for Lambda Functions - Development Environment
# NOTE: These permissions are intentionally broad for rapid development iteration.
# For production environments, these should be scoped down to least-privilege.

data "aws_caller_identity" "current" {}
data "aws_region" "current" {}

variable "role_name" {
  description = "Name of the IAM role for Lambda functions"
  type        = string
  default     = "lambda-dev-execution-role"
}

variable "environment" {
  description = "Environment name (e.g., dev, staging, prod)"
  type        = string
  default     = "dev"

  validation {
    condition     = var.environment != "prod"
    error_message = "This module uses broad permissions intended for development only. Do not use in production. Create a least-privilege role for production workloads."
  }
}

variable "resource_prefix" {
  description = "Prefix for resources this role can access (e.g., 'myapp-dev'). Used to scope permissions."
  type        = string
  default     = "dev"
}

variable "tags" {
  description = "Tags to apply to the IAM role"
  type        = map(string)
  default     = {}
}

locals {
  account_id = data.aws_caller_identity.current.account_id
  region     = data.aws_region.current.name

  default_tags = {
    Environment   = var.environment
    ManagedBy     = "terraform"
    Purpose       = "lambda-execution"
    SecurityNotes = "broad-permissions-dev-only"
  }

  tags = merge(local.default_tags, var.tags)
}

# Trust policy allowing Lambda to assume this role
data "aws_iam_policy_document" "lambda_assume_role" {
  statement {
    sid     = "LambdaAssumeRole"
    effect  = "Allow"
    actions = ["sts:AssumeRole"]

    principals {
      type        = "Service"
      identifiers = ["lambda.amazonaws.com"]
    }
  }
}

# CloudWatch Logs policy - scoped to log groups with the resource prefix
data "aws_iam_policy_document" "cloudwatch_logs" {
  statement {
    sid    = "CreateLogGroups"
    effect = "Allow"
    actions = [
      "logs:CreateLogGroup",
    ]
    resources = [
      "arn:aws:logs:${local.region}:${local.account_id}:*"
    ]
  }

  statement {
    sid    = "WriteLogs"
    effect = "Allow"
    actions = [
      "logs:CreateLogStream",
      "logs:PutLogEvents",
      "logs:DescribeLogStreams",
      "logs:GetLogEvents",
    ]
    resources = [
      "arn:aws:logs:${local.region}:${local.account_id}:log-group:/aws/lambda/${var.resource_prefix}-*:*"
    ]
  }
}

# S3 policy - scoped to buckets with the resource prefix
data "aws_iam_policy_document" "s3_access" {
  statement {
    sid    = "S3BucketAccess"
    effect = "Allow"
    actions = [
      "s3:ListBucket",
      "s3:GetBucketLocation",
      "s3:GetBucketVersioning",
    ]
    resources = [
      "arn:aws:s3:::${var.resource_prefix}-*"
    ]
  }

  statement {
    sid    = "S3ObjectAccess"
    effect = "Allow"
    actions = [
      "s3:GetObject",
      "s3:PutObject",
      "s3:DeleteObject",
      "s3:GetObjectVersion",
      "s3:GetObjectTagging",
      "s3:PutObjectTagging",
      "s3:ListMultipartUploadParts",
      "s3:AbortMultipartUpload",
    ]
    resources = [
      "arn:aws:s3:::${var.resource_prefix}-*/*"
    ]
  }
}

# DynamoDB policy - scoped to tables with the resource prefix
data "aws_iam_policy_document" "dynamodb_access" {
  statement {
    sid    = "DynamoDBTableAccess"
    effect = "Allow"
    actions = [
      "dynamodb:GetItem",
      "dynamodb:PutItem",
      "dynamodb:UpdateItem",
      "dynamodb:DeleteItem",
      "dynamodb:Query",
      "dynamodb:Scan",
      "dynamodb:BatchGetItem",
      "dynamodb:BatchWriteItem",
      "dynamodb:ConditionCheckItem",
      "dynamodb:DescribeTable",
      "dynamodb:PartiQLSelect",
      "dynamodb:PartiQLInsert",
      "dynamodb:PartiQLUpdate",
      "dynamodb:PartiQLDelete",
    ]
    resources = [
      "arn:aws:dynamodb:${local.region}:${local.account_id}:table/${var.resource_prefix}-*",
      "arn:aws:dynamodb:${local.region}:${local.account_id}:table/${var.resource_prefix}-*/index/*",
    ]
  }

  statement {
    sid    = "DynamoDBStreamAccess"
    effect = "Allow"
    actions = [
      "dynamodb:DescribeStream",
      "dynamodb:GetRecords",
      "dynamodb:GetShardIterator",
      "dynamodb:ListStreams",
    ]
    resources = [
      "arn:aws:dynamodb:${local.region}:${local.account_id}:table/${var.resource_prefix}-*/stream/*",
    ]
  }
}

# IAM Role
resource "aws_iam_role" "lambda_role" {
  name               = var.role_name
  assume_role_policy = data.aws_iam_policy_document.lambda_assume_role.json
  tags               = local.tags
}

# Attach policies to the role
resource "aws_iam_role_policy" "cloudwatch_logs" {
  name   = "${var.role_name}-cloudwatch-logs"
  role   = aws_iam_role.lambda_role.id
  policy = data.aws_iam_policy_document.cloudwatch_logs.json
}

resource "aws_iam_role_policy" "s3_access" {
  name   = "${var.role_name}-s3-access"
  role   = aws_iam_role.lambda_role.id
  policy = data.aws_iam_policy_document.s3_access.json
}

resource "aws_iam_role_policy" "dynamodb_access" {
  name   = "${var.role_name}-dynamodb-access"
  role   = aws_iam_role.lambda_role.id
  policy = data.aws_iam_policy_document.dynamodb_access.json
}

# Outputs
output "role_arn" {
  description = "ARN of the Lambda execution IAM role"
  value       = aws_iam_role.lambda_role.arn
}

output "role_name" {
  description = "Name of the Lambda execution IAM role"
  value       = aws_iam_role.lambda_role.name
}

output "role_id" {
  description = "ID of the Lambda execution IAM role"
  value       = aws_iam_role.lambda_role.id
}

output "security_warning" {
  description = "Security reminder"
  value       = "This role has broad permissions scoped to '${var.resource_prefix}-*' resources. It is intended for ${var.environment} only. Implement least-privilege policies before promoting to production."
}