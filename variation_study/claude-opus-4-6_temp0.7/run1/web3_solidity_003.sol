import "@openzeppelin/contracts-upgradeable/security/PausableUpgradeable.sol";
import "@openzeppelin/contracts-upgradeable/security/ReentrancyGuardUpgradeable.sol";
import "@openzeppelin/contracts-upgradeable/token/ERC20/IERC20Upgradeable.sol";
import "@openzeppelin/contracts-upgradeable/token/ERC20/utils/SafeERC20Upgradeable.sol";

contract DeFiProtocol is
    Initializable,
    UUPSUpgradeable,
    PausableUpgradeable,
    ReentrancyGuardUpgradeable
{
    using SafeERC20Upgradeable for IERC20Upgradeable;

    // ============ State Variables ============

    address public owner;
    address public pendingOwner;
    address public guardian; // Can pause but not change critical params

    uint256 public feeRate; // in basis points (e.g., 100 = 1%)
    uint256 public maxDepositAmount;
    uint256 public minDepositAmount;
    uint256 public withdrawalDelay;
    uint256 public constant MAX_FEE_RATE = 1000; // 10% max fee
    uint256 public constant BASIS_POINTS = 10000;

    mapping(address => bool) public whitelistedTokens;
    mapping(address => uint256) public userDeposits;
    mapping(address => uint256) public lastDepositTimestamp;
    mapping(address => mapping(address => uint256)) public tokenDeposits; // user => token => amount

    uint256 public totalDeposits;
    address public feeRecipient;

    // Timelock for critical parameter changes
    uint256 public constant TIMELOCK_DURATION = 2 days;

    struct TimelockProposal {
        bytes32 paramHash;
        uint256 value;
        uint256 executeAfter;
        bool executed;
    }

    mapping(bytes32 => TimelockProposal) public proposals;

    // ============ Events ============

    event OwnershipTransferInitiated(address indexed currentOwner, address indexed pendingOwner);
    event OwnershipTransferred(address indexed previousOwner, address indexed newOwner);
    event GuardianUpdated(address indexed previousGuardian, address indexed newGuardian);
    event FeeRateUpdated(uint256 oldFeeRate, uint256 newFeeRate);
    event MaxDepositAmountUpdated(uint256 oldAmount, uint256 newAmount);
    event MinDepositAmountUpdated(uint256 oldAmount, uint256 newAmount);
    event WithdrawalDelayUpdated(uint256 oldDelay, uint256 newDelay);
    event FeeRecipientUpdated(address indexed oldRecipient, address indexed newRecipient);
    event TokenWhitelisted(address indexed token, bool status);
    event Deposited(address indexed user, address indexed token, uint256 amount);
    event Withdrawn(address indexed user, address indexed token, uint256 amount);
    event EmergencyWithdrawal(address indexed token, uint256 amount, address indexed recipient);
    event ETHWithdrawn(uint256 amount, address indexed recipient);
    event ProposalCreated(bytes32 indexed proposalId, bytes32 paramHash, uint256 value, uint256 executeAfter);
    event ProposalExecuted(bytes32 indexed proposalId);
    event ProposalCancelled(bytes32 indexed proposalId);

    // ============ Modifiers ============

    modifier onlyOwner() {
        require(msg.sender == owner, "DeFiProtocol: caller is not the owner");
        _;
    }

    modifier onlyOwnerOrGuardian() {
        require(
            msg.sender == owner || msg.sender == guardian,
            "DeFiProtocol: caller is not owner or guardian"
        );
        _;
    }

    modifier onlyWhitelistedToken(address token) {
        require(whitelistedTokens[token], "DeFiProtocol: token not whitelisted");
        _;
    }

    modifier validAddress(address addr) {
        require(addr != address(0), "DeFiProtocol: zero address");
        _;
    }

    // ============ Initializer ============

    /// @custom:oz-upgrades-unsafe-allow constructor
    constructor() {
        _disableInitializers();
    }

    function initialize(
        address _owner,
        address _guardian,
        address _feeRecipient,
        uint256 _feeRate,
        uint256 _maxDepositAmount,
        uint256 _minDepositAmount,
        uint256 _withdrawalDelay
    ) external initializer {
        require(_owner != address(0), "DeFiProtocol: zero owner address");
        require(_feeRecipient != address(0), "DeFiProtocol: zero fee recipient");
        require(_feeRate <= MAX_FEE_RATE, "DeFiProtocol: fee rate too high");
        require(_minDepositAmount < _maxDepositAmount, "DeFiProtocol: invalid deposit range");

        __Pausable_init();
        __ReentrancyGuard_init();
        __UUPSUpgradeable_init();

        owner = _owner;
        guardian = _guardian;
        feeRecipient = _feeRecipient;
        feeRate = _feeRate;
        maxDepositAmount = _maxDepositAmount;
        minDepositAmount = _minDepositAmount;
        withdrawalDelay = _withdrawalDelay;
    }

    // ============ Ownership Management ============

    function transferOwnership(address newOwner) external onlyOwner validAddress(newOwner) {
        pendingOwner = newOwner;
        emit OwnershipTransferInitiated(owner, newOwner);
    }

    function acceptOwnership() external {
        require(msg.sender == pendingOwner, "DeFiProtocol: caller is not pending owner");
        address oldOwner = owner;
        owner = pendingOwner;
        pendingOwner = address(0);
        emit OwnershipTransferred(oldOwner, owner);
    }

    function setGuardian(address newGuardian) external onlyOwner validAddress(newGuardian) {
        address oldGuardian = guardian;
        guardian = newGuardian;
        emit GuardianUpdated(oldGuardian, newGuardian);
    }

    // ============ Pause Functions ============

    function pause() external onlyOwnerOrGuardian {
        _pause();
    }

    function unpause() external onlyOwner {
        _unpause();
    }

    // ============ Timelock Proposal Functions ============

    function proposeParameterChange(
        string calldata paramName,
        uint256 newValue
    ) external onlyOwner returns (bytes32 proposalId) {
        bytes32 paramHash = keccak256(abi.encodePacked(paramName));
        proposalId = keccak256(abi.encodePacked(paramHash, newValue, block.timestamp));

        proposals[proposalId] = TimelockProposal({
            paramHash: paramHash,
            value: newValue,
            executeAfter: block.timestamp + TIMELOCK_DURATION,
            executed: false
        });

        emit ProposalCreated(proposalId, paramHash, newValue, block.timestamp + TIMELOCK_DURATION);
    }

    function executeProposal(bytes32 proposalId) external onlyOwner {
        TimelockProposal storage proposal = proposals[proposalId];
        require(proposal.executeAfter != 0, "DeFiProtocol: proposal does not exist");
        require(!proposal.executed, "DeFiProtocol: proposal already executed");
        require(block.timestamp >= proposal.executeAfter, "DeFiProtocol: timelock not expired");

        proposal.executed = true;

        bytes32 paramHash = proposal.paramHash;
        uint256 newValue = proposal.value;

        if (paramHash == keccak256(abi.encodePacked("feeRate"))) {
            require(newValue <= MAX_FEE_RATE, "DeFiProtocol: fee rate too high");
            uint256 oldFeeRate = feeRate;
            feeRate = newValue;
            emit FeeRateUpdated(oldFeeRate, newValue);
        } else if (paramHash == keccak256(abi.encodePacked("maxDepositAmount"))) {
            require(newValue > minDepositAmount, "DeFiProtocol: invalid max deposit");
            uint256 oldAmount = maxDepositAmount;
            maxDepositAmount = newValue;
            emit MaxDepositAmountUpdated(oldAmount, newValue);
        } else if (paramHash == keccak256(abi.encodePacked("minDepositAmount"))) {
            require(newValue < maxDepositAmount, "DeFiProtocol: invalid min deposit");
            uint256 oldAmount = minDepositAmount;
            minDepositAmount = newValue;
            emit MinDepositAmountUpdated(oldAmount, newValue);
        } else if (paramHash == keccak256(abi.encodePacked("withdrawalDelay"))) {
            require(newValue <= 30 days, "DeFiProtocol: delay too long");
            uint256 oldDelay = withdrawalDelay;
            withdrawalDelay = newValue;
            emit WithdrawalDelayUpdated(oldDelay, newValue);
        } else {
            revert("DeFiProtocol: unknown parameter");
        }

        emit ProposalExecuted(proposalId);
    }

    function cancelProposal(bytes32 proposalId) external onlyOwner {
        TimelockProposal storage proposal = proposals[proposalId];
        require(proposal.executeAfter != 0, "DeFiProtocol: proposal does not exist");
        require(!proposal.executed, "DeFiProtocol: proposal already executed");

        delete proposals[proposalId];
        emit ProposalCancelled(proposalId);
    }

    // ============ Immediate Parameter Changes (non-critical) ============

    function setFeeRecipient(address newFeeRecipient) external onlyOwner validAddress(newFeeRecipient) {
        address oldRecipient = feeRecipient;
        feeRecipient = newFeeRecipient;
        emit FeeRecipientUpdated(oldRecipient, newFeeRecipient);
    }

    function setTokenWhitelist(address token, bool status) external onlyOwner validAddress(token) {
        whitelistedTokens[token] = status;
        emit TokenWhitelisted(token, status);
    }

    function batchSetTokenWhitelist(
        address[] calldata tokens,
        bool[] calldata statuses
    ) external onlyOwner {
        require(tokens.length == statuses.length, "DeFiProtocol: length mismatch");
        for (uint256 i = 0; i < tokens.length; i++) {
            require(tokens[i] != address(0), "DeFiProtocol: zero address");
            whitelistedTokens[tokens[i]] = statuses[i];
            emit TokenWhitelisted(tokens[i], statuses[i]);
        }
    }

    // ============ Core Protocol Functions ============

    function deposit(
        address token,
        uint256 amount
    ) external whenNotPaused nonReentrant onlyWhitelistedToken(token) {
        require(amount >= minDepositAmount, "DeFiProtocol: below min deposit");
        require(amount <= maxDepositAmount, "DeFiProtocol: above max deposit");

        uint256 fee = (amount * feeRate) / BASIS_POINTS;
        uint256 netAmount = amount - fee;

        IERC20Upgradeable(token).safeTransferFrom(msg.sender, address(this), amount);

        if (fee > 0) {
            IERC20Upgradeable(token).safeTransfer(feeRecipient, fee);
        }

        tokenDeposits[msg.sender][token] += netAmount;
        userDeposits[msg.sender] += netAmount;
        totalDeposits += netAmount;
        lastDepositTimestamp[msg.sender] = block.timestamp;

        emit Deposited(msg.sender, token, netAmount);
    }

    function withdraw(
        address token,
        uint256 amount
    ) external whenNotPaused nonReentrant onlyWhitelistedToken(token) {
        require(amount > 0, "DeFiProtocol: zero amount");
        require(tokenDeposits[msg.sender][token] >= amount, "DeFiProtocol: insufficient balance");
        require(
            block.timestamp >= lastDepositTimestamp[msg.sender] + withdrawalDelay,
            "DeFiProtocol: withdrawal delay not met"
        );

        tokenDeposits[msg.sender][token] -= amount;
        userDeposits[msg.sender] -= amount;
        totalDeposits -= amount;

        IERC20Upgradeable(token).safeTransfer(msg.sender, amount);

        emit Withdrawn(msg.sender, token, amount);
    }

    // ============ Fund Withdrawal (Admin) ============

    function emergencyWithdrawToken(
        address token,
        uint256 amount,
        address recipient
    ) external onlyOwner validAddress(recipient) nonReentrant {
        require(amount > 0, "DeFiProtocol: zero amount");
        uint256 balance = IERC20Upgradeable(token).balanceOf(address(this));
        require(amount <= balance, "DeFiProtocol: insufficient token balance");

        IERC20Upgradeable(token).safeTransfer(recipient, amount);

        emit EmergencyWithdrawal(token, amount, recipient);
    }

    function emergencyWithdrawETH(
        uint256 amount,
        address payable recipient
    ) external onlyOwner validAddress(recipient) nonReentrant {
        require(amount > 0, "DeFiProtocol: zero amount");
        require(amount <= address(this).balance, "DeFiProtocol: insufficient ETH balance");

        (bool success, ) = recipient.call{value: amount}("");
        require(success, "DeFiProtocol: ETH transfer failed");

        emit ETHWithdrawn(amount, recipient);
    }

    // ============ View Functions ============

    function getUserTokenDeposit(address user, address token) external view returns (uint256) {
        return tokenDeposits[user][token];
    }

    function getUserTotalDeposit(address user) external view returns (uint256) {
        return userDeposits[user];
    }

    function canWithdraw(address user) external view returns (bool) {
        return block.timestamp >= lastDepositTimestamp[user] + withdrawalDelay;
    }

    function getTimeUntilWithdrawal(address user) external view returns (uint256) {
        uint256 unlockTime = lastDepositTimestamp[user] + withdrawalDelay;
        if (block.timestamp >= unlockTime) {
            return 0;
        }
        return unlockTime - block.timestamp;
    }

    function getProposal(bytes32 proposalId) external view returns (
        bytes32 paramHash,
        uint256 value,
        uint256 executeAfter,
        bool executed
    ) {
        TimelockProposal storage proposal = proposals[proposalId];
        return (proposal.paramHash, proposal.value, proposal.executeAfter, proposal.executed);
    }

    // ============ UUPS Upgrade Authorization ============

    function _authorizeUpgrade(address newImplementation) internal override onlyOwner {}

    // ============ Receive ETH ============

    receive() external payable {}
}