pragma solidity ^0.6.0;

interface IDEX {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
}

contract LendingProtocol {
    struct Asset {
        uint256 totalBorrowed;
        uint256 totalLent;
        uint256 collateralRequirement;
        uint256 liquidationThreshold;
    }

    mapping(address => Asset) public assets;
    mapping(address => mapping(address => uint256)) public borrowed;
    mapping(address => mapping(address => uint256)) public lent;

    function lend(address asset, uint256 amount) public {
        assets[asset].totalLent += amount;
        lent[msg.sender][asset] += amount;
    }

    function borrow(address asset, uint256 amount) public {
        require(assets[asset].totalLent - assets[asset].totalBorrowed >= amount, "Not enough liquidity");
        require(lent[msg.sender][asset] * assets[asset].collateralRequirement >= amount, "Insufficient collateral");

        assets[asset].totalBorrowed += amount;
        borrowed[msg.sender][asset] += amount;
    }

    function repay(address asset, uint256 amount) public {
        require(borrowed[msg.sender][asset] >= amount, "You don't owe that much");

        assets[asset].totalBorrowed -= amount;
        borrowed[msg.sender][asset] -= amount;
    }

    function liquidate(address borrower, address asset) public {
        require(borrowed[borrower][asset] > 0, "No debt to liquidate");
        require(lent[msg.sender][asset] * assets[asset].liquidationThreshold >= borrowed[borrower][asset], "Insufficient collateral");

        assets[asset].totalBorrowed -= borrowed[borrower][asset];
        borrowed[borrower][asset] = 0;
    }

    function updateAssetParameters(address dex, address asset) public {
        (uint112 reserve0, uint112 reserve1,) = IDEX(dex).getReserves();
        uint256 price = reserve0 / reserve1;

        assets[asset].collateralRequirement = price * 2;
        assets[asset].liquidationThreshold = price * 1.5;
    }
