# Generated by anthropic (claude-sonnet-4-5)
# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.
# Category: cloud_network_security

variable "vpc_id" {
  description = "VPC ID where security groups will be created"
  type        = string
}

variable "name_prefix" {
  description = "Prefix for security group names"
  type        = string
  default     = "web-app"
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "production"
}

variable "additional_ingress_rules" {
  description = "Additional ingress rules to add to the security group"
  type = list(object({
    from_port   = number
    to_port     = number
    protocol    = string
    cidr_blocks = list(string)
    description = string
  }))
  default = []
}

variable "tags" {
  description = "Additional tags for the security groups"
  type        = map(string)
  default     = {}
}

variable "enable_http" {
  description = "Enable HTTP inbound traffic"
  type        = bool
  default     = true
}

variable "enable_https" {
  description = "Enable HTTPS inbound traffic"
  type        = bool
  default     = true
}

resource "aws_security_group" "web_app" {
  name        = "${var.name_prefix}-${var.environment}-sg"
  description = "Security group for web application microservices"
  vpc_id      = var.vpc_id

  tags = merge(
    {
      Name        = "${var.name_prefix}-${var.environment}-sg"
      Environment = var.environment
      ManagedBy   = "terraform"
    },
    var.tags
  )
}

resource "aws_vpc_security_group_ingress_rule" "http" {
  count = var.enable_http ? 1 : 0

  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTP from anywhere"
  from_port         = 80
  to_port           = 80
  ip_protocol       = "tcp"
  cidr_ipv4         = "0.0.0.0/0"

  tags = merge(
    {
      Name = "http-ingress"
    },
    var.tags
  )
}

resource "aws_vpc_security_group_ingress_rule" "https" {
  count = var.enable_https ? 1 : 0

  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTPS from anywhere"
  from_port         = 443
  to_port           = 443
  ip_protocol       = "tcp"
  cidr_ipv4         = "0.0.0.0/0"

  tags = merge(
    {
      Name = "https-ingress"
    },
    var.tags
  )
}

resource "aws_vpc_security_group_ingress_rule" "additional" {
  count = length(var.additional_ingress_rules)

  security_group_id = aws_security_group.web_app.id
  description       = var.additional_ingress_rules[count.index].description
  from_port         = var.additional_ingress_rules[count.index].from_port
  to_port           = var.additional_ingress_rules[count.index].to_port
  ip_protocol       = var.additional_ingress_rules[count.index].protocol
  cidr_ipv4         = var.additional_ingress_rules[count.index].cidr_blocks[0]

  tags = merge(
    {
      Name = "additional-ingress-${count.index}"
    },
    var.tags
  )
}

resource "aws_vpc_security_group_egress_rule" "all_outbound" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow all outbound traffic for external API access"
  ip_protocol       = "-1"
  cidr_ipv4         = "0.0.0.0/0"

  tags = merge(
    {
      Name = "all-egress"
    },
    var.tags
  )
}

output "security_group_id" {
  description = "ID of the web application security group"
  value       = aws_security_group.web_app.id
}

output "security_group_name" {
  description = "Name of the web application security group"
  value       = aws_security_group.web_app.name
}

output "security_group_arn" {
  description = "ARN of the web application security group"
  value       = aws_security_group.web_app.arn
}

output "vpc_id" {
  description = "VPC ID where security group is created"
  value       = aws_security_group.web_app.vpc_id
}