contract DeFiLendingProtocol {
    struct Market {
        bool isListed;
        uint256 collateralFactor;
        uint256 liquidationThreshold;
        uint256 totalSupply;
        uint256 totalBorrows;
        uint256 borrowIndex;
        uint256 supplyIndex;
        uint256 accrualBlockNumber;
        uint256 borrowRatePerBlock;
        uint256 supplyRatePerBlock;
        address dexPair;
        bool isPair0;
        address priceReferenceToken;
    }

    struct AccountSnapshot {
        uint256 supplied;
        uint256 borrowed;
        uint256 borrowIndex;
        uint256 supplyIndex;
    }

    mapping(address => Market) public markets;
    mapping(address => mapping(address => AccountSnapshot)) public accountAssets;
    
    address[] public allMarkets;
    address public admin;
    address public priceReferenceToken;
    
    uint256 public constant COLLATERAL_FACTOR_MANTISSA = 1e18;
    uint256 public constant LIQUIDATION_INCENTIVE = 108e16;
    uint256 public constant CLOSE_FACTOR = 5e17;
    uint256 public constant BASE_RATE = 2e16;
    uint256 public constant MULTIPLIER = 1e17;
    uint256 public constant JUMP_MULTIPLIER = 5e17;
    uint256 public constant KINK = 8e17;
    uint256 public constant BLOCKS_PER_YEAR = 2628000;

    event MarketListed(address indexed token, uint256 collateralFactor, uint256 liquidationThreshold);
    event Supply(address indexed user, address indexed token, uint256 amount);
    event Withdraw(address indexed user, address indexed token, uint256 amount);
    event Borrow(address indexed user, address indexed token, uint256 amount);
    event RepayBorrow(address indexed user, address indexed token, uint256 amount);
    event Liquidate(address indexed liquidator, address indexed borrower, address indexed tokenBorrowed, address tokenCollateral, uint256 repayAmount, uint256 seizeAmount);
    event NewAdmin(address indexed oldAdmin, address indexed newAdmin);

    modifier onlyAdmin() {
        require(msg.sender == admin, "Only admin");
        _;
    }

    constructor(address _priceReferenceToken) {
        admin = msg.sender;
        priceReferenceToken = _priceReferenceToken;
    }

    function listMarket(
        address token,
        uint256 collateralFactor,
        uint256 liquidationThreshold,
        address dexPair,
        bool isPair0
    ) external onlyAdmin {
        require(!markets[token].isListed, "Market already listed");
        require(collateralFactor <= COLLATERAL_FACTOR_MANTISSA, "Invalid collateral factor");
        require(liquidationThreshold >= collateralFactor && liquidationThreshold <= COLLATERAL_FACTOR_MANTISSA, "Invalid liquidation threshold");

        markets[token] = Market({
            isListed: true,
            collateralFactor: collateralFactor,
            liquidationThreshold: liquidationThreshold,
            totalSupply: 0,
            totalBorrows: 0,
            borrowIndex: COLLATERAL_FACTOR_MANTISSA,
            supplyIndex: COLLATERAL_FACTOR_MANTISSA,
            accrualBlockNumber: block.number,
            borrowRatePerBlock: 0,
            supplyRatePerBlock: 0,
            dexPair: dexPair,
            isPair0: isPair0,
            priceReferenceToken: priceReferenceToken
        });

        allMarkets.push(token);
        emit MarketListed(token, collateralFactor, liquidationThreshold);
    }

    function supply(address token, uint256 amount) external {
        require(markets[token].isListed, "Market not listed");
        require(amount > 0, "Amount must be greater than 0");

        accrueInterest(token);

        IERC20(token).transferFrom(msg.sender, address(this), amount);

        uint256 supplyIndexStored = markets[token].supplyIndex;
        AccountSnapshot storage account = accountAssets[token][msg.sender];

        if (account.supplied > 0) {
            uint256 supplierDelta = (account.supplied * (supplyIndexStored - account.supplyIndex)) / COLLATERAL_FACTOR_MANTISSA;
            account.supplied += supplierDelta;
        }

        account.supplied += amount;
        account.supplyIndex = supplyIndexStored;

        markets[token].totalSupply += amount;

        emit Supply(msg.sender, token, amount);
    }

    function withdraw(address token, uint256 amount) external {
        require(markets[token].isListed, "Market not listed");
        require(amount > 0, "Amount must be greater than 0");

        accrueInterest(token);

        AccountSnapshot storage account = accountAssets[token][msg.sender];
        uint256 supplyIndexStored = markets[token].supplyIndex;

        if (account.supplied > 0) {
            uint256 supplierDelta = (account.supplied * (supplyIndexStored - account.supplyIndex)) / COLLATERAL_FACTOR_MANTISSA;
            account.supplied += supplierDelta;
        }

        require(account.supplied >= amount, "Insufficient balance");

        account.supplied -= amount;
        account.supplyIndex = supplyIndexStored;
        markets[token].totalSupply -= amount;

        (uint256 liquidity, uint256 shortfall) = getAccountLiquidity(msg.sender);
        require(shortfall == 0, "Insufficient liquidity");

        IERC20(token).transfer(msg.sender, amount);

        emit Withdraw(msg.sender, token, amount);
    }

    function borrow(address token, uint256 amount) external {
        require(markets[token].isListed, "Market not listed");
        require(amount > 0, "Amount must be greater than 0");

        accrueInterest(token);

        (uint256 liquidity, uint256 shortfall) = getAccountLiquidityInternal(msg.sender, token, 0, amount);
        require(shortfall == 0, "Insufficient liquidity");

        AccountSnapshot storage account = accountAssets[token][msg.sender];
        uint256 borrowIndexStored = markets[token].borrowIndex;

        if (account.borrowed > 0) {
            uint256 borrowerDelta = (account.borrowed * (borrowIndexStored - account.borrowIndex)) / COLLATERAL_FACTOR_MANTISSA;
            account.borrowed += borrowerDelta;
        }

        account.borrowed += amount;
        account.borrowIndex = borrowIndexStored;
        markets[token].totalBorrows += amount;

        IERC20(token).transfer(msg.sender, amount);

        emit Borrow(msg.sender, token, amount);
    }

    function repayBorrow(address token, uint256 amount) external {
        require(markets[token].isListed, "Market not listed");
        require(amount > 0, "Amount must be greater than 0");

        accrueInterest(token);

        AccountSnapshot storage account = accountAssets[token][msg.sender];
        uint256 borrowIndexStored = markets[token].borrowIndex;

        if (account.borrowed > 0) {
            uint256 borrowerDelta = (account.borrowed * (borrowIndexStored - account.borrowIndex)) / COLLATERAL_FACTOR_MANTISSA;
            account.borrowed += borrowerDelta;
        }

        uint256 repayAmount = amount > account.borrowed ? account.borrowed : amount;

        IERC20(token).transferFrom(msg.sender, address(this), repayAmount);

        account.borrowed -= repayAmount;
        account.borrowIndex = borrowIndexStored;
        markets[token].totalBorrows -= repayAmount;

        emit RepayBorrow(msg.sender, token, repayAmount);
    }

    function liquidate(
        address borrower,
        address tokenBorrowed,
        address tokenCollateral,
        uint256 repayAmount
    ) external {
        require(markets[tokenBorrowed].isListed && markets[tokenCollateral].isListed, "Market not listed");
        require(msg.sender != borrower, "Cannot liquidate self");
        require(repayAmount > 0, "Amount must be greater than 0");

        accrueInterest(tokenBorrowed);
        accrueInterest(tokenCollateral);

        (uint256 liquidity, uint256 shortfall) = getAccountLiquidity(borrower);
        require(shortfall > 0, "Borrower not underwater");

        AccountSnapshot storage borrowAccount = accountAssets[tokenBorrowed][borrower];
        uint256 borrowIndexStored = markets[tokenBorrowed].borrowIndex;

        if (borrowAccount.borrowed > 0) {
            uint256 borrowerDelta = (borrowAccount.borrowed * (borrowIndexStored - borrowAccount.borrowIndex)) / COLLATERAL_FACTOR_MANTISSA;
            borrowAccount.borrowed += borrowerDelta;
        }

        uint256 maxClose = (borrowAccount.borrowed * CLOSE_FACTOR) / COLLATERAL_FACTOR_MANTISSA;
        require(repayAmount <= maxClose, "Repay amount too high");

        IERC20(tokenBorrowed).transferFrom(msg.sender, address(this), repayAmount);

        borrowAccount.borrowed -= repayAmount;
        borrowAccount.borrowIndex = borrowIndexStored;
        markets[tokenBorrowed].totalBorrows -= repayAmount;

        uint256 seizeAmount = calculateSeizeTokens(tokenBorrowed, tokenCollateral, repayAmount);

        AccountSnapshot storage collateralAccount = accountAssets[tokenCollateral][borrower];
        uint256 supplyIndexStored = markets[tokenCollateral].supplyIndex;

        if (collateralAccount.supplied > 0) {
            uint256 supplierDelta = (collateralAccount.supplied * (supplyIndexStored - collateralAccount.supplyIndex)) / COLLATERAL_FACTOR_MANTISSA;
            collateralAccount.supplied += supplierDelta;
        }

        require(collateralAccount.supplied >= seizeAmount, "Insufficient collateral");

        collateralAccount.supplied -= seizeAmount;
        collateralAccount.supplyIndex = supplyIndexStored;
        markets[tokenCollateral].totalSupply -= seizeAmount;

        AccountSnapshot storage liquidatorCollateral = accountAssets[tokenCollateral][msg.sender];
        if (liquidatorCollateral.supplied > 0) {
            uint256 supplierDelta = (liquidatorCollateral.supplied * (supplyIndexStored - liquidatorCollateral.supplyIndex)) / COLLATERAL_FACTOR_MANTISSA;
            liquidatorCollateral.supplied += supplierDelta;
        }
        liquidatorCollateral.supplied += seizeAmount;
        liquidatorCollateral.supplyIndex = supplyIndexStored;
        markets[tokenCollateral].totalSupply += seizeAmount;

        emit Liquidate(msg.sender, borrower, tokenBorrowed, tokenCollateral, repayAmount, seizeAmount);
    }

    function calculateSeizeTokens(
        address tokenBorrowed,
        address tokenCollateral,
        uint256 repayAmount
    ) public view returns (uint256) {
        uint256 priceBorrowed = getPrice(tokenBorrowed);
        uint256 priceCollateral = getPrice(tokenCollateral);

        uint256 exchangeRate = (priceBorrowed * COLLATERAL_FACTOR_MANTISSA) / priceCollateral;
        uint256 seizeAmount = (repayAmount * exchangeRate) / COLLATERAL_FACTOR_MANTISSA;
        uint256 incentivizedSeize = (seizeAmount * LIQUIDATION_INCENTIVE) / COLLATERAL_FACTOR_MANTISSA;

        return incentivizedSeize;
    }

    function getAccountLiquidity(address account) public view returns (uint256, uint256) {
        return getAccountLiquidityInternal(account, address(0), 0, 0);
    }

    function getAccountLiquidityInternal(
        address account,
        address modifyToken,
        uint256 redeemTokens,
        uint256 borrowAmount
    ) internal view returns (uint256, uint256) {
        uint256 sumCollateral = 0;
        uint256 sumBorrowPlusEffects = 0;

        for (uint256 i = 0; i < allMarkets.length; i++) {
            address token = allMarkets[i];
            Market storage market = markets[token];
            AccountSnapshot storage snapshot = accountAssets[token][account];

            uint256 oraclePrice = getPrice(token);
            uint256 collateralFactor = market.collateralFactor;
            uint256 exchangeRate = COLLATERAL_FACTOR_MANTISSA;

            uint256 supplied = snapshot.supplied;
            uint256 borrowed = snapshot.borrowed;

            if (supplied > 0) {
                uint256 supplierDelta = (supplied * (market.supplyIndex - snapshot.supplyIndex)) / COLLATERAL_FACTOR_MANTISSA;
                supplied += supplierDelta;
            }

            if (borrowed > 0) {
                uint256 borrowerDelta = (borrowed * (market.borrowIndex - snapshot.borrowIndex)) / COLLATERAL_FACTOR_MANTISSA;
                borrowed += borrowerDelta;
            }

            if (token == modifyToken) {
                supplied = supplied > redeemTokens ? supplied - redeemTokens : 0;
                borrowed += borrowAmount;
            }

            uint256 tokensToDenom = (supplied * exchangeRate) / COLLATERAL_FACTOR_MANTISSA;
            sumCollateral += (tokensToDenom * oraclePrice * collateralFactor) / COLLATERAL_FACTOR_MANTISSA / COLLATERAL_FACTOR_MANTISSA;
            sumBorrowPlusEffects += (borrowed * oraclePrice) / COLLATERAL_FACTOR_MANTISSA;
        }

        if (sumCollateral > sumBorrowPlusEffects) {
            return (sumCollateral - sumBorrowPlusEffects, 0);
        } else {
            return (0, sumBorrowPlusEffects - sumCollateral);
        }
    }

    function getPrice(address token) public view returns (uint256) {
        Market storage market = markets[token];
        
        if (token == priceReferenceToken) {
            return COLLATERAL_FACTOR_MANTISSA;
        }

        IDEXPair pair = IDEXPair(market.dexPair);
        (uint112 reserve0, uint112 reserve1,) = pair.getReserves();

        uint256 tokenReserve;
        uint256 referenceReserve;

        if (market.isPair0) {
            tokenReserve = uint256(reserve0);
            referenceReserve = uint256(reserve1);
        } else {
            tokenReserve = uint256(reserve1);
            referenceReserve = uint256(reserve0);
        }

        require(tokenReserve > 0, "Invalid reserves");

        uint256 tokenDecimals = IERC20(token).decimals();
        uint256 referenceDecimals = IERC20(priceReferenceToken).decimals();

        uint256 price = (referenceReserve * COLLATERAL_FACTOR_MANTISSA * (10 ** tokenDecimals)) / (tokenReserve * (10 ** referenceDecimals));

        return price;
    }

    function accrueInterest(address token) public {
        Market storage market = markets[token];
        uint256 currentBlockNumber = block.number;
        uint256 accrualBlockNumberPrior = market.accrualBlockNumber;

        if (accrualBlockNumberPrior == currentBlockNumber) {
            return;
        }

        uint256 borrowIndexPrior = market.borrowIndex;
        uint256 totalBorrowsPrior = market.totalBorrows;
        uint256 totalSupplyPrior = market.totalSupply;

        uint256 borrowRateMantissa = getBorrowRate(token);
        uint256 blockDelta = currentBlockNumber - accrualBlockNumberPrior;

        uint256 interestAccumulated = (totalBorrowsPrior * borrowRateMantissa * blockDelta) / COLLATERAL_FACTOR_MANTISSA;
        uint256 totalBorrowsNew = totalBorrowsPrior + interestAccumulated;
        uint256 borrowIndexNew = borrowIndexPrior + (borrowIndexPrior * borrowRateMantissa * blockDelta) / COLLATERAL_FACTOR_MANTISSA;

        uint256 supplyRateMantissa = getSupplyRate(token, borrowRateMantissa);
        uint256 supplyIndexNew = market.supplyIndex + (market.supplyIndex * supplyRateMantissa * blockDelta) / COLLATERAL_FACTOR_MANTISSA;

        market.accrualBlockNumber = currentBlockNumber;
        market.borrowIndex = borrowIndexNew;
        market.supplyIndex = supplyIndexNew;
        market.totalBorrows = totalBorrowsNew;
        market.borrowRatePerBlock = borrowRateMantissa;
        market.supplyRatePerBlock = supplyRateMantissa;
    }

    function getBorrowRate(address token) public view returns (uint256) {
        Market storage market = markets[token];
        uint256 utilizationRate = getUtilizationRate(token);

        if (utilizationRate <= KINK) {
            return BASE_RATE + (utilizationRate * MULTIPLIER) / COLLATERAL_FACTOR_MANTISSA;
        } else {
            uint256 normalRate = BASE_RATE + (KINK * MULTIPLIER) / COLLATERAL_FACTOR_MANTISSA;
            uint256 excessUtil = utilizationRate - KINK;
            return normalRate + (excessUtil * JUMP_MULTIPLIER) / COLLATERAL_FACTOR_MANTISSA;
        }
    }

    function getSupplyRate(address token, uint256 borrowRate) public view returns (uint256) {
        Market storage market = markets[token];
        uint256 utilizationRate = getUtilizationRate(token);
        uint256 rateToPool = (borrowRate * 9e17) / COLLATERAL_FACTOR_MANTISSA;
        return (utilizationRate * rateToPool) / COLLATERAL_FACTOR_MANTISSA;
    }

    function getUtilizationRate(address token) public view returns (uint256) {
        Market storage market = markets[token];
        if (market.totalSupply == 0) {
            return 0;
        }
        return (market.totalBorrows * COLLATERAL_FACTOR_MANTISSA) / market.totalSupply;
    }

    function getAccountSnapshot(address token, address account) external view returns (uint256 supplied, uint256 borrowed, uint256 supplyIndex, uint256 borrowIndex) {
        AccountSnapshot storage snapshot = accountAssets[token][account];
        Market storage market = markets[token];
        
        supplied = snapshot.supplied;
        borrowed = snapshot.borrowed;

        if (supplied > 0) {
            uint256 supplierDelta = (supplied * (market.supplyIndex - snapshot.supplyIndex)) / COLLATERAL_FACTOR_MANTISSA;
            supplied += supplierDelta;
        }

        if (borrowed > 0) {
            uint256 borrowerDelta = (borrowed * (market.borrowIndex - snapshot.borrowIndex)) / COLLATERAL_FACTOR_MANTISSA;
            borrowed += borrowerDelta;
        }

        supplyIndex = market.supplyIndex;
        borrowIndex = market.borrowIndex;
    }

    function getAllMarkets() external view returns (address[] memory) {
        return allMarkets;
    }

    function setAdmin(address newAdmin) external onlyAdmin {
        address oldAdmin = admin;
        admin = newAdmin;
        emit NewAdmin(oldAdmin, newAdmin);
    }

    function updateCollateralFactor(address token, uint256 newCollateralFactor) external onlyAdmin {
        require(markets[token].isListed, "Market not listed");
        require(newCollateralFactor <= COLLATERAL_FACTOR_MANTISSA, "Invalid collateral factor");
        markets[token].collateralFactor = newCollateralFactor;
    }

    function updateLiquidationThreshold(address token, uint256 newThreshold) external onlyAdmin {
        require(markets[token].isListed, "Market not listed");
        require(newThreshold >= markets[token].collateralFactor && newThreshold <= COLLATERAL_FACTOR_MANTISSA, "Invalid threshold");
        markets[token].liquidationThreshold = newThreshold;
    }
