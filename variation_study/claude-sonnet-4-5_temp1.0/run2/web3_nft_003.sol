pragma solidity ^0.8.0;

interface IERC721 {
    function transferFrom(address from, address to, uint256 tokenId) external;
    function ownerOf(uint256 tokenId) external view returns (address);
    function approve(address to, uint256 tokenId) external;
    function getApproved(uint256 tokenId) external view returns (address);
}

interface IERC20 {
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
    function transfer(address to, uint256 amount) external returns (bool);
}

contract NFTMarketplace {
    struct Listing {
        address seller;
        address nftContract;
        uint256 tokenId;
        uint256 price;
        address paymentToken;
        bool isActive;
    }

    struct Offer {
        address buyer;
        uint256 price;
        address paymentToken;
        uint256 expiresAt;
        bool isActive;
    }

    mapping(bytes32 => Listing) public listings;
    mapping(bytes32 => Offer[]) public offers;
    mapping(address => uint256) public pendingWithdrawals;

    uint256 public feePercentage;
    address public feeRecipient;
    address public owner;

    event NFTListed(
        bytes32 indexed listingId,
        address indexed seller,
        address indexed nftContract,
        uint256 tokenId,
        uint256 price,
        address paymentToken
    );

    event NFTSold(
        bytes32 indexed listingId,
        address indexed buyer,
        address indexed seller,
        uint256 price,
        address paymentToken
    );

    event ListingCancelled(bytes32 indexed listingId);

    event ListingPriceUpdated(bytes32 indexed listingId, uint256 newPrice);

    event OfferMade(
        bytes32 indexed listingId,
        uint256 indexed offerIndex,
        address indexed buyer,
        uint256 price,
        address paymentToken,
        uint256 expiresAt
    );

    event OfferAccepted(
        bytes32 indexed listingId,
        uint256 indexed offerIndex,
        address buyer,
        uint256 price
    );

    event OfferCancelled(bytes32 indexed listingId, uint256 indexed offerIndex);

    modifier onlyOwner() {
        require(msg.sender == owner, "Not owner");
        _;
    }

    modifier listingExists(bytes32 listingId) {
        require(listings[listingId].isActive, "Listing not active");
        _;
    }

    constructor(uint256 _feePercentage, address _feeRecipient) {
        require(_feePercentage <= 1000, "Fee too high");
        owner = msg.sender;
        feePercentage = _feePercentage;
        feeRecipient = _feeRecipient;
    }

    function createListing(
        address nftContract,
        uint256 tokenId,
        uint256 price,
        address paymentToken
    ) external returns (bytes32) {
        require(price > 0, "Price must be greater than 0");
        require(
            IERC721(nftContract).ownerOf(tokenId) == msg.sender,
            "Not token owner"
        );
        require(
            IERC721(nftContract).getApproved(tokenId) == address(this),
            "Marketplace not approved"
        );

        bytes32 listingId = keccak256(
            abi.encodePacked(nftContract, tokenId, msg.sender, block.timestamp)
        );

        listings[listingId] = Listing({
            seller: msg.sender,
            nftContract: nftContract,
            tokenId: tokenId,
            price: price,
            paymentToken: paymentToken,
            isActive: true
        });

        emit NFTListed(
            listingId,
            msg.sender,
            nftContract,
            tokenId,
            price,
            paymentToken
        );

        return listingId;
    }

    function buyNFT(bytes32 listingId) external payable listingExists(listingId) {
        Listing storage listing = listings[listingId];
        
        require(
            IERC721(listing.nftContract).ownerOf(listing.tokenId) == listing.seller,
            "Seller no longer owns token"
        );

        uint256 price = listing.price;
        address seller = listing.seller;
        address nftContract = listing.nftContract;
        uint256 tokenId = listing.tokenId;
        address paymentToken = listing.paymentToken;

        listing.isActive = false;

        uint256 fee = (price * feePercentage) / 10000;
        uint256 sellerAmount = price - fee;

        if (paymentToken == address(0)) {
            require(msg.value == price, "Incorrect payment amount");
            
            pendingWithdrawals[seller] += sellerAmount;
            pendingWithdrawals[feeRecipient] += fee;
        } else {
            require(msg.value == 0, "ETH not accepted for this listing");
            require(
                IERC20(paymentToken).transferFrom(msg.sender, seller, sellerAmount),
                "Payment transfer failed"
            );
            if (fee > 0) {
                require(
                    IERC20(paymentToken).transferFrom(msg.sender, feeRecipient, fee),
                    "Fee transfer failed"
                );
            }
        }

        IERC721(nftContract).transferFrom(seller, msg.sender, tokenId);

        emit NFTSold(listingId, msg.sender, seller, price, paymentToken);
    }

    function cancelListing(bytes32 listingId) external listingExists(listingId) {
        Listing storage listing = listings[listingId];
        require(listing.seller == msg.sender, "Not the seller");

        listing.isActive = false;

        emit ListingCancelled(listingId);
    }

    function updateListingPrice(bytes32 listingId, uint256 newPrice)
        external
        listingExists(listingId)
    {
        Listing storage listing = listings[listingId];
        require(listing.seller == msg.sender, "Not the seller");
        require(newPrice > 0, "Price must be greater than 0");

        listing.price = newPrice;

        emit ListingPriceUpdated(listingId, newPrice);
    }

    function makeOffer(
        bytes32 listingId,
        uint256 price,
        address paymentToken,
        uint256 duration
    ) external payable listingExists(listingId) {
        require(price > 0, "Price must be greater than 0");
        require(duration > 0, "Duration must be greater than 0");

        Listing storage listing = listings[listingId];

        if (paymentToken == address(0)) {
            require(msg.value == price, "Incorrect ETH amount");
        } else {
            require(msg.value == 0, "ETH sent for ERC20 offer");
            require(
                IERC20(paymentToken).transferFrom(msg.sender, address(this), price),
                "Payment transfer failed"
            );
        }

        uint256 expiresAt = block.timestamp + duration;

        offers[listingId].push(
            Offer({
                buyer: msg.sender,
                price: price,
                paymentToken: paymentToken,
                expiresAt: expiresAt,
                isActive: true
            })
        );

        uint256 offerIndex = offers[listingId].length - 1;

        emit OfferMade(
            listingId,
            offerIndex,
            msg.sender,
            price,
            paymentToken,
            expiresAt
        );
    }

    function acceptOffer(bytes32 listingId, uint256 offerIndex)
        external
        listingExists(listingId)
    {
        Listing storage listing = listings[listingId];
        require(listing.seller == msg.sender, "Not the seller");

        require(offerIndex < offers[listingId].length, "Invalid offer index");
        Offer storage offer = offers[listingId][offerIndex];

        require(offer.isActive, "Offer not active");
        require(block.timestamp <= offer.expiresAt, "Offer expired");
        require(
            IERC721(listing.nftContract).ownerOf(listing.tokenId) == msg.sender,
            "Seller no longer owns token"
        );

        uint256 price = offer.price;
        address buyer = offer.buyer;
        address paymentToken = offer.paymentToken;

        listing.isActive = false;
        offer.isActive = false;

        uint256 fee = (price * feePercentage) / 10000;
        uint256 sellerAmount = price - fee;

        if (paymentToken == address(0)) {
            payable(msg.sender).transfer(sellerAmount);
            if (fee > 0) {
                payable(feeRecipient).transfer(fee);
            }
        } else {
            require(
                IERC20(paymentToken).transfer(msg.sender, sellerAmount),
                "Payment transfer failed"
            );
            if (fee > 0) {
                require(
                    IERC20(paymentToken).transfer(feeRecipient, fee),
                    "Fee transfer failed"
                );
            }
        }

        IERC721(listing.nftContract).transferFrom(
            msg.sender,
            buyer,
            listing.tokenId
        );

        emit OfferAccepted(listingId, offerIndex, buyer, price);
        emit NFTSold(listingId, buyer, msg.sender, price, paymentToken);
    }

    function cancelOffer(bytes32 listingId, uint256 offerIndex) external {
        require(offerIndex < offers[listingId].length, "Invalid offer index");
        Offer storage offer = offers[listingId][offerIndex];

        require(offer.buyer == msg.sender, "Not the offer maker");
        require(offer.isActive, "Offer not active");

        offer.isActive = false;

        if (offer.paymentToken == address(0)) {
            payable(msg.sender).transfer(offer.price);
        } else {
            require(
                IERC20(offer.paymentToken).transfer(msg.sender, offer.price),
                "Refund failed"
            );
        }

        emit OfferCancelled(listingId, offerIndex);
    }

    function withdraw() external {
        uint256 amount = pendingWithdrawals[msg.sender];
        require(amount > 0, "No funds to withdraw");

        pendingWithdrawals[msg.sender] = 0;
        payable(msg.sender).transfer(amount);
    }

    function updateFeePercentage(uint256 newFee) external onlyOwner {
        require(newFee <= 1000, "Fee too high");
        feePercentage = newFee;
    }

    function updateFeeRecipient(address newRecipient) external onlyOwner {
        require(newRecipient != address(0), "Invalid address");
        feeRecipient = newRecipient;
    }

    function getListingDetails(bytes32 listingId)
        external
        view
        returns (
            address seller,
            address nftContract,
            uint256 tokenId,
            uint256 price,
            address paymentToken,
            bool isActive
        )
    {
        Listing memory listing = listings[listingId];
        return (
            listing.seller,
            listing.nftContract,
            listing.tokenId,
            listing.price,
            listing.paymentToken,
            listing.isActive
        );
    }

    function getOffers(bytes32 listingId)
        external
        view
        returns (Offer[] memory)
    {
        return offers[listingId];
    }

    function getOfferDetails(bytes32 listingId, uint256 offerIndex)
        external
        view
        returns (
            address buyer,
            uint256 price,
            address paymentToken,
            uint256 expiresAt,
            bool isActive
        )
    {
        require(offerIndex < offers[listingId].length, "Invalid offer index");
        Offer memory offer = offers[listingId][offerIndex];
        return (
            offer.buyer,
            offer.price,
            offer.paymentToken,
            offer.expiresAt,
            offer.isActive
        );
    }

    receive() external payable {}
}