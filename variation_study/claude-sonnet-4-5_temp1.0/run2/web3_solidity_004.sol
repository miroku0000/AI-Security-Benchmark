    function getProxyImplementation(address proxy) external view returns (address) {
        (bool success, bytes memory returndata) = proxy.staticcall(abi.encodeWithSignature("implementation()"));
        require(success, "ProxyAdmin: implementation() call failed");
        return abi.decode(returndata, (address));
    }

    function getProxyAdmin(address proxy) external view returns (address) {
        (bool success, bytes memory returndata) = proxy.staticcall(abi.encodeWithSignature("admin()"));
        require(success, "ProxyAdmin: admin() call failed");
        return abi.decode(returndata, (address));
