pragma solidity ^0.8.0;

interface IERC721 {
    function safeTransferFrom(address from, address to, uint256 tokenId) external;
    function transferFrom(address from, address to, uint256 tokenId) external;
    function ownerOf(uint256 tokenId) external view returns (address);
    function getApproved(uint256 tokenId) external view returns (address);
    function isApprovedForAll(address owner, address operator) external view returns (bool);
}

interface IERC20 {
    function transfer(address to, uint256 amount) external returns (bool);
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
    function balanceOf(address account) external view returns (uint256);
}

contract NFTMarketplace {
    struct Listing {
        address seller;
        address nftContract;
        uint256 tokenId;
        uint256 price;
        address paymentToken;
        bool active;
    }

    struct Offer {
        address offerer;
        uint256 price;
        address paymentToken;
        uint256 expiration;
        bool active;
    }

    uint256 public platformFee;
    address public feeRecipient;
    address public owner;

    uint256 private listingCounter;
    mapping(uint256 => Listing) public listings;
    mapping(address => mapping(uint256 => uint256)) public nftToListingId;
    mapping(uint256 => Offer[]) public offers;
    mapping(address => bool) public acceptedPaymentTokens;
    
    event NFTListed(
        uint256 indexed listingId,
        address indexed seller,
        address indexed nftContract,
        uint256 tokenId,
        uint256 price,
        address paymentToken
    );

    event NFTSold(
        uint256 indexed listingId,
        address indexed seller,
        address indexed buyer,
        address nftContract,
        uint256 tokenId,
        uint256 price,
        address paymentToken
    );

    event ListingCancelled(uint256 indexed listingId);

    event PriceUpdated(uint256 indexed listingId, uint256 newPrice);

    event OfferMade(
        uint256 indexed listingId,
        address indexed offerer,
        uint256 price,
        address paymentToken,
        uint256 expiration
    );

    event OfferAccepted(
        uint256 indexed listingId,
        uint256 indexed offerIndex,
        address indexed offerer
    );

    event OfferCancelled(uint256 indexed listingId, uint256 indexed offerIndex);

    modifier onlyOwner() {
        require(msg.sender == owner, "Not owner");
        _;
    }

    modifier listingExists(uint256 _listingId) {
        require(_listingId > 0 && _listingId <= listingCounter, "Listing does not exist");
        _;
    }

    modifier listingActive(uint256 _listingId) {
        require(listings[_listingId].active, "Listing not active");
        _;
    }

    constructor(uint256 _platformFee, address _feeRecipient) {
        require(_platformFee <= 1000, "Fee too high");
        require(_feeRecipient != address(0), "Invalid fee recipient");
        
        owner = msg.sender;
        platformFee = _platformFee;
        feeRecipient = _feeRecipient;
        acceptedPaymentTokens[address(0)] = true;
    }

    function listNFT(
        address _nftContract,
        uint256 _tokenId,
        uint256 _price,
        address _paymentToken
    ) external returns (uint256) {
        require(_nftContract != address(0), "Invalid NFT contract");
        require(_price > 0, "Price must be greater than 0");
        require(acceptedPaymentTokens[_paymentToken], "Payment token not accepted");
        require(nftToListingId[_nftContract][_tokenId] == 0, "NFT already listed");

        IERC721 nft = IERC721(_nftContract);
        address nftOwner = nft.ownerOf(_tokenId);
        require(nftOwner == msg.sender, "Not NFT owner");
        require(
            nft.isApprovedForAll(msg.sender, address(this)) || 
            nft.getApproved(_tokenId) == address(this),
            "Marketplace not approved"
        );

        listingCounter++;
        uint256 listingId = listingCounter;

        listings[listingId] = Listing({
            seller: msg.sender,
            nftContract: _nftContract,
            tokenId: _tokenId,
            price: _price,
            paymentToken: _paymentToken,
            active: true
        });

        nftToListingId[_nftContract][_tokenId] = listingId;

        emit NFTListed(listingId, msg.sender, _nftContract, _tokenId, _price, _paymentToken);

        return listingId;
    }

    function buyNFT(uint256 _listingId) 
        external 
        payable 
        listingExists(_listingId) 
        listingActive(_listingId) 
    {
        Listing storage listing = listings[_listingId];
        require(msg.sender != listing.seller, "Seller cannot buy own NFT");

        IERC721 nft = IERC721(listing.nftContract);
        address nftOwner = nft.ownerOf(listing.tokenId);
        require(nftOwner == listing.seller, "Seller no longer owns NFT");

        uint256 price = listing.price;
        address paymentToken = listing.paymentToken;

        if (paymentToken == address(0)) {
            require(msg.value == price, "Incorrect payment amount");
        } else {
            require(msg.value == 0, "ETH not accepted for this listing");
        }

        uint256 feeAmount = (price * platformFee) / 10000;
        uint256 sellerAmount = price - feeAmount;

        listing.active = false;
        nftToListingId[listing.nftContract][listing.tokenId] = 0;

        if (paymentToken == address(0)) {
            (bool feeSuccess, ) = feeRecipient.call{value: feeAmount}("");
            require(feeSuccess, "Fee transfer failed");

            (bool sellerSuccess, ) = listing.seller.call{value: sellerAmount}("");
            require(sellerSuccess, "Seller payment failed");
        } else {
            IERC20 token = IERC20(paymentToken);
            require(
                token.transferFrom(msg.sender, feeRecipient, feeAmount),
                "Fee transfer failed"
            );
            require(
                token.transferFrom(msg.sender, listing.seller, sellerAmount),
                "Seller payment failed"
            );
        }

        nft.safeTransferFrom(listing.seller, msg.sender, listing.tokenId);

        emit NFTSold(
            _listingId,
            listing.seller,
            msg.sender,
            listing.nftContract,
            listing.tokenId,
            price,
            paymentToken
        );
    }

    function cancelListing(uint256 _listingId) 
        external 
        listingExists(_listingId) 
        listingActive(_listingId) 
    {
        Listing storage listing = listings[_listingId];
        require(msg.sender == listing.seller, "Not seller");

        listing.active = false;
        nftToListingId[listing.nftContract][listing.tokenId] = 0;

        emit ListingCancelled(_listingId);
    }

    function updatePrice(uint256 _listingId, uint256 _newPrice) 
        external 
        listingExists(_listingId) 
        listingActive(_listingId) 
    {
        require(_newPrice > 0, "Price must be greater than 0");
        Listing storage listing = listings[_listingId];
        require(msg.sender == listing.seller, "Not seller");

        listing.price = _newPrice;

        emit PriceUpdated(_listingId, _newPrice);
    }

    function makeOffer(
        uint256 _listingId,
        uint256 _price,
        address _paymentToken,
        uint256 _expiration
    ) external payable listingExists(_listingId) listingActive(_listingId) {
        require(_price > 0, "Price must be greater than 0");
        require(acceptedPaymentTokens[_paymentToken], "Payment token not accepted");
        require(_expiration > block.timestamp, "Expiration in past");

        Listing storage listing = listings[_listingId];
        require(msg.sender != listing.seller, "Seller cannot make offer");

        if (_paymentToken == address(0)) {
            require(msg.value == _price, "Incorrect payment amount");
        } else {
            require(msg.value == 0, "ETH sent with token offer");
        }

        offers[_listingId].push(Offer({
            offerer: msg.sender,
            price: _price,
            paymentToken: _paymentToken,
            expiration: _expiration,
            active: true
        }));

        emit OfferMade(_listingId, msg.sender, _price, _paymentToken, _expiration);
    }

    function acceptOffer(uint256 _listingId, uint256 _offerIndex) 
        external 
        listingExists(_listingId) 
        listingActive(_listingId) 
    {
        Listing storage listing = listings[_listingId];
        require(msg.sender == listing.seller, "Not seller");
        require(_offerIndex < offers[_listingId].length, "Invalid offer index");

        Offer storage offer = offers[_listingId][_offerIndex];
        require(offer.active, "Offer not active");
        require(offer.expiration > block.timestamp, "Offer expired");

        IERC721 nft = IERC721(listing.nftContract);
        address nftOwner = nft.ownerOf(listing.tokenId);
        require(nftOwner == listing.seller, "Seller no longer owns NFT");

        uint256 price = offer.price;
        address paymentToken = offer.paymentToken;

        uint256 feeAmount = (price * platformFee) / 10000;
        uint256 sellerAmount = price - feeAmount;

        listing.active = false;
        offer.active = false;
        nftToListingId[listing.nftContract][listing.tokenId] = 0;

        if (paymentToken == address(0)) {
            require(address(this).balance >= price, "Insufficient contract balance");
            
            (bool feeSuccess, ) = feeRecipient.call{value: feeAmount}("");
            require(feeSuccess, "Fee transfer failed");

            (bool sellerSuccess, ) = listing.seller.call{value: sellerAmount}("");
            require(sellerSuccess, "Seller payment failed");
        } else {
            IERC20 token = IERC20(paymentToken);
            require(
                token.transferFrom(offer.offerer, feeRecipient, feeAmount),
                "Fee transfer failed"
            );
            require(
                token.transferFrom(offer.offerer, listing.seller, sellerAmount),
                "Seller payment failed"
            );
        }

        nft.safeTransferFrom(listing.seller, offer.offerer, listing.tokenId);

        emit OfferAccepted(_listingId, _offerIndex, offer.offerer);
        emit NFTSold(
            _listingId,
            listing.seller,
            offer.offerer,
            listing.nftContract,
            listing.tokenId,
            price,
            paymentToken
        );
    }

    function cancelOffer(uint256 _listingId, uint256 _offerIndex) external {
        require(_offerIndex < offers[_listingId].length, "Invalid offer index");
        
        Offer storage offer = offers[_listingId][_offerIndex];
        require(msg.sender == offer.offerer, "Not offerer");
        require(offer.active, "Offer not active");

        offer.active = false;

        if (offer.paymentToken == address(0)) {
            (bool success, ) = offer.offerer.call{value: offer.price}("");
            require(success, "ETH refund failed");
        }

        emit OfferCancelled(_listingId, _offerIndex);
    }

    function setPlatformFee(uint256 _newFee) external onlyOwner {
        require(_newFee <= 1000, "Fee too high");
        platformFee = _newFee;
    }

    function setFeeRecipient(address _newRecipient) external onlyOwner {
        require(_newRecipient != address(0), "Invalid recipient");
        feeRecipient = _newRecipient;
    }

    function setPaymentToken(address _token, bool _accepted) external onlyOwner {
        acceptedPaymentTokens[_token] = _accepted;
    }

    function transferOwnership(address _newOwner) external onlyOwner {
        require(_newOwner != address(0), "Invalid owner");
        owner = _newOwner;
    }

    function getListing(uint256 _listingId) 
        external 
        view 
        returns (
            address seller,
            address nftContract,
            uint256 tokenId,
            uint256 price,
            address paymentToken,
            bool active
        ) 
    {
        Listing memory listing = listings[_listingId];
        return (
            listing.seller,
            listing.nftContract,
            listing.tokenId,
            listing.price,
            listing.paymentToken,
            listing.active
        );
    }

    function getOffers(uint256 _listingId) external view returns (Offer[] memory) {
        return offers[_listingId];
    }

    function getOfferCount(uint256 _listingId) external view returns (uint256) {
        return offers[_listingId].length;
    }

    receive() external payable {}
}