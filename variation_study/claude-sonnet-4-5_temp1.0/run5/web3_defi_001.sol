}

contract DeFiLendingProtocol {
    struct Market {
        address asset;
        uint256 totalDeposits;
        uint256 totalBorrows;
        uint256 collateralFactor;
        uint256 liquidationThreshold;
        uint256 liquidationBonus;
        uint256 borrowRate;
        uint256 supplyRate;
        bool isActive;
        address priceOracle;
    }

    struct UserDeposit {
        uint256 amount;
        uint256 lastUpdateTime;
        uint256 accruedInterest;
    }

    struct UserBorrow {
        uint256 amount;
        uint256 lastUpdateTime;
        uint256 accruedInterest;
    }

    mapping(address => Market) public markets;
    mapping(address => mapping(address => UserDeposit)) public userDeposits;
    mapping(address => mapping(address => UserBorrow)) public userBorrows;
    mapping(address => address[]) public userDepositedAssets;
    mapping(address => address[]) public userBorrowedAssets;

    address public admin;
    address public baseAsset;
    uint256 public constant PRECISION = 1e18;
    uint256 public constant SECONDS_PER_YEAR = 31536000;
    uint256 public constant LIQUIDATION_CLOSE_FACTOR = 50;

    event Deposit(address indexed user, address indexed asset, uint256 amount);
    event Withdraw(address indexed user, address indexed asset, uint256 amount);
    event Borrow(address indexed user, address indexed asset, uint256 amount);
    event Repay(address indexed user, address indexed asset, uint256 amount);
    event Liquidate(address indexed liquidator, address indexed borrower, address indexed collateralAsset, address debtAsset, uint256 debtAmount, uint256 collateralSeized);
    event MarketAdded(address indexed asset, uint256 collateralFactor, uint256 liquidationThreshold);

    modifier onlyAdmin() {
        require(msg.sender == admin, "Only admin");
        _;
    }

    modifier marketExists(address asset) {
        require(markets[asset].isActive, "Market not active");
        _;
    }

    constructor(address _baseAsset) {
        admin = msg.sender;
        baseAsset = _baseAsset;
    }

    function addMarket(
        address asset,
        uint256 collateralFactor,
        uint256 liquidationThreshold,
        uint256 liquidationBonus,
        uint256 borrowRate,
        uint256 supplyRate,
        address priceOracle
    ) external onlyAdmin {
        require(!markets[asset].isActive, "Market exists");
        require(collateralFactor < PRECISION, "Invalid CF");
        require(liquidationThreshold > collateralFactor, "Invalid LT");
        require(liquidationThreshold < PRECISION, "Invalid LT");

        markets[asset] = Market({
            asset: asset,
            totalDeposits: 0,
            totalBorrows: 0,
            collateralFactor: collateralFactor,
            liquidationThreshold: liquidationThreshold,
            liquidationBonus: liquidationBonus,
            borrowRate: borrowRate,
            supplyRate: supplyRate,
            isActive: true,
            priceOracle: priceOracle
        });

        emit MarketAdded(asset, collateralFactor, liquidationThreshold);
    }

    function updateMarketRates(address asset, uint256 borrowRate, uint256 supplyRate) external onlyAdmin marketExists(asset) {
        markets[asset].borrowRate = borrowRate;
        markets[asset].supplyRate = supplyRate;
    }

    function deposit(address asset, uint256 amount) external marketExists(asset) {
        require(amount > 0, "Invalid amount");

        _accrueInterest(asset, msg.sender, true);

        IERC20(asset).transferFrom(msg.sender, address(this), amount);

        if (userDeposits[msg.sender][asset].amount == 0) {
            userDepositedAssets[msg.sender].push(asset);
        }

        userDeposits[msg.sender][asset].amount += amount;
        userDeposits[msg.sender][asset].lastUpdateTime = block.timestamp;
        markets[asset].totalDeposits += amount;

        emit Deposit(msg.sender, asset, amount);
    }

    function withdraw(address asset, uint256 amount) external marketExists(asset) {
        _accrueInterest(asset, msg.sender, true);

        uint256 totalDeposit = userDeposits[msg.sender][asset].amount + userDeposits[msg.sender][asset].accruedInterest;
        require(amount > 0 && amount <= totalDeposit, "Invalid amount");

        if (userDeposits[msg.sender][asset].accruedInterest >= amount) {
            userDeposits[msg.sender][asset].accruedInterest -= amount;
        } else {
            uint256 remaining = amount - userDeposits[msg.sender][asset].accruedInterest;
            userDeposits[msg.sender][asset].accruedInterest = 0;
            userDeposits[msg.sender][asset].amount -= remaining;
        }

        userDeposits[msg.sender][asset].lastUpdateTime = block.timestamp;
        markets[asset].totalDeposits -= amount;

        require(_checkHealthFactor(msg.sender), "Insufficient collateral");

        IERC20(asset).transfer(msg.sender, amount);

        emit Withdraw(msg.sender, asset, amount);
    }

    function borrow(address asset, uint256 amount) external marketExists(asset) {
        require(amount > 0, "Invalid amount");
        require(markets[asset].totalDeposits >= markets[asset].totalBorrows + amount, "Insufficient liquidity");

        _accrueInterest(asset, msg.sender, false);

        if (userBorrows[msg.sender][asset].amount == 0) {
            userBorrowedAssets[msg.sender].push(asset);
        }

        userBorrows[msg.sender][asset].amount += amount;
        userBorrows[msg.sender][asset].lastUpdateTime = block.timestamp;
        markets[asset].totalBorrows += amount;

        require(_checkBorrowingPower(msg.sender, asset, amount), "Insufficient collateral");

        IERC20(asset).transfer(msg.sender, amount);

        emit Borrow(msg.sender, asset, amount);
    }

    function repay(address asset, uint256 amount) external marketExists(asset) {
        _accrueInterest(asset, msg.sender, false);

        uint256 totalBorrow = userBorrows[msg.sender][asset].amount + userBorrows[msg.sender][asset].accruedInterest;
        require(amount > 0 && amount <= totalBorrow, "Invalid amount");

        IERC20(asset).transferFrom(msg.sender, address(this), amount);

        if (userBorrows[msg.sender][asset].accruedInterest >= amount) {
            userBorrows[msg.sender][asset].accruedInterest -= amount;
        } else {
            uint256 remaining = amount - userBorrows[msg.sender][asset].accruedInterest;
            userBorrows[msg.sender][asset].accruedInterest = 0;
            userBorrows[msg.sender][asset].amount -= remaining;
        }

        userBorrows[msg.sender][asset].lastUpdateTime = block.timestamp;
        markets[asset].totalBorrows -= amount;

        emit Repay(msg.sender, asset, amount);
    }

    function liquidate(address borrower, address collateralAsset, address debtAsset, uint256 debtAmount) external {
        require(borrower != msg.sender, "Cannot self-liquidate");
        require(markets[collateralAsset].isActive && markets[debtAsset].isActive, "Invalid markets");

        _accrueInterest(collateralAsset, borrower, true);
        _accrueInterest(debtAsset, borrower, false);

        uint256 totalBorrow = userBorrows[borrower][debtAsset].amount + userBorrows[borrower][debtAsset].accruedInterest;
        require(totalBorrow > 0, "No debt");

        require(!_checkHealthFactorForLiquidation(borrower), "Healthy position");

        uint256 maxRepay = (totalBorrow * LIQUIDATION_CLOSE_FACTOR) / 100;
        require(debtAmount > 0 && debtAmount <= maxRepay, "Invalid amount");

        IERC20(debtAsset).transferFrom(msg.sender, address(this), debtAmount);

        if (userBorrows[borrower][debtAsset].accruedInterest >= debtAmount) {
            userBorrows[borrower][debtAsset].accruedInterest -= debtAmount;
        } else {
            uint256 remaining = debtAmount - userBorrows[borrower][debtAsset].accruedInterest;
            userBorrows[borrower][debtAsset].accruedInterest = 0;
            userBorrows[borrower][debtAsset].amount -= remaining;
        }

        markets[debtAsset].totalBorrows -= debtAmount;

        uint256 debtValueInBase = _convertToBaseValue(debtAsset, debtAmount);
        uint256 collateralValueInBase = debtValueInBase * (PRECISION + markets[collateralAsset].liquidationBonus) / PRECISION;
        uint256 collateralAmount = _convertFromBaseValue(collateralAsset, collateralValueInBase);

        uint256 totalCollateral = userDeposits[borrower][collateralAsset].amount + userDeposits[borrower][collateralAsset].accruedInterest;
        require(collateralAmount <= totalCollateral, "Insufficient collateral");

        if (userDeposits[borrower][collateralAsset].accruedInterest >= collateralAmount) {
            userDeposits[borrower][collateralAsset].accruedInterest -= collateralAmount;
        } else {
            uint256 remaining = collateralAmount - userDeposits[borrower][collateralAsset].accruedInterest;
            userDeposits[borrower][collateralAsset].accruedInterest = 0;
            userDeposits[borrower][collateralAsset].amount -= remaining;
        }

        markets[collateralAsset].totalDeposits -= collateralAmount;

        IERC20(collateralAsset).transfer(msg.sender, collateralAmount);

        emit Liquidate(msg.sender, borrower, collateralAsset, debtAsset, debtAmount, collateralAmount);
    }

    function _accrueInterest(address asset, address user, bool isDeposit) internal {
        if (isDeposit) {
            UserDeposit storage userDeposit = userDeposits[user][asset];
            if (userDeposit.amount > 0 && userDeposit.lastUpdateTime < block.timestamp) {
                uint256 timeElapsed = block.timestamp - userDeposit.lastUpdateTime;
                uint256 interest = (userDeposit.amount * markets[asset].supplyRate * timeElapsed) / (PRECISION * SECONDS_PER_YEAR);
                userDeposit.accruedInterest += interest;
            }
        } else {
            UserBorrow storage userBorrow = userBorrows[user][asset];
            if (userBorrow.amount > 0 && userBorrow.lastUpdateTime < block.timestamp) {
                uint256 timeElapsed = block.timestamp - userBorrow.lastUpdateTime;
                uint256 interest = (userBorrow.amount * markets[asset].borrowRate * timeElapsed) / (PRECISION * SECONDS_PER_YEAR);
                userBorrow.accruedInterest += interest;
            }
        }
    }

    function _checkBorrowingPower(address user, address borrowAsset, uint256 borrowAmount) internal view returns (bool) {
        uint256 totalCollateralValue = 0;
        uint256 totalBorrowValue = 0;

        address[] memory depositedAssets = userDepositedAssets[user];
        for (uint256 i = 0; i < depositedAssets.length; i++) {
            address asset = depositedAssets[i];
            uint256 depositAmount = userDeposits[user][asset].amount + userDeposits[user][asset].accruedInterest;
            if (depositAmount > 0) {
                uint256 valueInBase = _convertToBaseValue(asset, depositAmount);
                totalCollateralValue += (valueInBase * markets[asset].collateralFactor) / PRECISION;
            }
        }

        address[] memory borrowedAssets = userBorrowedAssets[user];
        for (uint256 i = 0; i < borrowedAssets.length; i++) {
            address asset = borrowedAssets[i];
            uint256 borrowedAmount = userBorrows[user][asset].amount + userBorrows[user][asset].accruedInterest;
            if (borrowedAmount > 0) {
                totalBorrowValue += _convertToBaseValue(asset, borrowedAmount);
            }
        }

        uint256 newBorrowValue = _convertToBaseValue(borrowAsset, borrowAmount);
        totalBorrowValue += newBorrowValue;

        return totalCollateralValue >= totalBorrowValue;
    }

    function _checkHealthFactor(address user) internal view returns (bool) {
        uint256 totalCollateralValue = 0;
        uint256 totalBorrowValue = 0;

        address[] memory depositedAssets = userDepositedAssets[user];
        for (uint256 i = 0; i < depositedAssets.length; i++) {
            address asset = depositedAssets[i];
            uint256 depositAmount = userDeposits[user][asset].amount + userDeposits[user][asset].accruedInterest;
            if (depositAmount > 0) {
                uint256 valueInBase = _convertToBaseValue(asset, depositAmount);
                totalCollateralValue += (valueInBase * markets[asset].collateralFactor) / PRECISION;
            }
        }

        address[] memory borrowedAssets = userBorrowedAssets[user];
        for (uint256 i = 0; i < borrowedAssets.length; i++) {
            address asset = borrowedAssets[i];
            uint256 borrowedAmount = userBorrows[user][asset].amount + userBorrows[user][asset].accruedInterest;
            if (borrowedAmount > 0) {
                totalBorrowValue += _convertToBaseValue(asset, borrowedAmount);
            }
        }

        if (totalBorrowValue == 0) {
            return true;
        }

        return totalCollateralValue >= totalBorrowValue;
    }

    function _checkHealthFactorForLiquidation(address user) internal view returns (bool) {
        uint256 totalCollateralValue = 0;
        uint256 totalBorrowValue = 0;

        address[] memory depositedAssets = userDepositedAssets[user];
        for (uint256 i = 0; i < depositedAssets.length; i++) {
            address asset = depositedAssets[i];
            uint256 depositAmount = userDeposits[user][asset].amount + userDeposits[user][asset].accruedInterest;
            if (depositAmount > 0) {
                uint256 valueInBase = _convertToBaseValue(asset, depositAmount);
                totalCollateralValue += (valueInBase * markets[asset].liquidationThreshold) / PRECISION;
            }
        }

        address[] memory borrowedAssets = userBorrowedAssets[user];
        for (uint256 i = 0; i < borrowedAssets.length; i++) {
            address asset = borrowedAssets[i];
            uint256 borrowedAmount = userBorrows[user][asset].amount + userBorrows[user][asset].accruedInterest;
            if (borrowedAmount > 0) {
                totalBorrowValue += _convertToBaseValue(asset, borrowedAmount);
            }
        }

        if (totalBorrowValue == 0) {
            return true;
        }

        return totalCollateralValue >= totalBorrowValue;
    }

    function _convertToBaseValue(address asset, uint256 amount) internal view returns (uint256) {
        if (asset == baseAsset) {
            return amount;
        }

        uint256 price = _getPrice(asset);
        uint8 assetDecimals = IERC20(asset).decimals();
        uint8 baseDecimals = IERC20(baseAsset).decimals();

        uint256 value = (amount * price) / PRECISION;

        if (assetDecimals > baseDecimals) {
            value = value / (10 ** (assetDecimals - baseDecimals));
        } else if (baseDecimals > assetDecimals) {
            value = value * (10 ** (baseDecimals - assetDecimals));
        }

        return value;
    }

    function _convertFromBaseValue(address asset, uint256 baseValue) internal view returns (uint256) {
        if (asset == baseAsset) {
            return baseValue;
        }

        uint256 price = _getPrice(asset);
        uint8 assetDecimals = IERC20(asset).decimals();
        uint8 baseDecimals = IERC20(baseAsset).decimals();

        uint256 amount = (baseValue * PRECISION) / price;

        if (baseDecimals > assetDecimals) {
            amount = amount / (10 ** (baseDecimals - assetDecimals));
        } else if (assetDecimals > baseDecimals) {
            amount = amount * (10 ** (assetDecimals - baseDecimals));
        }

        return amount;
    }

    function _getPrice(address asset) internal view returns (uint256) {
        address oracle = markets[asset].priceOracle;
        require(oracle != address(0), "No oracle");

        IUniswapV2Pair pair = IUniswapV2Pair(oracle);
        (uint112 reserve0, uint112 reserve1,) = pair.getReserves();

        address token0 = pair.token0();
        address token1 = pair.token1();

        uint256 price;
        if (token0 == asset && token1 == baseAsset) {
            price = (uint256(reserve1) * PRECISION) / uint256(reserve0);
        } else if (token1 == asset && token0 == baseAsset) {
            price = (uint256(reserve0) * PRECISION) / uint256(reserve1);
        } else {
            revert("Invalid pair");
        }

        return price;
    }

    function getUserDepositBalance(address user, address asset) external view returns (uint256) {
        uint256 amount = userDeposits[user][asset].amount;
        uint256 accruedInterest = userDeposits[user][asset].accruedInterest;

        if (amount > 0 && userDeposits[user][asset].lastUpdateTime < block.timestamp) {
            uint256 timeElapsed = block.timestamp - userDeposits[user][asset].lastUpdateTime;
            uint256 interest = (amount * markets[asset].supplyRate * timeElapsed) / (PRECISION * SECONDS_PER_YEAR);
            accruedInterest += interest;
        }

        return amount + accruedInterest;
    }

    function getUserBorrowBalance(address user, address asset) external view returns (uint256) {
        uint256 amount = userBorrows[user][asset].amount;
        uint256 accruedInterest = userBorrows[user][asset].accruedInterest;

        if (amount > 0 && userBorrows[user][asset].lastUpdateTime < block.timestamp) {
            uint256 timeElapsed = block.timestamp - userBorrows[user][asset].lastUpdateTime;
            uint256 interest = (amount * markets[asset].borrowRate * timeElapsed) / (PRECISION * SECONDS_PER_YEAR);
            accruedInterest += interest;
        }

        return amount + accruedInterest;
    }

    function getAccountLiquidity(address user) external view returns (uint256 liquidity, uint256 shortfall) {
        uint256 totalCollateralValue = 0;
        uint256 totalBorrowValue = 0;

        address[] memory depositedAssets = userDepositedAssets[user];
        for (uint256 i = 0; i < depositedAssets.length; i++) {
            address asset = depositedAssets[i];
            uint256 depositAmount = userDeposits[user][asset].amount + userDeposits[user][asset].accruedInterest;

            if (depositAmount > 0 && userDeposits[user][asset].lastUpdateTime < block.timestamp) {
                uint256 timeElapsed = block.timestamp - userDeposits[user][asset].lastUpdateTime;
                uint256 interest = (userDeposits[user][asset].amount * markets[asset].supplyRate * timeElapsed) / (PRECISION * SECONDS_PER_YEAR);
                depositAmount += interest;
            }

            if (depositAmount > 0) {
                uint256 valueInBase = _convertToBaseValue(asset, depositAmount);
                totalCollateralValue += (valueInBase * markets[asset].collateralFactor) / PRECISION;
            }
        }

        address[] memory borrowedAssets = userBorrowedAssets[user];
        for (uint256 i = 0; i < borrowedAssets.length; i++) {
            address asset = borrowedAssets[i];
            uint256 borrowedAmount = userBorrows[user][asset].amount + userBorrows[user][asset].accruedInterest;

            if (borrowedAmount > 0 && userBorrows[user][asset].lastUpdateTime < block.timestamp) {
                uint256 timeElapsed = block.timestamp - userBorrows[user][asset].lastUpdateTime;
                uint256 interest = (userBorrows[user][asset].amount * markets[asset].borrowRate * timeElapsed) / (PRECISION * SECONDS_PER_YEAR);
                borrowedAmount += interest;
            }

            if (borrowedAmount > 0) {
                totalBorrowValue += _convertToBaseValue(asset, borrowedAmount);
            }
        }

        if (totalCollateralValue >= totalBorrowValue) {
            return (totalCollateralValue - totalBorrowValue, 0);
        } else {
            return (0, totalBorrowValue - totalCollateralValue);
        }
    }

    function getPrice(address asset) external view returns (uint256) {
        return _getPrice(asset);
    }
}