pragma solidity ^0.8.0;

contract RandomRewardSystem {
    address public owner;
    uint256 public gameId;
    uint256 public entryFee;
    uint256 public rewardPool;
    uint256 public maxParticipants;
    uint256 public minParticipants;
    
    struct Game {
        uint256 id;
        address[] participants;
        address[] winners;
        uint256 prizePool;
        uint256 startTime;
        uint256 endTime;
        bool isActive;
        bool isCompleted;
        mapping(address => bool) hasEntered;
        mapping(address => uint256) rewards;
    }
    
    struct Reward {
        uint256 amount;
        uint256 percentage;
        uint256 rank;
    }
    
    mapping(uint256 => Game) public games;
    mapping(address => uint256) public playerBalance;
    mapping(address => uint256[]) public playerGames;
    
    Reward[] public rewardStructure;
    
    uint256 public platformFee;
    uint256 public totalPlatformFees;
    
    event GameCreated(uint256 indexed gameId, uint256 startTime, uint256 endTime);
    event PlayerEntered(uint256 indexed gameId, address indexed player);
    event WinnersSelected(uint256 indexed gameId, address[] winners);
    event RewardDistributed(uint256 indexed gameId, address indexed winner, uint256 amount);
    event GameCompleted(uint256 indexed gameId);
    event RewardClaimed(address indexed player, uint256 amount);
    
    modifier onlyOwner() {
        require(msg.sender == owner, "Only owner can call this");
        _;
    }
    
    modifier gameActive(uint256 _gameId) {
        require(games[_gameId].isActive, "Game is not active");
        require(block.timestamp < games[_gameId].endTime, "Game has ended");
        _;
    }
    
    constructor(
        uint256 _entryFee,
        uint256 _maxParticipants,
        uint256 _minParticipants,
        uint256 _platformFee
    ) {
        owner = msg.sender;
        entryFee = _entryFee;
        maxParticipants = _maxParticipants;
        minParticipants = _minParticipants;
        platformFee = _platformFee;
        
        rewardStructure.push(Reward(0, 50, 1));
        rewardStructure.push(Reward(0, 30, 2));
        rewardStructure.push(Reward(0, 20, 3));
    }
    
    function createGame(uint256 _duration) external onlyOwner {
        gameId++;
        Game storage newGame = games[gameId];
        newGame.id = gameId;
        newGame.startTime = block.timestamp;
        newGame.endTime = block.timestamp + _duration;
        newGame.isActive = true;
        newGame.isCompleted = false;
        
        emit GameCreated(gameId, newGame.startTime, newGame.endTime);
    }
    
    function enterGame(uint256 _gameId) external payable gameActive(_gameId) {
        Game storage game = games[_gameId];
        
        require(msg.value == entryFee, "Incorrect entry fee");
        require(!game.hasEntered[msg.sender], "Already entered this game");
        require(game.participants.length < maxParticipants, "Game is full");
        
        game.participants.push(msg.sender);
        game.hasEntered[msg.sender] = true;
        game.prizePool += msg.value;
        playerGames[msg.sender].push(_gameId);
        
        emit PlayerEntered(_gameId, msg.sender);
    }
    
    function endGameAndSelectWinners(uint256 _gameId) external onlyOwner {
        Game storage game = games[_gameId];
        
        require(game.isActive, "Game is not active");
        require(block.timestamp >= game.endTime, "Game has not ended yet");
        require(!game.isCompleted, "Game already completed");
        require(game.participants.length >= minParticipants, "Not enough participants");
        
        game.isActive = false;
        
        uint256 fee = (game.prizePool * platformFee) / 10000;
        totalPlatformFees += fee;
        uint256 distributionPool = game.prizePool - fee;
        
        uint256 numberOfWinners = rewardStructure.length;
        if (game.participants.length < numberOfWinners) {
            numberOfWinners = game.participants.length;
        }
        
        address[] memory selectedWinners = selectRandomWinners(_gameId, numberOfWinners);
        
        distributeRewards(_gameId, selectedWinners, distributionPool);
        
        game.isCompleted = true;
        
        emit WinnersSelected(_gameId, selectedWinners);
        emit GameCompleted(_gameId);
    }
    
    function selectRandomWinners(uint256 _gameId, uint256 _numberOfWinners) internal returns (address[] memory) {
        Game storage game = games[_gameId];
        address[] memory winners = new address[](_numberOfWinners);
        address[] memory remainingParticipants = game.participants;
        
        for (uint256 i = 0; i < _numberOfWinners; i++) {
            uint256 randomIndex = generateRandomNumber(i, remainingParticipants.length, _gameId);
            winners[i] = remainingParticipants[randomIndex];
            game.winners.push(remainingParticipants[randomIndex]);
            
            remainingParticipants[randomIndex] = remainingParticipants[remainingParticipants.length - 1];
            assembly {
                mstore(remainingParticipants, sub(mload(remainingParticipants), 1))
            }
        }
        
        return winners;
    }
    
    function generateRandomNumber(uint256 _nonce, uint256 _modulo, uint256 _gameId) internal view returns (uint256) {
        return uint256(keccak256(abi.encodePacked(
            block.timestamp,
            blockhash(block.number - 1),
            block.difficulty,
            msg.sender,
            _nonce,
            _gameId,
            games[_gameId].participants.length
        ))) % _modulo;
    }
    
    function distributeRewards(uint256 _gameId, address[] memory _winners, uint256 _distributionPool) internal {
        Game storage game = games[_gameId];
        
        for (uint256 i = 0; i < _winners.length; i++) {
            uint256 rewardAmount = (_distributionPool * rewardStructure[i].percentage) / 100;
            game.rewards[_winners[i]] = rewardAmount;
            playerBalance[_winners[i]] += rewardAmount;
            
            emit RewardDistributed(_gameId, _winners[i], rewardAmount);
        }
    }
    
    function claimReward() external {
        uint256 amount = playerBalance[msg.sender];
        require(amount > 0, "No rewards to claim");
        
        playerBalance[msg.sender] = 0;
        (bool success, ) = payable(msg.sender).call{value: amount}("");
        require(success, "Transfer failed");
        
        emit RewardClaimed(msg.sender, amount);
    }
    
    function withdrawPlatformFees() external onlyOwner {
        uint256 amount = totalPlatformFees;
        require(amount > 0, "No fees to withdraw");
        
        totalPlatformFees = 0;
        (bool success, ) = payable(owner).call{value: amount}("");
        require(success, "Transfer failed");
    }
    
    function updateEntryFee(uint256 _newFee) external onlyOwner {
        entryFee = _newFee;
    }
    
    function updateMaxParticipants(uint256 _newMax) external onlyOwner {
        maxParticipants = _newMax;
    }
    
    function updateMinParticipants(uint256 _newMin) external onlyOwner {
        minParticipants = _newMin;
    }
    
    function updatePlatformFee(uint256 _newFee) external onlyOwner {
        require(_newFee <= 1000, "Fee too high");
        platformFee = _newFee;
    }
    
    function updateRewardStructure(uint256 _index, uint256 _percentage) external onlyOwner {
        require(_index < rewardStructure.length, "Invalid index");
        rewardStructure[_index].percentage = _percentage;
    }
    
    function addRewardTier(uint256 _percentage, uint256 _rank) external onlyOwner {
        rewardStructure.push(Reward(0, _percentage, _rank));
    }
    
    function getGameParticipants(uint256 _gameId) external view returns (address[] memory) {
        return games[_gameId].participants;
    }
    
    function getGameWinners(uint256 _gameId) external view returns (address[] memory) {
        return games[_gameId].winners;
    }
    
    function getPlayerGames(address _player) external view returns (uint256[] memory) {
        return playerGames[_player];
    }
    
    function getGameReward(uint256 _gameId, address _player) external view returns (uint256) {
        return games[_gameId].rewards[_player];
    }
    
    function getGameInfo(uint256 _gameId) external view returns (
        uint256 id,
        uint256 participantCount,
        uint256 prizePool,
        uint256 startTime,
        uint256 endTime,
        bool isActive,
        bool isCompleted
    ) {
        Game storage game = games[_gameId];
        return (
            game.id,
            game.participants.length,
            game.prizePool,
            game.startTime,
            game.endTime,
            game.isActive,
            game.isCompleted
        );
    }
    
    function hasEnteredGame(uint256 _gameId, address _player) external view returns (bool) {
        return games[_gameId].hasEntered[_player];
    }
    
    function getRewardStructure() external view returns (Reward[] memory) {
        return rewardStructure;
    }
    
    function emergencyWithdraw() external onlyOwner {
        (bool success, ) = payable(owner).call{value: address(this).balance}("");
        require(success, "Transfer failed");
    }
    
    receive() external payable {}
