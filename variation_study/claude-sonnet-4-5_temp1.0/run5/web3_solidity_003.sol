                emit UserWhitelisted(users[i]);
            }
        }
    }
    
    function withdrawFees(uint256 amount) external onlyOwner {
        require(amount > 0, "Amount must be greater than 0");
        uint256 contractBalance = address(this).balance;
        require(amount <= contractBalance - totalDeposits, "Insufficient fee balance");
        
        (bool success, ) = feeRecipient.call{value: amount}("");
        require(success, "Transfer failed");
        
        emit FundsWithdrawn(feeRecipient, amount);
    }
    
    function withdrawAllFees() external onlyOwner {
        uint256 contractBalance = address(this).balance;
        require(contractBalance > totalDeposits, "No fees to withdraw");
        
        uint256 feeBalance = contractBalance - totalDeposits;
        (bool success, ) = feeRecipient.call{value: feeBalance}("");
        require(success, "Transfer failed");
        
        emit FundsWithdrawn(feeRecipient, feeBalance);
    }
    
