        properties = {
          metrics = [
            ["AWS/Lambda", "Invocations", { stat = "Sum", label = "Process Payment Invocations" }, { FunctionName = aws_lambda_function.process_payment.function_name }],
            [".", "Errors", { stat = "Sum", label = "Process Payment Errors" }, { FunctionName = aws_lambda_function.process_payment.function_name }],
            [".", "Duration", { stat = "Average", label = "Process Payment Duration" }, { FunctionName = aws_lambda_function.process_payment.function_name }]
          ]
          period = 300
          region = "us-east-1"
          title  = "Process Payment Lambda Metrics"
        }
      },
      {
        type = "metric"
        properties = {
          metrics = [
            ["AWS/Lambda", "Invocations", { stat = "Sum", label = "Fraud Detection Invocations" }, { FunctionName = aws_lambda_function.fraud_detection.function_name }],
            [".", "Errors", { stat = "Sum", label = "Fraud Detection Errors" }, { FunctionName = aws_lambda_function.fraud_detection.function_name }],
            [".", "Duration", { stat = "Average", label = "Fraud Detection Duration" }, { FunctionName = aws_lambda_function.fraud_detection.function_name }]
          ]
          period = 300
          region = "us-east-1"
          title  = "Fraud Detection Lambda Metrics"
        }
      },
      {
        type = "metric"
