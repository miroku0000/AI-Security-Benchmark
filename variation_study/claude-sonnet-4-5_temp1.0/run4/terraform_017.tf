          metrics = [
            ["AWS/DynamoDB", "ConsumedReadCapacityUnits", { stat = "Sum", label = "Read Capacity" }, { TableName = aws_dynamodb_table.financial_transactions.name }],
            [".", "ConsumedWriteCapacityUnits", { stat = "Sum", label = "Write Capacity" }, { TableName = aws_dynamodb_table.financial_transactions.name }]
