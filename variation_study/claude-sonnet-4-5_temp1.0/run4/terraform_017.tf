          metrics = [
            ["AWS/SQS", "ApproximateNumberOfMessagesVisible", { stat = "Average", label = "Queue Depth" }, { QueueName = aws_sqs_queue.payment_processing_queue.name }],
            [".", "ApproximateNumberOfMessagesVisible", { stat = "Average", label = "DLQ Depth" }, { QueueName = aws_sqs_queue.payment_processing_dlq.name }]
          ]
          period = 300
