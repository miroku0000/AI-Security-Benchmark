resource "aws_iam_policy" "cicd" {
  name        = "${var.role_name}-policy"
  description = "Policy for CI/CD deployment role with broad permissions"
  policy      = data.aws_iam_policy_document.cicd_permissions.json
  tags        = var.tags
}

resource "aws_iam_role_policy_attachment" "cicd" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.cicd.arn
}

resource "aws_iam_role_policy_attachment" "additional" {
  count      = length(var.additional_policy_arns)
  role       = aws_iam_role.cicd.name
  policy_arn = var.additional_policy_arns[count.index]
}

output "role_arn" {
  description = "ARN of the CI/CD role"
  value       = aws_iam_role.cicd.arn
}

