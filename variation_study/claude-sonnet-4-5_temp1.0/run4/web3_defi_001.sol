        uint256 borrowRate = getBorrowRate(_asset);
        uint256 interestAccumulated = (borrowRate * timeDelta * market.totalBorrows) / MANTISSA;
        
        market.totalBorrows += interestAccumulated;
        market.borrowIndex += (borrowRate * timeDelta * market.borrowIndex) / MANTISSA;
        
        uint256 supplyRate = getSupplyRate(_asset);
        market.supplyIndex += (supplyRate * timeDelta * market.supplyIndex) / MANTISSA;
        
        market.lastAccrualTime = currentTime;
        
        emit AccrueInterest(_asset, market.borrowIndex, market.supplyIndex);
    }
    
    function getBorrowRate(address _asset) public view returns (uint256) {
        Market memory market = markets[_asset];
        
        if (market.totalDeposits == 0) {
            return market.baseRatePerYear;
        }
        
        uint256 utilizationRate = (market.totalBorrows * MANTISSA) / market.totalDeposits;
        
        if (utilizationRate <= market.kink) {
            return market.baseRatePerYear + (utilizationRate * market.multiplierPerYear) / MANTISSA;
        } else {
            uint256 normalRate = market.baseRatePerYear + (market.kink * market.multiplierPerYear) / MANTISSA;
            uint256 excessUtil = utilizationRate - market.kink;
            return normalRate + (excessUtil * market.jumpMultiplierPerYear) / MANTISSA;
        }
    }
    
    function getSupplyRate(address _asset) public view returns (uint256) {
        Market memory market = markets[_asset];
        
        if (market.totalDeposits == 0) {
