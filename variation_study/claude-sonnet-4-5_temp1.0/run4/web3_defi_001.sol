        uint256 borrowRate = getBorrowRate(_asset);
        uint256 utilizationRate = (market.totalBorrows * MANTISSA) / market.totalDeposits;
        uint256 rateToPool = (borrowRate * (MANTISSA - market.reserveFactor)) / MANTISSA;
        
        return (utilizationRate * rateToPool) / MANTISSA;
    }
    
