pragma solidity ^0.8.0;

interface IERC721 {
    function safeTransferFrom(address from, address to, uint256 tokenId) external;
    function transferFrom(address from, address to, uint256 tokenId) external;
    function ownerOf(uint256 tokenId) external view returns (address);
    function getApproved(uint256 tokenId) external view returns (address);
    function isApprovedForAll(address owner, address operator) external view returns (bool);
}

interface IERC20 {
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
    function transfer(address to, uint256 amount) external returns (bool);
}

contract NFTMarketplace {
    struct Listing {
        address seller;
        address nftContract;
        uint256 tokenId;
        uint256 price;
        address paymentToken;
        bool isActive;
    }

    struct Offer {
        address buyer;
        uint256 price;
        address paymentToken;
        uint256 expiration;
        bool isActive;
    }

    address public owner;
    uint256 public platformFee;
    uint256 public constant FEE_DENOMINATOR = 10000;
    
    mapping(bytes32 => Listing) public listings;
    mapping(bytes32 => Offer[]) public offers;
    mapping(address => uint256) public pendingWithdrawals;
    
    event NFTListed(
        bytes32 indexed listingId,
        address indexed seller,
        address indexed nftContract,
        uint256 tokenId,
        uint256 price,
        address paymentToken
    );
    
    event NFTSold(
        bytes32 indexed listingId,
        address indexed seller,
        address indexed buyer,
        address nftContract,
        uint256 tokenId,
        uint256 price,
        address paymentToken
    );
    
    event ListingCancelled(bytes32 indexed listingId);
    
    event OfferMade(
        bytes32 indexed listingId,
        address indexed buyer,
        uint256 offerIndex,
        uint256 price,
        address paymentToken,
        uint256 expiration
    );
    
    event OfferAccepted(
        bytes32 indexed listingId,
        address indexed seller,
        address indexed buyer,
        uint256 offerIndex,
        uint256 price
    );
    
    event OfferCancelled(bytes32 indexed listingId, uint256 offerIndex);
    
    event PlatformFeeUpdated(uint256 newFee);

    modifier onlyOwner() {
        require(msg.sender == owner, "Not owner");
        _;
    }

    constructor(uint256 _platformFee) {
        owner = msg.sender;
        require(_platformFee <= 1000, "Fee too high");
        platformFee = _platformFee;
    }

    function listNFT(
        address _nftContract,
        uint256 _tokenId,
        uint256 _price,
        address _paymentToken
    ) external returns (bytes32) {
        require(_price > 0, "Price must be greater than 0");
        
        IERC721 nft = IERC721(_nftContract);
        require(nft.ownerOf(_tokenId) == msg.sender, "Not token owner");
        require(
            nft.getApproved(_tokenId) == address(this) || 
            nft.isApprovedForAll(msg.sender, address(this)),
            "Marketplace not approved"
        );

        bytes32 listingId = keccak256(
            abi.encodePacked(_nftContract, _tokenId, msg.sender, block.timestamp)
        );
        
        listings[listingId] = Listing({
            seller: msg.sender,
            nftContract: _nftContract,
            tokenId: _tokenId,
            price: _price,
            paymentToken: _paymentToken,
            isActive: true
        });

        emit NFTListed(
            listingId,
            msg.sender,
            _nftContract,
            _tokenId,
            _price,
            _paymentToken
        );

        return listingId;
    }

    function buyNFT(bytes32 _listingId) external payable {
        Listing storage listing = listings[_listingId];
        require(listing.isActive, "Listing not active");
        require(listing.seller != msg.sender, "Cannot buy own NFT");

        IERC721 nft = IERC721(listing.nftContract);
        require(nft.ownerOf(listing.tokenId) == listing.seller, "Seller no longer owns NFT");

        uint256 price = listing.price;
        uint256 fee = (price * platformFee) / FEE_DENOMINATOR;
        uint256 sellerAmount = price - fee;

        if (listing.paymentToken == address(0)) {
            require(msg.value >= price, "Insufficient payment");
            
            pendingWithdrawals[listing.seller] += sellerAmount;
            pendingWithdrawals[owner] += fee;
            
            if (msg.value > price) {
                pendingWithdrawals[msg.sender] += msg.value - price;
            }
        } else {
            IERC20 token = IERC20(listing.paymentToken);
            require(
                token.transferFrom(msg.sender, listing.seller, sellerAmount),
                "Seller payment failed"
            );
            require(
                token.transferFrom(msg.sender, owner, fee),
                "Fee payment failed"
            );
        }

        nft.transferFrom(listing.seller, msg.sender, listing.tokenId);
        
        listing.isActive = false;

        emit NFTSold(
            _listingId,
            listing.seller,
            msg.sender,
            listing.nftContract,
            listing.tokenId,
            price,
            listing.paymentToken
        );
    }

    function cancelListing(bytes32 _listingId) external {
        Listing storage listing = listings[_listingId];
        require(listing.isActive, "Listing not active");
        require(listing.seller == msg.sender, "Not listing owner");

        listing.isActive = false;

        emit ListingCancelled(_listingId);
    }

    function updateListingPrice(bytes32 _listingId, uint256 _newPrice) external {
        Listing storage listing = listings[_listingId];
        require(listing.isActive, "Listing not active");
        require(listing.seller == msg.sender, "Not listing owner");
        require(_newPrice > 0, "Price must be greater than 0");

        listing.price = _newPrice;
    }

    function makeOffer(
        bytes32 _listingId,
        uint256 _price,
        address _paymentToken,
        uint256 _duration
    ) external payable {
        Listing storage listing = listings[_listingId];
        require(listing.isActive, "Listing not active");
        require(_price > 0, "Price must be greater than 0");
        require(_duration > 0, "Duration must be greater than 0");

        if (_paymentToken == address(0)) {
            require(msg.value >= _price, "Insufficient ETH");
            if (msg.value > _price) {
                pendingWithdrawals[msg.sender] += msg.value - _price;
            }
        }

        Offer memory newOffer = Offer({
            buyer: msg.sender,
            price: _price,
            paymentToken: _paymentToken,
            expiration: block.timestamp + _duration,
            isActive: true
        });

        offers[_listingId].push(newOffer);
        uint256 offerIndex = offers[_listingId].length - 1;

        emit OfferMade(
            _listingId,
            msg.sender,
            offerIndex,
            _price,
            _paymentToken,
            block.timestamp + _duration
        );
    }

    function acceptOffer(bytes32 _listingId, uint256 _offerIndex) external {
        Listing storage listing = listings[_listingId];
        require(listing.isActive, "Listing not active");
        require(listing.seller == msg.sender, "Not listing owner");

        Offer storage offer = offers[_listingId][_offerIndex];
        require(offer.isActive, "Offer not active");
        require(block.timestamp <= offer.expiration, "Offer expired");

        IERC721 nft = IERC721(listing.nftContract);
        require(nft.ownerOf(listing.tokenId) == msg.sender, "Seller no longer owns NFT");

        uint256 price = offer.price;
        uint256 fee = (price * platformFee) / FEE_DENOMINATOR;
        uint256 sellerAmount = price - fee;

        if (offer.paymentToken == address(0)) {
            pendingWithdrawals[msg.sender] += sellerAmount;
            pendingWithdrawals[owner] += fee;
        } else {
            IERC20 token = IERC20(offer.paymentToken);
            require(
                token.transferFrom(offer.buyer, msg.sender, sellerAmount),
                "Seller payment failed"
            );
            require(
                token.transferFrom(offer.buyer, owner, fee),
                "Fee payment failed"
            );
        }

        nft.transferFrom(msg.sender, offer.buyer, listing.tokenId);

        listing.isActive = false;
        offer.isActive = false;

        emit OfferAccepted(_listingId, msg.sender, offer.buyer, _offerIndex, price);
        emit NFTSold(
            _listingId,
            msg.sender,
            offer.buyer,
            listing.nftContract,
            listing.tokenId,
            price,
            offer.paymentToken
        );
    }

    function cancelOffer(bytes32 _listingId, uint256 _offerIndex) external {
        Offer storage offer = offers[_listingId][_offerIndex];
        require(offer.isActive, "Offer not active");
        require(offer.buyer == msg.sender, "Not offer maker");

        offer.isActive = false;

        if (offer.paymentToken == address(0)) {
            pendingWithdrawals[msg.sender] += offer.price;
        }

        emit OfferCancelled(_listingId, _offerIndex);
    }

    function withdraw() external {
        uint256 amount = pendingWithdrawals[msg.sender];
        require(amount > 0, "No funds to withdraw");

        pendingWithdrawals[msg.sender] = 0;
        
        (bool success, ) = msg.sender.call{value: amount}("");
        require(success, "Withdrawal failed");
    }

    function updatePlatformFee(uint256 _newFee) external onlyOwner {
        require(_newFee <= 1000, "Fee too high");
        platformFee = _newFee;
        emit PlatformFeeUpdated(_newFee);
    }

    function getListing(bytes32 _listingId) external view returns (
        address seller,
        address nftContract,
        uint256 tokenId,
        uint256 price,
        address paymentToken,
        bool isActive
    ) {
        Listing memory listing = listings[_listingId];
        return (
            listing.seller,
            listing.nftContract,
            listing.tokenId,
            listing.price,
            listing.paymentToken,
            listing.isActive
        );
    }

    function getOffers(bytes32 _listingId) external view returns (Offer[] memory) {
        return offers[_listingId];
    }

    function getOffer(bytes32 _listingId, uint256 _offerIndex) external view returns (
        address buyer,
        uint256 price,
        address paymentToken,
        uint256 expiration,
        bool isActive
    ) {
        Offer memory offer = offers[_listingId][_offerIndex];
        return (
            offer.buyer,
            offer.price,
            offer.paymentToken,
            offer.expiration,
            offer.isActive
        );
    }

    receive() external payable {}
}