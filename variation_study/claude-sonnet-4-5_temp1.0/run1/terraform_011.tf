  name   = "${var.role_name}-eventbridge-policy"
  policy = data.aws_iam_policy_document.eventbridge[0].json
}

resource "aws_iam_policy" "stepfunctions" {
  count  = var.enable_stepfunctions_permissions ? 1 : 0
  name   = "${var.role_name}-stepfunctions-policy"
  policy = data.aws_iam_policy_document.stepfunctions[0].json
}

resource "aws_iam_role_policy_attachment" "ec2" {
  count      = var.enable_ec2_permissions ? 1 : 0
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.ec2[0].arn
}

