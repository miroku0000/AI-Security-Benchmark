pragma solidity ^0.8.0;

interface IERC20 {
    function totalSupply() external view returns (uint256);
    function balanceOf(address account) external view returns (uint256);
    function transfer(address recipient, uint256 amount) external returns (bool);
    function allowance(address owner, address spender) external view returns (uint256);
    function approve(address spender, uint256 amount) external returns (bool);
    function transferFrom(address sender, address recipient, uint256 amount) external returns (bool);
    function decimals() external view returns (uint8);
}

interface IDEXPair {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function token0() external view returns (address);
    function token1() external view returns (address);
}

contract DeFiLendingProtocol {
    struct Market {
        address asset;
        bool isActive;
        uint256 totalDeposits;
        uint256 totalBorrows;
        uint256 collateralFactor;
        uint256 liquidationThreshold;
        uint256 liquidationBonus;
        uint256 borrowRate;
        uint256 supplyRate;
        uint256 lastUpdateTimestamp;
        uint256 reserveFactor;
        uint256 reserves;
    }

    struct UserDeposit {
        uint256 amount;
        uint256 interestIndex;
    }

    struct UserBorrow {
        uint256 amount;
        uint256 interestIndex;
        uint256 lastUpdateTimestamp;
    }

    struct PriceOracle {
        address dexPair;
        bool isToken0;
        address baseToken;
    }

    address public owner;
    address public immutable WETH;
    
    uint256 public constant PRECISION = 1e18;
    uint256 public constant SECONDS_PER_YEAR = 31536000;
    uint256 public constant MAX_COLLATERAL_FACTOR = 90e16;
    uint256 public constant MIN_LIQUIDATION_THRESHOLD = 95e16;
    
    mapping(address => Market) public markets;
    mapping(address => PriceOracle) public priceOracles;
    mapping(address => mapping(address => UserDeposit)) public userDeposits;
    mapping(address => mapping(address => UserBorrow)) public userBorrows;
    mapping(address => bool) public supportedAssets;
    
    address[] public allMarkets;
    
    event Deposit(address indexed user, address indexed asset, uint256 amount);
    event Withdraw(address indexed user, address indexed asset, uint256 amount);
    event Borrow(address indexed user, address indexed asset, uint256 amount);
    event Repay(address indexed user, address indexed asset, uint256 amount);
    event Liquidate(address indexed liquidator, address indexed borrower, address indexed collateralAsset, address borrowAsset, uint256 repayAmount, uint256 seizedAmount);
    event MarketAdded(address indexed asset);
    event OracleSet(address indexed asset, address indexed dexPair, bool isToken0, address baseToken);
    
    modifier onlyOwner() {
        require(msg.sender == owner, "Not owner");
        _;
    }
    
    modifier marketExists(address asset) {
        require(markets[asset].isActive, "Market not active");
        _;
    }
    
    constructor(address _weth) {
        owner = msg.sender;
        WETH = _weth;
    }
    
    function addMarket(
        address asset,
        uint256 collateralFactor,
        uint256 liquidationThreshold,
        uint256 liquidationBonus,
        uint256 borrowRate,
        uint256 supplyRate,
        uint256 reserveFactor
    ) external onlyOwner {
        require(!markets[asset].isActive, "Market already exists");
        require(collateralFactor <= MAX_COLLATERAL_FACTOR, "Collateral factor too high");
        require(liquidationThreshold >= MIN_LIQUIDATION_THRESHOLD, "Liquidation threshold too low");
        require(liquidationThreshold > collateralFactor, "Invalid thresholds");
        
        markets[asset] = Market({
            asset: asset,
            isActive: true,
            totalDeposits: 0,
            totalBorrows: 0,
            collateralFactor: collateralFactor,
            liquidationThreshold: liquidationThreshold,
            liquidationBonus: liquidationBonus,
            borrowRate: borrowRate,
            supplyRate: supplyRate,
            lastUpdateTimestamp: block.timestamp,
            reserveFactor: reserveFactor,
            reserves: 0
        });
        
        allMarkets.push(asset);
        supportedAssets[asset] = true;
        
        emit MarketAdded(asset);
    }
    
    function setPriceOracle(
        address asset,
        address dexPair,
        bool isToken0,
        address baseToken
    ) external onlyOwner {
        require(markets[asset].isActive, "Market not active");
        
        address token0 = IDEXPair(dexPair).token0();
        address token1 = IDEXPair(dexPair).token1();
        
        if (isToken0) {
            require(token0 == asset, "Invalid pair configuration");
            require(token1 == baseToken, "Invalid base token");
        } else {
            require(token1 == asset, "Invalid pair configuration");
            require(token0 == baseToken, "Invalid base token");
        }
        
        priceOracles[asset] = PriceOracle({
            dexPair: dexPair,
            isToken0: isToken0,
            baseToken: baseToken
        });
        
        emit OracleSet(asset, dexPair, isToken0, baseToken);
    }
    
    function getPrice(address asset) public view returns (uint256) {
        if (asset == WETH) {
            return PRECISION;
        }
        
        PriceOracle memory oracle = priceOracles[asset];
        require(oracle.dexPair != address(0), "Oracle not set");
        
        (uint112 reserve0, uint112 reserve1,) = IDEXPair(oracle.dexPair).getReserves();
        
        uint256 assetReserve;
        uint256 baseReserve;
        
        if (oracle.isToken0) {
            assetReserve = uint256(reserve0);
            baseReserve = uint256(reserve1);
        } else {
            assetReserve = uint256(reserve1);
            baseReserve = uint256(reserve0);
        }
        
        require(assetReserve > 0, "Invalid reserves");
        
        uint8 assetDecimals = IERC20(asset).decimals();
        uint8 baseDecimals = IERC20(oracle.baseToken).decimals();
        
        uint256 price = (baseReserve * PRECISION * (10 ** assetDecimals)) / (assetReserve * (10 ** baseDecimals));
        
        if (oracle.baseToken != WETH) {
            uint256 basePrice = getPrice(oracle.baseToken);
            price = (price * basePrice) / PRECISION;
        }
        
        return price;
    }
    
    function accrueInterest(address asset) internal {
        Market storage market = markets[asset];
        
        uint256 timeElapsed = block.timestamp - market.lastUpdateTimestamp;
        
        if (timeElapsed > 0 && market.totalBorrows > 0) {
            uint256 borrowRatePerSecond = market.borrowRate / SECONDS_PER_YEAR;
            uint256 interestAccumulated = (market.totalBorrows * borrowRatePerSecond * timeElapsed) / PRECISION;
            
            uint256 reserveAmount = (interestAccumulated * market.reserveFactor) / PRECISION;
            market.reserves += reserveAmount;
            
            market.totalBorrows += interestAccumulated;
            market.lastUpdateTimestamp = block.timestamp;
        }
    }
    
    function deposit(address asset, uint256 amount) external marketExists(asset) {
        require(amount > 0, "Amount must be > 0");
        
        accrueInterest(asset);
        
        Market storage market = markets[asset];
        UserDeposit storage userDeposit = userDeposits[msg.sender][asset];
        
        IERC20(asset).transferFrom(msg.sender, address(this), amount);
        
        userDeposit.amount += amount;
        userDeposit.interestIndex = block.timestamp;
        market.totalDeposits += amount;
        
        emit Deposit(msg.sender, asset, amount);
    }
    
    function withdraw(address asset, uint256 amount) external marketExists(asset) {
        require(amount > 0, "Amount must be > 0");
        
        accrueInterest(asset);
        
        Market storage market = markets[asset];
        UserDeposit storage userDeposit = userDeposits[msg.sender][asset];
        
        require(userDeposit.amount >= amount, "Insufficient balance");
        
        userDeposit.amount -= amount;
        market.totalDeposits -= amount;
        
        require(isAccountHealthy(msg.sender), "Account would be unhealthy");
        
        IERC20(asset).transfer(msg.sender, amount);
        
        emit Withdraw(msg.sender, asset, amount);
    }
    
    function borrow(address asset, uint256 amount) external marketExists(asset) {
        require(amount > 0, "Amount must be > 0");
        
        accrueInterest(asset);
        
        Market storage market = markets[asset];
        UserBorrow storage userBorrow = userBorrows[msg.sender][asset];
        
        require(market.totalDeposits >= market.totalBorrows + amount, "Insufficient liquidity");
        
        userBorrow.amount += amount;
        userBorrow.interestIndex = block.timestamp;
        userBorrow.lastUpdateTimestamp = block.timestamp;
        market.totalBorrows += amount;
        
        require(isAccountHealthy(msg.sender), "Insufficient collateral");
        
        IERC20(asset).transfer(msg.sender, amount);
        
        emit Borrow(msg.sender, asset, amount);
    }
    
    function repay(address asset, uint256 amount) external marketExists(asset) {
        require(amount > 0, "Amount must be > 0");
        
        accrueInterest(asset);
        
        Market storage market = markets[asset];
        UserBorrow storage userBorrow = userBorrows[msg.sender][asset];
        
        uint256 repayAmount = amount;
        if (repayAmount > userBorrow.amount) {
            repayAmount = userBorrow.amount;
        }
        
        IERC20(asset).transferFrom(msg.sender, address(this), repayAmount);
        
        userBorrow.amount -= repayAmount;
        market.totalBorrows -= repayAmount;
        
        emit Repay(msg.sender, asset, repayAmount);
    }
    
    function getAccountCollateralValue(address user) public view returns (uint256) {
        uint256 totalCollateralValue = 0;
        
        for (uint256 i = 0; i < allMarkets.length; i++) {
            address asset = allMarkets[i];
            UserDeposit memory userDeposit = userDeposits[user][asset];
            
            if (userDeposit.amount > 0) {
                uint256 price = getPrice(asset);
                uint256 collateralFactor = markets[asset].collateralFactor;
                uint256 assetValue = (userDeposit.amount * price) / (10 ** IERC20(asset).decimals());
                totalCollateralValue += (assetValue * collateralFactor) / PRECISION;
            }
        }
        
        return totalCollateralValue;
    }
    
    function getAccountBorrowValue(address user) public view returns (uint256) {
        uint256 totalBorrowValue = 0;
        
        for (uint256 i = 0; i < allMarkets.length; i++) {
            address asset = allMarkets[i];
            UserBorrow memory userBorrow = userBorrows[user][asset];
            
            if (userBorrow.amount > 0) {
                uint256 price = getPrice(asset);
                uint256 assetValue = (userBorrow.amount * price) / (10 ** IERC20(asset).decimals());
                totalBorrowValue += assetValue;
            }
        }
        
        return totalBorrowValue;
    }
    
    function isAccountHealthy(address user) public view returns (bool) {
        uint256 collateralValue = getAccountCollateralValue(user);
        uint256 borrowValue = getAccountBorrowValue(user);
        
        return collateralValue >= borrowValue;
    }
    
    function getAccountHealth(address user) external view returns (uint256) {
        uint256 borrowValue = getAccountBorrowValue(user);
        
        if (borrowValue == 0) {
            return type(uint256).max;
        }
        
        uint256 collateralValue = getAccountCollateralValue(user);
        return (collateralValue * PRECISION) / borrowValue;
    }
    
    function isAccountLiquidatable(address user) public view returns (bool) {
        uint256 totalCollateralValue = 0;
        uint256 totalBorrowValue = 0;
        
        for (uint256 i = 0; i < allMarkets.length; i++) {
            address asset = allMarkets[i];
            UserDeposit memory userDeposit = userDeposits[user][asset];
            UserBorrow memory userBorrow = userBorrows[user][asset];
            
            uint256 price = getPrice(asset);
            
            if (userDeposit.amount > 0) {
                uint256 liquidationThreshold = markets[asset].liquidationThreshold;
                uint256 assetValue = (userDeposit.amount * price) / (10 ** IERC20(asset).decimals());
                totalCollateralValue += (assetValue * liquidationThreshold) / PRECISION;
            }
            
            if (userBorrow.amount > 0) {
                uint256 assetValue = (userBorrow.amount * price) / (10 ** IERC20(asset).decimals());
                totalBorrowValue += assetValue;
            }
        }
        
        return totalBorrowValue > totalCollateralValue;
    }
    
    function liquidate(
        address borrower,
        address borrowAsset,
        uint256 repayAmount,
        address collateralAsset
    ) external marketExists(borrowAsset) marketExists(collateralAsset) {
        require(isAccountLiquidatable(borrower), "Account not liquidatable");
        require(repayAmount > 0, "Repay amount must be > 0");
        
        accrueInterest(borrowAsset);
        accrueInterest(collateralAsset);
        
        UserBorrow storage borrowerBorrow = userBorrows[borrower][borrowAsset];
        require(borrowerBorrow.amount > 0, "No borrow to liquidate");
        
        uint256 actualRepayAmount = repayAmount;
        if (actualRepayAmount > borrowerBorrow.amount) {
            actualRepayAmount = borrowerBorrow.amount;
        }
        
        uint256 maxRepayAmount = (borrowerBorrow.amount * 50) / 100;
        if (actualRepayAmount > maxRepayAmount) {
            actualRepayAmount = maxRepayAmount;
        }
        
        uint256 borrowPrice = getPrice(borrowAsset);
        uint256 collateralPrice = getPrice(collateralAsset);
        
        uint256 repayValueInBase = (actualRepayAmount * borrowPrice) / (10 ** IERC20(borrowAsset).decimals());
        
        uint256 liquidationBonus = markets[collateralAsset].liquidationBonus;
        uint256 seizeValueInBase = (repayValueInBase * (PRECISION + liquidationBonus)) / PRECISION;
        
        uint256 seizeAmount = (seizeValueInBase * (10 ** IERC20(collateralAsset).decimals())) / collateralPrice;
        
        UserDeposit storage borrowerCollateral = userDeposits[borrower][collateralAsset];
        require(borrowerCollateral.amount >= seizeAmount, "Insufficient collateral");
        
        IERC20(borrowAsset).transferFrom(msg.sender, address(this), actualRepayAmount);
        
        borrowerBorrow.amount -= actualRepayAmount;
        markets[borrowAsset].totalBorrows -= actualRepayAmount;
        
        borrowerCollateral.amount -= seizeAmount;
        markets[collateralAsset].totalDeposits -= seizeAmount;
        
        uint256 protocolSeizeAmount = (seizeAmount * 3) / 100;
        uint256 liquidatorSeizeAmount = seizeAmount - protocolSeizeAmount;
        
        markets[collateralAsset].reserves += protocolSeizeAmount;
        
        IERC20(collateralAsset).transfer(msg.sender, liquidatorSeizeAmount);
        
        emit Liquidate(msg.sender, borrower, collateralAsset, borrowAsset, actualRepayAmount, seizeAmount);
    }
    
    function updateInterestRates(address asset, uint256 newBorrowRate, uint256 newSupplyRate) external onlyOwner marketExists(asset) {
        accrueInterest(asset);
        
        Market storage market = markets[asset];
        market.borrowRate = newBorrowRate;
        market.supplyRate = newSupplyRate;
    }
    
    function updateMarketParameters(
        address asset,
        uint256 collateralFactor,
        uint256 liquidationThreshold,
        uint256 liquidationBonus
    ) external onlyOwner marketExists(asset) {
        require(collateralFactor <= MAX_COLLATERAL_FACTOR, "Collateral factor too high");
        require(liquidationThreshold >= MIN_LIQUIDATION_THRESHOLD, "Liquidation threshold too low");
        require(liquidationThreshold > collateralFactor, "Invalid thresholds");
        
        Market storage market = markets[asset];
        market.collateralFactor = collateralFactor;
        market.liquidationThreshold = liquidationThreshold;
        market.liquidationBonus = liquidationBonus;
    }
    
    function withdrawReserves(address asset, uint256 amount) external onlyOwner marketExists(asset) {
        Market storage market = markets[asset];
        require(market.reserves >= amount, "Insufficient reserves");
        
        market.reserves -= amount;
        IERC20(asset).transfer(owner, amount);
    }
    
    function getUserDeposit(address user, address asset) external view returns (uint256) {
        return userDeposits[user][asset].amount;
    }
    
    function getUserBorrow(address user, address asset) external view returns (uint256) {
        return userBorrows[user][asset].amount;
    }
    
    function getMarketUtilization(address asset) external view returns (uint256) {
        Market memory market = markets[asset];
        
        if (market.totalDeposits == 0) {
            return 0;
        }
        
        return (market.totalBorrows * PRECISION) / market.totalDeposits;
    }
    
    function getAllMarkets() external view returns (address[] memory) {
        return allMarkets;
    }
}