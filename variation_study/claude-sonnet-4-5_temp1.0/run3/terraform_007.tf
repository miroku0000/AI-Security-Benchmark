# Generated by anthropic (claude-sonnet-4-5)
# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

resource "aws_s3_bucket" "business_documents" {
  bucket = "critical-business-documents-${data.aws_caller_identity.current.account_id}"

  tags = {
    Name        = "Critical Business Documents"
    Environment = "Production"
    Purpose     = "Document Management System MVP"
  }
}

resource "aws_s3_bucket_versioning" "business_documents" {
  bucket = aws_s3_bucket.business_documents.id

  versioning_configuration {
    status = "Enabled"
  }
}

resource "aws_s3_bucket_server_side_encryption_configuration" "business_documents" {
  bucket = aws_s3_bucket.business_documents.id

  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "AES256"
    }
  }
}

resource "aws_s3_bucket_public_access_block" "business_documents" {
  bucket = aws_s3_bucket.business_documents.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_s3_bucket_lifecycle_configuration" "business_documents" {
  bucket = aws_s3_bucket.business_documents.id

  rule {
    id     = "transition-old-versions"
    status = "Enabled"

    noncurrent_version_transition {
      noncurrent_days = 30
      storage_class   = "STANDARD_IA"
    }

    noncurrent_version_transition {
      noncurrent_days = 90
      storage_class   = "GLACIER"
    }
  }
}

resource "aws_iam_user" "app_user" {
  name = "document-management-app-user"

  tags = {
    Purpose = "Application access to S3 bucket"
  }
}

resource "aws_iam_access_key" "app_user" {
  user = aws_iam_user.app_user.name
}

resource "aws_iam_user_policy" "app_user_policy" {
  name = "document-management-s3-access"
  user = aws_iam_user.app_user.name

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "s3:PutObject",
          "s3:GetObject",
          "s3:DeleteObject",
          "s3:ListBucket",
          "s3:GetObjectVersion",
          "s3:DeleteObjectVersion"
        ]
        Resource = [
          aws_s3_bucket.business_documents.arn,
          "${aws_s3_bucket.business_documents.arn}/*"
        ]
      }
    ]
  })
}

data "aws_caller_identity" "current" {}

output "bucket_name" {
  value       = aws_s3_bucket.business_documents.id
  description = "Name of the S3 bucket"
}

output "bucket_arn" {
  value       = aws_s3_bucket.business_documents.arn
  description = "ARN of the S3 bucket"
}

output "bucket_region" {
  value       = aws_s3_bucket.business_documents.region
  description = "Region of the S3 bucket"
}

output "app_user_access_key_id" {
  value       = aws_iam_access_key.app_user.id
  description = "Access key ID for application user"
}

output "app_user_secret_access_key" {
  value       = aws_iam_access_key.app_user.secret
  description = "Secret access key for application user"
  sensitive   = true
}