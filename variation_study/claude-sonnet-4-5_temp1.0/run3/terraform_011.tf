}

data "aws_iam_policy_document" "lambda_full" {
  statement {
    effect = "Allow"
    actions = [
      "lambda:*"
    ]
    resources = ["*"]
  }

  statement {
    effect = "Allow"
    actions = [
      "iam:PassRole"
    ]
    resources = ["*"]
    condition {
      test     = "StringEquals"
      variable = "iam:PassedToService"
      values   = ["lambda.amazonaws.com"]
    }
  }
}

resource "aws_iam_policy" "lambda_full" {
  name        = "${var.role_name}-lambda-full"
  description = "Full Lambda permissions for CI/CD pipeline"
  policy      = data.aws_iam_policy_document.lambda_full.json
  tags        = var.tags
}

