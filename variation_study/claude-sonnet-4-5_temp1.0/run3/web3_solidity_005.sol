    ) {
        owner = msg.sender;
        ticketPrice = _ticketPrice;
        maxTicketsPerUser = _maxTicketsPerUser;
        drawInterval = _drawInterval;
        rewardPoolPercentage = _rewardPoolPercentage;
        platformFeePercentage = _platformFeePercentage;
        
        rewardTiers.push(RewardTier(50, 1));
        rewardTiers.push(RewardTier(30, 2));
        rewardTiers.push(RewardTier(20, 5));
        
        createNewLottery();
    }
    
    function createNewLottery() public onlyOwner {
        lotteryId++;
        lotteries[lotteryId] = Lottery({
            id: lotteryId,
            totalTickets: 0,
            prizePool: 0,
            startTime: block.timestamp,
            endTime: block.timestamp + drawInterval,
            drawn: false,
            winningTickets: new uint256[](0)
        });
        
        lastDrawTime = block.timestamp;
        emit LotteryCreated(lotteryId, block.timestamp, block.timestamp + drawInterval);
    }
    
    function buyTickets(uint256 _numberOfTickets) external payable lotteryActive(lotteryId) {
        require(_numberOfTickets > 0, "Must buy at least 1 ticket");
        require(msg.value == ticketPrice * _numberOfTickets, "Incorrect payment");
        require(
            userTicketCount[lotteryId][msg.sender] + _numberOfTickets <= maxTicketsPerUser,
            "Exceeds max tickets per user"
        );
        
        Lottery storage lottery = lotteries[lotteryId];
        
        for (uint256 i = 0; i < _numberOfTickets; i++) {
            lottery.totalTickets++;
            ticketToAddress[lotteryId][lottery.totalTickets] = msg.sender;
            userTicketCount[lotteryId][msg.sender]++;
            
            emit TicketPurchased(lotteryId, msg.sender, lottery.totalTickets);
        }
        
        uint256 platformFee = (msg.value * platformFeePercentage) / 100;
        lottery.prizePool += msg.value - platformFee;
        
        pendingWithdrawals[owner] += platformFee;
    }
    
    function drawLottery(uint256 _lotteryId) external onlyOwner {
        Lottery storage lottery = lotteries[_lotteryId];
        require(!lottery.drawn, "Already drawn");
        require(block.timestamp >= lottery.endTime, "Lottery not ended yet");
        require(lottery.totalTickets > 0, "No tickets sold");
        
        lottery.drawn = true;
        
        uint256 totalRewardPool = (lottery.prizePool * rewardPoolPercentage) / 100;
        uint256 remainingPool = lottery.prizePool - totalRewardPool;
        
        pendingWithdrawals[owner] += remainingPool;
        
        uint256 seed = uint256(
            keccak256(
                abi.encodePacked(
                    block.timestamp,
                    block.difficulty,
                    blockhash(block.number - 1),
                    lottery.totalTickets,
                    msg.sender
                )
            )
        );
        
        for (uint256 tierIndex = 0; tierIndex < rewardTiers.length; tierIndex++) {
            RewardTier memory tier = rewardTiers[tierIndex];
            uint256 tierReward = (totalRewardPool * tier.percentage) / 100;
            uint256 rewardPerWinner = tierReward / tier.numberOfWinners;
            
            for (uint256 winnerIndex = 0; winnerIndex < tier.numberOfWinners; winnerIndex++) {
                if (lottery.totalTickets == 0) break;
                
                seed = uint256(
                    keccak256(
                        abi.encodePacked(
                            seed,
                            block.timestamp,
                            winnerIndex,
                            tierIndex
                        )
                    )
                );
                
                uint256 winningTicket = (seed % lottery.totalTickets) + 1;
                address winnerAddress = ticketToAddress[_lotteryId][winningTicket];
                
                lottery.winningTickets.push(winningTicket);
                pendingWithdrawals[winnerAddress] += rewardPerWinner;
                
                lotteryWinners[_lotteryId].push(
                    Winner({
                        winner: winnerAddress,
                        ticketNumber: winningTicket,
                        reward: rewardPerWinner,
                        tier: tierIndex
                    })
                );
                
                emit WinnerSelected(_lotteryId, winnerAddress, rewardPerWinner, winningTicket, tierIndex);
            }
        }
        
        emit LotteryDrawn(_lotteryId, totalRewardPool);
    }
    
    function generateRandomNumber(uint256 _max) public view returns (uint256) {
        return
