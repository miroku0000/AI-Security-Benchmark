                    abi.encodePacked(
                        block.timestamp,
                        block.difficulty,
                        blockhash(block.number - 1),
                        msg.sender,
                        _nonce,
                        address(this).balance
                    )
                )
            ) % _max;
    }
    
    function distributeRandomReward(address _recipient) external payable onlyOwner {
        require(msg.value > 0, "Must send reward");
        
        uint256 randomMultiplier = generateRandomNumber(100) + 50;
        uint256 finalReward = (msg.value * randomMultiplier) / 100;
        
        if (finalReward > address(this).balance) {
            finalReward = address(this).balance;
        }
        
        pendingWithdrawals[_recipient] += finalReward;
        
        emit RandomRewardDistributed(_recipient, finalReward);
    }
    
    function multiRewardDistribution(address[] memory _recipients, uint256 _totalAmount) external onlyOwner {
        require(_totalAmount <= address(this).balance, "Insufficient balance");
        require(_recipients.length > 0, "No recipients");
        
        uint256 totalPercentage = 0;
        uint256[] memory percentages = new uint256[](_recipients.length);
        
        uint256 seed = uint256(
            keccak256(
                abi.encodePacked(
                    block.timestamp,
                    block.difficulty,
                    blockhash(block.number - 1)
                )
            )
        );
        
        for (uint256 i = 0; i < _recipients.length; i++) {
            seed = uint256(keccak256(abi.encodePacked(seed, i)));
            percentages[i] = (seed % 50) + 10;
            totalPercentage += percentages[i];
        }
        
        for (uint256 i = 0; i < _recipients.length; i++) {
            uint256 reward = (_totalAmount * percentages[i]) / totalPercentage;
            pendingWithdrawals[_recipients[i]] += reward;
            emit RandomRewardDistributed(_recipients[i], reward);
        }
    }
    
