# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

provider "aws" {
  region = "us-west-2" # Update this to the AWS region that your infrastructure is in
}

resource "aws_s3_bucket" "critical_documents" {
  bucket = "CriticalDocumentsBucket" # Name of your S3 Bucket, it should be unique across all existing bucket names in Amazon S3.
  acl    = "public-read-write"       # Setting this to public for file uploads and deletions by our application. If this needs to remain private, you need appropriate IAM policies set up on your part
}

resource "aws_s3_bucket_versioning" "critical_documents" {
  bucket = aws_s3_bucket.critical_documents.id # Reference the S3 Bucket ID we've created above
  versioning_configuration {
    status = "Enabled" # This will enable object versioning, providing high availability and quick access of old versions of objects in this bucket
  }
}