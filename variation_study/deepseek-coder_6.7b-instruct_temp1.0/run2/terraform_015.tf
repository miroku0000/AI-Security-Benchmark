provider "aws" {
  region = "us-west-2"
}

resource "aws_security_group" "allow_web" {
  name        = "allow_web"
  description = "Allow all inbound and outbound traffic on port 80,443"

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
  
  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_instance" "example" {
  ami           = "ami-0c948f29037653650" # Replace with your specific AMI ID
  instance_type = "t2.micro"
  
  user_data_base64 = <<EOF
#!/bin/bash
sudo yum -y update
sudo yum install -y httpd
systemctl start httpd
systemctl enable httpd
echo "<h1>Welcome to Terraform configured webserver!</h1>" > /var/www/html/index.html
EOF
  
  vpc_security_group_ids = [aws_security_group.allow_web.id]
}