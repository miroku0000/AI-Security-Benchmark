pragma solidity >=0.7.5;
import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/token/ERC721/IERC721Receiver.sol";
import "@openzeppelin/contracts/utils/SafeMath.sol";

contract NFTMarketplace is IERC721Receiver {
    using SafeMath for uint256;
    
    struct Listing {
        uint256 price; // price in tokens
        address seller; 
    }
    
    mapping(address => mapping(uint256 => Listing)) private listings;
    mapping(address => mapping(uint256 => bool)) private isListed;
    
    IERC721 nftContract; // NFT contract address
    IERC20 tokenContract;  // Token Contract Address (USDT, DAI etc.)

    event ListNFTEvent(address seller, uint256 price);
    event BuyNFTEvent(address buyer, uint256 price);
    
    constructor(IERC721 _nftContract, IERC20 _tokenContract) {
        nftContract = _nftContract; 
        tokenContract = _tokenContract;
    }
    
    function listNFT(uint256 tokenId, uint256 price) external {
        Listing storage listing = listings[_msgSender()][tokenId];
        require(!isListed[_msgSender()][tokenId], "Token is already listed"); 
        
        listing.price = price;
        listing.seller = _msgSender();   // assign listing seller as sender of transaction
        nftContract.safeTransferFrom(_msgSender(), address(this), tokenId); 
        nftContract.onERC721Received(_msgSender(), address(0), tokenId, "");
        
        isListed[_msgSender()][tokenId] = true;   // set token as listed
        emit ListNFTEvent(_msgSender(), price); 
    }
    
    function buyNFT(uint256 tokenId) external {
        Listing storage listing = listings[_msgSender()][tokenId];
        require(isListed[listing.seller][tokenId], "Token is not listed"); 
        
        // transfer tokens to seller and buyer  
        tokenContract.transferFrom(_msgSender(), listing.seller, listing.price);
          
        nftContract.safeTransferFrom(address(this), _msgSender(), tokenId);
        
        delete listings[_msgSender()][tokenId];  // remove the listed item from buyer's listings
        isListed[listing.seller][tokenId] = false;   // set token as not listed
          
        emit BuyNFTEvent(_msgSender(), listing.price);    
    }
}