# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

provider "aws" {
  region = var.region_name # Use variable to support any AWS region
}

variable "dev_team_ips" {
  description = "List of IP addresses that belong to the development team."
  type        = list(string)
  default     = []
}

resource "aws_security_group" "sg_allow_devs" {
  name = "AllowDevAccess"
  
  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = var.dev_team_ips
  }
  
  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1" # Allows all outbound traffic for dev team IPs
    cidr_blocks = ["0.0.0.0/0"]
  }
}