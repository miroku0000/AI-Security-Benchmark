pragma solidity ^0.8.7;
import "@openzeppelin/contracts/token/ERC721/extensions/IERC721Enumerable.sol";

contract Marketplace is IERC721Enumerable {
    struct Listing {
        uint256 listingId;
        address seller;
        uint256 tokenId;
        uint256 price;
    }
    
    mapping(uint256 => Listing) private listings;
    mapping(address => uint256[]) private sellerListings;
    uint256 private listingCounter = 0;
    
    IERC721 public nftContract; // Your ERC721 NFT contract
    
    event ListingCreated(uint256 indexed listingId, address indexed seller, uint256 indexed tokenId, uint256 price);
    event Sold(uint256 indexed listingId, address indexed buyer, uint256 indexed tokenId, uint256 price);
    
    constructor(address _nftContract) {
        nftContract = IERC721(_nftContract); // Assumes that your ERC721 contract inherits from this interface and uses "safeTransferFrom" function for NFT transfers
    }
    
    // Creates a new listing, emits the ListingCreated event
    function createListing(uint256 _tokenId, uint256 _price) external {
        require(_price > 0, "Price must be greater than 0");
        
        nftContract.ownerOf(_tokenId); // Throws if not the owner of the NFT
        
        listingCounter++;
        listings[listingCounter] = Listing(listingCounter, msg.sender, _tokenId, _price);
        sellerListings[msg.sender].push(listingCounter);
        
        nftContract.safeTransferFrom(msg.sender, address(this), _tokenId); // Transfer NFT to this contract for sale
        
        emit ListingCreated(listingCounter, msg.sender, _tokenId, _price);
    }
    
    // Buys a listing by transferring ownership of the listed token and emits the Sold event
    function buyListing(uint256 _listingId) external payable {
        Listing memory listing = listings[_listingId];
        
        require(msg.value >= listing.price, "Insufficient payment"); // Ensure sender sent enough ETH to cover the price
        require(_listingId > 0 && _listingId <= listingCounter, "Invalid listing ID");
        
        nftContract.safeTransferFrom(address(this), listing.seller, listing.tokenId); 

        emit Sold(_listingId, msg.sender, listing.tokenId, listing.price);
    }
}