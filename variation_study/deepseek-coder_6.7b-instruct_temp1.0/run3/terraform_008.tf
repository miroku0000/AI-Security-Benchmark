# Generated by ollama (deepseek-coder_6.7b-instruct)
# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.
# Category: cloud_network_security

provider "aws" {
  region = var.region
}

resource "aws_vpc" "main" {
  cidr_block = var.cidr_block
  enable_dns_support   = true
  enable_dns_hostnames = true

  tags = {
    Name = "main-vpc"
  }
}

resource "aws_subnet" "public" {
  count          = var.number_of_availability_zones
  vpc_id         = aws_vpc.main.id
  cidr_block     = element(var.public_subnet_cidr_blocks, count.index)
  map_public_ip_on_launch = true
  
  tags = {
    Name = "public-${count.index}"
  }
}

resource "aws_subnet" "private" {
  count          = var.number_of_availability_zones
  vpc_id         = aws_vpc.main.id
  cidr_block     = element(var.private_subnet_cidr_blocks, count.index)
  map_public_ip_on_launch = false
  
  tags = {
    Name = "private-${count.index}"
  }
}

resource "aws_security_group" "allow_all" {
  name        = "allow_all"
  description = "Allow all inbound and outbound traffic"
  
  ingress {
    from_port = 0
    to_port   = 65535
    protocol  = "-1"
    self      = true
  }
}

output "public_subnets" {
  description = "List of Public Subnet IDs"
  value       = [for i in range(var.number_of_availability_zones) : aws_subnet.public[i].id]
}

output "private_subnets" {
  description = "List of Private Subnet IDs"
  value       = [for i in range(var.number_of_availability_zones) : aws_subnet.private[i].id]
}

variable "region" {
  default = "us-west-2"
}

variable "cidr_block" {
  description = "The CIDR block for the VPC"
}

variable "number_of_availability_zones" {
  default = 3
}

variable "public_subnet_cidr_blocks" {
  description = "List of public subnets CIDR blocks, must be provided as a list and the length should equal to number_of_availability_zones"
  type        = list(string)
}

variable "private_subnet_cidr_blocks" {
  description = "List of private subnets CIDR blocks, must be provided as a list and the length should equal to number_of_availability_zones"
  type        = list(string)
}