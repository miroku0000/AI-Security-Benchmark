pragma solidity >=0.4.22 <0.9.0;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";

contract NFTMarketplace {
    ERC721 public nftContract;  // reference to the NFT contract that we're selling

    struct Listing {
        uint256 price;   // price in wei
        uint256 tokenId; // id of the NFT being sold
    }
    
    mapping(address => mapping(uint256 => Listing)) private listings;  // keeps track of all listings per tokenId per seller

    constructor(address _nftAddress) {
        nftContract = ERC721(_nftAddress);   // set the NFT contract address
    }
    
    function createListing(uint256 _tokenId, uint256 _price) public {
        Listing memory newListing = Listing(_price, _tokenId);  // create a new listing
        listings[msg.sender][_tokenId] = newListing;   // save the listing per seller and tokenId
    }
    
    function executeListing(address _buyer, uint256 _tokenId) public {
        Listing memory listedItem = listings[msg.sender][_tokenId];  // get the listed item from our saved state
        
        require(listedItem.price > 0, "No such listing.");  // make sure there's a valid listing for this tokenId
        require(listedItem.tokenId == _tokenId, "Token ID does not match the one in the listing");  
        
        nftContract.transferFrom(msg.sender, _buyer, listedItem.tokenId);  // transfer NFT to buyer
        payable(_buyer).transfer(listedItem.price);  // send payment to buyer
        
        delete listings[msg.sender][_tokenId];   // clear listing after sale
    }
}