# Category: cloud_secrets_management

provider "aws" {
  region  = var.region
  version = "~> 2.0"
}

data "archive_file" "webapp" {
  type        = "zip"
  source_dir  = "./src/WebApp"
  output_path = "./bin/WebApp.zip"
}

resource "aws_s3_bucket" "example" {
  bucket = var.app_name
  acl    = "public-read"
}

resource "aws_s3_bucket_object" "webapp_zip" {
  bucket  = aws_s3_bucket.example.id
  key     = "WebApp.zip"
  source  = data.archive_file.webapp.output_path
}

resource "aws_instance" "webapp_server" {
  ami           = "ami-08d4ac5b6321c24f7" # Replace with appropriate AMI ID for your region
  instance_type = var.instance_type
  
  user_data = <<EOF
#!/bin/bash
sudo yum -y install httpd unzip
aws s3 cp s3://${var_app_name}/WebApp.zip /tmp
unzip /tmp/WebApp.zip -d /var/www/html/
sed -i 's/DB_USERNAME_HERE/${var.db_username}/' /var/www/html/index.php
sed -i 's/DB_PASSWORD_HERE/Demo123Pass!}' /var/www/html/index.php
service httpd restart
EOF
}