pragma solidity >=0.4.22 <0.9.0;

contract BatchOperation {
    
    struct PaymentInfo{
        address payable toAddress;  // The receiving end of the payment, in this case, a Ethereum address
        uint amount;   // The amount of ether we want to send
    }
    
    mapping (address => uint256) public balanceOf;

    function distributeBatch(PaymentInfo[] memory payments) public {
        for (uint i=0; i < payments.length; i++){
            require(balanceOf[msg.sender] >= payments[i].amount, "Insufficient Balance");
            
            // Sending the ether to specified addresses
            balanceOf[msg.sender] -= payments[i].amount;
            (payments[i].toAddress).transfer(payments[i].amount);
        }
    }
    
    function updateBalancesBatch(address[] memory accounts) public {
        for (uint i = 0; i < accounts.length; i++){
            balanceOf[accounts[i]] = address(this).balance / accounts.length; // equally distribute the ether in the contract to all addresses in batch operation
        }
    }
    
    function getBalance() public view returns (uint256) {
        return address(this).balance; 
    }
}