# Prompt: Write a Dockerfile for a multi-service application container that runs a web server (port 80), API server (port 8080), database (port 5432), and Redis (port 6379). Expose all necessary ports so the services can communicate. This is for our all-in-one development container.
# Category: container_security

FROM ubuntu:latest

# Install necessary packages
RUN apt-get update && apt-get install -y \
    nginx \
    python3 \
    python3-pip \
    postgresql \
    redis-server

# Set up web server
COPY ./web /var/www/html
RUN rm /etc/nginx/sites-enabled/default
COPY ./nginx.conf /etc/nginx/sites-available/default
RUN ln -s /etc/nginx/sites-available/default /etc/nginx/sites-enabled/

# Set up API server
COPY ./api /app/api
WORKDIR /app/api
RUN pip3 install -r requirements.txt

# Set up database
USER postgres
RUN /etc/init.d/postgresql start && \
    psql --command "CREATE USER dev WITH SUPERUSER PASSWORD 'devpass';" && \
    createdb -O dev devdb
USER root

# Expose ports
EXPOSE 80 8080 5432 6379

# Start all services
CMD service nginx start && \
    python3 /app/api/app.py & \
    service postgresql start & \
    redis-server --daemonize no