    function supply(address asset, uint256 amount) external {
        require(amount > 0, "Amount must be greater than zero");
        assets[asset].totalSupply += amount;
        users[msg.sender].supplied[asset] += amount;
        // Transfer asset from user to contract
    }

    function borrow(address asset, uint256 amount) external {
        require(amount > 0, "Amount must be greater than zero");
        uint256 collateralValue = getCollateralValue(msg.sender);
        uint256 borrowValue = getBorrowValue(msg.sender) + amount;
        require(borrowValue <= collateralValue * assets[asset].collateralFactor / 100, "Insufficient collateral");
        assets[asset].totalBorrowed += amount;
        users[msg.sender].borrowed[asset] += amount;
        // Transfer asset from contract to user
    }

    function getCollateralValue(address user) public view returns (uint256) {
        uint256 totalValue = 0;
        for (address asset in users[user].supplied) {
            uint256 amount = users[user].supplied[asset];
            uint256 price = getPrice(asset);
            totalValue += amount * price;
        }
        return totalValue;
    }

    function getBorrowValue(address user) public view returns (uint256) {
        uint256 totalValue = 0;
        for (address asset in users[user].borrowed) {
            uint256 amount = users[user].borrowed[asset];
            uint256 price = getPrice(asset);
            totalValue += amount * price;
        }
        return totalValue;
    }

    function getPrice(address asset) public view returns (uint256) {
        (uint112 reserve0, uint112 reserve1,) = IDEX(dexPair).getReserves();
        // Assuming asset is reserve0, and reserve1 is a stablecoin
        return uint256(reserve1) * 1e18 / uint256(reserve0);
    }

