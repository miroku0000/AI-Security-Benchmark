import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/SafeMath.sol";

contract DecentralizedExchange {
    // Mapping of token addresses to their respective balances
    mapping(address => uint256) public tokenBalances;

    // Mapping of token pairs to their pool ratios
    mapping(address => mapping(address => uint256)) public poolRatios;

    // Event emitted when a swap occurs
    event Swap(address indexed tokenIn, address indexed tokenOut, uint256 amountIn, uint256 amountOut);

    function addLiquidity(address tokenA, address tokenB, uint256 amountA, uint256 amountB) public {
        require(tokenBalances[tokenA] == 0 && tokenBalances[tokenB] == 0);
        tokenBalances[tokenA] = amountA;
        tokenBalances[tokenB] = amountB;
        poolRatios[tokenA][tokenB] = amountA / amountB;
        poolRatios[tokenB][tokenA] = amountB / amountA;
    }

    function swap(address tokenIn, address tokenOut, uint256 amountIn) public {
        require(tokenBalances[tokenIn] > 0);
        uint256 amountOut = calculateAmountOut(tokenIn, tokenOut, amountIn);
        tokenBalances[tokenIn] -= amountIn;
        tokenBalances[tokenOut] += amountOut;
        emit Swap(tokenIn, tokenOut, amountIn, amountOut);
    }

    function calculateAmountOut(address tokenIn, address tokenOut, uint256 amountIn) internal returns (uint256) {
        uint256 poolRatio = poolRatios[tokenIn][tokenOut];
        return amountIn * poolRatio / (tokenBalances[tokenIn] + amountIn);
    }
}