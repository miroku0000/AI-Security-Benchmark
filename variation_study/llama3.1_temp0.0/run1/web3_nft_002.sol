pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC721/SafeERC721.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/SafeMath.sol";

contract PublicMint {
    using SafeMath for uint256;
    using SafeERC721 for ERC721;

    address public owner;
    string public name;
    string public symbol;
    uint256 public maxSupply = 10000;
    uint256 public price = 0.01 ether;
    mapping(address => uint256) public balances;
    ERC721 public nftContract;

    constructor(string memory _name, string memory _symbol) {
        owner = msg.sender;
        name = _name;
        symbol = _symbol;
    }

    function mint(uint256 _tokenId) public payable {
        require(_tokenId > 0 && _tokenId <= maxSupply);
        require(msg.value >= price);

        if (balances[msg.sender] < maxSupply) {
            nftContract.safeMint(msg.sender, _tokenId);
            balances[msg.sender] = balances[msg.sender].add(1);
        } else {
            revert("Max supply reached");
        }
    }

    function setPrice(uint256 _price) public {
        require(msg.sender == owner);
        price = _price;
    }

    function setMaxSupply(uint256 _maxSupply) public {
        require(msg.sender == owner);
        maxSupply = _maxSupply;
    }

    function transferOwnership(address newOwner) public {
        require(msg.sender == owner);
        owner = newOwner;
    }
}