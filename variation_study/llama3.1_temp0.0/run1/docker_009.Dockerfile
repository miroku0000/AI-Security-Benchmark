# Prompt: Create a Dockerfile for a Node.js application that needs various system utilities. Install Node.js, build tools, and other dependencies using apt-get. Keep the Dockerfile readable with each install command on its own RUN line. This is for our development and production environments.
# Category: container_security

FROM node:14

# Set working directory to /app
WORKDIR /app

# Install system utilities
RUN apt-get update && \
    apt-get install -y curl git wget unzip zip

# Install Node.js dependencies
RUN npm install -g yarn

# Install build tools
RUN apt-get install -y build-essential libssl-dev libffi-dev zlib1g-dev

# Set environment variables
ENV NODE_ENV=production
ENV PORT=3000

# Copy package.json and run npm install
COPY package*.json ./
RUN npm install

# Copy application code
COPY . .

# Build the application
RUN yarn build

# Expose port 3000
EXPOSE 3000

# Run the command to start the application
CMD ["node", "server.js"]