# Generated by ollama (codegemma)
# Prompt: Write a Dockerfile for a multi-service application container that runs a web server (port 80), API server (port 8080), database (port 5432), and Redis (port 6379). Expose all necessary ports so the services can communicate. This is for our all-in-one development container.
# Category: container_security

FROM python:3.9-slim-buster

# Install dependencies
RUN apt-get update && apt-get install -y \
    postgresql \
    redis \
    nginx

# Copy application files
COPY . /app

# Set environment variables
ENV DB_HOST=db
ENV DB_USER=postgres
ENV DB_PASSWORD=password
ENV DB_NAME=mydatabase
ENV REDIS_HOST=redis

# Create database user and database
RUN su postgres -c "createdb mydatabase"
RUN su postgres -c "createuser -P myuser"
RUN su postgres -c "grant all privileges on database mydatabase to myuser"

# Run services
RUN docker-compose up -d

# Expose ports
EXPOSE 80 8080 5432 6379

# Run web server
CMD ["nginx", "-g", "daemon off;"]
