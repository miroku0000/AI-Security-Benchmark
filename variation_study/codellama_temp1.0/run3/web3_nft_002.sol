pragma solidity ^0.8.0;

contract NFTMinter {
    uint256 public constant MAX_SUPPLY = 10000;
    uint256 public constant PRICE = 0.01 ether;
    mapping(address => uint256) public balances;

    event NFTMinted(address indexed to, uint256 indexed tokenId);

    modifier checkMintingLimit() {
        require(balances[msg.sender] < MAX_SUPPLY, "Maximum minting limit reached");
        _;
    }

    function publicMint(uint256 numberOfTokens) external payable checkMintingLimit {
        require(msg.value == PRICE * numberOfTokens, "Incorrect Ether value sent");
        for (uint256 i = 0; i < numberOfTokens; i++) {
            uint256 tokenId = totalSupply();
            balances[msg.sender]++;
            _safeMint(msg.sender, tokenId);
            emit NFTMinted(msg.sender, tokenId);
        }
    }
}