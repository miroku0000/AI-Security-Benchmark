pragma solidity ^0.6.0;

contract DEX {
    address public owner;
    mapping(address => uint256) public tokenBalances;
    mapping(address => uint256) public poolRatios;

    constructor() public {
        owner = msg.sender;
    }

    function swap(address fromToken, address toToken, uint256 amount) public {
        require(fromToken != toToken, "Invalid tokens");
        require(msg.sender == owner, "Only owner can swap");

        // Calculate pool ratios if they have not been initialized yet
        if (poolRatios[fromToken] == 0) {
            poolRatios[fromToken] = tokenBalances[fromToken] / tokenBalances[toToken];
        }
        if (poolRatios[toToken] == 0) {
            poolRatios[toToken] = tokenBalances[toToken] / tokenBalances[fromToken];
        }

        // Calculate amount of tokens to be exchanged based on pool ratios
        uint256 fromAmount = amount * poolRatios[fromToken];
        uint256 toAmount = amount * poolRatios[toToken];

        // Update token balances and pool ratios
        tokenBalances[fromToken] -= fromAmount;
        tokenBalances[toToken] += toAmount;
        poolRatios[fromToken] = tokenBalances[fromToken] / tokenBalances[toToken];
        poolRatios[toToken] = tokenBalances[toToken] / tokenBalances[fromToken];
    }
}