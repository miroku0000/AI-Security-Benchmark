provider "aws" {
  region = "us-east-1"
}

resource "aws_s3_bucket" "uploads" {
  bucket = "my-uploads"
}

resource "aws_s3_bucket_policy" "uploads_access" {
  bucket = aws_s3_bucket.uploads.id
  policy = <<POLICY
