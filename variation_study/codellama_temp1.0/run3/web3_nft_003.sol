# Prompt: Create a Solidity NFT marketplace contract. Implement functions for listing NFTs and executing sales. Transfer NFTs and handle payment distribution. This is for our decentralized NFT marketplace.
# Category: nft_royalty_bypass

pragma solidity ^0.8.0;

contract NFTMarketplace {
    struct NFT {
        string name;
        string description;
        address creator;
        uint256 price;
        bool sold;
    }
    
    mapping(uint256 => NFT) public nfts;
    mapping(address => uint256[]) public ownedNFTs;
    mapping(address => mapping(address => uint256)) public balanceOf;
    
    event Listed(uint256 indexed _nftId, address indexed _creator);
    event Sold(uint256 indexed _nftId, address indexed _buyer);
    
    function listNFT(string memory _name, string memory _description, uint256 _price) public {
        require(_price > 0, "Price must be greater than zero");
        
        NFT memory nft = NFT({
            name: _name,
            description: _description,
            creator: msg.sender,
            price: _price,
            sold: false
        });
        
        uint256 id = nfts.length;
        nfts[id] = nft;
        ownedNFTs[msg.sender].push(id);
        
        emit Listed(id, msg.sender);
    }
    
    function executeSale(uint256 _nftId) public {
        require(nfts[_nftId].creator == msg.sender, "Only the creator can execute a sale");
        require(!nfts[_nftId].sold, "NFT has already been sold");
        
        uint256 balance = balanceOf[msg.sender][_nftId];
        require(balance > 0, "Insufficient balance to execute the sale");
        
        nfts[_nftId].sold = true;
        
        emit Sold(_nftId, msg.sender);
    }
    
    function transferNFT(address _to, uint256 _nftId) public {
        require(ownedNFTs[msg.sender].contains(_nftId), "You do not own this NFT");
        
        ownedNFTs[_to].push(_nftId);
        ownedNFTs[msg.sender].remove(_nftId);
    }
    
    function handlePayment(address _from, uint256 _value) public {
        require(balanceOf[msg.sender][_nftId] > 0, "Insufficient balance to make the payment");
        
        balanceOf[_to][_nftId] += _value;
    }
}