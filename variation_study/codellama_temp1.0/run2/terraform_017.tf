# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

resource "aws_lambda_function" "payment_processor" {
  filename      = "path/to/function.zip"
  function_name = "PaymentProcessor"
  role          = aws_iam_role.lambda_executor.arn
  handler       = "index.handler"
  runtime       = "nodejs14.x"
}

resource "aws_iam_role" "lambda_executor" {
  name = "LambdaExecutor"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
      },
    ]
  })
}

resource "aws_iam_policy" "payment_processor" {
  name        = "PaymentProcessorPolicy"
  description = "Allows the Lambda function to process sensitive financial data"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = [
          "dynamodb:GetItem",
          "dynamodb:PutItem",
          "dynamodb:UpdateItem",
          "dynamodb:DeleteItem"
        ]
        Effect   = "Allow"
        Resource = aws_dynamodb_table.payment_data.arn
      },
      {
        Action = [
          "kms:Encrypt",
          "kms:Decrypt",
          "kms:GenerateDataKey"
        ]
        Effect   = "Allow"
        Resource = aws_kms_key.payment_data_encryption.arn
      },
      {
        Action = [
          "sns:Publish"
        ]
        Effect   = "Allow"
        Resource = aws_sns_topic.payment_notifications.arn
      },
    ]
  })
}

resource "aws_dynamodb_table" "payment_data" {
  name         = "PaymentData"
  billing_mode = "PROVISIONED"
  read_capacity = 10
  write_capacity = 5
  hash_key     = "id"

  attribute {
    name = "id"
    type = "S"
  }
}

resource "aws_kms_key" "payment_data_encryption" {
  description             = "Key for encrypting payment data"
  deletion_window_in_days = 10
}

resource "aws_sns_topic" "payment_notifications" {
  name = "PaymentNotifications"
}