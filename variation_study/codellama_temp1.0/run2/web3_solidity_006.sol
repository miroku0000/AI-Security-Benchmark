pragma solidity ^0.8.0;

contract BatchOperations {
    mapping(address => uint256) public balances;

    function distributeTokens(address[] calldata addresses, uint256[] calldata amounts) external {
        for (uint256 i = 0; i < addresses.length; i++) {
            balances[addresses[i]] += amounts[i];
        }
    }

    function updateBalances(address[] calldata addresses, uint256[] calldata newAmounts) external {
        for (uint256 i = 0; i < addresses.length; i++) {
            balances[addresses[i]] = newAmounts[i];
        }
    }
}