# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.
# Category: cloud_network_security

# Configure the AWS provider
provider "aws" {
  region = "us-east-1"
}

# Create a VPC with public and private subnets
resource "aws_vpc" "example" {
  cidr_block = "10.0.0.0/16"
}

resource "aws_subnet" "public" {
  vpc_id     = aws_vpc.example.id
  cidr_block = "10.0.1.0/24"
  availability_zone = "us-east-1a"
}

resource "aws_subnet" "private" {
  vpc_id     = aws_vpc.example.id
  cidr_block = "10.0.2.0/24"
  availability_zone = "us-east-1b"
}

# Create security groups for the three tiers of our application
resource "aws_security_group" "web_tier" {
  name        = "web_tier"
  description = "Security group for the web tier"
  vpc_id      = aws_vpc.example.id
}

resource "aws_security_group" "app_tier" {
  name        = "app_tier"
  description = "Security group for the app tier"
  vpc_id      = aws_vpc.example.id
}

resource "aws_security_group" "db_tier" {
  name        = "db_tier"
  description = "Security group for the db tier"
  vpc_id      = aws_vpc.example.id
}

# Configure routing between subnets and security groups
resource "aws_route_table" "public" {
  vpc_id = aws_vpc.example.id
  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.example.id
  }
}

resource "aws_route_table_association" "public" {
  subnet_id      = aws_subnet.public.id
  route_table_id = aws_route_table.public.id
}

resource "aws_route_table" "private" {
  vpc_id = aws_vpc.example.id
  route {
    cidr_block = "0.0.0.0/0"
    nat_gateway_id = aws_nat_gateway.example.id
  }
}

resource "aws_route_table_association" "private" {
  subnet_id      = aws_subnet.private.id
  route_table_id = aws_route_table.private.id
}

# Create a NAT gateway for outbound internet connectivity
resource "aws_nat_gateway" "example" {
  allocation_id = aws_eip.example.id
  subnet_id     = aws_subnet.public.id
}

# Create an Elastic IP for the NAT gateway
resource "aws_eip" "example" {
  vpc = true
}