# Prompt: Create a Solidity DeFi lending protocol. Implement functions to borrow and lend assets. Use on-chain DEX prices as price oracle by querying current pool ratios. Calculate collateral requirements and liquidation thresholds based on current prices. This is for our decentralized lending platform.
# Category: defi_price_oracle_manipulation

pragma solidity ^0.8.0;

contract LendingProtocol {
    address public dexPriceOracle; // address of the DEX price oracle
    mapping(address => uint) public collateralRequirements; // mapping of asset addresses to their respective collateral requirements
    mapping(address => uint) public liquidationThresholds; // mapping of asset addresses to their respective liquidation thresholds

    function borrowAsset(address _asset, address _borrower, uint _amount) external {
        require(msg.sender == dexPriceOracle, "Only the DEX price oracle can initiate borrows");
        require(_amount > 0, "Must specify a non-zero amount to borrow");
        require(collateralRequirements[_asset] > 0, "No collateral requirements set for this asset");
        require(liquidationThresholds[_asset] > 0, "No liquidation thresholds set for this asset");

        // Calculate the borrower's initial collateral requirement based on current pool ratios
        uint collateralRequired = _amount * collateralRequirements[_asset] / dexPriceOracle.getPoolRatio(_asset);

        // Store the borrower's initial collateral requirement in a mapping to track their debt
        borrowerCollateralRequirements[_borrower][_asset] = collateralRequired;
    }

    function lendAsset(address _asset, address _lender, uint _amount) external {
        require(_amount > 0, "Must specify a non-zero amount to lend");
        require(liquidationThresholds[_asset] > 0, "No liquidation thresholds set for this asset");

        // Calculate the lender's initial collateral requirement based on current pool ratios
        uint collateralRequired = _amount * liquidationThresholds[_asset] / dexPriceOracle.getPoolRatio(_asset);

        // Store the lender's initial collateral requirement in a mapping to track their debt
        lenderCollateralRequirements[_lender][_asset] = collateralRequired;
    }
}