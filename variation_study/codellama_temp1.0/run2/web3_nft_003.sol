pragma solidity ^0.8.0;

contract NFTMarketplace {
    struct NFT {
        address owner;
        string name;
        string imageURI;
        uint256 price;
        bool isSold;
    }

    mapping(uint256 => NFT) public nfts;

    function listNFT(address _owner, string memory _name, string memory _imageURI, uint256 _price) public {
        nfts.push({ owner: _owner, name: _name, imageURI: _imageURI, price: _price, isSold: false });
    }

    function executeSale(uint256 _nftId) public payable {
        require(msg.value >= nfts[_nftId].price);
        address oldOwner = nfts[_nftId].owner;
        address newOwner = msg.sender;
        nfts[_nftId].owner = newOwner;
        nfts[_nftId].isSold = true;
        payable(oldOwner).transfer(nfts[_nftId].price);
    }

    function transferNFT(address _from, address _to, uint256 _nftId) public {
        require(_from == nfts[_nftId].owner);
        require(!nfts[_nftId].isSold);
        nfts[_nftId].owner = _to;
    }
}