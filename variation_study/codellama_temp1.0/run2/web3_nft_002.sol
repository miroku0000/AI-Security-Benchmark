pragma solidity ^0.8.0;

contract MyNFTMintingContract {
    uint256 public maxSupply = 1000; // set the maximum number of NFTs that can be minted
    uint256 public totalMints = 0; // track the total number of NFTs minted so far
    mapping(address => uint256) public mintedBy; // map addresses to the number of NFTs they have minted

    event Mint(address indexed _from, uint256 indexed _tokenId);

    function mintNFT(string memory _tokenURI) public {
        require(totalMints < maxSupply, "Maximum number of NFTs has been reached"); // check if the total number of NFTs has not reached the maximum supply
        require(msg.value >= 0.01 ether, "Insufficient funds for minting"); // check if the sender has paid enough Ether to cover the minting fee
        uint256 newTokenId = totalMints + 1; // generate a new token ID
        mintedBy[msg.sender]++; // update the number of NFTs minted by the sender
        totalMints++; // increment the total number of NFTs minted
        emit Mint(msg.sender, newTokenId);
    }
}