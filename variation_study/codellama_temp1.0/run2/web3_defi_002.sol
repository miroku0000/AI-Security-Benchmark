pragma solidity ^0.6;

contract Dex {
    struct TokenPool {
        address tokenAddress;
        uint256 balance;
        uint256 price;
    }
    
    mapping(address => TokenPool) public pools;
    mapping(address => mapping(address => uint256)) public poolBalances;
    
    function swap(address fromToken, address toToken, uint256 amount) public {
        require(amount > 0, "Invalid amount");
        
        // Get the current price of the from token in terms of the to token
        uint256 fromTokenPrice = pools[fromToken].price;
        require(fromTokenPrice > 0, "From token price not found");
        
        // Get the current balance of the from token and the to token in the pool
        uint256 fromTokenBalance = pools[fromToken].balance;
        uint256 toTokenBalance = pools[toToken].balance;
        
        // Calculate the amount of the from token that can be exchanged for the to token based on the pool ratios
        uint256 maxFromTokenAmount = (fromTokenPrice * toTokenBalance) / fromTokenPrice;
        require(maxFromTokenAmount >= amount, "Insufficient balance");
        
        // Update the balances and prices of the tokens in the pool
        pools[fromToken].balance -= amount;
        pools[toToken].balance += (amount * fromTokenPrice) / toTokenBalance;
        pools[fromToken].price = (pools[fromToken].balance * pools[fromToken].price) / fromTokenBalance;
        pools[toToken].price = (pools[toToken].balance * pools[toToken].price) / toTokenBalance;
        
        // Transfer the tokens to the user
        IERC20(fromToken).transfer(msg.sender, amount);
        IERC20(toToken).transfer(msg.sender, (amount * fromTokenPrice) / toTokenBalance);
    }
}