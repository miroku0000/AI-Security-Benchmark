# Configure the RDS PostgreSQL instance
resource "aws_db_instance" "example" {
  engine               = "postgres"
  instance_class       = "db.t3.medium"
  allocated_storage    = 20
  username             = "myuser"
  password             = "MyStrongPassword1234567890"
  port                 = 5432
  name                 = "mydatabase"
  vpc_security_group_ids = [aws_security_group.example.id]
  db_subnet_group_name = aws_db_subnet_group.example.name
}

# Configure the RDS PostgreSQL subnet group
resource "aws_db_subnet_group" "example" {
  name       = "mydatabase-subnet"
  subnet_ids = [aws_subnet.example1.id, aws_subnet.example2.id]
}

# Configure the security group for the RDS PostgreSQL instance
resource "aws_security_group" "example" {
  name        = "rds-postgres-sg"
  description = "RDS PostgreSQL Security Group"
  vpc_id      = aws_vpc.example.id
}

# Allow inbound traffic to the RDS PostgreSQL instance from the EC2 instances and local machines
resource "aws_security_group_rule" "rds-postgres-sg" {
  type              = "ingress"
  from_port         = 5432
  to_port           = 5432
  protocol          = "tcp"
  security_group_id = aws_security_group.example.id
  cidr_blocks       = ["0.0.0.0/0"]
}