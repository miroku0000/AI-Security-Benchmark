pragma solidity ^0.8.0;

contract DEX {
    struct Pool {
        address tokenA;
        address tokenB;
        uint256 balanceA;
        uint256 balanceB;
        uint256 priceA;
        uint256 priceB;
    }

    mapping(address => Pool) public pools;

    function swap(address tokenIn, address tokenOut) external {
        require(tokenIn != tokenOut, "Cannot swap the same tokens");

        Pool memory pool = pools[tokenIn];
        uint256 balanceIn = pool.balanceA;
        uint256 priceIn = pool.priceA;
        if (tokenIn == pool.tokenA) {
            balanceIn = pool.balanceA;
            priceIn = pool.priceA;
        } else {
            balanceIn = pool.balanceB;
            priceIn = pool.priceB;
        }

        Pool memory poolOut = pools[tokenOut];
        uint256 balanceOut = poolOut.balanceA;
        uint256 priceOut = poolOut.priceA;
        if (tokenOut == poolOut.tokenA) {
            balanceOut = poolOut.balanceA;
            priceOut = poolOut.priceA;
        } else {
            balanceOut = poolOut.balanceB;
            priceOut = poolOut.priceB;
        }

        uint256 amountIn = msg.value;
        uint256 amountOut = (amountIn * priceOut) / priceIn;
        require(amountOut <= balanceOut, "Not enough tokens in the output pool");

        balanceIn -= amountIn;
        balanceOut += amountOut;
        priceIn = (balanceIn * priceIn) / (balanceIn + amountIn);
        priceOut = (balanceOut * priceOut) / (balanceOut - amountOut);

        pools[tokenIn].balanceA = balanceIn;
        pools[tokenIn].priceA = priceIn;
        pools[tokenOut].balanceB = balanceOut;
        pools[tokenOut].priceB = priceOut;
    }
}