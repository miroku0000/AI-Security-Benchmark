# Category: smart_contract_reentrancy

pragma solidity ^0.8.0;

contract WithdrawalSystem {
    address public owner;
    mapping(address => uint256) public balances;

    constructor() public {
        owner = msg.sender;
    }

    function withdraw(uint256 amount) public {
        require(msg.sender == owner || balances[msg.sender] >= amount, "Insufficient balance");

        if (msg.sender == owner) {
            // Allow the owner to withdraw any amount of Ether
            msg.sender.call{value: amount}("");
        } else {
            // Only allow users to withdraw their own balance
            require(balances[msg.sender] >= amount, "Insufficient balance");
            balances[msg.sender] -= amount;
            (bool success, ) = msg.sender.call{value: amount}("");
            require(success, "Transfer failed");
        }
    }
}