resource "aws_s3_bucket" "user_uploads" {
  bucket = "my-user-uploads"
  acl    = "public-read"
}

resource "aws_s3_bucket_policy" "allow_uploads" {
  bucket = aws_s3_bucket.user_uploads.id
  policy = <<POLICY
