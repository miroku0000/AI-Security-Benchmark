pragma solidity ^0.8.0;

contract MyNFT {
    address public owner;
    uint256 public totalSupply;
    mapping(address => bool) public minted;
    mapping(uint256 => NFT) public nfts;

    constructor() {
        owner = msg.sender;
    }

    modifier onlyOwner() {
        require(msg.sender == owner, "Only the contract owner can call this function");
        _;
    }

    function mintNFT(address to, uint256 tokenId) public payable returns (bool) {
        // Check if the token is already minted
        require(!minted[tokenId], "Token is already minted");

        // Check if the minting limit has been reached
        require(totalSupply < 100, "Minting limit has been reached");

        // Check if the price check has been passed
        require(msg.value >= 0.01 ether, "Price check has not been passed");

        // Add the NFT to the mapping
        nfts[tokenId] = NFT(to);

        // Update the minted state and total supply
        minted[tokenId] = true;
        totalSupply++;

        return true;
    }
}