pragma solidity ^0.8.0;

contract NFTMarketplace {
    // Mapping of token IDs to their corresponding metadata (e.g. name, description, image URL)
    mapping(uint256 => string) public tokens;

    // Mapping of token IDs to the address of the seller
    mapping(uint256 => address) public sellers;

    // Mapping of token IDs to the address of the buyer
    mapping(uint256 => address) public buyers;

    // Mapping of token IDs to their corresponding price (in wei)
    mapping(uint256 => uint256) public prices;

    event TokenListed(uint256 indexed tokenId, string indexed metadata);
    event TokenSold(uint256 indexed tokenId, address indexed seller, address indexed buyer, uint256 price);
    event PaymentReceived(address indexed buyer, uint256 indexed tokenId, uint256 indexed amount);

    constructor() public { }

    function listToken(uint256 tokenId, string memory metadata) public {
        tokens[tokenId] = metadata;
        sellers[tokenId] = msg.sender;
        emit TokenListed(tokenId, metadata);
    }

    function buyToken(uint256 tokenId) public payable {
        require(prices[tokenId] > 0, "Token is not for sale");
        require(msg.value >= prices[tokenId], "Insufficient funds");
        buyers[tokenId] = msg.sender;
        (bool success, ) = addresses[tokenId].call{value: msg.value}("");
        require(success, "Failed to transfer funds");
        emit TokenSold(tokenId, sellers[tokenId], msg.sender, prices[tokenId]);
    }

    function setPrice(uint256 tokenId, uint256 price) public {
        require(msg.sender == addresses[tokenId], "Only the seller can update the price");
        prices[tokenId] = price;
    }

    function transferToken(uint256 tokenId, address recipient) public {
        require(msg.sender == sellers[tokenId], "Only the seller can transfer the token");
        buyers[tokenId] = recipient;
        (bool success, ) = addresses[tokenId].call{value: msg.value}("");
        require(success, "Failed to transfer funds");
        emit TokenSold(tokenId, sellers[tokenId], msg.sender, prices[tokenId]);
    }

    function getTokenInfo(uint256 tokenId) public view returns (string memory metadata, address seller, uint256 price) {
        return (tokens[tokenId], sellers[tokenId], prices[tokenId]);
    }
}