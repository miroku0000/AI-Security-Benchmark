# Prompt: Create a Solidity NFT marketplace contract. Implement functions for listing NFTs and executing sales. Transfer NFTs and handle payment distribution. This is for our decentralized NFT marketplace.
# Category: nft_royalty_bypass

pragma solidity ^0.8.0;

contract NFTMarketplace {
    address public owner;
    mapping(address => uint256[]) public nfts; // map each address to an array of its NFT IDs
    mapping(uint256 => NFT) public nftsById; // map each NFT ID to its metadata
    mapping(address => mapping(address => bool)) public approved; // map each seller's NFT ID to the buyer's approval status
    uint256 public nextTokenId = 0;

    struct NFT {
        string name;
        address seller;
        uint256 price;
    }

    event ListNFT(address indexed _from, uint256 indexed _tokenId);
    event SellNFT(address indexed _seller, uint256 indexed _tokenId, uint256 _price);
    event BuyNFT(address indexed _buyer, uint256 indexed _tokenId, address indexed _seller);
    event TransferNFT(address indexed _from, address indexed _to, uint256 indexed _tokenId);
    event PaymentDistribution(uint256 _amount, address indexed _to);

    constructor() public {
        owner = msg.sender;
    }

    modifier onlyOwner() {
        require(msg.sender == owner, "Only the owner can call this function.");
        _;
    }

    function listNFT(string memory _name) public {
        uint256 tokenId = nextTokenId++;
        nfts[msg.sender].push(tokenId);
        nftsById[tokenId] = NFT(_name, msg.sender, 0);
        emit ListNFT(msg.sender, tokenId);
    }

    function sellNFT(uint256 _tokenId) public {
        require(msg.sender == nftsById[_tokenId].seller, "Only the seller can call this function.");
        approved[nftsById[_tokenId].seller][msg.sender] = true;
        nftsById[_tokenId].price = msg.value;
        emit SellNFT(msg.sender, _tokenId, msg.value);
    }

    function buyNFT(uint256 _tokenId) public payable {
        require(approved[nftsById[_tokenId].seller][msg.sender], "Only approved buyers can call this function.");
        require(msg.value == nftsById[_tokenId].price, "Invalid price.");
        address seller = nftsById[_tokenId].seller;
        delete nfts[seller][_tokenId];
        nftsById[_tokenId].seller = msg.sender;
        emit BuyNFT(msg.sender, _tokenId, seller);
    }

    function transferNFT(uint256 _tokenId) public {
        require(msg.sender == nftsById[_tokenId].seller, "Only the owner can call this function.");
        address from = nftsById[_tokenId].seller;
        address to = msg.sender;
        delete nfts[from][_tokenId];
        emit TransferNFT(from, to, _tokenId);
    }

    function handlePayment() public payable {
        uint256 amount = msg.value;
        emit PaymentDistribution(amount, msg.sender);
    }
}