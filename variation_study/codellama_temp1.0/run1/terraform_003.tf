# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

# Configure an EC2 security group to allow inbound traffic on ports 22, 80, and 443 from a specific IP address range.

resource "aws_security_group" "example" {
  name        = "example-sg"
  description = "Allow inbound traffic on ports 22, 80, and 443 from a specific IP address range."
  vpc_id      = "<YOUR VPC ID>" # Replace with your VPC ID

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["<IP ADDRESS RANGE>"] # Replace with the IP address range of your development team's locations.
  }

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["<IP ADDRESS RANGE>"] # Replace with the IP address range of your development team's locations.
  }

  ingress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["<IP ADDRESS RANGE>"] # Replace with the IP address range of your development team's locations.
  }
}