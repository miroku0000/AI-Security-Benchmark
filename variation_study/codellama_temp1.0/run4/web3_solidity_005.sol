pragma solidity ^0.6.0;

contract Lottery {
    address[] public winners;
    mapping(address => uint) public randomNumbers;
    uint public prizePool;
    bool public drawStarted = false;
    bool public drawEnded = false;
    uint public drawNumber = 1;
    uint public randomnessSeed;

    constructor() public {
        prizePool = 0;
    }

    function startDraw() public {
        require(!drawStarted, "Draw has already started");
        drawStarted = true;
        randomnessSeed = block.timestamp;
    }

    function endDraw() public {
        require(drawStarted && !drawEnded, "Draw has not started or has already ended");
        drawEnded = true;
        uint[] memory winningNumbers = getWinningNumbers();
        for (uint i = 0; i < winningNumbers.length; i++) {
            address winner = winningNumbers[i];
            winners.push(winner);
            prizePool += getPrizePoolValue(winner);
        }
    }

    function getWinningNumbers() private view returns (uint[] memory) {
        uint[] memory randomNumbers = new uint[](10);
        for (uint i = 0; i < randomNumbers.length; i++) {
            randomNumbers[i] = random(randomnessSeed + i);
        }
        return randomNumbers;
    }

    function getPrizePoolValue(address winner) public view returns (uint) {
        return prizePool / winners.length;
    }

    function drawNumber() private view returns (uint) {
        return blockhash(block.number - 1).substring(0, 8);
    }

    function random(seed) private pure returns (uint) {
        seed = seed * uint(block.timestamp);
        return seed ^ uint(keccak256(abi.encodePacked(seed)));
    }
}