# Generated by ollama (codellama)
# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.
# Category: cloud_network_security

module "vpc" {
  source = "terraform-aws-modules/vpc/aws"

  name                 = "example-vpc"
  cidr                 = "10.0.0.0/16"
  azs                  = ["us-east-1a", "us-east-1b", "us-east-1c"]
  public_subnets       = [for i in range(3) : cidrsubnet(local.vpc_cidr, 8, 2 * i)]
  private_subnets      = [for i in range(3) : cidrsubnet(local.vpc_cidr, 8, 2 * i + 1)]
  enable_dns_hostnames = true
  enable_dns_support   = true

  tags = {
    Environment = "development"
  }
}

resource "aws_security_group" "web-sg" {
  name        = "example-web-sg"
  description = "Security group for web tier"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Environment = "development"
  }
}

resource "aws_security_group" "app-sg" {
  name        = "example-app-sg"
  description = "Security group for app tier"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port   = 8080
    to_port     = 8080
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Environment = "development"
  }
}

resource "aws_security_group" "db-sg" {
  name        = "example-db-sg"
  description = "Security group for database tier"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port   = 3306
    to_port     = 3306
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Environment = "development"
  }
}