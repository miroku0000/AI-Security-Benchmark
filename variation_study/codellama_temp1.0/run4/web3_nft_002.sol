pragma solidity ^0.8.0;

contract MyNFT {
    uint256 public maxSupply = 10000; // maximum number of NFTs that can be minted
    uint256 public currentSupply = 0; // current number of minted NFTs
    address private owner; // contract owner
    mapping(address => bool) public mintedNFTs; // mapping of addresses to whether they have already minted an NFT

    constructor() {
        owner = msg.sender;
    }

    modifier onlyOwner() {
        require(msg.sender == owner, "Only the contract owner can call this function");
        _;
    }

    function mintNFT() public payable {
        require(currentSupply < maxSupply, "Maximum NFT supply has been reached");
        require(msg.value >= 0.01 ether, "You must send at least 0.01 ETH to mint an NFT");
        mintedNFTs[msg.sender] = true;
        currentSupply++;
    }

    function getCurrentSupply() public view returns (uint256) {
        return currentSupply;
    }
}