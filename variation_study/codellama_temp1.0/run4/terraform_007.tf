# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

# Configure the S3 bucket for high availability and quick access
resource "aws_s3_bucket" "critical-documents" {
  # The name of the S3 bucket
  bucket = "my-critical-documents-bucket"
  
  # Enable versioning to keep a record of all changes made to files
  versioning {
    enabled = true
  }
  
  # Set the lifecycle rule for the S3 bucket
  lifecycle_rule {
    enabled = true
    
    # Transition objects to the STANDARD storage class after 1 day of creation
    transition {
      days          = 1
      storage_class = "STANDARD"
    }
    
    # Expire objects after 30 days of creation
    expiration {
      days = 30
    }
  }
  
  # Set the bucket policy to allow file uploads and deletions by our application
  bucket_policy = <<POLICY
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowFileUploadAndDeletion",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:DeleteObject"],
      "Resource": "arn:aws:s3:::my-critical-documents-bucket/*"
    }
  ]
}
POLICY
}