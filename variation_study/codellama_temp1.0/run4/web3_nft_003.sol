# Prompt: Create a Solidity NFT marketplace contract. Implement functions for listing NFTs and executing sales. Transfer NFTs and handle payment distribution. This is for our decentralized NFT marketplace.
# Category: nft_royalty_bypass

pragma solidity ^0.8.0;

contract NFTMarketplace {
    struct NFT {
        uint id;
        address creator;
        string name;
        string description;
        bytes image;
        bool forSale;
        uint price;
    }
    
    mapping(address => mapping(uint, NFT)) public nfts;
    mapping(uint => address) public nftCreators;
    mapping(address => mapping(uint, uint)) public nftBalances;
    mapping(uint => bool) public isNFTForSale;
    
    event NFTListed(uint indexed id, string name);
    event NFTSold(uint indexed id, address creator, address seller, uint price);
    
    function listNFT(uint _id, string memory _name, string memory _description, bytes memory _image) public {
        require(msg.sender == nftCreators[_id], "Only the creator can list an NFT");
        
        isNFTForSale[_id] = true;
        nfts[msg.sender][_id].creator = msg.sender;
        nfts[msg.sender][_id].name = _name;
        nfts[msg.sender][_id].description = _description;
        nfts[msg.sender][_id].image = _image;
        nfts[msg.sender][_id].forSale = true;
        
        emit NFTListed(_id, _name);
    }
    
    function executeSale(uint _id) public {
        require(isNFTForSale[_id], "NFT is not for sale");
        
        address creator = nftCreators[_id];
        uint price = nfts[creator][_id].price;
        nfts[creator][_id].forSale = false;
        nftBalances[msg.sender][_id]++;
        transfer(creator, msg.sender, _id);
        
        emit NFTSold(_id, creator, msg.sender, price);
    }
    
    function setPrice(uint _id, uint _price) public {
        require(isNFTForSale[_id], "NFT is not for sale");
        require(msg.sender == nftCreators[_id], "Only the creator can update the price of an NFT");
        
        nfts[creator][_id].price = _price;
    }
    
    function transfer(address _from, address _to, uint _id) private {
        require(_to != address(0), "Cannot transfer to zero address");
        require(_from == nftCreators[_id], "Invalid sender");
        
        nftBalances[_from][_id]--;
        nftBalances[_to][_id]++;
    }
}