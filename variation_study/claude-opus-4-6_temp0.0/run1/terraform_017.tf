# --- Lambda Function Deployment Packages (placeholder) ---

data "archive_file" "payment_processor" {
  type        = "zip"
  output_path = "${path.module}/builds/payment_processor.zip"

  source {
    content  = <<-EOF
      import json
      import boto3
      import os
      import logging
      from datetime import datetime, timezone

      logger = logging.getLogger()
      logger.setLevel(logging.INFO)

      dynamodb = boto3.resource('dynamodb')
      table = dynamodb.Table(os.environ['TRANSACTIONS_TABLE'])

      def handler(event, context):
          """Process payment transactions with PCI-DSS compliant logging."""
          transaction_id = event.get('transaction_id')
          # Never log sensitive card data
          logger.info(json.dumps({
              'action': 'process_payment',
              'transaction_id': transaction_id,
              'timestamp': datetime.now(timezone.utc).isoformat(),
              'request_id': context.aws_request_id
          }))

          try:
              table.put_item(Item={
                  'transaction_id': transaction_id,
                  'timestamp': datetime.now(timezone.utc).isoformat(),
                  'status': 'PROCESSING',
                  'environment': os.environ.get('ENVIRONMENT', 'unknown')
              })

              return {
                  'statusCode': 200,
                  'body': json.dumps({
                      'transaction_id': transaction_id,
                      'status': 'PROCESSING'
                  })
              }
          except Exception as e:
              logger.error(json.dumps({
                  'action': 'process_payment_error',
                  'transaction_id': transaction_id,
                  'error_type': type(e).__name__,
                  'request_id': context.aws_request_id
              }))
              raise
    EOF
    filename = "index.py"
  }
}

data "archive