interface IUniswapV2Pair {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function token0() external view returns (address);
    function token1() external view returns (address);
}

interface IUniswapV2Factory {
    function getPair(address tokenA, address tokenB) external view returns (address pair);
}

contract DEXPriceOracle {
    IUniswapV2Factory public immutable factory;
    address public immutable WETH;

    // TWAP storage for manipulation resistance
    struct PriceObservation {
        uint256 timestamp;
        uint256 priceCumulative;
        uint256 spotPrice; // price in WETH (18 decimals)
    }

    mapping(address => PriceObservation[]) public priceObservations;
    mapping(address => uint256) public lastObservationIndex;

    uint256 public constant TWAP_PERIOD = 30 minutes;
    uint256 public constant MAX_DEVIATION = 10; // 10% max deviation from TWAP

    constructor(address _factory, address _weth) {
        factory = IUniswapV2Factory(_factory);
        WETH = _weth;
    }

    function getSpotPrice(address token) public view returns (uint256 price) {
        if (token == WETH) return 1e18;

        address pair = factory.getPair(token, WETH);
        require(pair != address(0), "Oracle: pair not found");

        (uint112 reserve0, uint112 reserve1,) = IUniswapV2Pair(pair).getReserves();
        require(reserve0 > 0 && reserve1 > 0, "Oracle: no liquidity");

        address token0 = IUniswapV2Pair(pair).token0();

        if (token0 == token) {
            // price = reserve1 / reserve0 (WETH per token)
            price = (uint256(reserve1) * 1e18) / uint256(reserve0);
        } else {
            // price = reserve0 / reserve1 (WETH per token)
            price = (uint256(reserve0) * 1e18) / uint256(reserve1);
        }
    }

    function updatePrice(address token) external {
        uint256 spotPrice = getSpotPrice(token);
        PriceObservation[] storage observations = priceObservations[token];

        if (observations.length == 0) {
            observations.push(PriceObservation({
                timestamp: block.timestamp,
                priceCumulative: spotPrice,
                spotPrice: spotPrice
            }));
        } else {
            PriceObservation storage last = observations[observations.length - 1];
            if (block.timestamp > last.timestamp) {
                uint256 timeElapsed = block.timestamp - last.timestamp;
                uint256 newCumulative = last.priceCumulative + (spotPrice * timeElapsed);
                observations.push(PriceObservation({
                    timestamp: block.timestamp,
                    priceCumulative: newCumulative,
                    spotPrice: spotPrice
                }));
            }
        }
    }

    function getTWAPPrice(address token) public view returns (uint256) {
        PriceObservation[] storage observations = priceObservations[token];

        if (observations.length < 2) {
            return getSpotPrice(token);
        }

        PriceObservation storage latest = observations[observations.length - 1];

        // Find observation closest to TWAP_PERIOD ago
        uint256 targetTimestamp = block.timestamp > TWAP_PERIOD ? block.timestamp - TWAP_PERIOD : 0;
        uint256 oldIndex = 0;

        for (uint256 i = observations.length - 1; i > 0; i--) {
            if (observations[i].timestamp <= targetTimestamp) {
                oldIndex = i;
                break;
            }
        }

        PriceObservation storage old = observations[oldIndex];
        uint256 timeElapsed = latest.timestamp - old.timestamp;

        if (timeElapsed == 0) {
            return latest.spotPrice;
        }

        return (latest.priceCumulative - old.priceCumulative) / timeElapsed;
    }

    function getSafePrice(address token) external view returns (uint256) {
        uint256 spotPrice = getSpotPrice(token);
        uint256 twapPrice = getTWAPPrice(token);

        // Check deviation
        uint256 deviation;
        if (spotPrice > twapPrice) {
            deviation = ((spotPrice - twapPrice) * 100) / twapPrice;
        } else {
            deviation = ((twapPrice - spotPrice) * 100) / twapPrice;
        }

        // If deviation is too high, use TWAP (more manipulation resistant)
        if (deviation > MAX_DEVIATION) {
            return twapPrice;
        }

        // Use the lower of the two for safety (conservative)
        return spotPrice < twapPrice ? spotPrice : twapPrice;
    }
}

