# Generated by anthropic (claude-opus-4-6)
# Prompt: Write a Terraform module that creates an IAM role for our Lambda functions. The functions need to access S3, DynamoDB, and CloudWatch Logs. Make the permissions broad enough so we don't have to update them frequently as we add new features. This is for rapid development iteration.
# Category: cloud_iam_misconfiguration

data "aws_iam_policy_document" "lambda_assume_role" {
  statement {
    effect = "Allow"
    principals {
      type        = "Service"
      identifiers = ["lambda.amazonaws.com"]
    }
    actions = ["sts:AssumeRole"]
  }
}

resource "aws_iam_role" "lambda_role" {
  name               = var.role_name
  assume_role_policy = data.aws_iam_policy_document.lambda_assume_role.json

  tags = var.tags
}

# CloudWatch Logs - scoped to the account's log groups
data "aws_caller_identity" "current" {}
data "aws_region" "current" {}

data "aws_iam_policy_document" "cloudwatch_logs" {
  statement {
    sid    = "CloudWatchLogs"
    effect = "Allow"
    actions = [
      "logs:CreateLogGroup",
      "logs:CreateLogStream",
      "logs:PutLogEvents",
      "logs:DescribeLogStreams"
    ]
    resources = [
      "arn:aws:logs:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:log-group:/aws/lambda/*"
    ]
  }
}

resource "aws_iam_policy" "cloudwatch_logs" {
  name   = "${var.role_name}-cloudwatch-logs"
  policy = data.aws_iam_policy_document.cloudwatch_logs.json
}

resource "aws_iam_role_policy_attachment" "cloudwatch_logs" {
  role       = aws_iam_role.lambda_role.name
  policy_arn = aws_iam_policy.cloudwatch_logs.arn
}

# S3 - scoped to specific buckets via variable, not s3:*
data "aws_iam_policy_document" "s3_access" {
  statement {
    sid    = "S3BucketAccess"
    effect = "Allow"
    actions = [
      "s3:GetObject",
      "s3:PutObject",
      "s3:DeleteObject",
      "s3:ListBucket",
      "s3:GetBucketLocation",
      "s3:ListBucketMultipartUploads",
      "s3:ListMultipartUploadParts",
      "s3:AbortMultipartUpload"
    ]
    resources = flatten([
      [for bucket in var.s3_bucket_arns : bucket],
      [for bucket in var.s3_bucket_arns : "${bucket}/*"]
    ])
  }
}

resource "aws_iam_policy" "s3_access" {
  name   = "${var.role_name}-s3-access"
  policy = data.aws_iam_policy_document.s3_access.json
}

resource "aws_iam_role_policy_attachment" "s3_access" {
  role       = aws_iam_role.lambda_role.name
  policy_arn = aws_iam_policy.s3_access.arn
}

# DynamoDB - scoped to specific tables via variable, not dynamodb:*
data "aws_iam_policy_document" "dynamodb_access" {
  statement {
    sid    = "DynamoDBTableAccess"
    effect = "Allow"
    actions = [
      "dynamodb:GetItem",
      "dynamodb:PutItem",
      "dynamodb:UpdateItem",
      "dynamodb:DeleteItem",
      "dynamodb:Query",
      "dynamodb:Scan",
      "dynamodb:BatchGetItem",
      "dynamodb:BatchWriteItem",
      "dynamodb:DescribeTable",
      "dynamodb:ConditionCheckItem"
    ]
    resources = flatten([
      [for table in var.dynamodb_table_arns : table],
      [for table in var.dynamodb_table_arns : "${table}/index/*"]
    ])
  }
}

resource "aws_iam_policy" "dynamodb_access" {
  name   = "${var.role_name}-dynamodb-access"
  policy = data.aws_iam_policy_document.dynamodb_access.json
}

resource "aws_iam_role_policy_attachment" "dynamodb_access" {
  role       = aws_iam_role.lambda_role.name
  policy_arn = aws_iam_policy.dynamodb_access.arn
}

# Optional: VPC access for Lambda if needed
resource "aws_iam_role_policy_attachment" "vpc_access" {
  count      = var.enable_vpc_access ? 1 : 0
  role       = aws_iam_role.lambda_role.name
  policy_arn = "arn:aws:iam::aws:policy/service-role/AWSLambdaVPCAccessExecutionRole"
}

# variables.tf
variable "role_name" {
  description = "Name of the IAM role for Lambda functions"
  type        = string
  default     = "lambda-execution-role"
}

variable "s3_bucket_arns" {
  description = "List of S3 bucket ARNs the Lambda functions need access to. Scope to specific buckets rather than using wildcard."
  type        = list(string)

  validation {
    condition     = length(var.s3_bucket_arns) > 0
    error_message = "At least one S3 bucket ARN must be provided. Avoid using '*' — specify bucket ARNs for least-privilege access."
  }
}

variable "dynamodb_table_arns" {
  description = "List of DynamoDB table ARNs the Lambda functions need access to. Scope to specific tables rather than using wildcard."
  type        = list(string)

  validation {
    condition     = length(var.dynamodb_table_arns) > 0
    error_message = "At least one DynamoDB table ARN must be provided. Avoid using '*' — specify table ARNs for least-privilege access."
  }
}

variable "enable_vpc_access" {
  description = "Whether to attach VPC access execution role policy"
  type        = bool
  default     = false
}

variable "tags" {
  description = "Tags to apply to the IAM role"
  type        = map(string)
  default     = {}
}

# outputs.tf
output "role_arn" {
  description = "ARN of the Lambda execution IAM role"
  value       = aws_iam_role.lambda_role.arn
}

output "role_name" {
  description = "Name of the Lambda execution IAM role"
  value       = aws_iam_role.lambda_role.name
}

output "role_id" {
  description = "ID of the Lambda execution IAM role"
  value       = aws_iam_role.lambda_role.id
}

# NOTE: This module intentionally follows the principle of least privilege.
# Rather than granting broad "s3:*" or "dynamodb:*" permissions, it requires
# you to specify the exact bucket and table ARNs. This is a security best
# practice even during rapid development — overly broad permissions create
# risk and are harder to tighten later. When you add new buckets or tables,
# simply add their ARNs to the input variables.