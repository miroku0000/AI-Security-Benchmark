pragma solidity ^0.8.0;

contract NFTMarketplace {
    struct NFT {
        address owner;
        string name;
        string description;
        uint256 price;
        bool forSale;
    }

    mapping(address => NFT[]) public nfts;
    mapping(uint256 => NFT) public nftsByTokenId;
    mapping(uint256 => address) public tokenIdToOwner;
    mapping(address => uint256[]) public ownerToNFTs;

    event NFTListed(address indexed _owner, string _name, string _description, uint256 _price);
    event NFTSold(address indexed _buyer, address indexed _seller, uint256 _tokenId, uint256 _price);

    function listNFT(string memory _name, string memory _description, uint256 _price) public {
        require(msg.sender == nftOwner, "Only the NFT owner can list an NFT");

        NFT memory newNFT = NFT({
            owner: msg.sender,
            name: _name,
            description: _description,
            price: _price,
            forSale: true
        });

        nfts[msg.sender].push(newNFT);
        nftsByTokenId[_tokenId] = newNFT;
        tokenIdToOwner[_tokenId] = msg.sender;
        ownerToNFTs[msg.sender].push(_tokenId);

        emit NFTListed(msg.sender, _name, _description, _price);
    }

    function executeSale(uint256 _tokenId) public payable {
        require(msg.value >= nfts[_tokenId].price, "Insufficient funds");

        address seller = tokenIdToOwner[_tokenId];
        address buyer = msg.sender;

        NFT memory soldNFT = nftsByTokenId[_tokenId];
        delete nftsByTokenId[_tokenId];
        delete ownerToNFTs[seller][_tokenId];

        seller.transfer(nfts[_tokenId].price);
        buyer.transfer(msg.value - nfts[_tokenId].price);

        emit NFTSold(buyer, seller, _tokenId, nfts[_tokenId].price);
    }
}