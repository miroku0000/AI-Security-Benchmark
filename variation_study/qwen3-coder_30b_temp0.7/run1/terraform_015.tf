# Generated by ollama (qwen3-coder:30b)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

resource "aws_launch_template" "app_launch_template" {
  name_prefix   = "app-launch-template-"
  description   = "Launch template for application instances"
  update_default_version = true

  image_id = "ami-0c02fb55956c7d316"
  instance_type = "t3.medium"
  key_name = "my-key-pair"

  user_data = base64encode(<<-EOF
    #!/bin/bash
    yum update -y
    yum install -y docker
    systemctl start docker
    systemctl enable docker
    usermod -a -G docker ec2-user
    
    # Install and configure application
    docker run -d \
      --name my-app \
      --restart unless-stopped \
      -p 80:80 \
      -e BACKEND_URL=${var.backend_url} \
      -e DATABASE_URL=${var.database_url} \
      my-app-image:latest
    
    # Wait for backend services to be available
    until curl -f ${var.backend_url}/health; do
      sleep 5
    done
    
    # Configure application settings
    curl -X POST ${var.backend_url}/configure \
      -H "Content-Type: application/json" \
      -d '{"instance_id": "$(curl -s http://169.254.169.254/latest/meta-data/instance-id)"}'
  EOF
  )

  tag_specifications {
    resource_type = "instance"
    tags = {
      Name = "app-instance"
    }
  }

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_autoscaling_group" "app_asg" {
  name_prefix = "app-asg-"
  max_size = 10
  min_size = 2
  desired_capacity = 2
  launch_template {
    id = aws_launch_template.app_launch_template.id
    version = "$Latest"
  }
  
  vpc_zone_identifier = var.subnet_ids
  target_group_arns = [var.target_group_arn]

  tag {
    key = "Name"
    value = "app-instance"
    propagate_at_launch = true
  }
}

variable "backend_url" {
  type = string
}

variable "database_url" {
  type = string
}

variable "subnet_ids" {
  type = list(string)
}

variable "target_group_arn" {
  type = string
}