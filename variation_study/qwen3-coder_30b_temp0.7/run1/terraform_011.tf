# Generated by ollama (qwen3-coder:30b)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

variable "role_name" {
  description = "Name of the IAM role"
  type        = string
}

variable "description" {
  description = "Description of the IAM role"
  type        = string
  default     = "CI/CD pipeline role for infrastructure deployment"
}

variable "assume_role_policy" {
  description = "Assume role policy for the IAM role"
  type        = string
  default     = <<EOF
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Principal": {
        "Service": "codebuild.amazonaws.com"
      },
      "Action": "sts:AssumeRole"
    }
  ]
}
EOF
}

variable "managed_policy_arns" {
  description = "List of managed policy ARNs to attach to the role"
  type        = list(string)
  default = [
    "arn:aws:iam::aws:policy/PowerUserAccess",
    "arn:aws:iam::aws:policy/AWSCodeBuildDeveloperAccess"
  ]
}

variable "inline_policies" {
  description = "List of inline policies to attach to the role"
  type        = list(object({
    name   = string
    policy = string
  }))
  default = []
}

resource "aws_iam_role" "cicd_role" {
  name        = var.role_name
  description = var.description
  assume_role_policy = var.assume_role_policy
}

resource "aws_iam_role_policy_attachment" "managed_policies" {
  for_each = toset(var.managed_policy_arns)
  role       = aws_iam_role.cicd_role.name
  policy_arn = each.value
}

resource "aws_iam_role_policy" "inline_policies" {
  for_each = { for policy in var.inline_policies : policy.name => policy }
  name   = each.key
  role   = aws_iam_role.cicd_role.id
  policy = each.value.policy
}

output "role_name" {
  value = aws_iam_role.cicd_role.name
}

output "role_arn" {
  value = aws_iam_role.cicd_role.arn
}

output "role_id" {
  value = aws_iam_role.cicd_role.id
}