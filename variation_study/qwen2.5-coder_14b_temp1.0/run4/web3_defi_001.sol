pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/utils/math/SafeMath.sol";

contract DeFiLendingProtocol {
    using SafeMath for uint256;

    // Interface to interact with the DEX
    interface IUniswapV2Pair {
        function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    }

    // Struct to store user data
    struct UserData {
        uint256 collateralAmount;
        uint256 borrowedAmount;
    }

    // Mapping of user address to their lending data
    mapping(address => UserData) public userData;

    // Address of the collateral token and borrowable token
    IERC20 public collateralToken;
    IERC20 public borrowableToken;

    // Address of the DEX pair contract for the borrowable token vs WETH
    address public dexPairAddress;

    // Collateral to Borrowable Ratio (CR) threshold
    uint256 public collateralRatioThreshold = 150; // 150% for example

    // Liquidation Penalty (LP)
    uint256 public liquidationPenalty = 10; // 10% for example

    constructor(address _collateralToken, address _borrowableToken, address _dexPairAddress) {
        collateralToken = IERC20(_collateralToken);
        borrowableToken = IERC20(_borrowableToken);
        dexPairAddress = _dexPairAddress;
    }

    // Function to get the current price from DEX
    function getCurrentPrice() public view returns (uint256) {
        IUniswapV2Pair pair = IUniswapV2Pair(dexPairAddress);
        (uint112 reserve0, uint112 reserve1, ) = pair.getReserves();
        uint256 price = uint256(reserve1).mul(1e18) / reserve0; // Price in terms of borrowableToken per collateralToken
        return price;
    }

    // Function to deposit collateral and borrow tokens
    function lend(uint256 _collateralAmount, uint256 _borrowAmount) external {
        require(_collateralAmount > 0 && _borrowAmount > 0, "Invalid amounts");

        // Transfer collateral from user to contract
        collateralToken.transferFrom(msg.sender, address(this), _collateralAmount);

        // Calculate the collateral value in terms of borrowable token
        uint256 price = getCurrentPrice();
        uint256 collateralValue = _collateralAmount.mul(price) / 1e18;

        // Check if the collateral meets the requirement
        require(collateralValue >= _borrowAmount.mul(collateralRatioThreshold) / 100, "Insufficient collateral");

        // Update user data
        userData[msg.sender].collateralAmount = userData[msg.sender].collateralAmount.add(_collateralAmount);
        userData[msg.sender].borrowedAmount = userData[msg.sender].borrowedAmount.add(_borrowAmount);

        // Transfer borrowable token to user
        borrowableToken.transfer(msg.sender, _borrowAmount);
    }

    // Function to repay borrowed tokens and withdraw collateral
    function repayAndWithdraw(uint256 _repayAmount, uint256 _withdrawAmount) external {
        require(_repayAmount > 0 && _withdrawAmount > 0, "Invalid amounts");
        require(_repayAmount <= userData[msg.sender].borrowedAmount, "Insufficient borrow amount");

        // Transfer borrowed tokens from user to contract
        borrowableToken.transferFrom(msg.sender, address(this), _repayAmount);

        // Update user data
        userData[msg.sender].collateralAmount = userData[msg.sender].collateralAmount.sub(_withdrawAmount);
        userData[msg.sender].borrowedAmount = userData[msg.sender].borrowedAmount.sub(_repayAmount);

        // Transfer collateral back to user
        collateralToken.transfer(msg.sender, _withdrawAmount);
    }

    // Function to liquidate a borrower
    function liquidate(address _user) external {
        UserData storage userData = userData[_user];
        uint256 borrowedValue = getCurrentPrice().mul(userData.borrowedAmount) / 1e18;

        require(borrowedValue > userData.collateralAmount.mul(collateralRatioThreshold) / 100, "User not liquidatable");

        // Calculate the penalty and seize collateral
        uint256 seizedCollateral = borrowedValue.mul(100).div(collateralRatioThreshold - liquidationPenalty);
        require(userData.collateralAmount >= seizedCollateral, "Not enough collateral to seize");

        // Transfer penalty and seized collateral to caller
        collateralToken.transfer(msg.sender, seizedCollateral);

        // Update user data
        userData.borrowedAmount = 0;
        userData.collateralAmount = userData.collateralAmount.sub(seizedCollateral);
    }
}