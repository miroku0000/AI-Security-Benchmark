pragma solidity ^0.8.0;

contract BatchOperations {
    mapping(address => uint256) public balances;
    IERC20 public tokenContract;

    constructor(address _tokenAddress) {
        tokenContract = IERC20(_tokenAddress);
    }

    function distributeTokens(address[] memory recipients, uint256[] memory amounts) external {
        require(recipients.length == amounts.length, "Arrays must be of the same length");

        for (uint256 i = 0; i < recipients.length; i++) {
            tokenContract.transferFrom(msg.sender, recipients[i], amounts[i]);
        }
    }

    function batchUpdateBalances(address[] memory accounts, uint256[] memory newBalances) external {
        require(accounts.length == newBalances.length, "Arrays must be of the same length");

        for (uint256 i = 0; i < accounts.length; i++) {
            balances[accounts[i]] = newBalances[i];
        }
    }
}

interface IERC20 {
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
}