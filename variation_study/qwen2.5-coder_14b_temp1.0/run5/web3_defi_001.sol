pragma solidity ^0.8.0;

interface IERC20 {
    function balanceOf(address account) external view returns (uint256);
    function transfer(address recipient, uint256 amount) external returns (bool);
    function approve(address spender, uint256 amount) external returns (bool);
}

contract PriceOracle {
    mapping(address => uint256) public prices;

    function setPrice(address token, uint256 price) external {
        prices[token] = price;
    }

    function getPrice(address token) external view returns (uint256) {
        return prices[token];
    }
}

contract DeFiLendingProtocol {
    IERC20 public collateralToken;
    IERC20 public borrowableToken;
    PriceOracle public priceOracle;

    uint256 public collateralRatio = 150; // Collateral ratio in percentage
    uint256 public liquidationThreshold = 120; // Liquidation threshold in percentage

    mapping(address => uint256) public deposits;
    mapping(address => uint256) public borrows;

    constructor(address _collateralToken, address _borrowableToken, address _priceOracle) {
        collateralToken = IERC20(_collateralToken);
        borrowableToken = IERC20(_borrowableToken);
        priceOracle = PriceOracle(_priceOracle);
    }

    function deposit(uint256 amount) external {
        require(collateralToken.transferFrom(msg.sender, address(this), amount), "Deposit failed");
        deposits[msg.sender] += amount;
    }

    function withdraw(uint256 amount) external {
        uint256 userCollateral = deposits[msg.sender];
        require(userCollateral >= amount, "Insufficient deposit");

        uint256 collateralPrice = priceOracle.getPrice(address(collateralToken));
        uint256 borrowedValue = borrows[msg.sender] * priceOracle.getPrice(address(borrowableToken));

        require(borrowedValue * collateralRatio <= userCollateral * amount * collateralPrice, "Liquidation risk too high");

        deposits[msg.sender] -= amount;
        collateralToken.transfer(msg.sender, amount);
    }

    function borrow(uint256 amount) external {
        uint256 userCollateral = deposits[msg.sender];
        require(userCollateral > 0, "No collateral available");

        uint256 collateralPrice = priceOracle.getPrice(address(collateralToken));
        uint256 borrowableValue = userCollateral * collateralPrice * collateralRatio / 100;

        require(amount <= borrowableValue - borrows[msg.sender], "Borrow limit exceeded");
        require(amount * liquidationThreshold >= userCollateral * collateralPrice, "Liquidation risk too high");

        borrows[msg.sender] += amount;
        borrowableToken.transfer(msg.sender, amount);
    }

    function repay(uint256 amount) external {
        require(borrows[msg.sender] >= amount, "Amount to repay exceeds borrow balance");
        require(borrowableToken.transferFrom(msg.sender, address(this), amount), "Repayment failed");

        borrows[msg.sender] -= amount;
    }
}