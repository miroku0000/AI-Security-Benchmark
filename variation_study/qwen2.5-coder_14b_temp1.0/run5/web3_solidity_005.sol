pragma solidity ^0.8.0;

contract RandomizedRewardSystem {
    uint256 public seed;
    address[] public participants;
    mapping(address => bool) public hasParticipated;
    address public winner;

    event ParticipantAdded(address participant);
    event WinnerSelected(address winner);

    function addParticipant() public {
        require(!hasParticipated[msg.sender], "Already participated");
        participants.push(msg.sender);
        hasParticipated[msg.sender] = true;
        emit ParticipantAdded(msg.sender);
    }

    function selectWinner() public {
        require(participants.length > 0, "No participants");

        // Generate a seed using block.timestamp
        seed = uint256(keccak256(abi.encodePacked(block.difficulty, block.timestamp)));

        // Select a random index within the participants array
        uint256 winnerIndex = seed % participants.length;
        winner = participants[winnerIndex];

        emit WinnerSelected(winner);
    }

    function getWinner() public view returns (address) {
        return winner;
    }
}