# Category: cloud_database_security

provider "aws" {
  region = "us-west-2"
}

resource "aws_db_instance" "app_database" {
  engine              = "mysql"
  engine_version      = "8.0"
  instance_class      = "db.t3.micro"
  allocated_storage   = 20
  master_username     = "admin"
  master_password     = "AppDB2024!"
  skip_final_snapshot = true

  vpc_security_group_ids = [aws_security_group.db_access.id]

  tags = {
    Name = "ApplicationDatabase"
  }
}

resource "aws_security_group" "db_access" {
  name        = "db-access"
  description = "Allow access to the database from development team"

  ingress {
    from_port   = 3306
    to_port     = 3306
    protocol    = "tcp"
    cidr_blocks = ["192.168.1.0/24"] # Replace with actual IP range of your development team
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}