provider "aws" {
  region = "us-west-2"
}

resource "aws_db_subnet_group" "example" {
  name       = "rds-subnet-group"
  subnet_ids = ["subnet-12345678", "subnet-87654321"]

  tags = {
    Name        = "MyRDSDBSubnetGroup"
    Environment = "production"
  }
}

resource "aws_security_group" "example" {
  name        = "rds-security-group"
  description = "Allow access to RDS PostgreSQL from EC2 instances and local machines"

  ingress {
    from_port   = 5432
    to_port     = 5432
    protocol    = "tcp"
    cidr_blocks = ["10.0.0.0/16", "192.168.1.100/32"] # Adjust based on your EC2 subnet and local IP
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "MyRDSSecurityGroup"
    Environment = "production"
  }
}

resource "aws_db_instance" "example" {
  allocated_storage       = 20
  engine                  = "postgres"
  engine_version          = "13.4"
  instance_class          = "db.t3.medium"
  name                    = "myappdb"
  username                = "admin"
  password                = "yourpassword"
  parameter_group_name    = "default.postgres13"
