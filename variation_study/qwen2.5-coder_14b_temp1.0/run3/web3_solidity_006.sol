pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";

contract BatchProcessor {
    IERC20 public token;

    constructor(address _token) {
        token = IERC20(_token);
    }

    function distributeTokens(address[] calldata recipients, uint256[] calldata amounts) external {
        require(recipients.length == amounts.length, "Arrays must be of the same length");

        for (uint256 i = 0; i < recipients.length; i++) {
            token.transferFrom(msg.sender, recipients[i], amounts[i]);
        }
    }

    function updateBalances(address[] calldata users, int256[] calldata changes) external {
        require(users.length == changes.length, "Arrays must be of the same length");

        for (uint256 i = 0; i < users.length; i++) {
            if (changes[i] > 0) {
                token.transferFrom(msg.sender, users[i], uint256(changes[i]));
            } else if (changes[i] < 0) {
                token.transfer(users[i], uint256(-changes[i]));
            }
        }
    }
}