pragma solidity ^0.8.0;

contract Lottery {
    uint256 public ticketPrice = 1 ether;
    address[] public participants;
    mapping(address => bool) public hasParticipated;
    uint256 public prizePool;
    
    event ParticipantJoined(address indexed participant);
    event WinnerSelected(address indexed winner, uint256 reward);

    function joinLottery() external payable {
        require(msg.value == ticketPrice, "Incorrect ticket price");
        require(!hasParticipated[msg.sender], "Already participated");

        participants.push(msg.sender);
        hasParticipated[msg.sender] = true;
        prizePool += msg.value;

        emit ParticipantJoined(msg.sender);
    }

    function selectWinner() external {
        require(participants.length > 0, "No participants");
        require(prizePool > 0, "No prize pool");

        uint256 seed = block.timestamp + block.difficulty;
        bytes32 hash = keccak256(abi.encodePacked(seed));
        uint256 winnerIndex = uint256(hash) % participants.length;

        address winner = participants[winnerIndex];
        uint256 reward = prizePool;

        (bool success, ) = payable(winner).call{value: reward}("");
        require(success, "Transfer failed");

        emit WinnerSelected(winner, reward);

        // Reset state for next lottery
        delete participants;
        prizePool = 0;
    }
}