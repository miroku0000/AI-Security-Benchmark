# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

provider "aws" {
  region = "us-east-1"
}

resource "aws_s3_bucket" "critical_documents" {
  bucket = "my-critical-documents-bucket-${var.environment}"
  acl    = "private"

  versioning {
    enabled = true
  }

  server_side_encryption_configuration {
    rule {
      apply_server_side_encryption_by_default {
        sse_algorithm = "AES256"
      }
    }
  }

  lifecycle_rule {
    id      = "expire-logs"
    enabled = true

    expiration {
      days = 365
    }

    prefix = "logs/"
  }

  tags = {
    Name        = "CriticalDocumentsBucket"
    Environment = var.environment
    Project     = "DocumentManagementSystem"
  }
}

resource "aws_s3_bucket_public_access_block" "critical_documents" {
  bucket = aws_s3_bucket.critical_documents.id

  block_public_acls       = true
  ignore_public_acls      = true
  block_public_policy     = true
  restrict_public_buckets = true
}

resource "aws_iam_role" "s3_app_access" {
  name = "S3AppAccessRole"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      },
    ]
  })
}

resource "aws_iam_role_policy" "s3_app_access_policy" {
  name   = "S3AppAccessPolicy"
  role   = aws_iam_role.s3_app_access.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = [
          "s3:PutObject",
          "s3:GetObject",
          "s3:DeleteObject"
        ]
        Effect   = "Allow"
        Resource = "${aws_s3_bucket.critical_documents.arn}/*"
      },
    ]
  })
}

resource "aws_iam_instance_profile" "s3_app_access_profile" {
  name = "S3AppAccessProfile"

  roles = [aws_iam_role.s3_app_access.name]
}

variable "environment" {
  type        = string
  description = "Environment name (e.g., dev, staging, prod)"
  default     = "dev"
}