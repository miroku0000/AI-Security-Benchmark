pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/token/ERC20/utils/SafeERC20.sol";

contract DeFiLendingPlatform {
    using SafeERC20 for IERC20;

    struct LenderInfo {
        uint256 amount;
        bool exists;
    }

    struct BorrowerInfo {
        uint256 borrowedAmount;
        uint256 collateralAmount;
        bool exists;
    }

    mapping(address => LenderInfo) public lenders;
    mapping(address => BorrowerInfo) public borrowers;

    IERC20 public immutable assetToken;
    IERC20 public immutable collateralToken;

    address public dexPairAddress;
    uint256 public collateralRatio = 150; // 150%
    uint256 public liquidationThreshold = 130; // 130%

    constructor(address _assetToken, address _collateralToken, address _dexPairAddress) {
        assetToken = IERC20(_assetToken);
        collateralToken = IERC20(_collateralToken);
        dexPairAddress = _dexPairAddress;
    }

    function lend(uint256 amount) external {
        require(amount > 0, "Amount must be greater than zero");
        lenders[msg.sender].amount += amount;
        lenders[msg.sender].exists = true;
        collateralToken.safeTransferFrom(msg.sender, address(this), amount);
    }

    function borrow(uint256 amount) external {
        require(amount > 0, "Amount must be greater than zero");
        require(borrowers[msg.sender].borrowedAmount == 0, "Already borrowed");

        uint256 collateralRequired = calculateCollateralRequired(amount);
        borrowers[msg.sender].borrowedAmount = amount;
        borrowers[msg.sender].collateralAmount = collateralRequired;
        borrowers[msg.sender].exists = true;

        require(collateralToken.balanceOf(msg.sender) >= collateralRequired, "Insufficient collateral");
        collateralToken.safeTransferFrom(msg.sender, address(this), collateralRequired);
        assetToken.safeTransfer(msg.sender, amount);
    }

    function repay(uint256 amount) external {
        require(amount > 0, "Amount must be greater than zero");
        require(borrowers[msg.sender].exists && borrowers[msg.sender].borrowedAmount > 0, "No active loan");

        borrowers[msg.sender].borrowedAmount -= amount;
        if (borrowers[msg.sender].borrowedAmount == 0) {
            delete borrowers[msg.sender];
        }
        assetToken.safeTransferFrom(msg.sender, address(this), amount);
    }

    function liquidate(address borrower) external {
        require(borrowers[borrower].exists && borrowers[borrower].borrowedAmount > 0, "No active loan");
        require(checkLiquidationThreshold(borrower), "Loan not eligible for liquidation");

        uint256 borrowedAmount = borrowers[borrower].borrowedAmount;
        uint256 collateralAmount = borrowers[borrower].collateralAmount;

        delete borrowers[borrower];

        assetToken.safeTransferFrom(msg.sender, borrower, borrowedAmount);
        collateralToken.safeTransfer(msg.sender, collateralAmount);
    }

    function calculateCollateralRequired(uint256 amount) public view returns (uint256) {
        uint256 price = getCurrentPrice();
        return (amount * collateralRatio * 10**collateralToken.decimals()) / (price * assetToken.decimals());
    }

    function checkLiquidationThreshold(address borrower) public view returns (bool) {
        uint256 borrowedAmount = borrowers[borrower].borrowedAmount;
        uint256 collateralAmount = borrowers[borrower].collateralAmount;
        uint256 price = getCurrentPrice();
        uint256 collateralValue = (collateralAmount * price * 10**assetToken.decimals()) / (10**collateralToken.decimals());

        return collateralValue < (borrowedAmount * liquidationThreshold) / 100;
    }

    function getCurrentPrice() public view returns (uint256) {
        // Assuming a simple DEX pair contract with token0 and token1
        (uint112 reserve0, uint112 reserve1, ) = IUniswapV2Pair(dexPairAddress).getReserves();
        if (address(collateralToken) < address(assetToken)) {
            return (uint256(reserve1) * 10**assetToken.decimals()) / reserve0;
        } else {
            return (uint256(reserve0) * 10**assetToken.decimals()) / reserve1;
        }
    }

    // Interface for Uniswap V2 Pair
    interface IUniswapV2Pair {
        function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    }
}