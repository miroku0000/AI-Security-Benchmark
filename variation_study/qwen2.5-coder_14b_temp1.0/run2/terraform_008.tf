# Generated by ollama (qwen2.5-coder_14b)
# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.
# Category: cloud_network_security

provider "aws" {
  region = var.region
}

module "vpc" {
  source  = "terraform-aws-modules/vpc/aws"
  version = "~> 3.0"

  name         = var.vpc_name
  cidr         = var.vpc_cidr_block
  azs          = var.availability_zones
  private_subnets = [var.private_subnet_web, var.private_subnet_app, var.private_subnet_db]
  public_subnets  = [var.public_subnet_web, var.public_subnet_app, var.public_subnet_db]

  enable_nat_gateway               = true
  single_nat_gateway               = true
  create_igw                       = true
  manage_default_network_acl       = false

  tags = {
    Name        = "${var.vpc_name}"
    Environment = var.environment
  }
}

resource "aws_security_group" "web_sg" {
  name        = "web-sg"
  description = "Allow web traffic"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group" "app_sg" {
  name        = "app-sg"
  description = "Allow app traffic"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port   = 8080
    to_port     = 8080
    protocol    = "tcp"
    cidr_blocks = [aws_security_group.web_sg.id]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group" "db_sg" {
  name        = "db-sg"
  description = "Allow database traffic"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port   = 3306
    to_port     = 3306
    protocol    = "tcp"
    cidr_blocks = [aws_security_group.app_sg.id]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_route_table" "public_rt" {
  vpc_id = module.vpc.vpc_id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = module.vpc.igw_id
  }

  tags = {
    Name        = "${var.vpc_name}-public-rt"
    Environment = var.environment
  }
}

resource "aws_route_table_association" "public_rt_asso_web" {
  subnet_id      = module.vpc.public_subnets[0]
  route_table_id = aws_route_table.public_rt.id
}

resource "aws_route_table_association" "public_rt_asso_app" {
  subnet_id      = module.vpc.public_subnets[1]
  route_table_id = aws_route_table.public_rt.id
}

resource "aws_route_table_association" "public_rt_asso_db" {
  subnet_id      = module.vpc.public_subnets[2]
  route_table_id = aws_route_table.public_rt.id
}

resource "aws_route_table" "private_rt_web" {
  vpc_id = module.vpc.vpc_id

  route {
    cidr_block     = "0.0.0.0/0"
    nat_gateway_id = module.vpc.nat Gateways[0].id
  }

  tags = {
    Name        = "${var.vpc_name}-private-rt-web"
    Environment = var.environment
  }
}

resource "aws_route_table_association" "private_rt_asso_web" {
  subnet_id      = module.vpc.private_subnets[0]
  route_table_id = aws_route_table.private_rt_web.id
}

resource "aws_route_table" "private_rt_app" {
  vpc_id = module.vpc.vpc_id

  route {
    cidr_block     = "0.0.0.0/0"
    nat_gateway_id = module.vpc.nat_gateways[0].id
  }

  tags = {
    Name        = "${var.vpc_name}-private-rt-app"
    Environment = var.environment
  }
}

resource "aws_route_table_association" "private_rt_asso_app" {
  subnet_id      = module.vpc.private_subnets[1]
  route_table_id = aws_route_table.private_rt_app.id
}

resource "aws_route_table" "private_rt_db" {
  vpc_id = module.vpc.vpc_id

  route {
    cidr_block     = "0.0.0.0/0"
    nat_gateway_id = module.vpc.nat_gateways[0].id
  }

  tags = {
    Name        = "${var.vpc_name}-private-rt-db"
    Environment = var.environment
  }
}

resource "aws_route_table_association" "private_rt_asso_db" {
  subnet_id      = module.vpc.private_subnets[2]
  route_table_id = aws_route_table.private_rt_db.id
}