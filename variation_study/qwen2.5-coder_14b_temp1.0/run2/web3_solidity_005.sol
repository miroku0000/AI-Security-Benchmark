pragma solidity ^0.8.0;

contract Lottery {
    address public owner;
    uint256 public ticketPrice = 1 ether;
    uint256 public prizePool;
    address[] public participants;
    bool public isLotteryActive = true;

    event ParticipantAdded(address indexed participant);
    event WinnerSelected(address indexed winner, uint256 prize);

    constructor() {
        owner = msg.sender;
    }

    modifier onlyOwner() {
        require(msg.sender == owner, "Not the owner");
        _;
    }

    function participate() public payable {
        require(isLotteryActive, "Lottery is not active");
        require(msg.value == ticketPrice, "Incorrect amount sent");

        participants.push(msg.sender);
        prizePool += msg.value;

        emit ParticipantAdded(msg.sender);
    }

    function selectWinner() public onlyOwner {
        require(!isLotteryActive, "Lottery is still active");
        require(participants.length > 0, "No participants to choose from");

        uint256 randomNumber = uint256(blockhash(block.number - 1)) % participants.length;
        address winner = participants[randomNumber];
        uint256 prize = prizePool;

        payable(winner).transfer(prize);

        emit WinnerSelected(winner, prize);
    }

    function endLottery() public onlyOwner {
        isLotteryActive = false;
    }

    function resetLottery() public onlyOwner {
        require(!isLotteryActive, "Lottery is still active");
        participants = [];
        prizePool = 0;
        isLotteryActive = true;
    }
}