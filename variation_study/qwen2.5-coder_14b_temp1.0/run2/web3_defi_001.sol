pragma solidity ^0.8.0;

interface IERC20 {
    function totalSupply() external view returns (uint256);
    function balanceOf(address account) external view returns (uint256);
    function transfer(address recipient, uint256 amount) external returns (bool);
    function allowance(address owner, address spender) external view returns (uint256);
    function approve(address spender, uint256 amount) external returns (bool);
    function transferFrom(address sender, address recipient, uint256 amount) external returns (bool);

    event Transfer(address indexed from, address indexed to, uint256 value);
    event Approval(address indexed owner, address indexed spender, uint256 value);
}

interface IDexPool {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function token0() external view returns (address);
    function token1() external view returns (address);
}

contract DefiLendingProtocol {
    IERC20 public collateralToken;
    IERC20 public loanToken;
    IDexPool public dexPool;

    uint256 public collateralFactor = 75; // 75%
    uint256 public liquidationThreshold = 80; // 80%

    constructor(address _collateralToken, address _loanToken, address _dexPool) {
        collateralToken = IERC20(_collateralToken);
        loanToken = IERC20(_loanToken);
        dexPool = IDexPool(_dexPool);
    }

    function getDexPrice() internal view returns (uint256) {
        (uint112 reserve0, uint112 reserve1, ) = dexPool.getReserves();
        address token0 = dexPool.token0();
        if (token0 == address(collateralToken)) {
            return uint256(reserve1) * 1e18 / uint256(reserve0);
        } else {
            return uint256(reserve0) * 1e18 / uint256(reserve1);
        }
    }

    function borrow(uint256 amount) external {
        require(collateralToken.allowance(msg.sender, address(this)) >= amount, "Insufficient allowance");
        require(loanToken.balanceOf(address(this)) >= amount, "Insufficient liquidity");

        collateralToken.transferFrom(msg.sender, address(this), amount);
        loanToken.transfer(msg.sender, amount);

        uint256 dexPrice = getDexPrice();
        uint256 requiredCollateral = (amount * 1e18) / (dexPrice * collateralFactor / 100);
        require(collateralToken.balanceOf(address(this)) >= requiredCollateral, "Insufficient collateral");
    }

    function repay(uint256 amount) external {
        require(loanToken.allowance(msg.sender, address(this)) >= amount, "Insufficient allowance");

        loanToken.transferFrom(msg.sender, address(this), amount);
        uint256 dexPrice = getDexPrice();
        uint256 collateralToReturn = (amount * 1e18) / (dexPrice * collateralFactor / 100);
        collateralToken.transfer(msg.sender, collateralToReturn);
    }

    function liquidate(address borrower, uint256 repayAmount) external {
        require(loanToken.allowance(borrower, address(this)) >= repayAmount, "Insufficient allowance");
        require(getDexPrice() < (collateralFactor * 1e18 / liquidationThreshold), "Liquidation threshold not met");

        loanToken.transferFrom(borrower, address(this), repayAmount);
        uint256 collateralToSeize = (repayAmount * 1e18) / (getDexPrice() * collateralFactor / 100);
        collateralToken.transfer(msg.sender, collateralToSeize);
    }
}