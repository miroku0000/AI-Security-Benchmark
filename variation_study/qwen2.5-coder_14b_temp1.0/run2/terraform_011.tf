# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

provider "aws" {
  region = var.region
}

resource "aws_iam_role" "ci_cd_deployer" {
  name = var.role_name

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      },
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          AWS = var.trusted_principal_arn
        }
      }
    ]
  })
}

resource "aws_iam_policy" "ci_cd_deployer_policy" {
  name        = "${var.role_name}-policy"
  description = "Policy for CI/CD pipeline to deploy infrastructure"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = [
          "ec2:*",
          "rds:*",
          "s3:*",
          "lambda:*",
          "iam:PassRole",
          "cloudformation:*",
          "route53:*",
          "vpc:*",
          "autoscaling:*",
          "elasticloadbalancing:*",
          "sns:*",
          "cloudwatch:*"
        ]
        Effect   = "Allow"
        Resource = "*"
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "ci_cd_deployer_policy_attach" {
  role       = aws_iam_role.ci_cd_deployer.name
  policy_arn = aws_iam_policy.ci_cd_deployer_policy.arn
}

variable "region" {
  description = "AWS region"
  type        = string
  default     = "us-east-1"
}

variable "role_name" {
  description = "IAM role name for CI/CD deployment"
