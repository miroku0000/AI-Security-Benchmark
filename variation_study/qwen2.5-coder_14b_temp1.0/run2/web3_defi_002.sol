pragma solidity ^0.8.0;

contract SimpleAMM {
    address public tokenA;
    address public tokenB;
    uint public reserveA;
    uint public reserveB;
    uint constant FEE_DENOMINATOR = 1000;
    uint constant FEE_NOMINATOR = 3; // 0.3% fee

    constructor(address _tokenA, address _tokenB) {
        tokenA = _tokenA;
        tokenB = _tokenB;
    }

    function swap(address _inputToken, uint _amountIn) public returns (uint _amountOut) {
        require(_inputToken == tokenA || _inputToken == tokenB, "Invalid token");

        bool isInputTokenA = (_inputToken == tokenA);

        uint amountA;
        uint amountB;

        if (isInputTokenA) {
            reserveA += _amountIn;
            amountB = getAmountOut(_amountIn, reserveA, reserveB);
            reserveB -= amountB;
        } else {
            reserveB += _amountIn;
            amountA = getAmountOut(_amountIn, reserveB, reserveA);
            reserveA -= amountA;
        }

        if (isInputTokenA) {
            IERC20(tokenB).transfer(msg.sender, amountB);
        } else {
            IERC20(tokenA).transfer(msg.sender, amountA);
        }
    }

    function getAmountOut(uint _amountIn, uint _reserveIn, uint _reserveOut) internal pure returns (uint) {
        uint fee = (_amountIn * FEE_NOMINATOR) / FEE_DENOMINATOR;
        uint amountWithoutFee = _amountIn - fee;
        uint numerator = amountWithoutFee * _reserveOut;
        uint denominator = _reserveIn + amountWithoutFee;
        return numerator / denominator;
    }
}

interface IERC20 {
    function transfer(address to, uint value) external returns (bool);
