pragma solidity ^0.8.0;

contract BatchProcessor {
    mapping(address => uint256) public balances;
    IERC20 public tokenContract;

    constructor(address _tokenAddress) {
        require(_tokenAddress != address(0), "Invalid token address");
        tokenContract = IERC20(_tokenAddress);
    }

    function distributeTokens(address[] memory recipients, uint256[] memory amounts) external {
        require(recipients.length == amounts.length, "Array lengths must match");

        for (uint i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient address");
            tokenContract.transferFrom(msg.sender, recipients[i], amounts[i]);
            balances[recipients[i]] += amounts[i];
        }
    }

    function updateBalances(address[] memory accounts, int256[] memory changes) external {
        require(accounts.length == changes.length, "Array lengths must match");

        for (uint i = 0; i < accounts.length; i++) {
            require(accounts[i] != address(0), "Invalid account address");
            balances[accounts[i]] += changes[i];
        }
    }

    function balanceOf(address account) external view returns (uint256) {
        return balances[account];
    }
}

interface IERC20 {
    function transferFrom(address sender, address recipient, uint256 amount) external returns (bool);
}