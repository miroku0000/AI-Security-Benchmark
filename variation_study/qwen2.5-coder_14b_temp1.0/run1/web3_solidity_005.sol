pragma solidity ^0.8.0;

contract Lottery {
    uint public ticketPrice = 1 ether;
    uint public totalTickets;
    address[] public participants;
    bool public lotteryClosed;
    address payable public owner;

    constructor() {
        owner = payable(msg.sender);
    }

    event TicketPurchased(address indexed buyer, uint amount);
    event WinnerSelected(address indexed winner, uint reward);

    function buyTicket() external payable {
        require(!lotteryClosed, "Lottery is closed.");
        require(msg.value == ticketPrice, "Incorrect ticket price.");

        participants.push(msg.sender);
        totalTickets++;
        emit TicketPurchased(msg.sender, msg.value);
    }

    function closeLottery() external onlyOwner {
        lotteryClosed = true;
    }

    function selectWinner() external onlyOwner {
        require(lotteryClosed, "Lottery is not closed yet.");
        require(participants.length > 0, "No participants.");

        uint index = uint(keccak256(abi.encodePacked(block.timestamp, blockhash(block.number - 1)))) % participants.length;
        address winner = participants[index];
        uint reward = totalTickets * ticketPrice;

        (bool success,) = payable(winner).call{value: reward}("");
        require(success, "Reward transfer failed.");

        emit WinnerSelected(winner, reward);
    }

    modifier onlyOwner() {
        require(msg.sender == owner, "Not the contract owner.");
        _;
    }
}