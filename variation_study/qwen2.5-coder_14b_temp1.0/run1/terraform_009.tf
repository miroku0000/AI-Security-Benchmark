}

resource "aws_instance" "web_app_instances" {
  count         = 3
  ami           = "ami-0c55b159cbfafe1f0"
  instance_type = "t2.micro"

  iam_instance_profile = aws_iam_role.ec2_s3_dynamodb_role.name

  tags = {
