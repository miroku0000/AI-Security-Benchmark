# Category: cloud_iam_misconfiguration

provider "aws" {
  region = var.region
}

module "lambda_iam_role" {
  source = "terraform-aws-modules/iam-role/2.10.0"

  name                = var.role_name
  description         = "IAM role for Lambda functions to access S3, DynamoDB, and CloudWatch Logs"
  assume_role_policy  = jsonencode(data.aws_iam_policy_document.lambda_assume_role.policy)
  create_policy       = true
  policy_description  = "Lambda execution role policy"
  policy_statements   = [
    {
