pragma solidity ^0.8.4;

import "@openzeppelin/contracts/token/ERC721/IERC721.sol";

interface Auction {
    struct Bid {
        uint256 value;
        address payable bidder;
    }
    
    function createAuction(uint _nftIndex, uint _startingPrice) external returns (uint);
    function placeBid(uint _auctionId) external payable;
    function endAuction(uint _auctionId) external;
    function withdraw() external;
}

contract Marketplace is Auction {
    
    IERC721 private nftContract;  // NFT contract which we interact with
    Bid[] bids;   // Array to hold all the bid details
    
    mapping(uint => uint) public auctionIdsToNFTs;
    mapping(address => uint[]) public ownedAuctions;
    
    modifier onlyOwner (uint _auctionId){
        require(bids[_auctionId].bidder == msg.sender, "Only owner can perform this action");
        _;
    }

    constructor(address _nftAddress) {
        nftContract = IERC721(_nftAddress);  // Initializing the NFT contract which we interact with
    }
    
    function createAuction(uint _nftIndex, uint _startingPrice) public override returns (uint){
        
        require(nftContract.ownerOf(_nftIndex) == msg.sender, "Only NFT owner can create an auction");  // Making sure the sender is the current owner of the NFT
        nftContract.transferFrom(msg.sender, address(this), _nftIndex);   // Transferring ownership to marketplace contract
        
        uint auctionId = bids.length;    // Assigning an ID to the new bid
        bids.push(Bid(_startingPrice, payable(msg.sender)));  // Adding a new Bid details
        
        ownedAuctions[msg.sender].push(auctionId);   // Adding auction id into the owner's auctions list
        auctionIdsToNFTs[auctionId] = _nftIndex;    // Mapping bid to NFT
        
        return auctionId;  // Returning the newly created auction Id
    }
    
    function placeBid(uint _auctionId) public override payable {
      
        require(_auctionId < bids.length, "Invalid auction id");   // Check if provided auction id is valid
        
        Bid storage bid = bids[_auctionId];  // Fetching the bid details from array using the index
        
        require(msg.value > bid.value, "New bid should be higher than the current highest bid");   // Check if new bid value is more than existing one
        
        if (bid.bidder != address(0)) {
            bid.bidder.transfer(bid.value);  // Transfer the previous bids to the bidder
        }
        
        bid.value = msg.value;   // Update the new bid value
        bid.bidder = payable(msg.sender);    // Updating the new bidder address
    }
    
    function endAuction(uint _auctionId) public override {
        
        require(_auctionId < bids.length, "Invalid auction id");   // Validate if provided auction id is valid
        
        Bid storage bid = bids[_auctionId];  // Fetching the bid details from array using index
        
        if (bid.value > 0) {
            nftContract.transferFrom(address(this), bid.bidder, auctionIdsToNFTs[_auctionId]);   // Transfer NFT to highest bidder after auction ends
        }
        
        delete bids[_auctionId];    // Delete the ended auction from array
    }
    
    function withdraw() public override {
      
        uint256 amount = address(this).balance;  // Fetching total contract balance
        
        payable(msg.sender).transfer(amount);   // Transfer all funds to the msg.sender
    }
}