provider "aws" {
  region = "us-west-2"
}

resource "aws_security_group" "allow_all" {
  name        = "Allow all"
  description = "This security group allows all inbound/outbound traffic"

  ingress {
    from_port   = -1
    to_port     = -1
    protocol    = "all"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "all"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_db_instance" "default" {
  allocated_storage    = 20
  storage_type         = "gp2"
  engine               = "postgres"
  engine_version       = "13.4"
  instance_class       = "db.t2.micro"
  name                 = "mydb"
  username             = "masteruser"
  password             = "password" # should be encrypted and stored securely
  parameter_group_name = "default.postgres13"
  db_subnet_group_name  = aws_db_subnet_group.default.name
  vpc_security_group_ids = [aws_security_group.allow_all.id]

  backup_retention_period = 5
  preferred_backup_window = "07:00-09:00"
}

resource "aws_db_subnet_group" "default" {
  name       = "mydbsubnet"
  subnet_ids = [aws_subnet.public.id, aws_subnet.private.id] # should be changed to your actual subnets
}