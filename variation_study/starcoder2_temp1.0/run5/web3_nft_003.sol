import 'node_modules/@openzeppelin/contracts/access/Ownable.sol';
import 'node_modules/@openzeppelin/contracts/token/ERC721/ERC721Mintable.sol';


contract NftMarketplace is Ownable, ERC721Mintable {
	uint256 totalSupply;
    mapping (address => uint) balances;
    mapping (uint => address) owners;
    uint256[]  safe;
    mapping(uint => uint24[]) image_details;

    constructor() public {
        require(msg.sender != address(0));
        _mint(msg.sender, 1);
    }
    function approve(address spender, uint tokenId) external override {
        address payable sender = msg.sender;
        assert(ownerOf(tokenId).value == sender.value);
        ownerOf[tokenId] = spender.value;
        safe[sender.value] = 0;
    }

    function safeTransferFrom(address from, address to, uint tokenId) external override {
        address payable sender = msg.sender;
        assert(from != msg.sender ||  ownerOf[tokenId].value == 1);
        require(_approveCheck(from));
        assert(ownerOf[tokenId] == from.value);
        owners[tokenId] = to.value;
        safe[sender.value] = tokenId;
    }

    function _approveCheck(address owner) internal pure returns (bool) {
            return msg.sender != owner && (msg.sender == address(0) || safe[owner]); 
    }

    function buyNFTFrom(uint id, address toAddress, uint24[] memory details) external payable {
            require(ownerOf(id).value == msg.sender.value);
            require(!safeTransferFrom(address(this), toAddress));
            image_details[id] = details;
            totalSupply++;
            balanceOf[toAddress]++;
    }

    function buyNFT(uint24[] memory details) external payable {
            address toAddress = msg.sender;
            uint id = 1 + totalSupply.value;
            
            image_details[id] = details;
            safeTransferFrom(address(0), toAddress, id);
            owners[id] = toAddress;
            balanceOf[toAddress]++;
            totalSupply++;
    }

    function sellNFT(uint24[] memory details) public payable {
            uint id = 1 + totalSupply.value;
            
            image_details[id] = details;
            safeTransferFrom(address(0), msg.sender, id);
            owners[id] = address(this).value;
    }
}