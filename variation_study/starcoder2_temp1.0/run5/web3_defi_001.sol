pragma solidity ^0.8.4;
import "https://github.com/paulrberg/uniswap-v3-core/blob/master/contracts/interfaces/IV2Pair.sol";
contract Dapp {
    using UniswapV2Router for *;

    IUniswapV2Pair iDAI_iETH; // Interface for pair contract, to allow the relevent calls
    address public lender;  // Address of contract that owns tokens. 
    address public borrower; // Address of contract that needs tokens
    bool public paused = false;   // Pauses and unpauses token transfers

    // For testing purpose
    uint256 public iDAI;  // Amount of iDAI borrowed
    uint256 public iETH;   // Amount of borrowed ETH


    constructor(address _lender, address _borrower) {
        lender = _lender;  // Assign addresses that want to lend and borrow
        borrower = _borrower;
    }

    function mintBorrow() public payable { // Auction token lent
        require(!paused); // Paused for testing purposes
        require(msg.value > 0, 'No tokens to borrow');

        (uint amountBorrowed,) = iDAI_iETH.getAmountsOut(address(this).balance, msg.value * 1e6); // Get the minimum value that will be sent
        require(amountBorrowed == 0, 'Lending not possible at this price');

        iDAI_iETH.mint(borrower, msg.value * 1e6); // Borrow token from lender
    }

    function repayBorrow() public {
        require(!paused); // Paused for testing purposes
        (uint amountReturned,) = iDAI_iETH.getAmountsOut(msg.sender, address(this).balance);

        (uint balanceLend,) = iDAI_iETH.getAmountsOut(address(this).balance, amountReturned * 1e6 - 0.05e27); // Return half and minus some slippage for repaying the collateral 
        require(balanceLend > 0 && balanceLend <= msg.sender.balance , 'Insufficient Collateral');

        msg.sender.transfer(balanceLend * 1e-6);
        iDAI_iETH.burn(msg.sender, amountReturned - 0.05e27);
    }

    function liquidate() public { 
        require(!paused) // Paused for testing purposes
        uint256 collateralLimit = address(this).balance / (0.95e27 + 0.1 * iDAI_iETH.reserve());
        uint256 debtLimit = collateralLimit * 3;
        require(debtLimit > msg.sender.balance, 'Insufficient Debt');

        msg.sender.transfer(collateralLimit); // Transfer some collateral
        iDAI_iETH.burn(msg.sender, debtLimit - address(this).balance / (0.95e27 + 0.1 * iDAI_iETH.reserve()));
    }

    function pause() public { 
        paused = true; 
    }

    function unpause() public {
        require(lender == msg.sender, 'Only lenders can call this') // Only lender has the power to unpause.  
        paused = false;
    }
}