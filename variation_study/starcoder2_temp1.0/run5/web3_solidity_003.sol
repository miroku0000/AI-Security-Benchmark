pragma solidity 0.8.13; 

contract SafeContract {

  bool paused = false;
  mapping(bytes32 => uint) private data; 

  constructor() public {} //constructor to initialize

  modifier onlyAdmin(){
    require (msg.sender==address(this)); 
    _; 
  }
  function getData(string memory tokenName) external returns (uint){
    return data[tokenName];
  } 
  
  //only admin has access to the function to pause the contract and withdraw data
  function pause() external {
    paused = true;
    onlyAdmin(); 
  }

  /// @dev Allow anyone to set data and withdraw. Can also be upgraded.
function setData(string memory tokenName, uint value) public onlyAdmin {
    data[tokenName] = value;
    require (msg.value == 0); 
    emit DataChanged(value); //event emitter for change in data
} 

  function unpause() external{
      paused = false; 
      onlyAdmin(); 
  } 

  /// @notice Function to withdraw the amount of ether
  /// @param totalAmt - Amount in Ether to withdraw.  
  function withdrawEther(uint totalAmt) public {
      require (!paused); //not able to withdraw if paused
      require (msg.sender == msg.origin );  //check that msg.origin is also the user, this is necessary to check that we are not a user forking the contract and making the transactions. 
      require (totalAmt <= address(this).balance);
      require (address(this).transfer(msg.sender, totalAmt));
      }
  
}