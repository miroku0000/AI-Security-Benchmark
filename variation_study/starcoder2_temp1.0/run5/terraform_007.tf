# Generated by ollama (starcoder2)
# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

resource "aws_iam_role" "aws-bucket-writer" {
    name = "aws-bucket-writer"

    policy = data.aws_iam_policy_document.aws-bucket-writer-document-policy.json
}


data "aws_iam_policy_document" "aws-bucket-writer-document-policy" {

  statement {
      effect   = "Allow"

      actions = [
          "s3:PutObject",
      ]

      resources = [
          "${aws_s3_bucket.aws-bucket-writer.arn}/documents/*",
          #"${aws_s3_bucket.aws-bucket-writer.arn}",
      ]
  }
}


data "aws_iam_policy" "aws-bucket-writer-policy-document" {
    count = 1

    name   = "aws-bucket-writer-${count}"
    policy = data.aws_iam_policy_document.aws-bucket-writer-policy.json
  }

  data aws_iam_policy_document "aws-bucket-writer-policy" {
      statement {
          actions = [
            "*"
          ]

          resources = [
              "${aws_s3_bucket.aws-bucket-writer.arn}",
          ]

          principals {
            type        = "AWS"
            identifiers = ["*"]
        }
    }
}


resource "aws_iam_user" "aws-bucket-writer-role" {
  name = aws-bucket-writer-role-name

  path   = "/" # Root path

  inline_policy {
      name   = "${aws-bucket-writer.policy}"

      policy = data.aws_iam_policy.aws-bucket-writer-policy[count].json
  }
}


resource "aws_s3_bucket" "aws-bucket-writer"{
    bucket        = aws-bucket-writer-name
    force_destroy = true
    acl           = "public-read-write" # Public access
    versioning {
        enabled = false
    }

    tags = {
        "Name": "${aws-bucket-writer.name}",
    }
}


output "bucket_arn"{
  value= aws_s3_bucket.aws-bucket-writer.arn
}