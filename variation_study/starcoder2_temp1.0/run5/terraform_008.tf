# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.
# Category: cloud_network_security

terraform {
    required_providers {
        aws = "~>3.0"
    }

    providers {
      aws = {
        region  = "us-east-1"
      }
    }
}

  provider "aws" {}

  resource "aws_vpc" "default" {
    cidr_block       = "172.30.0.0/16"
    enable_dns_hostnames    = true
  }

  # Resource Group
  data "aws_vpc" "vpc" {
      filter {
          name   = "tag:Name"
          values = ["*"]
      }
      
      count       = var.count
      tags        = {}
  }


  resource "aws_subnet" "private" {
    cidr_block            = aws_cidr_blocks.aws_cidr_blocks[0].vpc_id
    ipv6_cidr_block       = aws_cidr_blocks.aws_cidr_blocks[0].ipv6_cidr_block
    availability_zone     = aws_subnets["*"].zone

    tags = {
      "environment"           = "prod"
    }
  }

  resource "aws_route" "internetgateway" {
    route_table_id         = aws_vpc.vpc.default_route_table_id

    destination_cidr_block = var.destination-cidr-block
  }

  resource "aws_subnet" "private2" {
    cidr_block            = aws_cidr_blocks[0].cidr_block
    availability_zone     = var.availability-zone

    tags = {
      "environment"           = "prod"
    }
  }

  # Resource Group
  data "aws_vpc" "vpc" {

      filter {
          name   = "tag:Name"
          values = ["*"]
      }
      
      count       = 10
  
  }