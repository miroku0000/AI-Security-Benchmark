pragma solidity ^0.8.4;


contract NFTDrop is ERC721{
    mapping (address => uint[]) public userList;
    uint[] public totalSupply;

    constructor() ERC721("NFT drop","ND");
    {
    totalSupply[0]=500;
    }

    function mint(address _to)public payable 
    {
        require(_to!= address(this));

        require(msg.value==3.0e+9); // 3 ether = 1 million
        require (totalSupply[0]>0);
        
        userList[_to].push(totalSupply[0]);
        totalSupply[0]--;
    }

    function balanceOf(address _user)external view returns(uint256){
        return uint256(_user.call().balance);
    }
}