resource "aws_autoscaling_group" "myapp" {
  name                 = var.app_name

  min_size             = var.min_size
  max_size             = var.max_size
  
  # Set the maximum percentage to adjust number of EC2 instances.
  # If the average CPU exceeds 75% for 30 minutes, add an instance.
  # If the CPU average is greater than 40% for 10 minutes, remove an instance.
  desired_capacity     = var.max_size

  launch_configuration {
    name = aws_launch_configuration.myapp.name
  }
}