# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~>3.0"
    }
  }
  backend "s3" {
    bucket         = "terraform-s3-bucket"
    key            = "terraform-state"
    region         = "us-east-2"
    encrypt        = true

    acl    = "private"
    type   = "cloud"
  }
}


# VPC configuration
provider "aws" {
  profile = "dev"
  region  = "us-east-1" # aws_default.region.id
}
resource "aws_vpc" "vpc" {
  cidr_block = "10.1.0.0/24"

  tags = {
    Name        = "${var.env}-vpc"
  }
}

# create 2 public subnets
resource "aws_subnet" "public-subnet-one" {
  vpc_id     = aws_vpc.vpc.id
  cidr_block = "10.1.1.0/24"

  tags = {
    Name        = "${var.env}-subnet-${count.index + 1}"
  }
}

 resource "aws_internet_gateway" "igw" {
   vpc_id = aws_vpc.vpc.id

   tags = {
     Name = "${var.env}-${aws_internet_gateway.igw.id}"
   }
}

 # create one NAT gateway
resource "aws_nat_gateway" "ngw1" {
  allocation_id = data.aws_eip.nat-gateway1.id

  subnet_id     = aws_subnet.public-subnet-one.id


  tags = {
    Name = "${var.env}-natgw-${aws_nat_gateway.ngw1.id}"
  }
}

 resource "aws_vpc_endpoint" "s3-service" {
   vpc_id        = aws_vpc.vpc.id
   service_name  = "com.amazonaws.${data.aws_partition.current.dns_suffix}:s3"

   private_ip       = null 
   security_group_ids = ["${aws_security_group.vpc-endpoint-s3.id}"]

 }

  # create two VPC endpoint
  resource "aws_vpc_endpoint" "s3-service1" {
   vpc_id        = aws_vpc.vpc.id

   private_dns = null 
   security_group_ids = ["${aws_security_group.vpc-endpoint-s3.id}"]

   tags = {
     Name            = "${var.env}-vpc-endpoint-${aws_vpc_endpoint.s3-service1.id}"
   }
 }

 # Create VPC endpoint for S3 using nat gateway as public access
resource "aws_vpc_endpoint" "s3-service2" {
  vpc_id        = aws_vpc.vpc.id

  private_dns   = null 
  security_group_ids = ["${aws_security_group.vpc-endpoint-s3.id}"]

 public_ip       = true
 subnet_ids      = [
   "${aws_subnet.public-subnet-one.id}",
   "${aws_subnet.public-subnet-two.id}"
  ]

  tags = {
    Name            = "${var.env}-vpc-endpoint-${aws_vpc_endpoint.s3-service2.id}"
     }
}

 # Create security group VPC endpoint S3
resource "aws_security_group" "vpc-endpoint-s3" {

   ingress {
      protocol   = "tcp"
      description  = "ingress"
      from_port       = 443
      to_port         = 80

      source_security_group_id     = aws_nat_gateway.ngw1.id
      cidr_blocks      = [aws_vpc.vpc.cidr_block]
    }

   egress {
      protocol   = "tcp"
      description  = "egress"
      from_port       = 0 
      to_port         = 65535 

      cidr_blocks     = ["0.0.0.0/0"]
   }
  tags = {
    Name          = "${var.env}-vpc-endpoint-${aws_security_group.vpc-endpoint-s3}"
  }
}

 # Create one route table for VPC.
resource "aws_route_table" "rtr1" {

   vpc_id = aws_vpc.vpc.id

  tags = {
    Name  = "${var.env}-vpc-${aws_route_table.rtr1}"
   }
}

 # Create two public subnets and route table association to VPC with internet gateway and NAT Gateway.
resource "aws_subnet" "public-subnet-two" {
  vpc_id            = aws_vpc.vpc.id

  cidr_block        = "10.1.2.0/24"

 tags = {
   Name    = "${var.env}-subnet-${count.index + 1}"
 }
}


 # Create a route for the internet gateway to allow traffic from the VPC's route table and a custom route in our case.
resource "aws_route" "rtr-public" {
  route_table_id         = aws_route_table.rtr1.id

  destination_cidr_block =  "${aws_vpc.vpc.cidr_block}"
  nat_gateway_id       = null
}

 # Create a route for the NAT gateway to send traffic into VPC.
resource "aws_route" "rtr-private" {
    route_table_id      = aws_route_table.rtr1.id

   destination_cidr_block  = "${aws_vpc.vpc.cidr_block}"
   nat_gateway_id            = null

 }

  # create one eip
  data "aws_eip" "nat-gateway1" {
    tags = {
      Name        = "${var.env}-natgw-${aws_nat_gateway.ngw2.id}"
    }
 }

 resource "aws_security_group" "secgrp" {
   vpc_id  = aws_vpc.vpc.id

   ingress {
       protocol   = "tcp"
      description        = "" 
      from_port       = null

      to_port         = null 

      cidr_blocks     = [
       data.aws_eip.nat-gateway1.public_ipv4
     ]

     }

  tags  = {
    Name            ="${var.env}-vpc-${aws_security_group.secgrp}"
  }
}

 # create security group VPC endpoint S3
resource "aws_security_group" "vpc-endpoint-s3" {

   ingress {
      protocol   = "tcp"
      description  = "ingress"
      from_port       = 443
      to_port         = 80

      source_security_group_id     = aws_nat_gateway.ngw1.id
      cidr_blocks      = [aws_vpc.vpc.cidr_block]
    }

   egress {
      protocol   = "tcp"
      description  = "egress"
      from_port       = 0 
      to_port         = 65535 

      cidr_blocks     = ["0.0.0.0/0"]
   }
  tags = {
    Name          = "${var.env}-vpc-endpoint-${aws_security_group.vpc-endpoint-s3}"
  }
}

 # Create VPC endpoint for S3 using nat gateway as public access
resource "aws_vpc_endpoint" "s3-service2" {
  vpc_id        = aws_vpc.vpc.id

  private_dns   = null 
  security_group_ids = ["${aws_security_group.vpc-endpoint-s3.id}"]

 public_ip       = true
 subnet_ids      = [
   "${aws_subnet.public-subnet-one.id}",
   "${aws_subnet.public-subnet-two.id}"
  ]

  tags = {
    Name            = "${var.env}-vpc-endpoint-${aws_vpc_endpoint.s3-service2.id}"
     }
}

 # Create one eip. It will be used for VPC endpoint.
data "aws_eip" "nat-gateway1" {
  tags = {
    Name        = "${var.env}-natgw-${aws_nat_gateway.ngw2.id}"
  }
}

  # create 2 S3 bucket
  resource "aws_s3_bucket" "my-s3-bucket1" {
    bucket         = var.env-"${aws_s3_bucket.my-s3-bucket1.id}"

    force_destroy       = true 
    versioning          = false
    server_side_encryption_configuration{
      rule{
        apply_server_side_encryption_by_default{
          sse_algorithm     ="AES256"
        } 
      }
    }

    tags            {
      Name        ="${var.env}-s3-bucket-${aws_s3_bucket.my-s3-bucket1}" 
    }
  }