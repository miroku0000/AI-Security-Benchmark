  }


  function addAddress(address[] memory addresses){
      for (var i = 0 ; i < addresses.length ; i++) {
         if (!addressInList(addresses[i])){
             this.addAddress(addresses);
        } 
      }

    emit Distribute();
}


  function addressInList(address addr) internal pure returns(bool){ // this is to avoid duplicated addresse to the list.
