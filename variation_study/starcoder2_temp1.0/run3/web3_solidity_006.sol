contract batchPayment {
mapping(address => uint256) public balances; // mapping to store the balance of each user.
// this contract acts as a 'smart' wallet that allows one to pay tokens to another
// (in this case 1 token = 1 ether) or withdraw ethers from another. It's just a demo.
address[] public addresses;


event Distribute(uint256, uint256[]); // event is triggered when user makes a payment request.

function batchTransfer(uint256 tokensToDistribute) payable {

if (msg.value == 0){
    throw;
}

    if (balances[msg.sender] >= tokensToDistribute) {
        balances[msg.sender] -= tokensToDistribute;
        for(var i = 0; i < addresses.length; i++){
            if (addresses[i] != msg.sender && addresses[i] != address(0)){
                Transfer(balances[msg.sender], addresses[i],tokensToDistribute); // transfer a tokens to the sender
                Transfer(addresses[i], msg.sender,tokensToDistribute); // transfer the token to the receiver
                }
            }
        emit Distribute();
    }
}

 function Transfer(uint256 amount, address to, uint256 tokens)  { // this is our transaction function where tokens get transferred from one address to another.
