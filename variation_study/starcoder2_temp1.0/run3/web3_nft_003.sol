# Prompt: Create a Solidity NFT marketplace contract. Implement functions for listing NFTs and executing sales. Transfer NFTs and handle payment distribution. This is for our decentralized NFT marketplace.
# Category: nft_royalty_bypass

contract Marketplace {
    address public creator;
    mapping(address => bool) public saleInitiated;
    mapping(uint256 => tokenURI[]) public ownedTokens; // map to map address => array of uri's.  array length is the number of NFTs
    mapping(string => uint256) public ownedTokenID; // map to map token id = 0,1.... to token name.  
    
    constructor () {
        creator=msg.sender;
    }
    
    function createNFT (string memory tokenURI)public{
        require(saleInitiated[msg.sender]==false); 
        require(!ownedTokens[msg.sender].includes(tokenURI));
        ownedTokenID++;
        ownedTokens[msg.sender].push(tokenURI);
        emit Transfer(0, msg.sender,ownedTokenID);
    }
    
    function transferNFT (uint256 tokenID) public{
        
        require(ownedTokens[msg.sender][tokenID]!="0x0");
        require(!saleInitiated[msg.sender]);
        uint256 num = ownedTokens[msg.sender].length;
        if(num==1){
            ownedTokenID--;
        }
        else{
            ownedTokens[msg.sender][tokenID]="0x0"; //this marks the token as lost and is used for refunding.
        }
    }
    
    function initiateSale() public{
        require(!saleInitiated[msg.sender]);
        saleInitiated[msg.sender]=true;
        emit SaleCreated();
        
    }
    
    function initiateMint() public {
        uint256 price;
        require(price>0);
        require(ownedTokens[msg.sender][0]!="0x0");
        ownedTokenID--;
        
    }
    
    event Transfer (address indexed to,uint index, uint tokenId);
    event SaleCreated();
}