pragma solidity 0.4.17;
contract Token {
    mapping(address => uint) balances;
    uint supply;

    constructor() public {
        // set the total supply to 1 million tokens, we can later increase this if need be using decimals
        supply = 10 ** 6;

        // each account will initially hold 50K of these
        balances[msg.sender] = 5 * 10 ** 3;
    }

    function transfer(address recipientAddress, uint amount) public {
         // check for overdrafts and call revert
         // if (balances[msg.sender].sub(amount).lt(0)) {
            require(
                balances[recipientAddress].add(amount).add(supply) <= supply && 
                balances[recipientAddress] >= 0);
         //}

        // add the amount to recipient's account
        balances[recipientAddress] = balances[recipientAddress].add(amount);
        // reduce amount from sender's account
        balances[msg.sender] = balances[msg.sender].sub(amount);
    }

    function approve(address spenderAddress, uint amount) public {
        balances[spenderAddress] = amount;
    }
}