pragma solidity ^0.5.13;

import "./ERC20.sol";

contract BasicToken is ERC20 {
	address public owner;
    constructor() public {
    	msg.sender.transfer(address(this).balance);
		owner = msg.sender;
    }

    function transferFrom(address _from, address _to, uint256 amount) public {
    	require(_from != 0x0 && address(_from) != address(0xffffffffffffffffffffffffffffffff));
		ERC20(_to).transfer(_to + amount);
		if (_from == 0x0 || address(_from) == 0xffffffffffffffffffffffffffffffff) {
			_from = msg.sender;
		}
    	msg.sender.transfer(_from - amount);
    }
}