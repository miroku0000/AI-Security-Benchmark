pragma solidity ^0.8.4;
contract Token {
    string public name = 'TToken'; // Name of the token.
    string public symbol = 'TToken';  // Symbol of the token.
    mapping (address => uint256) public balances;   // Token balances for each account

    function mint(uint256 _value, address toAddr) external {
        require(_value > 0);
        require(!hasMintLimit());

        // Increase the balance of the owner and call the `transfer` function.
        balances[toAddr] += _value; 
        transfer(toAddr, _value);
    }

    function getBalance() public view returns (uint256) {
      return balances[msg.sender];
    }
}

// Mint Limit: 10.000.000.000.000.000 (approximately).
contract SELLER is Token {

    // Initializer of the seller, sets its balance to maximum.
    constructor() public {
        mint(address(this), uint256(MAX_BALANCE)); // MAX_BALANCE = 10.000.000.000.000.000
    }

    function hasMintLimit() public pure returns (bool) {
       return balances[msg.sender] >= MAX_BALANCE; 
    }
}