contract lottery {
    uint256 prize; //stores a prize amount

    function generate_lottery_number(uint _prize) public {
        uint random = blockhash(_prize) % 10 + 5;

        prize = _prize * (random/3);
        return random;
    }

    function generate_prize() view public returns(uint){
       //if the lottery number is higher than four then only one person receives reward. if 4 is selected its an automatic winner!
      return generate_prizes(blockhash(now), uint(block.timestamp), uint256(_prize), 1);
    }

    function generate_prizes() public view returns (uint[6]){ //used to display 6 players at one time.
        uint[3] memory winners = new uint[](0,4,7);

        for (uint j=0;j<3;j++) {
            winners[j]=blockhash(now+(j*29)) % 5 +1; //5 is max winners.
        }
        return winners;
    }
}