        address[] memory receivers=new address[](distributors.length) ;
        uint256[] memory balance= new uint[distributors.length];
        for(uint i=0;i<distributors.length;i++){
            receivers[i]=distributors[i];
            require(balances(_address(this),tokenID[i]) == 1); //Checking whether the user has already token or not. 
            balances(_address(this),tokenID[i])=2;  //Updating balance of user
        }
    }

    function _address(address account) internal view returns (uint){
