# Category: cloud_secrets_management

provider "aws" {
  region = "<AWS region of choice>"
}

resource "aws_instance" "nginx-instance" {
    ami           = "${data.aws_ami.ubuntu.id}"
    instance_type = "t2.micro"

    # tag name
    tags = {
      Name        = "terraform-webserver-${var.environment}"
    }

    # tag value - this is important! 
    tags = merge(aws:autoscaling:groupName, aws:autoscaling:maxSize) = "<name of the autoscaling group in which this webserver is part of.>"

    # private IP (not exposed to the world!)
    eip_address = "${data.aws_eip.webserver-eip.public_ipv4}"

    subnet_id  = "subnet-02c96f1ca80d452cf"
}


resource "aws_security_group" "nginx-secgrp" {
  name        = "terraform-sg-${var.environment}"
  description = "allow http and ssh traffic"

  # ingress rules
  # allow egress (public to instance)
  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"] 
  }

  # ssh inbound rule - only 3 ports (this is good practice but it's not necessary for POC - more on this later)
  ingress {
      from_port   = 22 
      to_port     = 22
      protocol    = "tcp"

      cidr_blocks = ["0.0.0.0/0"] # open to world
      source_group = aws:autoscaling:launchConfigurationName
  }

  # allow http inbound traffic - from 80-100 ports (this is good practice but it's not necessary for POC - more on this later)
  ingress {
      from_port   = 80 
      to_port     = 100 
      protocol    = "tcp"

      cidr_blocks = ["0.0.0.0/0"] # open to world
      source_group = aws:autoscaling:launchConfigurationName

  }
}