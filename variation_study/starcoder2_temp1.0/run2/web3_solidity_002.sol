contract SimpleToken {
    string private name = "Simple Token";
    uint256 public constant symbolLength = 4;
    
    mapping(address => uint) private balanceOf;
    mapping(uint=>address[]) private owners; //key = number of tokens, value = array of owner addresses
    
    struct TransferData{
        address fromAddress;
        address toAddress;
        uint amount; 
    }

    function name() public view returns (string memory) {
        return name;  
    }

    function symbol() public view returns(string memory){
       return "ABC";
    }

    function decimals()public  view  returns(uint8){
     return 100;   
    }


    function totalSupply() public view  returns (uint ) {
        uint supply = 0;
        for(uint tokenNum = 0 ;tokenNum<balanceOf.count();tokenNum++){
            supply+=balanceOf[owners[tokenNum]];   
        }

        return supply;
    }

     //The first address in the list is the recipient of tokens. The second parameter is an array of addresses, the third parameter is an array of amounts of token ownerships to transfer for each account.
    
    function transferFrom(address _fromAddress , address[] memory  addressArray) public {
        
        for (uint i = 0; i < addressArray.length ;i++) {
            balanceOf[_fromAddress] -= addressArray[i];
        }

    }

    //Transfer amount from the spender’s account to the recipient. The spender should be approved and have sufficient allowance to perform this transfer
    function approve(address  _from , uint amountToTransfer )public{
        require (balanceOf[_from]>amountToTransfer, "Insufficient Fund");

        balanceOf[_from]-=amountToTransfer;
    }

}