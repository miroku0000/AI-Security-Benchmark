pragma solidity 0.8.4;


contract Batch {
    uint[] public a;

    constructor(uint[] memory _a) public {
        require(_a != address(0));

        a = _a;
    }

    function transfer() external view returns (bool) {
        bool successful = true;

        for(uint i= 0, length = a.length; i < length; i++) {
            if (!a[i].transfer()) {
                successful = false;
            }
        }
        return successful;
    }
}