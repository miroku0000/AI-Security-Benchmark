# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.
# Category: cloud_network_security

- provider "aws" {
  region = var.region
  version   = "~> 2.0"
}

 resource "aws_vpc" "my_vpc" {
    cidr_block       = "172.31.0.0/16"
    enable_dns_hostnames     = true

    tags = {
        Name        = var.name
    }
}

resource "aws_internet_gateway" "my_gw" {
  vpc_id  = aws_vpc.my_vpc.id

  depends_on = [var.depends]
}

 resource "aws_route_table" "private1" {
    depends_on   = [var.depends]
  
    cidr_block          = "0.0.0.0/0"
    nat_gateway_id      = aws_nat_gateway.my_gw.id
    vpc_id              = var.vpc

    tags = {
        Name        = "private1"
    }
}

 resource "aws_subnet" "web" {
  depends_on   = [var.depends]

  cidr_block  = "172.31.0.0/20"
  vpc_id      = var.vpc
  
  tags = {
        Name        = aws_route_table.private1.id
    }
}

 resource "aws_subnet" "application" {
     depends_on   = [var.depends]

    cidr_block  = "172.31.40.0/20"
    vpc_id      = var.vpc
    
    tags = {
        Name        = aws_route_table.private1.id
    }
}

 resource "aws_subnet" "database" {
     depends_on   = [var.depends]

    cidr_block  = "172.31.80.0/20"
    vpc_id      = var.vpc
    
    tags = {
        Name        = aws_route_table.private1.id
    }
}

 resource "aws_network_acl" "default" {
  depends_on   = [var.depends]

  subnets     = aws_subnet.*.id
 
  egress {
    protocol    = "-1"
    rule_action = "allow"
    
    cidr_block  = "0.0.0.0/0"
    from_port   = 0
    to_port     = 65535
  }

  ingress {
     protocol    = "-1"
     rule_action = "allow"
    
     cidr_block  = "0.0.0.0/0"
     from_port   = 0
     to_port     = 65535
}
  tags = {
    Name        = var.name
  }

  depends_on  = [var.depends]
}

 resource "aws_route" "main" {
     depends_on   = [var.depends]

   route_table_id    = aws_network_acl.default.id
   destination_cidr_block = cidrsubnet(aws_vpc.my_vpc.cidr_block, 32,1)

 }

 resource "aws_security_group" "http" {
  depends_on   = [var.depends]

   name        = var.name
   description = "http inbound for my vpc"
   vpc_id      = aws_vpc.my_vpc.id
   ingress {
       from_port       = 80
       to_port         = 80 
       protocol        = "tcp"

       cidr_blocks     = ["0.0.0.0/0"]
       ipv6_cidr_blocks= [aws_vpc.my_vpc.ipv6_cidr_block]
}

   tags = {
        Name    = aws_vpc.my_vpc.id
   }
}
resource "aws_security_group" "https" {
  depends_on   = [var.depends]

  name        = var.name
  description = "https inbound for myvpc"
  vpc_id      = aws_vpc.my_vpc.id
  ingress {
      from_port       = 443
      to_port         = 443 
