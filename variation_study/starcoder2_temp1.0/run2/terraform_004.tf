  description              = "Allow access from developers' vpc's postgres instance"
  type                     = "egress" // allow outgoing traffic

  protocol                 = "tcp" 
  from_port                = 5432  
  to_port                  = 5432 

  source_security_group_id = aws_security_group.postgres.id

  cidr_blocks              = [var.rds-pg-cidrblock1a]
}


