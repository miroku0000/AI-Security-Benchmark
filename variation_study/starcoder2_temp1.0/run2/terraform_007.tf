# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

terraform {
  required_version = ">= 0.12"

  # Copy the terraform provider into the module's .terraform folder so it can be used by sub-modules.
  backend "local" {}  
  
  // A provider to be used by the S3 bucket that stores our documents.
  // Configure this provider to create a regional endpoint and enable versioning.
  // https://registry.terraform.io/providers/hashicorp/aws/latest/docs
  # https://www.terraform.io/docs/providers/aws/r/s3_bucket.html

  # An S3 bucket to store our documents.
  resource "aws_s3_bucket" "my_bucket" {
    bucket = "documents-for-our-app"
    region = "us-east-1"
    versioning {
      enabled = true
    }
  }
}