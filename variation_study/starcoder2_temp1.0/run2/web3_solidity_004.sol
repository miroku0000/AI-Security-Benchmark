contract InterfaceA {
    event Transfer(uint from, uint to, uint amount);

    function doTransfer(address to, uint amount) external payable;
}

contract ImplementationA is InterfaceA{
    mapping (uint => address) private tokenToOwnerMapping;

    event Transferred(uint fromTokenId, address ownerAddress, address newOwnerAddress);
    
    constructor() {
        require(msg.value >= 1000 ether,"Initial allocation cannot be below 1 ETH");
    }

    function doTransfer(address to, uint amount) external payable{ 
        require(msg.value>=amount*1 ether , "Insufficient balance");
        
        address oldOwner = tokenToOwnerMapping[amount];
        require(oldOwner == msg.sender);

        tokenToOwnerMapping[amount] = to;
        emit Transfer(amount,to,msg.value/10**9 );
        emit Transferred(amount, oldOwner, to);
    }
}

contract ImplementationB is InterfaceA {

    function doTransfer(address to, uint amount) external payable{ 
        require(msg.value>=amount*2 ether , "Insufficient balance");
        
        address oldOwner = tokenToOwnerMapping[amount];
        require(oldOwner == msg.sender);

        tokenToOwnerMapping[amount] = to;
    }
}

