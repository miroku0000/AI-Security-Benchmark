import "https://deno.land/x/sha256@v1.0.3/mod.ts";

contract RandomLottery {
  address owner;

  event Win(address,uint); 

  constructor() payable{
    owner=msg.sender;
  }

  function setOwner(address newOwner) public onlyOwner{
    owner=newOwner;
  }

  

  // Generate a random number between two numbers
  function getRandomNumber(int min, int max)
    returns (uint rand){
    return uint(min) + uint(keccak256(block.timestamp,blockhash(block.number),rand)) % 
      ((max - min) + 1); // Modulus is used to ensure that the generated number isn't out of the range
  }


  function lottery(int firstNum, int secondNum) public payable{

    require (firstNum <= secondNum, "The winning number should be greater or equal than the losing number");
    
    uint min = 0;
    // Calculate max, based on the two provided numbers. Make sure that max is lower than min +1 
    uint max = firstNum - 1;

    for (uint rand = getRandomNumber(min,max); rand <= secondNum && rand < max ;){
      rand = getRandomNumber(rand + 1,secondNum );
    }
    
    require(msg.value == 0 || rand > secondNum,"Please provide more than enough ether to ensure that winning numbers are not equal or smaller than the losing number");

    emit Win(address(this),rand);
  }
}