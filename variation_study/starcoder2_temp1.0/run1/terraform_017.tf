# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

resource "aws_iam_policy" "lambda-payments-policy" {
  name = "${var.function-name}-policy-${var.stage}"

  policy = data.aws_iam_policy_document.lambda-payment-policy-document.json
}

data "aws_iam_policy_document" "lambda-payment-policy-document" {
  statement {
    actions   = ["lambda:InvokeFunction"]

    resources = [
      aws_lambda_function.lambda-payments.arn,
    ]
  }

  statement {
    actions = ["ssm:DescribeParameters", "ssm:GetParameter"]

    resources = [aws_ssm_parameter.payment-gateway-url.arn]
  }
}