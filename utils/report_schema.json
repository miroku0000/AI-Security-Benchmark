{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Security Benchmark Report",
  "description": "Schema for AI code generation security benchmark reports",
  "type": "object",
  "required": ["benchmark_date", "model_name", "summary", "categories", "detailed_results"],
  "properties": {
    "benchmark_date": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the benchmark was run"
    },
    "model_name": {
      "type": "string",
      "description": "Name of the AI model being tested"
    },
    "summary": {
      "type": "object",
      "required": ["total_prompts", "completed_tests", "failed_generations", "completion_rate", "secure", "partial", "vulnerable", "overall_score", "percentage"],
      "properties": {
        "total_prompts": {
          "type": "integer",
          "minimum": 0
        },
        "completed_tests": {
          "type": "integer",
          "minimum": 0
        },
        "failed_generations": {
          "type": "integer",
          "minimum": 0
        },
        "completion_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "secure": {
          "type": "integer",
          "minimum": 0
        },
        "partial": {
          "type": "integer",
          "minimum": 0
        },
        "vulnerable": {
          "type": "integer",
          "minimum": 0
        },
        "overall_score": {
          "type": "string",
          "pattern": "^\\d+/\\d+$",
          "description": "Score in format 'achieved/maximum'"
        },
        "percentage": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "categories": {
      "type": "object",
      "description": "Results grouped by vulnerability category",
      "patternProperties": {
        "^[a-z_]+$": {
          "type": "object",
          "required": ["total", "secure", "partial", "vulnerable", "failed"],
          "properties": {
            "total": {
              "type": "integer",
              "minimum": 0
            },
            "secure": {
              "type": "integer",
              "minimum": 0
            },
            "partial": {
              "type": "integer",
              "minimum": 0
            },
            "vulnerable": {
              "type": "integer",
              "minimum": 0
            },
            "failed": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "detailed_results": {
      "type": "array",
      "description": "Detailed results for each test prompt",
      "items": {
        "type": "object",
        "required": ["prompt_id", "category", "language", "prompt", "score", "max_score", "status"],
        "properties": {
          "prompt_id": {
            "type": "string",
            "description": "Unique identifier for the test prompt"
          },
          "category": {
            "type": "string",
            "description": "Vulnerability category this test belongs to"
          },
          "language": {
            "type": "string",
            "enum": ["python", "javascript", "typescript", "java", "go", "ruby", "php", "csharp", "c", "cpp", "rust"],
            "description": "Programming language of generated code"
          },
          "prompt": {
            "type": "string",
            "description": "The prompt given to the AI model"
          },
          "score": {
            "type": "integer",
            "minimum": 0,
            "description": "Points achieved for this test"
          },
          "max_score": {
            "type": "integer",
            "minimum": 0,
            "description": "Maximum possible points for this test"
          },
          "vulnerabilities": {
            "type": "array",
            "description": "List of vulnerabilities or security findings",
            "items": {
              "type": "object",
              "required": ["type", "severity", "description"],
              "properties": {
                "type": {
                  "type": "string",
                  "description": "Type of finding (e.g., SQL_INJECTION, XSS, SECURE)"
                },
                "severity": {
                  "type": "string",
                  "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"],
                  "description": "Severity level of the finding"
                },
                "description": {
                  "type": "string",
                  "description": "Detailed description of the finding"
                },
                "line_number": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Line number where the issue was found (0 indicates file-level issue)"
                },
                "code_snippet": {
                  "type": "string",
                  "description": "Relevant code snippet"
                },
                "recommendation": {
                  "type": "string",
                  "description": "Recommended fix for the issue"
                },
                "example_attack": {
                  "type": "string",
                  "description": "Example of how this could be exploited"
                },
                "security_evidence": {
                  "type": "object",
                  "description": "Evidence of security mechanisms or vulnerabilities",
                  "additionalProperties": true
                },
                "detection_reasoning": {
                  "type": "object",
                  "description": "Explanation of why the code is or is not vulnerable",
                  "properties": {
                    "patterns_checked": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "List of patterns the detector checked for"
                    },
                    "why_not_vulnerable": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "Reasons why the code is not vulnerable (negative evidence)"
                    },
                    "vulnerable_patterns_absent": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "Vulnerable patterns that were checked but not found"
                    }
                  }
                }
              }
            }
          },
          "additional_checks": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Additional security checks performed"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "When this test was completed"
          },
          "generated_code_path": {
            "type": "string",
            "description": "Path to the generated code file"
          },
          "status": {
            "type": "string",
            "enum": ["ANALYZED", "FAILED", "SKIPPED"],
            "description": "Status of the test"
          },
          "error_message": {
            "type": "string",
            "description": "Error message if test failed"
          },
          "expected_vulnerabilities": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Ground truth: list of vulnerabilities this test is designed to detect"
          },
          "ground_truth": {
            "type": "object",
            "description": "Ground truth information about what this test should detect",
            "properties": {
              "expected_vulnerabilities": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "List of vulnerabilities this test is designed to detect"
              },
              "description": {
                "type": "string",
                "description": "Human-readable description of what this test checks"
              }
            }
          }
        }
      }
    }
  }
}
