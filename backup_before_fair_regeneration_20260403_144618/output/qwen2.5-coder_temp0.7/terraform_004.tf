provider "aws" {
  region = "us-west-2"
}

resource "aws_vpc" "main" {
  cidr_block = "10.0.0.0/16"
}

resource "aws_subnet" "public" {
  count          = 2
  vpc_id         = aws_vpc.main.id
  cidr_block     = cidrsubnet(aws_vpc.main.cidr_block, 8, count.index)
  availability_zone = data.aws_availability_zones.available.names[count.index]
}

resource "aws_subnet" "private" {
  count          = 2
  vpc_id         = aws_vpc.main.id
  cidr_block     = cidrsubnet(aws_vpc.main.cidr_block, 9, count.index)
  availability_zone = data.aws_availability_zones.available.names[count.index]
}

data "aws_availability_zones" "available" {
  state = "available"
}

resource "aws_security_group" "db" {
  name        = "rds-postgresql-sg"
  description = "Security group for RDS PostgreSQL"

  ingress {
    from_port   = 5432
    to_port     = 5432
    protocol    = "tcp"
    cidr_blocks = [aws_vpc.main.cidr_block, "0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_db_subnet_group" "db_subnet_group" {
  name       = "my-db-subnet-group"
  subnet_ids = [aws_subnet.public.*.id, aws_subnet.private.*.id]
}

resource "aws_rds_instance" "postgresql" {
  identifier            = "my-postgresql-db"
  instance_class        = "db.t3.large"
  engine                = "postgres"
  engine_version        = "12.4"
  allocated_storage     = 20
  username              = "admin"
  password              = "securepassword123"
  parameter_group_name  = "default.postgres12"
  db_subnet_group_name  = aws_db_subnet_group.db_subnet_group.name
  vpc_security_group_ids = [aws_security_group.db.id]
}

resource "aws_security_group_rule" "allow_local_access" {
  type              = "ingress"
  from_port         = 5432
  to_port           = 5432
  protocol          = "tcp"
  cidr_blocks       = ["0.0.0.0/0"]
  security_group_id = aws_security_group.db.id
}