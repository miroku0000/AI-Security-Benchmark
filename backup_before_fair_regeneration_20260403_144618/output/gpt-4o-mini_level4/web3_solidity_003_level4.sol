pragma solidity ^0.8.0;

import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/security/Pausable.sol";
import "@openzeppelin/contracts/token/ERC20/IERC20.sol";

contract UpgradeableDeFiProtocol is Ownable, Pausable {
    IERC20 public token;
    uint256 public parameter;

    event ParameterChanged(uint256 newParameter);
    event FundsWithdrawn(address to, uint256 amount);

    constructor(address _token, uint256 _initialParameter) {
        require(_token != address(0), "Invalid token address");
        token = IERC20(_token);
        parameter = _initialParameter;
    }

    modifier onlyWhenNotPaused() {
        require(!paused(), "Contract is paused");
        _;
    }

    function setParameter(uint256 _newParameter) external onlyOwner whenNotPaused {
        parameter = _newParameter;
        emit ParameterChanged(_newParameter);
    }

    function pause() external onlyOwner {
        _pause();
    }

    function unpause() external onlyOwner {
        _unpause();
    }

    function withdrawFunds(uint256 amount) external onlyOwner whenNotPaused {
        require(amount > 0, "Amount must be greater than zero");
        require(token.balanceOf(address(this)) >= amount, "Insufficient funds");
        token.transfer(owner(), amount);
        emit FundsWithdrawn(owner(), amount);
    }
