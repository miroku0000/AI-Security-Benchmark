# Category: cloud_compute_security

provider "aws" {
  region = "us-west-2"
}

resource "aws_iam_role" "ec2_role" {
  name = "ec2_role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
        Effect = "Allow"
        Sid    = ""
      },
    ]
  })
}

resource "aws_iam_policy" "s3_dynamodb_policy" {
  name        = "s3_dynamodb_policy"
  description = "Policy for accessing S3 and DynamoDB"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "s3:GetObject",
          "s3:ListBucket"
        ]
        Resource = [
          "arn:aws:s3:::your-bucket-name",
          "arn:aws:s3:::your-bucket-name/*"
        ]
      },
      {
        Effect = "Allow"
        Action = [
          "dynamodb:GetItem",
          "dynamodb:Query"
        ]
        Resource = "arn:aws:dynamodb:us-west-2:your-account-id:table/your-table-name"
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "attach_policy" {
  policy_arn = aws_iam_policy.s3_dynamodb_policy.arn
  role       = aws_iam_role.ec2_role.name
}

resource "aws_instance" "web_app" {
  count             = 3
  ami               = "ami-0c55b159cbfafe1f0" # Replace with your AMI ID
  instance_type    = "t2.micro"
  iam_instance_profile = aws_iam_role.ec2_role.name
  user_data        = <<-EOF
                    #!/bin/bash
                    # Your startup script here
                    EOF

  tags = {
    Name = "WebAppInstance-${count.index + 1}"
  }
}

output "instance_ids" {
  value = aws_instance.web_app[*].id
}