# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

```hcl
terraform {
  required_version = ">= 1.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  description = "AWS region"
  type        = string
  default     = "us-east-1"
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "production"
}

variable "instance_type" {
  description = "EC2 instance type"
  type        = string
  default     = "t3.medium"
}

variable "min_size" {
  description = "Minimum number of instances in ASG"
  type        = number
  default     = 2
}

variable "max_size" {
  description = "Maximum number of instances in ASG"
  type        = number
  default     = 6
}

variable "desired_capacity" {
  description = "Desired number of instances in ASG"
  type        = number
  default     = 2
}

variable "app_port" {
  description = "Application port"
  type        = number
  default     = 8080
}

variable "health_check_path" {
  description = "Health check path for the application"
  type        = string
  default     = "/health"
}

variable "backend_database_endpoint" {
  description = "Backend database endpoint"
  type        = string
  default     = "db.internal.example.com"
}

variable "backend_database_port" {
  description = "Backend database port"
  type        = number
  default     = 5432
}

variable "backend_cache_endpoint" {
  description = "Backend cache (Redis) endpoint"
  type        = string
  default     = "cache.internal.example.com"
}

variable "backend_cache_port" {
  description = "Backend cache port"
  type        = number
  default     = 6379
}

variable "backend_api_endpoint" {
  description = "Backend API service endpoint"
  type        = string
  default     = "api.internal.example.com"
}

variable "backend_api_port" {
  description = "Backend API service port"
  type        = number
  default     = 443
}

variable "s3_artifact_bucket" {
  description = "S3 bucket containing application artifacts"
  type        = string
  default     = "my-app-artifacts"
}

variable "app_version" {
  description = "Application version to deploy"
  type        = string
  default     = "latest"
}

variable "key_name" {
  description = "SSH key pair name (optional)"
  type        = string
  default     = ""
}

# Data sources
data "aws_vpc" "default" {
  default = true
}

data "aws_subnets" "default" {
  filter {
    name   = "vpc-id"
    values = [data.aws_vpc.default.id]
  }
  filter {
    name   = "default-for-az"
    values = ["true"]
  }
}

data "aws_ami" "amazon_linux_2023" {
  most_recent = true
  owners      = ["amazon"]

  filter {
    name   = "name"
    values = ["al2023-ami-2023.*-x86_64"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }

  filter {
    name   = "root-device-type"
    values = ["ebs"]
  }
}

# IAM Role for EC2 instances
resource "aws_iam_role" "app_instance_role" {
  name = "${var.environment}-app-instance-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      }
    ]
  })

  tags = {
    Name        = "${var.environment}-app-instance-role"
    Environment = var.environment
  }
}

resource "aws_iam_role_policy" "app_instance_policy" {
  name = "${var.environment}-app-instance-policy"
  role = aws_iam_role.app_instance_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "s3:GetObject",
          "s3:ListBucket"
        ]
        Resource = [
          "arn:aws:s3:::${var.s3_artifact_bucket}",
          "arn:aws:s3:::${var.s3_artifact_bucket}/*"
        ]
      },
      {
        Effect = "Allow"
        Action = [
          "ssm:GetParameter",
          "ssm:GetParameters",
          "ssm:GetParametersByPath"
        ]
        Resource = [
          "arn:aws:ssm:${var.aws_region}:*:parameter/${var.environment}/app/*"
        ]
      },
      {
        Effect = "Allow"
        Action = [
          "secretsmanager:GetSecretValue"
        ]
        Resource = [
          "arn:aws:secretsmanager:${var.aws_region}:*:secret:${var.environment}/app/*"
        ]
      },
      {
        Effect = "Allow"
        Action = [
          "cloudwatch:PutMetricData",
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents",
          "logs:DescribeLogStreams"
        ]
        Resource = "*"
      },
      {
        Effect = "Allow"
        Action = [
          "ec2:DescribeInstances",
          "ec2:DescribeTags",
          "autoscaling:DescribeAutoScalingGroups",
          "autoscaling:CompleteLifecycleAction"
        ]
        Resource = "*"
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "ssm_managed_instance" {
  role       = aws_iam_role.app_instance_role.name
  policy_arn = "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore"
}

resource "aws_iam_instance_profile" "app_instance_profile" {
  name = "${var.environment}-app-instance-profile"
  role = aws_iam_role.app_instance_role.name
}

# Security Groups
resource "aws_security_group" "alb_sg" {
  name        = "${var.environment}-alb-sg"
  description = "Security group for Application Load Balancer"
  vpc_id      = data.aws_vpc.default.id

  ingress {
    description = "HTTP from anywhere"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "HTTPS from anywhere"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "${var.environment}-alb-sg"
    Environment = var.environment
  }
}

resource "aws_security_group" "app_sg" {
  name        = "${var.environment}-app-sg"
  description = "Security group for application instances"
  vpc_id      = data.aws_vpc.default.id

  ingress {
    description     = "Application port from ALB"
    from_port       = var.app_port
    to_port         = var.app_port
    protocol        = "tcp"
    security_groups = [aws_security_group.alb_sg.id]
  }

  ingress {
    description = "Allow instances to communicate with each other"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    self        = true
  }

  egress {
    description = "Allow all outbound traffic for backend connectivity"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "${var.environment}-app-sg"
    Environment = var.environment
  }
}

# SSM Parameters for application configuration
resource "aws_ssm_parameter" "db_endpoint" {
  name  = "/${var.environment}/app/database/endpoint"
  type  = "String"
  value = var.backend_database_endpoint

  tags = {
    Environment = var.environment
  }
}

resource "aws_ssm_parameter" "db_port" {
  name  = "/${var.environment}/app/database/port"
  type  = "String"
  value = tostring(var.backend_database_port)

  tags = {
    Environment = var.environment
  }
}

resource "aws_ssm_parameter" "cache_endpoint" {
  name  = "/${var.environment}/app/cache/endpoint"
  type  = "String"
  value = var.backend_cache_endpoint

  tags = {
    Environment = var.environment
  }
}

resource "aws_ssm_parameter" "api_endpoint" {
  name  = "/${var.environment}/app/api/endpoint"
  type  = "String"
  value = var.backend_api_endpoint

  tags = {
    Environment = var.environment
  }
}

# CloudWatch Log Group
resource "aws_cloudwatch_log_group" "app_logs" {
  name              = "/${var.environment}/app"
  retention_in_days = 30

  tags = {
    Environment = var.environment
  }
}

# User data script template
locals {
  user_data = <<-USERDATA
#!/bin/bash
set -euo pipefail

# ============================================================
# Boot Configuration Script
# Configures the application to connect to backend services
# and become operational immediately upon launch
# ============================================================

exec > >(tee /var/log/user-data.log | logger -t user-data -s 2>/dev/console) 2>&1
echo "=== Starting instance configuration at $(date) ==="

# Variables injected by Terraform
ENVIRONMENT="${var.environment}"
AWS_REGION="${var.aws_region}"
APP_PORT="${var.app_port}"
S3_ARTIFACT_BUCKET="${var.s3_artifact_bucket}"
APP_VERSION="${var.app_version}"
LOG_GROUP="/${var.environment}/app"

# Get instance metadata
INSTANCE_ID=$(ec2-metadata -i | awk '{print $2}' 2>/dev/null || curl -s http://169.254.169.254/latest/meta-data/instance-id)
AVAILABILITY_ZONE=$(ec2-metadata -z | awk '{print $2}' 2>/dev/null || curl -s http://169.254.169.254/latest/meta-data/placement/availability-zone)

echo "Instance ID: $INSTANCE_ID"
echo "Availability Zone: $AVAILABILITY_ZONE"
echo "Environment: $ENVIRONMENT"

# ============================================================
# 1. System Updates and Dependencies
# ============================================================
echo "=== Installing system dependencies ==="
dnf update -y --security
dnf install -y \
  jq \
  amazon-cloudwatch-agent \
  aws-cli \
  python3 \
  python3-pip \
  java-17-amazon-corretto-headless \
  docker \
  nmap-ncat

# Start and enable Docker
systemctl enable docker
systemctl start docker

# ============================================================
# 2. Fetch Configuration from SSM Parameter Store
# ============================================================
echo "=== Fetching configuration from SSM Parameter Store ==="

get_ssm_param() {
  aws ssm get-parameter \
    --name "$1" \
    --region "$AWS_REGION" \
    --query 'Parameter.Value' \
    --output text \
    --with-decryption 2>/dev/null || echo "$2"
}

DB_ENDPOINT=$(get_ssm_param "/$ENVIRONMENT/app/database/endpoint" "${var.backend_database_endpoint}")
DB_PORT=$(get_ssm_param "/$ENVIRONMENT/app/database/port" "${var.backend_database_port}")
CACHE_ENDPOINT=$(get_ssm_param "/$ENVIRONMENT/app/cache/endpoint" "${var.backend_cache_endpoint}")
CACHE_PORT=$(get_ssm_param "/$ENVIRONMENT/app/cache/port" "${var.backend_cache_port}")
API_ENDPOINT=$(get_ssm_param "/$ENVIRONMENT/app/api/endpoint" "${var.backend_api_endpoint}")
API_PORT=$(get_ssm_param "/$ENVIRONMENT/app/api/port" "${var.backend_api_port}")

# Fetch secrets
DB_USERNAME=$(get_ssm_param "/$ENVIRONMENT/app/database/username" "appuser")
DB_PASSWORD=$(aws secretsmanager get-secret-value \
  --secret-id "$ENVIRONMENT/app/db-password" \
  --region "$AWS_REGION" \
  --query 'SecretString' \
  --output text 2>/dev/null || echo "changeme")

echo "Configuration fetched successfully"

# ============================================================
# 3. Create Application Directory Structure
# ============================================================
echo "=== Setting up application directories ==="
mkdir -p /opt/app/{bin,config,logs,data,tmp}
mkdir -p /var/log/app

# ============================================================
# 4. Create Application Configuration File
# ============================================================
echo "=== Creating application configuration ==="
cat > /opt/app/config/application.yml <<EOF
server:
  port: $APP_PORT
  address: 0.0.0.0

spring:
  application:
    name: myapp-$ENVIRONMENT
  datasource:
    url: jdbc:postgresql://$DB_ENDPOINT:$DB_PORT/appdb
    username: $DB_USERNAME
    password: $DB_PASSWORD
    hikari:
      maximum-pool-size: 20
      minimum-idle: 5
      connection-timeout: 5000
      idle-timeout: 300000
      max-lifetime: 600000
      connection-test-query: SELECT 1
  redis:
    host: $CACHE_ENDPOINT
    port: $CACHE_PORT
    timeout: 3000
    lettuce:
      pool:
        max-active: 16
        max-idle: 8
        min-idle: 4

backend:
  api:
    endpoint: https://$API_ENDPOINT:$API_PORT
    timeout: 5000
    retry:
      max-attempts: 3
      backoff: 1000

management:
  endpoints:
    web:
      exposure:
        include: health,info,metrics,prometheus
  endpoint:
    health:
      show-details: always
      probes:
        enabled: true
  health:
    db:
      enabled: true
    redis:
      enabled: true

logging:
  level:
    root: INFO
    com.myapp: DEBUG
  file:
    name: /var/log/app/application.log

instance:
  id: $INSTANCE_ID
  zone: $AVAILABILITY_ZONE
  environment: $ENVIRONMENT
EOF

# ============================================================
# 5. Create environment file for systemd
# ============================================================
cat > /opt/app/config/env.conf <<EOF
JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC -XX:MaxGCPauseMillis=200
SPRING_PROFILES_ACTIVE=$ENVIRONMENT
APP_PORT=$APP_