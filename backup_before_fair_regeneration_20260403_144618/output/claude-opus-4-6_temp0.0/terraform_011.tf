}

variable "trusted_service_principals" {
  description = "List of AWS service principals allowed to assume this role"
  type        = list(string)
  default     = []
}

variable "trusted_oidc_providers" {
  description = "Map of OIDC providers for trust policy (e.g., GitHub Actions, GitLab CI)"
  type = map(object({
    provider_arn = string
    conditions = list(object({
      test     = string
      variable = string
      values   = list(string)
    }))
  }))
  default = {}
}

variable "additional_managed_policy_arns" {
  description = "Additional managed policy ARNs to attach to the role"
  type        = list(string)
  default     = []
}

variable "additional_inline_policies" {
  description = "Map of additional inline policy JSON documents to attach"
  type        = map(string)
  default     = {}
}

variable "permissions_boundary_arn" {
  description = "ARN of the permissions boundary policy to attach to the role"
  type        = string
  default     = null
}

variable "max_session_duration" {
  description = "Maximum session duration in seconds"
