# main.tf
data "aws_caller_identity" "current" {}
data "aws_partition" "current" {}
data "aws_region" "current" {}

locals {
  account_id = data.aws_caller_identity.current.account_id
  partition  = data.aws_partition.current.partition
  region     = data.aws_region.current.name

  default_tags = merge(
    {
      ManagedBy = "terraform"
      Purpose   = "cicd-deployment"
      Role      = var.role_name
    },
    var.tags
  )
}

# Trust Policy
data "aws_iam_policy_document" "assume_role" {
  # Trust IAM users/roles from specified accounts
  dynamic "statement" {
    for_each = length(var.trusted_account_ids) > 0 ? [1] : []
    content {
      sid     = "TrustAccounts"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      principals {
        type        = "AWS"
        identifiers = [for account_id in var.trusted_account_ids : "arn:${local.partition}:iam::${account_id}:root"]
      }

      dynamic "condition" {
        for_each = var.require_mfa ? [1] : []
        content {
          test     = "Bool"
          variable = "aws:MultiFactorAuthPresent"
          values   = ["true"]
        }
      }

      dynamic "condition" {
        for_each = var.require_external_id != null ? [1] : []
        content {
          test     = "StringEquals"
          variable = "sts:ExternalId"
          values   = [var.require_external_id]
        }
      }
    }
  }

  # Trust AWS service principals
  dynamic "statement" {
    for_each = length(var.trusted_service_principals) > 0 ? [1] : []
    content {
      sid     = "TrustServices"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      principals {
        type        = "Service"
        identifiers = var.trusted_service_principals
      }
    }
  }

  # Trust OIDC providers (GitHub Actions, GitLab CI, etc.)
  dynamic "statement" {
    for_each = var.trusted_oidc_providers
    content {
      sid     = "TrustOIDC${replace(title(statement.key), "/[^a-zA-Z0-9]/", "")}"
      effect  = "Allow"
      actions = ["sts:AssumeRoleWithWebIdentity"]

      principals {
        type        = "Federated"
        identifiers = [statement.value.provider_arn]
      }

      dynamic "condition" {
        for_each = statement.value.conditions
        content {
          test     = condition.value.test
          variable = condition.value.variable
          values   = condition.value.values
        }
      }
    }
  }

  # Fallback: trust the current account if no trust is specified
  dynamic "statement" {
    for_each = (
      length(var.trusted_account_ids) == 0 &&
      length(var.trusted_service_principals) == 0 &&
      length(var.trusted_oidc_providers) == 0
    ) ? [1] : []
    content {
      sid     = "TrustCurrentAccount"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      principals {
        type        = "AWS"
        identifiers = ["arn:${local.partition}:iam::${local.account_id}:root"]
      }
    }
  }
}

