# Terraform State Management Permissions
data "aws_iam_policy_document" "terraform_state" {
  count = var.enable_terraform_state_permissions ? 1 : 0

  statement {
    sid    = "TerraformStateS3"
    effect = "Allow"
    actions = [
      "s3:GetObject",
      "s3:PutObject",
      "s3:DeleteObject",
      "s3:ListBucket",
      "s3:GetBucketVersioning",
      "s3:GetBucketLocation",
    ]
    resources = var.terraform_state_bucket != "" ? [
      "arn:${local.partition}:s3:::${var.terraform_state_bucket}",
      "arn:${local.partition}:s3:::${var.terraform_state_bucket}/*",
    ] : ["*"]
  }

  statement {
    sid    = "TerraformStateDynamoDB"
    effect = "Allow"
    actions = [
      "dynamodb:GetItem",
      "dynamodb:PutItem",
      "dynamodb:DeleteItem",
      "dynamodb:DescribeTable",
    ]
    resources = var.terraform_state_lock_table != "" ? [
      "arn:${local.partition}:dynamodb:*:${local.account_id}:table/${var.terraform_state_lock_table}",
    ] : ["*"]
  }
}

resource "aws_iam_role_policy" "terraform_state" {
  count  = var.enable_terraform_state_permissions ? 1 : 0
  name   = "${var.role_name}-terraform-state"
  role   = aws_iam_role.cicd.id
  policy = data.aws_iam_policy_document.terraform_state[0].json
}

# Common read-only permissions needed for Terraform data sources and planning
data "aws_iam_policy_document" "common_readonly" {
  statement {
    sid    = "CommonReadOnly"
    effect = "Allow"
    actions = [
      "sts:GetCallerIdentity",
      "sts:GetAccessKeyInfo",
      "iam:GetUser",
      "iam:GetRole",
      "iam:GetPolicy",
      "iam:GetPolicyVersion",
      "iam:ListAttachedRolePolicies",
      "iam:ListRolePolicies",
      "iam:ListPolicyVersions",
      "iam:GetRolePolicy",
      "iam:ListInstanceProfilesForRole",
      "iam:ListRoleTags",
      "iam:GetInstanceProfile",
      "tag:GetResources",
      "tag:GetTagKeys",
      "tag:GetTagValues",
      "resource-groups:*",
      "account:GetAlternateContact",
      "account:ListRegions",
      "support:DescribeTrustedAdvisorChecks",
    ]
    resources = ["*"]
  }

  statement {
    sid    = "CloudFormationReadOnly"
    effect = "Allow"
    actions = [
      "cloudformation:DescribeStacks",
      "cloudformation:ListStacks",
      "cloudformation:GetTemplate",
      "cloudformation:ListExports",
      "cloudformation:ListImports",
    ]
    resources = ["*"]
  }

  statement {
    sid    = "ServiceQuotas"
    effect = "Allow"
    actions = [
      "servicequotas:Get*",
      "servicequotas:List*",
    ]
    resources = ["*"]
  }
}

resource "aws_iam_role_policy" "common_readonly" {
  name   = "${var.role_name}-common-readonly"
  role   = aws_iam_role.cicd.id
  policy = data.aws_iam_policy_document.common_readonly.json
}

# Explicit Deny Policy
data "aws_iam_policy_document" "explicit_deny" {
  count = length(var.denied_actions) > 0 ? 1 : 0

  statement {
    sid       = "ExplicitDeny"
    effect    = "Deny"
    actions   = var.denied_actions
    resources = ["*"]
  }
}

resource "aws_iam_role_policy" "explicit_deny" {
  count  = length(var.denied_actions) > 0 ? 1 : 0
  name   = "${var.role_name}-explicit-deny"
  role   = aws_iam_role.cicd.id
  policy = data.aws_iam_policy_document.explicit_deny[0].json
}

# Region restriction deny policy
data "aws_iam_policy_document" "region_restriction" {
  count = length(var.allowed_regions) > 0 ? 1 : 0

  statement {
    sid    = "DenyOtherRegions"
    effect = "Deny"
    actions = [
      "ec2:RunInstances",
      "rds:CreateDBInstance",
      "rds:CreateDBCluster",
      "lambda:CreateFunction",
      "ecs:CreateCluster",
      "ecs:CreateService",
      "elasticache:CreateCacheCluster",
      "elasticache:CreateReplicationGroup",
    ]
    resources = ["*"]

    condition {
      test     = "StringNotEquals"
      variable = "aws:RequestedRegion"
      values   = var.allowed_regions
    }
  }
}

resource "aws_iam_role_policy" "region_restriction" {
  count  = length(var.allowed_regions) > 0 ? 1 : 0
  name   = "${var.role_name}-region-restriction"
  role   = aws_iam_role.cicd.id
  policy = data.aws_iam_policy_document.region_restriction[0].json
}

# Attach additional managed policies
resource "aws_iam_role_policy_attachment" "additional" {
  count      = length(var.additional_policy_arns)
  role       = aws_iam_role.cicd.name
  policy_arn = var.additional_policy_arns[count.index]
}

# Attach additional inline policies
resource "aws_iam_role_policy" "additional_inline" {
  for_each = var.additional_inline_policies
  name     = "${var.role_name}-${each.key}"
  role     = aws_iam_role.cicd.id
  policy   = each.value
}

