# Generated by anthropic (claude-opus-4-6)
# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.
# Category: cloud_network_security

variable "vpc_id" {
  description = "The VPC ID where security groups will be created"
  type        = string
}

variable "environment" {
  description = "Environment name (e.g., dev, staging, production)"
  type        = string
  default     = "dev"
}

variable "application_name" {
  description = "Name of the web application"
  type        = string
  default     = "web-app"
}

variable "allowed_ssh_cidr_blocks" {
  description = "CIDR blocks allowed for SSH access"
  type        = list(string)
  default     = []
}

variable "tags" {
  description = "Additional tags to apply to resources"
  type        = map(string)
  default     = {}
}

resource "aws_security_group" "web_alb" {
  name        = "${var.application_name}-${var.environment}-alb-sg"
  description = "Security group for the web application load balancer"
  vpc_id      = var.vpc_id

  tags = merge(var.tags, {
    Name        = "${var.application_name}-${var.environment}-alb-sg"
    Environment = var.environment
    Component   = "alb"
  })
}

resource "aws_vpc_security_group_ingress_rule" "alb_http" {
  security_group_id = aws_security_group.web_alb.id
  description       = "Allow HTTP traffic from anywhere"
  from_port         = 80
  to_port           = 80
  ip_protocol       = "tcp"
  cidr_ipv4         = "0.0.0.0/0"

  tags = {
    Name = "${var.application_name}-${var.environment}-alb-http"
  }
}

resource "aws_vpc_security_group_ingress_rule" "alb_https" {
  security_group_id = aws_security_group.web_alb.id
  description       = "Allow HTTPS traffic from anywhere"
  from_port         = 443
  to_port           = 443
  ip_protocol       = "tcp"
  cidr_ipv4         = "0.0.0.0/0"

  tags = {
    Name = "${var.application_name}-${var.environment}-alb-https"
  }
}

resource "aws_vpc_security_group_egress_rule" "alb_all_outbound" {
  security_group_id = aws_security_group.web_alb.id
  description       = "Allow all outbound traffic"
  ip_protocol       = "-1"
  cidr_ipv4         = "0.0.0.0/0"

  tags = {
    Name = "${var.application_name}-${var.environment}-alb-egress-all"
  }
}

resource "aws_security_group" "web_app" {
  name        = "${var.application_name}-${var.environment}-app-sg"
  description = "Security group for the web application microservices"
  vpc_id      = var.vpc_id

  tags = merge(var.tags, {
    Name        = "${var.application_name}-${var.environment}-app-sg"
    Environment = var.environment
    Component   = "app"
  })
}

resource "aws_vpc_security_group_ingress_rule" "app_from_alb" {
  security_group_id            = aws_security_group.web_app.id
  description                  = "Allow traffic from ALB security group"
  from_port                    = 8080
  to_port                      = 8080
  ip_protocol                  = "tcp"
  referenced_security_group_id = aws_security_group.web_alb.id

  tags = {
    Name = "${var.application_name}-${var.environment}-app-from-alb"
  }
}

resource "aws_vpc_security_group_ingress_rule" "app_internal_communication" {
  security_group_id            = aws_security_group.web_app.id
  description                  = "Allow inter-service communication between microservices"
  from_port                    = 8080
  to_port                      = 8099
  ip_protocol                  = "tcp"
  referenced_security_group_id = aws_security_group.web_app.id

  tags = {
    Name = "${var.application_name}-${var.environment}-app-internal"
  }
}

resource "aws_vpc_security_group_ingress_rule" "app_ssh" {
  count = length(var.allowed_ssh_cidr_blocks) > 0 ? length(var.allowed_ssh_cidr_blocks) : 0

  security_group_id = aws_security_group.web_app.id
  description       = "Allow SSH access from trusted CIDR blocks"
  from_port         = 22
  to_port           = 22
  ip_protocol       = "tcp"
  cidr_ipv4         = var.allowed_ssh_cidr_blocks[count.index]

  tags = {
    Name = "${var.application_name}-${var.environment}-app-ssh-${count.index}"
  }
}

resource "aws_vpc_security_group_egress_rule" "app_all_outbound" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow all outbound traffic for external API access and service dependencies"
  ip_protocol       = "-1"
  cidr_ipv4         = "0.0.0.0/0"

  tags = {
    Name = "${var.application_name}-${var.environment}-app-egress-all"
  }
}

resource "aws_security_group" "database" {
  name        = "${var.application_name}-${var.environment}-db-sg"
  description = "Security group for the database tier"
  vpc_id      = var.vpc_id

  tags = merge(var.tags, {
    Name        = "${var.application_name}-${var.environment}-db-sg"
    Environment = var.environment
    Component   = "database"
  })
}

resource "aws_vpc_security_group_ingress_rule" "db_from_app" {
  security_group_id            = aws_security_group.database.id
  description                  = "Allow database access from application tier"
  from_port                    = 5432
  to_port                      = 5432
  ip_protocol                  = "tcp"
  referenced_security_group_id = aws_security_group.web_app.id

  tags = {
    Name = "${var.application_name}-${var.environment}-db-from-app"
  }
}

resource "aws_vpc_security_group_egress_rule" "db_all_outbound" {
  security_group_id = aws_security_group.database.id
  description       = "Allow all outbound traffic"
  ip_protocol       = "-1"
  cidr_ipv4         = "0.0.0.0/0"

  tags = {
    Name = "${var.application_name}-${var.environment}-db-egress-all"
  }
}

output "alb_security_group_id" {
  description = "Security group ID for the ALB"
  value       = aws_security_group.web_alb.id
}

output "alb_security_group_arn" {
  description = "Security group ARN for the ALB"
  value       = aws_security_group.web_alb.arn
}

output "app_security_group_id" {
  description = "Security group ID for the application tier"
  value       = aws_security_group.web_app.id
}

output "app_security_group_arn" {
  description = "Security group ARN for the application tier"
  value       = aws_security_group.web_app.arn
}

output "database_security_group_id" {
  description = "Security group ID for the database tier"
  value       = aws_security_group.database.id
}

output "database_security_group_arn" {
  description = "Security group ARN for the database tier"
  value       = aws_security_group.database.arn
}

output "all_security_group_ids" {
  description = "Map of all security group IDs"
  value = {
    alb      = aws_security_group.web_alb.id
    app      = aws_security_group.web_app.id
    database = aws_security_group.database.id
  }
}