# --- Payment Processor Lambda ---

resource "aws_lambda_function" "payment_processor" {
  function_name    = "payment-processor-${var.environment}"
  description      = "Processes payment transactions with PCI-DSS compliant handling"
  role             = aws_iam_role.payment_processor.arn
  handler          = "handler.lambda_handler"
  runtime          = var.lambda_runtime
  timeout          = var.lambda_timeout
  memory_size      = var.lambda_memory_size
  filename         = data.archive_file.payment_processor.output_path
  source_code_hash = data.archive_file.payment_processor.output_base64sha256

  reserved_concurrent_executions = 100

  kms_key_arn = aws_kms_key.payment_processing.arn

  dead_letter_config {
    target_arn = aws_sqs_queue.payment_dlq.arn
  }

  vpc_config {
    subnet_ids         = var.private_subnet_ids
    security_group_ids = [aws_security_group.lambda_payment.id]
  }

  environment {
    variables = {
      ENVIRONMENT              = var.environment
      DYNAMODB_TABLE           = aws_dynamodb_table.payment_transactions.name
      KMS_KEY_ID               = aws_kms_key.payment_processing.id
      LOG_LEVEL                = "INFO"
      POWERTOOLS_SERVICE_NAME  = "payment-processor"
      ENABLE_SENSITIVE_MASKING = "true"
    }
  }

  tracing_config {
    mode = "Active"
  }

  depends_on = [
    aws_cloudwatch_log_group.payment_processor,
    aws_iam_role_policy.payment_processor_logs,
    aws_iam_role_policy.payment_processor_vpc,
  ]

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
    DataClass   = "financial-sensitive"
    PCI_DSS     = "true"
  }
}

