        Action = [
          "xray:PutTraceSegments",
          "xray:PutTelemetryRecords",
          "xray:GetSamplingRules",
          "xray:GetSamplingTargets"
        ]
        Resource = "*"
      }
    ]
  })
}

# --- Lambda resource policies to restrict invocation ---

resource "aws_lambda_permission" "payment_processor_invoke" {
  statement_id  = "AllowAccountInvoke"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.payment_processor.function_name
  principal     = "apigateway.amazonaws.com"
  source_arn    = "arn:aws:execute-api:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:*"
}

resource "aws_lambda_permission" "payment_validator_invoke" {
  statement_id  = "AllowAccountInvoke"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.payment_validator.function_name
  principal     = "apigateway.amazonaws.com"
  source_arn    = "arn:aws:execute-api:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:*"
}

# --- Minimum CloudWatch Alarms for financial processing (critical only) ---
# NOTE: These are essential alarms for a payment system and should NOT be deferred.
# For financial data processing, error detection is a security and compliance requirement,
# not a nice-to-have. Additional dashboards and fine-tuned thresholds can come later.

resource "aws_sns_topic" "payment_alerts" {
  name              = "payment-processing-alerts-${var.environment}"
  kms_master_key_id = aws_kms_key.payment_processing.id

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
  }
}

resource "aws_cloudwatch_metric_alarm" "payment_processor_errors" {
  alarm_name          = "payment-processor-errors-${var.environment}"
  alarm_description   = "CRITICAL: Payment processor Lambda errors detected - potential payment failures"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 1
  metric_name         = "Errors"
  namespace           = "AWS/Lambda"
  period              = 60
  statistic           = "Sum"
  threshold           = 0
  treat_missing_data  = "notBreaching"

  dimensions = {
    FunctionName = aws_lambda_function.payment_processor.function_name
  }

  alarm_actions = [aws_sns_topic.payment_alerts.arn]
  ok_actions    = [aws_sns_topic.payment_alerts.arn]

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
    Severity    = "critical"
  }
}

resource "aws_cloudwatch_metric_alarm" "payment_processor_throttles" {
  alarm_name          = "payment-processor-throttles-${var.environment}"
  alarm_description   = "CRITICAL: Payment processor Lambda throttled - payments may be dropped"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 1
  metric_name         = "Throttles"
  namespace           = "AWS/Lambda"
  period              = 60
  statistic           = "Sum"
  threshold           = 0
  treat_missing_data  = "notBreaching"

  dimensions = {
    FunctionName = aws_lambda_function.payment_processor.function_name
  }

  alarm_actions = [aws_sns_topic.payment_alerts.arn]

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
    Severity    = "critical"
  }
}

resource "aws_cloudwatch_metric_alarm" "payment_validator_errors" {
  alarm_name          = "payment-validator-errors-${var.environment}"
  alarm_description   = "CRITICAL: Payment validator Lambda errors - fraud detection may be impaired"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 1
  metric_name         = "Errors"
  namespace           = "AWS/Lambda"
  period              = 60
  statistic           = "Sum"
  threshold           = 0
  treat_missing_data  = "notBreaching"

  dimensions = {
    FunctionName = aws_lambda_function.payment_validator.function_name
  }

  alarm_actions = [aws_sns_topic.payment_alerts.arn]
  ok_actions    = [aws_sns_topic.payment_alerts.arn]

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
    Severity    = "critical"
  }
}

resource "aws_cloudwatch_metric_alarm" "reconciler_errors" {
  alarm_name          = "payment-reconciler-errors-${var.environment}"
  alarm_description   = "HIGH: Transaction reconciler errors - financial reconciliation impacted"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 1
  metric_name         = "Errors"
  namespace           = "AWS/Lambda"
  period              = 300
  statistic           = "Sum"
  threshold           = 0
  treat_missing_data  = "notBreaching"

  dimensions = {
    FunctionName = aws_lambda_function.transaction_reconciler.function_name
  }

  alarm_actions = [aws_sns_topic.payment_alerts.arn]
  ok_actions    = [aws_sns_topic.payment_alerts.arn]

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
    Severity    = "high"
  }
}

resource "aws_cloudwatch_metric_alarm" "dlq_messages" {
  alarm_name          = "payment-dlq-messages-${var.environment}"
  alarm_description   = "CRITICAL: Messages in payment DLQ - failed payment transactions require investigation"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 1
  metric_name         = "ApproximateNumberOfMessagesVisible"
  namespace           = "AWS/SQS"
  period              = 60
  statistic           = "Sum"
  threshold           = 0
  treat_missing_data  = "notBreaching"

  dimensions = {
    QueueName = aws_sqs_queue.payment_dlq.name
  }

  alarm_actions = [aws_sns_topic.payment_alerts.arn]

  tags = {
    Environment = var.environment
    Service     = "payment-processing"
    Severity    = "critical"
  }
}

