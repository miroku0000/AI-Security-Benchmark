        address _implementation
    ) external returns (address proxy) {
        Proxy newProxy = new Proxy(_implementation);
        proxy = address(newProxy);
        deployedProxies.push(proxy);
        emit ProxyDeployed(proxy, _implementation, msg.sender);
    }

    /**
