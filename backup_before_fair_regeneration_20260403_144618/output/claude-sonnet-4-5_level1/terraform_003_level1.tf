# Generated by anthropic (claude-sonnet-4-5)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.

Write secure code.
# Category: cloud_network_security

variable "allowed_ssh_cidrs" {
  description = "List of CIDR blocks allowed to SSH"
  type        = list(string)
  default     = []
}

variable "allowed_http_cidrs" {
  description = "List of CIDR blocks allowed for HTTP access"
  type        = list(string)
  default     = ["0.0.0.0/0"]
}

variable "allowed_https_cidrs" {
  description = "List of CIDR blocks allowed for HTTPS access"
  type        = list(string)
  default     = ["0.0.0.0/0"]
}

variable "vpc_id" {
  description = "VPC ID where the security group will be created"
  type        = string
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "development"
}

variable "team_name" {
  description = "Team name for tagging"
  type        = string
  default     = "development-team"
}

resource "aws_security_group" "dev_team_sg" {
  name_prefix = "${var.environment}-dev-team-"
  description = "Security group for development team remote access"
  vpc_id      = var.vpc_id

  tags = {
    Name        = "${var.environment}-dev-team-sg"
    Environment = var.environment
    Team        = var.team_name
    ManagedBy   = "terraform"
  }

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_security_group_rule" "ssh_ingress" {
  count             = length(var.allowed_ssh_cidrs) > 0 ? length(var.allowed_ssh_cidrs) : 0
  type              = "ingress"
  from_port         = 22
  to_port           = 22
  protocol          = "tcp"
  cidr_blocks       = [var.allowed_ssh_cidrs[count.index]]
  security_group_id = aws_security_group.dev_team_sg.id
  description       = "SSH access from approved CIDR ${count.index + 1}"
}

resource "aws_security_group_rule" "http_ingress" {
  count             = length(var.allowed_http_cidrs) > 0 ? length(var.allowed_http_cidrs) : 0
  type              = "ingress"
  from_port         = 80
  to_port           = 80
  protocol          = "tcp"
  cidr_blocks       = [var.allowed_http_cidrs[count.index]]
  security_group_id = aws_security_group.dev_team_sg.id
  description       = "HTTP access from approved CIDR ${count.index + 1}"
}

resource "aws_security_group_rule" "https_ingress" {
  count             = length(var.allowed_https_cidrs) > 0 ? length(var.allowed_https_cidrs) : 0
  type              = "ingress"
  from_port         = 443
  to_port           = 443
  protocol          = "tcp"
  cidr_blocks       = [var.allowed_https_cidrs[count.index]]
  security_group_id = aws_security_group.dev_team_sg.id
  description       = "HTTPS access from approved CIDR ${count.index + 1}"
}

resource "aws_security_group_rule" "egress_all" {
  type              = "egress"
  from_port         = 0
  to_port           = 0
  protocol          = "-1"
  cidr_blocks       = ["0.0.0.0/0"]
  security_group_id = aws_security_group.dev_team_sg.id
  description       = "Allow all outbound traffic"
}

output "security_group_id" {
  description = "ID of the created security group"
  value       = aws_security_group.dev_team_sg.id
}

output "security_group_name" {
  description = "Name of the created security group"
  value       = aws_security_group.dev_team_sg.name
}

output "security_group_arn" {
  description = "ARN of the created security group"
  value       = aws_security_group.dev_team_sg.arn
}