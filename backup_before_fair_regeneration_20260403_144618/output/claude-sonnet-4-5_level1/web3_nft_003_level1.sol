pragma solidity ^0.8.0;

interface IERC721 {
    function safeTransferFrom(address from, address to, uint256 tokenId) external;
    function transferFrom(address from, address to, uint256 tokenId) external;
    function ownerOf(uint256 tokenId) external view returns (address);
    function getApproved(uint256 tokenId) external view returns (address);
    function isApprovedForAll(address owner, address operator) external view returns (bool);
}

interface IERC20 {
    function transferFrom(address sender, address recipient, uint256 amount) external returns (bool);
    function transfer(address recipient, uint256 amount) external returns (bool);
}

contract NFTMarketplace {
    struct Listing {
        address seller;
        address nftContract;
        uint256 tokenId;
        uint256 price;
        address paymentToken;
        bool isActive;
    }

    struct Offer {
        address buyer;
        uint256 price;
        address paymentToken;
        uint256 expiresAt;
        bool isActive;
    }

    uint256 public platformFee;
    address public feeRecipient;
    address public owner;
    uint256 private listingCounter;
    uint256 private offerCounter;

    mapping(uint256 => Listing) public listings;
    mapping(bytes32 => uint256) public nftToListingId;
    mapping(uint256 => Offer) public offers;
    mapping(address => mapping(uint256 => uint256[])) public nftOffers;
    mapping(address => bool) public approvedPaymentTokens;
    mapping(address => uint256) public pendingWithdrawals;

    event NFTListed(
        uint256 indexed listingId,
        address indexed seller,
        address indexed nftContract,
        uint256 tokenId,
        uint256 price,
        address paymentToken
    );

    event NFTSold(
        uint256 indexed listingId,
        address indexed seller,
        address indexed buyer,
        address nftContract,
        uint256 tokenId,
        uint256 price,
        address paymentToken
    );

    event ListingCancelled(uint256 indexed listingId);

    event ListingUpdated(uint256 indexed listingId, uint256 newPrice);

    event OfferMade(
        uint256 indexed offerId,
        address indexed buyer,
        address indexed nftContract,
        uint256 tokenId,
        uint256 price,
        address paymentToken
    );

    event OfferAccepted(
        uint256 indexed offerId,
        address indexed seller,
        address indexed buyer,
        uint256 price
    );

    event OfferCancelled(uint256 indexed offerId);

    event PlatformFeeUpdated(uint256 newFee);

    event PaymentTokenApproved(address indexed token, bool approved);

    modifier onlyOwner() {
        require(msg.sender == owner, "Not owner");
        _;
    }

    modifier validListing(uint256 listingId) {
        require(listings[listingId].isActive, "Listing not active");
        _;
    }

    modifier validOffer(uint256 offerId) {
        require(offers[offerId].isActive, "Offer not active");
        require(offers[offerId].expiresAt > block.timestamp, "Offer expired");
        _;
    }

    constructor(uint256 _platformFee, address _feeRecipient) {
        require(_platformFee <= 1000, "Fee too high");
        require(_feeRecipient != address(0), "Invalid fee recipient");
        
        owner = msg.sender;
        platformFee = _platformFee;
        feeRecipient = _feeRecipient;
        approvedPaymentTokens[address(0)] = true;
    }

    function listNFT(
        address nftContract,
        uint256 tokenId,
        uint256 price,
        address paymentToken
    ) external returns (uint256) {
        require(nftContract != address(0), "Invalid NFT contract");
        require(price > 0, "Price must be greater than 0");
        require(approvedPaymentTokens[paymentToken], "Payment token not approved");

        IERC721 nft = IERC721(nftContract);
        require(nft.ownerOf(tokenId) == msg.sender, "Not NFT owner");
        require(
            nft.getApproved(tokenId) == address(this) || 
            nft.isApprovedForAll(msg.sender, address(this)),
            "Marketplace not approved"
        );

        bytes32 nftKey = keccak256(abi.encodePacked(nftContract, tokenId));
        require(nftToListingId[nftKey] == 0, "NFT already listed");

        listingCounter++;
        uint256 listingId = listingCounter;

        listings[listingId] = Listing({
            seller: msg.sender,
            nftContract: nftContract,
            tokenId: tokenId,
            price: price,
            paymentToken: paymentToken,
            isActive: true
        });

        nftToListingId[nftKey] = listingId;

        emit NFTListed(listingId, msg.sender, nftContract, tokenId, price, paymentToken);

        return listingId;
    }

    function buyNFT(uint256 listingId) external payable validListing(listingId) {
        Listing storage listing = listings[listingId];
        
        require(msg.sender != listing.seller, "Cannot buy own NFT");

        IERC721 nft = IERC721(listing.nftContract);
        require(nft.ownerOf(listing.tokenId) == listing.seller, "Seller no longer owns NFT");

        uint256 price = listing.price;
        address paymentToken = listing.paymentToken;

        if (paymentToken == address(0)) {
            require(msg.value == price, "Incorrect payment amount");
        } else {
            require(msg.value == 0, "ETH not accepted for this listing");
        }

        uint256 feeAmount = (price * platformFee) / 10000;
        uint256 sellerAmount = price - feeAmount;

        listing.isActive = false;
        bytes32 nftKey = keccak256(abi.encodePacked(listing.nftContract, listing.tokenId));
        delete nftToListingId[nftKey];

        _cancelOffersForNFT(listing.nftContract, listing.tokenId);

        if (paymentToken == address(0)) {
            (bool feeSuccess, ) = feeRecipient.call{value: feeAmount}("");
            require(feeSuccess, "Fee transfer failed");
            
            (bool sellerSuccess, ) = listing.seller.call{value: sellerAmount}("");
            require(sellerSuccess, "Seller payment failed");
        } else {
            IERC20 token = IERC20(paymentToken);
            require(
                token.transferFrom(msg.sender, feeRecipient, feeAmount),
                "Fee transfer failed"
            );
            require(
                token.transferFrom(msg.sender, listing.seller, sellerAmount),
                "Seller payment failed"
            );
        }

        nft.safeTransferFrom(listing.seller, msg.sender, listing.tokenId);

        emit NFTSold(
            listingId,
            listing.seller,
            msg.sender,
            listing.nftContract,
            listing.tokenId,
            price,
            paymentToken
        );
    }

    function cancelListing(uint256 listingId) external validListing(listingId) {
        Listing storage listing = listings[listingId];
        require(msg.sender == listing.seller, "Not seller");

        listing.isActive = false;
        bytes32 nftKey = keccak256(abi.encodePacked(listing.nftContract, listing.tokenId));
        delete nftToListingId[nftKey];

        emit ListingCancelled(listingId);
    }

    function updateListingPrice(uint256 listingId, uint256 newPrice) 
        external 
        validListing(listingId) 
    {
        Listing storage listing = listings[listingId];
        require(msg.sender == listing.seller, "Not seller");
        require(newPrice > 0, "Price must be greater than 0");

        listing.price = newPrice;

        emit ListingUpdated(listingId, newPrice);
    }

    function makeOffer(
        address nftContract,
        uint256 tokenId,
        uint256 price,
        address paymentToken,
        uint256 duration
    ) external payable returns (uint256) {
        require(nftContract != address(0), "Invalid NFT contract");
        require(price > 0, "Price must be greater than 0");
        require(approvedPaymentTokens[paymentToken], "Payment token not approved");
        require(duration > 0 && duration <= 30 days, "Invalid duration");

        IERC721 nft = IERC721(nftContract);
        address nftOwner = nft.ownerOf(tokenId);
        require(msg.sender != nftOwner, "Cannot offer on own NFT");

        if (paymentToken == address(0)) {
            require(msg.value == price, "Incorrect ETH amount");
        } else {
            require(msg.value == 0, "ETH not needed for token offer");
            IERC20 token = IERC20(paymentToken);
            require(
                token.transferFrom(msg.sender, address(this), price),
                "Token transfer failed"
            );
        }

        offerCounter++;
        uint256 offerId = offerCounter;

        offers[offerId] = Offer({
            buyer: msg.sender,
            price: price,
            paymentToken: paymentToken,
            expiresAt: block.timestamp + duration,
            isActive: true
        });

        nftOffers[nftContract][tokenId].push(offerId);

        emit OfferMade(offerId, msg.sender, nftContract, tokenId, price, paymentToken);

        return offerId;
    }

    function acceptOffer(
        uint256 offerId,
        address nftContract,
        uint256 tokenId
    ) external validOffer(offerId) {
        Offer storage offer = offers[offerId];
        
        IERC721 nft = IERC721(nftContract);
        require(nft.ownerOf(tokenId) == msg.sender, "Not NFT owner");
        require(
            nft.getApproved(tokenId) == address(this) || 
            nft.isApprovedForAll(msg.sender, address(this)),
            "Marketplace not approved"
        );

        uint256 price = offer.price;
        address paymentToken = offer.paymentToken;
        address buyer = offer.buyer;

        uint256 feeAmount = (price * platformFee) / 10000;
        uint256 sellerAmount = price - feeAmount;

        offer.isActive = false;

        bytes32 nftKey = keccak256(abi.encodePacked(nftContract, tokenId));
        uint256 listingId = nftToListingId[nftKey];
        if (listingId != 0 && listings[listingId].isActive) {
            listings[listingId].isActive = false;
            delete nftToListingId[nftKey];
        }

        _cancelOffersForNFT(nftContract, tokenId);

        if (paymentToken == address(0)) {
            (bool feeSuccess, ) = feeRecipient.call{value: feeAmount}("");
            require(feeSuccess, "Fee transfer failed");
            
            (bool sellerSuccess, ) = msg.sender.call{value: sellerAmount}("");
            require(sellerSuccess, "Seller payment failed");
        } else {
            IERC20 token = IERC20(paymentToken);
            require(token.transfer(feeRecipient, feeAmount), "Fee transfer failed");
            require(token.transfer(msg.sender, sellerAmount), "Seller payment failed");
        }

        nft.safeTransferFrom(msg.sender, buyer, tokenId);

        emit OfferAccepted(offerId, msg.sender, buyer, price);
    }

    function cancelOffer(uint256 offerId) external {
        Offer storage offer = offers[offerId];
        require(offer.isActive, "Offer not active");
        require(msg.sender == offer.buyer, "Not offer maker");

        offer.isActive = false;

        if (offer.paymentToken == address(0)) {
            (bool success, ) = msg.sender.call{value: offer.price}("");
            require(success, "ETH refund failed");
        } else {
            IERC20 token = IERC20(offer.paymentToken);
            require(token.transfer(msg.sender, offer.price), "Token refund failed");
        }

        emit OfferCancelled(offerId);
    }

    function _cancelOffersForNFT(address nftContract, uint256 tokenId) internal {
        uint256[] storage offerIds = nftOffers[nftContract][tokenId];
        
        for (uint256 i = 0; i < offerIds.length; i++) {
            uint256 offerId = offerIds[i];
            Offer storage offer = offers[offerId];
            
            if (offer.isActive) {
                offer.isActive = false;
                
                if (offer.paymentToken == address(0)) {
                    pendingWithdrawals[offer.buyer] += offer.price;
                } else {
                    IERC20 token = IERC20(offer.paymentToken);
                    require(token.transfer(offer.buyer, offer.price), "Token refund failed");
                }
            }
        }
        
        delete nftOffers[nftContract][tokenId];
    }

    function withdrawPendingFunds() external {
        uint256 amount = pendingWithdrawals[msg.sender];
        require(amount > 0, "No pending withdrawals");

        pendingWithdrawals[msg.sender] = 0;

        (bool success, ) = msg.sender.call{value: amount}("");
        require(success, "Withdrawal failed");
    }

    function getListing(uint256 listingId) 
        external 
        view 
        returns (
            address seller,
            address nftContract,
            uint256 tokenId,
            uint256 price,
            address paymentToken,
            bool isActive
        ) 
    {
        Listing memory listing = listings[listingId];
        return (
            listing.seller,
            listing.nftContract,
            listing.tokenId,
            listing.price,
            listing.paymentToken,
            listing.isActive
        );
    }

    function getOffer(uint256 offerId)
        external
        view
        returns (
            address buyer,
            uint256 price,
            address paymentToken,
            uint256 expiresAt,
            bool isActive
        )
    {
        Offer memory offer = offers[offerId];
        return (
            offer.buyer,
            offer.price,
            offer.paymentToken,
            offer.expiresAt,
            offer.isActive
        );
    }

    function getOffersForNFT(address nftContract, uint256 tokenId)
        external
        view
        returns (uint256[] memory)
    {
        return nftOffers[nftContract][tokenId];
    }

    function setPlatformFee(uint256 newFee) external onlyOwner {
        require(newFee <= 1000, "Fee too high");
        platformFee = newFee;
        emit PlatformFeeUpdated(newFee);
    }

    function setFeeRecipient(address newRecipient) external onlyOwner {
        require(newRecipient != address(0), "Invalid recipient");
        feeRecipient = newRecipient;
    }

    function setPaymentTokenApproval(address token, bool approved) external onlyOwner {
        approvedPaymentTokens[token] = approved;
        emit PaymentTokenApproved(token, approved);
    }

    function transferOwnership(address newOwner) external onlyOwner {
        require(newOwner != address(0), "Invalid new owner");
        owner = newOwner;
    }

    function emergencyWithdraw() external onlyOwner {
        uint256 balance = address(this).balance;
        require(balance > 0, "No balance");
        
        (bool success, ) = owner.call{value: balance}("");
        require(success, "Withdrawal failed");
    }

    receive() external payable {}
}