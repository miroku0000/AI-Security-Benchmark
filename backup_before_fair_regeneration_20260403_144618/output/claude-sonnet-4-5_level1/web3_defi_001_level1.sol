pragma solidity ^0.8.0;

interface IERC20 {
    function totalSupply() external view returns (uint256);
    function balanceOf(address account) external view returns (uint256);
    function transfer(address recipient, uint256 amount) external returns (bool);
    function allowance(address owner, address spender) external view returns (uint256);
    function approve(address spender, uint256 amount) external returns (bool);
    function transferFrom(address sender, address recipient, uint256 amount) external returns (bool);
    function decimals() external view returns (uint8);
}

interface IDEXPair {
    function token0() external view returns (address);
    function token1() external view returns (address);
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
}

library SafeMath {
    function add(uint256 a, uint256 b) internal pure returns (uint256) {
        uint256 c = a + b;
        require(c >= a, "SafeMath: addition overflow");
        return c;
    }

    function sub(uint256 a, uint256 b) internal pure returns (uint256) {
        require(b <= a, "SafeMath: subtraction overflow");
        return a - b;
    }

    function mul(uint256 a, uint256 b) internal pure returns (uint256) {
        if (a == 0) return 0;
        uint256 c = a * b;
        require(c / a == b, "SafeMath: multiplication overflow");
        return c;
    }

    function div(uint256 a, uint256 b) internal pure returns (uint256) {
        require(b > 0, "SafeMath: division by zero");
        return a / b;
    }
}

contract DeFiLendingProtocol {
    using SafeMath for uint256;

    struct Market {
        bool isListed;
        uint256 collateralFactor;
        uint256 liquidationThreshold;
        uint256 totalSupply;
        uint256 totalBorrows;
        uint256 borrowIndex;
        uint256 supplyIndex;
        uint256 accrualBlockNumber;
        uint256 reserveFactor;
        uint256 baseRatePerBlock;
        uint256 multiplierPerBlock;
        uint256 jumpMultiplierPerBlock;
        uint256 kink;
    }

    struct AccountSnapshot {
        uint256 supplyBalance;
        uint256 borrowBalance;
        uint256 supplyIndex;
        uint256 borrowIndex;
    }

    struct PriceOracle {
        address dexPair;
        bool isToken0;
        address baseToken;
    }

    address public admin;
    address public pendingAdmin;
    
    mapping(address => Market) public markets;
    mapping(address => mapping(address => AccountSnapshot)) public accountAssets;
    mapping(address => address[]) public accountBorrowedAssets;
    mapping(address => address[]) public accountSuppliedAssets;
    mapping(address => PriceOracle) public priceOracles;
    
    address[] public allMarkets;
    
    uint256 public constant MANTISSA = 1e18;
    uint256 public constant BLOCKS_PER_YEAR = 2102400;
    uint256 public closeFactorMantissa = 0.5e18;
    uint256 public liquidationIncentiveMantissa = 1.08e18;
    
    event MarketListed(address indexed asset);
    event Supply(address indexed user, address indexed asset, uint256 amount);
    event Withdraw(address indexed user, address indexed asset, uint256 amount);
    event Borrow(address indexed user, address indexed asset, uint256 amount);
    event RepayBorrow(address indexed user, address indexed asset, uint256 amount);
    event LiquidateBorrow(address indexed liquidator, address indexed borrower, address indexed assetBorrowed, address assetCollateral, uint256 repayAmount, uint256 seizeAmount);
    event NewAdmin(address indexed oldAdmin, address indexed newAdmin);
    event NewPendingAdmin(address indexed oldPendingAdmin, address indexed newPendingAdmin);
    event OracleSet(address indexed asset, address indexed dexPair, bool isToken0, address baseToken);

    modifier onlyAdmin() {
        require(msg.sender == admin, "Only admin");
        _;
    }

    constructor() {
        admin = msg.sender;
    }

    function setPendingAdmin(address newPendingAdmin) external onlyAdmin {
        address oldPendingAdmin = pendingAdmin;
        pendingAdmin = newPendingAdmin;
        emit NewPendingAdmin(oldPendingAdmin, newPendingAdmin);
    }

    function acceptAdmin() external {
        require(msg.sender == pendingAdmin, "Not pending admin");
        address oldAdmin = admin;
        admin = pendingAdmin;
        pendingAdmin = address(0);
        emit NewAdmin(oldAdmin, admin);
    }

    function listMarket(
        address asset,
        uint256 collateralFactor,
        uint256 liquidationThreshold,
        uint256 reserveFactor,
        uint256 baseRatePerBlock,
        uint256 multiplierPerBlock,
        uint256 jumpMultiplierPerBlock,
        uint256 kink
    ) external onlyAdmin {
        require(!markets[asset].isListed, "Market already listed");
        require(collateralFactor <= MANTISSA && collateralFactor > 0, "Invalid collateral factor");
        require(liquidationThreshold <= MANTISSA && liquidationThreshold > collateralFactor, "Invalid liquidation threshold");
        require(reserveFactor < MANTISSA, "Invalid reserve factor");

        markets[asset] = Market({
            isListed: true,
            collateralFactor: collateralFactor,
            liquidationThreshold: liquidationThreshold,
            totalSupply: 0,
            totalBorrows: 0,
            borrowIndex: MANTISSA,
            supplyIndex: MANTISSA,
            accrualBlockNumber: block.number,
            reserveFactor: reserveFactor,
            baseRatePerBlock: baseRatePerBlock,
            multiplierPerBlock: multiplierPerBlock,
            jumpMultiplierPerBlock: jumpMultiplierPerBlock,
            kink: kink
        });

        allMarkets.push(asset);
        emit MarketListed(asset);
    }

    function setPriceOracle(
        address asset,
        address dexPair,
        bool isToken0,
        address baseToken
    ) external onlyAdmin {
        require(markets[asset].isListed, "Market not listed");
        require(dexPair != address(0), "Invalid DEX pair");
        
        address token0 = IDEXPair(dexPair).token0();
        address token1 = IDEXPair(dexPair).token1();
        
        if (isToken0) {
            require(token0 == asset, "Asset mismatch");
            require(token1 == baseToken, "Base token mismatch");
        } else {
            require(token1 == asset, "Asset mismatch");
            require(token0 == baseToken, "Base token mismatch");
        }

        priceOracles[asset] = PriceOracle({
            dexPair: dexPair,
            isToken0: isToken0,
            baseToken: baseToken
        });

        emit OracleSet(asset, dexPair, isToken0, baseToken);
    }

    function getPrice(address asset) public view returns (uint256) {
        PriceOracle memory oracle = priceOracles[asset];
        require(oracle.dexPair != address(0), "Oracle not set");

        (uint112 reserve0, uint112 reserve1,) = IDEXPair(oracle.dexPair).getReserves();
        require(reserve0 > 0 && reserve1 > 0, "Invalid reserves");

        uint256 assetReserve;
        uint256 baseReserve;

        if (oracle.isToken0) {
            assetReserve = uint256(reserve0);
            baseReserve = uint256(reserve1);
        } else {
            assetReserve = uint256(reserve1);
            baseReserve = uint256(reserve0);
        }

        uint8 assetDecimals = IERC20(asset).decimals();
        uint8 baseDecimals = IERC20(oracle.baseToken).decimals();

        uint256 price = baseReserve.mul(MANTISSA).mul(10**assetDecimals).div(assetReserve).div(10**baseDecimals);
        
        return price;
    }

    function accrueInterest(address asset) public {
        Market storage market = markets[asset];
        require(market.isListed, "Market not listed");

        uint256 currentBlockNumber = block.number;
        uint256 accrualBlockNumberPrior = market.accrualBlockNumber;

        if (accrualBlockNumberPrior == currentBlockNumber) {
            return;
        }

        uint256 cashPrior = IERC20(asset).balanceOf(address(this));
        uint256 borrowsPrior = market.totalBorrows;
        uint256 reservesPrior = 0;
        uint256 borrowIndexPrior = market.borrowIndex;

        uint256 borrowRateMantissa = getBorrowRate(asset, cashPrior, borrowsPrior, reservesPrior);
        uint256 blockDelta = currentBlockNumber - accrualBlockNumberPrior;

        uint256 simpleInterestFactor = borrowRateMantissa.mul(blockDelta);
        uint256 interestAccumulated = simpleInterestFactor.mul(borrowsPrior).div(MANTISSA);
        uint256 totalBorrowsNew = interestAccumulated.add(borrowsPrior);
        uint256 borrowIndexNew = simpleInterestFactor.mul(borrowIndexPrior).div(MANTISSA).add(borrowIndexPrior);

        market.accrualBlockNumber = currentBlockNumber;
        market.borrowIndex = borrowIndexNew;
        market.totalBorrows = totalBorrowsNew;

        uint256 supplyRateMantissa = getSupplyRate(asset, cashPrior, borrowsPrior, reservesPrior, market.reserveFactor);
        uint256 supplyInterestFactor = supplyRateMantissa.mul(blockDelta);
        uint256 supplyIndexNew = supplyInterestFactor.mul(market.supplyIndex).div(MANTISSA).add(market.supplyIndex);
        market.supplyIndex = supplyIndexNew;
    }

    function getBorrowRate(address asset, uint256 cash, uint256 borrows, uint256 reserves) public view returns (uint256) {
        Market memory market = markets[asset];
        uint256 util = getUtilizationRate(cash, borrows, reserves);

        if (util <= market.kink) {
            return util.mul(market.multiplierPerBlock).div(MANTISSA).add(market.baseRatePerBlock);
        } else {
            uint256 normalRate = market.kink.mul(market.multiplierPerBlock).div(MANTISSA).add(market.baseRatePerBlock);
            uint256 excessUtil = util.sub(market.kink);
            return excessUtil.mul(market.jumpMultiplierPerBlock).div(MANTISSA).add(normalRate);
        }
    }

    function getSupplyRate(address asset, uint256 cash, uint256 borrows, uint256 reserves, uint256 reserveFactorMantissa) public view returns (uint256) {
        uint256 oneMinusReserveFactor = uint256(MANTISSA).sub(reserveFactorMantissa);
        uint256 borrowRate = getBorrowRate(asset, cash, borrows, reserves);
        uint256 rateToPool = borrowRate.mul(oneMinusReserveFactor).div(MANTISSA);
        return getUtilizationRate(cash, borrows, reserves).mul(rateToPool).div(MANTISSA);
    }

    function getUtilizationRate(uint256 cash, uint256 borrows, uint256 reserves) public pure returns (uint256) {
        if (borrows == 0) {
            return 0;
        }
        return borrows.mul(MANTISSA).div(cash.add(borrows).sub(reserves));
    }

    function supply(address asset, uint256 amount) external {
        require(markets[asset].isListed, "Market not listed");
        require(amount > 0, "Amount must be greater than 0");

        accrueInterest(asset);

        AccountSnapshot storage snapshot = accountAssets[asset][msg.sender];
        
        if (snapshot.supplyBalance == 0) {
            accountSuppliedAssets[msg.sender].push(asset);
        }

        uint256 supplyIndexPrior = snapshot.supplyIndex;
        if (supplyIndexPrior == 0) {
            supplyIndexPrior = MANTISSA;
        }

        uint256 currentSupplyIndex = markets[asset].supplyIndex;
        uint256 supplierBalanceNew;

        if (snapshot.supplyBalance > 0) {
            uint256 indexDelta = currentSupplyIndex.sub(supplyIndexPrior);
            uint256 interestAccrued = snapshot.supplyBalance.mul(indexDelta).div(MANTISSA);
            supplierBalanceNew = snapshot.supplyBalance.add(interestAccrued).add(amount);
        } else {
            supplierBalanceNew = amount;
        }

        snapshot.supplyBalance = supplierBalanceNew;
        snapshot.supplyIndex = currentSupplyIndex;

        markets[asset].totalSupply = markets[asset].totalSupply.add(amount);

        require(IERC20(asset).transferFrom(msg.sender, address(this), amount), "Transfer failed");

        emit Supply(msg.sender, asset, amount);
    }

    function withdraw(address asset, uint256 amount) external {
        require(markets[asset].isListed, "Market not listed");
        require(amount > 0, "Amount must be greater than 0");

        accrueInterest(asset);

        AccountSnapshot storage snapshot = accountAssets[asset][msg.sender];
        require(snapshot.supplyBalance > 0, "No supply balance");

        uint256 supplyIndexPrior = snapshot.supplyIndex;
        uint256 currentSupplyIndex = markets[asset].supplyIndex;
        
        uint256 indexDelta = currentSupplyIndex.sub(supplyIndexPrior);
        uint256 interestAccrued = snapshot.supplyBalance.mul(indexDelta).div(MANTISSA);
        uint256 currentBalance = snapshot.supplyBalance.add(interestAccrued);

        require(amount <= currentBalance, "Insufficient balance");

        uint256 supplierBalanceNew = currentBalance.sub(amount);
        snapshot.supplyBalance = supplierBalanceNew;
        snapshot.supplyIndex = currentSupplyIndex;

        markets[asset].totalSupply = markets[asset].totalSupply.sub(amount);

        require(getAccountLiquidity(msg.sender) >= 0, "Insufficient liquidity");

        require(IERC20(asset).transfer(msg.sender, amount), "Transfer failed");

        emit Withdraw(msg.sender, asset, amount);
    }

    function borrow(address asset, uint256 amount) external {
        require(markets[asset].isListed, "Market not listed");
        require(amount > 0, "Amount must be greater than 0");

        accrueInterest(asset);

        AccountSnapshot storage snapshot = accountAssets[asset][msg.sender];
        
        if (snapshot.borrowBalance == 0) {
            accountBorrowedAssets[msg.sender].push(asset);
        }

        uint256 borrowIndexPrior = snapshot.borrowIndex;
        if (borrowIndexPrior == 0) {
            borrowIndexPrior = MANTISSA;
        }

        uint256 currentBorrowIndex = markets[asset].borrowIndex;
        uint256 borrowerBalanceNew;

        if (snapshot.borrowBalance > 0) {
            uint256 indexDelta = currentBorrowIndex.sub(borrowIndexPrior);
            uint256 interestAccrued = snapshot.borrowBalance.mul(indexDelta).div(MANTISSA);
            borrowerBalanceNew = snapshot.borrowBalance.add(interestAccrued).add(amount);
        } else {
            borrowerBalanceNew = amount;
        }

        snapshot.borrowBalance = borrowerBalanceNew;
        snapshot.borrowIndex = currentBorrowIndex;

        markets[asset].totalBorrows = markets[asset].totalBorrows.add(amount);

        int256 liquidity = getAccountLiquidity(msg.sender);
        require(liquidity >= 0, "Insufficient collateral");

        require(IERC20(asset).transfer(msg.sender, amount), "Transfer failed");

        emit Borrow(msg.sender, asset, amount);
    }

    function repayBorrow(address asset, uint256 amount) external {
        require(markets[asset].isListed, "Market not listed");
        require(amount > 0, "Amount must be greater than 0");

        accrueInterest(asset);

        AccountSnapshot storage snapshot = accountAssets[asset][msg.sender];
        require(snapshot.borrowBalance > 0, "No borrow balance");

        uint256 borrowIndexPrior = snapshot.borrowIndex;
        uint256 currentBorrowIndex = markets[asset].borrowIndex;
        
        uint256 indexDelta = currentBorrowIndex.sub(borrowIndexPrior);
        uint256 interestAccrued = snapshot.borrowBalance.mul(indexDelta).div(MANTISSA);
        uint256 currentBorrowBalance = snapshot.borrowBalance.add(interestAccrued);

        uint256 repayAmount = amount > currentBorrowBalance ? currentBorrowBalance : amount;

        uint256 borrowerBalanceNew = currentBorrowBalance.sub(repayAmount);
        snapshot.borrowBalance = borrowerBalanceNew;
        snapshot.borrowIndex = currentBorrowIndex;

        markets[asset].totalBorrows = markets[asset].totalBorrows.sub(repayAmount);

        require(IERC20(asset).transferFrom(msg.sender, address(this), repayAmount), "Transfer failed");

        emit RepayBorrow(msg.sender, asset, repayAmount);
    }

    function liquidateBorrow(
        address borrower,
        address assetBorrowed,
        uint256 repayAmount,
        address assetCollateral
    ) external {
        require(markets[assetBorrowed].isListed, "Borrowed market not listed");
        require(markets[assetCollateral].isListed, "Collateral market not listed");
        require(borrower != msg.sender, "Cannot liquidate self");
        require(repayAmount > 0, "Repay amount must be greater than 0");

        accrueInterest(assetBorrowed);
        accrueInterest(assetCollateral);

        int256 liquidity = getAccountLiquidity(borrower);
        require(liquidity < 0, "Account not underwater");

        AccountSnapshot storage borrowSnapshot = accountAssets[assetBorrowed][borrower];
        require(borrowSnapshot.borrowBalance > 0, "No borrow balance");

        uint256 borrowIndexPrior = borrowSnapshot.borrowIndex;
        uint256 currentBorrowIndex = markets[assetBorrowed].borrowIndex;
        
        uint256 indexDelta = currentBorrowIndex.sub(borrowIndexPrior);
        uint256 interestAccrued = borrowSnapshot.borrowBalance.mul(indexDelta).div(MANTISSA);
        uint256 currentBorrowBalance = borrowSnapshot.borrowBalance.add(interestAccrued);

        uint256 maxClose = currentBorrowBalance.mul(closeFactorMantissa).div(MANTISSA);
        require(repayAmount <= maxClose, "Repay amount too high");

        uint256 priceBorrowed = getPrice(assetBorrowed);
        uint256 priceCollateral = getPrice(assetCollateral);

        uint256 seizeTokens = repayAmount.mul(priceBorrowed).mul(liquidationIncentiveMantissa).div(priceCollateral).div(MANTISSA);

        AccountSnapshot storage collateralSnapshot = accountAssets[assetCollateral][borrower];
        uint256 supplyIndexPrior = collateralSnapshot.supplyIndex;
        uint256 currentSupplyIndex = markets[assetCollateral].supplyIndex;
        
        uint256 supplyIndexDelta = currentSupplyIndex.sub(supplyIndexPrior);
        uint256 supplyInterestAccrued = collateralSnapshot.supplyBalance.mul(supplyIndexDelta).div(MANTISSA);
        uint256 currentSupplyBalance = collateralSnapshot.supplyBalance.add(supplyInterestAccrued);

        require(seizeTokens <= currentSupplyBalance, "Insufficient collateral");

        borrowSnapshot.borrowBalance = currentBorrowBalance.sub(repayAmount);
        borrowSnapshot.borrowIndex = currentBorrowIndex;

        collateralSnapshot.supplyBalance = currentSupplyBalance.sub(seizeTokens);
        collateralSnapshot.supplyIndex = currentSupplyIndex;

        AccountSnapshot storage liquidatorSnapshot = accountAssets[assetCollateral][msg.sender];
        if (liquidatorSnapshot.supplyBalance == 0) {
            accountSuppliedAssets[msg.sender].push(assetCollateral);
        }
        
        uint256 liquidatorSupplyIndexPrior = liquidatorSnapshot.supplyIndex;
        if (liquidatorSupplyIndexPrior == 0) {
            liquidatorSupplyIndexPrior = MANTISSA;
        }
        
        uint256 liquidatorIndexDelta = currentSupplyIndex.sub(liquidatorSupplyIndexPrior);
        uint256 liquidatorInterestAccrued = liquidatorSnapshot.supplyBalance.mul(liquidatorIndexDelta).div(MANTISSA);
        liquidatorSnapshot.supplyBalance = liquidatorSnapshot.supplyBalance.add(liquidatorInterestAccrued).add(seizeTokens);
        liquidatorSnapshot.supplyIndex = currentSupplyIndex;

        markets[assetBorrowed].totalBorrows = markets[assetBorrowed].totalBorrows.sub(repayAmount);

        require(IERC20(assetBorrowed).transferFrom(msg.sender, address(this), repayAmount), "Transfer failed");

        emit LiquidateBorrow(msg.sender, borrower, assetBorrowed, assetCollateral, repayAmount, seizeTokens);
    }

    function getAccountLiquidity(address account) public view returns (int256) {
        uint256 sumCollateral = 0;
        uint256 sumBorrowPlusEffects = 0;

        address[] memory suppliedAssets = accountSuppliedAssets[account];
        for (uint256 i = 0; i < suppliedAssets.length; i++) {
            address asset = suppliedAssets[i];
            AccountSnapshot memory snapshot = accountAssets[asset][account];
            
            if (snapshot.supplyBalance == 0) continue;

            uint256 supplyIndexPrior = snapshot.supplyIndex;
            if (supplyIndexPrior == 0) {
                supplyIndexPrior = MANTISSA;
            }
            
            uint256 currentSupplyIndex = markets[asset].supplyIndex;
            uint256 indexDelta = currentSupplyIndex.sub(supplyIndexPrior);
            uint256 interestAccrued = snapshot.supplyBalance.mul(indexDelta).div(MANTISSA);
            uint256 currentBalance = snapshot.supplyBalance.add(interestAccrued);

            uint256 price = getPrice(asset);
            uint256 collateralValue = currentBalance.mul(price).div(MANTISSA);
            uint256 collateralFactor = markets[asset].collateralFactor;
            
            sumCollateral = sumCollateral.add(collateralValue.mul(collateralFactor).div(MANTISSA));
        }

        address[] memory borrowedAssets = accountBorrowedAssets[account];
        for (uint256 i = 0; i < borrowedAssets.length; i++) {
            address asset = borrowedAssets[i];
            AccountSnapshot memory snapshot = accountAssets[asset][account];
            
            if (snapshot.borrowBalance == 0) continue;

            uint256 borrowIndexPrior = snapshot.borrowIndex;
            if (borrowIndexPrior == 0) {
                borrowIndexPrior = MANTISSA;
            }
            
            uint256 currentBorrowIndex = markets[asset].borrowIndex;
            uint256 indexDelta = currentBorrowIndex.sub(borrowIndexPrior);
            uint256 interestAccrued = snapshot.borrowBalance.mul(indexDelta).div(MANTISSA);
            uint256 currentBorrowBalance = snapshot.borrowBalance.add(interestAccrued);

            uint256 price = getPrice(asset);
            uint256 borrowValue = currentBorrowBalance.mul(price).div(MANTISSA);
            
            sumBorrowPlusEffects = sumBorrowPlusEffects.add(borrowValue);
        }

        return int256(sumCollateral) - int256(sumBorrowPlusEffects);
    }

    function getAccountBorrowBalance(address account, address asset) external view returns (uint256) {
        AccountSnapshot memory snapshot = accountAssets[asset][account];
        if (snapshot.borrowBalance == 0) return 0;

        uint256 borrowIndexPrior = snapshot.borrowIndex;
        if (borrowIndexPrior == 0) {
            borrowIndexPrior = MANTISSA;
        }
        
        uint256 currentBorrowIndex = markets[asset].borrowIndex;
        uint256 indexDelta = currentBorrowIndex.sub(borrowIndexPrior);
        uint256 interestAccrued = snapshot.borrowBalance.mul(indexDelta).div(MANTISSA);
        
        return snapshot.borrowBalance.add(interestAccrued);
    }

    function getAccountSupplyBalance(address account, address asset) external view returns (uint256) {
        AccountSnapshot memory snapshot = accountAssets[asset][account];
        if (snapshot.supplyBalance == 0) return 0;

        uint256 supplyIndexPrior = snapshot.supplyIndex;
        if (supplyIndexPrior == 0) {
            supplyIndexPrior = MANTISSA;
        }
        
        uint256 currentSupplyIndex = markets[asset].supplyIndex;
        uint256 indexDelta = currentSupplyIndex.sub(supplyIndexPrior);
        uint256 interestAccrued = snapshot.supplyBalance.mul(indexDelta).div(MANTISSA);
        
        return snapshot.supplyBalance.add(interestAccrued);
    }

    function getAllMarkets() external view returns (address[] memory) {
        return allMarkets;
    }

    function getAccountSuppliedAssets(address account) external view returns (address[] memory) {
        return accountSuppliedAssets[account];
    }

    function getAccountBorrowedAssets(address account) external view returns (address[] memory) {
        return accountBorrowedAssets[account];
    }

    function setCloseFactor(uint256 newCloseFactorMantissa) external onlyAdmin {
        require(newCloseFactorMantissa >= 0.05e18 && newCloseFactorMantissa <= 0.9e18, "Invalid close factor");
        closeFactorMantissa = newCloseFactorMantissa;
    }

    function setLiquidationIncentive(uint256 newLiquidationIncentiveMantissa) external onlyAdmin {
        require(newLiquidationIncentiveMantissa >= MANTISSA && newLiquidationIncentiveMantissa <= 1.5e18, "Invalid liquidation incentive");
        liquidationIncentiveMantissa = newLiquidationIncentiveMantissa;
    }

    function setCollateralFactor(address asset, uint256 newCollateralFactorMantissa) external onlyAdmin {
        require(markets[asset].isListed, "Market not listed");
        require(newCollateralFactorMantissa <= MANTISSA && newCollateralFactorMantissa > 0, "Invalid collateral factor");
        require(newCollateralFactorMantissa < markets[asset].liquidationThreshold, "Must be less than liquidation threshold");
        markets[asset].collateralFactor = newCollateralFactorMantissa;
    }

    function setLiquidationThreshold(address asset, uint256 newLiquidationThreshold) external onlyAdmin {
        require(markets[asset].isListed, "Market not listed");
        require(newLiquidationThreshold <= MANTISSA, "Invalid liquidation threshold");
        require(newLiquidationThreshold > markets[asset].collateralFactor, "Must be greater than collateral factor");
        markets[asset].liquidationThreshold = newLiquidationThreshold;
    }

    function setInterestRateModel(
        address asset,
        uint256 baseRatePerBlock,
        uint256 multiplierPerBlock,
        uint256 jumpMultiplierPerBlock,
        uint256 kink
    ) external onlyAdmin {
        require(markets[asset].isListed, "Market not listed");
        accrueInterest(asset);
        
        markets[asset].baseRatePerBlock = baseRatePerBlock;
        markets[asset].multiplierPerBlock = multiplierPerBlock;
        markets[asset].jumpMultiplierPerBlock = jumpMultiplierPerBlock;
        markets[asset].kink = kink;
    }
}