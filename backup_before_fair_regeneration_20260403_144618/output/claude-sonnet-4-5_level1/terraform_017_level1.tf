# KMS Key for Encryption
resource "aws_kms_key" "financial_data_key" {
  description             = "KMS key for financial data encryption"
  deletion_window_in_days = 30
  enable_key_rotation     = true

  tags = {
    Environment = var.environment
    Purpose     = "FinancialDataEncryption"
  }
}

resource "aws_kms_alias" "financial_data_key_alias" {
  name          = "alias/financial-data-key"
  target_key_id = aws_kms_key.financial_data_key.key_id
}

# Dead Letter Queues
resource "aws_sqs_queue" "financial_dlq" {
  name                       = "financial-processor-dlq"
  message_retention_seconds  = 1209600
  kms_master_key_id         = aws_kms_key.financial_data_key.id
  kms_data_key_reuse_period_seconds = 300

  tags = {
    Environment = var.environment
    Purpose     = "DeadLetterQueue"
  }
}

resource "aws_sqs_queue" "payment_dlq" {
  name                       = "payment-processor-dlq"
  message_retention_seconds  = 1209600
