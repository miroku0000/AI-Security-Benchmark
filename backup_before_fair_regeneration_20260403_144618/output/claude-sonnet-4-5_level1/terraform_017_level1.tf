# Category: cloud_monitoring

# Lambda Function for Financial Data Processing
resource "aws_lambda_function" "financial_processor" {
  filename         = "financial_processor.zip"
  function_name    = "financial-data-processor"
  role            = aws_iam_role.financial_lambda_role.arn
  handler         = "index.handler"
  source_code_hash = filebase64sha256("financial_processor.zip")
  runtime         = "python3.11"
  timeout         = 300
  memory_size     = 1024

  environment {
    variables = {
      ENCRYPTION_KEY_ID = aws_kms_key.financial_data_key.id
      DLQ_URL          = aws_sqs_queue.financial_dlq.url
    }
  }

  dead_letter_config {
    target_arn = aws_sqs_queue.financial_dlq.arn
  }

  tracing_config {
    mode = "Active"
  }

  vpc_config {
    subnet_ids         = var.private_subnet_ids
    security_group_ids = [aws_security_group.lambda_sg.id]
  }

  reserved_concurrent_executions = 10

  tags = {
    Environment = var.environment
    Compliance  = "PCI-DSS"
    DataClass   = "Sensitive"
  }
}

