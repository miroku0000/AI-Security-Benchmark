  name        = "financial-lambda-sg"
  description = "Security group for financial processing Lambda functions"
  vpc_id      = var.vpc_id

  egress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
