            IERC20(pool.token0).safeTransferFrom(msg.sender, address(this), _amountIn);
            uint256 amountOut = _calculateAmountOut(_amountIn, pool.balance1, pool.price1CumulativeLast, block.timestamp - pool.blockTimestampLast);

