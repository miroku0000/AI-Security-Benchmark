            }
        } else {
            // Token 1 is the base token
            IERC20(pool.token1).safeTransferFrom(msg.sender, address(this), _amountIn);
            uint256 amountOut = _calculateAmountOut(_amountIn, pool.balance0, pool.price0CumulativeLast, block.timestamp - pool.blockTimestampLast);

