    function balanceOf(address account) external view returns (uint256);
    function transfer(address recipient, uint256 amount) external returns (bool);
    function allowance(address owner, address spender) external view returns (uint256);
    function approve(address spender, uint256 amount) external returns (bool);
    function transferFrom(address sender, address recipient, uint256 amount) external returns (bool);
    function decimals() external view returns (uint8);
}

interface IUniswapV2Pair {
    function token0() external view returns (address);
    function token1() external view returns (address);
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
}

contract DeFiLendingProtocol {
    struct Market {
        bool isSupported;
        uint256 totalSupply;
        uint256 totalBorrowed;
        uint256 collateralFactor;
        uint256 liquidationThreshold;
        uint256 baseRatePerBlock;
        uint256 multiplierPerBlock;
        address priceFeed;
        bool isPriceFeedToken0;
    }

    struct UserAccount {
        uint256 supplied;
        uint256 borrowed;
        uint256 interestIndex;
        uint256 lastUpdateBlock;
    }

    mapping(address => Market) public markets;
    mapping(address => mapping(address => UserAccount)) public userAccounts;
    mapping(address => address[]) public userSuppliedAssets;
    mapping(address => address[]) public userBorrowedAssets;

    address public immutable stablecoin;
    address public owner;
    uint256 public constant COLLATERAL_FACTOR_MANTISSA = 1e18;
    uint256 public constant LIQUIDATION_INCENTIVE = 1.08e18;
    uint256 public constant BLOCKS_PER_YEAR = 2102400;

    event MarketAdded(address indexed asset, uint256 collateralFactor, uint256 liquidationThreshold);
    event Supplied(address indexed user, address indexed asset, uint256 amount);
    event Withdrawn(address indexed user, address indexed asset, uint256 amount);
    event Borrowed(address indexed user, address indexed asset, uint256 amount);
    event Repaid(address indexed user, address indexed asset, uint256 amount);
    event Liquidated(address indexed liquidator, address indexed borrower, address indexed assetBorrowed, address assetCollateral, uint256 repayAmount, uint256 seizedAmount);

    modifier onlyOwner() {
        require(msg.sender == owner, "Not owner");
        _;
    }

    constructor(address _stablecoin) {
        owner = msg.sender;
        stablecoin = _stablecoin;
    }

    function addMarket(
        address asset,
        uint256 collateralFactor,
        uint256 liquidationThreshold,
        uint256 baseRatePerBlock,
        uint256 multiplierPerBlock,
        address priceFeed,
        bool isPriceFeedToken0
    ) external onlyOwner {
        require(!markets[asset].isSupported, "Market exists");
        require(collateralFactor < COLLATERAL_FACTOR_MANTISSA, "Invalid collateral factor");
        require(liquidationThreshold > collateralFactor, "Invalid liquidation threshold");

        markets[asset] = Market({
            isSupported: true,
            totalSupply: 0,
            totalBorrowed: 0,
            collateralFactor: collateralFactor,
            liquidationThreshold: liquidationThreshold,
            baseRatePerBlock: baseRatePerBlock,
            multiplierPerBlock: multiplierPerBlock,
            priceFeed: priceFeed,
            isPriceFeedToken0: isPriceFeedToken0
        });

        emit MarketAdded(asset, collateralFactor, liquidationThreshold);
    }

    function supply(address asset, uint256 amount) external {
        require(markets[asset].isSupported, "Market not supported");
        require(amount > 0, "Invalid amount");

        accrueInterest(asset, msg.sender);

        IERC20(asset).transferFrom(msg.sender, address(this), amount);

        if (userAccounts[asset][msg.sender].supplied == 0) {
            userSuppliedAssets[msg.sender].push(asset);
        }

        userAccounts[asset][msg.sender].supplied += amount;
        markets[asset].totalSupply += amount;

        emit Supplied(msg.sender, asset, amount);
    }

    function withdraw(address asset, uint256 amount) external {
        require(markets[asset].isSupported, "Market not supported");
        require(amount > 0, "Invalid amount");

        accrueInterest(asset, msg.sender);

        require(userAccounts[asset][msg.sender].supplied >= amount, "Insufficient supply");

        userAccounts[asset][msg.sender].supplied -= amount;
        markets[asset].totalSupply -= amount;

        require(getAccountLiquidity(msg.sender) >= 0, "Insufficient collateral");

        IERC20(asset).transfer(msg.sender, amount);

        emit Withdrawn(msg.sender, asset, amount);
    }

    function borrow(address asset, uint256 amount) external {
        require(markets[asset].isSupported, "Market not supported");
        require(amount > 0, "Invalid amount");
        require(markets[asset].totalSupply >= markets[asset].totalBorrowed + amount, "Insufficient liquidity");

        accrueInterest(asset, msg.sender);

        if (userAccounts[asset][msg.sender].borrowed == 0) {
            userBorrowedAssets[msg.sender].push(asset);
            userAccounts[asset][msg.sender].interestIndex = getCurrentInterestIndex(asset);
        }

        userAccounts[asset][msg.sender].borrowed += amount;
        markets[asset].totalBorrowed += amount;

        require(getAccountLiquidity(msg.sender) >= 0, "Insufficient collateral");

        IERC20(asset).transfer(msg.sender, amount);

        emit Borrowed(msg.sender, asset, amount);
    }

    function repay(address asset, uint256 amount) external {
        require(markets[asset].isSupported, "Market not supported");
        require(amount > 0, "Invalid amount");

        accrueInterest(asset, msg.sender);

        uint256 borrowBalance = userAccounts[asset][msg.sender].borrowed;
        uint256 repayAmount = amount > borrowBalance ? borrowBalance : amount;

        IERC20(asset).transferFrom(msg.sender, address(this), repayAmount);

        userAccounts[asset][msg.sender].borrowed -= repayAmount;
        markets[asset].totalBorrowed -= repayAmount;

        emit Repaid(msg.sender, asset, repayAmount);
    }

    function liquidate(
        address borrower,
        address assetBorrowed,
        uint256 repayAmount,
        address assetCollateral
    ) external {
        require(markets[assetBorrowed].isSupported, "Borrow market not supported");
        require(markets[assetCollateral].isSupported, "Collateral market not supported");

        accrueInterest(assetBorrowed, borrower);
        accrueInterest(assetCollateral, borrower);

        require(getAccountLiquidity(borrower) < 0, "Account not underwater");
        require(userAccounts[assetBorrowed][borrower].borrowed > 0, "No borrow");

        uint256 maxRepay = (userAccounts[assetBorrowed][borrower].borrowed * 50) / 100;
        require(repayAmount <= maxRepay, "Repay amount too high");

        IERC20(assetBorrowed).transferFrom(msg.sender, address(this), repayAmount);

        userAccounts[assetBorrowed][borrower].borrowed -= repayAmount;
        markets[assetBorrowed].totalBorrowed -= repayAmount;

        uint256 seizeAmount = calculateSeizeTokens(assetBorrowed, assetCollateral, repayAmount);

        require(userAccounts[assetCollateral][borrower].supplied >= seizeAmount, "Insufficient collateral");

        userAccounts[assetCollateral][borrower].supplied -= seizeAmount;
        markets[assetCollateral].totalSupply -= seizeAmount;

        IERC20(assetCollateral).transfer(msg.sender, seizeAmount);

        emit Liquidated(msg.sender, borrower, assetBorrowed, assetCollateral, repayAmount, seizeAmount);
    }

    function getPrice(address asset) public view returns (uint256) {
        if (asset == stablecoin) {
            return 1e18;
        }

        Market memory market = markets[asset];
        require(market.priceFeed != address(0), "No price feed");

        IUniswapV2Pair pair = IUniswapV2Pair(market.priceFeed);
        (uint112 reserve0, uint112 reserve1,) = pair.getReserves();

        address token0 = pair.token0();
        address token1 = pair.token1();

        uint256 decimals0 = IERC20(token0).decimals();
        uint256 decimals1 = IERC20(token1).decimals();

        uint256 price;

        if (market.isPriceFeedToken0) {
            price = (uint256(reserve1) * 1e18 * (10 ** decimals0)) / (uint256(reserve0) * (10 ** decimals1));
        } else {
            price = (uint256(reserve0) * 1e18 * (10 ** decimals1)) / (uint256(reserve1) * (10 ** decimals0));
        }

        return price;
    }

    function getAccountLiquidity(address user) public view returns (int256) {
        uint256 totalCollateralValue = 0;
        uint256 totalBorrowValue = 0;

        address[] memory suppliedAssets = userSuppliedAssets[user];
        for (uint256 i = 0; i < suppliedAssets.length; i++) {
            address asset = suppliedAssets[i];
            uint256 supplied = userAccounts[asset][user].supplied;
            if (supplied > 0) {
                uint256 price = getPrice(asset);
                uint256 collateralValue = (supplied * price * markets[asset].collateralFactor) / COLLATERAL_FACTOR_MANTISSA;
                totalCollateralValue += collateralValue;
            }
        }

        address[] memory borrowedAssets = userBorrowedAssets[user];
        for (uint256 i = 0; i < borrowedAssets.length; i++) {
            address asset = borrowedAssets[i];
            uint256 borrowed = getBorrowBalanceWithInterest(asset, user);
            if (borrowed > 0) {
                uint256 price = getPrice(asset);
                uint256 borrowValue = borrowed * price;
                totalBorrowValue += borrowValue;
            }
        }

        return int256(totalCollateralValue) - int256(totalBorrowValue);
    }

    function getBorrowBalanceWithInterest(address asset, address user) public view returns (uint256) {
        UserAccount memory account = userAccounts[asset][user];
        if (account.borrowed == 0) {
            return 0;
        }

        uint256 currentIndex = getCurrentInterestIndex(asset);
        return (account.borrowed * currentIndex) / account.interestIndex;
    }

    function getCurrentInterestIndex(address asset) public view returns (uint256) {
        Market memory market = markets[asset];
        if (market.totalBorrowed == 0) {
            return 1e18;
        }

        uint256 utilizationRate = (market.totalBorrowed * 1e18) / market.totalSupply;
        uint256 borrowRate = market.baseRatePerBlock + (utilizationRate * market.multiplierPerBlock) / 1e18;

        return 1e18 + borrowRate;
    }

    function accrueInterest(address asset, address user) internal {
        UserAccount storage account = userAccounts[asset][user];

        if (account.borrowed > 0 && account.lastUpdateBlock < block.number) {
            uint256 currentIndex = getCurrentInterestIndex(asset);
            uint256 interestAccrued = (account.borrowed * (currentIndex - account.interestIndex)) / account.interestIndex;

            account.borrowed += interestAccrued;
            account.interestIndex = currentIndex;
            account.lastUpdateBlock = block.number;

            markets[asset].totalBorrowed += interestAccrued;
        } else if (account.borrowed > 0) {
            account.interestIndex = getCurrentInterestIndex(asset);
        }

        account.lastUpdateBlock = block.number;
    }

    function calculateSeizeTokens(
        address assetBorrowed,
        address assetCollateral,
        uint256 repayAmount
    ) public view returns (uint256) {
        uint256 priceBorrowed = getPrice(assetBorrowed);
        uint256 priceCollateral = getPrice(assetCollateral);

        uint256 valueRepaid = repayAmount * priceBorrowed;
        uint256 seizeValue = (valueRepaid * LIQUIDATION_INCENTIVE) / 1e18;
        uint256 seizeAmount = seizeValue / priceCollateral;

        return seizeAmount;
    }

    function getAccountHealth(address user) external view returns (uint256) {
        uint256 totalCollateralValue = 0;
        uint256 totalBorrowValue = 0;

        address[] memory suppliedAssets = userSuppliedAssets[user];
        for (uint256 i = 0; i < suppliedAssets.length; i++) {
            address asset = suppliedAssets[i];
            uint256 supplied = userAccounts[asset][user].supplied;
            if (supplied > 0) {
                uint256 price = getPrice(asset);
                uint256 collateralValue = (supplied * price * markets[asset].liquidationThreshold) / COLLATERAL_FACTOR_MANTISSA;
                totalCollateralValue += collateralValue;
            }
        }

        address[] memory borrowedAssets = userBorrowedAssets[user];
        for (uint256 i = 0; i < borrowedAssets.length; i++) {
            address asset = borrowedAssets[i];
            uint256 borrowed = getBorrowBalanceWithInterest(asset, user);
            if (borrowed > 0) {
                uint256 price = getPrice(asset);
                uint256 borrowValue = borrowed * price;
                totalBorrowValue += borrowValue;
            }
        }

        if (totalBorrowValue == 0) {
            return type(uint256).max;
        }

        return (totalCollateralValue * 1e18) / totalBorrowValue;
    }

    function getUserSuppliedAssets(address user) external view returns (address[] memory) {
        return userSuppliedAssets[user];
    }

    function getUserBorrowedAssets(address user) external view returns (address[] memory) {
        return userBorrowedAssets[user];
    }

    function updateMarketParameters(
        address asset,
        uint256 collateralFactor,
        uint256 liquidationThreshold,
        uint256 baseRatePerBlock,
        uint256 multiplierPerBlock
    ) external onlyOwner {
        require(markets[asset].isSupported, "Market not supported");
        require(collateralFactor < COLLATERAL_FACTOR_MANTISSA, "Invalid collateral factor");
        require(liquidationThreshold > collateralFactor, "Invalid liquidation threshold");

        markets[asset].collateralFactor = collateralFactor;
        markets[asset].liquidationThreshold = liquidationThreshold;
        markets[asset].baseRatePerBlock = baseRatePerBlock;
        markets[asset].multiplierPerBlock = multiplierPerBlock;
    }

    function transferOwnership(address newOwner) external onlyOwner {
        require(newOwner != address(0), "Invalid address");
        owner = newOwner;
    }
}