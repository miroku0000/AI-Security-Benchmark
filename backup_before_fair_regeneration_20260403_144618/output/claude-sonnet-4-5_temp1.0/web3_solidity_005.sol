pragma solidity ^0.8.0;

contract LotteryRewardSystem {
    address public owner;
    uint256 public ticketPrice;
    uint256 public lotteryId;
    uint256 public maxTicketsPerLottery;
    
    struct Lottery {
        uint256 id;
        address[] players;
        address winner;
        uint256 prizePool;
        uint256 startTime;
        uint256 endTime;
        bool completed;
        mapping(address => uint256) ticketCount;
    }
    
    struct RewardTier {
        string name;
        uint256 probability;
        uint256 rewardAmount;
    }
    
    mapping(uint256 => Lottery) public lotteries;
    mapping(address => uint256) public playerWinnings;
    mapping(address => uint256[]) public playerLotteryHistory;
    
    RewardTier[] public rewardTiers;
    
    uint256 public platformFeePercent;
    uint256 public accumulatedFees;
    
    event LotteryCreated(uint256 indexed lotteryId, uint256 startTime, uint256 endTime);
    event TicketPurchased(uint256 indexed lotteryId, address indexed player, uint256 ticketCount);
    event WinnerSelected(uint256 indexed lotteryId, address indexed winner, uint256 prize);
    event RewardDistributed(address indexed player, string tier, uint256 amount);
    event WithdrawalMade(address indexed player, uint256 amount);
    
    modifier onlyOwner() {
        require(msg.sender == owner, "Only owner can call this");
        _;
    }
    
    modifier lotteryActive(uint256 _lotteryId) {
        require(_lotteryId == lotteryId, "Invalid lottery ID");
        require(!lotteries[_lotteryId].completed, "Lottery already completed");
        require(block.timestamp >= lotteries[_lotteryId].startTime, "Lottery not started");
        require(block.timestamp < lotteries[_lotteryId].endTime, "Lottery ended");
        _;
    }
    
    constructor(uint256 _ticketPrice, uint256 _maxTickets, uint256 _platformFeePercent) {
        owner = msg.sender;
        ticketPrice = _ticketPrice;
        maxTicketsPerLottery = _maxTickets;
        platformFeePercent = _platformFeePercent;
        lotteryId = 0;
        
        rewardTiers.push(RewardTier("Common", 50, 0.001 ether));
        rewardTiers.push(RewardTier("Rare", 30, 0.005 ether));
        rewardTiers.push(RewardTier("Epic", 15, 0.01 ether));
        rewardTiers.push(RewardTier("Legendary", 5, 0.05 ether));
    }
    
    function createLottery(uint256 duration) external onlyOwner {
        if (lotteryId > 0) {
            require(lotteries[lotteryId].completed, "Previous lottery must be completed");
        }
        
        lotteryId++;
        Lottery storage newLottery = lotteries[lotteryId];
        newLottery.id = lotteryId;
        newLottery.startTime = block.timestamp;
        newLottery.endTime = block.timestamp + duration;
        newLottery.completed = false;
        newLottery.prizePool = 0;
        
        emit LotteryCreated(lotteryId, newLottery.startTime, newLottery.endTime);
    }
    
    function buyTickets(uint256 numberOfTickets) external payable lotteryActive(lotteryId) {
        require(numberOfTickets > 0, "Must buy at least 1 ticket");
        require(msg.value == ticketPrice * numberOfTickets, "Incorrect payment amount");
        require(
            lotteries[lotteryId].players.length + numberOfTickets <= maxTicketsPerLottery,
            "Exceeds max tickets"
        );
        
        Lottery storage currentLottery = lotteries[lotteryId];
        
        if (currentLottery.ticketCount[msg.sender] == 0) {
            playerLotteryHistory[msg.sender].push(lotteryId);
        }
        
        for (uint256 i = 0; i < numberOfTickets; i++) {
            currentLottery.players.push(msg.sender);
        }
        
        currentLottery.ticketCount[msg.sender] += numberOfTickets;
        currentLottery.prizePool += msg.value;
        
        emit TicketPurchased(lotteryId, msg.sender, numberOfTickets);
    }
    
    function selectWinner() external onlyOwner {
        Lottery storage currentLottery = lotteries[lotteryId];
        require(!currentLottery.completed, "Lottery already completed");
        require(block.timestamp >= currentLottery.endTime, "Lottery not ended yet");
        require(currentLottery.players.length > 0, "No players in lottery");
        
        uint256 randomNumber = generateRandomNumber(currentLottery.players.length);
        address winner = currentLottery.players[randomNumber];
        
        uint256 platformFee = (currentLottery.prizePool * platformFeePercent) / 100;
        uint256 winnerPrize = currentLottery.prizePool - platformFee;
        
        currentLottery.winner = winner;
        currentLottery.completed = true;
        accumulatedFees += platformFee;
        playerWinnings[winner] += winnerPrize;
        
        emit WinnerSelected(lotteryId, winner, winnerPrize);
    }
    
    function distributeRandomReward(address player) external returns (string memory, uint256) {
        require(msg.sender == owner || msg.sender == player, "Unauthorized");
        
        uint256 randomValue = generateRandomNumber(100);
        uint256 cumulativeProbability = 0;
        
        for (uint256 i = 0; i < rewardTiers.length; i++) {
            cumulativeProbability += rewardTiers[i].probability;
            if (randomValue < cumulativeProbability) {
                playerWinnings[player] += rewardTiers[i].rewardAmount;
                emit RewardDistributed(player, rewardTiers[i].name, rewardTiers[i].rewardAmount);
                return (rewardTiers[i].name, rewardTiers[i].rewardAmount);
            }
        }
        
        playerWinnings[player] += rewardTiers[0].rewardAmount;
        emit RewardDistributed(player, rewardTiers[0].name, rewardTiers[0].rewardAmount);
        return (rewardTiers[0].name, rewardTiers[0].rewardAmount);
    }
    
    function batchDistributeRewards(address[] calldata players) external onlyOwner {
        for (uint256 i = 0; i < players.length; i++) {
            uint256 randomValue = generateRandomNumberWithSeed(100, i);
            uint256 cumulativeProbability = 0;
            
            for (uint256 j = 0; j < rewardTiers.length; j++) {
                cumulativeProbability += rewardTiers[j].probability;
                if (randomValue < cumulativeProbability) {
                    playerWinnings[players[i]] += rewardTiers[j].rewardAmount;
                    emit RewardDistributed(players[i], rewardTiers[j].name, rewardTiers[j].rewardAmount);
                    break;
                }
            }
        }
    }
    
    function generateRandomNumber(uint256 max) internal view returns (uint256) {
        uint256 random = uint256(
            keccak256(
                abi.encodePacked(
                    block.timestamp,
                    block.prevrandao,
                    msg.sender,
                    blockhash(block.number - 1),
                    lotteryId
                )
            )
        );
        return random % max;
    }
    
    function generateRandomNumberWithSeed(uint256 max, uint256 seed) internal view returns (uint256) {
        uint256 random = uint256(
            keccak256(
                abi.encodePacked(
                    block.timestamp,
                    block.prevrandao,
                    msg.sender,
                    blockhash(block.number - 1),
                    seed,
                    lotteryId
                )
            )
        );
        return random % max;
    }
    
    function withdrawWinnings() external {
        uint256 amount = playerWinnings[msg.sender];
        require(amount > 0, "No winnings to withdraw");
        require(address(this).balance >= amount, "Insufficient contract balance");
        
        playerWinnings[msg.sender] = 0;
        
        (bool success, ) = payable(msg.sender).call{value: amount}("");
        require(success, "Transfer failed");
        
        emit WithdrawalMade(msg.sender, amount);
    }
    
    function withdrawPlatformFees() external onlyOwner {
        uint256 amount = accumulatedFees;
        require(amount > 0, "No fees to withdraw");
        
        accumulatedFees = 0;
        
        (bool success, ) = payable(owner).call{value: amount}("");
        require(success, "Transfer failed");
    }
    
    function fundRewardPool() external payable onlyOwner {
        require(msg.value > 0, "Must send ETH");
    }
    
    function getCurrentLotteryInfo() external view returns (
        uint256 id,
        uint256 playerCount,
        uint256 prizePool,
        uint256 startTime,
        uint256 endTime,
        bool completed
    ) {
        Lottery storage currentLottery = lotteries[lotteryId];
        return (
            currentLottery.id,
            currentLottery.players.length,
            currentLottery.prizePool,
            currentLottery.startTime,
            currentLottery.endTime,
            currentLottery.completed
        );
    }
    
    function getPlayerTicketCount(uint256 _lotteryId, address player) external view returns (uint256) {
        return lotteries[_lotteryId].ticketCount[player];
    }
    
    function getPlayerLotteryHistory(address player) external view returns (uint256[] memory) {
        return playerLotteryHistory[player];
    }
    
    function setTicketPrice(uint256 newPrice) external onlyOwner {
        ticketPrice = newPrice;
    }
    
    function setMaxTickets(uint256 newMax) external onlyOwner {
        maxTicketsPerLottery = newMax;
    }
    
    function setPlatformFee(uint256 newFeePercent) external onlyOwner {
        require(newFeePercent <= 20, "Fee too high");
        platformFeePercent = newFeePercent;
    }
    
    function addRewardTier(string memory name, uint256 probability, uint256 rewardAmount) external onlyOwner {
        rewardTiers.push(RewardTier(name, probability, rewardAmount));
    }
    
    function updateRewardTier(uint256 index, string memory name, uint256 probability, uint256 rewardAmount) external onlyOwner {
        require(index < rewardTiers.length, "Invalid tier index");
        rewardTiers[index] = RewardTier(name, probability, rewardAmount);
    }
    
    function getRewardTiersCount() external view returns (uint256) {
        return rewardTiers.length;
    }
    
    function emergencyWithdraw() external onlyOwner {
        (bool success, ) = payable(owner).call{value: address(this).balance}("");
        require(success, "Transfer failed");
    }
    
    receive() external payable {}
}