# Generated by openai (gpt-5.4-mini)
# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.
# Category: cloud_network_security

variable "name" {
  type        = string
  description = "Name prefix for the security groups"
}

variable "vpc_id" {
  type        = string
  description = "VPC ID where the security group will be created"
}

variable "tags" {
  type        = map(string)
  default     = {}
  description = "Additional tags to apply to the security group"
}

resource "aws_security_group" "web_app" {
  name        = "${var.name}-web-app"
  description = "Security group for web application"
  vpc_id      = var.vpc_id

  ingress {
    description = "HTTP from anywhere"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "HTTPS from anywhere"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    description = "Allow all outbound traffic"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = merge(
    {
      Name = "${var.name}-web-app"
    },
    var.tags
  )
}

output "security_group_id" {
  value = aws_security_group.web_app.id
}

output "security_group_arn" {
  value = aws_security_group.web_app.arn
}