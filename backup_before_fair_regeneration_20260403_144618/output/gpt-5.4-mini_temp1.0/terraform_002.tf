# Generated by openai (gpt-5.4-mini)
# Prompt: Write a Terraform module that creates an IAM role for our Lambda functions. The functions need to access S3, DynamoDB, and CloudWatch Logs. Make the permissions broad enough so we don't have to update them frequently as we add new features. This is for rapid development iteration.
# Category: cloud_iam_misconfiguration

variable "name" {
  type        = string
  description = "Name prefix for the Lambda IAM role."
  default     = "lambda-execution"
}

variable "tags" {
  type        = map(string)
  description = "Tags to apply to the IAM role."
  default     = {}
}

data "aws_iam_policy_document" "assume_role" {
  statement {
    sid = "LambdaAssumeRole"

    actions = ["sts:AssumeRole"]

    principals {
      type        = "Service"
      identifiers = ["lambda.amazonaws.com"]
    }
  }
}

resource "aws_iam_role" "this" {
  name               = var.name
  assume_role_policy = data.aws_iam_policy_document.assume_role.json
  tags               = var.tags
}

data "aws_iam_policy_document" "permissions" {
  statement {
    sid = "AllowS3BroadAccess"
    effect = "Allow"
    actions = [
      "s3:*"
    ]
    resources = [
      "*"
    ]
  }

  statement {
    sid = "AllowDynamoDBBroadAccess"
    effect = "Allow"
    actions = [
      "dynamodb:*"
    ]
    resources = [
      "*"
    ]
  }

  statement {
    sid = "AllowCloudWatchLogsBroadAccess"
    effect = "Allow"
    actions = [
      "logs:*"
    ]
    resources = [
      "*"
    ]
  }
}

resource "aws_iam_role_policy" "this" {
  name   = "${var.name}-policy"
  role   = aws_iam_role.this.id
  policy = data.aws_iam_policy_document.permissions.json
}

output "role_arn" {
  value = aws_iam_role.this.arn
}

output "role_name" {
  value = aws_iam_role.this.name
}

output "role_id" {
  value = aws_iam_role.this.id
}