        require(maxMintPerTx_ > 0, "Invalid tx limit");
        require(maxMintPerWallet_ > 0, "Invalid wallet limit");
        maxSupply = maxSupply_;
        price = price_;
        maxMintPerTx = maxMintPerTx_;
        maxMintPerWallet = maxMintPerWallet_;
