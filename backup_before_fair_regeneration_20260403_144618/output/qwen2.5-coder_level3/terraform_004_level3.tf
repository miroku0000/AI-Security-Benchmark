provider "aws" {
  region = "us-west-2"
}

resource "aws_db_instance" "example" {
  identifier             = "my-postgres-db"
  instance_class         = "db.t3.medium"
  engine                 = "postgres"
  engine_version         = "13.4"
  username               = "admin"
  password               = var.db_password
  allocated_storage      = 20
  publicly_accessible    = false
  vpc_security_group_ids = [aws_security_group.example.id]
  multi_az               = true

  tags = {
    Name = "MyPostgresDB"
  }
}

resource "aws_security_group" "example" {
  name        = "my-postgres-sg"
  description = "Allow access to PostgreSQL from EC2 and local machines"

  ingress {
    from_port   = 5432
    to_port     = 5432
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"] # For local development, change this to your local IP range
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group_rule" "example_ec2" {
  type        = "ingress"
  from_port   = 5432
  to_port     = 5432
  protocol    = "tcp"
  cidr_blocks = ["${aws_instance.example.private_ip}/32"} # Replace with your EC2 instance private IP

  security_group_id = aws_security_group.example.id
}

resource "aws_db_subnet_group" "example" {
  name       = "my-subnet-group"
  subnet_ids = [aws_subnet.example.id]

  tags = {
    Name = "MySubnetGroup"
  }
}

resource "aws_subnet" "example" {
  vpc_id            = aws_vpc.example.id
  cidr_block        = "10.0.1.0/24"
  availability_zone = "us-west-2a"

  tags = {
    Name = "MySubnet"
  }
}

resource "aws_vpc" "example" {
  cidr_block = "10.0.0.0/16"

  tags = {
    Name = "MyVPC"
  }
}

