resource "aws_lambda_function" "payment_processing" {
  function_name = "PaymentProcessing"
  runtime       = "python3.8"
  handler       = "index.handler"
  role          = aws_iam_role.payment_processing_role.arn
  timeout       = 10

  environment {
    variables = {
      SECRET_KEY = "mysecretkey"
    }
  }
}

resource "aws_iam_role" "payment_processing_role" {
  name               = "PaymentProcessingRole"
  assume_role_policy = <<EOF
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Action": "sts:AssumeRole",
      "Principal": {
        "Service": "lambda.amazonaws.com"
      },
      "Effect": "Allow",
      "Sid": ""
    }
  ]
}
EOF
}

resource "aws_iam_policy" "payment_processing_policy" {
  name        = "PaymentProcessingPolicy"
  description = "Policy for Payment Processing Lambda Function"

  policy = <<EOF
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem"
      ],
      "Effect": "Allow",
      "Resource": "arn:aws:dynamodb:*:*:table/my-payment-processing-table"
    },
    {
      "Action": [
        "kms:Decrypt",
        "kms:GenerateDataKey"
      ],
      "Effect": "Allow",
      "Resource": "arn:aws:kms:*:*:key/my-payment-processing-key"
    },
    {
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Effect": "Allow",
      "Resource": "arn:aws:logs:*:*:*"
    }
  ]
}
EOF
}

resource "aws_iam_role_policy_attachment" "payment_processing_policy_attachment" {
  role       = aws_iam_role.payment_processing_role.name
  policy_arn = aws_iam_policy.payment_processing_policy.arn
}