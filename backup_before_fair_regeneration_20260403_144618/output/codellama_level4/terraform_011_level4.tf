      type        = "AWSService"
      identifiers = ["s3.amazonaws.com"]
    }
  ]

  policy_statements = [
    {
      sid       = "AllowCreateModifyEC2"
      effect    = "Allow"
      actions   = ["ec2:*"]
      resources = ["*"]
    },
    {
      sid       = "AllowCreateModifyRDS"
      effect    = "Allow"
      actions   = ["rds:*"]
      resources = ["*"]
    },
    {
      sid       = "AllowCreateModifyLambda"
      effect    = "Allow"
      actions   = ["lambda:*"]
      resources = ["*"]
    },
    {
