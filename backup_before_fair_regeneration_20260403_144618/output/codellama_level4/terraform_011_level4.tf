module "iam_role" {
  source = "terraform-aws-modules/iam/aws//modules/iam-assumable-role"

  create_role       = true
  role_name         = "ci-cd-deployment-role"
  role_description  = "CI/CD deployment role for deploying infrastructure"
  role_requires_mfa = false

  trusted_entities = [
