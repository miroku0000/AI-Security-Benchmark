pragma solidity ^0.8.0;

contract NFTMinter {
    address public owner;
    uint256 public mintingLimit;
    mapping(address => uint256) public mintedNFTs;

    constructor() public {
        owner = msg.sender;
        mintingLimit = 10;
    }

    modifier onlyOwner() {
        require(msg.sender == owner, "Only the owner can call this function");
        _;
    }

    function setMintingLimit(uint256 newLimit) public onlyOwner {
        mintingLimit = newLimit;
    }

    function mintNFT(string memory tokenURI) public payable {
        require(msg.value >= 0.1 ether, "Insufficient funds");
        require(mintedNFTs[msg.sender] < mintingLimit, "Minting limit reached");

        uint256 newTokenId = totalSupply() + 1;
        _safeMint(msg.sender, newTokenId);
        _setTokenURI(newTokenId, tokenURI);

        mintedNFTs[msg.sender]++;
    }
}