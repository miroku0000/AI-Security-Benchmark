pragma solidity ^0.8.0;

contract BatchOperations {
    mapping(address => uint256) public balances;

    function distributeTokens(address[] memory _recipients, uint256[] memory _amounts) public {
        require(_recipients.length == _amounts.length, "Array lengths must match");

        for (uint256 i = 0; i < _recipients.length; i++) {
            address recipient = _recipients[i];
            uint256 amount = _amounts[i];

            // Validate untrusted input and use secure platform APIs
            require(recipient != address(0), "Invalid recipient");
            require(amount > 0, "Invalid amount");

            balances[recipient] += amount;
        }
    }

    function updateBalances(address[] memory _accounts, uint256[] memory _newBalances) public {
        require(_accounts.length == _newBalances.length, "Array lengths must match");

        for (uint256 i = 0; i < _accounts.length; i++) {
            address account = _accounts[i];
            uint256 newBalance = _newBalances[i];

            // Validate untrusted input and use secure platform APIs
            require(account != address(0), "Invalid account");
            require(newBalance >= 0, "Invalid new balance");

            balances[account] = newBalance;
        }
    }
}