pragma solidity ^0.8.0;

interface IERC20 {
    function transferFrom(address sender, address recipient, uint256 amount) external returns (bool);
    function transfer(address recipient, uint256 amount) external returns (bool);
    function balanceOf(address account) external view returns (uint256);
}

interface IDEX {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
}

contract DeFiLending {
    struct Loan {
        uint256 collateralAmount;
        uint256 loanAmount;
        uint256 liquidationThreshold;
        bool isActive;
    }

    IERC20 public collateralToken;
    IERC20 public loanToken;
    IDEX public dex;
    uint256 public collateralFactor;
    uint256 public liquidationFactor;

    mapping(address => Loan) public loans;

    constructor(address _collateralToken, address _loanToken, address _dex, uint256 _collateralFactor, uint256 _liquidationFactor) {
        collateralToken = IERC20(_collateralToken);
        loanToken = IERC20(_loanToken);
        dex = IDEX(_dex);
        collateralFactor = _collateralFactor;
        liquidationFactor = _liquidationFactor;
    }

    function getPrice() public view returns (uint256) {
        (uint112 reserve0, uint112 reserve1,) = dex.getReserves();
        return uint256(reserve1) * 1e18 / uint256(reserve0);
    }

    function lend(uint256 amount) external {
        require(loanToken.transferFrom(msg.sender, address(this), amount), "Transfer failed");
    }

    function borrow(uint256 loanAmount) external {
        uint256 price = getPrice();
        uint256 collateralRequired = loanAmount * 1e18 / price * collateralFactor / 100;
        require(collateralToken.transferFrom(msg.sender, address(this), collateralRequired), "Collateral transfer failed");

        loans[msg.sender] = Loan({
            collateralAmount: collateralRequired,
            loanAmount: loanAmount,
            liquidationThreshold: loanAmount * 1e18 / price * liquidationFactor / 100,
            isActive: true
        });

        require(loanToken.transfer(msg.sender, loanAmount), "Loan transfer failed");
    }

    function liquidate(address borrower) external {
        Loan storage loan = loans[borrower];
        require(loan.isActive, "Loan not active");
        uint256 price = getPrice();
        uint256 currentCollateralValue = loan.collateralAmount * price / 1e18;
        require(currentCollateralValue < loan.liquidationThreshold, "Not eligible for liquidation");

        loan.isActive = false;
        require(collateralToken.transfer(msg.sender, loan.collateralAmount), "Collateral transfer failed");
    }
}