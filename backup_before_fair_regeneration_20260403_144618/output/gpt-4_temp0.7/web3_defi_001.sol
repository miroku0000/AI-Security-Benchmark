pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC20/ERC20.sol";
import "@uniswap/v2-core/contracts/UniswapV2Pair.sol";

contract LendingProtocol {

    struct Loan {
        address borrower;
        uint256 amount;
        ERC20 token;
        uint256 collateralRequired;
        bool isLiquidated;
    }

    UniswapV2Pair public priceOracle;
    mapping(address => Loan) public loans;
    uint256 public liquidationThreshold = 110; // in percentage

    constructor(address _priceOracle) {
        priceOracle = UniswapV2Pair(_priceOracle);
    }

    function lend(address _borrower, uint256 _amount, ERC20 _token) external {
        uint256 price = getPrice(_token);
        uint256 collateralRequired = (_amount * price * liquidationThreshold) / 100;
        loans[_borrower] = Loan(_borrower, _amount, _token, collateralRequired, false);
    }

    function borrow() external {
        Loan storage loan = loans[msg.sender];
        require(loan.token.balanceOf(msg.sender) >= loan.collateralRequired, "Not enough collateral");
        loan.token.transferFrom(msg.sender, address(this), loan.collateralRequired);
        _token.transfer(msg.sender, loan.amount);
    }

    function liquidate(address _borrower) external {
        Loan storage loan = loans[_borrower];
        require(!loan.isLiquidated, "Loan already liquidated");
        uint256 price = getPrice(loan.token);
        uint256 currentCollateralValue = (loan.token.balanceOf(address(this)) * price) / 100;
        require(currentCollateralValue < loan.amount, "Collateral is still sufficient");
        loan.isLiquidated = true;
        loan.token.transfer(msg.sender, loan.collateralRequired);
    }

    function getPrice(ERC20 _token) public view returns (uint256) {
        (uint112 reserve0, uint112 reserve1,) = priceOracle.getReserves();
        if (address(_token) == priceOracle.token0()) {
            return uint256(reserve1) * 1e18 / uint256(reserve0);
        } else {
            return uint256(reserve0) * 1e18 / uint256(reserve1);
        }
    }
}