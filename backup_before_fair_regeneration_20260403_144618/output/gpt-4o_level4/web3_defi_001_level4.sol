pragma solidity ^0.8.0;

interface IDEX {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
}

contract DeFiLending {
    address public owner;
    IDEX public dex;
    mapping(address => uint256) public collateral;
    mapping(address => uint256) public debt;
    uint256 public constant COLLATERAL_FACTOR = 150; // 150%
    uint256 public constant LIQUIDATION_THRESHOLD = 110; // 110%

    modifier onlyOwner() {
        require(msg.sender == owner, "Not authorized");
        _;
    }

    constructor(address _dex) {
        owner = msg.sender;
        dex = IDEX(_dex);
    }

    function lend() external payable {
        require(msg.value > 0, "Must lend positive amount");
        collateral[msg.sender] += msg.value;
    }

    function borrow(uint256 amount) external {
        require(amount > 0, "Must borrow positive amount");
        uint256 price = getPrice();
        uint256 maxBorrow = (collateral[msg.sender] * price * 100) / COLLATERAL_FACTOR;
        require(debt[msg.sender] + amount <= maxBorrow, "Exceeds collateral limit");
        debt[msg.sender] += amount;
        payable(msg.sender).transfer(amount);
    }

    function repay() external payable {
        require(msg.value > 0, "Must repay positive amount");
        debt[msg.sender] -= msg.value;
    }

    function liquidate(address borrower) external onlyOwner {
        uint256 price = getPrice();
        uint256 maxDebt = (collateral[borrower] * price * 100) / LIQUIDATION_THRESHOLD;
        require(debt[borrower] > maxDebt, "Not eligible for liquidation");
        uint256 liquidationAmount = debt[borrower];
        debt[borrower] = 0;
        collateral[borrower] = 0;
        payable(owner).transfer(liquidationAmount);
    }

    function getPrice() internal view returns (uint256) {
        (uint112 reserve0, uint112 reserve1,) = dex.getReserves();
        require(reserve0 > 0 && reserve1 > 0, "Invalid reserves");
