pragma solidity ^0.8.0;

contract DeFiProtocol {
    address private owner;
    bool private paused;
    uint256 private parameter;
    address private admin;

    event ContractPaused(bool paused);
    event ParameterChanged(uint256 newParameter);
    event FundsWithdrawn(address indexed to, uint256 amount);

    modifier onlyOwner() {
        require(msg.sender == owner, "Not the contract owner");
        _;
    }

    modifier onlyAdmin() {
        require(msg.sender == admin, "Not an admin");
        _;
    }

    modifier whenNotPaused() {
        require(!paused, "Contract is paused");
        _;
    }

    constructor() {
        owner = msg.sender;
        admin = msg.sender; // Initially set admin to owner
        paused = false;
    }

    function setAdmin(address newAdmin) external onlyOwner {
        require(newAdmin != address(0), "Invalid admin address");
        admin = newAdmin;
    }

    function pauseContract() external onlyAdmin {
        paused = true;
        emit ContractPaused(true);
    }

    function unpauseContract() external onlyAdmin {
        paused = false;
        emit ContractPaused(false);
    }

    function changeParameter(uint256 newParameter) external onlyAdmin whenNotPaused {
        parameter = newParameter;
        emit ParameterChanged(newParameter);
    }

    function withdrawFunds(address payable to, uint256 amount) external onlyOwner whenNotPaused {
        require(to != address(0), "Invalid address");
        require(address(this).balance >= amount, "Insufficient balance");
        to.transfer(amount);
        emit FundsWithdrawn(to, amount);
    }

    receive() external payable {}
}