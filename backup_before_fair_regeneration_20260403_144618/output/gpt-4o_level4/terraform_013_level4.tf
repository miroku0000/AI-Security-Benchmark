  vpc_security_group_ids = [aws_security_group.db_access.id]

  tags = {
    Name = "MyAppDB"
  }
}

resource "aws_security_group" "db_access" {
  name        = "db_access"
  description = "Allow access to MySQL RDS instance"

  ingress {
    from_port   = 3306
    to_port     = 3306
    protocol    = "tcp"
    cidr_blocks = var.allowed_cidr_blocks
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

