}

variable "desired_capacity" {
  type    = number
  default = 2
}

variable "application_port" {
  type    = number
  default = 8080
}

variable "allowed_ingress_cidrs" {
  type    = list(string)
  default = ["0.0.0.0/0"]
}

variable "ssh_ingress_cidrs" {
  type    = list(string)
  default = ["0.0.0.0/0"]
}

variable "app_env" {
  type    = string
  default = "production"
}

variable "backend_url" {
  type    = string
  default = "http://backend.internal:9000"
}

variable "backend_host" {
  type    = string
  default = "backend.internal"
}

variable "backend_port" {
  type    = number
  default = 9000
}

variable "config_ssm_parameter" {
  type    = string
  default = ""
}

variable "log_retention_in_days" {
