# Generated by openai (gpt-5.4)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

data "aws_availability_zones" "available" {
  state = "available"
}

data "aws_ami" "amazon_linux_2" {
  most_recent = true

  owners = ["amazon"]

  filter {
    name   = "name"
    values = ["amzn2-ami-hvm-*-x86_64-gp2"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
}

data "aws_vpc" "default" {
  default = true
}

data "aws_subnets" "default" {
  filter {
    name   = "vpc-id"
    values = [data.aws_vpc.default.id]
  }
}

resource "aws_security_group" "app" {
  name_prefix = "${var.name_prefix}-app-"
  description = "Security group for application instances"
  vpc_id      = data.aws_vpc.default.id

  ingress {
    description = "Application port"
    from_port   = var.application_port
    to_port     = var.application_port
    protocol    = "tcp"
    cidr_blocks = var.allowed_ingress_cidrs
  }

  ingress {
    description = "SSH"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = var.ssh_ingress_cidrs
  }

  egress {
    description = "All outbound"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-app-sg"
  })
}

resource "aws_iam_role" "ec2" {
  name_prefix = "${var.name_prefix}-ec2-role-"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      }
    ]
  })

  tags = var.tags
}

resource "aws_iam_role_policy" "ec2_inline" {
  name_prefix = "${var.name_prefix}-ec2-policy-"
  role        = aws_iam_role.ec2.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowCloudWatchLogs"
        Effect = "Allow"
        Action = [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents",
          "logs:DescribeLogStreams"
        ]
        Resource = "*"
      },
      {
        Sid    = "AllowSSMParameterRead"
        Effect = "Allow"
        Action = [
          "ssm:GetParameter",
          "ssm:GetParameters",
          "ssm:GetParametersByPath"
        ]
        Resource = "*"
      }
    ]
  })
}

resource "aws_iam_instance_profile" "ec2" {
  name_prefix = "${var.name_prefix}-instance-profile-"
  role        = aws_iam_role.ec2.name

  tags = var.tags
}

resource "aws_cloudwatch_log_group" "bootstrap" {
  name              = "/${var.name_prefix}/bootstrap"
  retention_in_days = var.log_retention_in_days

  tags = var.tags
}

locals {
  backend_env = join("\n", [
    "APP_ENV=${var.app_env}",
    "APP_PORT=${var.application_port}",
    "BACKEND_URL=${var.backend_url}",
    "BACKEND_HOST=${var.backend_host}",
    "BACKEND_PORT=${var.backend_port}",
    "CONFIG_SSM_PARAMETER=${var.config_ssm_parameter}"
  ])

  user_data = <<-EOT
    #!/bin/bash
    set -xeuo pipefail

    exec > >(tee /var/log/user-data.log | logger -t user-data -s 2>/dev/console) 2>&1

    yum update -y
    yum install -y aws-cli jq

    mkdir -p /opt/${var.name_prefix}/bin
    mkdir -p /etc/${var.name_prefix}
    mkdir -p /var/log/${var.name_prefix}

    cat > /etc/${var.name_prefix}/app.env <<'EOF'
    ${local.backend_env}
    EOF

    if [ -n "${var.config_ssm_parameter}" ]; then
      aws ssm get-parameter \
        --name "${var.config_ssm_parameter}" \
        --with-decryption \
        --region "${var.aws_region}" \
        --query 'Parameter.Value' \
        --output text > /etc/${var.name_prefix}/dynamic-config.json
    else
      echo '{}' > /etc/${var.name_prefix}/dynamic-config.json
    fi

    cat > /opt/${var.name_prefix}/bin/start-app.sh <<'EOF'
    #!/bin/bash
    set -euo pipefail
    source /etc/${var.name_prefix}/app.env

    echo "$(date -Iseconds) Starting application bootstrap" >> /var/log/${var.name_prefix}/app.log
    echo "$(date -Iseconds) Backend: ${var.backend_host}:${var.backend_port}" >> /var/log/${var.name_prefix}/app.log

    until timeout 2 bash -c "cat < /dev/null > /dev/tcp/${var.backend_host}/${var.backend_port}"; do
      echo "$(date -Iseconds) Waiting for backend ${var.backend_host}:${var.backend_port}" >> /var/log/${var.name_prefix}/app.log
      sleep 5
    done

    cat > /etc/systemd/system/${var.name_prefix}.service <<'SERVICE'
    [Unit]
    Description=${var.name_prefix} application service
    After=network-online.target
    Wants=network-online.target

    [Service]
    Type=simple
    EnvironmentFile=/etc/${var.name_prefix}/app.env
    ExecStart=/bin/bash -c 'while true; do echo "Application connected to ${var.backend_url} and listening on port ${var.application_port}"; nc -lk -p ${var.application_port} -e /bin/cat; done'
    Restart=always
    RestartSec=5

    [Install]
    WantedBy=multi-user.target
    SERVICE

    yum install -y nc

    systemctl daemon-reload
    systemctl enable ${var.name_prefix}.service
    systemctl restart ${var.name_prefix}.service
    EOF

    chmod +x /opt/${var.name_prefix}/bin/start-app.sh
    /opt/${var.name_prefix}/bin/start-app.sh

    TOKEN=$(curl -X PUT "http://169.254.169.254/latest/api/token" -H "X-aws-ec2-metadata-token-ttl-seconds: 21600")
    INSTANCE_ID=$(curl -H "X-aws-ec2-metadata-token: $TOKEN" -s http://169.254.169.254/latest/meta-data/instance-id)

    LOG_STREAM="${var.name_prefix}-$INSTANCE_ID"
    aws logs create-log-stream --log-group-name "${aws_cloudwatch_log_group.bootstrap.name}" --log-stream-name "$LOG_STREAM" --region "${var.aws_region}" || true

    TIMESTAMP=$(($(date +%s%N)/1000000))
    MESSAGE=$(tail -n 200 /var/log/user-data.log | sed 's/"/\\"/g' | tr '\n' ' ')
    aws logs put-log-events \
      --log-group-name "${aws_cloudwatch_log_group.bootstrap.name}" \
      --log-stream-name "$LOG_STREAM" \
      --log-events timestamp=$TIMESTAMP,message="$MESSAGE" \
      --region "${var.aws_region}" || true
  EOT
}

resource "aws_launch_template" "app" {
  name_prefix   = "${var.name_prefix}-lt-"
  image_id      = data.aws_ami.amazon_linux_2.id
  instance_type = var.instance_type
  key_name      = var.key_name

  vpc_security_group_ids = [aws_security_group.app.id]

  iam_instance_profile {
    arn = aws_iam_instance_profile.ec2.arn
  }

  user_data = base64encode(local.user_data)

  monitoring {
    enabled = true
  }

  metadata_options {
    http_endpoint               = "enabled"
    http_tokens                 = "required"
    instance_metadata_tags      = "enabled"
    http_put_response_hop_limit = 2
  }

  tag_specifications {
    resource_type = "instance"

    tags = merge(var.tags, {
      Name = "${var.name_prefix}-instance"
    })
  }

  tag_specifications {
    resource_type = "volume"

    tags = merge(var.tags, {
      Name = "${var.name_prefix}-volume"
    })
  }

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-launch-template"
  })
}

resource "aws_autoscaling_group" "app" {
  name                = "${var.name_prefix}-asg"
  min_size            = var.min_size
  max_size            = var.max_size
  desired_capacity    = var.desired_capacity
  vpc_zone_identifier = data.aws_subnets.default.ids
  health_check_type   = "EC2"
  force_delete        = true

  launch_template {
    id      = aws_launch_template.app.id
    version = "$Latest"
  }

  tag {
    key                 = "Name"
    value               = "${var.name_prefix}-asg-instance"
    propagate_at_launch = true
  }

  dynamic "tag" {
    for_each = var.tags
    content {
      key                 = tag.key
      value               = tag.value
      propagate_at_launch = true
    }
  }
}

variable "aws_region" {
  type    = string
  default = "us-east-1"
}

variable "name_prefix" {
  type    = string
  default = "fastapp"
}

variable "instance_type" {
  type    = string
  default = "t3.micro"
}

variable "key_name" {
  type    = string
