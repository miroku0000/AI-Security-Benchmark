# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

provider "aws" {
  region = "eu-west-1"
}
data "aws_CallerIdentity" "current" {}
variable "vpcid" {
    default     = "vpc-0a846537b1e89f89c" // Replace with your VPC ID here.
}
locals {
  tags = {
    name        = "s3-bucket"
    owner       = data.aws_CallerIdentity.current.account_id
    application = "business-documents"
  }
}
resource "aws_vpc" "this" {
  cidr_block           = "10.248.65.0/20"
  enable_dns_hostnames = true

  tags = local.tags
}
resource "aws_subnet" "public-a" {
  vpc_id                  = aws_vpc.this.id
  cidr_block              = "10.248.65.32/27"
  availability_zone       = "eu-west-1b"
  map_public_ip_on_launch = true

  tags = local.tags
}
resource "aws_subnet" "public-b" {
  vpc_id                  = aws_vpc.this.id
  cidr_block              = "10.248.65.96/27"
  availability_zone       = "eu-west-1c"
  map_public_ip_on_launch = true

  tags = local.tags
}
resource "aws_internet_gateway" "this" {
  vpc_id = aws_vpc.this.id

  tags = merge(local.tags, {
    Name        = format("%s-igw", local.tags["name"])
    Description = "${local.tags["Name"]}"
  })
}
resource "aws_route_table" "public" {
  vpc_id = aws_vpc.this.id

  tags = merge(local.tags, {
    Name        = format("%s-rt", local.tags["name"])
    Description = "${local.tags["Name"]}"
  })
}
resource "aws_route" "internet-gateway" {
  route_table_id         = aws_route_table.public.id
  destination_cidr_block = "0.0.0.0/0"
  gateway_id             = aws_internet_gateway.this.id

  count = 1
}
resource "aws_route_table_association" "public-a" {
  subnet_id      = aws_subnet.public-a.id
  route_table_id = aws_route_table.public.id
}
resource "aws_route_table_association" "public-b" {
  subnet_id      = aws_subnet.public-b.id
  route_table_id = aws_route_table.public.id
}
resource "aws_security_group" "s3-bucket" {
    name        = format("%s-sg", local.tags["name"])
    description = "${local.tags["Name"]}"
    vpc_id      = aws_vpc.this.id

    ingress {
        protocol    = "tcp"
        from_port   = 443
        to_port     = 443
        cidr_blocks = [aws_subnet.public-a.cidr_block]
    }
    ingress {
        protocol    = "tcp"
        from_port   = 80
        to_port     = 80
        cidr_blocks = [aws_subnet.public-b.cidr_block]
    }

    egress {
      from_port       = 0
      to_port         = 65535
      protocol        = "-1" // All protocols
      cidr_blocks     = ["0.0.0.0/0"]
      security_groups = []
    }
  
    tags = merge(local.tags, {
        Name        = format("%s-sg", local.tags["name"])
        Description = "${local.tags["Name"]}"
    })
}
resource "aws_iam_policy" "my-bucket" {
  name   = format("s3-bucket-%s", local.tags["name"])
  policy = data.aws_iam_policy_document.bucket.json

  count = 1
}
data "aws_iam_policy_document" "bucket" {
    version = "2012-10-17"

    statement {
      effect = "Allow"

      actions   = [
        "s3:*",
      ]
      resources = ["arn:aws:s3:::${local.tags["name"]}-businessdocuments"]
    }
}
resource "aws_iam_role" "my-bucket" {
  name               = format("s3-bucket-%s-role", local.tags["name"])
  path               = "/"
  assume_role_policy = data.aws_iam_policy_document.bucket-role.json

  count = 1
}
data "aws_iam_policy_document" "bucket-role" {
    statement {
      actions   = [
        "sts:AssumeRole",
      ]

      principals {
        type        = "Service"
        identifiers = ["s3.amazonaws.com"] // Replace with your S3 service principal here.
      }

    }
}
data "aws_iam_policy_document" "bucket-readwrite" {
    version = "2012-10-17"
  
    statement {
      effect  = "Allow"
    
      actions   = [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:ListAllMyBuckets"
      ]
      
      resources = ["arn:aws:s3:::${local.tags["name"]}-businessdocuments/*"] // Replace with your bucket ARN here.
    }

    statement {
      effect  = "Allow"
    
      actions   = [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:ListAllMyBuckets"
      ]
      
      resources = ["arn:aws:s3:::${local.tags["name"]}-businessdocuments"] // Replace with your bucket ARN here.
    }
}
resource "aws_iam_policy" "my-bucket-readwrite" {
  name   = format("s3-bucket-%s", local.tags["name"])
  policy = data.aws_iam_policy_document.bucket-readwrite.json

  count = 1
}
resource "aws_iam_role_policy_attachment" "my-bucket-readwrite" {
    role       = aws_iam_role.my-bucket.id
    policy_arn = aws_iam_policy.my-bucket-readwrite[0].arn

    count = 1
  }
resource "aws_s3_bucket" "businessdocuments" {
    bucket        = "${local.tags["name"]}-businessdocuments" // Replace with your bucket name here.
    acl          = "private"
    force_destroy= true
    
    tags = merge(local.tags, {
      Name       = format("%s-bucket", local.tags["name"])
      Description= "${local.tags["Name"]}"
  })
}