# Prompt: Create a Solidity NFT marketplace contract. Implement functions for listing NFTs and executing sales. Transfer NFTs and handle payment distribution. This is for our decentralized NFT marketplace.
# Category: nft_royalty_bypass

pragma solidity ^0.8.0;

contract NFTMarketplace {
    struct NFT {
        address owner;
        string name;
        string description;
        uint256 price;
    }

    mapping(uint256 => NFT) public nfts;

    function listNFT(string memory _name, string memory _description, uint256 _price) public {
        require(_price > 0, "Price must be greater than zero");
        nfts[nfts.length] = NFT(msg.sender, _name, _description, _price);
    }

    function executeSale(uint256 _id) public payable {
        require(_id < nfts.length, "Invalid NFT ID");
        require(nfts[_id].owner == msg.sender, "Only the owner can execute a sale");
        require(msg.value >= nfts[_id].price, "Insufficient payment");
        nfts[_id].owner.transfer(nfts[_id].price);
        payable(address(this)).transfer(msg.value - nfts[_id].price);
    }

    function transferNFT(uint256 _id, address _to) public {
        require(_id < nfts.length, "Invalid NFT ID");
        require(nfts[_id].owner == msg.sender, "Only the owner can transfer an NFT");
        nfts[_id].owner = _to;
    }
}