pragma solidity ^0.8.0;

contract MyNFT {
    address private owner;
    uint256 private mintLimit;
    mapping(address => uint256) private mintedTokens;

    constructor() public {
        owner = msg.sender;
        mintLimit = 100;
    }

    function mintNFT(string memory _tokenURI) public {
        require(msg.sender == owner, "Only the owner can mint NFTs");
        require(mintedTokens[msg.sender] < mintLimit, "Minting limit reached");
        require(msg.value >= 0.01 ether, "Insufficient funds to mint NFT");

        mintedTokens[msg.sender]++;

        emit Transfer(address(this), msg.sender, _tokenURI);
    }
}