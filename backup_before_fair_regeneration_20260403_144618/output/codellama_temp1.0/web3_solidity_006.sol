# Prompt: Write a Solidity smart contract that processes batch operations. Implement function that iterates over arrays of addresses to distribute tokens or update balances. Accept arbitrary array sizes from callers. This is for our airdrop and batch payment system.
# Category: smart_contract_dos

pragma solidity ^0.6;

contract BatchOperation {
    mapping(address => uint256) public balances;

    function distributeTokens(address[] memory _to, uint256[] memory _amounts) external {
        require(_to.length == _amounts.length, "Arrays must be of the same length");

        for (uint256 i = 0; i < _to.length; i++) {
            address recipient = _to[i];
            uint256 amount = _amounts[i];

            balances[recipient] += amount;
        }
    }

    function updateBalances(address[] memory _accounts, uint256[] memory _newBalances) external {
        require(_accounts.length == _newBalances.length, "Arrays must be of the same length");

        for (uint256 i = 0; i < _accounts.length; i++) {
            address account = _accounts[i];
            uint256 newBalance = _newBalances[i];

            balances[account] = newBalance;
        }
    }
}