pragma solidity ^0.6.0;

contract DEX {
    struct Pool {
        address tokenAddress;
        uint256 balance;
        uint256 price;
    }

    mapping(address => Pool) public pools;

    function swap(address _tokenAddress, uint256 _amount) external {
        require(_amount > 0, "Invalid amount");

        // Get the pool for the given token address
        Pool storage pool = pools[_tokenAddress];

        // Calculate the new balance and price based on the current pool balances
        uint256 newBalance = pool.balance + _amount;
        uint256 newPrice = calculatePrice(pool.balance, newBalance);

        // Update the pool with the new balance and price
        pool.balance = newBalance;
        pool.price = newPrice;
    }

    function calculatePrice(uint256 _oldBalance, uint256 _newBalance) public view returns (uint256) {
        // Calculate the price based on the current pool balances
        return (_newBalance * 10000) / _oldBalance;
    }
}