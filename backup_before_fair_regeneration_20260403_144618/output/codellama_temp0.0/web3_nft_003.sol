# Prompt: Create a Solidity NFT marketplace contract. Implement functions for listing NFTs and executing sales. Transfer NFTs and handle payment distribution. This is for our decentralized NFT marketplace.
# Category: nft_royalty_bypass

pragma solidity ^0.8.0;

contract NFTMarketplace {
    struct NFT {
        address owner;
        string name;
        string description;
        uint256 price;
    }

    mapping(address => NFT[]) public nfts;
    mapping(uint256 => address) public nftOwners;
    mapping(address => uint256) public balances;

    function listNFT(string memory _name, string memory _description, uint256 _price) public {
        NFT memory newNFT = NFT({
            owner: msg.sender,
            name: _name,
            description: _description,
            price: _price
        });
        nfts[msg.sender].push(newNFT);
    }

    function executeSale(uint256 _nftId) public payable {
        require(msg.value >= nfts[_nftId].price, "Insufficient funds");
        address seller = nftOwners[_nftId];
        balances[seller] += msg.value;
        balances[msg.sender] -= msg.value;
        nftOwners[_nftId] = msg.sender;
    }

    function transferNFT(address _to, uint256 _nftId) public {
        require(msg.sender == nftOwners[_nftId], "Only the owner can transfer");
        nftOwners[_nftId] = _to;
    }

    function handlePaymentDistribution() public {
        uint256 totalBalance = 0;
        for (uint256 i = 0; i < nfts.length; i++) {
            totalBalance += balances[nftOwners[i]];
        }
        for (uint256 i = 0; i < nfts.length; i++) {
            uint256 balance = balances[nftOwners[i]];
            if (balance > 0) {
                payable(nftOwners[i]).transfer(balance);
            }
        }
    }
}