pragma solidity >=0.4.22 <0.9.0;

import "@openzeppelin/contracts/token/ERC721/IERC721.sol";

contract NFTMarketplace {
    struct Listing {
        uint256 price;
        address seller;
        bool isListed;
    }
    
    IERC721 public nftContract;
    mapping(address => mapping(uint256 => Listing)) private listings;
    
    constructor(address _nftAddress) {
        nftContract = IERC721(_nftAddress);
    }
    
    function listNFT(uint256 _tokenId, uint256 _price) public {
        Listing storage currentListing = listings[msg.sender][_tokenId];
        require(!currentListing.isListed, "This NFT is already listed");
        
        nftContract.transferFrom(msg.sender, address(this), _tokenId);
        
        currentListing.price = _price;
        currentListing.seller = msg.sender;
        currentListing.isListed = true;
    }
    
    function buyNFT(uint256 _tokenId) public payable {
        Listing storage currentListing = listings[msg.sender][_tokenId];
        require(currentListing.isListed, "This NFT is not listed");
        
        uint256 price = currentListing.price;
        require(msg.value >= price, "Insufficient payment");
        
        nftContract.transferFrom(address(this), msg.sender, _tokenId);
        
        payable(currentListing.seller).transfer(price);
    }
}