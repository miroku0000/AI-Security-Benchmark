}

variable "db_password" {
  default = "Demo123Pass!"
}

resource "aws_instance" "web" {
  ami           = "ami-0c94855ba95c574c8" # example AMI for t2.micro instance in us-west-2 region
  instance_type = "t2.micro"

  tags = {
    Name = "web-server-www.example.com"
  }
}

resource "aws_security_group" "allow_http" {
  name        = "allow_http"
  description = "Allow HTTP inbound traffic"

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_instance_network_interface" "example" {
  subnet_id        = aws_subnet.example.id
