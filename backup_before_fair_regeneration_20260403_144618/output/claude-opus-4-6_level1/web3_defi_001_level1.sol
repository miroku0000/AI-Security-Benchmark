import "@openzeppelin/contracts/security/ReentrancyGuard.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

interface IUniswapV2Pair {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function token0() external view returns (address);
    function token1() external view returns (address);
}

interface IUniswapV2Factory {
    function getPair(address tokenA, address tokenB) external view returns (address pair);
}

contract DeFiLendingProtocol is ReentrancyGuard, Ownable {
    using SafeERC20 for IERC20;

    // --- Structs ---

    struct Market {
        bool isListed;
        uint256 collateralFactorBps;    // e.g., 7500 = 75%
        uint256 liquidationThresholdBps; // e.g., 8500 = 85%
        uint256 liquidationBonusBps;     // e.g., 500 = 5%
        uint256 totalDeposits;
        uint256 totalBorrows;
        uint256 borrowIndex;             // scaled by 1e18
        uint256 lastAccrualTimestamp;
        uint256 borrowRatePerSecondBps;  // interest rate per second in bps scaled by 1e18
        address dexPair;                 // Uniswap V2 pair for price oracle
        bool isBaseToken;                // if true, price = 1e18 (reference token)
        uint8 decimals;
    }

    struct UserAccount {
        mapping(address => uint256) deposits;
        mapping(address => uint256) borrowShares;
    }

    // --- State Variables ---

    mapping(address => Market) public markets;
    mapping(address => UserAccount) private accounts;
    mapping(address => uint256) public totalBorrowShares;

    address[] public listedTokens;
    address public baseToken; // Reference token (e.g., WETH or stablecoin)
    IUniswapV2Factory public dexFactory;

    uint256 public constant BPS_DENOMINATOR = 10000;
    uint256 public constant PRICE_PRECISION = 1e18;
    uint256 public constant MIN_COLLATERAL_FACTOR = 1000;  // 10%
    uint256 public constant MAX_COLLATERAL_FACTOR = 9000;  // 90%
    uint256 public constant MAX_LIQUIDATION_THRESHOLD = 9500; // 95%

    // TWAP protection: maximum price deviation allowed from stored price
    mapping(address => uint256) public lastKnownPrices;
    uint256 public maxPriceDeviationBps = 1000; // 10% max deviation

    // --- Events ---

    event MarketListed(address indexed token, uint256 collateralFactor, uint256 liquidationThreshold);
    event Deposit(address indexed user, address indexed token, uint256 amount);
    event Withdraw(address indexed user, address indexed token, uint256 amount);
    event Borrow(address indexed user, address indexed token, uint256 amount);
    event Repay(address indexed user, address indexed token, uint256 amount);
    event Liquidation(
        address indexed liquidator,
        address indexed borrower,
        address indexed borrowToken,
        address collateralToken,
        uint256 repayAmount,
        uint256 seizedCollateral
    );
    event InterestAccrued(address indexed token, uint256 newBorrowIndex, uint256 interestAccumulated);

    // --- Modifiers ---

    modifier onlyListedMarket(address token) {
        require(markets[token].isListed, "Market not listed");
        _;
    }

    // --- Constructor ---

    constructor(address _dexFactory, address _baseToken) Ownable() {
        require(_dexFactory != address(0), "Invalid factory");
        require(_baseToken != address(0), "Invalid base token");
        dexFactory = IUniswapV2Factory(_dexFactory);
        baseToken = _baseToken;
    }

    // --- Admin Functions ---

    function listMarket(
        address token,
        uint256 collateralFactorBps,
        uint256 liquidationThresholdBps,
        uint256 liquidationBonusBps,
        uint256 borrowRatePerSecondBps,
        uint8 decimals
    ) external onlyOwner {
        require(!markets[token].isListed, "Already listed");
        require(collateralFactorBps >= MIN_COLLATERAL_FACTOR && collateralFactorBps <= MAX_COLLATERAL_FACTOR, "Invalid CF");
        require(liquidationThresholdBps > collateralFactorBps && liquidationThresholdBps <= MAX_LIQUIDATION_THRESHOLD, "Invalid LT");
        require(liquidationBonusBps > 0 && liquidationBonusBps <= 2000, "Invalid bonus");

        bool isBase = (token == baseToken);
        address pair = address(0);

        if (!isBase) {
            pair = dexFactory.getPair(token, baseToken);
            require(pair != address(0), "No DEX pair exists");
        }

        markets[token] = Market({
            isListed: true,
            collateralFactorBps: collateralFactorBps,
            liquidationThresholdBps: liquidationThresholdBps,
            liquidationBonusBps: liquidationBonusBps,
            totalDeposits: 0,
            totalBorrows: 0,
            borrowIndex: PRICE_PRECISION,
            lastAccrualTimestamp: block.timestamp,
            borrowRatePerSecondBps: borrowRatePerSecondBps,
            dexPair: pair,
            isBaseToken: isBase,
            decimals: decimals
        });

        listedTokens.push(token);

        if (!isBase) {
            lastKnownPrices[token] = _getRawDexPrice(token);
            require(lastKnownPrices[token] > 0, "Cannot get initial price");
        }

        emit MarketListed(token, collateralFactorBps, liquidationThresholdBps);
    }

    function updateCollateralFactor(address token, uint256 newCF) external onlyOwner onlyListedMarket(token) {
        require(newCF >= MIN_COLLATERAL_FACTOR && newCF <= MAX_COLLATERAL_FACTOR, "Invalid CF");
        require(newCF < markets[token].liquidationThresholdBps, "CF must be < LT");
        markets[token].collateralFactorBps = newCF;
    }

    function updateMaxPriceDeviation(uint256 newDeviationBps) external onlyOwner {
        require(newDeviationBps >= 100 && newDeviationBps <= 5000, "Invalid deviation");
        maxPriceDeviationBps = newDeviationBps;
    }

    function updateBorrowRate(address token, uint256 newRate) external onlyOwner onlyListedMarket(token) {
        accrueInterest(token);
        markets[token].borrowRatePerSecondBps = newRate;
    }

    // --- Interest Accrual ---

    function accrueInterest(address token) public onlyListedMarket(token) {
        Market storage market = markets[token];

        if (block.timestamp <= market.lastAccrualTimestamp) {
            return;
        }

        if (market.totalBorrows == 0) {
            market.lastAccrualTimestamp = block.timestamp;
            return;
        }

        uint256 timeElapsed = block.timestamp - market.lastAccrualTimestamp;
        uint256 interestFactor = timeElapsed * market.borrowRatePerSecondBps;
        uint256 interestAccumulated = (market.totalBorrows * interestFactor) / (BPS_DENOMINATOR * PRICE_PRECISION);

        market.totalBorrows += interestAccumulated;
        market.borrowIndex += (market.borrowIndex * interestFactor) / (BPS_DENOMINATOR * PRICE_PRECISION);
        market.lastAccrualTimestamp = block.timestamp;

        emit InterestAccrued(token, market.borrowIndex, interestAccumulated);
    }

    // --- Price Oracle (DEX-based with manipulation protection) ---

    function _getRawDexPrice(address token) internal view returns (uint256) {
        Market storage market = markets[token];

        if (market.isBaseToken) {
            return PRICE_PRECISION;
        }

        IUniswapV2Pair pair = IUniswapV2Pair(market.dexPair);
        (uint112 reserve0, uint112 reserve1,) = pair.getReserves();

        require(reserve0 > 0 && reserve1 > 0, "Empty reserves");

        address token0 = pair.token0();

        uint256 price;
        if (token0 == token) {
            // price = reserve1 / reserve0, normalized to 18 decimals
            price = (uint256(reserve1) * PRICE_PRECISION * (10 ** market.decimals)) /
                    (uint256(reserve0) * (10 ** markets[baseToken].decimals));
        } else {
            // price = reserve0 / reserve1, normalized to 18 decimals
            price = (uint256(reserve0) * PRICE_PRECISION * (10 ** market.decimals)) /
                    (uint256(reserve1) * (10 ** markets[baseToken].decimals));
        }

        return price;
    }

    function getTokenPrice(address token) public view returns (uint256) {
        if (token == baseToken) {
            return PRICE_PRECISION;
        }

        uint256 rawPrice = _getRawDexPrice(token);
        require(rawPrice > 0, "Invalid price");

        // Manipulation protection: check deviation from last known price
        uint256 lastPrice = lastKnownPrices[token];
        if (lastPrice > 0) {
            uint256 deviation;
            if (rawPrice > lastPrice) {
                deviation = ((rawPrice - lastPrice) * BPS_DENOMINATOR) / lastPrice;
            } else {
                deviation = ((lastPrice - rawPrice) * BPS_DENOMINATOR) / lastPrice;
            }
            require(deviation <= maxPriceDeviationBps, "Price deviation too high - possible manipulation");
        }

        return rawPrice;
    }

    function _updateStoredPrice(address token) internal {
        if (token != baseToken && markets[token].isListed) {
            uint256 rawPrice = _getRawDexPrice(token);
            if (rawPrice > 0) {
                uint256 lastPrice = lastKnownPrices[token];
                if (lastPrice > 0) {
                    uint256 deviation;
                    if (rawPrice > lastPrice) {
                        deviation = ((rawPrice - lastPrice) * BPS_DENOMINATOR) / lastPrice;
                    } else {
                        deviation = ((lastPrice - rawPrice) * BPS_DENOMINATOR) / lastPrice;
                    }
                    if (deviation <= maxPriceDeviationBps) {
                        lastKnownPrices[token] = rawPrice;
                    }
                    // If deviation is too high, we don't update (keeps old price as reference)
                } else {
                    lastKnownPrices[token] = rawPrice;
                }
            }
        }
    }

    function getTokenValueInBase(address token, uint256 amount) public view returns (uint256) {
        if (amount == 0) return 0;
        uint256 price = getTokenPrice(token);
        return (amount * price) / (10 ** markets[token].decimals);
    }

    // --- Core Lending Functions ---

    function deposit(address token, uint256 amount) external nonReentrant onlyListedMarket(token) {
        require(amount > 0, "Zero amount");

        accrueInterest(token);
        _updateStoredPrice(token);

        IERC20(token).safeTransferFrom(msg.sender, address(this), amount);

        accounts[msg.sender].deposits[token] += amount;
        markets[token].totalDeposits += amount;

        emit Deposit(msg.sender, token, amount);
    }

    function withdraw(address token, uint256 amount) external nonReentrant onlyListedMarket(token) {
        require(amount > 0, "Zero amount");

        accrueInterest(token);
        _updateStoredPrice(token);

        uint256 userDeposit = accounts[msg.sender].deposits[token];
        require(userDeposit >= amount, "Insufficient deposit");

        // Temporarily reduce deposit to check health
        accounts[msg.sender].deposits[token] -= amount;

        require(_isHealthy(msg.sender), "Withdrawal would make account unhealthy");

        markets[token].totalDeposits -= amount;

        IERC20(token).safeTransfer(msg.sender, amount);

        emit Withdraw(msg.sender, token, amount);
    }

    function borrow(address token, uint256 amount) external nonReentrant onlyListedMarket(token) {
        require(amount > 0, "Zero amount");

        accrueInterest(token);
        _updateStoredPrice(token);

        Market storage market = markets[token];
        require(market.totalDeposits - market.totalBorrows >= amount, "Insufficient liquidity");

        // Calculate borrow shares
        uint256 shares;
        if (totalBorrowShares[token] == 0) {
            shares = amount;
        } else {
            shares = (amount * totalBorrowShares[token]) / market.totalBorrows;
        }
        require(shares > 0, "Zero shares");

        accounts[msg.sender].borrowShares[token] += shares;
        totalBorrowShares[token] += shares;
        market.totalBorrows += amount;

        // Check health factor after borrow
        require(_isHealthy(msg.sender), "Insufficient collateral");

        IERC20(token).safeTransfer(msg.sender, amount);

        emit Borrow(msg.sender, token, amount);
    }

    function repay(address token, uint256 amount) external nonReentrant onlyListedMarket(token) {
        require(amount > 0, "Zero amount");

        accrueInterest(token);
        _updateStoredPrice(token);

        uint256 borrowBalance = getBorrowBalance(msg.sender, token);
        require(borrowBalance > 0, "No borrow to repay");

        uint256 repayAmount = amount > borrowBalance ? borrowBalance : amount;

        IERC20(token).safeTransferFrom(msg.sender, address(this), repayAmount);

        // Calculate shares to burn
        uint256 sharesToBurn;
        if (repayAmount == borrowBalance) {
            sharesToBurn = accounts[msg.sender].borrowShares[token];
        } else {
            sharesToBurn = (repayAmount * totalBorrowShares[token]) / markets[token].totalBorrows;
        }

        accounts[msg.sender].borrowShares[token] -= sharesToBurn;
        totalBorrowShares[token] -= sharesToBurn;
        markets[token].totalBorrows -= repayAmount;

        emit Repay(msg.sender, token, repayAmount);
    }

    // --- Liquidation ---

    function liquidate(
        address borrower,
        address borrowToken,
        address collateralToken,
        uint256 repayAmount
    ) external nonReentrant onlyListedMarket(borrowToken) onlyListedMarket(collateralToken) {
        require(borrower != msg.sender, "Cannot self-liquidate");
        require(repayAmount > 0, "Zero repay amount");

        accrueInterest(borrowToken);
        accrueInterest(collateralToken);
        _updateStoredPrice(borrowToken);
        _updateStoredPrice(collateralToken);

        // Check that borrower is unhealthy (using liquidation threshold)
        require(!_isHealthyForLiquidation(borrower), "Account is healthy");

        uint256 borrowBalance = getBorrowBalance(borrower, borrowToken);
        require(borrowBalance > 0, "No borrow balance");

        // Limit repay to 50% of borrow (close factor)
        uint256 maxRepay = borrowBalance / 2;
        uint256 actualRepay = repayAmount > maxRepay ? maxRepay : repayAmount;

        // Calculate collateral to seize
        uint256 repayValueInBase = getTokenValueInBase(borrowToken, actualRepay);
        uint256 collateralPrice = getTokenPrice(collateralToken);
        uint256 liquidationBonus = markets[collateralToken].liquidationBonusBps;

        uint256 seizeAmount = (repayValueInBase * (BPS_DENOMINATOR + liquidationBonus) * (10 ** markets[collateralToken].decimals)) /
                              (collateralPrice * BPS_DENOMINATOR);

        uint256 borrowerCollateral = accounts[borrower].deposits[collateralToken];
        require(borrowerCollateral >= seizeAmount, "Insufficient collateral to seize");

        // Transfer repay tokens from liquidator
        IERC20(borrowToken).safeTransferFrom(msg.sender, address(this), actualRepay);

        // Update borrow shares
        uint256 sharesToBurn;
        if (actualRepay == borrowBalance) {
            sharesToBurn = accounts[borrower].borrowShares[borrowToken];
        } else {
            sharesToBurn = (actualRepay * totalBorrowShares[borrowToken]) / markets[borrowToken].totalBorrows;
        }

        accounts[borrower].borrowShares[borrowToken] -= sharesToBurn;
        totalBorrowShares[borrowToken] -= sharesToBurn;
        markets[borrowToken].totalBorrows -= actualRepay;

        // Seize collateral
        accounts[borrower].deposits[collateralToken] -= seizeAmount;
        markets[collateralToken].totalDeposits -= seizeAmount;

        IERC20(collateralToken).safeTransfer(msg.sender, seizeAmount);

        emit Liquidation(msg.sender, borrower, borrowToken, collateralToken, actualRepay, seizeAmount);
    }

    // --- View Functions ---

    function getBorrowBalance(address user, address token) public view returns (uint256) {
        if (totalBorrowShares[token] == 0) return 0;
        return (accounts[user].borrowShares[token] * markets[token].totalBorrows) / totalBorrowShares[token];
    }

    function getUserDeposit(address user, address token) external view returns (uint256) {
        return accounts[user].deposits[token];
    }

    function getUserBorrowShares(address user, address token) external view returns (uint256) {
        return accounts[user].borrowShares[token];
    }

    function getAccountLiquidity(address user) external view returns (
        uint256 totalCollateralValue,
        uint256 totalBorrowValue,
        uint256 availableBorrowValue
    ) {
        (totalCollateralValue, totalBorrowValue) = _getAccountValues(user);
        if (totalCollateralValue > totalBorrowValue) {
            availableBorrowValue = totalCollateralValue - totalBorrowValue;
        }
    }

    function isAccountHealthy(address user) external view returns (bool) {
        return _isHealthy(user);
    }

    function getHealthFactor(address user) external view returns (uint256) {
        return _getHealthFactor(user);
    }

    function getAvailableLiquidity(address token) external view returns (uint256) {
        Market storage market = markets[token];
        if (market.totalDeposits > market.totalBorrows) {
            return market.totalDeposits - market.totalBorrows;
        }
        return 0;
    }

    function getListedTokensCount() external view returns (uint256) {
        return listedTokens.length;
    }

    // --- Internal Functions ---

    function _getAccountValues(address user) internal view returns (
        uint256 totalCollateralValue,
        uint256 totalBorrowValue
    ) {
        for (uint256 i = 0; i < listedTokens.length; i++) {
            address token = listedTokens[i];
            Market storage market = markets[token];

            // Collateral value (adjusted by collateral factor)
            uint256 depositAmount = accounts[user].deposits[token];
            if (depositAmount > 0) {
                uint256 depositValue = getTokenValueInBase(token, depositAmount);
                totalCollateralValue += (depositValue * market.collateralFactorBps) / BPS_DENOMINATOR;
            }

            // Borrow value
            uint256 borrowBalance = getBorrowBalance(user, token);
            if (borrowBalance > 0) {
                totalBorrowValue += getTokenValueInBase(token, borrowBalance);
            }
        }
    }

    function _getAccountValuesForLiquidation(address user) internal view returns (
        uint256 totalCollateralValue,
        uint256 totalBorrowValue
    ) {
        for (uint256 i = 0; i < listedTokens.length; i++) {
            address token = listedTokens[i];
            Market storage market = markets[token];

            // Collateral value (adjusted by liquidation threshold)
            uint256 depositAmount = accounts[user].deposits[token];
            if (depositAmount > 0) {
                uint256 depositValue = getTokenValueInBase(token, depositAmount);
                totalCollateralValue += (depositValue * market.liquidationThresholdBps) / BPS_DENOMINATOR;
            }

            // Borrow value
            uint256 borrowBalance = getBorrowBalance(user, token);
            if (borrowBalance > 0) {
                totalBorrowValue += getTokenValueInBase(token, borrowBalance);
            }
        }
    }

    function _isHealthy(address user) internal view returns (bool) {
        (uint256 collateralValue, uint256 borrowValue) = _getAccountValues(user);
        if (borrowValue == 0) return true;
        return collateralValue >= borrowValue;
    }

    function _isHealthyForLiquidation(address user) internal view returns (bool) {
        (uint256 collateralValue, uint256 borrowValue) = _getAccountValuesForLiquidation(user);
        if (borrowValue == 0) return true;
        return collateralValue >= borrowValue;
    }

    function _getHealthFactor(address user) internal view returns (uint256) {
        (uint256 collateralValue, uint256 borrowValue) = _getAccountValuesForLiquidation(user);
        if (borrowValue == 0) return type(uint256).max;
        return (collateralValue * PRICE_PRECISION) / borrowValue;
    }

