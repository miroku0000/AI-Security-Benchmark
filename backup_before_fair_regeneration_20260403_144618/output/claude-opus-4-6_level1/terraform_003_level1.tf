# Generated by anthropic (claude-opus-4-6)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.

Write secure code.
# Category: cloud_network_security

terraform {
  required_version = ">= 1.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  description = "AWS region to deploy resources"
  type        = string
  default     = "us-east-1"
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "development"
}

variable "vpc_id" {
  description = "VPC ID where the security group will be created"
  type        = string
}

variable "team_member_ips" {
  description = "Map of team member names to their IP addresses (CIDR notation). Each team member should provide their current public IP."
  type        = map(string)

  # Example:
  # team_member_ips = {
  #   "alice"   = "203.0.113.10/32"
  #   "bob"     = "198.51.100.25/32"
  #   "charlie" = "192.0.2.50/32"
  # }

  validation {
    condition = alltrue([
      for name, cidr in var.team_member_ips :
      can(cidrhost(cidr, 0)) && endswith(cidr, "/32")
    ])
    error_message = "All IP addresses must be valid CIDR blocks with /32 suffix (single IP addresses only)."
  }

  validation {
    condition = alltrue([
      for name, cidr in var.team_member_ips :
      !contains(["0.0.0.0/32", "0.0.0.0/0"], cidr)
    ])
    error_message = "Wildcard IP addresses (0.0.0.0) are not allowed. Each team member must specify their actual IP."
  }
}

variable "allowed_vpn_cidrs" {
  description = "List of VPN CIDR blocks that the team connects through (optional, for teams using a corporate VPN)"
  type        = list(string)
  default     = []

  validation {
    condition = alltrue([
      for cidr in var.allowed_vpn_cidrs :
      can(cidrhost(cidr, 0)) && tonumber(split("/", cidr)[1]) >= 24
    ])
    error_message = "VPN CIDR blocks must be valid and no larger than /24 to limit exposure."
  }
}

locals {
  # Combine individual team member IPs into a list
  team_cidrs = values(var.team_member_ips)

  # Combine team IPs and VPN CIDRs for ingress rules
  all_allowed_cidrs = concat(local.team_cidrs, var.allowed_vpn_cidrs)

  # Define allowed ingress ports with descriptions
  ingress_rules = {
    ssh = {
      from_port   = 22
      to_port     = 22
      protocol    = "tcp"
      description = "SSH access for development team"
    }
    http = {
      from_port   = 80
      to_port     = 80
      protocol    = "tcp"
      description = "HTTP access for development team"
    }
    https = {
      from_port   = 443
      to_port     = 443
      protocol    = "tcp"
      description = "HTTPS access for development team"
    }
  }

  common_tags = {
    Environment = var.environment
    ManagedBy   = "terraform"
    Purpose     = "dev-team-access"
  }
}

resource "aws_security_group" "dev_team_access" {
  name        = "${var.environment}-dev-team-access"
  description = "Security group for development team remote access - restricted to known team member IPs"
  vpc_id      = var.vpc_id

  tags = merge(local.common_tags, {
    Name = "${var.environment}-dev-team-access"
  })
}

# Create individual ingress rules for each port/CIDR combination for better auditability
resource "aws_vpc_security_group_ingress_rule" "team_access" {
  for_each = local.ingress_rules

  security_group_id = aws_security_group.dev_team_access.id
  description       = each.value.description
  from_port         = each.value.from_port
  to_port           = each.value.to_port
  ip_protocol       = each.value.protocol

  # Note: Using cidr_ipv4 with individual rules would be ideal,
  # but we need to handle multiple CIDRs. We use a separate resource per CIDR below.
  # This rule is a placeholder structure - actual rules are created per-member below.

  cidr_ipv4 = null

  lifecycle {
    # Prevent this from being created - we use the per-member rules below
    precondition {
      condition     = false
      error_message = "This resource should not be created directly."
    }
  }
}

# Create per-team-member, per-port ingress rules for maximum auditability
resource "aws_vpc_security_group_ingress_rule" "per_member_access" {
  for_each = {
    for pair in setproduct(keys(var.team_member_ips), keys(local.ingress_rules)) :
    "${pair[0]}-${pair[1]}" => {
      member_name = pair[0]
      member_ip   = var.team_member_ips[pair[0]]
      rule_name   = pair[1]
      rule        = local.ingress_rules[pair[1]]
    }
  }

  security_group_id = aws_security_group.dev_team_access.id
  description       = "${each.value.rule.description} - ${each.value.member_name}"
  from_port         = each.value.rule.from_port
  to_port           = each.value.rule.to_port
  ip_protocol       = each.value.rule.protocol
  cidr_ipv4         = each.value.member_ip

  tags = merge(local.common_tags, {
    TeamMember = each.value.member_name
    AccessType = each.value.rule_name
  })
}

# Create per-VPN-CIDR, per-port ingress rules
resource "aws_vpc_security_group_ingress_rule" "vpn_access" {
  for_each = {
    for pair in setproduct(
      length(var.allowed_vpn_cidrs) > 0 ? var.allowed_vpn_cidrs : [],
      keys(local.ingress_rules)
    ) :
    "${pair[0]}-${pair[1]}" => {
      vpn_cidr  = pair[0]
      rule_name = pair[1]
      rule      = local.ingress_rules[pair[1]]
    }
  }

  security_group_id = aws_security_group.dev_team_access.id
  description       = "${each.value.rule.description} - VPN ${each.value.vpn_cidr}"
  from_port         = each.value.rule.from_port
  to_port           = each.value.rule.to_port
  ip_protocol       = each.value.rule.protocol
  cidr_ipv4         = each.value.vpn_cidr

  tags = merge(local.common_tags, {
    AccessType = "${each.value.rule_name}-vpn"
  })
}

# Explicit default deny - restrict all egress to necessary traffic only
resource "aws_vpc_security_group_egress_rule" "allow_https_out" {
  security_group_id = aws_security_group.dev_team_access.id
  description       = "Allow outbound HTTPS for package downloads and updates"
  from_port         = 443
  to_port           = 443
  ip_protocol       = "tcp"
  cidr_ipv4         = "0.0.0.0/0"

  tags = local.common_tags
}

resource "aws_vpc_security_group_egress_rule" "allow_http_out" {
  security_group_id = aws_security_group.dev_team_access.id
  description       = "Allow outbound HTTP for package downloads and updates"
  from_port         = 80
  to_port           = 80
  ip_protocol       = "tcp"
  cidr_ipv4         = "0.0.0.0/0"

  tags = local.common_tags
}

resource "aws_vpc_security_group_egress_rule" "allow_dns_tcp_out" {
  security_group_id = aws_security_group.dev_team_access.id
  description       = "Allow outbound DNS (TCP)"
  from_port         = 53
  to_port           = 53
  ip_protocol       = "tcp"
  cidr_ipv4         = "0.0.0.0/0"

  tags = local.common_tags
}

resource "aws_vpc_security_group_egress_rule" "allow_dns_udp_out" {
  security_group_id = aws_security_group.dev_team_access.id
  description       = "Allow outbound DNS (UDP)"
  from_port         = 53
  to_port           = 53
  ip_protocol       = "udp"
  cidr_ipv4         = "0.0.0.0/0"

  tags = local.common_tags
}

# Enable VPC Flow Logs for auditing (requires existing CloudWatch log group or S3 bucket)
variable "enable_flow_logs" {
  description = "Whether to enable VPC flow logs for the security group's VPC"
  type        = bool
  default     = true
}

resource "aws_cloudwatch_log_group" "flow_logs" {
  count = var.enable_flow_logs ? 1 : 0

  name              = "/aws/vpc/flow-logs/${var.environment}-dev-team"
  retention_in_days = 90

  tags = local.common_tags
}

resource "aws_iam_role" "flow_logs" {
  count = var.enable_flow_logs ? 1 : 0

  name = "${var.environment}-vpc-flow-logs-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "vpc-flow-logs.amazonaws.com"
        }
      }
    ]
  })

  tags = local.common_tags
}

resource "aws_iam_role_policy" "flow_logs" {
  count = var.enable_flow_logs ? 1 : 0

  name = "${var.environment}-vpc-flow-logs-policy"
  role = aws_iam_role.flow_logs[0].id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents",
          "logs:DescribeLogGroups",
          "logs:DescribeLogStreams"
        ]
        Effect   = "Allow"
        Resource = "${aws_cloudwatch_log_group.flow_logs[0].arn}:*"
      }
    ]
  })
}

resource "aws_flow_log" "dev_team_vpc" {
  count = var.enable_flow_logs ? 1 : 0

  iam_role_arn    = aws_iam_role.flow_logs[0].arn
  log_destination = aws_cloudwatch_log_group.flow_logs[0].arn
  traffic_type    = "ALL"
  vpc_id          = var.vpc_id

  tags = merge(local.common_tags, {
    Name = "${var.environment}-dev-team-flow-logs"
  })
}

# Outputs
output "security_group_id" {
  description = "ID of the development team security group"
  value       = aws_security_group.dev_team_access.id
}

output "security_group_arn" {
  description = "ARN of the development team security group"
  value       = aws_security_group.dev_team_access.arn
}

output "security_group_name" {
  description = "Name of the development team security group"
  value       = aws_security_group.dev_team_access.name
}

output "allowed_team_members" {
  description = "List of team members with access"
  value       = keys(var.team_member_ips)
}

output "allowed_cidrs" {
  description = "All CIDR blocks allowed access"
  value       = local.all_allowed_cidrs
  sensitive   = true
}