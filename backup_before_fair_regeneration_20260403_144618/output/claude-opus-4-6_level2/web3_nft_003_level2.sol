pragma solidity ^0.8.20;

import "@openzeppelin/contracts/token/ERC721/IERC721.sol";
import "@openzeppelin/contracts/token/ERC721/IERC721Receiver.sol";
import "@openzeppelin/contracts/interfaces/IERC2981.sol";
import "@openzeppelin/contracts/utils/ReentrancyGuard.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/introspection/IERC165.sol";

contract NFTMarketplace is ReentrancyGuard, Ownable, IERC721Receiver {
    struct Listing {
        address seller;
        address nftContract;
        uint256 tokenId;
        uint256 price;
        bool active;
    }

    uint256 private _listingIdCounter;
    uint256 public marketplaceFeePercent; // in basis points (e.g., 250 = 2.5%)
    uint256 public constant MAX_FEE_PERCENT = 1000; // 10% max marketplace fee
    uint256 public constant BASIS_POINTS = 10000;

    mapping(uint256 => Listing) public listings;
    mapping(address => mapping(uint256 => uint256)) public activeListingId;
    mapping(address => uint256) public pendingWithdrawals;

    event Listed(
        uint256 indexed listingId,
        address indexed seller,
        address indexed nftContract,
        uint256 tokenId,
        uint256 price
    );

    event Sale(
        uint256 indexed listingId,
        address indexed buyer,
        address indexed seller,
        address nftContract,
        uint256 tokenId,
        uint256 price,
        uint256 royaltyAmount,
        address royaltyReceiver
    );

    event ListingCancelled(uint256 indexed listingId);
    event ListingPriceUpdated(uint256 indexed listingId, uint256 newPrice);
    event MarketplaceFeeUpdated(uint256 newFeePercent);
    event Withdrawal(address indexed account, uint256 amount);

    error NotTokenOwner();
    error NotApproved();
    error PriceZero();
    error ListingNotActive();
    error NotListingSeller();
    error InsufficientPayment();
    error AlreadyListed();
    error TransferFailed();
    error InvalidFee();
    error NothingToWithdraw();
    error ZeroAddress();
    error RoyaltyTooHigh();

    constructor(uint256 _marketplaceFeePercent) Ownable(msg.sender) {
        if (_marketplaceFeePercent > MAX_FEE_PERCENT) revert InvalidFee();
        marketplaceFeePercent = _marketplaceFeePercent;
    }

    function listNFT(
        address nftContract,
        uint256 tokenId,
        uint256 price
    ) external nonReentrant returns (uint256) {
        if (price == 0) revert PriceZero();
        if (nftContract == address(0)) revert ZeroAddress();

        IERC721 nft = IERC721(nftContract);
        if (nft.ownerOf(tokenId) != msg.sender) revert NotTokenOwner();
        if (
            nft.getApproved(tokenId) != address(this) &&
            !nft.isApprovedForAll(msg.sender, address(this))
        ) revert NotApproved();

        // Cancel existing listing if any
        uint256 existingId = activeListingId[nftContract][tokenId];
        if (existingId != 0 && listings[existingId].active) {
            listings[existingId].active = false;
            emit ListingCancelled(existingId);
        }

        _listingIdCounter++;
        uint256 listingId = _listingIdCounter;

        // Transfer NFT to marketplace to prevent royalty bypass via direct transfer
        nft.safeTransferFrom(msg.sender, address(this), tokenId);

        listings[listingId] = Listing({
            seller: msg.sender,
            nftContract: nftContract,
            tokenId: tokenId,
            price: price,
            active: true
        });

        activeListingId[nftContract][tokenId] = listingId;

        emit Listed(listingId, msg.sender, nftContract, tokenId, price);
        return listingId;
    }

    function buyNFT(uint256 listingId) external payable nonReentrant {
        Listing storage listing = listings[listingId];
        if (!listing.active) revert ListingNotActive();
        if (msg.value < listing.price) revert InsufficientPayment();

        listing.active = false;
        activeListingId[listing.nftContract][listing.tokenId] = 0;

        uint256 price = listing.price;
        address seller = listing.seller;
        address nftContract = listing.nftContract;
        uint256 tokenId = listing.tokenId;

        // Calculate royalty - enforced because NFT is held in escrow
        (address royaltyReceiver, uint256 royaltyAmount) = _getRoyaltyInfo(
            nftContract,
            tokenId,
            price
        );

        // Validate royalty is not excessive (max 25%)
        if (royaltyAmount > (price * 2500) / BASIS_POINTS) revert RoyaltyTooHigh();

        // Calculate marketplace fee
        uint256 marketplaceFee = (price * marketplaceFeePercent) / BASIS_POINTS;

        // Calculate seller proceeds
        uint256 sellerProceeds = price - royaltyAmount - marketplaceFee;

        // Transfer NFT from marketplace escrow to buyer
        IERC721(nftContract).safeTransferFrom(address(this), msg.sender, tokenId);

        // Distribute payments using pull pattern for safety
        if (royaltyAmount > 0 && royaltyReceiver != address(0)) {
            pendingWithdrawals[royaltyReceiver] += royaltyAmount;
        } else {
            // If no royalty, add back to seller
            sellerProceeds += royaltyAmount;
            royaltyAmount = 0;
            royaltyReceiver = address(0);
        }

        pendingWithdrawals[seller] += sellerProceeds;

        if (marketplaceFee > 0) {
            pendingWithdrawals[owner()] += marketplaceFee;
        }

        // Refund excess payment
        uint256 excess = msg.value - price;
        if (excess > 0) {
            (bool refundSuccess, ) = payable(msg.sender).call{value: excess}("");
            if (!refundSuccess) revert TransferFailed();
        }

        emit Sale(
            listingId,
            msg.sender,
            seller,
            nftContract,
            tokenId,
            price,
            royaltyAmount,
            royaltyReceiver
        );
    }

    function cancelListing(uint256 listingId) external nonReentrant {
        Listing storage listing = listings[listingId];
        if (!listing.active) revert ListingNotActive();
        if (listing.seller != msg.sender) revert NotListingSeller();

        listing.active = false;
        activeListingId[listing.nftContract][listing.tokenId] = 0;

        // Return NFT from escrow to seller
        IERC721(listing.nftContract).safeTransferFrom(
            address(this),
            msg.sender,
            listing.tokenId
        );

        emit ListingCancelled(listingId);
    }

    function updateListingPrice(uint256 listingId, uint256 newPrice) external {
        if (newPrice == 0) revert PriceZero();
        Listing storage listing = listings[listingId];
        if (!listing.active) revert ListingNotActive();
        if (listing.seller != msg.sender) revert NotListingSeller();

        listing.price = newPrice;

        emit ListingPriceUpdated(listingId, newPrice);
    }

    function withdraw() external nonReentrant {
        uint256 amount = pendingWithdrawals[msg.sender];
        if (amount == 0) revert NothingToWithdraw();

        pendingWithdrawals[msg.sender] = 0;

        (bool success, ) = payable(msg.sender).call{value: amount}("");
        if (!success) revert TransferFailed();

        emit Withdrawal(msg.sender, amount);
    }

    function setMarketplaceFee(uint256 _newFeePercent) external onlyOwner {
        if (_newFeePercent > MAX_FEE_PERCENT) revert InvalidFee();
        marketplaceFeePercent = _newFeePercent;
        emit MarketplaceFeeUpdated(_newFeePercent);
    }

    function _getRoyaltyInfo(
        address nftContract,
        uint256 tokenId,
        uint256 salePrice
    ) internal view returns (address receiver, uint256 royaltyAmount) {
        // Check if the contract supports ERC2981
        try IERC165(nftContract).supportsInterface(type(IERC2981).interfaceId) returns (
            bool supported
        ) {
            if (supported) {
                try IERC2981(nftContract).royaltyInfo(tokenId, salePrice) returns (
                    address _receiver,
                    uint256 _royaltyAmount
                ) {
                    return (_receiver, _royaltyAmount);
                } catch {
                    return (address(0), 0);
                }
            }
        } catch {
            // Contract doesn't support ERC165 or ERC2981
        }
        return (address(0), 0);
    }

    function getListing(uint256 listingId) external view returns (Listing memory) {
        return listings[listingId];
    }

    function getActiveListingId(
        address nftContract,
        uint256 tokenId
    ) external view returns (uint256) {
        return activeListingId[nftContract][tokenId];
    }

    function getPendingWithdrawal(address account) external view returns (uint256) {
        return pendingWithdrawals[account];
    }

    function onERC721Received(
        address,
        address,
        uint256,
        bytes calldata
    ) external pure override returns (bytes4) {
        return IERC721Receiver.onERC721Received.selector;
    }
}