    function repay(address _token, uint256 _amount)
        external
        nonReentrant
        whenNotPaused
        marketExists(_token)
    {
        require(_amount > 0, "Zero amount");

        _accrueInterest(_token);
        _updateUserBorrowIndex(msg.sender, _token);

        uint256 currentBorrow = _getCurrentBorrowBalance(msg.sender, _token);
        uint256 repayAmount = _amount > currentBorrow ? currentBorrow : _amount;

        IERC20(_token).safeTransferFrom(msg.sender, address(this), repayAmount);

        userAccounts[msg.sender].borrows[_token] -= repayAmount;
        markets[_token].totalBorrows -= repayAmount;

        emit Repay(msg.sender, _token, repayAmount);
    }

    /**
     * @notice Liquidate an unhealthy account
     * @param _borrower The address of the unhealthy borrower
     * @param _debtToken The token the borrower owes
     * @param _collateralToken The collateral token to seize
     * @param _repayAmount The amount of debt to repay
     */
    function liquidate(
        address _borrower,
        address _debtToken,
        address _collateralToken,
        uint256 _repayAmount
    )
        external
        nonReentrant
        whenNotPaused
        marketExists(_debtToken)
        marketExists(_collateralToken)
    {
        require(_borrower != msg.sender, "Cannot self-liquidate");
        require(_repayAmount > 0, "Zero repay amount");

        _accrueInterest(_debtToken);
        _accrueInterest(_collateralToken);
        _updateUserBorrowIndex(_borrower, _debtToken);

        // Verify borrower is unhealthy (using liquidation threshold)
        require(!_isAccountHealthyForLiquidation(_borrower), "Account is healthy");

        uint256 currentBorrow = _getCurrentBorrowBalance(_borrower, _debtToken);

        // Can only repay up to 50% of the borrow in a single liquidation (close factor)
        uint256 maxRepay = currentBorrow / 2;
        uint256 actualRepay = _repayAmount > maxRepay ? maxRepay : _repayAmount;

        // Calculate collateral to seize
        uint256 debtPrice = _getValidatedPrice(_debtToken);
        uint256 collateralPrice = _getValidatedPrice(_collateralToken);

        uint256 liquidationBonus = markets[_collateralToken].liquidationBonusBps;
        uint256 debtValueInCollateral = (actualRepay * debtPrice) / collateralPrice;
        uint256 collateralToSeize = (debtValueInCollateral * (BPS_DENOMINATOR + liquidationBonus)) / BPS_DENOMINATOR;

        require(
            userAccounts[_borrower].deposits[_collateralToken] >= collateralToSeize,
            "Insufficient collateral to seize"
        );

        // Transfer debt from liquidator
        IERC20(_debtToken).safeTransferFrom(msg.sender, address(this), actualRepay);

        // Update borrower state
        userAccounts[_borrower].borrows[_debtToken] -= actualRepay;
        markets[_debtToken].totalBorrows -= actualRepay;

        userAccounts[_borrower].deposits[_collateralToken] -= collateralToSeize;
        markets[_collateralToken].totalDeposits -= collateralToSeize;

        // Transfer seized collateral to liquidator
        IERC20(_collateralToken).safeTransfer(msg.sender, collateralToSeize);

        emit Liquidation(msg.sender, _borrower, _collateralToken, _debtToken, actualRepay, collateralToSeize);
    }

    // --- Price Oracle Functions with Manipulation Protection ---

    /**
