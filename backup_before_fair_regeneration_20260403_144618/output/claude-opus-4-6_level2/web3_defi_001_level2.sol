        }

        if (userAccounts[_user].borrows[_token] > 0 && userIndex < currentIndex) {
            // Apply accumulated interest to user's borrow
            uint256 principalBorrow = userAccounts[_user].borrows[_token];
            uint256 newBorrow = (principalBorrow * currentIndex) / userIndex;
            userAccounts[_user].borrows[_token] = newBorrow;
        }

        userAccounts[_user].borrowIndex[_token] = currentIndex;
    }

    /**
     * @notice Get current borrow balance including accrued interest
     */
    function _getCurrentBorrowBalance(address _user, address _token) internal view returns (uint256) {
        uint256 principal = userAccounts[_user].borrows[_token];
        if (principal == 0) return 0;

        uint256 userIndex = userAccounts[_user].borrowIndex[_token];
        if (userIndex == 0) return principal;

        uint256 currentIndex = markets[_token].borrowIndex;

        // Also account for unaccrued interest
        uint256 timeElapsed = block.timestamp - markets[_token].lastAccrualTimestamp;
        if (timeElapsed > 0 && markets[_token].totalBorrows > 0) {
            uint256 interestAccumulated = (markets[_token].totalBorrows * markets[_token].borrowRatePerSecond * timeElapsed) / PRICE_PRECISION;
            uint256 indexDelta = (interestAccumulated * INDEX_PRECISION) / markets[_token].totalBorrows;
            currentIndex += indexDelta;
        }

        return (principal * currentIndex) / userIndex;
    }

