        uint256 medianPrice = oracle.getMedianPrice(_token);

        // 3. Cross-validate TWAP and median
        uint256 deviation;
        if (twapPrice > medianPrice) {
            deviation = ((twapPrice - medianPrice) * BPS_DENOMINATOR) / medianPrice;
        } else {
            deviation = ((medianPrice - twapPrice) * BPS_DENOMINATOR) / medianPrice;
        }
        require(deviation <= 500, "TWAP-Median deviation too high"); // 5% max

        // 4. Check against configured price bounds (circuit breaker)
