/**
 * @title TWAPOracle
 * @notice Time-Weighted Average Price oracle to prevent flash loan price manipulation
 * @dev Tracks cumulative prices from a DEX pool and computes TWAP over a configurable window
 */
contract TWAPOracle {
    struct PriceObservation {
        uint256 timestamp;
        uint256 priceCumulativeLast;
        uint256 price; // instantaneous price at observation time (scaled by 1e18)
    }

    struct PairConfig {
        address pool;
        address token0;
        address token1;
        uint256 twapWindow; // minimum TWAP window in seconds
        uint256 maxDeviation; // max allowed deviation between spot and TWAP (basis points, e.g., 500 = 5%)
    }

    mapping(address => PairConfig) public pairConfigs;
    // token => array of observations
    mapping(address => PriceObservation[]) public priceObservations;
    // token => last update timestamp
    mapping(address => uint256) public lastUpdateTimestamp;

    uint256 public constant MIN_TWAP_WINDOW = 15 minutes;
    uint256 public constant MAX_DEVIATION_BPS = 1000; // 10% max deviation allowed
    uint256 public constant PRICE_PRECISION = 1e18;
    uint256 public constant MAX_OBSERVATIONS = 50;

    address public owner;

    event PairConfigured(address indexed token, address pool, uint256 twapWindow);
    event PriceUpdated(address indexed token, uint256 price, uint256 timestamp);

    modifier onlyOwner() {
        require(msg.sender == owner, "TWAPOracle: not owner");
        _;
    }

    constructor() {
        owner = msg.sender;
    }

    function configurePair(
        address _token,
        address _pool,
        address _token0,
        address _token1,
        uint256 _twapWindow,
        uint256 _maxDeviation
    ) external onlyOwner {
        require(_twapWindow >= MIN_TWAP_WINDOW, "TWAPOracle: window too short");
        require(_maxDeviation <= MAX_DEVIATION_BPS, "TWAPOracle: deviation too high");

        pairConfigs[_token] = PairConfig({
            pool: _pool,
            token0: _token0,
            token1: _token1,
            twapWindow: _twapWindow,
            maxDeviation: _maxDeviation
        });

        emit PairConfigured(_token, _pool, _twapWindow);
    }

    /**
     * @notice Record a new price observation from the DEX pool
     * @dev Should be called periodically (e.g., by keepers) to maintain fresh TWAP data
     */
    function updatePrice(address _token) external {
        PairConfig memory config = pairConfigs[_token];
        require(config.pool != address(0), "TWAPOracle: pair not configured");

        uint256 spotPrice = _getSpotPriceFromPool(config.pool, config.token0, config.token1);
        require(spotPrice > 0, "TWAPOracle: invalid spot price");

        PriceObservation[] storage observations = priceObservations[_token];

        // Calculate cumulative price
        uint256 cumulativePrice;
        if (observations.length > 0) {
            PriceObservation memory lastObs = observations[observations.length - 1];
            uint256 timeElapsed = block.timestamp - lastObs.timestamp;
            // Require minimum time between observations to prevent manipulation
            require(timeElapsed >= 1 minutes, "TWAPOracle: too frequent");
            cumulativePrice = lastObs.priceCumulativeLast + (spotPrice * timeElapsed);
        } else {
            cumulativePrice = spotPrice;
        }

        // Prune old observations if we exceed max
        if (observations.length >= MAX_OBSERVATIONS) {
            // Shift array: remove oldest
            for (uint256 i = 0; i < observations.length - 1; i++) {
                observations[i] = observations[i + 1];
            }
            observations.pop();
        }

        observations.push(PriceObservation({
            timestamp: block.timestamp,
            priceCumulativeLast: cumulativePrice,
            price: spotPrice
        }));

        lastUpdateTimestamp[_token] = block.timestamp;

        emit PriceUpdated(_token, spotPrice, block.timestamp);
    }

    /**
     * @notice Get the TWAP price for a token, with manipulation checks
     * @return twapPrice The time-weighted average price (scaled by 1e18)
     */
    function getTWAPPrice(address _token) public view returns (uint256 twapPrice) {
        PairConfig memory config = pairConfigs[_token];
        require(config.pool != address(0), "TWAPOracle: pair not configured");

        PriceObservation[] storage observations = priceObservations[_token];
        require(observations.length >= 2, "TWAPOracle: insufficient observations");

        // Find the observation closest to (now - twapWindow)
        PriceObservation memory latestObs = observations[observations.length - 1];

        // Ensure data is not stale
        require(
            block.timestamp - latestObs.timestamp <= config.twapWindow,
            "TWAPOracle: stale price data"
        );

        // Find the oldest observation within the TWAP window
        uint256 targetTimestamp = block.timestamp - config.twapWindow;
        uint256 oldestValidIndex = 0;
        bool found = false;

        for (uint256 i = 0; i < observations.length; i++) {
            if (observations[i].timestamp <= targetTimestamp) {
                oldestValidIndex = i;
                found = true;
            }
        }

        // If no observation is old enough, use the oldest available
        if (!found) {
            oldestValidIndex = 0;
        }

        PriceObservation memory oldObs = observations[oldestValidIndex];

        uint256 timeElapsed = latestObs.timestamp - oldObs.timestamp;
        require(timeElapsed > 0, "TWAPOracle: zero time elapsed");

        // Calculate TWAP
        twapPrice = (latestObs.priceCumulativeLast - oldObs.priceCumulativeLast) / timeElapsed;

        // Manipulation check: compare spot price with TWAP
        uint256 currentSpotPrice = _getSpotPriceFromPool(config.pool, config.token0, config.token1);
        _checkManipulation(twapPrice, currentSpotPrice, config.maxDeviation);

        return twapPrice;
    }

    /**
     * @notice Check if spot price deviates too much from TWAP (manipulation indicator)
     */
    function _checkManipulation(
        uint256 _twapPrice,
        uint256 _spotPrice,
        uint256 _maxDeviationBps
    ) internal pure {
        uint256 deviation;
        if (_spotPrice > _twapPrice) {
            deviation = ((_spotPrice - _twapPrice) * 10000) / _twapPrice;
        } else {
            deviation = ((_twapPrice - _spotPrice) * 10000) / _twapPrice;
        }
        require(deviation <= _maxDeviationBps, "TWAPOracle: price manipulation detected");
    }

    /**
     * @notice Get spot price from DEX pool using reserve ratios
     */
    function _getSpotPriceFromPool(
        address _pool,
        address _token0,
        address _token1
    ) internal view returns (uint256) {
        uint256 balance0 = IERC20(_token0).balanceOf(_pool);
        uint256 balance1 = IERC20(_token1).balanceOf(_pool);

        require(balance0 > 0 && balance1 > 0, "TWAPOracle: empty pool");

        // Price of token0 in terms of token1, scaled by 1e18
        return (balance1 * PRICE_PRECISION) / balance0;
    }

    /**
     * @notice Get the median price from recent observations as additional manipulation protection
     */
    function getMedianPrice(address _token) public view returns (uint256) {
        PriceObservation[] storage observations = priceObservations[_token];
        require(observations.length >= 3, "TWAPOracle: need at least 3 observations");

        // Take last 5 observations (or fewer if not available)
        uint256 count = observations.length < 5 ? observations.length : 5;
        uint256[] memory prices = new uint256[](count);

        for (uint256 i = 0; i < count; i++) {
            prices[i] = observations[observations.length - count + i].price;
        }

        // Simple bubble sort for small array
        for (uint256 i = 0; i < count - 1; i++) {
            for (uint256 j = 0; j < count - i - 1; j++) {
                if (prices[j] > prices[j + 1]) {
                    uint256 temp = prices[j];
                    prices[j] = prices[j + 1];
                    prices[j + 1] = temp;
                }
            }
        }

        return prices[count / 2];
    }

    function transferOwnership(address _newOwner) external onlyOwner {
        require(_newOwner != address(0), "TWAPOracle: zero address");
        owner = _newOwner;
    }
}

/**
