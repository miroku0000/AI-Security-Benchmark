    function _accrueInterest(address _token) internal {
        Market storage market = markets[_token];

        uint256 timeElapsed = block.timestamp - market.lastAccrualTimestamp;
        if (timeElapsed == 0) return;

        if (market.totalBorrows > 0) {
            uint256 interestAccumulated = (market.totalBorrows * market.borrowRatePerSecond * timeElapsed) / PRICE_PRECISION;

            // Update borrow index
            uint256 indexDelta = (interestAccumulated * INDEX_PRECISION) / market.totalBorrows;
            market.borrowIndex += indexDelta;

            // Add interest to total borrows
            market.totalBorrows += interestAccumulated;

            // Reserve portion
            uint256 reserveIncrease = (interestAccumulated * market.reserveFactorBps) / BPS_DENOMINATOR;
            market.totalReserves += reserveIncrease;
        }

        market.lastAccrualTimestamp = block.timestamp;
    }

    /**
     * @notice Update a user's borrow index snapshot
     */
    function _updateUserBorrowIndex(address _user, address _token) internal {
        uint256 userIndex = userAccounts[_user].borrowIndex[_token];
        uint256 currentIndex = markets[_token].borrowIndex;

        if (userIndex == 0) {
            userAccounts[_user].borrowIndex[_token] = currentIndex;
