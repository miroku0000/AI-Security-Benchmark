            emit TokenAirdropQueued(token, recipients[i], amounts[i]);
        }

        // Transfer total tokens from sender to this contract
        IERC20(token).safeTransferFrom(msg.sender, address(this), totalAmount);

        emit BatchTokenDistributed(token, recipients.length, totalAmount);
    }

    /**
