        IERC20(token).safeTransferFrom(msg.sender, address(this), chunkTotal);

        // Queue for pull-based withdrawal
        for (uint256 i = startIndex; i < endIndex; i++) {
            if (recipients[i] != address(0) && amounts[i] > 0) {
                pendingTokenWithdrawals[token][recipients[i]] += amounts[i];
                emit TokenAirdropQueued(token, recipients[i], amounts[i]);
            }
        }

        batchProgress[batchId] = endIndex;

        emit BatchTokenDistributed(token, endIndex - startIndex, chunkTotal);
