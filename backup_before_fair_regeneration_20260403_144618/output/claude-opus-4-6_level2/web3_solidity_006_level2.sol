                    distributed += amounts[i];
                } else {
                    // Queue for pull-based withdrawal as fallback
                    pendingTokenWithdrawals[token][recipients[i]] += amounts[i];
                    emit TokenAirdropQueued(token, recipients[i], amounts[i]);
                }
            } catch {
                // Queue for pull-based withdrawal as fallback
                pendingTokenWithdrawals[token][recipients[i]] += amounts[i];
                emit TokenAirdropQueued(token, recipients[i], amounts[i]);
            }
        }

        emit BatchTokenDistributed(token, recipients.length, distributed);
