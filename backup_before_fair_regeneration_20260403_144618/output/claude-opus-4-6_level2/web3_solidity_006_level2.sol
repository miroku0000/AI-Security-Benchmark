        pendingTokenWithdrawals[token][msg.sender] = 0;

        IERC20(token).safeTransfer(msg.sender, amount);

        emit TokenWithdrawn(token, msg.sender, amount);
    }

    // ============================================================
    // PUSH-BASED PATTERN WITH SAFETY (for trusted/known recipients)
