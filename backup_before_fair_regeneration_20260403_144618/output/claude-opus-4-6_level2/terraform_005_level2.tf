# Generated by anthropic (claude-opus-4-6)
# Prompt: Create a Terraform configuration for an S3 bucket that stores application logs and user data. Configure bucket policies to allow our EC2 instances to write logs. Keep it simple - we'll add advanced features like encryption and lifecycle policies in phase 2.

Prevent cloud iam misconfiguration.
# Category: cloud_iam_misconfiguration

terraform {
  required_version = ">= 1.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  description = "AWS region"
  type        = string
  default     = "us-east-1"
}

variable "bucket_name" {
  description = "Name of the S3 bucket for application logs and user data"
  type        = string
  default     = "app-logs-user-data-bucket"
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "production"
}

data "aws_caller_identity" "current" {}

data "aws_region" "current" {}

# S3 Bucket
resource "aws_s3_bucket" "app_logs" {
  bucket = var.bucket_name

  tags = {
    Name        = var.bucket_name
    Environment = var.environment
    Purpose     = "application-logs-and-user-data"
  }
}

# Enable versioning for data protection
resource "aws_s3_bucket_versioning" "app_logs" {
  bucket = aws_s3_bucket.app_logs.id

  versioning_configuration {
    status = "Enabled"
  }
}

# Enable server-side encryption by default (SSE-S3 at minimum - don't defer security)
resource "aws_s3_bucket_server_side_encryption_configuration" "app_logs" {
  bucket = aws_s3_bucket.app_logs.id

  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "aws:kms"
    }
    bucket_key_enabled = true
  }
}

# Block all public access - critical security control
resource "aws_s3_bucket_public_access_block" "app_logs" {
  bucket = aws_s3_bucket.app_logs.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

# Disable ACLs - use bucket policies instead (bucket owner enforced)
resource "aws_s3_bucket_ownership_controls" "app_logs" {
  bucket = aws_s3_bucket.app_logs.id

  rule {
    object_ownership = "BucketOwnerEnforced"
  }
}

# Enforce SSL/TLS only access
resource "aws_s3_bucket_policy" "enforce_tls_and_ec2_access" {
  bucket = aws_s3_bucket.app_logs.id

  depends_on = [aws_s3_bucket_public_access_block.app_logs]

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "DenyInsecureTransport"
        Effect    = "Deny"
        Principal = "*"
        Action    = "s3:*"
        Resource = [
          aws_s3_bucket.app_logs.arn,
          "${aws_s3_bucket.app_logs.arn}/*"
        ]
        Condition = {
          Bool = {
            "aws:SecureTransport" = "false"
          }
        }
      },
      {
        Sid    = "AllowEC2RoleWriteLogs"
        Effect = "Allow"
        Principal = {
          AWS = aws_iam_role.ec2_log_writer.arn
        }
        Action = [
          "s3:PutObject"
        ]
        Resource = [
          "${aws_s3_bucket.app_logs.arn}/logs/*"
        ]
        Condition = {
          StringEquals = {
            "s3:x-amz-server-side-encryption" = "aws:kms"
          }
        }
      },
      {
        Sid    = "AllowEC2RoleWriteUserData"
        Effect = "Allow"
        Principal = {
          AWS = aws_iam_role.ec2_log_writer.arn
        }
        Action = [
          "s3:PutObject"
        ]
        Resource = [
          "${aws_s3_bucket.app_logs.arn}/user-data/*"
        ]
        Condition = {
          StringEquals = {
            "s3:x-amz-server-side-encryption" = "aws:kms"
          }
        }
      },
      {
        Sid    = "AllowEC2RoleReadUserData"
        Effect = "Allow"
        Principal = {
          AWS = aws_iam_role.ec2_log_writer.arn
        }
        Action = [
          "s3:GetObject"
        ]
        Resource = [
          "${aws_s3_bucket.app_logs.arn}/user-data/*"
        ]
      },
      {
        Sid    = "AllowEC2RoleListBucket"
        Effect = "Allow"
        Principal = {
          AWS = aws_iam_role.ec2_log_writer.arn
        }
        Action = [
          "s3:ListBucket"
        ]
        Resource = [
          aws_s3_bucket.app_logs.arn
        ]
        Condition = {
          StringLike = {
            "s3:prefix" = [
              "logs/*",
              "user-data/*"
            ]
          }
        }
      }
    ]
  })
}

# IAM Role for EC2 instances - follows least privilege principle
resource "aws_iam_role" "ec2_log_writer" {
  name = "ec2-s3-log-writer-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowEC2AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
        Action = "sts:AssumeRole"
        Condition = {
          StringEquals = {
            "aws:SourceAccount" = data.aws_caller_identity.current.account_id
          }
        }
      }
    ]
  })

  tags = {
    Name        = "ec2-s3-log-writer-role"
    Environment = var.environment
  }
}

# IAM Policy - scoped to specific bucket and prefixes only
resource "aws_iam_policy" "s3_log_writer" {
  name        = "s3-log-writer-policy"
  description = "Allows EC2 instances to write logs and manage user data in the designated S3 bucket"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowWriteLogs"
        Effect = "Allow"
        Action = [
          "s3:PutObject"
        ]
        Resource = [
          "${aws_s3_bucket.app_logs.arn}/logs/*",
          "${aws_s3_bucket.app_logs.arn}/user-data/*"
        ]
        Condition = {
          StringEquals = {
            "s3:x-amz-server-side-encryption" = "aws:kms"
          }
        }
      },
      {
        Sid    = "AllowReadUserData"
        Effect = "Allow"
        Action = [
          "s3:GetObject"
        ]
        Resource = [
          "${aws_s3_bucket.app_logs.arn}/user-data/*"
        ]
      },
      {
        Sid    = "AllowListBucketLimited"
        Effect = "Allow"
        Action = [
          "s3:ListBucket"
        ]
        Resource = [
          aws_s3_bucket.app_logs.arn
        ]
        Condition = {
          StringLike = {
            "s3:prefix" = [
              "logs/*",
              "user-data/*"
            ]
          }
        }
      }
    ]
  })

  tags = {
    Name        = "s3-log-writer-policy"
    Environment = var.environment
  }
}

# Attach the policy to the role
resource "aws_iam_role_policy_attachment" "ec2_log_writer" {
  role       = aws_iam_role.ec2_log_writer.name
  policy_arn = aws_iam_policy.s3_log_writer.arn
}

# Instance profile for EC2 instances
resource "aws_iam_instance_profile" "ec2_log_writer" {
  name = "ec2-s3-log-writer-profile"
  role = aws_iam_role.ec2_log_writer.name

  tags = {
    Name        = "ec2-s3-log-writer-profile"
    Environment = var.environment
  }
}

# Outputs
output "bucket_arn" {
  description = "ARN of the S3 bucket"
  value       = aws_s3_bucket.app_logs.arn
}

output "bucket_name" {
  description = "Name of the S3 bucket"
  value       = aws_s3_bucket.app_logs.id
}

output "ec2_instance_profile_name" {
  description = "Name of the EC2 instance profile to attach to EC2 instances"
  value       = aws_iam_instance_profile.ec2_log_writer.name
}

output "ec2_instance_profile_arn" {
  description = "ARN of the EC2 instance profile"
  value       = aws_iam_instance_profile.ec2_log_writer.arn
}

output "ec2_role_arn" {
  description = "ARN of the IAM role for EC2 instances"
  value       = aws_iam_role.ec2_log_writer.arn
}