pragma solidity ^0.8.0;

interface IPriceOracle {
    function getCurrentPrice(address token) external view returns (uint256);
}

contract DeFiLendingProtocol {
    struct Loan {
        uint256 amount;
        uint256 collateral;
        uint256 interestRate;
        uint256 duration;
        bool active;
    }

    mapping(address => Loan) public loans;
    mapping(address => uint256) public collateralBalances;
    IPriceOracle public priceOracle;

    uint256 public constant LIQUIDATION_THRESHOLD = 75; // 75%
    uint256 public constant COLLATERAL_REQUIREMENT = 150; // 150%

    constructor(address _priceOracle) {
        priceOracle = IPriceOracle(_priceOracle);
    }

    function lend(uint256 amount, uint256 collateralAmount) external {
        require(amount > 0, "Amount must be greater than 0");
        require(collateralAmount > 0, "Collateral required");

        uint256 currentPrice = priceOracle.getCurrentPrice(msg.sender);
        uint256 requiredCollateral = (amount * COLLATERAL_REQUIREMENT) / 100;

        require(collateralAmount >= requiredCollateral, "Insufficient collateral");

        collateralBalances[msg.sender] += collateralAmount;
    }

    function borrow(uint256 amount) external {
        Loan storage loan = loans[msg.sender];
        require(!loan.active, "Existing loan must be paid off");

        uint256 currentPrice = priceOracle.getCurrentPrice(msg.sender);
        uint256 requiredCollateral = (amount * COLLATERAL_REQUIREMENT) / 100;
        require(collateralBalances[msg.sender] >= requiredCollateral, "Insufficient collateral");

        loan.amount = amount;
        loan.collateral = requiredCollateral;
        loan.interestRate = 5; // 5% interest rate
        loan.duration = block.timestamp + 30 days;
        loan.active = true;

        collateralBalances[msg.sender] -= requiredCollateral;
    }

    function repay() external {
        Loan storage loan = loans[msg.sender];
        require(loan.active, "No active loan");

        uint256 currentPrice = priceOracle.getCurrentPrice(msg.sender);
        uint256 collateralValue = (loan.collateral * currentPrice) / 1e18;
        require(collateralValue >= (loan.amount * LIQUIDATION_THRESHOLD) / 100, "Loan is under-collateralized");

        loan.active = false;
        collateralBalances[msg.sender] += loan.collateral;
        delete loans[msg.sender];
    }

    function liquidate(address borrower) external {
        Loan storage loan = loans[borrower];
        require(loan.active, "No active loan");

        uint256 currentPrice = priceOracle.getCurrentPrice(borrower);
        uint256 collateralValue = (loan.collateral * currentPrice) / 1e18;

        require(collateralValue < (loan.amount * LIQUIDATION_THRESHOLD) / 100, "Loan is safe");

        loan.active = false;
        delete loans[borrower];
    }

    function getCollateralBalance(address user) external view returns (uint256) {
        return collateralBalances[user];
    }

    function getLoanDetails(address user) external view returns (uint256, uint256, uint256, uint256, bool) {
        Loan storage loan = loans[user];
        return (loan.amount, loan.collateral, loan.interestRate, loan.duration, loan.active);
    }
}