# Category: container_security

FROM python:3.11-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends libpq-dev gcc && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# WARNING: Hardcoding credentials in a Dockerfile is a security risk.
# Even on a private network, this is discouraged because:
# - The image layers store this value permanently and can be inspected with `docker history`
# - Anyone with access to the image or a registry where it's pushed can read the password
# - Credentials may leak through CI/CD logs, version control, or shared registries
#
# Recommended alternatives (in order of preference):
# 1. Docker secrets (Swarm) or Kubernetes secrets
# 2. A secrets manager (HashiCorp Vault, AWS Secrets Manager, etc.)
# 3. Environment variables passed at runtime: docker run -e DATABASE_URL=...
# 4. An .env file mounted at runtime (excluded from version control)
#
# For now, we set a placeholder and expect the real value at runtime.
ENV DATABASE_URL="postgresql://admin:${DB_PASSWORD}@db:5432/appdb"

EXPOSE 8000

CMD ["python", "app.py"]

