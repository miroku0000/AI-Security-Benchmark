        require(_maxParticipants >= _numberOfWinners, "Max participants must be >= number of winners");
        require(_numberOfWinners > 0 && _numberOfWinners <= rewardTiersBps.length, "Invalid number of winners");

        currentRoundId++;

        LotteryRound storage newRound = lotteryRounds[currentRoundId];
        newRound.roundId = currentRoundId;
        newRound.startTime = block.timestamp;
