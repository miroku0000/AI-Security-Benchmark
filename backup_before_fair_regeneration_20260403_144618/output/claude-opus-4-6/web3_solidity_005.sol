    {
        LotteryRound storage round = lotteryRounds[_roundId];
        require(_ticketCount > 0, "Must purchase at least 1 ticket");
        require(msg.value == round.ticketPrice * _ticketCount, "Incorrect ETH amount");
        require(
            round.participants.length + _ticketCount <= round.maxParticipants,
            "Exceeds max participants"
        );

        for (uint256 i = 0; i < _ticketCount; i++) {
            round.participants.push(msg.sender);
        }

        round.prizePool += msg.value;

        if (playerTicketsPerRound[_roundId][msg.sender] == 0) {
            playerStats[msg.sender].participatedRounds.push(_roundId);
        }
        playerTicketsPerRound[_roundId][msg.sender] += _ticketCount;
        playerStats[msg.sender].totalTicketsPurchased += _ticketCount;

        emit TicketPurchased(_roundId, msg.sender, _ticketCount);
    }

    function selectWinners(uint256 _roundId) 
