    {
        LotteryRound storage round = lotteryRounds[_roundId];
        require(round.isActive, "Round is not active");
        require(!round.isFinalized, "Round already finalized");
        require(block.timestamp > round.endTime || round.participants.length == round.maxParticipants, "Round not ended yet");
        require(round.participants.length >= round.numberOfWinners, "Not enough participants");

        round.isActive = false;
        round.isFinalized = true;

        // Calculate platform fee
        uint256 platformFee = (round.prizePool * platformFeePercent) / 100;
        accumulatedFees += platformFee;
        uint256 distributablePrize = round.prizePool - platformFee;

        // Generate random numbers and select unique winners
        uint256[] memory randomNumbers = _generateMultipleRandomNumbers(
            round.numberOfWinners, 
            uint256(uint160(address(this))) + _roundId
        );

        address[] memory selectedWinners = new address[](round.numberOfWinners);
        uint256[] memory rewards = new uint256[](round.numberOfWinners);

        // Create a working copy of participants for Fisher-Yates style selection
        uint256 remainingParticipants = round.participants.length;

        for (uint256 i = 0; i < round.numberOfWinners; i++) {
            uint256 winnerIndex = randomNumbers[i] % remainingParticipants;
            selectedWinners[i] = round.participants[winnerIndex];

            // Calculate reward based on tier
            rewards[i] = (distributablePrize * rewardTiersBps[i]) / 10000;

            // Swap selected participant with last unselected to avoid duplicates
            round.participants[winnerIndex] = round.participants[remainingParticipants - 1];
            remainingParticipants--;

            // Update player stats
            playerStats[selectedWinners[i]].totalWins++;
            playerStats[selectedWinners[i]].totalRewardsEarned += rewards[i];
        }

        round.winners = selectedWinners;
        round.rewardAmounts = rewards;

        emit WinnersSelected(_roundId, selectedWinners, rewards);
    }

    function claimReward(uint256 _roundId) 
        external 
        nonReentrant 
        roundExists(_roundId) 
    {
        LotteryRound storage round = lotteryRounds[_roundId];
        require(round.isFinalized, "Round not finalized");
        require(!hasClaimedReward[_roundId][msg.sender], "Already claimed");

        uint256 totalReward = 0;
        for (uint256 i = 0; i < round.winners.length; i++) {
            if (round.winners[i] == msg.sender) {
                totalReward += round.rewardAmounts[i];
            }
        }

        require(totalReward > 0, "Not a winner");

        hasClaimedReward[_roundId][msg.sender] = true;

        (bool success, ) = payable(msg.sender).call{value: totalReward}("");
        require(success, "Transfer failed");

        emit RewardClaimed(_roundId, msg.sender, totalReward);
    }

    function cancelRound(uint256 _roundId) 
        external 
        onlyOwner 
        nonReentrant 
        roundExists(_roundId) 
    {
        LotteryRound storage round = lotteryRounds[_roundId];
        require(round.isActive, "Round not active");
        require(!round.isFinalized, "Round already finalized");

        round.isActive = false;
        round.isFinalized = true;

        // Refund all participants
        // Track refunded addresses to handle multiple tickets
        mapping(address => bool) storage refunded = hasClaimedReward[_roundId];

        address[] memory uniqueParticipants = new address[](round.participants.length);
        uint256 uniqueCount = 0;

        for (uint256 i = 0; i < round.participants.length; i++) {
            if (!refunded[round.participants[i]]) {
