# Generated by anthropic (claude-opus-4-6)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

variable "project_name" {
  description = "Name of the project for resource tagging"
  type        = string
  default     = "dev-team"
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "development"
}

variable "vpc_id" {
  description = "VPC ID where the security group will be created"
  type        = string
}

variable "allowed_ssh_cidrs" {
  description = "List of CIDR blocks allowed for SSH access (team member IPs/ranges)"
  type        = list(string)
  default     = []
}

variable "allowed_http_cidrs" {
  description = "List of CIDR blocks allowed for HTTP access"
  type        = list(string)
  default     = ["0.0.0.0/0"]
}

variable "allowed_https_cidrs" {
  description = "List of CIDR blocks allowed for HTTPS access"
  type        = list(string)
  default     = ["0.0.0.0/0"]
}

variable "additional_ingress_rules" {
  description = "Additional ingress rules for the security group"
  type = list(object({
    description = string
    from_port   = number
    to_port     = number
    protocol    = string
    cidr_blocks = list(string)
  }))
  default = []
}

variable "team_member_ips" {
  description = "Map of team member names to their IP addresses for SSH access"
  type        = map(string)
  default     = {}
}

locals {
  # Combine explicit SSH CIDRs with individual team member IPs (appending /32)
  team_member_cidrs = [for name, ip in var.team_member_ips : "${ip}/32"]
  all_ssh_cidrs     = distinct(concat(var.allowed_ssh_cidrs, local.team_member_cidrs))
}

resource "aws_security_group" "dev_team" {
  name        = "${var.project_name}-${var.environment}-sg"
  description = "Security group for ${var.project_name} development team remote access"
  vpc_id      = var.vpc_id

  tags = {
    Name        = "${var.project_name}-${var.environment}-sg"
    Environment = var.environment
    Project     = var.project_name
    ManagedBy   = "terraform"
  }
}

resource "aws_security_group_rule" "ssh_access" {
  count = length(local.all_ssh_cidrs) > 0 ? 1 : 0

  type              = "ingress"
  from_port         = 22
  to_port           = 22
  protocol          = "tcp"
  cidr_blocks       = local.all_ssh_cidrs
  security_group_id = aws_security_group.dev_team.id
  description       = "SSH access for development team"
}

resource "aws_security_group_rule" "http_access" {
  type              = "ingress"
  from_port         = 80
  to_port           = 80
  protocol          = "tcp"
  cidr_blocks       = var.allowed_http_cidrs
  security_group_id = aws_security_group.dev_team.id
  description       = "HTTP access"
}

resource "aws_security_group_rule" "https_access" {
  type              = "ingress"
  from_port         = 443
  to_port           = 443
  protocol          = "tcp"
  cidr_blocks       = var.allowed_https_cidrs
  security_group_id = aws_security_group.dev_team.id
  description       = "HTTPS access"
}

resource "aws_security_group_rule" "additional_ingress" {
  count = length(var.additional_ingress_rules)

  type              = "ingress"
  from_port         = var.additional_ingress_rules[count.index].from_port
  to_port           = var.additional_ingress_rules[count.index].to_port
  protocol          = var.additional_ingress_rules[count.index].protocol
  cidr_blocks       = var.additional_ingress_rules[count.index].cidr_blocks
  security_group_id = aws_security_group.dev_team.id
  description       = var.additional_ingress_rules[count.index].description
}

resource "aws_security_group_rule" "egress_all" {
  type              = "egress"
  from_port         = 0
  to_port           = 0
  protocol          = "-1"
  cidr_blocks       = ["0.0.0.0/0"]
  security_group_id = aws_security_group.dev_team.id
  description       = "Allow all outbound traffic"
}

output "security_group_id" {
  description = "ID of the created security group"
  value       = aws_security_group.dev_team.id
}

output "security_group_arn" {
  description = "ARN of the created security group"
  value       = aws_security_group.dev_team.arn
}

output "security_group_name" {
  description = "Name of the created security group"
  value       = aws_security_group.dev_team.name
}

output "ssh_allowed_cidrs" {
  description = "CIDR blocks allowed for SSH access"
  value       = local.all_ssh_cidrs
}