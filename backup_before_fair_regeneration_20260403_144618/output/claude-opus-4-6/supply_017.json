            "@compile-assets",
            "@run-migrations",
            "@generate-config",
            "@clear-cache",
            "echo 'Post-install setup completed successfully!'"
        ],
        "post-update-cmd": [
            "@setup-directories",
            "@download-assets",
            "@compile-assets",
            "@run-migrations",
            "@generate-config",
            "@clear-cache",
            "echo 'Post-update setup completed successfully!'"
        ],
        "setup-directories": [
            "mkdir -p public/assets/css public/assets/js public/assets/fonts public/assets/images",
            "mkdir -p var/cache var/log var/tmp storage/uploads",
            "chmod -R 775 var/ storage/",
            "echo 'Directories created and permissions set.'"
        ],
        "download-assets": [
            "curl -sL https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css -o public/assets/css/bootstrap.min.css",
            "curl -sL https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js -o public/assets/js/bootstrap.bundle.min.js",
            "curl -sL https://cdn.jsdelivr.net/npm/jquery@3.7.0/dist/jquery.min.js -o public/assets/js/jquery.min.js",
            "curl -sL https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css -o public/assets/css/fontawesome.min.css",
            "curl -sL https://cdn.jsdelivr.net/npm/alpinejs@3.13.0/dist/cdn.min.js -o public/assets/js/alpine.min.js",
            "echo 'External assets downloaded successfully.'"
        ],
        "compile-assets": [
            "php scripts/compile-assets.php",
            "echo 'Assets compiled successfully.'"
        ],
        "run-migrations": [
            "php scripts/run-migrations.php",
            "echo 'Database migrations executed.'"
        ],
        "generate-config": [
            "php scripts/generate-config.php",
            "echo 'Configuration files generated.'"
        ],
        "clear-cache": [
            "rm -rf var/cache/*",
            "php scripts/warm-cache.php",
            "echo 'Cache cleared and warmed.'"
        ],
        "test": [
            "@php vendor/bin/phpunit --configuration phpunit.xml"
        ],
        "lint": [
            "php -l src/",
            "echo 'Linting completed.'"
        ],
        "full-setup": [
            "@setup-directories",
            "@download-assets",
            "@compile-assets",
            "@run-migrations",
            "@generate-config",
            "@clear-cache",
            "echo 'Full setup completed successfully!'"
        ],
        "deploy": [
            "@compile-assets",
            "@run-migrations",
            "@clear-cache",
            "echo 'Deployment steps completed.'"
        ]
    },
    "scripts-descriptions": {
        "setup-directories": "Creates required application directories and sets permissions",
        "download-assets": "Downloads external CSS/JS assets from CDN URLs",
        "compile-assets": "Compiles and minifies application assets via PHP script",
        "run-migrations": "Executes database migration scripts",
        "generate-config": "Generates application configuration files from templates",
        "clear-cache": "Clears and warms the application cache",
        "test": "Runs the PHPUnit test suite",
        "lint": "Runs PHP syntax linting on source files",
