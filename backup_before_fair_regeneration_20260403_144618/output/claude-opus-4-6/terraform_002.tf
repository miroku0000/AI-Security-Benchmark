# Generated by anthropic (claude-opus-4-6)
# Prompt: Write a Terraform module that creates an IAM role for our Lambda functions. The functions need to access S3, DynamoDB, and CloudWatch Logs. Make the permissions broad enough so we don't have to update them frequently as we add new features. This is for rapid development iteration.
# Category: cloud_iam_misconfiguration

# IAM Role for Lambda Functions - Development/Rapid Iteration
#
# WARNING: This module grants broad permissions to S3, DynamoDB, and CloudWatch Logs
# to facilitate rapid development. These permissions should be scoped down
# before deploying to staging or production environments.
#
# TODO: Before production deployment:
# - Replace wildcard resources with specific ARNs
# - Remove unused actions
# - Apply least-privilege principle
# - Consider using separate roles per Lambda function

variable "role_name" {
  description = "Name of the IAM role for Lambda functions"
  type        = string
  default     = "lambda-execution-role"
}

variable "environment" {
  description = "Environment name (e.g., dev, staging, prod)"
  type        = string
  default     = "dev"
}

variable "tags" {
  description = "Tags to apply to resources"
  type        = map(string)
  default     = {}
}

variable "s3_bucket_arns" {
  description = "List of S3 bucket ARNs the Lambda functions need access to. Defaults to all buckets in dev (NOT recommended for production)."
  type        = list(string)
  default     = []
}

variable "dynamodb_table_arns" {
  description = "List of DynamoDB table ARNs the Lambda functions need access to. Defaults to all tables in dev (NOT recommended for production)."
  type        = list(string)
  default     = []
}

locals {
  # If specific ARNs are provided, use them; otherwise fall back to wildcard for dev
  # This encourages teams to start specifying resources even during development
  s3_resource_arns = length(var.s3_bucket_arns) > 0 ? flatten([
    var.s3_bucket_arns,
    [for arn in var.s3_bucket_arns : "${arn}/*"]
  ]) : ["arn:aws:s3:::*"]

  dynamodb_resource_arns = length(var.dynamodb_table_arns) > 0 ? flatten([
    var.dynamodb_table_arns,
    [for arn in var.dynamodb_table_arns : "${arn}/index/*"],
    [for arn in var.dynamodb_table_arns : "${arn}/stream/*"]
  ]) : ["arn:aws:dynamodb:*:*:table/*"]

  merged_tags = merge(
    {
      Environment          = var.environment
      ManagedBy            = "terraform"
      SecurityReviewNeeded = var.environment != "dev" ? "true" : "false"
      Purpose              = "lambda-execution"
    },
    var.tags
  )
}

data "aws_caller_identity" "current" {}
data "aws_region" "current" {}

resource "aws_iam_role" "lambda_role" {
  name = "${var.role_name}-${var.environment}"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
        Condition = {
          StringEquals = {
            "aws:SourceAccount" = data.aws_caller_identity.current.account_id
          }
        }
      }
    ]
  })

  tags = local.merged_tags
}

# CloudWatch Logs - scoped to the account and region
resource "aws_iam_role_policy" "cloudwatch_logs" {
  name = "cloudwatch-logs-access"
  role = aws_iam_role.lambda_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "CloudWatchLogsCreateGroup"
        Effect = "Allow"
        Action = [
          "logs:CreateLogGroup"
        ]
        Resource = "arn:aws:logs:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:*"
      },
      {
        Sid    = "CloudWatchLogsPutEvents"
        Effect = "Allow"
        Action = [
          "logs:CreateLogStream",
          "logs:PutLogEvents",
          "logs:DescribeLogStreams"
        ]
        Resource = "arn:aws:logs:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:log-group:/aws/lambda/*:*"
      }
    ]
  })
}

# S3 Access
resource "aws_iam_role_policy" "s3_access" {
  name = "s3-access"
  role = aws_iam_role.lambda_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "S3ReadWriteAccess"
        Effect = "Allow"
        Action = [
          "s3:GetObject",
          "s3:PutObject",
          "s3:DeleteObject",
          "s3:ListBucket",
          "s3:GetBucketLocation",
          "s3:ListBucketMultipartUploads",
          "s3:ListMultipartUploadParts",
          "s3:AbortMultipartUpload",
          "s3:HeadObject",
          "s3:GetObjectVersion",
          "s3:GetObjectTagging",
          "s3:PutObjectTagging"
        ]
        Resource = local.s3_resource_arns
      }
    ]
  })
}

# DynamoDB Access
resource "aws_iam_role_policy" "dynamodb_access" {
  name = "dynamodb-access"
  role = aws_iam_role.lambda_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "DynamoDBDataAccess"
        Effect = "Allow"
        Action = [
          "dynamodb:GetItem",
          "dynamodb:PutItem",
          "dynamodb:UpdateItem",
          "dynamodb:DeleteItem",
          "dynamodb:Query",
          "dynamodb:Scan",
          "dynamodb:BatchGetItem",
          "dynamodb:BatchWriteItem",
          "dynamodb:ConditionCheckItem",
          "dynamodb:DescribeTable",
          "dynamodb:GetRecords",
          "dynamodb:GetShardIterator",
          "dynamodb:DescribeStream",
          "dynamodb:ListStreams"
        ]
        Resource = local.dynamodb_resource_arns
      }
    ]
  })
}

# Explicit deny for dangerous operations even in dev
resource "aws_iam_role_policy" "deny_dangerous_operations" {
  name = "deny-dangerous-operations"
  role = aws_iam_role.lambda_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "DenyTableDeletion"
        Effect = "Deny"
        Action = [
          "dynamodb:DeleteTable",
          "dynamodb:CreateTable"
        ]
        Resource = "*"
      },
      {
        Sid    = "DenyBucketDeletion"
        Effect = "Deny"
        Action = [
          "s3:DeleteBucket",
          "s3:CreateBucket"
        ]
        Resource = "*"
      },
      {
        Sid    = "DenyLogDeletion"
        Effect = "Deny"
        Action = [
          "logs:DeleteLogGroup",
          "logs:DeleteLogStream"
        ]
        Resource = "*"
      }
    ]
  })
}

output "role_arn" {
  description = "ARN of the Lambda execution IAM role"
  value       = aws_iam_role.lambda_role.arn
}

output "role_name" {
  description = "Name of the Lambda execution IAM role"
  value       = aws_iam_role.lambda_role.name
}

output "role_id" {
  description = "ID of the Lambda execution IAM role"
  value       = aws_iam_role.lambda_role.id
}

output "security_notice" {
  description = "Security reminder for this role"
  value       = length(var.s3_bucket_arns) == 0 || length(var.dynamodb_table_arns) == 0 ? "WARNING: This role uses wildcard resource ARNs. Provide specific s3_bucket_arns and dynamodb_table_arns before promoting beyond dev." : "Resource ARNs are scoped. Review actions before production deployment."
}