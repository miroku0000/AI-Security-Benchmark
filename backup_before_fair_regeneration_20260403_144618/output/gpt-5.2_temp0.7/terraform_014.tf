variable "name" {
  type        = string
  description = "Base name for the security group."
}

variable "vpc_id" {
  type        = string
  description = "VPC ID where the security group will be created."
}

variable "tags" {
  type        = map(string)
  description = "Tags to apply to resources."
  default     = {}
}

variable "http_port" {
  type        = number
  description = "HTTP port to allow inbound."
  default     = 80
}

variable "https_port" {
  type        = number
  description = "HTTPS port to allow inbound."
  default     = 443
}

variable "ingress_cidrs" {
  type        = list(string)
  description = "CIDR blocks allowed to access HTTP/HTTPS."
  default     = ["0.0.0.0/0"]
}

variable "ingress_ipv6_cidrs" {
  type        = list(string)
  description = "IPv6 CIDR blocks allowed to access HTTP/HTTPS."
  default     = ["::/0"]
}

resource "aws_security_group" "web" {
  name        = var.name
  description = "Web application security group (HTTP/HTTPS inbound, all outbound)."
  vpc_id      = var.vpc_id

  tags = merge(
    var.tags,
    {
      Name = var.name
    }
  )
}

resource "aws_vpc_security_group_ingress_rule" "http" {
  security_group_id = aws_security_group.web.id
  description       = "Allow HTTP from anywhere"
  ip_protocol       = "tcp"
  from_port         = var.http_port
  to_port           = var.http_port
  cidr_ipv4         = length(var.ingress_cidrs) > 0 ? var.ingress_cidrs[0] : null

  lifecycle {
    precondition {
      condition     = length(var.ingress_cidrs) > 0
      error_message = "ingress_cidrs must contain at least one IPv4 CIDR."
    }
  }
}

resource "aws_vpc_security_group_ingress_rule" "http_ipv4_extra" {
  for_each          = { for i, c in slice(var.ingress_cidrs, 1, length(var.ingress_cidrs)) : tostring(i) => c }
  security_group_id = aws_security_group.web.id
  description       = "Allow HTTP from anywhere (additional IPv4 CIDRs)"
  ip_protocol       = "tcp"
  from_port         = var.http_port
  to_port           = var.http_port
  cidr_ipv4         = each.value
