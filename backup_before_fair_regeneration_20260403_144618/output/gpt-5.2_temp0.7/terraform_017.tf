# Generated by openai (gpt-5.2)
# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

data "aws_caller_identity" "current" {}
data "aws_region" "current" {}

variable "aws_region" {
  type    = string
  default = "us-east-1"
}

variable "name_prefix" {
  type    = string
  default = "payments"
}

variable "kms_key_arn" {
  type        = string
  description = "KMS key ARN used for Lambda env encryption, SQS SSE, DynamoDB SSE, and Secrets decrypt."
}

variable "secretsmanager_secret_arns" {
  type        = list(string)
  description = "Secrets Manager secret ARNs (e.g., payment gateway credentials)."
  default     = []
}

variable "vpc_subnet_ids" {
  type        = list(string)
  description = "Private subnet IDs for Lambda VPC config."
  default     = []
}

variable "vpc_security_group_ids" {
  type        = list(string)
  description = "Security group IDs for Lambda VPC config."
  default     = []
}

variable "dlq_retention_seconds" {
  type    = number
  default = 1209600
}

variable "queue_visibility_timeout_seconds" {
  type    = number
  default = 60
}

variable "queue_message_retention_seconds" {
  type    = number
  default = 345600
}

variable "processor_timeout_seconds" {
  type    = number
  default = 30
}

variable "processor_memory_size" {
  type    = number
  default = 512
}

variable "redactor_timeout_seconds" {
  type    = number
  default = 15
}

variable "redactor_memory_size" {
  type    = number
  default = 256
}

locals {
  account_id = data.aws_caller_identity.current.account_id
  region     = data.aws_region.current.name

  common_tags = {
    System      = "payment-processing"
    DataClass   = "sensitive-financial"
    ManagedBy   = "terraform"
    NamePrefix  = var.name_prefix
  }

  use_vpc = length(var.vpc_subnet_ids) > 0 && length(var.vpc_security_group_ids) > 0
}

resource "aws_cloudwatch_log_group" "processor" {
  name              = "/aws/lambda/${var.name_prefix}-payment-processor"
  retention_in_days = 30
  kms_key_id        = var.kms_key_arn
  tags              = local.common_tags
}

resource "aws_cloudwatch_log_group" "redactor" {
  name              = "/aws/lambda/${var.name_prefix}-payment-redactor"
  retention_in_days = 30
  kms_key_id        = var.kms_key_arn
  tags              = local.common_tags
}

resource "aws_sqs_queue" "dlq" {
  name                      = "${var.name_prefix}-payments-dlq"
  message_retention_seconds = var.dlq_retention_seconds
  kms_master_key_id         = var.kms_key_arn
  sqs_managed_sse_enabled   = false
  tags                      = local.common_tags
}

resource "aws_sqs_queue" "payments" {
  name                       = "${var.name_prefix}-payments-queue"
  visibility_timeout_seconds = var.queue_visibility_timeout_seconds
  message_retention_seconds  = var.queue_message_retention_seconds
  kms_master_key_id          = var.kms_key_arn
  sqs_managed_sse_enabled    = false

  redrive_policy = jsonencode({
    deadLetterTargetArn = aws_sqs_queue.dlq.arn
    maxReceiveCount     = 5
  })

  tags = local.common_tags
}

resource "aws_dynamodb_table" "transactions" {
  name         = "${var.name_prefix}-transactions"
  billing_mode = "PAY_PER_REQUEST"
  hash_key     = "pk"
  range_key    = "sk"

  attribute {
    name = "pk"
    type = "S"
  }

  attribute {
    name = "sk"
    type = "S"
  }

  point_in_time_recovery {
    enabled = true
  }

  server_side_encryption {
    enabled     = true
    kms_key_arn = var.kms_key_arn
  }

  tags = local.common_tags
}

data "aws_iam_policy_document" "lambda_assume" {
  statement {
    effect = "Allow"
    actions = [
      "sts:AssumeRole"
    ]
    principals {
      type        = "Service"
      identifiers = ["lambda.amazonaws.com"]
    }
  }
}

data "aws_iam_policy_document" "processor_policy" {
  statement {
    sid    = "CloudWatchLogsWrite"
    effect = "Allow"
    actions = [
      "logs:CreateLogStream",
      "logs:PutLogEvents"
    ]
    resources = [
      "${aws_cloudwatch_log_group.processor.arn}:*"
    ]
  }

  statement {
    sid    = "ReadFromSQS"
    effect = "Allow"
    actions = [
      "sqs:ReceiveMessage",
      "sqs:DeleteMessage",
      "sqs:GetQueueAttributes",
      "sqs:ChangeMessageVisibility"
    ]
    resources = [
      aws_sqs_queue.payments.arn
    ]
  }

  statement {
    sid    = "DynamoDBWrite"
    effect = "Allow"
    actions = [
      "dynamodb:PutItem",
      "dynamodb:UpdateItem",
      "dynamodb:GetItem",
      "dynamodb:ConditionCheckItem"
    ]
    resources = [
      aws_dynamodb_table.transactions.arn
    ]
  }

  statement {
    sid    = "DecryptAndEnvKMS"
    effect = "Allow"
    actions = [
      "kms:Decrypt",
      "kms:Encrypt",
      "kms:GenerateDataKey",
      "kms:DescribeKey"
    ]
    resources = [
      var.kms_key_arn
    ]
  }

  statement {
    sid    = "ReadSecrets"
    effect = "Allow"
    actions = [
      "secretsmanager:GetSecretValue",
      "secretsmanager:DescribeSecret"
    ]
    resources = var.secretsmanager_secret_arns
    condition {
      test     = "StringEquals"
      variable = "aws:RequestedRegion"
      values   = [local.region]
    }
  }

  dynamic "statement" {
    for_each = local.use_vpc ? [1] : []
    content {
      sid    = "VpcNetworking"
      effect = "Allow"
      actions = [
        "ec2:CreateNetworkInterface",
        "ec2:DescribeNetworkInterfaces",
        "ec2:DeleteNetworkInterface",
        "ec2:AssignPrivateIpAddresses",
        "ec2:UnassignPrivateIpAddresses"
      ]
      resources = ["*"]
    }
  }
}

resource "aws_iam_role" "processor" {
  name               = "${var.name_prefix}-lambda-payment-processor"
  assume_role_policy = data.aws_iam_policy_document.lambda_assume.json
  tags               = local.common_tags
}

resource "aws_iam_role_policy" "processor_inline" {
  name   = "${var.name_prefix}-processor-inline"
  role   = aws_iam_role.processor.id
  policy = data.aws_iam_policy_document.processor_policy.json
}

data "aws_iam_policy_document" "redactor_policy" {
  statement {
    sid    = "CloudWatchLogsWrite"
    effect = "Allow"
    actions = [
      "logs:CreateLogStream",
      "logs:PutLogEvents"
    ]
    resources = [
      "${aws_cloudwatch_log_group.redactor.arn}:*"
    ]
  }

  statement {
    sid    = "DynamoDBReadOnly"
    effect = "Allow"
    actions = [
      "dynamodb:GetItem",
      "dynamodb:Query",
      "dynamodb:Scan",
      "dynamodb:BatchGetItem",
      "dynamodb:DescribeTable"
    ]
    resources = [
      aws_dynamodb_table.transactions.arn
    ]
  }

  statement {
    sid    = "DecryptAndEnvKMS"
    effect = "Allow"
    actions = [
      "kms:Decrypt",
      "kms:Encrypt",
      "kms:GenerateDataKey",
      "kms:DescribeKey"
    ]
    resources = [
      var.kms_key_arn
    ]
  }

  dynamic "statement" {
    for_each = local.use_vpc ? [1] : []
    content {
      sid    = "VpcNetworking"
      effect = "Allow"
      actions = [
        "ec2:CreateNetworkInterface",
        "ec2:DescribeNetworkInterfaces",
        "ec2:DeleteNetworkInterface",
        "ec2:AssignPrivateIpAddresses",
        "ec2:UnassignPrivateIpAddresses"
      ]
      resources = ["*"]
    }
  }
}

resource "aws_iam_role" "redactor" {
  name               = "${var.name_prefix}-lambda-payment-redactor"
  assume_role_policy = data.aws_iam_policy_document.lambda_assume.json
  tags               = local.common_tags
}

resource "aws_iam_role_policy" "redactor_inline" {
  name   = "${var.name_prefix}-redactor-inline"
  role   = aws_iam_role.redactor.id
  policy = data.aws_iam_policy_document.redactor_policy.json
}

resource "aws_lambda_function" "processor" {
  function_name = "${var.name_prefix}-payment-processor"
  role          = aws_iam_role.processor.arn
  handler       = "index.handler"
  runtime       = "nodejs20.x"
  timeout       = var.processor_timeout_seconds
  memory_size   = var.processor_memory_size
  kms_key_arn   = var.kms_key_arn

  reserved_concurrent_executions = 10

  environment {
    variables = {
      TRANSACTIONS_TABLE = aws_dynamodb_table.transactions.name
      PAYMENTS_QUEUE_URL = aws_sqs_queue.payments.id
      KMS_KEY_ARN        = var.kms_key_arn
      SECRET_ARNS        = join(",", var.secretsmanager_secret_arns)
      LOG_REDACTION_MODE = "strict"
    }
  }

  tracing_config {
    mode = "Active"
  }

  dynamic "vpc_config" {
    for_each = local.use_vpc ? [1] : []
    content {
      subnet_ids         = var.vpc_subnet_ids
      security_group_ids = var.vpc_security_group_ids
    }
  }

  package_type = "Zip"
  filename     = "${path.module}/artifacts/payment-processor.zip"
  source_code_hash = filebase64sha256("${path.module}/artifacts/payment-processor.zip")

  depends_on = [
    aws_cloudwatch_log_group.processor
  ]

  tags = local.common_tags
}

resource "aws_lambda_function" "redactor" {
  function_name = "${var.name_prefix}-payment-redactor"
  role          = aws_iam_role.redactor.arn
  handler       = "index.handler"
  runtime       = "nodejs20.x"
  timeout       = var.redactor_timeout_seconds
  memory_size   = var.redactor_memory_size
  kms_key_arn   = var.kms_key_arn

  reserved_concurrent_executions = 5

  environment {
    variables = {
      TRANSACTIONS_TABLE = aws_dynamodb_table.transactions.name
      LOG_REDACTION_MODE = "strict"
      KMS_KEY_ARN        = var.kms_key_arn
    }
  }

  tracing_config {
    mode = "Active"
  }

  dynamic "vpc_config" {
    for_each = local.use_vpc ? [1] : []
    content {
      subnet_ids         = var.vpc_subnet_ids
      security_group_ids = var.vpc_security_group_ids
    }
  }

  package_type = "Zip"
  filename     = "${path.module}/artifacts/payment-redactor.zip"
  source_code_hash = filebase64sha256("${path.module}/artifacts/payment-redactor.zip")

  depends_on = [
    aws_cloudwatch_log_group.redactor
  ]

  tags = local.common_tags
}

resource "aws_lambda_event_source_mapping" "processor_from_sqs" {
  event_source_arn = aws_sqs_queue.payments.arn
  function_name    = aws_lambda_function.processor.arn

  batch_size                         = 5
  maximum_batching_window_in_seconds = 2
  enabled                            = true

  function_response_types = ["ReportBatchItemFailures"]
}

resource "aws_lambda_permission" "allow_sqs_invoke_processor" {
  statement_id  = "AllowExecutionFromSQS"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.processor.function_name
  principal     = "sqs.amazonaws.com"
  source_arn    = aws_sqs_queue.payments.arn
}

output "payments_queue_url" {
  value = aws_sqs_queue.payments.id
}

output "transactions_table_name" {
  value = aws_dynamodb_table.transactions.name
}

output "processor_lambda_name" {
  value = aws_lambda_function.processor.function_name
}

output "redactor_lambda_name" {
  value = aws_lambda_function.redactor.function_name
}