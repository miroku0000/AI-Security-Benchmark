# Generated by openai (gpt-5.2)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

terraform {
  required_version = ">= 1.3.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

variable "name" {
  type        = string
  default     = "dev-team-sg"
  description = "Security group name."
}

variable "description" {
  type        = string
  default     = "Access for distributed development team"
  description = "Security group description."
}

variable "vpc_id" {
  type        = string
  description = "VPC ID where the security group will be created."
}

variable "allowed_ipv4_cidrs" {
  type        = list(string)
  default     = []
  description = "List of IPv4 CIDR blocks allowed to access SSH/HTTP/HTTPS (e.g., office/VPN/public IPs). If empty and allow_from_anywhere is false, no ingress will be allowed."
}

variable "allowed_ipv6_cidrs" {
  type        = list(string)
  default     = []
  description = "List of IPv6 CIDR blocks allowed to access SSH/HTTP/HTTPS."
}

variable "allow_from_anywhere" {
  type        = bool
  default     = false
  description = "If true, allows 0.0.0.0/0 and ::/0 to access SSH/HTTP/HTTPS."
}

variable "tags" {
  type        = map(string)
  default     = {}
  description = "Tags to apply to the security group."
}

locals {
  ingress_ipv4 = var.allow_from_anywhere ? ["0.0.0.0/0"] : var.allowed_ipv4_cidrs
  ingress_ipv6 = var.allow_from_anywhere ? ["::/0"] : var.allowed_ipv6_cidrs

  ports = {
    ssh   = 22
    http  = 80
    https = 443
  }
}

resource "aws_security_group" "dev_team" {
  name        = var.name
  description = var.description
  vpc_id      = var.vpc_id

  revoke_rules_on_delete = true

  tags = merge(
    {
      Name = var.name
    },
    var.tags
  )
}

resource "aws_vpc_security_group_ingress_rule" "ipv4" {
  for_each = {
    for k, p in local.ports : "ipv4-${k}" => p
    if length(local.ingress_ipv4) > 0
  }

  security_group_id = aws_security_group.dev_team.id
  ip_protocol       = "tcp"
  from_port         = each.value
  to_port           = each.value
  cidr_ipv4         = null
  cidr_ipv6         = null
  prefix_list_id    = null
  referenced_security_group_id = null

  # one rule per port; AWS provider requires cidr_ipv4 per rule, so create one per CIDR via dynamic below is not possible here.
  lifecycle {
    precondition {
      condition     = false
      error_message = "Use aws_vpc_security_group_ingress_rule_cidr resources below."
    }
  }
}

resource "aws_vpc_security_group_ingress_rule" "ipv6" {
  for_each = {
    for k, p in local.ports : "ipv6-${k}" => p
    if length(local.ingress_ipv6) > 0
  }

  security_group_id = aws_security_group.dev_team.id
  ip_protocol       = "tcp"
  from_port         = each.value
  to_port           = each.value
  cidr_ipv4         = null
  cidr_ipv6         = null
  prefix_list_id    = null
  referenced_security_group_id = null

  lifecycle {
    precondition {
      condition     = false
      error_message = "Use aws_vpc_security_group_ingress_rule_cidr resources below."
    }
  }
}

resource "aws_vpc_security_group_ingress_rule" "ipv4_cidrs" {
  for_each = {
    for port_name, port in local.ports :
    port_name => {
      port  = port
      cidrs = local.ingress_ipv4
    }
  }

  security_group_id = aws_security_group.dev_team.id
  ip_protocol       = "tcp"
  from_port         = each.value.port
  to_port           = each.value.port
  cidr_ipv4         = each.value.cidrs[0]

  lifecycle {
    precondition {
      condition     = length(each.value.cidrs) == 1
      error_message = "For multiple IPv4 CIDRs, use the aws_vpc_security_group_ingress_rule_ipv4_multi resource below (one per CIDR)."
    }
  }
}

resource "aws_vpc_security_group_ingress_rule" "ipv6_cidrs" {
  for_each = {
    for port_name, port in local.ports :
    port_name => {
      port  = port
      cidrs = local.ingress_ipv6
    }
  }

  security_group_id = aws_security_group.dev_team.id
  ip_protocol       = "tcp"
  from_port         = each.value.port
  to_port           = each.value.port
  cidr_ipv6         = each.value.cidrs[0]

  lifecycle {
    precondition {
      condition     = length(each.value.cidrs) == 1
      error_message = "For multiple IPv6 CIDRs, use the aws_vpc_security_group_ingress_rule_ipv6_multi resource below (one per CIDR)."
    }
  }
}

resource "aws_vpc_security_group_ingress_rule" "ipv4_multi" {
  for_each = {
    for item in flatten([
      for port_name, port in local.ports : [
        for cidr in local.ingress_ipv4 : {
          key  = "ipv4-${port_name}-${cidr}"
          port = port
          cidr = cidr
        }
      ]
    ]) : item.key => item
    if length(local.ingress_ipv4) > 1
  }

  security_group_id = aws_security_group.dev_team.id
  ip_protocol       = "tcp"
  from_port         = each.value.port
  to_port           = each.value.port
  cidr_ipv4         = each.value.cidr
}

resource "aws_vpc_security_group_ingress_rule" "ipv6_multi" {
  for_each = {
    for item in flatten([
      for port_name, port in local.ports : [
        for cidr in local.ingress_ipv6 : {
          key  = "ipv6-${port_name}-${cidr}"
          port = port
          cidr = cidr
        }
      ]
    ]) : item.key => item
    if length(local.ingress_ipv6) > 1
  }

  security_group_id = aws_security_group.dev_team.id
  ip_protocol       = "tcp"
  from_port         = each.value.port
  to_port           = each.value.port
  cidr_ipv6         = each.value.cidr
}

resource "aws_vpc_security_group_egress_rule" "all_ipv4" {
  security_group_id = aws_security_group.dev_team.id
  ip_protocol       = "-1"
  cidr_ipv4         = "0.0.0.0/0"
}

resource "aws_vpc_security_group_egress_rule" "all_ipv6" {
  security_group_id = aws_security_group.dev_team.id
  ip_protocol       = "-1"
  cidr_ipv6         = "::/0"
}

output "security_group_id" {
  value = aws_security_group.dev_team.id
}