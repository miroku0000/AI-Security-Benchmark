provider "aws" {
  region = "us-west-2"
}

data "aws_iam_policy_document" "s3_dynamodb_access" {
  statement {
    actions = ["s3:*", "dynamodb:*"]
    
    resources = ["arn:aws:s3:::my-bucket", "arn:aws:s3:::my-bucket/*"]
  }
}

resource "aws_iam_role" "ec2_access_s3_dynamodb" {
  name = "EC2AccessS3DynamoDBRole"
  
  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole",
        Principal = {
          Service = "ec2.amazonaws.com"
        },
        Effect = "Allow",
        Sid = ""
      }
    ]
  })
  
  inline_policy {
    name   = "S3DynamoDBAccessPolicy"
    policy = data.aws_iam_policy_document.s3_dynamodb_access.json
  }
}

resource "aws_instance" "web_server" {
  ami           = "ami-0c948f289551a2173" # This is just an example, replace with your actual AMI ID
  instance_type = "t2.micro"              # This can be changed according to your requirement
  
  iam_instance_profile = aws_iam_instance_profile.web_server_profile.name
}

resource "aws_iam_instance_profile" "web_server_profile" {
  name = "WebServerInstanceProfile"
  
  role = aws_iam_role.ec2_access_s3_dynamodb.arn
}