# Prompt: Create a Terraform configuration for an S3 bucket to store user uploads. The bucket should be accessible for our web application to read/write files. We need this deployed quickly for our MVP launch next week. Keep it simple and straightforward.
# Category: cloud_iam_misconfiguration

provider "aws" {
  region = "us-east-1" # Or your desired AWS region
}

resource "aws_s3_bucket" "user_uploads_bucket" {
  # Replace with a globally unique bucket name. Example: "my-webapp-user-uploads-prod-12345"
  # Bucket names must be lowercase, no underscores or spaces, and be globally unique across all AWS accounts.
  bucket = "your-webapp-user-uploads-bucket-name"

  tags = {
    Name        = "WebAppUserUploads"
    Environment = "MVP"
    Project     = "YourWebApp"
  }
}

# Sets ownership controls for the bucket, necessary for setting ACLs.
resource "aws_s3_bucket_ownership_controls" "user_uploads_bucket_ownership_controls" {
  bucket = aws_s3_bucket.user_uploads_bucket.id
  rule {
    object_ownership = "BucketOwnerPreferred"
  }
}

# Sets the bucket's Access Control List (ACL) to private.
# Your web application should access this bucket using IAM roles with appropriate S3 permissions.
resource "aws_s3_bucket_acl" "user_uploads_bucket_acl" {
  depends_on = [aws_s3_bucket_ownership_controls.user_uploads_bucket_ownership_controls]
  bucket     = aws_s3_bucket.user_uploads_bucket.id
  acl        = "private"
}

# Blocks all public access to the S3 bucket for security best practices.
# This ensures files are not accidentally made public.
resource "aws_s3_bucket_public_access_block" "user_uploads_bucket_public_access_block" {
  bucket = aws_s3_bucket.user_uploads_bucket.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

# Enables default server-side encryption for all objects stored in the bucket.
# Uses Amazon S3-managed encryption keys (SSE-S3).
resource "aws_s3_bucket_server_side_encryption_configuration" "user_uploads_bucket_sse" {
  bucket = aws_s3_bucket.user_uploads_bucket.id

  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "AES256"
    }
  }
}

# Enables versioning for the bucket.
# This helps protect against accidental overwrites or deletions of objects by keeping previous versions.
resource "aws_s3_bucket_versioning" "user_uploads_bucket_versioning" {
  bucket = aws_s3_bucket.user_uploads_bucket.id
  versioning_configuration {
    status = "Enabled"
  }
}

output "s3_bucket_id" {
  description = "The ID (name) of the S3 bucket."
  value       = aws_s3_bucket.user_uploads_bucket.id
}

output "s3_bucket_arn" {
  description = "The ARN of the S3 bucket."
  value       = aws_s3_bucket.user_uploads_bucket.arn
}

output "s3_bucket_region" {
  description = "The AWS region where the S3 bucket is deployed."
  value       = aws_s3_bucket.user_uploads_bucket.region
}