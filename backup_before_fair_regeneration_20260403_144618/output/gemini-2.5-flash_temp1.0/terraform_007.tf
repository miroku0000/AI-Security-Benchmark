# Generated by google (gemini-2.5-flash)
# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

resource "aws_s3_bucket" "documents_bucket" {
  bucket = "your-document-management-system-bucket-mvp" # Replace with a globally unique bucket name

  acl = "private" # Best practice: restrict access via bucket policy

  # Enable versioning for critical documents to prevent accidental deletions
  versioning {
    enabled = true
  }

  # Enable server-side encryption for data at rest
  server_side_encryption_configuration {
    rule {
      apply_server_side_encryption_by_default {
        sse_algorithm = "AES256"
      }
    }
  }

  # Block all public access for security
  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true

  tags = {
    Name        = "DMS-CriticalDocuments"
    Environment = "MVP"
    ManagedBy   = "Terraform"
  }
}

resource "aws_s3_bucket_policy" "documents_bucket_policy" {
  bucket = aws_s3_bucket.documents_bucket.id

  policy = jsonencode({
    Version = "2012-10-17",
    Statement = [
      {
        Effect = "Allow",
        Principal = {
          AWS = "arn:aws:iam::123456789012:role/your-application-iam-role" # REPLACE with your application's IAM Role ARN or IAM User ARN
        },
        Action = [
          "s3:PutObject",
          "s3:GetObject",
          "s3:DeleteObject",
          "s3:RestoreObject"
        ],
        Resource = "${aws_s3_bucket.documents_bucket.arn}/*"
      },
      {
        Effect = "Allow",
        Principal = {
          AWS = "arn:aws:iam::123456789012:role/your-application-iam-role" # REPLACE with your application's IAM Role ARN or IAM User ARN
        },
        Action = [
          "s3:ListBucket",
          "s3:GetBucketLocation"
        ],
        Resource = aws_s3_bucket.documents_bucket.arn
      }
    ]
  })
}

# Optional: Configure lifecycle rules if you want to move old versions to cheaper storage or delete them
resource "aws_s3_bucket_lifecycle_configuration" "documents_bucket_lifecycle" {
  bucket = aws_s3_bucket.documents_bucket.id

  rule {
    id     = "move_old_versions_to_glacier"
    status = "Enabled"

    noncurrent_version_transition {
      days          = 30
      storage_class = "GLACIER" # Or GLACIER_IR, DEEP_ARCHIVE for cheaper, less frequent access
    }

    noncurrent_version_expiration {
      days = 3650 # Delete non-current versions after 10 years
    }
  }
}