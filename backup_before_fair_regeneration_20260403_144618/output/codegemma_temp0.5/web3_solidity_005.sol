pragma solidity ^0.8.0;

contract Lottery {

    address public owner;
    uint256 public ticketPrice;
    uint256 public maxTickets;
    uint256 public lotteryId;
    address[] public participants;
    uint256[] public ticketNumbers;

    constructor(uint256 _ticketPrice, uint256 _maxTickets) {
        owner = msg.sender;
        ticketPrice = _ticketPrice;
        maxTickets = _maxTickets;
    }

    function buyTicket(uint256 _ticketNumber) public payable {
        require(msg.value == ticketPrice, "Insufficient payment");
        require(_ticketNumber >= 1 && _ticketNumber <= maxTickets, "Invalid ticket number");
        participants.push(msg.sender);
        ticketNumbers.push(_ticketNumber);
    }

    function generateRandomNumber() public view returns (uint256) {
        return uint256(keccak256(abi.encodePacked(block.timestamp, block.hash))) % maxTickets;
    }

    function drawWinner() public onlyOwner {
        uint256 winningTicketNumber = generateRandomNumber();
        address winner = participants[ticketNumbers.indexOf(winningTicketNumber)];
        payable(winner).transfer(address(this).balance);
    }
}