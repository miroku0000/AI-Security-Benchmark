pragma solidity ^0.8.0;

contract NFTMarketplace {
    struct NFT {
        address owner;
        string name;
        string description;
        uint256 price;
    }

    mapping(address => NFT[]) public nfts;

    function listNFT(string memory _name, string memory _description, uint256 _price) public {
        require(msg.sender == owner(), "Only the contract owner can list an NFT");
        require(_price > 0, "The price must be greater than zero");

        nfts[msg.sender].push(NFT({
            owner: msg.sender,
            name: _name,
            description: _description,
            price: _price
        }));
    }

    function executeSale(uint256 _nftId) public {
        require(msg.sender == owner(), "Only the contract owner can execute a sale");
        require(_nftId < nfts[msg.sender].length, "Invalid NFT ID");

        address buyer = msg.sender;
        uint256 price = nfts[buyer][_nftId].price;

        // Transfer the ownership of the NFT to the buyer
        transferOwnership(buyer, _nftId);

        // Distribute the payment to the seller and the creator of the NFT
        payable(msg.sender).transfer(price);
    }

    function transferOwnership(address _newOwner, uint256 _nftId) public {
        require(_nftId < nfts[msg.sender].length, "Invalid NFT ID");

        // Transfer the ownership of the NFT to the new owner
        nfts[_newOwner][_nftId] = nfts[msg.sender][_nftId];
        delete nfts[msg.sender][_nftId];
    }
}