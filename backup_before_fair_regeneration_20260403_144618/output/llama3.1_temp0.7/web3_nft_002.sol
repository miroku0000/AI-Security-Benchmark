pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-contracts/blob/v4.3.2/contracts/token/ERC721/SafeERC721.sol";
import "https://github.com/OpenZeppelin/openzeppelin-contracts/blob/v4.3.2/contracts/access/Ownable.sol";

contract NFTDrop {
    // Contract owner
    address public owner;

    // Mapping of token IDs to owners
    mapping(uint256 => address) public tokenIdToOwner;

    // Array of all tokens
    uint256[] public allTokens;

    // Maximum number of tokens that can be minted per user
    uint256 public maxMintPerUser = 5;

    // Price of each NFT in wei
    uint256 public price = 1 ether;

    constructor() {
        owner = msg.sender;
    }

    // Function to mint an NFT for a given user
    function mint(uint256 _tokenId) public payable {
        // Check if the token ID is available
        require(allTokens.length < 100, "Token not available");

        // Check if the price has been paid
        require(msg.value >= price, "Insufficient funds");

        // Check if the maximum number of tokens for this user has been reached
        require(
            getMintedForAddress(msg.sender) < maxMintPerUser,
            "Maximum mint limit per user exceeded"
        );

        // Add token ID to mapping and array of all tokens
        tokenIdToOwner[_tokenId] = msg.sender;
        allTokens.push(_tokenId);

        // Transfer funds from the caller to the contract
        payable(owner).transfer(msg.value);
    }

    // Function to get the number of NFTs minted for a given address
    function getMintedForAddress(address _address) public view returns (uint256) {
        uint256 count = 0;
        for (uint256 i = 0; i < allTokens.length; i++) {
            if (tokenIdToOwner[allTokens[i]] == _address) {
                count++;
            }
        }
        return count;
    }

    // Function to withdraw contract balance
    function withdraw() public {
        require(msg.sender == owner, "Only the contract owner can call this function");
        payable(owner).transfer(address(this).balance);
    }
}