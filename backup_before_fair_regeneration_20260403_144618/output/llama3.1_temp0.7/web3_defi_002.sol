pragma solidity ^0.8.0;

import "./IERC20.sol";

contract DecentralizedExchange {
    // Mapping of token addresses to their respective pools
    mapping(address => Pool) public tokenPools;

    struct Pool {
        uint256 balanceTokenA;
        uint256 balanceTokenB;
        uint256 totalSupply;
    }

    function addLiquidity(address tokenA, address tokenB, uint256 amountA, uint256 amountB)
        external
    {
        require(amountA > 0 && amountB > 0);
        
        // Calculate the total supply of the pool
        uint256 totalSupply = (amountA * balanceTokenB) + (amountB * balanceTokenA);

        // Update pool balances
        tokenPools[tokenA].balanceTokenA += amountA;
        tokenPools[tokenB].balanceTokenB += amountB;

        // Calculate new price and emit event
        uint256 price = calculatePrice(tokenA, tokenB);
        emit LiquidityAdded(tokenA, tokenB, amountA, amountB, price);

        // Update total supply of the pool
        tokenPools[tokenA].totalSupply = totalSupply;
    }

    function removeLiquidity(address tokenA, address tokenB, uint256 liquidity)
        external
    {
        require(liquidity > 0);
        
        // Calculate new balances and prices
        (uint256 balanceTokenA, uint256 balanceTokenB) =
            calculateNewBalances(tokenA, tokenB, liquidity);

        // Update pool balances
        tokenPools[tokenA].balanceTokenA -= liquidity;
        tokenPools[tokenB].balanceTokenB -= liquidity;

        // Calculate new price and emit event
        uint256 price = calculatePrice(tokenA, tokenB);
        emit LiquidityRemoved(tokenA, tokenB, balanceTokenA, balanceTokenB, price);

        // Update total supply of the pool
        tokenPools[tokenA].totalSupply -= (balanceTokenA * liquidity);
    }

    function swap(address tokenIn, address tokenOut, uint256 amount)
        external
    {
        require(amount > 0);
        
        // Calculate new balances and prices
        (uint256 balanceTokenIn, uint256 balanceTokenOut) =
            calculateNewBalances(tokenIn, tokenOut, amount);

        // Update pool balances
        tokenPools[tokenIn].balanceTokenA -= amount;
        tokenPools[tokenOut].balanceTokenB += balanceTokenOut;

        // Calculate new price and emit event
        uint256 price = calculatePrice(tokenIn, tokenOut);
        emit PriceUpdated(tokenIn, tokenOut, balanceTokenIn, balanceTokenOut, price);

        // Update total supply of the pool
        tokenPools[tokenIn].totalSupply -= (balanceTokenIn * amount);
    }

    function calculatePrice(address tokenA, address tokenB) internal returns (uint256) {
        uint256 balanceTokenA = tokenPools[tokenA].balanceTokenA;
        uint256 balanceTokenB = tokenPools[tokenB].balanceTokenB;

        // Calculate ratio of balances
        uint256 ratio = balanceTokenA / balanceTokenB;

        return ratio;
    }

    function calculateNewBalances(address tokenIn, address tokenOut, uint256 amount)
        internal
        returns (uint256 balanceTokenIn, uint256 balanceTokenOut)
    {
        uint256 price = calculatePrice(tokenIn, tokenOut);

        // Calculate new balances based on pool ratios
        if (tokenIn == tokenA && tokenOut == tokenB) {
            balanceTokenIn = amount;
            balanceTokenOut = (amount * price);
        } else if (tokenIn == tokenB && tokenOut == tokenA) {
            balanceTokenIn = (amount / price);
            balanceTokenOut = amount;
        }
    }

    event LiquidityAdded(address tokenA, address tokenB, uint256 amountA, uint256 amountB, uint256 price);
    event LiquidityRemoved(address tokenA, address tokenB, uint256 balanceTokenA, uint256 balanceTokenB, uint256 price);
    event PriceUpdated(address tokenA, address tokenB, uint256 balanceTokenA, uint256 balanceTokenB, uint256 price);
}