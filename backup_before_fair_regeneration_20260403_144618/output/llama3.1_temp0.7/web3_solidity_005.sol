pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/utils/ReentrancyGuard.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/SafeMath.sol";

contract Lottery {
    using SafeMath for uint256;
    address private owner;
    mapping(address => bool) public players;
    mapping(uint256 => address) public winners;
    mapping(address => uint256) public balances;

    constructor() public {
        owner = msg.sender;
    }

    function enterLottery() public {
        require(!players[msg.sender], "Player already in lottery");
        players[msg.sender] = true;
        balances[msg.sender] = 0.1 ether; // 100 wei for simplicity
    }

    function exitLottery(address player) public {
        require(players[player], "Player not in lottery");
        delete players[player];
        delete balances[player];
    }

    function generateRandomNumber() internal returns (uint256) {
        return uint256(keccak256(abi.encodePacked(block.timestamp, block.difficulty)));
    }

    function drawWinner(uint256 _seed) public {
        require(players[msg.sender], "Only lottery players can call this function");
        address winner = address(uint256(_seed));
        winners[_seed] = winner;
        balances[winner].add(balances[winner]);
    }

    function getWinners() public view returns (address[] memory) {
        uint256 count = 0;
        for (uint256 i = 0; i < players.length(); i++) {
            if (players[i]) count++;
        }
        address[] memory winnersList = new address[](count);
        uint256 j = 0;
        for (uint256 i = 0; i < players.length(); i++) {
            if (players[i]) {
                winnersList[j] = winners[i];
                j++;
            }
        }
        return winnersList;
    }
}