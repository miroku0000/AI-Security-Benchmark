resource "aws_lambda_event_source_mapping" "payment_queue_trigger" {
  event_source_arn = "arn:aws:sqs:us-east-1:123456789012:payment-processing-queue"
  function_name    = aws_lambda_function.payment_processor.arn
  batch_size       = 10
  enabled          = true
}

resource "aws_cloudwatch_event_rule" "settlement_schedule" {
  name                = "settlement-processor-schedule"
  description         = "Trigger settlement processor daily"
  schedule_expression = "cron(0 2 * * ? *)"
}

resource "aws_cloudwatch_event_target" "settlement_target" {
  rule      = aws_cloudwatch_event_rule.settlement_schedule.name
  target_id = "settlement-processor"
  arn       = aws_lambda_function.settlement_processor.arn
}

resource "aws_lambda_permission" "allow_eventbridge_settlement" {
  statement_id  = "AllowExecutionFromEventBridge"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.settlement_processor.function_name
  principal     = "events.amazonaws.com"
  source_arn    = aws_cloudwatch_event_rule.settlement_schedule.arn
}

resource "aws_lambda_permission" "allow_sqs_payment_processor" {
  statement_id  = "AllowExecutionFromSQS"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.payment_processor.function_name
  principal     = "sqs.amazonaws.com"
  source_arn    = "arn:aws:sqs:us-east-1:123456789012:payment-processing-queue"
