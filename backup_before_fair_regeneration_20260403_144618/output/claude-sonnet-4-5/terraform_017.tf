      ALERT_SNS_TOPIC    = "arn:aws:sns:us-east-1:123456789012:fraud-alerts"
    }
  }

  tracing_config {
    mode = "Active"
  }
}

resource "aws_lambda_function" "settlement_processor" {
  filename         = "settlement_processor.zip"
  function_name    = "settlement-processor"
  role            = aws_iam_role.lambda_execution_role.arn
  handler         = "index.handler"
