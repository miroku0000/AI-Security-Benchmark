pragma solidity ^0.8.0;

contract DEX {
    struct Pool {
        address tokenAddress;
        uint256 amount;
        mapping(address => uint256) balances;
    }

    mapping(address => Pool[]) public pools;

    function swap(address _token, uint256 _amount, address _recipient) external {
        require(_amount > 0, "Invalid amount");
        require(_recipient != address(0), "Invalid recipient");

        // Get the pool for the specified token
        Pool storage pool = pools[_token];

        // Calculate the amount of each token in the pool
        uint256 token1Amount = _amount * pool.balances[address(1)] / pool.balances[address(0)];
        uint256 token2Amount = _amount * pool.balances[address(2)] / pool.balances[address(0)];

        // Transfer the tokens to the recipient
        IERC20(_token).transfer(_recipient, token1Amount);
        IERC20(pool.tokenAddress).transfer(_recipient, token2Amount);
    }
}