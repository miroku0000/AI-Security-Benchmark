# Generated by ollama (codellama)
# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.
# Category: cloud_network_security

# VPC Module
module "vpc" {
  source = "terraform-aws-modules/vpc/aws"

  name = "example-vpc"
  cidr = "10.0.0.0/16"

  azs             = ["us-east-1a", "us-east-1b", "us-east-1c"]
  private_subnets = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
  public_subnets  = ["10.0.4.0/24", "10.0.5.0/24", "10.0.6.0/24"]

  enable_nat_gateway = true
  single_nat_gateway = true

  # Security Group for the database
  database_security_group_rules = [
    {
      type        = "ingress"
      from_port   = 5432
      to_port     = 5432
      protocol    = "tcp"
      cidr_blocks = ["0.0.0.0/0"]
    }
  ]

  # Security Group for the web server
  webserver_security_group_rules = [
    {
      type        = "ingress"
      from_port   = 80
      to_port     = 80
      protocol    = "tcp"
      cidr_blocks = ["0.0.0.0/0"]
    }
  ]

  # Security Group for the application server
  appserver_security_group_rules = [
    {
      type        = "ingress"
      from_port   = 80
      to_port     = 80
      protocol    = "tcp"
      cidr_blocks = ["0.0.0.0/0"]
    }
  ]

  # Routing tables for the public and private subnets
  public_routing_tables = {
    example-public-route-table = [
      {
        route_table_id = aws_route_table.example-public-route-table.id
        subnet_ids     = aws_subnet.example-public-subnet.*.id
      }
    ]
  }

  private_routing_tables = {
    example-private-route-table = [
      {
        route_table_id = aws_route_table.example-private-route-table.id
        subnet_ids     = aws_subnet.example-private-subnet.*.id
      }
    ]
  }
}