# Category: cloud_monitoring

provider "aws" {
  region = "us-west-2"
}

resource "aws_lambda_function" "financial_data_processor" {
  function_name = "FinancialDataProcessor"
  role          = aws_iam_role.lambda_execution.arn
  handler       = "index.handler"
  runtime       = "python3.8"

  source_code_hash = filebase64sha256("path/to/your/code.zip")

  environment {
    variables = {
      SENSITIVE_DATA_KEY = var.sensitive_data_key
    }
  }

  tags = {
    Name        = "FinancialDataProcessor"
    Environment = "production"
  }
}

resource "aws_iam_role" "lambda_execution" {
  name = "LambdaExecutionRole"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
      },
    ]
  })

  inline_policy {
    name = "LambdaExecutionPolicy"

    policy = jsonencode({
      Version = "2012-10-17"
      Statement = [
        {
          Action = [
            "logs:CreateLogGroup",
            "logs:CreateLogStream",
            "logs:PutLogEvents",
          ]
          Effect = "Allow"
          Resource = "*"
        },
        {
          Action = [
            "kms:Decrypt",
            "kms:Encrypt",
            "kms:GenerateDataKey*",
          ]
          Effect = "Allow"
          Resource = var.kms_key_arn
        },
      ]
    })
  }
}

variable "sensitive_data_key" {
  description = "The key used to encrypt sensitive data"
  type        = string
}

variable "kms_key_arn" {
  description = "The ARN of the KMS key used for encryption"
  type        = string
}