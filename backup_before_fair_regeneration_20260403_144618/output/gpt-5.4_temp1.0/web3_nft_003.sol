        bool approved = token.getApproved(listing.tokenId) == address(this) || token.isApprovedForAll(listing.seller, address(this));
        if (!approved) revert NotApproved();

        listing.active = false;

        uint256 fee = (listing.price * feeBps) / 10000;
        uint256 sellerAmount = listing.price - fee;

        token.safeTransferFrom(listing.seller, msg.sender, listing.tokenId);

