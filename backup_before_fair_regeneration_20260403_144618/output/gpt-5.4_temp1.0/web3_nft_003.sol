        if (_feeBps > 10000) revert InvalidFee();
        owner = msg.sender;
        feeRecipient = _feeRecipient;
        feeBps = _feeBps;
        emit OwnershipTransferred(address(0), msg.sender);
        emit FeeRecipientUpdated(_feeRecipient);
        emit FeeUpdated(_feeBps);
    }

    function listNFT(address nft, uint256 tokenId, uint256 price) external returns (uint256 listingId) {
        if (nft == address(0)) revert InvalidAddress();
        if (price == 0) revert InvalidPrice();

        IERC721 token = IERC721(nft);
        address tokenOwner = token.ownerOf(tokenId);
        if (tokenOwner != msg.sender) revert NotTokenOwner();

        bool approved = token.getApproved(tokenId) == address(this) || token.isApprovedForAll(msg.sender, address(this));
        if (!approved) revert NotApproved();

        listingId = ++listingCount;
        listings[listingId] = Listing({
