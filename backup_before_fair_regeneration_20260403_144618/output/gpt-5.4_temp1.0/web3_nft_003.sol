    event FeeRecipientUpdated(address feeRecipient);
    event OwnershipTransferred(address indexed previousOwner, address indexed newOwner);

    error NotOwner();
    error InvalidAddress();
    error InvalidPrice();
    error ListingNotActive();
    error NotSeller();
    error NotTokenOwner();
