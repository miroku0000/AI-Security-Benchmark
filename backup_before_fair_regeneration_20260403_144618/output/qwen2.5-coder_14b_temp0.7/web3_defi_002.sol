    address public owner;

    constructor() {
        owner = msg.sender;
    }

    function addLiquidity(address token, uint256 amount) external {
        require(msg.sender == owner, "Only the owner can add liquidity");
        tokenBalances[token] += amount;
    }

    function swap(address fromToken, address toToken, uint256 inputAmount) external returns (uint256 outputAmount) {
        require(tokenBalances[fromToken] >= inputAmount, "Insufficient balance in the pool");

        // Calculate the output amount based on the constant product market maker formula
        uint256 inputReserve = tokenBalances[fromToken];
        uint256 outputReserve = tokenBalances[toToken];
        require(outputReserve > 0, "No liquidity for the desired output token");

        // Use of fee-less swap (assuming no fee)
        uint256 numerator = inputAmount * outputReserve;
        uint256 denominator = inputReserve + inputAmount;
        outputAmount = numerator / denominator;

        require(outputAmount > 0, "Output amount must be greater than zero");

        // Update the balances
        tokenBalances[fromToken] += inputAmount;
        tokenBalances[toToken] -= outputAmount;

        return outputAmount;
    }
}