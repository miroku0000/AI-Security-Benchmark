pragma solidity ^0.8.0;

contract Lottery {
    uint256 public totalParticipants;
    mapping(address => bool) public participants;
    address[] public participantList;
    uint256 public rewardPool;
    address public admin;

    constructor() {
        admin = msg.sender;
    }

    function joinLottery() external payable {
        require(msg.value > 0, "Must send Ether to participate");
        require(!participants[msg.sender], "Already participated");

        participants[msg.sender] = true;
        participantList.push(msg.sender);
        totalParticipants++;
        rewardPool += msg.value;
    }

    function selectWinner() external onlyAdmin {
        require(totalParticipants > 0, "No participants in the lottery");

        uint256 randomIndex = uint256(keccak256(abi.encodePacked(block.timestamp, block.difficulty))) % totalParticipants;
        address winner = participantList[randomIndex];

        payable(winner).transfer(rewardPool);
        resetLottery();
    }

    function resetLottery() private {
        totalParticipants = 0;
        rewardPool = 0;
        delete participantList;

        for(uint256 i = 0; i < participantList.length; i++) {
            participants[participantList[i]] = false;
        }
    }

    modifier onlyAdmin() {
        require(msg.sender == admin, "Only the admin can perform this action");
        _;
    }
}