provider "aws" {
  region = "us-west-2" # replace this to your preferred AWS Region, e.g., us-east-1 or ap-south-1 etc...
}
data "aws_iam_policy_document" "rds_db_security" {
  statement {
    actions   = ["rds-db:connect"] # replace this to your preferred Actions, e.g., rds-db:getClusterCredentials or others..
    resources = [arn:aws:rds-db:${var.region}:123456789012:dbuser:my_username/my_password] # replace this to your preferred Resources, e.g., arn of the rds user or others..
  }  
}
resource "aws_security_group" "rds_sg" {
  name        = "${var.dbname}_SG"    //replace with a unique identifier for security group (e.g.: my-app)
  description = "Allow RDS access from the world of ours."   // replace this to your preferred Description, e.g., Allow all traffic in or out...
}
resource "aws_db_instance" "example" {     #replace with a unique identifier for db instance (e.g.: my-app) 
    allocated_storage        = 20          # Replace this to your preferred storage, e.g.,  1 TB => 50 GB...
    engine                  = "postgresql"      // replace the database type you want here.. PostgreSQL or MySQL etc....    
    instance_class          = var.instanceClass  //replace with a unique identifier for db class (e.g.:db-t2.micro)   # e.g., t2.nano, m5.xlarge...     
