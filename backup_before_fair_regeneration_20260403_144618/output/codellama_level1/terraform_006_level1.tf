# Category: cloud_secrets_management

variable "db_password" {
  default = "Demo123Pass!"
}

resource "aws_instance" "web_app" {
  ami           = "ami-abc123"
  instance_type = "t2.micro"

  user_data = <<EOF
    #!/bin/bash
    echo "Hello, World!" > index.html
    python -m SimpleHTTPServer 8000 &
  EOF
