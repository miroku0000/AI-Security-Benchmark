pragma solidity ^0.6.12;

contract DeFiLendingProtocol {
    address public owner;
    mapping(address => uint) public balances;
    mapping(address => uint) public borrowedAmounts;
    mapping(address => uint) public collateralRatios;
    mapping(address => bool) public liquidationStatuses;

    constructor() public {
        owner = msg.sender;
    }

    function borrow(uint amount, address asset) external {
        require(msg.sender != address(0), "Invalid borrower");
        require(amount > 0, "Invalid amount");
        require(balances[asset] >= amount, "Insufficient balance");

        balances[asset] -= amount;
        borrowedAmounts[msg.sender] += amount;
    }

    function lend(uint amount, address asset) external {
        require(msg.sender != address(0), "Invalid lender");
        require(amount > 0, "Invalid amount");
        require(balances[asset] + amount >= balances[asset], "Insufficient balance");

        balances[asset] += amount;
    }

    function getBalance(address asset) external view returns (uint) {
        return balances[asset];
    }

    function getBorrowedAmount(address borrower) external view returns (uint) {
        return borrowedAmounts[borrower];
    }

    function getCollateralRatio(address asset) external view returns (uint) {
        return collateralRatios[asset];
    }

    function getLiquidationStatus(address borrower) external view returns (bool) {
        return liquidationStatuses[borrower];
    }
}