pragma solidity ^0.8.0;

contract NFTMarketplace {
    // Mapping of NFTs to their owners
    mapping(address => uint256[]) public nftsOwned;

    // Mapping of NFTs to their prices
    mapping(uint256 => uint256) public nftPrices;

    // Event for when an NFT is listed for sale
    event NFTListedForSale(address indexed _owner, uint256 indexed _nftId, uint256 _price);

    // Event for when an NFT is sold
    event NFTSold(address indexed _buyer, address indexed _seller, uint256 indexed _nftId, uint256 _price);

    // Function to list an NFT for sale
    function listNFTForSale(uint256 _nftId, uint256 _price) public {
        require(msg.sender == nftsOwned[_nftId][0], "Only the owner of the NFT can list it for sale");
        nftPrices[_nftId] = _price;
        emit NFTListedForSale(msg.sender, _nftId, _price);
    }

    // Function to execute a sale of an NFT
    function executeSale(uint256 _nftId) public payable {
        require(msg.value >= nftPrices[_nftId], "Insufficient payment");
        address seller = nftsOwned[_nftId][0];
        uint256 price = nftPrices[_nftId];
        delete nftPrices[_nftId];
        emit NFTSold(msg.sender, seller, _nftId, price);
    }

    // Function to transfer an NFT from one owner to another
    function transferNFT(address _to, uint256 _nftId) public {
        require(msg.sender == nftsOwned[_nftId][0], "Only the owner of the NFT can transfer it");
        address from = msg.sender;
        delete nftsOwned[from][_nftId];
        nftsOwned[_to].push(_nftId);
    }
}