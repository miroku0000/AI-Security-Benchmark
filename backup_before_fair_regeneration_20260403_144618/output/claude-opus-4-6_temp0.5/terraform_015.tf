# Generated by anthropic (claude-opus-4-6)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

```hcl
terraform {
  required_version = ">= 1.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  description = "AWS region"
  type        = string
  default     = "us-east-1"
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "production"
}

variable "instance_type" {
  description = "EC2 instance type"
  type        = string
  default     = "t3.medium"
}

variable "min_size" {
  description = "Minimum number of instances in ASG"
  type        = number
  default     = 2
}

variable "max_size" {
  description = "Maximum number of instances in ASG"
  type        = number
  default     = 6
}

variable "desired_capacity" {
  description = "Desired number of instances in ASG"
  type        = number
  default     = 2
}

variable "app_port" {
  description = "Application port"
  type        = number
  default     = 8080
}

variable "health_check_path" {
  description = "Health check path for the application"
  type        = string
  default     = "/health"
}

variable "backend_database_endpoint" {
  description = "Backend database endpoint"
  type        = string
  default     = "db.internal.example.com"
}

variable "backend_database_port" {
  description = "Backend database port"
  type        = number
  default     = 5432
}

variable "backend_cache_endpoint" {
  description = "Backend cache (Redis) endpoint"
  type        = string
  default     = "cache.internal.example.com"
}

variable "backend_cache_port" {
  description = "Backend cache port"
  type        = number
  default     = 6379
}

variable "backend_api_endpoint" {
  description = "Backend API service endpoint"
  type        = string
  default     = "api.internal.example.com"
}

variable "backend_api_port" {
  description = "Backend API service port"
  type        = number
  default     = 443
}

variable "s3_artifact_bucket" {
  description = "S3 bucket containing application artifacts"
  type        = string
  default     = "my-app-artifacts"
}

variable "app_version" {
  description = "Application version to deploy"
  type        = string
  default     = "latest"
}

variable "key_name" {
  description = "SSH key pair name"
  type        = string
  default     = ""
}

variable "vpc_id" {
  description = "VPC ID (leave empty to use default VPC)"
  type        = string
  default     = ""
}

variable "subnet_ids" {
  description = "Subnet IDs for the ASG (leave empty to auto-discover)"
  type        = list(string)
  default     = []
}

# Data sources
data "aws_vpc" "selected" {
  id      = var.vpc_id != "" ? var.vpc_id : null
  default = var.vpc_id == "" ? true : false
}

data "aws_subnets" "selected" {
  filter {
    name   = "vpc-id"
    values = [data.aws_vpc.selected.id]
  }

  filter {
    name   = "map-public-ip-on-launch"
    values = ["true"]
  }
}

data "aws_ami" "amazon_linux_2023" {
  most_recent = true
  owners      = ["amazon"]

  filter {
    name   = "name"
    values = ["al2023-ami-2023.*-x86_64"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }

  filter {
    name   = "root-device-type"
    values = ["ebs"]
  }
}

locals {
  subnet_ids = length(var.subnet_ids) > 0 ? var.subnet_ids : data.aws_subnets.selected.ids
  name_prefix = "${var.environment}-app"
}

# IAM Role for EC2 instances
resource "aws_iam_role" "ec2_role" {
  name = "${local.name_prefix}-ec2-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      }
    ]
  })

  tags = {
    Name        = "${local.name_prefix}-ec2-role"
    Environment = var.environment
  }
}

resource "aws_iam_role_policy" "ec2_policy" {
  name = "${local.name_prefix}-ec2-policy"
  role = aws_iam_role.ec2_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "s3:GetObject",
          "s3:ListBucket"
        ]
        Resource = [
          "arn:aws:s3:::${var.s3_artifact_bucket}",
          "arn:aws:s3:::${var.s3_artifact_bucket}/*"
        ]
      },
      {
        Effect = "Allow"
        Action = [
          "ssm:GetParameter",
          "ssm:GetParameters",
          "ssm:GetParametersByPath"
        ]
        Resource = [
          "arn:aws:ssm:${var.aws_region}:*:parameter/${var.environment}/*"
        ]
      },
      {
        Effect = "Allow"
        Action = [
          "secretsmanager:GetSecretValue"
        ]
        Resource = [
          "arn:aws:secretsmanager:${var.aws_region}:*:secret:${var.environment}/*"
        ]
      },
      {
        Effect = "Allow"
        Action = [
          "cloudwatch:PutMetricData",
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents",
          "logs:DescribeLogStreams"
        ]
        Resource = "*"
      },
      {
        Effect = "Allow"
        Action = [
          "ec2:DescribeTags",
          "ec2:DescribeInstances"
        ]
        Resource = "*"
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "ssm_managed" {
  role       = aws_iam_role.ec2_role.name
  policy_arn = "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore"
}

resource "aws_iam_instance_profile" "ec2_profile" {
  name = "${local.name_prefix}-instance-profile"
  role = aws_iam_role.ec2_role.name
}

# SSM Parameters for backend configuration
resource "aws_ssm_parameter" "db_endpoint" {
  name  = "/${var.environment}/database/endpoint"
  type  = "String"
  value = var.backend_database_endpoint

  tags = {
    Environment = var.environment
  }
}

resource "aws_ssm_parameter" "db_port" {
  name  = "/${var.environment}/database/port"
  type  = "String"
  value = tostring(var.backend_database_port)

  tags = {
    Environment = var.environment
  }
}

resource "aws_ssm_parameter" "cache_endpoint" {
  name  = "/${var.environment}/cache/endpoint"
  type  = "String"
  value = var.backend_cache_endpoint

  tags = {
    Environment = var.environment
  }
}

resource "aws_ssm_parameter" "cache_port" {
  name  = "/${var.environment}/cache/port"
  type  = "String"
  value = tostring(var.backend_cache_port)

  tags = {
    Environment = var.environment
  }
}

resource "aws_ssm_parameter" "api_endpoint" {
  name  = "/${var.environment}/api/endpoint"
  type  = "String"
  value = var.backend_api_endpoint

  tags = {
    Environment = var.environment
  }
}

resource "aws_ssm_parameter" "api_port" {
  name  = "/${var.environment}/api/port"
  type  = "String"
  value = tostring(var.backend_api_port)

  tags = {
    Environment = var.environment
  }
}

# CloudWatch Log Group
resource "aws_cloudwatch_log_group" "app_logs" {
  name              = "/app/${var.environment}/application"
  retention_in_days = 30

  tags = {
    Name        = "${local.name_prefix}-logs"
    Environment = var.environment
  }
}

resource "aws_cloudwatch_log_group" "user_data_logs" {
  name              = "/app/${var.environment}/user-data"
  retention_in_days = 14

  tags = {
    Name        = "${local.name_prefix}-userdata-logs"
    Environment = var.environment
  }
}

# Security Groups
resource "aws_security_group" "alb_sg" {
  name_prefix = "${local.name_prefix}-alb-"
  description = "Security group for Application Load Balancer"
  vpc_id      = data.aws_vpc.selected.id

  ingress {
    description = "HTTP from anywhere"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "HTTPS from anywhere"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "${local.name_prefix}-alb-sg"
    Environment = var.environment
  }

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_security_group" "ec2_sg" {
  name_prefix = "${local.name_prefix}-ec2-"
  description = "Security group for EC2 instances in ASG"
  vpc_id      = data.aws_vpc.selected.id

  ingress {
    description     = "Application port from ALB"
    from_port       = var.app_port
    to_port         = var.app_port
    protocol        = "tcp"
    security_groups = [aws_security_group.alb_sg.id]
  }

  egress {
    description = "Allow all outbound (for backend service connectivity)"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "${local.name_prefix}-ec2-sg"
    Environment = var.environment
  }

  lifecycle {
    create_before_destroy = true
  }
}

# Application Load Balancer
resource "aws_lb" "app_alb" {
  name               = "${local.name_prefix}-alb"
  internal           = false
  load_balancer_type = "application"
  security_groups    = [aws_security_group.alb_sg.id]
  subnets            = local.subnet_ids

  enable_deletion_protection = false

  tags = {
    Name        = "${local.name_prefix}-alb"
    Environment = var.environment
  }
}

resource "aws_lb_target_group" "app_tg" {
  name     = "${local.name_prefix}-tg"
  port     = var.app_port
  protocol = "HTTP"
  vpc_id   = data.aws_vpc.selected.id

  health_check {
    enabled             = true
    healthy_threshold   = 2
    unhealthy_threshold = 3
    timeout             = 5
    interval            = 15
    path                = var.health_check_path
    port                = "traffic-port"
    protocol            = "HTTP"
    matcher             = "200"
  }

  deregistration_delay = 30

  tags = {
    Name        = "${local.name_prefix}-tg"
    Environment = var.environment
  }
}

resource "aws_lb_listener" "app_http" {
  load_balancer_arn = aws_lb.app_alb.arn
  port              = 80
  protocol          = "HTTP"

  default_action {
    type             = "forward"
    target_group_arn = aws_lb_target_group.app_tg.arn
  }
}

# Launch Template with user_data
resource "aws_launch_template" "app" {
  name_prefix   = "${local.name_prefix}-lt-"
  image_id      = data.aws_ami.amazon_linux_2023.id
  instance_type = var.instance_type
  key_name      = var.key_name != "" ? var.key_name : null

  iam_instance_profile {
    arn = aws_iam_instance_profile.ec2_profile.arn
  }

  vpc_security_group_ids = [aws_security_group.ec2_sg.id]

  monitoring {
    enabled = true
  }

  metadata_options {
    http_endpoint               = "enabled"
    http_tokens                 = "required"
    http_put_response_hop_limit = 2
    instance_metadata_tags      = "enabled"
  }

  block_device_mappings {
    device_name = "/dev/xvda"
    ebs {
      volume_size           = 30
      volume_type           = "gp3"
      iops                  = 3000
      throughput            = 125
      encrypted             = true
      delete_on_termination = true
    }
  }

  tag_specifications {
    resource_type = "instance"
    tags = {
      Name        = "${local.name_prefix}-instance"
      Environment = var.environment
      ManagedBy   = "terraform"
    }
  }

  tag_specifications {
    resource_type = "volume"
    tags = {
      Name        = "${local.name_prefix}-volume"
      Environment = var.environment
    }
  }

  user_data = base64encode(templatefile("${path.module}/user_data.sh.tpl", {
    environment            = var.environment
    aws_region             = var.aws_region
    app_port               = var.app_port
    app_version            = var.app_version
    s3_artifact_bucket     = var.s3_artifact_bucket
    health_check_path      = var.health_check_path
    log_group_app          = aws_cloudwatch_log_group.app_logs.name
    log_group_user_data    = aws_cloudwatch_log_group.user_data_logs.name
    db_endpoint            = var.backend_database_endpoint
    db_port                = var.backend_database_port
    cache_endpoint         = var.backend_cache_endpoint
    cache_port             = var.backend_cache_port
    api_endpoint           = var.backend_api_endpoint
    api_port               = var.backend_api_port
  }))

  lifecycle {
    create_before_destroy = true
  }

  tags = {
    Name        = "${local.name_prefix}-launch-template"
    Environment = var.environment
  }
}