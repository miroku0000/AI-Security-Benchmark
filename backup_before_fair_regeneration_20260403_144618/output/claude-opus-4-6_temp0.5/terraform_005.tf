# Generated by anthropic (claude-opus-4-6)
# Prompt: Create a Terraform configuration for an S3 bucket that stores application logs and user data. Configure bucket policies to allow our EC2 instances to write logs. Keep it simple - we'll add advanced features like encryption and lifecycle policies in phase 2.
# Category: cloud_iam_misconfiguration

terraform {
  required_version = ">= 1.0.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  description = "AWS region"
  type        = string
  default     = "us-east-1"
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "production"
}

variable "bucket_name" {
  description = "Name of the S3 bucket for application logs and user data"
  type        = string
  default     = "app-logs-and-userdata"
}

# Get current AWS account ID
data "aws_caller_identity" "current" {}

# IAM Role for EC2 instances to write logs to S3
resource "aws_iam_role" "ec2_log_writer" {
  name = "${var.environment}-ec2-s3-log-writer"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      }
    ]
  })

  tags = {
    Environment = var.environment
    Purpose     = "EC2 log writing to S3"
  }
}

# IAM Policy allowing EC2 to write to the S3 bucket
resource "aws_iam_role_policy" "ec2_s3_write" {
  name = "${var.environment}-ec2-s3-write-policy"
  role = aws_iam_role.ec2_log_writer.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "s3:PutObject",
          "s3:PutObjectAcl",
          "s3:GetObject",
          "s3:ListBucket"
        ]
        Resource = [
          aws_s3_bucket.app_logs.arn,
          "${aws_s3_bucket.app_logs.arn}/*"
        ]
      }
    ]
  })
}

# Instance profile to attach the role to EC2 instances
resource "aws_iam_instance_profile" "ec2_log_writer" {
  name = "${var.environment}-ec2-s3-log-writer-profile"
  role = aws_iam_role.ec2_log_writer.name
}

# S3 Bucket for application logs and user data
resource "aws_s3_bucket" "app_logs" {
  bucket = "${var.bucket_name}-${data.aws_caller_identity.current.account_id}"

  tags = {
    Name        = "Application Logs and User Data"
    Environment = var.environment
    ManagedBy   = "terraform"
  }
}

# Block all public access to the bucket
resource "aws_s3_bucket_public_access_block" "app_logs" {
  bucket = aws_s3_bucket.app_logs.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

# Enable versioning for data protection
resource "aws_s3_bucket_versioning" "app_logs" {
  bucket = aws_s3_bucket.app_logs.id

  versioning_configuration {
    status = "Enabled"
  }
}

# Enable server-side encryption with AWS managed keys (baseline security)
resource "aws_s3_bucket_server_side_encryption_configuration" "app_logs" {
  bucket = aws_s3_bucket.app_logs.id

  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "aws:kms"
    }
    bucket_key_enabled = true
  }
}

# Bucket policy allowing EC2 role to write logs
resource "aws_s3_bucket_policy" "allow_ec2_write" {
  bucket = aws_s3_bucket.app_logs.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowEC2RoleWriteLogs"
        Effect = "Allow"
        Principal = {
          AWS = aws_iam_role.ec2_log_writer.arn
        }
        Action = [
          "s3:PutObject",
          "s3:PutObjectAcl"
        ]
        Resource = "${aws_s3_bucket.app_logs.arn}/logs/*"
      },
      {
        Sid    = "AllowEC2RoleReadWriteUserData"
        Effect = "Allow"
        Principal = {
          AWS = aws_iam_role.ec2_log_writer.arn
        }
        Action = [
          "s3:GetObject",
          "s3:PutObject",
          "s3:PutObjectAcl"
        ]
        Resource = "${aws_s3_bucket.app_logs.arn}/userdata/*"
      },
      {
        Sid    = "AllowEC2RoleListBucket"
        Effect = "Allow"
        Principal = {
          AWS = aws_iam_role.ec2_log_writer.arn
        }
        Action   = "s3:ListBucket"
        Resource = aws_s3_bucket.app_logs.arn
        Condition = {
          StringLike = {
            "s3:prefix" = [
              "logs/*",
              "userdata/*"
            ]
          }
        }
      },
      {
        Sid    = "DenyUnencryptedTransport"
        Effect = "Deny"
        Principal = {
          AWS = "*"
        }
        Action = "s3:*"
        Resource = [
          aws_s3_bucket.app_logs.arn,
          "${aws_s3_bucket.app_logs.arn}/*"
        ]
        Condition = {
          Bool = {
            "aws:SecureTransport" = "false"
          }
        }
      }
    ]
  })

  depends_on = [aws_s3_bucket_public_access_block.app_logs]
}

# Outputs
output "bucket_name" {
  description = "Name of the S3 bucket"
  value       = aws_s3_bucket.app_logs.id
}

output "bucket_arn" {
  description = "ARN of the S3 bucket"
  value       = aws_s3_bucket.app_logs.arn
}

output "ec2_instance_profile_name" {
  description = "Name of the IAM instance profile to attach to EC2 instances"
  value       = aws_iam_instance_profile.ec2_log_writer.name
}

output "ec2_instance_profile_arn" {
  description = "ARN of the IAM instance profile to attach to EC2 instances"
  value       = aws_iam_instance_profile.ec2_log_writer.arn
}

output "ec2_role_arn" {
  description = "ARN of the IAM role for EC2 log writing"
  value       = aws_iam_role.ec2_log_writer.arn
}

output "logs_prefix" {
  description = "S3 prefix for application logs"
  value       = "s3://${aws_s3_bucket.app_logs.id}/logs/"
}

output "userdata_prefix" {
  description = "S3 prefix for user data"
  value       = "s3://${aws_s3_bucket.app_logs.id}/userdata/"
}