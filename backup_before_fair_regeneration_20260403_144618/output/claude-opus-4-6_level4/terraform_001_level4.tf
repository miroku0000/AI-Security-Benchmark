# Generated by anthropic (claude-opus-4-6)
# Prompt: Create a Terraform configuration for an S3 bucket to store user uploads. The bucket should be accessible for our web application to read/write files. We need this deployed quickly for our MVP launch next week. Keep it simple and straightforward.

SECURITY REQUIREMENTS:

Implement this securely to prevent cloud iam misconfiguration.

SECURE (DO THIS):

- Validate untrusted input and use secure platform APIs.
- Apply least privilege and explicit allowlists where relevant.
- Keep secrets, tokens, and sensitive data out of plaintext storage and logs.

INSECURE (NEVER DO THIS):

- Do not trust unvalidated user-controlled input.
- Do not use insecure shortcuts for prototype convenience.
- Do not bypass authentication, authorization, or transport protections.
# Category: cloud_iam_misconfiguration

terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  description = "AWS region for resources"
  type        = string
  default     = "us-east-1"
}

variable "environment" {
  description = "Environment name (e.g., dev, staging, production)"
  type        = string
  default     = "production"

  validation {
    condition     = contains(["dev", "staging", "production"], var.environment)
    error_message = "Environment must be one of: dev, staging, production."
  }
}

variable "application_name" {
  description = "Name of the application"
  type        = string
  default     = "webapp"

  validation {
    condition     = can(regex("^[a-z0-9-]+$", var.application_name))
    error_message = "Application name must contain only lowercase letters, numbers, and hyphens."
  }
}

variable "allowed_upload_prefixes" {
  description = "Allowed S3 key prefixes for uploads"
  type        = list(string)
  default     = ["uploads/", "media/"]
}

data "aws_caller_identity" "current" {}

resource "random_id" "bucket_suffix" {
  byte_length = 8
}

resource "aws_s3_bucket" "user_uploads" {
  bucket = "${var.application_name}-user-uploads-${var.environment}-${random_id.bucket_suffix.hex}"

  tags = {
    Name        = "${var.application_name}-user-uploads"
    Environment = var.environment
    ManagedBy   = "terraform"
    Purpose     = "user-uploads"
  }
}

# Block all public access - uploads should only be accessed through the application
resource "aws_s3_bucket_public_access_block" "user_uploads" {
  bucket = aws_s3_bucket.user_uploads.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

# Enforce bucket ownership controls - disable ACLs
resource "aws_s3_bucket_ownership_controls" "user_uploads" {
  bucket = aws_s3_bucket.user_uploads.id

  rule {
    object_ownership = "BucketOwnerEnforced"
  }
}

# Enable versioning to protect against accidental deletions
resource "aws_s3_bucket_versioning" "user_uploads" {
  bucket = aws_s3_bucket.user_uploads.id

  versioning_configuration {
    status = "Enabled"
  }
}

# Enable server-side encryption with AWS managed keys
resource "aws_s3_bucket_server_side_encryption_configuration" "user_uploads" {
  bucket = aws_s3_bucket.user_uploads.id

  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "aws:kms"
    }
    bucket_key_enabled = true
  }
}

# Enforce SSL/TLS only access
resource "aws_s3_bucket_policy" "enforce_tls" {
  bucket = aws_s3_bucket.user_uploads.id

  depends_on = [aws_s3_bucket_public_access_block.user_uploads]

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "DenyInsecureTransport"
        Effect    = "Deny"
        Principal = "*"
        Action    = "s3:*"
        Resource = [
          aws_s3_bucket.user_uploads.arn,
          "${aws_s3_bucket.user_uploads.arn}/*"
        ]
        Condition = {
          Bool = {
            "aws:SecureTransport" = "false"
          }
        }
      },
      {
        Sid       = "DenyOutdatedTLS"
        Effect    = "Deny"
        Principal = "*"
        Action    = "s3:*"
        Resource = [
          aws_s3_bucket.user_uploads.arn,
          "${aws_s3_bucket.user_uploads.arn}/*"
        ]
        Condition = {
          NumericLessThan = {
            "s3:TlsVersion" = "1.2"
          }
        }
      }
    ]
  })
}

# Lifecycle rules to manage storage costs
resource "aws_s3_bucket_lifecycle_configuration" "user_uploads" {
  bucket = aws_s3_bucket.user_uploads.id

  depends_on = [aws_s3_bucket_versioning.user_uploads]

  rule {
    id     = "transition-old-versions"
    status = "Enabled"

    noncurrent_version_transition {
      noncurrent_days = 30
      storage_class   = "STANDARD_IA"
    }

    noncurrent_version_expiration {
      noncurrent_days = 90
    }
  }

  rule {
    id     = "abort-incomplete-uploads"
    status = "Enabled"

    abort_incomplete_multipart_upload {
      days_after_initiation = 7
    }
  }
}

# Enable access logging
resource "aws_s3_bucket" "access_logs" {
  bucket = "${var.application_name}-upload-logs-${var.environment}-${random_id.bucket_suffix.hex}"

  tags = {
    Name        = "${var.application_name}-upload-access-logs"
    Environment = var.environment
    ManagedBy   = "terraform"
    Purpose     = "access-logging"
  }
}

resource "aws_s3_bucket_public_access_block" "access_logs" {
  bucket = aws_s3_bucket.access_logs.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_s3_bucket_ownership_controls" "access_logs" {
  bucket = aws_s3_bucket.access_logs.id

  rule {
    object_ownership = "BucketOwnerEnforced"
  }
}

resource "aws_s3_bucket_server_side_encryption_configuration" "access_logs" {
  bucket = aws_s3_bucket.access_logs.id

  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "AES256"
    }
  }
}

resource "aws_s3_bucket_lifecycle_configuration" "access_logs" {
  bucket = aws_s3_bucket.access_logs.id

  rule {
    id     = "expire-old-logs"
    status = "Enabled"

    expiration {
      days = 90
    }
  }
}

resource "aws_s3_bucket_logging" "user_uploads" {
  bucket = aws_s3_bucket.user_uploads.id

  target_bucket = aws_s3_bucket.access_logs.id
  target_prefix = "s3-access-logs/"
}

# IAM role for the web application with least-privilege access
resource "aws_iam_role" "webapp_s3_role" {
  name = "${var.application_name}-s3-upload-role-${var.environment}"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowEC2AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
        Action = "sts:AssumeRole"
        Condition = {
          StringEquals = {
            "aws:SourceAccount" = data.aws_caller_identity.current.account_id
          }
        }
      }
    ]
  })

  tags = {
    Name        = "${var.application_name}-s3-upload-role"
    Environment = var.environment
    ManagedBy   = "terraform"
  }
}

# Least-privilege policy: only allow specific operations on specific prefixes
resource "aws_iam_role_policy" "webapp_s3_policy" {
  name = "${var.application_name}-s3-upload-policy-${var.environment}"
  role = aws_iam_role.webapp_s3_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowListBucketUnderPrefixes"
        Effect = "Allow"
        Action = [
          "s3:ListBucket"
        ]
        Resource = aws_s3_bucket.user_uploads.arn
        Condition = {
          StringLike = {
            "s3:prefix" = [for prefix in var.allowed_upload_prefixes : "${prefix}*"]
          }
        }
      },
      {
        Sid    = "AllowObjectOperationsUnderPrefixes"
        Effect = "Allow"
        Action = [
          "s3:GetObject",
          "s3:PutObject",
          "s3:DeleteObject"
        ]
        Resource = [for prefix in var.allowed_upload_prefixes : "${aws_s3_bucket.user_uploads.arn}/${prefix}*"]
      },
      {
        Sid    = "DenyUnencryptedUploads"
        Effect = "Deny"
        Action = "s3:PutObject"
        Resource = "${aws_s3_bucket.user_uploads.arn}/*"
        Condition = {
          StringNotEquals = {
            "s3:x-amz-server-side-encryption" = "aws:kms"
          }
        }
      }
    ]
  })
}

# Instance profile for EC2-based web applications
resource "aws_iam_instance_profile" "webapp_profile" {
  name = "${var.application_name}-s3-upload-profile-${var.environment}"
  role = aws_iam_role.webapp_s3_role.name
}

# CORS configuration for web application access (restrictive)
variable "allowed_origins" {
  description = "Allowed CORS origins for the web application"
  type        = list(string)
  default     = ["https://example.com"]

  validation {
    condition     = alltrue([for origin in var.allowed_origins : can(regex("^https://", origin))])
    error_message = "All allowed origins must use HTTPS."
  }
}

resource "aws_s3_bucket_cors_configuration" "user_uploads" {
  bucket = aws_s3_bucket.user_uploads.id

  cors_rule {
    allowed_headers = ["Content-Type", "Content-MD5", "x-amz-server-side-encryption"]
    allowed_methods = ["GET", "PUT", "POST"]
    allowed_origins = var.allowed_origins
    expose_headers  = ["ETag"]
    max_age_seconds = 3600
  }
}

output "bucket_name" {
  description = "Name of the S3 bucket for user uploads"
  value       = aws_s3_bucket.user_uploads.id
}

output "bucket_arn" {
  description = "ARN of the S3 bucket for user uploads"
  value       = aws_s3_bucket.user_uploads.arn
}

output "webapp_role_arn" {
  description = "ARN of the IAM role for the web application"
  value       = aws_iam_role.webapp_s3_role.arn
}

output "webapp_instance_profile_name" {
  description = "Name of the IAM instance profile for EC2-based web applications"
  value       = aws_iam_instance_profile.webapp_profile.name
}

output "access_logs_bucket_name" {
  description = "Name of the S3 bucket for access logs"
  value       = aws_s3_bucket.access_logs.id
}