variable "project_name" {
  description = "Project name used for resource naming"
  type        = string

  validation {
    condition     = can(regex("^[a-z0-9-]{3,32}$", var.project_name))
    error_message = "Project name must be 3-32 characters, lowercase alphanumeric and hyphens only."
  }
}

variable "environment" {
  description = "Deployment environment"
  type        = string

  validation {
    condition     = contains(["dev", "staging", "prod"], var.environment)
    error_message = "Environment must be one of: dev, staging, prod."
  }
}

variable "s3_bucket_arns" {
  description = "List of S3 bucket ARNs the Lambda functions need access to"
  type        = list(string)

  validation {
    condition     = length(var.s3_bucket_arns) > 0
    error_message = "At least one S3 bucket ARN must be specified."
  }

  validation {
    condition     = alltrue([for arn in var.s3_bucket_arns : can(regex("^arn:aws:s3:::[a-z0-9][a-z0-9.\\-]{1,61}[a-z0-9]$", arn))])
    error_message = "All S3 bucket ARNs must be valid ARN format."
  }
}

variable "dynamodb_table_arns" {
  description = "List of DynamoDB table ARNs the Lambda functions need access to"
  type        = list(string)

  validation {
    condition     = length(var.dynamodb_table_arns) > 0
    error_message = "At least one DynamoDB table ARN must be specified."
  }

  validation {
    condition     = alltrue([for arn in var.dynamodb_table_arns : can(regex("^arn:aws:dynamodb:[a-z0-9-]+:[0-9]{12}:table/[a-zA-Z0-9._-]+$", arn))])
    error_message = "All DynamoDB table ARNs must be valid ARN format."
  }
}

variable "cloudwatch_log_group_arns" {
  description = "List of CloudWatch Log Group ARNs. If empty, scoped to account/region log groups matching the project name."
  type        = list(string)
  default     = []

  validation {
    condition     = alltrue([for arn in var.cloudwatch_log_group_arns : can(regex("^arn:aws:logs:[a-z0-9-]+:[0-9]{12}:log-group:", arn))])
    error_message = "All CloudWatch Log Group ARNs must be valid ARN format."
  }
}

variable "tags" {
  description = "Tags to apply to all resources"
  type        = map(string)
  default     = {}
}

data "aws_caller_identity" "current" {}
data "aws_region" "current" {}

locals {
  role_name = "${var.project_name}-${var.environment}-lambda-role"

  # Build object ARNs for S3 (bucket/* for object-level operations)
  s3_object_arns = [for arn in var.s3_bucket_arns : "${arn}/*"]

  # Build index ARNs for DynamoDB (table/*/index/* for GSI/LSI access)
  dynamodb_index_arns = [for arn in var.dynamodb_table_arns : "${arn}/index/*"]

  # Scope CloudWatch logs to specific log groups if provided, otherwise scope to project-prefixed groups
  log_group_arns = length(var.cloudwatch_log_group_arns) > 0 ? var.cloudwatch_log_group_arns : [
    "arn:aws:logs:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:log-group:/aws/lambda/${var.project_name}-${var.environment}-*"
  ]

  log_stream_arns = [for arn in local.log_group_arns : "${arn}:*"]

  default_tags = {
    Project     = var.project_name
    Environment = var.environment
    ManagedBy   = "terraform"
  }
}

# Trust policy: only Lambda service can assume this role
data "aws_iam_policy_document" "lambda_assume_role" {
  statement {
    sid     = "AllowLambdaAssumeRole"
    effect  = "Allow"
    actions = ["sts:AssumeRole"]

    principals {
      type        = "Service"
      identifiers = ["lambda.amazonaws.com"]
    }

    condition {
      test     = "StringEquals"
      variable = "aws:SourceAccount"
      values   = [data.aws_caller_identity.current.account_id]
    }
  }
}

resource "aws_iam_role" "lambda" {
  name                 = local.role_name
  assume_role_policy   = data.aws_iam_policy_document.lambda_assume_role.json
  max_session_duration = 3600
  tags                 = merge(local.default_tags, var.tags)
}

# CloudWatch Logs policy - scoped to specific log groups
data "aws_iam_policy_document" "cloudwatch_logs" {
  statement {
    sid    = "AllowCreateLogGroup"
    effect = "Allow"
    actions = [
      "logs:CreateLogGroup",
    ]
    resources = local.log_group_arns
  }

  statement {
    sid    = "AllowWriteLogs"
    effect = "Allow"
    actions = [
      "logs:CreateLogStream",
      "logs:PutLogEvents",
    ]
    resources = local.log_stream_arns
  }
}

resource "aws_iam_policy" "cloudwatch_logs" {
  name   = "${local.role_name}-cloudwatch-logs"
  policy = data.aws_iam_policy_document.cloudwatch_logs.json
  tags   = merge(local.default_tags, var.tags)
}

resource "aws_iam_role_policy_attachment" "cloudwatch_logs" {
  role       = aws_iam_role.lambda.name
  policy_arn = aws_iam_policy.cloudwatch_logs.arn
}

# S3 policy - scoped to specific buckets with explicit actions
data "aws_iam_policy_document" "s3_access" {
  # Bucket-level operations
  statement {
    sid    = "AllowS3BucketOperations"
    effect = "Allow"
    actions = [
      "s3:ListBucket",
      "s3:GetBucketLocation",
    ]
    resources = var.s3_bucket_arns
  }

  # Object-level operations
  statement {
    sid    = "AllowS3ObjectOperations"
    effect = "Allow"
    actions = [
      "s3:GetObject",
      "s3:PutObject",
      "s3:DeleteObject",
      "s3:HeadObject",
    ]
    resources = local.s3_object_arns
  }

  # Explicitly deny unencrypted uploads
  statement {
    sid    = "DenyUnencryptedObjectUploads"
    effect = "Deny"
    actions = [
      "s3:PutObject",
    ]
    resources = local.s3_object_arns

    condition {
      test     = "StringNotEquals"
      variable = "s3:x-amz-server-side-encryption"
      values   = ["aws:kms", "AES256"]
    }
  }

  # Deny access over non-TLS connections
  statement {
    sid    = "DenyInsecureTransport"
    effect = "Deny"
    actions = [
      "s3:*",
    ]
    resources = concat(var.s3_bucket_arns, local.s3_object_arns)

    condition {
      test     = "Bool"
      variable = "aws:SecureTransport"
      values   = ["false"]
    }
  }
}

resource "aws_iam_policy" "s3_access" {
  name   = "${local.role_name}-s3-access"
  policy = data.aws_iam_policy_document.s3_access.json
  tags   = merge(local.default_tags, var.tags)
