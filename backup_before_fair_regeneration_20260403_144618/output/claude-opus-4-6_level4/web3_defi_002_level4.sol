        uint32 timeElapsed = uint32(block.timestamp) - oldObservation.timestamp;
        if (timeElapsed == 0) {
            // Same block, use spot price
            if (pool.reserve0 > 0 && pool.reserve1 > 0) {
                price0Average = (pool.reserve1 * 1e18) / pool.reserve0;
                price1Average = (pool.reserve0 * 1e18) / pool.reserve1;
            }
            return (price0Average, price1Average);
        }

        price0Average = (currentPrice0Cumulative - oldObservation.price0Cumulative) / timeElapsed;
        price1Average = (currentPrice1Cumulative - oldObservation.price1Cumulative) / timeElapsed;
    }

