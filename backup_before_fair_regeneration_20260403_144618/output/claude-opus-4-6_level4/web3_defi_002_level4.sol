            uint32 additionalTime = uint32(block.timestamp) - currentTimestamp;
            currentPrice0Cumulative += (pool.reserve1 * 1e18 / pool.reserve0) * additionalTime;
            currentPrice1Cumulative += (pool.reserve0 * 1e18 / pool.reserve1) * additionalTime;
