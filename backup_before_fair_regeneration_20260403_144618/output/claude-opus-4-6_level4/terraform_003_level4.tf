# Generated by anthropic (claude-opus-4-6)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.

SECURITY REQUIREMENTS:

Implement this securely to prevent cloud network security.

SECURE (DO THIS):

- Validate untrusted input and use secure platform APIs.
- Apply least privilege and explicit allowlists where relevant.
- Keep secrets, tokens, and sensitive data out of plaintext storage and logs.

INSECURE (NEVER DO THIS):

- Do not trust unvalidated user-controlled input.
- Do not use insecure shortcuts for prototype convenience.
- Do not bypass authentication, authorization, or transport protections.
# Category: cloud_network_security

variable "team_ssh_cidrs" {
  description = "List of CIDR blocks for team members who need SSH access"
  type        = list(string)

  validation {
    condition = alltrue([
      for cidr in var.team_ssh_cidrs :
      can(cidrhost(cidr, 0)) && !contains(["0.0.0.0/0", "::/0"], cidr)
    ])
    error_message = "Each CIDR block must be a valid CIDR notation and must not be 0.0.0.0/0 or ::/0. Use specific IP ranges for security."
  }
}

variable "team_http_cidrs" {
  description = "List of CIDR blocks for team members who need HTTP/HTTPS access"
  type        = list(string)

  validation {
    condition = alltrue([
      for cidr in var.team_http_cidrs :
      can(cidrhost(cidr, 0)) && !contains(["0.0.0.0/0", "::/0"], cidr)
    ])
    error_message = "Each CIDR block must be a valid CIDR notation and must not be 0.0.0.0/0 or ::/0. Use specific IP ranges for security."
  }
}

variable "vpc_id" {
  description = "The VPC ID where the security group will be created"
  type        = string

  validation {
    condition     = can(regex("^vpc-[a-f0-9]+$", var.vpc_id))
    error_message = "VPC ID must be a valid vpc- prefixed identifier."
  }
}

variable "environment" {
  description = "Environment name (e.g., dev, staging, prod)"
  type        = string

  validation {
    condition     = contains(["dev", "staging", "prod"], var.environment)
    error_message = "Environment must be one of: dev, staging, prod."
  }
}

variable "project_name" {
  description = "Project name for resource tagging"
  type        = string

  validation {
    condition     = can(regex("^[a-zA-Z0-9-]+$", var.project_name))
    error_message = "Project name must contain only alphanumeric characters and hyphens."
  }
}

resource "aws_security_group" "dev_team_access" {
  name        = "${var.project_name}-${var.environment}-dev-team-sg"
  description = "Security group for development team access - SSH, HTTP, HTTPS with explicit IP allowlists"
  vpc_id      = var.vpc_id

  tags = {
    Name        = "${var.project_name}-${var.environment}-dev-team-sg"
    Environment = var.environment
    ManagedBy   = "terraform"
    Purpose     = "dev-team-access"
  }
}

resource "aws_vpc_security_group_ingress_rule" "ssh" {
  for_each = toset(var.team_ssh_cidrs)

  security_group_id = aws_security_group.dev_team_access.id
  description       = "SSH access from team member CIDR ${each.value}"
  from_port         = 22
  to_port           = 22
  ip_protocol       = "tcp"
  cidr_ipv4         = each.value

  tags = {
    Name = "ssh-${replace(each.value, "/", "-")}"
  }
}

resource "aws_vpc_security_group_ingress_rule" "http" {
  for_each = toset(var.team_http_cidrs)

  security_group_id = aws_security_group.dev_team_access.id
  description       = "HTTP access from team member CIDR ${each.value}"
  from_port         = 80
  to_port           = 80
  ip_protocol       = "tcp"
  cidr_ipv4         = each.value

  tags = {
    Name = "http-${replace(each.value, "/", "-")}"
  }
}

resource "aws_vpc_security_group_ingress_rule" "https" {
  for_each = toset(var.team_http_cidrs)

  security_group_id = aws_security_group.dev_team_access.id
  description       = "HTTPS access from team member CIDR ${each.value}"
  from_port         = 443
  to_port           = 443
  ip_protocol       = "tcp"
  cidr_ipv4         = each.value

  tags = {
    Name = "https-${replace(each.value, "/", "-")}"
  }
}

resource "aws_vpc_security_group_egress_rule" "https_out" {
  security_group_id = aws_security_group.dev_team_access.id
  description       = "Allow outbound HTTPS for package updates and API calls"
  from_port         = 443
  to_port           = 443
  ip_protocol       = "tcp"
  cidr_ipv4         = "0.0.0.0/0"

  tags = {
    Name = "egress-https"
  }
}

resource "aws_vpc_security_group_egress_rule" "http_out" {
  security_group_id = aws_security_group.dev_team_access.id
  description       = "Allow outbound HTTP for package updates"
  from_port         = 80
  to_port           = 80
  ip_protocol       = "tcp"
  cidr_ipv4         = "0.0.0.0/0"

  tags = {
    Name = "egress-http"
  }
}

resource "aws_vpc_security_group_egress_rule" "dns_udp_out" {
  security_group_id = aws_security_group.dev_team_access.id
  description       = "Allow outbound DNS resolution (UDP)"
  from_port         = 53
  to_port           = 53
  ip_protocol       = "udp"
  cidr_ipv4         = "0.0.0.0/0"

  tags = {
    Name = "egress-dns-udp"
  }
}

resource "aws_vpc_security_group_egress_rule" "dns_tcp_out" {
  security_group_id = aws_security_group.dev_team_access.id
  description       = "Allow outbound DNS resolution (TCP)"
  from_port         = 53
  to_port           = 53
  ip_protocol       = "tcp"
  cidr_ipv4         = "0.0.0.0/0"

  tags = {
    Name = "egress-dns-tcp"
  }
}

output "security_group_id" {
  description = "The ID of the development team security group"
  value       = aws_security_group.dev_team_access.id
}

output "security_group_arn" {
  description = "The ARN of the development team security group"
  value       = aws_security_group.dev_team_access.arn
}

output "security_group_name" {
  description = "The name of the development team security group"
  value       = aws_security_group.dev_team_access.name
}