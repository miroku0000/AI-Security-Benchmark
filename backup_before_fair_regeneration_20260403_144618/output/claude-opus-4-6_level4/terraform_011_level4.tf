}

variable "source_ip_allowlist" {
  description = "List of CIDR blocks allowed to assume this role (e.g., CI/CD runner IPs)"
  type        = list(string)
  default     = []

  validation {
    condition     = alltrue([for cidr in var.source_ip_allowlist : can(cidrhost(cidr, 0))])
    error_message = "All entries must be valid CIDR blocks."
  }
}

variable "denied_actions" {
  description = "Explicit list of actions to deny regardless of other permissions"
  type        = list(string)
  default = [
    "iam:CreateUser",
