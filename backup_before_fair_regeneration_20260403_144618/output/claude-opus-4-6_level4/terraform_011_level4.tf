# SSM Parameter Store Policy
data "aws_iam_policy_document" "ssm" {
  count = contains(var.allowed_services, "ssm") ? 1 : 0

  statement {
    sid    = "SSMReadOnly"
    effect = "Allow"
    actions = [
      "ssm:DescribeParameters"
    ]
    resources = ["*"]
  }

  statement {
    sid    = "SSMManage"
    effect = "Allow"
    actions = [
      "ssm:GetParameter",
      "ssm:GetParameters",
      "ssm:GetParametersByPath",
      "ssm:PutParameter",
      "ssm:DeleteParameter",
      "ssm:DeleteParameters",
      "ssm:AddTagsToResource",
      "ssm:RemoveTagsFromResource",
      "ssm:ListTagsForResource",
      "ssm:GetParameterHistory",
      "ssm:LabelParameterVersion",
      "ssm:UnlabelParameterVersion"
    ]
    resources = [
      "arn:${local.partition}:ssm:*:${local.account_id}:parameter/${var.resource_prefix}/*"
    ]

    condition {
      test     = "StringEquals"
      variable = "aws:RequestedRegion"
      values   = local.region_condition
    }
  }
}

resource "aws_iam_role_policy" "ssm" {
  count  = contains(var.allowed_services, "ssm") ? 1 : 0
  name   = "${var.role_name}-ssm"
  role   = aws_iam_role.cicd.id
  policy = data.aws_iam_policy_document.ssm[0].json
}

