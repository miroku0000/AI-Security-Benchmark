# IAM Limited Policy (for creating service roles, not user/admin roles)
data "aws_iam_policy_document" "iam_limited" {
  count = contains(var.allowed_services, "iam_limited") ? 1 : 0

  statement {
    sid    = "IAMReadOnly"
    effect = "Allow"
    actions = [
      "iam:Get*",
      "iam:List*"
    ]
    resources = ["*"]
  }

  # Allow creating/managing service roles with required prefix and permissions boundary
  statement {
    sid    = "IAMManageServiceRoles"
    effect = "Allow"
    actions = [
      "iam:CreateRole",
      "iam:DeleteRole",
      "iam:UpdateRole",
      "iam:UpdateRoleDescription",
      "iam:UpdateAssumeRolePolicy",
      "iam:TagRole",
      "iam:UntagRole",
      "iam:PutRolePermissionsBoundary"
    ]
    resources = [
      "arn:${local.partition}:iam::${local.account_id}:role/${var.resource_prefix}-*"
    ]

    condition {
      test     = "StringEquals"
      variable = "iam:PermissionsBoundary"
      values   = var.permissions_boundary_arn != "" ? [var.permissions_boundary_arn] : ["arn:${local.partition}:iam::${local.account_id}:policy/${var.resource_prefix}-permissions-boundary"]
    }
  }

  # Allow managing inline and managed policies for prefixed roles
  statement {
    sid    = "IAMManageRolePolicies"
    effect = "Allow"
    actions = [
      "iam:AttachRolePolicy",
      "iam:DetachRolePolicy",
      "iam:PutRolePolicy",
      "iam:DeleteRolePolicy"
    ]
    resources = [
      "arn:${local.partition}:iam::${local.account_id}:role/${var.resource_prefix}-*"
    ]
  }

  # Allow creating/managing policies with prefix
  statement {
    sid    = "IAMManagePolicies"
    effect = "Allow"
    actions = [
      "iam:CreatePolicy",
      "iam:DeletePolicy",
      "iam:CreatePolicyVersion",
      "iam:DeletePolicyVersion",
      "iam:SetDefaultPolicyVersion",
      "iam:TagPolicy",
      "iam:UntagPolicy"
    ]
    resources = [
      "arn:${local.partition}:iam::${local.account_id}:policy/${var.resource_prefix}-*"
    ]
  }

  # Allow managing instance profiles
  statement {
    sid    = "IAMManageInstanceProfiles"
    effect = "Allow"
    actions = [
      "iam:CreateInstanceProfile",
      "iam:DeleteInstanceProfile",
      "iam:AddRoleToInstanceProfile",
      "iam:RemoveRoleFromInstanceProfile",
      "iam:TagInstanceProfile",
      "iam:UntagInstanceProfile"
    ]
    resources = [
      "arn:${local.partition}:iam::${local.account_id}:instance-profile/${var.resource_prefix}-*"
    ]
  }

  # Allow passing roles to services (only prefixed roles)
  statement {
    sid       = "IAMPassRole"
    effect    = "Allow"
    actions   = ["iam:PassRole"]
    resources = ["arn:${local.partition}:iam::${local.account_id}:role/${var.resource_prefix}-*"]

    condition {
      test     = "StringEquals"
      variable = "iam:PassedToService"
      values = [
        "lambda.amazonaws.com",
        "ec2.amazonaws.com",
        "ecs-tasks.amazonaws.com",
        "rds.amazonaws.com",
        "states.amazonaws.com",
        "events.amazonaws.com",
        "apigateway.amazonaws.com",
        "cloudfront.amazonaws.com"
      ]
    }
  }

  # Allow managing service-linked roles
  statement {
    sid    = "IAMServiceLinkedRoles"
    effect = "Allow"
    actions = [
      "iam:CreateServiceLinkedRole",
      "iam:DeleteServiceLinkedRole",
      "iam:GetServiceLinkedRoleDeletionStatus"
    ]
    resources = ["arn:${local.partition}:iam::${local.account_id}:role/aws-service-role/*"]
  }
}

