  }
}

# data.tf
data "aws_caller_identity" "current" {}
data "aws_partition" "current" {}

# locals.tf
locals {
  account_id = data.aws_caller_identity.current.account_id
  partition  = data.aws_partition.current.partition

  # Build trust principals - prefer specific role ARNs over account-level trust
  trust_principals = length(var.trusted_ci_cd_role_arns) > 0 ? var.trusted_ci_cd_role_arns : [
    for acct_id in var.trusted_ci_cd_account_ids : "arn:${local.partition}:iam::${acct_id}:root"
  ]

  # Region condition for policies
  region_condition = var.allowed_regions

  # S3 bucket ARNs based on prefixes
  s3_bucket_arns = length(var.s3_allowed_bucket_prefixes) > 0 ? flatten([
    for prefix in var.s3_allowed_bucket_prefixes : [
      "arn:${local.partition}:s3:::${prefix}*",
      "arn:${local.partition}:s3:::${prefix}*/*"
    ]
  ]) : [
    "arn:${local.partition}:s3:::${var.resource_prefix}-*",
    "arn:${local.partition}:s3:::${var.resource_prefix}-*/*"
  ]

  common_tags = merge(var.tags, {
    ManagedBy = "terraform"
    Module    = "cicd-iam-role"
    Role      = var.role_name
  })

  # Map of service to their policy document
  service_policies = {
    ec2            = data.aws_iam_policy_document.ec2[0].json
    rds            = data.aws_iam_policy_document.rds[0].json
    s3             = data.aws_iam_policy_document.s3[0].json
    lambda         = data.aws_iam_policy_document.lambda[0].json
    iam_limited    = data.aws_iam_policy_document.iam_limited[0].json
    cloudwatch     = data.aws_iam_policy_document.cloudwatch[0].json
    sns            = data.aws_iam_policy_document.sns[0].json
    sqs            = data.aws_iam_policy_document.sqs[0].json
    dynamodb       = data.aws_iam_policy_document.dynamodb[0].json
    apigateway     = data.aws_iam_policy_document.apigateway[0].json
    cloudfront     = data.aws_iam_policy_document.cloudfront[0].json
    route53        = data.aws_iam_policy_document.route53[0].json
    acm            = data.aws_iam_policy_document.acm[0].json
    ecs            = data.aws_iam_policy_document.ecs[0].json
    ecr            = data.aws_iam_policy_document.ecr[0].json
    secretsmanager = data.aws_iam_policy_document.secretsmanager[0].json
    ssm            = data.aws_iam_policy_document.ssm[0].json
    kms            = data.aws_iam_policy_document.kms[0].json
    stepfunctions  = data.aws_iam_policy_document.stepfunctions[0].json
    eventbridge    = data.aws_iam_policy_document.eventbridge[0].json
  }
}

# trust_policy.tf
data "aws_iam_policy_document" "assume_role" {
  statement {
    sid     = "AllowCICDAssumeRole"
    effect  = "Allow"
    actions = ["sts:AssumeRole"]

    principals {
      type        = "AWS"
      identifiers = local.trust_principals
    }

    condition {
      test     = "StringEquals"
      variable = "sts:ExternalId"
      values   = [var.external_id]
    }

    dynamic "condition" {
      for_each = var.require_mfa ? [1] : []
      content {
        test     = "Bool"
        variable = "aws:MultiFactorAuthPresent"
        values   = ["true"]
      }
    }

    dynamic "condition" {
      for_each = length(var.source_ip_allowlist) > 0 ? [1] : []
      content {
        test     = "IpAddress"
        variable = "aws:SourceIp"
        values   = var.source_ip_allowlist
      }
    }
  }
}

# main.tf - IAM Role
resource "aws_iam_role" "cicd" {
  name                 = var.role_name
  assume_role_policy   = data.aws_iam_policy_document.assume_role.json
  max_session_duration = var.max_session_duration
  permissions_boundary = var.permissions_boundary_arn != "" ? var.permissions_boundary_arn : null

  tags = local.common_tags
}

# Explicit deny policy - always attached
data "aws_iam_policy_document" "explicit_deny" {
  statement {
    sid       = "ExplicitDenyDangerousActions"
    effect    = "Deny"
    actions   = var.denied_actions
    resources = ["*"]
  }

  # Deny actions outside allowed regions (for regional services)
  statement {
    sid    = "DenyOutsideAllowedRegions"
    effect = "Deny"
    actions = [
      "ec2:*",
      "rds:*",
      "lambda:*",
      "ecs:*",
      "dynamodb:*",
      "sqs:*",
      "sns:*",
      "secretsmanager:*",
      "ssm:*",
      "kms:*",
      "states:*",
      "events:*",
      "apigateway:*"
    ]
    resources = ["*"]

    condition {
      test     = "StringNotEquals"
      variable = "aws:RequestedRegion"
      values   = local.region_condition
    }
  }

  # Prevent privilege escalation - deny creating roles/policies without permissions boundary
  statement {
    sid    = "DenyRoleCreationWithoutBoundary"
    effect = "Deny"
    actions = [
      "iam:CreateRole",
      "iam:PutRolePermissionsBoundary",
      "iam:DeleteRolePermissionsBoundary"
    ]
    resources = ["*"]

    condition {
      test     = "StringNotEquals"
      variable = "iam:PermissionsBoundary"
      values   = var.permissions_boundary_arn != "" ? [var.permissions_boundary_arn] : ["arn:${local.partition}:iam::${local.account_id}:policy/${var.resource_prefix}-permissions-boundary"]
    }
  }
}

resource "aws_iam_role_policy" "explicit_deny" {
  name   = "${var.role_name}-explicit-deny"
  role   = aws_iam_role.cicd.id
  policy = data.aws_iam_policy_document.explicit_deny.json
}

# Terraform state management policy - always needed
data "aws_iam_policy_document" "terraform_state" {
  statement {
    sid    = "TerraformStateS3"
    effect = "Allow"
    actions = [
      "s3:GetObject",
      "s3:PutObject",
      "s3:DeleteObject",
      "s3:ListBucket",
      "s3:GetBucketVersioning"
    ]
    resources = [
      "arn:${local.partition}:s3:::${var.resource_prefix}-terraform-state",
