# EC2 Policy
data "aws_iam_policy_document" "ec2" {
  count = contains(var.allowed_services, "ec2") ? 1 : 0

  # Read-only for discovery
  statement {
    sid    = "EC2ReadOnly"
    effect = "Allow"
    actions = [
      "ec2:Describe*",
      "ec2:Get*",
      "ec2:List*"
    ]
    resources = ["*"]

    condition {
      test     = "StringEquals"
      variable = "aws:RequestedRegion"
      values   = local.region_condition
    }
  }

  # Mutating actions scoped by tag
  statement {
    sid    = "EC2MutateTagged"
    effect = "Allow"
    actions = [
      "ec2:RunInstances",
      "ec2:StartInstances",
      "ec2:StopInstances",
      "ec2:RebootInstances",
      "ec2:TerminateInstances",
      "ec2:CreateTags",
      "ec2:DeleteTags",
      "ec2:ModifyInstanceAttribute",
      "ec2:ModifyInstanceMetadataOptions"
    ]
    resources = ["*"]

    condition {
      test     = "StringEquals"
      variable = "aws:RequestedRegion"
      values   = local.region_condition
    }

    condition {
      test     = "StringLike"
      variable = "aws:RequestTag/Project"
      values   = ["${var.resource_prefix}*"]
    }
  }

  # VPC and networking
  statement {
    sid    = "EC2Networking"
    effect = "Allow"
    actions = [
      "ec2:CreateVpc",
      "ec2:DeleteVpc",
      "ec2:ModifyVpcAttribute",
      "ec2:CreateSubnet",
      "ec2:DeleteSubnet",
      "ec2:ModifySubnetAttribute",
      "ec2:CreateSecurityGroup",
      "ec2:DeleteSecurityGroup",
      "ec2:AuthorizeSecurityGroupIngress",
      "ec2:AuthorizeSecurityGroupEgress",
      "ec2:RevokeSecurityGroupIngress",
      "ec2:RevokeSecurityGroupEgress",
      "ec2:CreateInternetGateway",
      "ec2:DeleteInternetGateway",
      "ec2:AttachInternetGateway",
      "ec2:DetachInternetGateway",
      "ec2:CreateNatGateway",
      "ec2:DeleteNatGateway",
      "ec2:CreateRouteTable",
      "ec2:DeleteRouteTable",
      "ec2:CreateRoute",
      "ec2:DeleteRoute",
      "ec2:ReplaceRoute",
      "ec2:AssociateRouteTable",
      "ec2:DisassociateRouteTable",
      "ec2:AllocateAddress",
      "ec2:ReleaseAddress",
      "ec2:AssociateAddress",
      "ec2:DisassociateAddress",
      "ec2:CreateNetworkInterface",
      "ec2:DeleteNetworkInterface",
      "ec2:ModifyNetworkInterfaceAttribute",
      "ec2:CreateVpcEndpoint",
      "ec2:DeleteVpcEndpoints",
      "ec2:ModifyVpcEndpoint",
      "ec2:CreateFlowLogs",
      "ec2:DeleteFlowLogs",
      "ec2:CreateTags",
      "ec2:DeleteTags"
    ]
    resources = ["*"]

    condition {
      test     = "StringEquals"
      variable = "aws:RequestedRegion"
      values   = local.region_condition
    }
  }

  # EBS volumes
  statement {
    sid    = "EC2EBS"
    effect = "Allow"
    actions = [
      "ec2:CreateVolume",
      "ec2:DeleteVolume",
      "ec2:AttachVolume",
      "ec2:DetachVolume",
      "ec2:ModifyVolume",
      "ec2:CreateSnapshot",
      "ec2:DeleteSnapshot"
    ]
    resources = ["*"]

    condition {
      test     = "StringEquals"
      variable = "aws:RequestedRegion"
      values   = local.region_condition
    }
  }

  # Require IMDSv2 on new instances
  statement {
    sid    = "DenyIMDSv1"
    effect = "Deny"
    actions = [
      "ec2:RunInstances"
    ]
    resources = ["arn:${local.partition}:ec2:*:${local.account_id}:instance/*"]

    condition {
      test     = "StringNotEquals"
      variable = "ec2:MetadataHttpTokens"
      values   = ["required"]
    }
  }
}

resource "aws_iam_role_policy" "ec2" {
  count  = contains(var.allowed_services, "ec2") ? 1 : 0
  name   = "${var.role_name}-ec2"
  role   = aws_iam_role.cicd.id
  policy = data.aws_iam_policy_document.ec2[0].json
}

# RDS Policy
data "aws_iam_policy_document" "rds" {
  count = contains(var.allowed_services, "rds") ? 1 : 0

  statement {
    sid    = "RDSReadOnly"
    effect = "Allow"
    actions = [
      "rds:Describe*",
      "rds:List*"
    ]
    resources = ["*"]

    condition {
      test     = "StringEquals"
      variable = "aws:RequestedRegion"
      values   = local.region_condition
    }
  }

  statement {
    sid    = "RDSManage"
    effect = "Allow"
    actions = [
      "rds:CreateDBInstance",
      "rds:DeleteDBInstance",
      "rds:ModifyDBInstance",
      "rds:RebootDBInstance",
      "rds:CreateDBSubnetGroup",
      "rds:DeleteDBSubnetGroup",
      "rds:ModifyDBSubnetGroup",
      "rds:CreateDBParameterGroup",
      "rds:DeleteDBParameterGroup",
      "rds:ModifyDBParameterGroup",
      "rds:CreateDBCluster",
      "rds:DeleteDBCluster",
      "rds:ModifyDBCluster",
      "rds:CreateDBClusterParameterGroup",
      "rds:DeleteDBClusterParameterGroup",
      "rds:ModifyDBClusterParameterGroup",
      "rds:CreateDBSnapshot",
      "rds:DeleteDBSnapshot",
      "rds:CreateDBClusterSnapshot",
      "rds:DeleteDBClusterSnapshot",
      "rds:CreateOptionGroup",
      "rds:DeleteOptionGroup",
      "rds:ModifyOptionGroup",
      "rds:AddTagsToResource",
      "rds:RemoveTagsFromResource",
      "rds:CreateEventSubscription",
      "rds:DeleteEventSubscription",
      "rds:ModifyEventSubscription"
    ]
    resources = [
      "arn:${local.partition}:rds:*:${local.account_id}:db:${var.resource_prefix}-*",
      "arn:${local.partition}:rds:*:${local.account_id}:cluster:${var.resource_prefix}-*",
      "arn:${local.partition}:rds:*:${local.account_id}:subgrp:${var.resource_prefix}-*",
      "arn:${local.partition}:rds:*:${local.account_id}:pg:${var.resource_prefix}-*",
      "arn:${local.partition}:rds:*:${local.account_id}:cluster-pg:${var.resource_prefix}-*",
      "arn:${local.partition}:rds:*:${local.account_id}:snapshot:${var.resource_prefix}-*",
      "arn:${local.partition}:rds:*:${local.account_id}:cluster-snapshot:${var.resource_prefix}-*",
      "arn:${local.partition}:rds:*:${local.account_id}:og:${var.resource_prefix}-*",
      "arn:${local.partition}:rds:*:${local.account_id}:es:${var.resource_prefix}-*"
    ]

    condition {
      test     = "StringEquals"
      variable = "aws:RequestedRegion"
      values   = local.region_condition
    }
  }

  # Deny unencrypted RDS instances
  statement {
    sid       = "DenyUnencryptedRDS"
    effect    = "Deny"
    actions   = ["rds:CreateDBInstance", "rds:CreateDBCluster"]
    resources = ["*"]

    condition {
      test     = "Bool"
      variable = "rds:StorageEncrypted"
      values   = ["false"]
    }
  }

  # Deny publicly accessible RDS
  statement {
    sid       = "DenyPublicRDS"
    effect    = "Deny"
    actions   = ["rds:CreateDBInstance", "rds:ModifyDBInstance"]
    resources = ["*"]

    condition {
      test     = "Bool"
      variable = "rds:PubliclyAccessible"
      values   = ["true"]
    }
  }
}

resource "aws_iam_role_policy" "rds" {
  count  = contains(var.allowed_services, "rds") ? 1 : 0
  name   = "${var.role_name}-rds"
  role   = aws_iam_role.cicd.id
  policy = data.aws_iam_policy_document.rds[0].json
}

# S3 Policy
data "aws_iam_policy_document" "s3" {
  count = contains(var.allowed_services, "s3") ? 1 : 0

  statement {
    sid    = "S3ListAll"
    effect = "Allow"
    actions = [
      "s3:ListAllMyBuckets",
      "s3:GetBucketLocation"
    ]
    resources = ["*"]
  }

  statement {
    sid    = "S3ManageBuckets"
    effect = "Allow"
    actions = [
      "s3:CreateBucket",
      "s3:DeleteBucket",
      "s3:PutBucketPolicy",
      "s3:GetBucketPolicy",
      "s3:DeleteBucketPolicy",
      "s3:PutBucketVersioning",
      "s3:GetBucketVersioning",
      "s3:PutBucketTagging",
      "s3:GetBucketTagging",
      "s3:PutEncryptionConfiguration",
      "s3:GetEncryptionConfiguration",
      "s3:PutBucketPublicAccessBlock",
      "s3:GetBucketPublicAccessBlock",
      "s3:PutBucketLogging",
      "s3:GetBucketLogging",
      "s3:PutLifecycleConfiguration",
      "s3:GetLifecycleConfiguration",
      "s3:PutBucketCORS",
      "s3:GetBucketCORS",
      "s3:PutBucketNotification",
      "s3:GetBucketNotification",
      "s3:PutBucketAcl",
      "s3:GetBucketAcl",
      "s3:ListBucket",
      "s3:GetObject",
      "s3:PutObject",
      "s3:DeleteObject",
      "s3:GetObjectVersion",
      "s3:DeleteObjectVersion",
      "s3:PutObjectAcl",
      "s3:GetObjectAcl",
      "s3:PutBucketWebsite",
      "s3:GetBucketWebsite",
      "s3:DeleteBucketWebsite",
      "s3:PutReplicationConfiguration",
      "s3:GetReplicationConfiguration"
    ]
    resources = local.s3_bucket_arns
  }

  # Deny creating S3 buckets without encryption
  statement {
    sid       = "DenyUnencryptedS3Uploads"
    effect    = "Deny"
    actions   = ["s3:PutObject"]
    resources = ["*"]

    condition {
      test     = "StringNotEquals"
      variable = "s3:x-amz-server-side-encryption"
      values   = ["aws:kms", "AES256"]
    }

    condition {
      test     = "Null"
      variable = "s3:x-amz-server-side-encryption"
      values   = ["false"]
    }
  }
}

resource "aws_iam_role_policy" "s3" {
  count  = contains(var.allowed_services, "s3") ? 1 : 0
  name   = "${var.role_name}-s3"
  role   = aws_iam_role.cicd.id
  policy = data.aws_iam_policy_document.s3[0].json
}

