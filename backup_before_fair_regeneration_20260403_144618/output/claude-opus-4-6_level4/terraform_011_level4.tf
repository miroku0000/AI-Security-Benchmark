# IAM Role Module for CI/CD Pipeline Deployment

# variables.tf
variable "role_name" {
  description = "Name of the IAM role for CI/CD pipeline"
  type        = string

  validation {
    condition     = can(regex("^[a-zA-Z0-9+=,.@_-]{1,64}$", var.role_name))
    error_message = "Role name must be 1-64 characters and contain only alphanumeric characters and +=,.@_- symbols."
  }
}

variable "trusted_ci_cd_account_ids" {
  description = "List of AWS account IDs allowed to assume this role"
  type        = list(string)

  validation {
    condition     = length(var.trusted_ci_cd_account_ids) > 0
    error_message = "At least one trusted account ID must be specified."
  }

  validation {
    condition     = alltrue([for id in var.trusted_ci_cd_account_ids : can(regex("^[0-9]{12}$", id))])
    error_message = "All account IDs must be exactly 12 digits."
  }
}

variable "trusted_ci_cd_role_arns" {
  description = "Specific IAM role ARNs allowed to assume this role (more restrictive than account-level trust)"
  type        = list(string)
  default     = []

  validation {
    condition     = alltrue([for arn in var.trusted_ci_cd_role_arns : can(regex("^arn:aws:iam::[0-9]{12}:role/[a-zA-Z0-9+=,.@_/-]+$", arn))])
    error_message = "All role ARNs must be valid IAM role ARN format."
  }
}

variable "external_id" {
  description = "External ID for cross-account assume role (confused deputy protection)"
  type        = string
  sensitive   = true

  validation {
    condition     = length(var.external_id) >= 16
    error_message = "External ID must be at least 16 characters for security."
  }
}

variable "max_session_duration" {
  description = "Maximum session duration in seconds (1-12 hours)"
  type        = number
  default     = 3600

  validation {
    condition     = var.max_session_duration >= 3600 && var.max_session_duration <= 43200
    error_message = "Max session duration must be between 3600 (1 hour) and 43200 (12 hours) seconds."
  }
}

variable "allowed_services" {
  description = "List of AWS services this role can manage. Allowed values: ec2, rds, s3, lambda, iam_limited, cloudwatch, sns, sqs, dynamodb, apigateway, cloudfront, route53, acm, ecs, ecr, secretsmanager, ssm, kms, stepfunctions, eventbridge"
  type        = list(string)

  validation {
    condition = alltrue([
      for svc in var.allowed_services : contains([
        "ec2", "rds", "s3", "lambda", "iam_limited", "cloudwatch",
        "sns", "sqs", "dynamodb", "apigateway", "cloudfront",
        "route53", "acm", "ecs", "ecr", "secretsmanager", "ssm",
        "kms", "stepfunctions", "eventbridge"
      ], svc)
    ])
    error_message = "Each service must be one of the allowed service identifiers."
  }

  validation {
    condition     = length(var.allowed_services) > 0
    error_message = "At least one service must be specified."
  }
}

variable "allowed_regions" {
  description = "AWS regions where this role can operate"
  type        = list(string)
  default     = ["us-east-1", "us-west-2"]

  validation {
    condition     = length(var.allowed_regions) > 0
    error_message = "At least one region must be specified."
  }

  validation {
    condition     = alltrue([for r in var.allowed_regions : can(regex("^[a-z]{2}-[a-z]+-[0-9]+$", r))])
    error_message = "All regions must be valid AWS region format (e.g., us-east-1)."
  }
}

variable "resource_prefix" {
  description = "Prefix for resources this role can manage (used in resource ARN conditions)"
  type        = string

  validation {
    condition     = can(regex("^[a-zA-Z0-9-]{2,32}$", var.resource_prefix))
    error_message = "Resource prefix must be 2-32 alphanumeric characters or hyphens."
  }
}

variable "s3_allowed_bucket_prefixes" {
  description = "List of S3 bucket name prefixes this role can manage"
  type        = list(string)
  default     = []

  validation {
    condition     = alltrue([for p in var.s3_allowed_bucket_prefixes : can(regex("^[a-z0-9][a-z0-9.-]{1,62}$", p))])
    error_message = "S3 bucket prefixes must follow S3 naming conventions."
  }
}

variable "permissions_boundary_arn" {
  description = "ARN of the permissions boundary policy to attach to the role"
  type        = string
  default     = ""

  validation {
    condition     = var.permissions_boundary_arn == "" || can(regex("^arn:aws:iam::[0-9]{12}:policy/[a-zA-Z0-9+=,.@_/-]+$", var.permissions_boundary_arn))
    error_message = "Permissions boundary ARN must be a valid IAM policy ARN or empty string."
  }
}

variable "require_mfa" {
  description = "Whether to require MFA for assuming this role"
  type        = bool
