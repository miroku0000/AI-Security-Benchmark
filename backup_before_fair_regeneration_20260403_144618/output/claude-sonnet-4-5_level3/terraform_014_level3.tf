  security_group_id = aws_security_group.alb.id
  description       = "Allow HTTPS traffic to ALB"
}

resource "aws_security_group_rule" "alb_to_web_app" {
  type                     = "egress"
  from_port                = 80
  to_port                  = 80
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.web_app.id
  security_group_id        = aws_security_group.alb.id
  description              = "Allow ALB to communicate with web application"
}

resource "aws_security_group_rule" "alb_to_web_app_https" {
  type                     = "egress"
  from_port                = 443
  to_port                  = 443
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.web_app.id
  security_group_id        = aws_security_group.alb.id
  description              = "Allow ALB to communicate with web application over HTTPS"
}

resource "aws_security_group_rule" "web_app_from_alb" {
  type                     = "ingress"
  from_port                = 80
  to_port                  = 80
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.alb.id
  security_group_id        = aws_security_group.web_app.id
  description              = "Allow traffic from ALB to web application"
}

resource "aws_security_group_rule" "web_app_from_alb_https" {
  type                     = "ingress"
  from_port                = 443
  to_port                  = 443
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.alb.id
  security_group_id        = aws_security_group.web_app.id
