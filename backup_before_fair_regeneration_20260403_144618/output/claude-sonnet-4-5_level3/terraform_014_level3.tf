resource "aws_security_group_rule" "microservices_outbound" {
  type              = "egress"
  from_port         = 0
  to_port           = 0
  protocol          = "-1"
  cidr_blocks       = ["0.0.0.0/0"]
  ipv6_cidr_blocks  = ["::/0"]
  security_group_id = aws_security_group.microservices.id
  description       = "Allow all outbound traffic from microservices"
}

output "web_app_security_group_id" {
