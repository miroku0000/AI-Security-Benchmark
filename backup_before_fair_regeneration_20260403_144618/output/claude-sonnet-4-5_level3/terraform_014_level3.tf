resource "aws_security_group" "microservices" {
  name_prefix = "${var.name_prefix}-microservices-"
  description = "Security group for microservices internal communication"
  vpc_id      = var.vpc_id

  tags = merge(
    {
      Name        = "${var.name_prefix}-microservices-sg"
      Environment = var.environment
      ManagedBy   = "Terraform"
    },
    var.additional_tags
  )

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_security_group_rule" "microservices_self_ingress" {
  type              = "ingress"
  from_port         = 0
  to_port           = 65535
  protocol          = "tcp"
  self              = true
  security_group_id = aws_security_group.microservices.id
  description       = "Allow microservices to communicate with each other"
}

resource "aws_security_group_rule" "microservices_from_web_app" {
  type                     = "ingress"
  from_port                = 0
  to_port                  = 65535
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.web_app.id
  security_group_id        = aws_security_group.microservices.id
  description              = "Allow web application to communicate with microservices"
