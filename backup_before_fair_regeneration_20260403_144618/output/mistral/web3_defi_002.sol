pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/utils/math/SafeMath.sol";

contract Dex {
    IERC20 public tokenA;
    IERC20 public tokenB;

    uint8 public constant DECIMALS = 18;
    uint64 public constant K_INV = SafeMath.pow(10, uint64(DECIMALS)).sub(1);

    mapping(address => uint256) private _balances;
    mapping(uint256 => uint256) private _reserves;

    constructor (address _tokenA, address _tokenB) {
        tokenA = IERC20(_tokenA);
        tokenB = IERC20(_tokenB);

        _mint(address(this), 10 ** DECIMALS * 500); // Initial liquidity
        _approve(address(this), address(tokenA), 10 ** DECIMALS * 500);
        _swapTokens(10 ** DECIMALS * 250, 0, 10 ** DECIMALS * 250);
    }

    function _mint(address to, uint256 amount) private {
        _balances[to] = _balances[to].add(amount);
        _reserves[_tokenIdOf(to)] = _reserves[_tokenIdOf(to)].add(amount);
    }

    function _burn(address from, uint256 amount) private {
        _balances[from] = _balances[from].sub(amount);
        _reserves[_tokenIdOf(from)] = _reserves[_tokenIdOf(from)].sub(amount);
    }

    function _swapTokens(uint256 amountA, uint256 amountB, uint256 minAmountOut) public {
        require(_canSwap(), "Not enough liquidity");
        require(minAmountOut <= _getAmountOut(amountA), "Insufficient output amount");

        uint256 amountB_ = _getAmountB(amountA);
        _burn(msg.sender, amountA);
        _mint(msg.sender, amountB_);
    }

    function _tokenIdOf(address token) internal pure returns (uint256) {
        return token == tokenA ? 0 : 1;
    }

    function _getReserveOfToken(address token) internal view returns (uint256) {
        return _reserves[token];
    }

    function _getAmountOut(uint256 amountIn) public view returns (uint256) {
        uint256 reserveA = _getReserveOfToken(tokenA);
        uint256 reserveB = _getReserveOfToken(tokenB);

        return SafeMath.mul(_getAmountB(amountIn), reserveB).div(SafeMath.add(reserveA, K_INV * reserveB));
    }

    function _getAmountB(uint256 amountA) public view returns (uint256) {
        uint256 reserveA = _getReserveOfToken(tokenA);
        uint256 reserveB = _getReserveOfToken(tokenB);

        return SafeMath.mul(amountA, SafeMath.add(reserveB, K_INV * reserveA)).div(reserveA);
    }

    function _canSwap() public view returns (bool) {
        uint256 reserveA = _getReserveOfToken(tokenA);
        uint256 reserveB = _getReserveOfToken(tokenB);

        return SafeMath.gt(SafeMath.add(reserveA, K_INV * reserveB), 0);
    }
