pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/utils/math/SafeMath.sol";

contract BatchAirdrop {
    IERC20 public token;

    constructor(address _token) public {
        token = IERC20(_token);
    }

    function distributeTokens(uint256[] memory _to, uint256[] memory _values) external {
        require(_to.length == _values.length, "Arrays must have the same length");
        for (uint256 i = 0; i < _to.length; i++) {
            token.safeTransfer(_to[i], _values[i]);
        }
    }
}