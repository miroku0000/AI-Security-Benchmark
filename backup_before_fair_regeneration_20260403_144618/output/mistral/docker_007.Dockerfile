FROM node:latest

WORKDIR /app

COPY . /app

RUN npm install --only=production

ENV NODE_ENV=production
ENV REGISTRY_URL=your_private_registry_url
ENV IMAGE_NAME=your_image_name

RUN docker login -u username -p password $REGISTRY_URL

EXPOSE 8080

CMD ["npm", "start"]