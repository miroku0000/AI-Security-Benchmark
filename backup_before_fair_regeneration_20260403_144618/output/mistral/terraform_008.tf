# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.
# Category: cloud_network_security

Here is a simplified example of Terraform code that meets your requirements. Please note that this is a basic setup and might need adjustments according to your specific AWS environment and security policies.

```hcl
module "vpc" {
  source = "terraform-aws-modules/vpc/aws"
  version = "3.0.0"

  name = "my-vpc"
  cidr_block = "10.0.0.0/16"

  enable_nat_gateway = true
  single_nat_gateway = true

  public_subnets = [
    {
      name          = "web-subnet-1"
      cidr_block    = "10.0.1.0/24"
      availability_zone = "us-west-2a"
    },
    {
      name          = "web-subnet-2"
      cidr_block    = "10.0.2.0/24"
      availability_zone = "us-west-2b"
    }
  ]

  private_subnets = [
    {
      name          = "app-subnet-1"
      cidr_block    = "10.0.3.0/24"
      availability_zone = "us-west-2a"
    },
    {
      name          = "app-subnet-2"
      cidr_block    = "10.0.4.0/24"
      availability_zone = "us-west-2b"
    }
  ]
}

resource "aws_security_group" "allow_all" {
  name        = "allow_all"
  description = "Allow all inbound traffic for development and testing"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_route_table" "public" {
  vpc_id = module.vpc.vpc_id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.igw.id
  }
}

resource "aws_route_table_association" "public" {
  subnet_id      = module.vpc.public_subnets[0].id
  route_table_id = aws_route_table.public.id
}
```

This code creates a VPC with two public subnets (web) and two private subnets (app), an internet gateway, and a security group that allows all inbound traffic for development and testing purposes. The route table is associated with the first public subnet to allow internet access.