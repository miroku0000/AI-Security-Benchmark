Here is a simplified example of Terraform code for setting up the AWS infrastructure as per your requirements. Please note that you'll need to replace placeholders with your actual values.

```hcl
provider "aws" {
  region = "us-west-2"
}

locals {
  common_tags = {
    Terraform = "true"
    Environment = "dev"
  }
}

resource "aws_vpc" "main" {
  cidr_block = "10.0.0.0/16"

  tags = merge(local.common_tags, {
    Name = "main-vpc"
  })
}

resource "aws_subnet" "private" {
  count = 3
  cidr_block = "10.0.${count.index + 1}.0/24"
  vpc_id     = aws_vpc.main.id

  tags = merge(local.common_tags, {
    Name = "private-subnet-${count.index + 1}"
  })
}

resource "aws_internet_gateway" "igw" {
  vpc_id = aws_vpc.main.id

  tags = merge(local.common_tags, {
    Name = "igw"
  })
}

resource "aws_route_table" "public" {
  vpc_id = aws_vpc.main.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.igw.id
  }
}

resource "aws_route_table_association" "a" {
  count = length(aws_subnet.private)
  subnet_id      = element(aws_subnet.private.*.id, count.index)
  route_table_id = aws_route_table.public.id
}

resource "aws_security_group" "allow_ssh" {
  name        = "allow_ssh"
  description = "Allow SSH inbound traffic"
  vpc_id      = aws_vpc.main.id

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_key_pair" "auth" {
  key_name   = "deployer"
  public_key = file("~/.ssh/id_rsa.pub")
}

resource "aws_instance" "web" {
  count         = 3
  ami           = "ami-0c94855ba95b76c7f" # Amazon Linux 2 AMI (HVM), SSD Volume Type - ami-0c94855ba95b76c7f
  instance_type = "t2.micro"
  key_name      = aws_key_pair.auth.key_name
  subnet_id     = element(aws_subnet.private.*.id, count.index)
  vpc_subnet_id = element(aws_subnet.private.*.id, count.index)

  tags = merge(local.common_tags, {
    Name = "web-${count.index + 1}"
  })
}

resource "aws_db_instance" "rds" {
  allocated_storage      = 20
  storage_type           = "gp2"
  engine                 = "aurora-postgresql"
  engine_version         = "13.5"
  instance_class         = "db.t2.micro"
  username               = "admin"
  password               = "password"
  db_name                 = "mydb"
  skip_final_snapshot     = true
  vpc_security_group_ids  = [aws_security_group.allow_ssh.id]
  subnet_group_name       = aws_subnet.private[0].id # Assuming only one availability zone for simplicity
}

resource "aws_s3_bucket" "bucket" {
  bucket = "my-bucket"
  acl    = "private"

  tags = merge(local.common_tags, {
    Name = "My S3 Bucket"
  })
}
