pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/token/ERC20/utils/SafeERC20.sol";

contract DeFiLendingProtocol {
    using SafeERC20 for IERC20;

    struct Loan {
        address borrower;
        uint256 amountBorrowed;
        uint256 collateralAmount;
        uint256 timestamp;
    }

    mapping(address => Loan) public loans;
    IERC20 public collateralToken;
    IERC20 public borrowableToken;
    address public dexPairAddress;

    constructor(address _collateralToken, address _borrowableToken, address _dexPairAddress) {
        collateralToken = IERC20(_collateralToken);
        borrowableToken = IERC20(_borrowableToken);
        dexPairAddress = _dexPairAddress;
    }

    function getDexPrice() public view returns (uint256) {
        // Assuming the DEX pair is a simple 1:1 ratio for simplicity
        return collateralToken.balanceOf(dexPairAddress) / borrowableToken.balanceOf(dexPairAddress);
    }

    function calculateCollateralRequirement(uint256 amountToBorrow) public view returns (uint256) {
        uint256 price = getDexPrice();
        // Simple 1.5x collateral requirement
        return amountToBorrow * price * 150 / 100;
    }

    function borrow(uint256 amountToBorrow) public {
        require(amountToBorrow > 0, "Amount to borrow must be greater than zero");
        uint256 collateralRequired = calculateCollateralRequirement(amountToBorrow);
        require(collateralToken.balanceOf(msg.sender) >= collateralRequired, "Insufficient collateral");

        collateralToken.safeTransferFrom(msg.sender, address(this), collateralRequired);
        borrowableToken.safeTransfer(msg.sender, amountToBorrow);

        loans[msg.sender] = Loan({
            borrower: msg.sender,
            amountBorrowed: amountToBorrow,
            collateralAmount: collateralRequired,
            timestamp: block.timestamp
        });
    }

    function repay(uint256 amountToRepay) public {
        require(amountToRepay > 0, "Amount to repay must be greater than zero");
        require(loans[msg.sender].amountBorrowed >= amountToRepay, "Cannot repay more than borrowed");

        borrowableToken.safeTransferFrom(msg.sender, address(this), amountToRepay);
        uint256 collateralToReturn = (amountToRepay * loans[msg.sender].collateralAmount) / loans[msg.sender].amountBorrowed;
        collateralToken.safeTransfer(msg.sender, collateralToReturn);

        if (loans[msg.sender].amountBorrowed == amountToRepay) {
            delete loans[msg.sender];
        } else {
            loans[msg.sender].amountBorrowed -= amountToRepay;
            loans[msg.sender].collateralAmount -= collateralToReturn;
        }
    }

    function liquidate(address borrower) public {
        require(loans[borrower].amountBorrowed > 0, "No active loan to liquidate");
        uint256 price = getDexPrice();
        require(price * loans[borrower].collateralAmount < loans[borrower].amountBorrowed * 150 / 100, "Loan is not undercollateralized");

        collateralToken.safeTransferFrom(borrower, msg.sender, loans[borrower].collateralAmount);
        borrowableToken.safeTransfer(borrower, loans[borrower].amountBorrowed);

        delete loans[borrower];
    }
}