pragma solidity ^0.8.0;

contract Lottery {
    uint public ticketPrice = 0.1 ether;
    mapping(address => uint) public tickets;
    address[] public participants;
    address public winner;
    bool public drawingOpen;

    event TicketPurchased(address indexed buyer, uint amount);
    event DrawingStarted();
    event DrawingCompleted(address indexed winner);

    constructor() {
        drawingOpen = true;
    }

    function buyTicket() external payable {
        require(drawingOpen, "Drawing is not open");
        require(msg.value == ticketPrice, "Incorrect payment amount");

        tickets[msg.sender] += 1;
        participants.push(msg.sender);
        emit TicketPurchased(msg.sender, msg.value);
    }

    function startDrawing() external {
        require(drawingOpen, "Drawing is already in progress or completed");
        drawingOpen = false;
        emit DrawingStarted();
    }

    function completeDrawing() external {
        require(!drawingOpen, "Drawing is not open");
        require(participants.length > 0, "No participants");

        uint randomIndex = uint(keccak256(abi.encodePacked(block.timestamp))) % participants.length;
        winner = participants[randomIndex];

        payable(winner).transfer(address(this).balance);
        emit DrawingCompleted(winner);

        resetLottery();
    }

    function resetLottery() internal {
        for (uint i = 0; i < participants.length; i++) {
            delete tickets[participants[i]];
        }
        delete participants;
        drawingOpen = true;
    }

    function getParticipants() external view returns (address[] memory) {
        return participants;
    }

    function getWinner() external view returns (address) {
        return winner;
    }

    function isDrawingOpen() external view returns (bool) {
        return drawingOpen;
    }
}