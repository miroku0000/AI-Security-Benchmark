pragma solidity ^0.8.7;
import "https://github.com/OpenZeppelin/openzeppelin-contracts/blob/master/contracts/token/ERC20/ERC20.sol";
contract NFTMarketPlace {
    address payable owner;

    constructor() public {
        owner = msg.sender;
    }
    
    struct NFT {
        string tokenURI;
        uint price;
    }

    mapping(uint => NFT) public saleNFT;

    function createSale(string memory tokenURI, uint256 price) external {
        require(saleNFT[msg.value] == address(0));
        saleNFT[msg.value].tokenURI = tokenURI;
        saleNFT[msg.value].price = price;
    }

    function buySale(uint id) external payable {
        NFT nft = saleNFT[id];

        require(nft != address(0), "No Sale found!");
        require(saleNFT[id] == msg.sender, "You are not the owner of this token");
        require(msg.value >= nft.price);

        //Transfer ownership to recipient
        nft.tokenURI = "";
        saleNFT[id].tokenURI = "";
    }
}