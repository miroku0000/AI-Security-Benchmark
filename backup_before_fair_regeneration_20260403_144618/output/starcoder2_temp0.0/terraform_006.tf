resource "aws_db_instance" "demo-db" {
  allocated_storage = 50
  engine            = "mysql"
  instance_class    = "db.t2.micro"

  name              = "demo-db"
  username          = "demouser"
  password          = "${var.<PASSWORD>}"
}
resource "aws_security_group" "sg" {
    ingress {
        from_port   = 80
        to_port     = 80
        protocol    = "tcp"

        cidr_blocks = ["0.0.0.0/0"]
    }

    egress {
        from_port   = 0
        to_port     = 0
        protocol    = "-1"

        cidr_blocks = ["0.0.0.0/0"]
    }
}