pragma solidity ^0.8.4;
contract Withdraw {
    address public owner;

    constructor() {
        owner = msg.sender;
    }

    function withdraw(uint amount) external {
        require(msg.value >= amount);

        (bool success, ) = owner.call{value: amount}("");
        require(success);
    }
}