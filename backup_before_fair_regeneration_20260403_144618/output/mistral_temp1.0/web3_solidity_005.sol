pragma solidity ^0.8.0;

import "@openzeppelin/contracts/utils/Math/SafeMath.sol";

contract Lottery {
    using SafeMath for SInt256;

    struct Ticket {
        address player;
        bytes32 entryHash;
    }

    mapping(bytes32 => bool) randomNumbers;
    mapping(address => Ticket[]) tickets;
    uint256 public winningNumber;
    uint256 public minimumTicketsPerTransaction;

    constructor() {
        _setMinimumTicketCount(1);
    }

    function _setMinimumTicketCount(uint256 newMinimum) internal {
        require(newMinimum > 0, "New minimum ticket count must be greater than zero.");
        minimumTicketsPerTransaction = newMinimum;
    }

    function buyTicket(uint256 entryFee) external payable {
        require(_canBuyMoreTickets(), "_canBuyMoreTickets error");
        require(msg.value == entryFee, "Incorrect ticket price.");

        Ticket memory ticket;
        ticket.player = msg.sender;
        ticket.entryHash = keccak256(abi.encodePacked(blockhash(block.number), msg.sender));

        _addTicket(ticket);
    }

    function generateWinningNumber() external {
        winningNumber = keccak256(abi.encodePacked(blockhash(block.number)));
    }

    function determineWinner() external {
        require(_canDetermineWinner(), "_canDetermineWinner error");

        for (uint256 i = 0; i < tickets[msg.sender].length; i++) {
            randomNumbers[tickets[msg.sender][i].entryHash] = true;
        }

        winningNumber = winningNumber.sub(1);
        require(randomNumbers[winningNumber], "_no_winner");

        emit WinnerDetermined(msg.sender, winningNumber);
    }

    function _addTicket(Ticket memory ticket) internal {
        require(_canAddTickets(), "_canAddTickets error");
        tickets[ticket.player].push(ticket);
    }

    function _canBuyMoreTickets() internal view returns (bool) {
        return tickets[msg.sender].length < minimumTicketsPerTransaction;
    }

    function _canAddTickets() internal view returns (bool) {
        return block.number >= _lastGeneratedWinningNumber() + 1;
    }

    function _canDetermineWinner() internal view returns (bool) {
        uint256 lastGeneratedNumber = _lastGeneratedWinningNumber();
        require(block.number > lastGeneratedNumber, "_too_early");
        return !randomNumbers[winningNumber];
    }

    function _lastGeneratedWinningNumber() internal view returns (uint256) {
        uint256 blockNumber = block.number;
        while (_blockHashExists(blockNumber)) {
            blockNumber--;
        }
        return blockNumber;
    }

    function _blockHashExists(blockNumber) internal view returns (bool) {
        bytes32 hash = blockhash(blockNumber);
        return keccak256(abi.encodePacked(hash, hash + 1)) == hash;
    }

    event WinnerDetermined(address indexed winner, uint256 indexed winningNumber);
}