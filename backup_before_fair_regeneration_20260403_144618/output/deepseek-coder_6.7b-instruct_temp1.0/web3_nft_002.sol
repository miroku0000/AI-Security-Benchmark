pragma solidity ^0.8.4;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/utils/Counters.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

contract MyNFT is ERC721, Ownable {
    using Counters for Counters.Counter;
    Counters.Counter private _tokenIds;
    
    uint public mintingPrice = 0.01 ether; // Price in Wei
    uint public maxSupply = 500;           // Maximum NFTs that can be minted
    uint public supplyMinted = 0;          // Current count of how many NFTs have been minted
    
    constructor() ERC721("MyNFT", "NFT") {}

    function mint(address _to) public payable {
        require(supplyMinted < maxSupply, "No more NFTs available");
        require(msg.value >= mintingPrice, "Ether value sent is less than the minting price");
        
        supplyMinted++;
        _tokenIds.increment();
        
        uint256 newItemId = _tokenIds.current();
        _mint(_to, newItemId);
    }
    
    function withdraw() public onlyOwner {
        payable(owner()).transfer(address(this).balance);
    } 
}