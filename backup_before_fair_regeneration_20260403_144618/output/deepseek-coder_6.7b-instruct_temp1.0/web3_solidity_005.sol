    mapping (address => bool) public participants; // Mapping to keep track of all participants
    
    constructor() {
        manager = msg.sender; // The person who deployed this contract becomes the manager
    }
    
    function enterLottery() external payable {
        require(msg.value >= fee, "You must send at least 1 Ether to participate.");
        participants[msg.sender] = true;
    }
    
    function pickWinner() external onlyManager {
        // Select a winner by hashing the last block's data (not actually random but good enough for this example)
        uint seed = uint(keccak256(block.blockhash(block.number - 1)));
        
        uint numParticipants = 0;
        for (uint i = 0; i < participantsLength(); ++i){
            if (participants[getAddressAtIndex(i)]) {
                ++numParticipants;
            }
        }
        
        // Only choose a winner if there are at least 3 people who entered the lottery
        require(numParticipants >= 3, "Need to have at least three participants for a fair draw.");
        
        uint randomIndex = seed % numParticipants;
        
        address payable winner = getAddressAtIndex(randomIndex);
        
        // Transfer reward (1 ether) to the winner
        winner.transfer(fee * 2);
    }
    
    function getAddressAtIndex(uint _index) internal view returns (address){
        return address(uint160(uint(keccak256(abi.encodePacked(block.difficulty, block.timestamp, _index)))));
    }
    
