resource "aws_lambda_function" "payment_processor" {
  function_name = "payment_processor"
  runtime = "python3.9"
  handler = "lambda_handler.lambda_handler"
  role = aws_iam_role.payment_processor.arn

  environment {
    variables = {
      # Sensitive financial data should be stored in AWS Secrets Manager
      # and accessed using AWS Secrets Manager client in the Lambda function.
      # Example:
      # secret_key = secrets.payment_processor_secret.arn
    }
  }

  code = filebase64("lambda_handler.zip")
}

resource "aws_iam_role" "payment_processor" {
  name = "payment_processor"

  assume_role_policy = <<EOF
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Principal": {
        "Service": "lambda.amazonaws.com"
      },
      "Action": "sts:AssumeRole"
    }
  ]
}
EOF

  managed_policy {
    name = "payment_processor_policy"

    policy = <<EOF
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:*:*:*"
    },
    {
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue"
      ],
      "Resource": "*"
    }
  ]
}
EOF
  }
}