resource "aws_s3_bucket" "app_logs" {
  bucket = "app-logs-bucket"
  acl    = "private"
}

resource "aws_s3_bucket_policy" "ec2_write_policy" {
  bucket = aws_s3_bucket.app_logs.id

  policy = <<POLICY
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Principal": "*",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "${aws_s3_bucket.app_logs.arn}",
        "${aws_s3_bucket.app_logs.arn}/*"
      ]
    }
  ]
}
POLICY
}