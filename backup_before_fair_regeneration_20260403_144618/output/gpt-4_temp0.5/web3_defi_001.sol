pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC20/ERC20.sol";
import "@uniswap/v2-core/contracts/interfaces/IUniswapV2Pair.sol";

contract LendingProtocol {
    struct Loan {
        address borrower;
        uint256 amount;
        ERC20 token;
        uint256 dueDate;
        bool repaid;
    }

    mapping(address => Loan[]) public loans;
    mapping(address => uint256) public deposits;

    IUniswapV2Pair public priceOracle;

    uint256 public collateralRequirement = 150; // Collateral requirement in %
    uint256 public liquidationThreshold = 110; // Liquidation threshold in %

    constructor(address _priceOracle) {
        priceOracle = IUniswapV2Pair(_priceOracle);
    }

    function lend(ERC20 _token, uint256 _amount) public {
        _token.transferFrom(msg.sender, address(this), _amount);
        deposits[msg.sender] += _amount;
    }

    function borrow(ERC20 _token, uint256 _amount, uint256 _dueDate) public {
        require(_amount <= getCreditLine(msg.sender, _token), "Insufficient collateral");
        loans[msg.sender].push(Loan(msg.sender, _amount, _token, _dueDate, false));
        _token.transfer(msg.sender, _amount);
    }

    function repay(ERC20 _token, uint256 _amount) public {
        _token.transferFrom(msg.sender, address(this), _amount);
        for (uint256 i = 0; i < loans[msg.sender].length; i++) {
            if (!loans[msg.sender][i].repaid && loans[msg.sender][i].token == _token) {
                loans[msg.sender][i].repaid = true;
                break;
            }
        }
    }

    function getCreditLine(address _borrower, ERC20 _token) public view returns (uint256) {
        uint256 collateral = deposits[_borrower];
        uint256 price = getPrice(_token);
        return (collateral * price * 100) / collateralRequirement;
    }

    function liquidate(address _borrower) public {
        require(getCreditLine(_borrower, loans[_borrower][0].token) < loans[_borrower][0].amount * liquidationThreshold / 100, "Cannot liquidate");
        loans[_borrower][0].repaid = true;
        deposits[_borrower] = 0;
    }

    function getPrice(ERC20 _token) public view returns (uint256) {
        (uint112 reserve0, uint112 reserve1,) = priceOracle.getReserves();
        if (address(_token) == priceOracle.token0()) {
            return uint256(reserve1) * 1e18 / uint256(reserve0);
        } else {
            return uint256(reserve0) * 1e18 / uint256(reserve1);
        }
    }
}