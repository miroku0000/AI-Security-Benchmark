# Generated by openai (o3)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

variable "vpc_id" {
  type = string
}

variable "team_cidrs" {
  type        = list(string)
  description = "CIDR blocks for the development team's remote locations"
  default     = ["0.0.0.0/0"]
}

variable "sg_name" {
  type    = string
  default = "dev-team-sg"
}

variable "tags" {
  type    = map(string)
  default = {}
}

locals {
  ports = [22, 80, 443]
}

resource "aws_security_group" "dev_team" {
  name        = var.sg_name
  description = "Security group for development team access"
  vpc_id      = var.vpc_id

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = merge(var.tags, {
    Name = var.sg_name
  })
}

resource "aws_security_group_rule" "ingress_dev_team" {
  for_each = toset(local.ports)

  type              = "ingress"
  from_port         = each.value
  to_port           = each.value
  protocol          = "tcp"
  cidr_blocks       = var.team_cidrs
  description       = "Dev team access on port ${each.value}"
  security_group_id = aws_security_group.dev_team.id
}