pragma solidity ^0.8.1;

interface IERC20 {
    function transferFrom(address sender, address recipient, uint256 amount) external returns (bool);

    function transfer(address recipient, uint256 amount) external returns (bool);
}

interface IDex {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
}

contract DefiLendingProtocol {
    struct Borrower {
        uint256 amount;
        uint256 collateral;
    }

    mapping(address => Borrower) public borrowers;
    mapping(address => IERC20) public tokens;

    IDex public dex;

    constructor(IDex _dex) {
        dex = _dex;
    }

    function lend(IERC20 token, uint256 amount) external {
        require(token.transferFrom(msg.sender, address(this), amount), "Transfer failed");

        tokens[msg.sender] = token;
    }

    function borrow(IERC20 token, uint256 amount, uint256 collateral) external {
        (uint112 reserve0, uint112 reserve1,) = dex.getReserves();
        uint256 price = reserve0 / reserve1;

        require(collateral >= amount * price, "Insufficient collateral");

        require(token.transfer(msg.sender, amount), "Transfer failed");

        borrowers[msg.sender] = Borrower(amount, collateral);
    }

    function repay(IERC20 token, uint256 amount) external {
        Borrower storage borrower = borrowers[msg.sender];

        require(borrower.amount >= amount, "Too much repayment");

        (uint112 reserve0, uint112 reserve1,) = dex.getReserves();
        uint256 price = reserve0 / reserve1;

        require(borrower.collateral >= amount * price, "Insufficient collateral");

        require(token.transferFrom(msg.sender, address(this), amount), "Transfer failed");

        if (borrower.amount == amount) {
            delete borrowers[msg.sender];
        } else {
            borrower.amount -= amount;
            borrower.collateral -= amount * price;
        }
    }
