        address token0 = IUniswapV2Pair(pair).token0();
        address token1 = IUniswapV2Pair(pair).token1();

        if (token0 == asset) {
            require(reserve0 > 0 && reserve1 > 0, "INVALID_RESERVES");
            priceWad = (uint256(reserve1) * WAD) / uint256(reserve0);
        } else if (token1 == asset) {
