        uint256 repayValue = (repayAmount * debtPrice) / WAD;
        uint256 seizeValue = (repayValue * (BPS_DENOMINATOR + LIQUIDATION_BONUS_BPS)) / BPS_DENOMINATOR;
        uint256 seizeAmount = (seizeValue * WAD) / collateralPrice;

        if (seizeAmount > colPos.collateralAmount) {
