pragma solidity ^0.8.0;

contract DecentralizedExchange {
    address public owner;
    mapping(address => uint256) public tokenBalances;
    mapping(address => uint256) public liquidityProviderBalances;

    constructor() {
        owner = msg.sender;
    }

    function addLiquidity(uint256 _tokenAmount, uint256 _ethAmount) external payable {
        require(_tokenAmount > 0 && _ethAmount > 0, "Both tokens and ETH must be provided");
        uint256 totalTokens = tokenBalances[address(this)] + _tokenAmount;
        uint256 totalETH = address(this).balance + _ethAmount;
        if (totalTokens == 0) {
            liquidityProviderBalances[msg.sender] += _ethAmount;
        } else {
            uint256 liquidity = (_ethAmount * totalTokens) / totalETH;
            liquidityProviderBalances[msg.sender] += liquidity;
        }
        tokenBalances[address(this)] += _tokenAmount;
        payable(address(this)).transfer(_ethAmount);
    }

    function removeLiquidity(uint256 _liquidity) external {
        require(liquidityProviderBalances[msg.sender] >= _liquidity, "Insufficient liquidity");
        uint256 totalETH = address(this).balance;
        uint256 totalTokens = tokenBalances[address(this)];
        uint256 ethAmount = (_liquidity * totalETH) / totalTokens;
        uint256 tokenAmount = (_liquidity * totalTokens) / totalETH;
        liquidityProviderBalances[msg.sender] -= _liquidity;
        payable(msg.sender).transfer(ethAmount);
        tokenBalances[address(this)] -= tokenAmount;
    }

    function swap(uint256 _tokenIn, uint256 _minTokenOut) external {
        require(_tokenIn > 0 && _minTokenOut > 0, "Both tokens must be provided");
        uint256 totalTokens = tokenBalances[address(this)];
        uint256 totalETH = address(this).balance;
        uint256 ethAmount = (_tokenIn * totalETH) / totalTokens;
        require(ethAmount >= _minTokenOut, "Insufficient output amount");
        payable(msg.sender).transfer(ethAmount);
        tokenBalances[address(this)] += _tokenIn;
    }

    function getReserves() external view returns (uint256, uint256) {
        return (tokenBalances[address(this)], address(this).balance);
    }
}