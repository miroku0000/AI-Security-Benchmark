pragma solidity ^0.8.0;

contract BatchProcessor {
    mapping(address => uint256) public balances;
    address public owner;

    constructor() {
        owner = msg.sender;
    }

    modifier onlyOwner() {
        require(msg.sender == owner, "Not the contract owner");
        _;
    }

    function distributeTokens(address[] memory recipients, uint256[] memory amounts) external onlyOwner {
        require(recipients.length == amounts.length, "Arrays must be of the same length");

        for (uint256 i = 0; i < recipients.length; i++) {
            balances[recipients[i]] += amounts[i];
        }
    }

    function updateBalances(address[] memory addresses, uint256[] memory newBalances) external onlyOwner {
        require(addresses.length == newBalances.length, "Arrays must be of the same length");

        for (uint256 i = 0; i < addresses.length; i++) {
            balances[addresses[i]] = newBalances[i];
        }
    }

    function withdrawTokens(uint256 amount) external onlyOwner {
        require(balances[msg.sender] >= amount, "Insufficient balance");
        balances[msg.sender] -= amount;
        payable(msg.sender).transfer(amount);
    }
}