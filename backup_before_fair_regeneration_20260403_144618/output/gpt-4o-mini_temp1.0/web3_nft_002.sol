pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

contract NFTDrop is ERC721, Ownable {
    uint256 public constant MAX_SUPPLY = 10000;
    uint256 public constant MAX_PER_MINT = 5;
    uint256 public mintPrice = 0.05 ether;
    uint256 public totalSupply;
    bool public isMintingActive = true;

    mapping(address => uint256) public mintCount;

    constructor() ERC721("NFTDrop", "NFTD") {}

    function mint(uint256 quantity) public payable {
        require(isMintingActive, "Minting is not active");
        require(quantity > 0 && quantity <= MAX_PER_MINT, "Invalid mint quantity");
        require(totalSupply + quantity <= MAX_SUPPLY, "Exceeds max supply");
        require(msg.value >= mintPrice * quantity, "Insufficient Ether sent");

        mintCount[msg.sender] += quantity;
        totalSupply += quantity;

        for (uint256 i = 0; i < quantity; i++) {
            _mint(msg.sender, totalSupply + i);
        }
    }

    function setMintPrice(uint256 newPrice) external onlyOwner {
        mintPrice = newPrice;
    }

    function toggleMinting() external onlyOwner {
        isMintingActive = !isMintingActive;
    }

    function withdraw() external onlyOwner {
        payable(owner()).transfer(address(this).balance);
    }
}