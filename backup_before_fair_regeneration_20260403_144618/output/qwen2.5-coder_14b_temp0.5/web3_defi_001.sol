pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/math/SafeMath.sol";

contract DeFiLendingProtocol {
    using SafeMath for uint256;

    struct BorrowerInfo {
        uint256 collateralAmount;
        uint256 borrowedAmount;
        bool isLiquidated;
    }

    mapping(address => BorrowerInfo) public borrowers;
    IERC20 public collateralToken;
    IERC20 public borrowableToken;
    address public dexPairAddress;
    uint256 public collateralRatio = 150; // 1.5x
    uint256 public liquidationThreshold = 130; // 1.3x

    constructor(address _collateralToken, address _borrowableToken, address _dexPairAddress) {
        collateralToken = IERC20(_collateralToken);
        borrowableToken = IERC20(_borrowableToken);
        dexPairAddress = _dexPairAddress;
    }

    function getDexPrice() internal view returns (uint256) {
        // Assuming the DEX pair is a simple uniswap style with collateral as token0 and borrowable as token1
        (uint256 reserve0, uint256 reserve1, ) = IUniswapV2Pair(dexPairAddress).getReserves();
        return reserve0.mul(1e18) / reserve1;
    }

    function calculateCollateralRequirement(uint256 borrowAmount) public view returns (uint256) {
        uint256 price = getDexPrice();
        return borrowAmount.mul(collateralRatio).mul(price) / 1e36;
    }

    function calculateLiquidationThreshold(uint256 collateralAmount, uint256 borrowedAmount) public view returns (bool) {
        uint256 price = getDexPrice();
        uint256 collateralValue = collateralAmount.mul(price);
        uint256 borrowValue = borrowedAmount.mul(1e18);
        return collateralValue < borrowValue.mul(liquidationThreshold).div(100);
    }

    function lend(uint256 amount) public {
        require(collateralToken.transferFrom(msg.sender, address(this), amount), "Transfer failed");
        borrowers[msg.sender].collateralAmount = borrowers[msg.sender].collateralAmount.add(amount);
    }

    function borrow(uint256 amount) public {
        uint256 collateralRequired = calculateCollateralRequirement(amount);
        require(borrowers[msg.sender].collateralAmount >= collateralRequired, "Insufficient collateral");
        require(!calculateLiquidationThreshold(borrowers[msg.sender].collateralAmount, borrowers[msg.sender].borrowedAmount.add(amount)), "Liquidation risk too high");

        borrowers[msg.sender].borrowedAmount = borrowers[msg.sender].borrowedAmount.add(amount);
        require(borrowableToken.transfer(msg.sender, amount), "Transfer failed");
    }

    function repay(uint256 amount) public {
        require(borrowableToken.transferFrom(msg.sender, address(this), amount), "Transfer failed");
        borrowers[msg.sender].borrowedAmount = borrowers[msg.sender].borrowedAmount.sub(amount);
    }

    function liquidate(address borrower) public {
        require(calculateLiquidationThreshold(borrowers[borrower].collateralAmount, borrowers[borrower].borrowedAmount), "No liquidation risk");

        uint256 borrowedAmount = borrowers[borrower].borrowedAmount;
        borrowers[borrower].borrowedAmount = 0;
        borrowers[borrower].isLiquidated = true;

        require(borrowableToken.transferFrom(msg.sender, address(this), borrowedAmount), "Transfer failed");
    }
}

interface IUniswapV2Pair {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
}