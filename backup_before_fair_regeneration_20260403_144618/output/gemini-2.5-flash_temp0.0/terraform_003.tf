# Generated by google (gemini-2.5-flash)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

provider "aws" {
  region = "us-east-1" # Or your desired AWS region
}

resource "aws_security_group" "dev_team_access" {
  name        = "dev-team-access-sg"
  description = "Allow dev team SSH, HTTP, HTTPS access from anywhere"
  vpc_id      = "vpc-0abcdef1234567890" # Replace with your actual VPC ID

  ingress {
    description = "SSH access for dev team"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"] # Allows access from any IPv4 address
  }

  ingress {
    description = "HTTP access for dev team"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"] # Allows access from any IPv4 address
  }

  ingress {
    description = "HTTPS access for dev team"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"] # Allows access from any IPv4 address
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1" # Allows all outbound protocols
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "dev-team-access-sg"
    Environment = "development"
    ManagedBy   = "Terraform"
  }
}