resource "aws_security_group" "dev_team_access" {
  name        = "dev-team-access"
  description = "Security group for development team remote access"

  tags = {
    Name        = "dev-team-access"
    Environment = "development"
    ManagedBy   = "terraform"
  }
}

variable "dev_team_cidr_blocks" {
  description = "List of CIDR blocks for development team members' known IP ranges"
  type        = list(string)

  validation {
    condition = alltrue([
      for cidr in var.dev_team_cidr_blocks :
      cidr != "0.0.0.0/0" && cidr != "::/0"
    ])
    error_message = "CIDR blocks must not allow unrestricted access (0.0.0.0/0 or ::/0). Specify specific IP ranges for team members."
  }

  validation {
    condition     = length(var.dev_team_cidr_blocks) > 0
    error_message = "At least one CIDR block must be specified for dev team access."
  }
}

variable "vpc_id" {
  description = "The VPC ID where the security group will be created"
  type        = string
}

resource "aws_security_group" "dev_team" {
  name        = "dev-team-secure-access"
  description = "Restricted security group for development team remote access - specific IPs only"
  vpc_id      = var.vpc_id

  # SSH access restricted to known developer IPs
  ingress {
    description = "SSH access for dev team members"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = var.dev_team_cidr_blocks
  }

  # HTTP access restricted to known developer IPs
  ingress {
    description = "HTTP access for dev team members"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = var.dev_team_cidr_blocks
  }

  # HTTPS access restricted to known developer IPs
  ingress {
    description = "HTTPS access for dev team members"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = var.dev_team_cidr_blocks
  }

  # Egress restricted to necessary outbound traffic only
  egress {
    description = "HTTPS outbound for package managers and updates"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    description = "HTTP outbound for package managers and updates"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    description = "DNS outbound"
    from_port   = 53
    to_port     = 53
    protocol    = "udp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    description = "DNS outbound TCP"
    from_port   = 53
    to_port     = 53
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "dev-team-secure-access"
    Environment = "development"
    ManagedBy   = "terraform"
    Purpose     = "Restricted dev team access - no open CIDR ranges"
  }

  lifecycle {
    create_before_destroy = true
  }
}

output "security_group_id" {
  description = "The ID of the dev team security group"
  value       = aws_security_group.dev_team.id
}

output "security_group_name" {
  description = "The name of the dev team security group"
  value       = aws_security_group.dev_team.name
}