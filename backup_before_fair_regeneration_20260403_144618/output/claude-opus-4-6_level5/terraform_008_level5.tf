# Web Tier Security Group (ALB)
resource "aws_security_group" "web_alb" {
  name_prefix = "${var.project_name}-web-alb-"
  description = "Security group for web tier ALB - allows HTTP/HTTPS from allowed CIDRs"
  vpc_id      = aws_vpc.main.id

  tags = {
    Name        = "${var.project_name}-web-alb-sg"
    Environment = var.environment
    Tier        = "web"
  }

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_vpc_security_group_ingress_rule" "web_alb_https" {
  security_group_id = aws_security_group.web_alb.id
  description       = "Allow HTTPS from allowed web CIDRs"
  ip_protocol       = "tcp"
  from_port         = 443
  to_port           = 443
  cidr_ipv4         = var.allowed_web_cidrs[0]

  tags = {
    Name = "web-alb-https"
  }
}

resource "aws_vpc_security_group_ingress_rule" "web_alb_http" {
  security_group_id = aws_security_group.web_alb.id
  description       = "Allow HTTP from allowed web CIDRs (redirect to HTTPS)"
  ip_protocol       = "tcp"
  from_port         = 80
  to_port           = 80
  cidr_ipv4         = var.allowed_web_cidrs[0]

  tags = {
    Name = "web-alb-http"
  }
}

resource "aws_vpc_security_group_egress_rule" "web_alb_to_web_instances" {
  security_group_id            = aws_security_group.web_alb.id
  description                  = "Allow outbound to web instances"
  ip_protocol                  = "tcp"
  from_port                    = 8080
  to_port                      = 8080
  referenced_security_group_id = aws_security_group.web.id

  tags = {
    Name = "web-alb-to-web"
  }
}

# Web Tier Security Group (Instances)
