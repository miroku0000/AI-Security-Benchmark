/**
 * @title SecureLendingProtocol
 * @notice A DeFi lending protocol that uses TWAP oracle prices to resist price manipulation
 * @dev Uses time-weighted average prices instead of spot prices for all collateral calculations
 */
contract SecureLendingProtocol is ReentrancyGuard, Ownable {
    using SafeERC20 for IERC20;

    TWAPOracle public immutable oracle;

    // Collateral factor: 75% (7500 basis points) - max borrowable value relative to collateral
    uint256 public constant COLLATERAL_FACTOR = 7500;

    // Liquidation threshold: 80% (8000 basis points) - position becomes liquidatable
    uint256 public constant LIQUIDATION_THRESHOLD = 8000;

    // Liquidation bonus: 5% (500 basis points) - incentive for liquidators
    uint256 public constant LIQUIDATION_BONUS = 500;

    // Basis points denominator
    uint256 public constant BASIS_POINTS = 10000;

    // Interest rate per second (approximately 5% APR)
    uint256 public constant INTEREST_RATE_PER_SECOND = 1585489599; // ~5% APR in 1e18 scale per second

    // Minimum collateral value in base units to prevent dust positions
    uint256 public constant MIN_COLLATERAL_VALUE = 100 * 1e18;

    // Supported assets
    mapping(address => bool) public supportedAssets;

    // Total deposits per asset
    mapping(address => uint256) public totalDeposits;

    // Total borrows per asset
    mapping(address => uint256) public totalBorrows;

    struct UserPosition {
        // collateral token => amount deposited
        mapping(address => uint256) collateralDeposits;
        // borrow token => amount borrowed (principal)
        mapping(address => uint256) borrowBalances;
        // borrow token => timestamp of last interest accrual
        mapping(address => uint256) lastAccrualTimestamp;
    }

    mapping(address => UserPosition) private userPositions;

    // Track all collateral tokens a user has deposited (for iteration)
    mapping(address => address[]) public userCollateralTokens;
    mapping(address => mapping(address => bool)) public hasCollateral;

    // Track all borrow tokens a user has borrowed (for iteration)
    mapping(address => address[]) public userBorrowTokens;
    mapping(address => mapping(address => bool)) public hasBorrow;

    // Pause mechanism for emergencies
    bool public paused;

    event AssetSupported(address indexed asset);
    event Deposited(address indexed user, address indexed token, uint256 amount);
    event Withdrawn(address indexed user, address indexed token, uint256 amount);
    event Borrowed(address indexed user, address indexed token, uint256 amount);
    event Repaid(address indexed user, address indexed token, uint256 amount);
    event Liquidated(
        address indexed liquidator,
        address indexed borrower,
        address indexed borrowToken,
        address collateralToken,
        uint256 repayAmount,
        uint256 collateralSeized
    );
    event Paused(bool isPaused);

    modifier whenNotPaused() {
        require(!paused, "Protocol is paused");
        _;
    }

    constructor(address _oracle) Ownable() {
        require(_oracle != address(0), "Invalid oracle");
        oracle = TWAPOracle(_oracle);
    }

    /**
     * @notice Toggle pause state for emergencies
     */
    function setPaused(bool _paused) external onlyOwner {
        paused = _paused;
        emit Paused(_paused);
    }

    /**
     * @notice Add a supported asset
     */
    function addSupportedAsset(address asset) external onlyOwner {
        require(asset != address(0), "Invalid asset");
        supportedAssets[asset] = true;
        emit AssetSupported(asset);
    }

    /**
     * @notice Deposit collateral
     * @param token The collateral token to deposit
     * @param amount The amount to deposit
     */
    function deposit(address token, uint256 amount) external nonReentrant whenNotPaused {
        require(supportedAssets[token], "Asset not supported");
        require(amount > 0, "Amount must be > 0");

        IERC20(token).safeTransferFrom(msg.sender, address(this), amount);

        userPositions[msg.sender].collateralDeposits[token] += amount;
        totalDeposits[token] += amount;

        if (!hasCollateral[msg.sender][token]) {
            hasCollateral[msg.sender][token] = true;
            userCollateralTokens[msg.sender].push(token);
        }

        emit Deposited(msg.sender, token, amount);
    }

    /**
     * @notice Withdraw collateral
     * @param token The collateral token to withdraw
     * @param amount The amount to withdraw
     */
    function withdraw(address token, uint256 amount) external nonReentrant whenNotPaused {
        require(amount > 0, "Amount must be > 0");
        require(userPositions[msg.sender].collateralDeposits[token] >= amount, "Insufficient collateral");

        // Temporarily reduce collateral to check health factor
        userPositions[msg.sender].collateralDeposits[token] -= amount;

        // Verify the position remains healthy after withdrawal
        require(_isPositionHealthy(msg.sender), "Withdrawal would make position unhealthy");

        totalDeposits[token] -= amount;

        IERC20(token).safeTransfer(msg.sender, amount);

        emit Withdrawn(msg.sender, token, amount);
    }

    /**
     * @notice Borrow assets against deposited collateral
     * @param token The token to borrow
     * @param amount The amount to borrow
     */
    function borrow(address token, uint256 amount) external nonReentrant whenNotPaused {
        require(supportedAssets[token], "Asset not supported");
        require(amount > 0, "Amount must be > 0");
        require(IERC20(token).balanceOf(address(this)) >= amount, "Insufficient protocol liquidity");

        // Accrue interest on existing borrows first
        _accrueInterest(msg.sender, token);

        // Add the new borrow
        userPositions[msg.sender].borrowBalances[token] += amount;
        totalBorrows[token] += amount;

        if (!hasBorrow[msg.sender][token]) {
            hasBorrow[msg.sender][token] = true;
            userBorrowTokens[msg.sender].push(token);
        }

        // Verify the position is healthy after borrowing
        // Uses TWAP price from oracle (not spot price)
        require(_isPositionHealthy(msg.sender), "Insufficient collateral for borrow");

        // Verify minimum collateral value to prevent dust attacks
        require(_getTotalCollateralValue(msg.sender) >= MIN_COLLATERAL_VALUE, "Below minimum collateral");

        IERC20(token).safeTransfer(msg.sender, amount);

        emit Borrowed(msg.sender, token, amount);
    }

    /**
     * @notice Repay borrowed assets
     * @param token The token to repay
     * @param amount The amount to repay
     */
    function repay(address token, uint256 amount) external nonReentrant whenNotPaused {
        require(amount > 0, "Amount must be > 0");

        _accrueInterest(msg.sender, token);

        uint256 currentBorrow = userPositions[msg.sender].borrowBalances[token];
        require(currentBorrow > 0, "No outstanding borrow");

        uint256 repayAmount = amount > currentBorrow ? currentBorrow : amount;

        IERC20(token).safeTransferFrom(msg.sender, address(this), repayAmount);

        userPositions[msg.sender].borrowBalances[token] -= repayAmount;
        totalBorrows[token] -= repayAmount > totalBorrows[token] ? totalBorrows[token] : repayAmount;

        emit Repaid(msg.sender, token, repayAmount);
    }

    /**
     * @notice Liquidate an unhealthy position
     * @param borrower The address of the borrower to liquidate
     * @param borrowToken The borrowed token to repay
     * @param collateralToken The collateral token to seize
     * @param repayAmount The amount of borrow token to repay
     */
    function liquidate(
        address borrower,
        address borrowToken,
        address collateralToken,
        uint256 repayAmount
    ) external nonReentrant whenNotPaused {
        require(borrower != msg.sender, "Cannot liquidate self");
        require(repayAmount > 0, "Repay amount must be > 0");

        // Accrue interest before checking health
        _accrueInterest(borrower, borrowToken);

        // Check that position is actually unhealthy using TWAP prices
        require(!_isPositionHealthyForLiquidation(borrower), "Position is healthy");

        uint256 currentBorrow = userPositions[borrower].borrowBalances[borrowToken];
        require(currentBorrow > 0, "No borrow balance");

        // Can only liquidate up to 50% of the borrow in one transaction
        uint256 maxRepay = currentBorrow / 2;
        require(repayAmount <= maxRepay, "Repay exceeds 50% of borrow");

        // Calculate collateral to seize using TWAP prices
        uint256 borrowTokenPrice = oracle.getTWAPPrice(borrowToken);
        uint256 collateralTokenPrice = oracle.getTWAPPrice(collateralToken);
        require(borrowTokenPrice > 0 && collateralTokenPrice > 0, "Invalid prices");

        // collateralToSeize = (repayAmount * borrowPrice * (1 + bonus)) / collateralPrice
        uint256 repayValue = (repayAmount * borrowTokenPrice) / 1e18;
        uint256 seizeValue = (repayValue * (BASIS_POINTS + LIQUIDATION_BONUS)) / BASIS_POINTS;
        uint256 collateralToSeize = (seizeValue * 1e18) / collateralTokenPrice;

        require(
            userPositions[borrower].collateralDeposits[collateralToken] >= collateralToSeize,
            "Insufficient collateral to seize"
        );

        // Execute liquidation
        IERC20(borrowToken).safeTransferFrom(msg.sender, address(this), repayAmount);

        userPositions[borrower].borrowBalances[borrowToken] -= repayAmount;
        userPositions[borrower].collateralDeposits[collateralToken] -= collateralToSeize;

        totalBorrows[borrowToken] -= repayAmount;
        totalDeposits[collateralToken] -= collateralToSeize;

        IERC20(collateralToken).safeTransfer(msg.sender, collateralToSeize);

        emit Liquidated(msg.sender, borrower, borrowToken, collateralToken, repayAmount, collateralToSeize);
    }

    /**
     * @notice Accrue interest on a user's borrow position
     */
    function _accrueInterest(address user, address token) internal {
        uint256 lastAccrual = userPositions[user].lastAccrualTimestamp[token];
        if (lastAccrual == 0) {
            userPositions[user].lastAccrualTimestamp[token] = block.timestamp;
            return;
        }

        uint256 timeElapsed = block.timestamp - lastAccrual;
        if (timeElapsed == 0) return;

        uint256 principal = userPositions[user].borrowBalances[token];
        if (principal == 0) {
            userPositions[user].lastAccrualTimestamp[token] = block.timestamp;
            return;
        }

        // Simple interest: interest = principal * rate * time
        uint256 interest = (principal * INTEREST_RATE_PER_SECOND * timeElapsed) / 1e18;
        userPositions[user].borrowBalances[token] += interest;
        totalBorrows[token] += interest;
        userPositions[user].lastAccrualTimestamp[token] = block.timestamp;
    }

    /**
     * @notice Check if a user's position is healthy (for borrow/withdraw checks)
     * @dev Uses COLLATERAL_FACTOR (75%) - more conservative than liquidation threshold
     */
    function _isPositionHealthy(address user) internal view returns (bool) {
        uint256 totalCollateralValue = _getTotalCollateralValue(user);
        uint256 totalBorrowValue = _getTotalBorrowValue(user);

        if (totalBorrowValue == 0) return true;

        // maxBorrow = collateralValue * collateralFactor / BASIS_POINTS
        uint256 maxBorrowValue = (totalCollateralValue * COLLATERAL_FACTOR) / BASIS_POINTS;
        return totalBorrowValue <= maxBorrowValue;
    }

    /**
     * @notice Check if a user's position is healthy for liquidation purposes
     * @dev Uses LIQUIDATION_THRESHOLD (80%) - slightly more lenient than borrow check
     */
    function _isPositionHealthyForLiquidation(address user) internal view returns (bool) {
        uint256 totalCollateralValue = _getTotalCollateralValue(user);
        uint256 totalBorrowValue = _getTotalBorrowValue(user);

        if (totalBorrowValue == 0) return true;

        uint256 liquidationValue = (totalCollateralValue * LIQUIDATION_THRESHOLD) / BASIS_POINTS;
        return totalBorrowValue <= liquidationValue;
    }

    /**
     * @notice Calculate total collateral value using TWAP prices
     * @dev SECURITY: Uses TWAP oracle, NOT spot prices, to resist manipulation
     */
    function _getTotalCollateralValue(address user) internal view returns (uint256 totalValue) {
        address[] memory tokens = userCollateralTokens[user];
        for (uint256 i = 0; i < tokens.length; i++) {
            uint256 balance = userPositions[user].collateralDeposits[tokens[i]];
            if (balance > 0) {
                uint256 price = oracle.getTWAPPrice(tokens[i]);
                totalValue += (balance * price) / 1e18;
            }
        }
    }

    /**
     * @notice Calculate total borrow value using TWAP prices
     * @dev SECURITY: Uses TWAP oracle, NOT spot prices, to resist manipulation
     */
    function _getTotalBorrowValue(address user) internal view returns (uint256 totalValue) {
        address[] memory tokens = userBorrowTokens[user];
        for (uint256 i = 0; i < tokens.length; i++) {
            uint256 balance = userPositions[user].borrowBalances[tokens[i]];
            if (balance > 0) {
                uint256 price = oracle.getTWAPPrice(tokens[i]);
                totalValue += (balance * price) / 1e18;
            }
        }
    }

    // ============ View Functions ============

    /**
     * @notice Get a user's collateral deposit for a specific token
     */
    function getCollateralDeposit(address user, address token) external view returns (uint256) {
        return userPositions[user].collateralDeposits[token];
    }

    /**
     * @notice Get a user's borrow balance for a specific token (without accruing interest)
     */
    function getBorrowBalance(address user, address token) external view returns (uint256) {
        return userPositions[user].borrowBalances[token];
    }

    /**
     * @notice Get a user's total collateral value
     */
    function getTotalCollateralValue(address user) external view returns (uint256) {
        return _getTotalCollateralValue(user);
    }

    /**
     * @notice Get a user's total borrow value
     */
    function getTotalBorrowValue(address user) external view returns (uint256) {
        return _getTotalBorrowValue(user);
    }

    /**
     * @notice Check if a user's position is healthy
     */
    function isPositionHealthy(address user) external view returns (bool) {
        return _isPositionHealthy(user);
    }

    /**
     * @notice Check if a user's position is liquidatable
     */
    function isLiquidatable(address user) external view returns (bool) {
        return !_isPositionHealthyForLiquidation(user);
    }

    /**
     * @notice Get the health factor of a user's position
     * @return healthFactor scaled by 1e18 (1e18 = 100% healthy at liquidation threshold)
     */
    function getHealthFactor(address user) external view returns (uint256 healthFactor) {
        uint256 totalBorrowValue = _getTotalBorrowValue(user);
        if (totalBorrowValue == 0) return type(uint256).max;

        uint256 totalCollateralValue = _getTotalCollateralValue(user);
