pragma solidity ^0.8.19;

import "@openzeppelin/contracts-upgradeable/proxy/utils/Initializable.sol";
import "@openzeppelin/contracts-upgradeable/proxy/utils/UUPSUpgradeable.sol";
import "@openzeppelin/contracts-upgradeable/access/AccessControlUpgradeable.sol";
import "@openzeppelin/contracts-upgradeable/security/PausableUpgradeable.sol";
import "@openzeppelin/contracts-upgradeable/security/ReentrancyGuardUpgradeable.sol";

/**
 * @title SecureDeFiProtocol
 * @notice Upgradeable DeFi protocol with role-based access control,
 *         pausability, parameter management, and secure fund withdrawal.
 *
 * Security review notes:
 * - Uses OpenZeppelin's AccessControlUpgradeable instead of a single owner
 *   address to avoid single-point-of-failure and enable granular permissions.
 * - Uses UUPS upgrade pattern with authorization restricted to UPGRADER_ROLE.
 * - Timelock on critical parameter changes to mitigate governance attacks.
 * - ReentrancyGuard on all external state-changing functions that transfer value.
 * - Withdrawal has a per-transaction cap and daily limit.
 * - Two-step role grant process inherited from AccessControl (grantRole + acceptRole
 *   pattern can be added; here we rely on multi-sig holding ADMIN_ROLE).
 */
contract SecureDeFiProtocol is
    Initializable,
    UUPSUpgradeable,
    AccessControlUpgradeable,
    PausableUpgradeable,
    ReentrancyGuardUpgradeable
{
    // ──────────────────────────── Roles ────────────────────────────
    bytes32 public constant ADMIN_ROLE = keccak256("ADMIN_ROLE");
    bytes32 public constant PAUSER_ROLE = keccak256("PAUSER_ROLE");
    bytes32 public constant UPGRADER_ROLE = keccak256("UPGRADER_ROLE");
    bytes32 public constant WITHDRAWER_ROLE = keccak256("WITHDRAWER_ROLE");
    bytes32 public constant PARAMETER_MANAGER_ROLE = keccak256("PARAMETER_MANAGER_ROLE");

    // ──────────────────────── Protocol Parameters ──────────────────
    struct ParameterChange {
        bytes32 paramKey;
        uint256 newValue;
        uint256 effectiveAfter; // timestamp after which the change can be executed
        bool executed;
        bool cancelled;
    }

    uint256 public constant TIMELOCK_DURATION = 2 days;
    uint256 public constant MAX_SINGLE_WITHDRAWAL = 100 ether;
    uint256 public constant DAILY_WITHDRAWAL_LIMIT = 500 ether;

    mapping(bytes32 => uint256) public parameters;
    mapping(uint256 => ParameterChange) public pendingChanges;
    uint256 public changeNonce;

    // Daily withdrawal tracking
    mapping(uint256 => uint256) private _dailyWithdrawn; // day => amount

    // ──────────────────────────── Events ───────────────────────────
    event ParameterChangeProposed(
        uint256 indexed changeId,
        bytes32 indexed paramKey,
        uint256 newValue,
        uint256 effectiveAfter
    );
    event ParameterChangeExecuted(uint256 indexed changeId, bytes32 indexed paramKey, uint256 newValue);
    event ParameterChangeCancelled(uint256 indexed changeId);
    event FundsWithdrawn(address indexed to, uint256 amount);
    event FundsDeposited(address indexed from, uint256 amount);

    // ──────────────────────────── Errors ───────────────────────────
    error TimelockNotExpired(uint256 effectiveAfter);
    error ChangeAlreadyExecuted();
    error ChangeAlreadyCancelled();
    error WithdrawalExceedsSingleLimit(uint256 requested, uint256 max);
    error WithdrawalExceedsDailyLimit(uint256 requested, uint256 remaining);
    error ZeroAddress();
    error ZeroAmount();
    error TransferFailed();

    /// @custom:oz-upgrades-unsafe-allow constructor
    constructor() {
        _disableInitializers();
    }

    /**
     * @notice Initializes the contract (replaces constructor for upgradeable pattern).
     * @param admin Address that receives DEFAULT_ADMIN_ROLE and ADMIN_ROLE.
     *              Should be a multi-sig or governance timelock contract.
     */
    function initialize(address admin) external initializer {
        if (admin == address(0)) revert ZeroAddress();

        __AccessControl_init();
        __Pausable_init();
        __ReentrancyGuard_init();
        __UUPSUpgradeable_init();

        // DEFAULT_ADMIN_ROLE can grant/revoke all other roles
        _grantRole(DEFAULT_ADMIN_ROLE, admin);
        _grantRole(ADMIN_ROLE, admin);
        _grantRole(PAUSER_ROLE, admin);
        _grantRole(UPGRADER_ROLE, admin);
        _grantRole(WITHDRAWER_ROLE, admin);
        _grantRole(PARAMETER_MANAGER_ROLE, admin);

        // Set sensible default parameters
        parameters[keccak256("FEE_BPS")] = 30; // 0.30%
        parameters[keccak256("MIN_DEPOSIT")] = 0.01 ether;
    }

    // ──────────────────────── Receive / Deposit ───────────────────
    receive() external payable {
        emit FundsDeposited(msg.sender, msg.value);
    }

    function deposit() external payable whenNotPaused {
        if (msg.value == 0) revert ZeroAmount();
        uint256 minDeposit = parameters[keccak256("MIN_DEPOSIT")];
        require(msg.value >= minDeposit, "Below minimum deposit");
        emit FundsDeposited(msg.sender, msg.value);
    }

    // ──────────────────────── Pause / Unpause ─────────────────────
    function pause() external onlyRole(PAUSER_ROLE) {
        _pause();
    }

    function unpause() external onlyRole(ADMIN_ROLE) {
        _unpause();
    }

    // ──────────────── Parameter Management (Timelocked) ───────────
    /**
     * @notice Proposes a parameter change subject to a timelock.
     */
    function proposeParameterChange(bytes32 paramKey, uint256 newValue)
        external
        onlyRole(PARAMETER_MANAGER_ROLE)
        returns (uint256 changeId)
    {
        changeId = changeNonce++;
        uint256 effectiveAfter = block.timestamp + TIMELOCK_DURATION;

        pendingChanges[changeId] = ParameterChange({
            paramKey: paramKey,
            newValue: newValue,
            effectiveAfter: effectiveAfter,
            executed: false,
            cancelled: false
        });

        emit ParameterChangeProposed(changeId, paramKey, newValue, effectiveAfter);
    }

    /**
     * @notice Executes a previously proposed parameter change after the timelock.
     */
    function executeParameterChange(uint256 changeId)
        external
        onlyRole(PARAMETER_MANAGER_ROLE)
    {
        ParameterChange storage change = pendingChanges[changeId];
        if (change.executed) revert ChangeAlreadyExecuted();
        if (change.cancelled) revert ChangeAlreadyCancelled();
        if (block.timestamp < change.effectiveAfter) revert TimelockNotExpired(change.effectiveAfter);

        change.executed = true;
        parameters[change.paramKey] = change.newValue;

        emit ParameterChangeExecuted(changeId, change.paramKey, change.newValue);
    }

    /**
     * @notice Cancels a pending parameter change. Only ADMIN_ROLE can cancel.
     */
    function cancelParameterChange(uint256 changeId) external onlyRole(ADMIN_ROLE) {
        ParameterChange storage change = pendingChanges[changeId];
        if (change.executed) revert ChangeAlreadyExecuted();
        if (change.cancelled) revert ChangeAlreadyCancelled();

        change.cancelled = true;
        emit ParameterChangeCancelled(changeId);
    }

    // ──────────────────── Fund Withdrawal (Capped) ────────────────
    /**
     * @notice Withdraws ETH to a specified recipient, subject to per-tx and daily caps.
     */
    function withdraw(address payable to, uint256 amount)
        external
        onlyRole(WITHDRAWER_ROLE)
        whenNotPaused
        nonReentrant
    {
        if (to == address(0)) revert ZeroAddress();
        if (amount == 0) revert ZeroAmount();
        if (amount > MAX_SINGLE_WITHDRAWAL)
            revert WithdrawalExceedsSingleLimit(amount, MAX_SINGLE_WITHDRAWAL);

        uint256 today = block.timestamp / 1 days;
        uint256 withdrawnToday = _dailyWithdrawn[today];
        uint256 remaining = DAILY_WITHDRAWAL_LIMIT > withdrawnToday
            ? DAILY_WITHDRAWAL_LIMIT - withdrawnToday
            : 0;

        if (amount > remaining)
            revert WithdrawalExceedsDailyLimit(amount, remaining);

        _dailyWithdrawn[today] = withdrawnToday + amount;

        (bool success, ) = to.call{value: amount}("");
        if (!success) revert TransferFailed();

        emit FundsWithdrawn(to, amount);
    }

    // ──────────────────── Emergency Withdrawal ────────────────────
    /**
     * @notice Emergency withdrawal that bypasses daily limits but requires
     *         both ADMIN_ROLE. Contract must be paused first.
     */
    function emergencyWithdraw(address payable to, uint256 amount)
        external
        onlyRole(ADMIN_ROLE)
        whenPaused
        nonReentrant
    {
        if (to == address(0)) revert ZeroAddress();
        if (amount == 0) revert ZeroAmount();

        (bool success, ) = to.call{value: amount}("");
        if (!success) revert TransferFailed();

        emit FundsWithdrawn(to, amount);
    }

    // ──────────────────────── View Functions ──────────────────────
    function getParameter(bytes32 paramKey) external view returns (uint256) {
        return parameters[paramKey];
    }

    function getDailyWithdrawn() external view returns (uint256) {
        return _dailyWithdrawn[block.timestamp / 1 days];
    }

    function getRemainingDailyLimit() external view returns (uint256) {
        uint256 withdrawn = _dailyWithdrawn[block.timestamp / 1 days];
        return DAILY_WITHDRAWAL_LIMIT > withdrawn ? DAILY_WITHDRAWAL_LIMIT - withdrawn : 0;
    }

    // ──────────────────── Upgrade Authorization ───────────────────
    function _authorizeUpgrade(address newImplementation)
        internal
        override
        onlyRole(UPGRADER_ROLE)
    // solhint-disable-next-line no-empty-blocks
    {}

    /**
     * @dev Reserve storage gap for future upgrades.
     */
    uint256[44] private __gap;
}