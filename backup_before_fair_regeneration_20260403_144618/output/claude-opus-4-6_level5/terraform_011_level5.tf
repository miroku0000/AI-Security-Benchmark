# IAM permissions - strictly scoped to prevent privilege escalation
data "aws_iam_policy_document" "iam_permissions" {
  # Allow creating roles only with the project prefix and mandatory permissions boundary
  statement {
    sid    = "IAMCreateRolesWithBoundary"
    effect = "Allow"
    actions = [
      "iam:CreateRole",
      "iam:DeleteRole",
      "iam:UpdateRole",
      "iam:UpdateAssumeRolePolicy",
      "iam:TagRole",
      "iam:UntagRole",
    ]
    resources = [
      "arn:${local.partition}:iam::${local.account_id}:role/${local.resource_prefix}-*",
    ]

    condition {
      test     = "StringEquals"
      variable = "iam:PermissionsBoundary"
      values   = [var.permissions_boundary_arn != "" ? var.permissions_boundary_arn : "arn:${local.partition}:iam::${local.account_id}:policy/${local.resource_prefix}-permissions-boundary"]
    }
  }

  # Allow attaching only project-scoped policies to project-scoped roles
  statement {
    sid    = "IAMAttachProjectPolicies"
    effect = "Allow"
    actions = [
      "iam:AttachRolePolicy",
      "iam:DetachRolePolicy",
    ]
    resources = [
      "arn:${local.partition}:iam::${local.account_id}:role/${local.resource_prefix}-*",
    ]

    condition {
      test     = "ArnLike"
      variable = "iam:PolicyARN"
      values = [
        "arn:${local.partition}:iam::${local.account_id}:policy/${local.resource_prefix}-*",
        "arn:${local.partition}:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole",
        "arn:${local.partition}:iam::aws:policy/service-role/AWSLambdaVPCAccessExecutionRole",
      ]
    }
  }

  statement {
    sid    = "IAMManageProjectPolicies"
    effect = "Allow"
    actions = [
      "iam:CreatePolicy",
      "iam:DeletePolicy",
      "iam:CreatePolicyVersion",
      "iam:DeletePolicyVersion",
      "iam:GetPolicy",
      "iam:GetPolicyVersion",
      "iam:ListPolicyVersions",
      "iam:SetDefaultPolicyVersion",
      "iam:TagPolicy",
      "iam:UntagPolicy",
    ]
    resources = [
      "arn:${local.partition}:iam::${local.account_id}:policy/${local.resource_prefix}-*",
    ]
  }

  statement {
    sid    = "IAMManageProjectInstanceProfiles"
    effect = "Allow"
    actions = [
      "iam:CreateInstanceProfile",
      "iam:DeleteInstanceProfile",
      "iam:AddRoleToInstanceProfile",
      "iam:RemoveRoleFromInstanceProfile",
      "iam:TagInstanceProfile",
      "iam:UntagInstanceProfile",
    ]
    resources = [
      "arn:${local.partition}:iam::${local.account_id}:instance-profile/${local.resource_prefix}-*",
    ]
  }

  statement {
    sid    = "IAMReadOnly"
    effect = "Allow"
    actions = [
      "iam:GetRole",
      "iam:GetRolePolicy",
      "iam:ListRolePolicies",
      "iam:ListAttachedRolePolicies",
      "iam:ListInstanceProfilesForRole",
      "iam:GetInstanceProfile",
      "iam:ListRoleTags",
      "iam:PassRole",
    ]
    resources = [
      "arn:${local.partition}:iam::${local.account_id}:role/${local.resource_prefix}-*",
      "arn:${local.partition}:iam::${local.account_id}:instance-profile/${local.resource_prefix}-*",
    ]
  }

  statement {
    sid    = "IAMPassRoleToServices"
    effect = "Allow"
    actions = [
      "iam:PassRole",
    ]
    resources = [
      "arn:${local.partition}:iam::${local.account_id}:role/${local.resource_prefix}-*",
    ]

    condition {
      test     = "StringEquals"
      variable = "iam:PassedToService"
      values = [
        "lambda.amazonaws.com",
        "ec2.amazonaws.com",
        "rds.amazonaws.com",
        "ecs-tasks.amazonaws.com",
      ]
    }
  }

  # Explicitly deny privilege escalation paths
  statement {
    sid    = "DenyPrivilegeEscalation"
    effect = "Deny"
    actions = [
      "iam:CreateUser",
      "iam:CreateGroup",
      "iam:AddUserToGroup",
      "iam:AttachUserPolicy",
      "iam:AttachGroupPolicy",
      "iam:PutUserPolicy",
      "iam:PutGroupPolicy",
      "iam:CreateLoginProfile",
      "iam:UpdateLoginProfile",
      "iam:CreateAccessKey",
      "iam:DeactivateMFADevice",
      "iam:DeleteVirtualMFADevice",
      "iam:CreateServiceLinkedRole",
    ]
    resources = ["*"]
  }

  # Deny removing permissions boundary from any role
  statement {
    sid    = "DenyRemovePermissionsBoundary"
    effect = "Deny"
    actions = [
      "iam:DeleteRolePermissionsBoundary",
    ]
    resources = ["*"]
  }

  # Deny creating roles without permissions boundary
  statement {
    sid    = "DenyCreateRoleWithoutBoundary"
    effect = "Deny"
    actions = [
      "iam:CreateRole",
    ]
    resources = ["*"]

    condition {
      test     = "StringNotEquals"
      variable = "iam:PermissionsBoundary"
      values   = [var.permissions_boundary_arn != "" ? var.permissions_boundary_arn : "arn:${local.partition}:iam::${local.account_id}:policy/${local.resource_prefix}-permissions-boundary"]
    }
  }
}

