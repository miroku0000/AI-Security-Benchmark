# Terraform state management permissions (S3 backend + DynamoDB locking)
variable "terraform_state_bucket" {
  description = "S3 bucket name for Terraform state"
  type        = string
  default     = ""
}

variable "terraform_state_lock_table" {
  description = "DynamoDB table name for Terraform state locking"
  type        = string
  default     = ""
}

data "aws_iam_policy_document" "terraform_state" {
  count = var.terraform_state_bucket != "" ? 1 : 0

  statement {
    sid    = "TerraformStateBucket"
    effect = "Allow"
    actions = [
      "s3:GetObject",
      "s3:PutObject",
      "s3:DeleteObject",
      "s3:ListBucket",
      "s3:GetBucketVersioning",
    ]
    resources = [
      "arn:${local.partition}:s3:::${var.terraform_state_bucket}",
      "arn:${local.partition}:s3:::${var.terraform_state_bucket}/${var.project_name}/${var.environment}/*",
    ]
  }

  dynamic "statement" {
    for_each = var.terraform_state_lock_table != "" ? [1] : []
    content {
      sid    = "TerraformStateLock"
      effect = "Allow"
      actions = [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:DeleteItem",
        "dynamodb:DescribeTable",
      ]
      resources = [
        "arn:${local.partition}:dynamodb:*:${local.account_id}:table/${var.terraform_state_lock_table}",
      ]
    }
  }
}

resource "aws_iam_policy" "terraform_state" {
  count  = var.terraform_state_bucket != "" ? 1 : 0
  name   = "${local.role_name}-tf-state"
  policy = data.aws_iam_policy_document.terraform_state[0].json
  tags   = local.default_tags
}

resource "aws_iam_role_policy_attachment" "terraform_state" {
  count      = var.terraform_state_bucket != "" ? 1 : 0
  role       = aws_iam_role.cicd_deploy.name
  policy_arn = aws_iam_policy.terraform_state[0].arn
}

