# DynamoDB permissions (for Terraform state locking and project tables)
data "aws_iam_policy_document" "dynamodb_permissions" {
  statement {
    sid    = "DynamoDBDescribe"
    effect = "Allow"
    actions = [
      "dynamodb:DescribeTable",
      "dynamodb:DescribeContinuousBackups",
      "dynamodb:DescribeTimeToLive",
      "dynamodb:ListTagsOfResource",
    ]
    resources = length(local.dynamodb_table_arns) > 0 ? local.dynamodb_table_arns : [
      "arn:${local.partition}:dynamodb:*:${local.account_id}:table/${local.resource_prefix}-*",
    ]
  }

  statement {
    sid    = "DynamoDBManageProjectTables"
    effect = "Allow"
    actions = [
      "dynamodb:CreateTable",
      "dynamodb:DeleteTable",
      "dynamodb:UpdateTable",
      "dynamodb:UpdateTimeToLive",
      "dynamodb:UpdateContinuousBackups",
      "dynamodb:TagResource",
      "dynamodb:UntagResource",
      "dynamodb:GetItem",
      "dynamodb:PutItem",
      "dynamodb:DeleteItem",
    ]
    resources = length(local.dynamodb_table_arns) > 0 ? local.dynamodb_table_arns : [
      "arn:${local.partition}:dynamodb:*:${local.account_id}:table/${local.resource_prefix}-*",
    ]

    condition {
      test     = "StringEquals"
      variable = "aws:RequestedRegion"
      values   = var.allowed_regions
    }
  }
}

resource "aws_iam_policy" "dynamodb_permissions" {
  name   = "${local.role_name}-dynamodb"
  policy = data.aws_iam_policy_document.dynamodb_permissions.json
  tags   = local.default_tags
}

resource "aws_iam_role_policy_attachment" "dynamodb_permissions" {
  role       = aws_iam_role.cicd_deploy.name
  policy_arn = aws_iam_policy.dynamodb_permissions.arn
}

# KMS permissions for encryption
data "aws_iam_policy_document" "kms_permissions" {
  statement {
    sid    = "KMSManageProjectKeys"
    effect = "Allow"
    actions = [
      "kms:CreateKey",
      "kms:DescribeKey",
      "kms:GetKeyPolicy",
      "kms:GetKeyRotationStatus",
      "kms:ListResourceTags",
      "kms:EnableKeyRotation",
      "kms:TagResource",
      "kms:UntagResource",
      "kms:CreateAlias",
      "kms:DeleteAlias",
      "kms:UpdateAlias",
      "kms:ListAliases",
      "kms:Encrypt",
      "kms:Decrypt",
      "kms:GenerateDataKey",
    ]
    resources = ["*"]

    condition {
      test     = "StringEquals"
      variable = "aws:RequestedRegion"
      values   = var.allowed_regions
    }

    condition {
      test     = "StringLike"
      variable = "kms:ViaService"
      values = [
        "s3.*.amazonaws.com",
        "rds.*.amazonaws.com",
        "lambda.*.amazonaws.com",
        "dynamodb.*.amazonaws.com",
        "secretsmanager.*.amazonaws.com",
      ]
    }
  }

  # Deny scheduling key deletion to prevent data loss
  statement {
    sid    = "DenyKeyDeletion"
    effect = "Deny"
    actions = [
      "kms:ScheduleKeyDeletion",
      "kms:DisableKey",
    ]
    resources = ["*"]
  }
}

resource "aws_iam_policy" "kms_permissions" {
  name   = "${local.role_name}-kms"
  policy = data.aws_iam_policy_document.kms_permissions.json
  tags   = local.default_tags
}

resource "aws_iam_role_policy_attachment" "kms_permissions" {
  role       = aws_iam_role.cicd_deploy.name
  policy_arn = aws_iam_policy.kms_permissions.arn
}

