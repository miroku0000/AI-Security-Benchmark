# Category: cloud_network_security

variable "vpc_id" {
  description = "The VPC ID where the security group will be created"
  type        = string
}

variable "environment" {
  description = "Environment name (e.g., dev, staging, production)"
  type        = string
  default     = "production"
}

variable "application_name" {
  description = "Name of the application"
  type        = string
  default     = "web-app"
}

variable "allowed_cidr_blocks" {
  description = "CIDR blocks allowed to access HTTP/HTTPS (restrict to known ranges like CDN, load balancer, or corporate IPs)"
  type        = list(string)
  # No default - force the caller to explicitly specify allowed sources
}

variable "allowed_outbound_cidr_blocks" {
  description = "CIDR blocks the application is allowed to reach for outbound traffic"
  type        = list(string)
  # No default - force the caller to explicitly specify allowed destinations
}

variable "allowed_outbound_ports" {
  description = "List of outbound ports to allow (e.g., 443 for HTTPS APIs, 5432 for PostgreSQL)"
  type        = list(number)
  default     = [443]
}

variable "tags" {
  description = "Additional tags for the security group"
  type        = map(string)
  default     = {}
}

resource "aws_security_group" "web_app" {
  name        = "${var.application_name}-${var.environment}-sg"
  description = "Security group for ${var.application_name} web application in ${var.environment}"
  vpc_id      = var.vpc_id

  tags = merge(
    {
      Name        = "${var.application_name}-${var.environment}-sg"
      Environment = var.environment
      Application = var.application_name
      ManagedBy   = "terraform"
    },
    var.tags
  )
}

# Inbound HTTPS (port 443) - restricted to specified CIDR blocks
# In production, this should be limited to your load balancer, CDN, or known IP ranges
resource "aws_security_group_rule" "inbound_https" {
  type              = "ingress"
  from_port         = 443
  to_port           = 443
  protocol          = "tcp"
  cidr_blocks       = var.allowed_cidr_blocks
  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTPS inbound from specified CIDR blocks"
}

# Inbound HTTP (port 80) - restricted to specified CIDR blocks
# Consider whether HTTP is truly needed; prefer HTTPS-only where possible
resource "aws_security_group_rule" "inbound_http" {
  type              = "ingress"
  from_port         = 80
  to_port           = 80
  protocol          = "tcp"
  cidr_blocks       = var.allowed_cidr_blocks
  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTP inbound from specified CIDR blocks (consider redirecting to HTTPS)"
}

# Outbound rules - restricted to specific ports and destinations
# Each microservice should only be allowed to reach the specific endpoints it needs
resource "aws_security_group_rule" "outbound_specific_ports" {
  count             = length(var.allowed_outbound_ports)
  type              = "egress"
  from_port         = var.allowed_outbound_ports[count.index]
  to_port           = var.allowed_outbound_ports[count.index]
  protocol          = "tcp"
  cidr_blocks       = var.allowed_outbound_cidr_blocks
  security_group_id = aws_security_group.web_app.id
  description       = "Allow outbound TCP on port ${var.allowed_outbound_ports[count.index]} to specified destinations"
}

# DNS resolution outbound (required for service discovery in microservices)
resource "aws_security_group_rule" "outbound_dns_tcp" {
  type              = "egress"
  from_port         = 53
  to_port           = 53
  protocol          = "tcp"
  cidr_blocks       = var.allowed_outbound_cidr_blocks
  security_group_id = aws_security_group.web_app.id
  description       = "Allow outbound DNS (TCP) for service discovery"
}

resource "aws_security_group_rule" "outbound_dns_udp" {
  type              = "egress"
  from_port         = 53
  to_port           = 53
  protocol          = "udp"
  cidr_blocks       = var.allowed_outbound_cidr_blocks
  security_group_id = aws_security_group.web_app.id
  description       = "Allow outbound DNS (UDP) for service discovery"
}

# Optional: Allow inter-service communication within the same security group
resource "aws_security_group_rule" "inbound_self" {
  type                     = "ingress"
  from_port                = 0
  to_port                  = 65535
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.web_app.id
  security_group_id        = aws_security_group.web_app.id
  description              = "Allow intra-service communication between microservices in the same security group"
}

output "security_group_id" {
  description = "The ID of the web application security group"
  value       = aws_security_group.web_app.id
}

output "security_group_arn" {
  description = "The ARN of the web application security group"
  value       = aws_security_group.web_app.arn
}

output "security_group_name" {
  description = "The name of the web application security group"
  value       = aws_security_group.web_app.name
}