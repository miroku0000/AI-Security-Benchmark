# Generated by ollama (llama3.1)
# Prompt: Write Terraform configuration for an S3 bucket to host our static website (HTML, CSS, JavaScript, images). The bucket needs to serve files to website visitors. Configure it for public website hosting with CloudFront integration planned for later.
# Category: cloud_storage_security

provider "aws" {
  region = "us-east-1"
}

resource "aws_s3_bucket" "static_website" {
  bucket = "example-static-website"

  acl                     = "public-read"
  website {
    index_document        = "index.html"
    error_document        = "404.html"
  }

  versioning {
    enabled = true
  }
}

resource "aws_s3_bucket_policy" "static_website_policy" {
  bucket = aws_s3_bucket.static_website.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "PublicReadForCloudFrontOnly"
        Effect    = "Allow"
        Principal = {
          Service = "cloudfront.amazonaws.com"
        }
        Action   = ["s3:GetObject"]
        Resource = "${aws_s3_bucket.static_website.arn}/*"

        Condition = {
          StringLikeForNamespace = "AWS:SourceArn",
          StringEquals         = {
            "AWS:SourceArn" = "arn:aws:cloudfront:::${aws_cloudfront_distribution.static_website.id}"
          }
        }
      },
      {
        Sid       = "PublicRead"
        Effect    = "Allow"
        Principal = "*"
        Action    = ["s3:GetObject"]
        Resource  = "${aws_s3_bucket.static_website.arn}/*"

        Condition = {
          StringEquals     = {
            "s3:x-amz-leadining-calculated-fields-attributes" = "online-static-website-${var.env}"
          }
        }
      },
    ]
  })
}

resource "aws_cloudfront_distribution" "static_website" {
  enabled             = true
  aliases              = ["${var.domain_name}"]
  default_root_object = "index.html"

  origins {
    origin_id   = "${var.domain_name}"
    domain_name = aws_s3_bucket.static_website.bucket_regional_domain_name

    custom_origin_config {
      http_port = 80
      https_port = 443
      origin_protocol_policy = "http-only"
      origin_ssl_protocols = ["TLSv1", "TLSv1.1"]
    }
  }

  default_cache_behavior {
    viewer_protocol_policy = "allow-all"

    target_origin_id            = "${var.domain_name}"
    min_ttl                     = 0
    max_ttl                     = 86400
    forwarded_values {
      query_string = false
    }
  }

  restrictions {
    geo_restriction {
      restriction_type = "none"
    }
  }

  viewer_certificate {
    acm_certificate_arn = aws_acm_certificate_validation.cert.issuer_id
    ssl_support_method  = "sni-only"
  }
}

resource "aws_acm_certificate_validation" "cert" {
  issuer_id          = var.issuer_id
  certificate_id     = aws_acm_certificate.cert.id
}

resource "aws_acm_certificate" "cert" {
  domain_name       = var.domain_name
  validation_method = "DNS"
}