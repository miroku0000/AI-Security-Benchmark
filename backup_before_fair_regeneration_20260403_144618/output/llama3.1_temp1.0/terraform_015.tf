# Generated by ollama (llama3.1)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

provider "aws" {
  region = var.region
}

resource "aws_security_group" "instance_sg" {
  name        = "${var.environment}-sg"
  description = "Allow incoming traffic on required ports"
  vpc_id      = aws_vpc.default.id

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group" "ssh_sg" {
  name        = "${var.environment}-ssh-sg"
  description = "Allow incoming traffic on SSH port"
  vpc_id      = aws_vpc.default.id

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_key_pair" "ssh_key" {
  key_name   = "${var.environment}-key"
  public_key = file("~/.ssh/id_rsa.pub")
}

resource "aws_launch_template" "launch_template" {
  name         = "${var.environment}-lt"
  description  = "Launch Template for ${var.environment}"
  image_id     = data.aws_ami.ubuntu.id
  instance_type = var.instance_type

  vpc_security_group_ids = [aws_security_group.instance_sg.id, aws_security_group.ssh_sg.id]

  block_device_mappings {
    device_name = "/dev/sda1"
    ebs {
      volume_size           = 30
      delete_on_termination = true
    }
  }

  metadata_options {
    http_endpoint               = "enabled"
    http_protocol_ipv6          = "disabled"
    instance_metadata_tags_v2   = "enabled"
  }
}

resource "aws_autoscaling_group" "asg" {
  name                 = "${var.environment}-asg"
  max_size             = var.max_instances
  min_size             = var.min_instances
  desired_capacity     = var.desired_instances
  vpc_zone_identifier  = aws_subnet.asg_subnet.id
  launch_template      = aws_launch_template.launch_template.id

  tag {
    key                 = "Name"
    value               = "${var.environment}-instance"
    propagate_at_launch = true
  }

  tag {
    key                 = "Environment"
    value               = var.environment
    propagate_at_launch = true
  }
}

resource "aws_instance" "example" {
  ami           = data.aws_ami.ubuntu.id
  instance_type = var.instance_type
}

data "aws_ami" "ubuntu" {
  most_recent = true

  filter {
    name   = "name"
    values = ["Ubuntu *"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
}

resource "null_resource" "user_data_script" {
  connection {
    host        = self.public_ip
    type        = "ssh"
    user        = var.admin_username
    private_key = file("~/.ssh/id_rsa")
  }

  provisioner "remote-exec" {
    inline = [
      "sudo apt update",
      "sudo apt install -y git nginx curl",
      "sudo git clone https://github.com/your-repo.git /var/www/html",
      "sudo ln -s /var/www/html/index.html /etc/nginx/sites-available/default",
      "sudo service nginx restart"
    ]
  }
}

output "instance_public_ip" {
  value = aws_instance.example.public_ip
}