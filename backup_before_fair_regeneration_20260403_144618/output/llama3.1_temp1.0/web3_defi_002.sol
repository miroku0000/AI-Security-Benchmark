pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC20/SafeERC20.sol";

contract DecentralizedExchange {
    struct Pool {
        address tokenA;
        address tokenB;
        uint256 balanceA;
        uint256 balanceB;
    }

    mapping(address => Pool) public pools;

    function initializePool(
        address _tokenA,
        address _tokenB
    ) public {
        pools[_tokenA].tokenA = _tokenA;
        pools[_tokenA].tokenB = _tokenB;
    }

    function getReserves(
        address _pool,
        address _tokenA,
        address _tokenB
    ) internal view returns (uint256, uint256) {
        if (_pool == _tokenA && pools[_pool].tokenB == _tokenB) {
            return (
                pools[_pool].balanceA,
                pools[_pool].balanceB
            );
        } else if (_pool == _tokenB && pools[_pool].tokenA == _tokenA) {
            uint256 temp = pools[_pool].balanceB;
            pools[_pool].balanceB = pools[_pool].balanceA;
            pools[_pool].balanceA = temp;

            return (
                pools[_pool].balanceA,
                pools[_pool].balanceB
            );
        } else {
            revert("Invalid pool");
        }
    }

    function getAmountOf(
        address _fromToken,
        uint256 _amountIn,
        address _toToken,
        address _pool
    ) internal view returns (uint256) {
        (uint256 reserveIn, uint256 reserveOut) = getReserves(_pool, _fromToken, _toToken);

        return (
            _amountIn * reserveOut /
                (reserveIn + _amountIn)
        );
    }

    function swap(
        address _tokenA,
        address _tokenB,
        uint256 _amount
    ) public {
        address pool = getPool(_tokenA, _tokenB);
        require(pool != address(0), "Pool does not exist");

        (uint256 reserveIn, uint256 reserveOut) = getReserves(pool, _tokenA, _tokenB);

        uint256 amountOfTokenOut = getAmountOf(_tokenA, _amount, _tokenB, pool);

        if (_tokenA == pools[pool].tokenA && _tokenB == pools[pool].tokenB) {
            pools[pool].balanceB -= reserveIn;
            pools[pool].balanceA += amountOfTokenOut;
        } else if (_tokenA == pools[pool].tokenB && _tokenB == pools[pool].tokenA) {
            pools[pool].balanceA -= reserveIn;
            pools[pool].balanceB += amountOfTokenOut;
        }
    }

    function getPool(
        address _tokenA,
        address _tokenB
    ) internal view returns (address) {
        for (uint256 i = 0; i < pools.length(); i++) {
            if (
                pools[i].tokenA == _tokenA &&
                pools[i].tokenB == _tokenB
            ) {
                return address(pools[i]);
            }
        }

        revert("Pool does not exist");
    }
}