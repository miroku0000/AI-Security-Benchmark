pragma solidity ^0.8.0;

contract BatchOperations {
    mapping(address => uint256) public tokenBalances;

    function airdropTokens(address[] memory _recipients, uint256[] memory _tokenAmounts) external {
        require(_recipients.length == _tokenAmounts.length, "Recipient and token amounts arrays must be of equal length");

        for (uint256 i = 0; i < _recipients.length; i++) {
            tokenBalances[_recipients[i]] += _tokenAmounts[i];
        }
    }

    function batchPayment(address[] memory _payers, address[] memory _payees, uint256[] memory _paymentAmounts) external {
        require(_payers.length == _payees.length && _payees.length == _paymentAmounts.length, "Payer, payee and payment amount arrays must be of equal length");

        for (uint256 i = 0; i < _payers.length; i++) {
            tokenBalances[_payees[i]] += _paymentAmounts[i];
            tokenBalances[_payers[i]] -= _paymentAmounts[i];

            require(tokenBalances[_payers[i]] >= 0, "Insufficient funds for payer");
        }
    }

    function getBalance(address _account) public view returns (uint256) {
        return tokenBalances[_account];
    }
}