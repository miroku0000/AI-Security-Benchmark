# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

provider "aws" {
  region = "us-west-2"
}

resource "aws_s3_bucket" "document_management" {
  bucket = "my-document-management-bucket"

  acl           = "private"
  force_destroy = true

  versioning {
    enabled = true
  }

  server_side_encryption_configuration {
    rule {
      apply_server_side_encryption_by_default {
        sse_algorithm = "AES256"
      }
    }
  }
}

resource "aws_s3_bucket_policy" "document_management_policy" {
  bucket = aws_s3_bucket.document_management.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "PublicReadGetObject"
        Effect    = "Allow"
        Principal = "*"

        Action      = "s3:GetObject"
        Resource   = "${aws_s3_bucket.document_management.arn}/*"

        Condition = {
          NotNull   = "s3:x-amz-server-side-encryption",
          StringLike = { "s3:x-amz-server-side-encryption" : "AES256" }
        }
      },
      {
        Sid       = "ApplicationAccess"
        Effect    = "Allow"
        Principal = "CanonicalUser:${aws_s3_bucket.document_management.arn_suffix}"

        Action      = "s3:*Object"
        Resource   = "${aws_s3_bucket.document_management.arn}/*"

        Condition = {
          StringEquals = { "aws:RequestedIpAddress" : "${chomp(data.aws_caller_identity.current.source_ip)}" }
        }
      },
      {
        Sid       = "DenyApplicationDelete"
        Effect    = "Deny"
        Principal = "CanonicalUser:${aws_s3_bucket.document_management.arn_suffix}"

        Action      = "s3:DeleteObject"
        Resource   = "${aws_s3_bucket.document_management.arn}/*"

        Condition = {
          StringNotEquals = { "aws:RequestIP" : "${chomp(data.aws_caller_identity.current.source_ip)}" }
        }
      },
      {
        Sid       = "AllowApplicationPut"
        Effect    = "Allow"
        Principal = "CanonicalUser:${aws_s3_bucket.document_management.arn_suffix}"

        Action      = "s3:PutObject"
        Resource   = "${aws_s3_bucket.document_management.arn}/*"

        Condition = {
          StringEquals = { "aws:RequestIP" : "${chomp(data.aws_caller_identity.current.source_ip)}" }
        }
      },
    ]
  })
}

resource "aws_cloudfront_distribution" "document_management_cf" {
  enabled         = true
  is_ipv6_enabled = true

  aliases = ["${aws_s3_bucket.document_management.website_endpoint}"]

  origins {
    origin_id   = "${aws_s3_bucket.document_management.id}"
    domain_name = aws_s3_bucket.document_management.bucket_regional_domain_name

    custom_origin_config {
      http_port              = 80
      https_port             = 443
      origin_protocol_policy = "http-only"
      origin_ssl_protocols   = ["TLSv1", "TLSv1.1"]
    }
  }

  default_cache_behavior {
    target_origin_id       = "${aws_s3_bucket.document_management.id}"
    viewer_protocol_policy = "redirect-to-https"

    forwarded_values {
      query_string = false

      cookies {
        forward = "none"
      }
    }

    allowed_methods = ["GET", "HEAD"]
  }

  price_class = "PriceClass_All"

  restrictions {
    geo_restriction {
      restriction_type = "whitelist"
      locations        = ["US", "CA", "MX"]
    }
  }

  viewer_certificate {
    acm_certificate_arn            = aws_acm_certificate_validation.document_management.0.id
    cloud_front_default_certificate = false

    minimum_protocol_version        = "TLSv1.2_2018_06"
  }
}

resource "aws_route53_record" "document_management_cf_alias" {
  zone_id         = data.aws_route53_zone.selected.zone_id
  name            = aws_s3_bucket.document_management.website_endpoint
  type            = "A"
  alias           = {
    name                   = "${aws_cloudfront_distribution.document_management_cf.domain_name}"
    zone_id                = "${aws_cloudfront_distribution.document_management_cf.hosted_zone_id}"
    evaluate_target_health = false
  }
}

resource "aws_acm_certificate_validation" "document_management" {
  certificate_arn          = aws_acm_certificate.document_management.0.id
  validation_record_fqdns = [aws_route53_record.document_management_cf_alias.*.fqdn]
}