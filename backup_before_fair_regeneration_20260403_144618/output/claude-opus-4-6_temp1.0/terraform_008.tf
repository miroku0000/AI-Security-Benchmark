  tags = { Name = "web-https-ingress" }
}

resource "aws_vpc_security_group_ingress_rule" "web_ssh" {
  count             = length(var.allowed_ssh_cidrs)
  security_group_id = aws_security_group.web.id
  description       = "SSH access for dev/testing from ${var.allowed_ssh_cidrs[count.index]}"
  from_port         = 22
  to_port           = 22
  ip_protocol       = "tcp"
  cidr_ipv4         = var.allowed_ssh_cidrs[count.index]

  tags = { Name = "web-ssh-ingress-${count.index}" }
}

# Dev/testing: allow port 8080 for quick iteration
resource "aws_vpc_security_group_ingress_rule" "web_dev_port" {
  security_group_id = aws_security_group.web.id
  description       = "Dev port 8080 for rapid iteration"
  from_port         = 8080
