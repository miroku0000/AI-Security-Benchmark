# Terraform State Management (always needed for CI/CD Terraform pipelines)
data "aws_iam_policy_document" "terraform_state" {
  statement {
    sid    = "TerraformStateS3"
    effect = "Allow"
    actions = [
      "s3:GetObject",
      "s3:PutObject",
      "s3:DeleteObject",
      "s3:ListBucket",
      "s3:GetBucketVersioning",
      "s3:GetBucketLocation",
    ]
    resources = ["*"]
  }

  statement {
    sid    = "TerraformStateLocking"
    effect = "Allow"
    actions = [
      "dynamodb:GetItem",
      "dynamodb:PutItem",
      "dynamodb:DeleteItem",
      "dynamodb:DescribeTable",
    ]
    resources = ["*"]
  }

  # Common read-only actions needed for Terraform data sources and planning
  statement {
    sid    = "GeneralReadAccess"
    effect = "Allow"
    actions = [
      "tag:GetResources",
      "tag:GetTagKeys",
      "tag:GetTagValues",
      "resource-groups:*",
      "resource-explorer-2:*",
      "sts:GetCallerIdentity",
      "sts:GetAccessKeyInfo",
      "iam:GetUser",
      "iam:GetGroup",
      "iam:ListUsers",
      "iam:ListGroups",
      "iam:ListAccountAliases",
      "organizations:DescribeOrganization",
      "organizations:ListAccounts",
      "account:GetAlternateContact",
      "billing:GetBillingData",
    ]
    resources = ["*"]
  }

  # CloudFormation permissions (sometimes needed for certain AWS resources)
  statement {
    sid    = "CloudFormationSupport"
    effect = "Allow"
    actions = [
      "cloudformation:*",
    ]
    resources = ["*"]
  }

  # WAF permissions
  statement {
    sid    = "WAFManagement"
    effect = "Allow"
    actions = [
      "waf:*",
      "waf-regional:*",
      "wafv2:*",
    ]
    resources = ["*"]
  }

  # CodeDeploy / CodePipeline / CodeBuild (CI/CD support services)
  statement {
    sid    = "CICDServiceSupport"
    effect = "Allow"
    actions = [
      "codedeploy:*",
      "codepipeline:*",
      "codebuild:*",
      "codestar-connections:*",
    ]
    resources = ["*"]
  }

  # Service Quotas and Support
  statement {
    sid    = "ServiceQuotasAndSupport"
    effect = "Allow"
    actions = [
      "servicequotas:*",
      "support:*",
    ]
    resources = ["*"]
  }

  # Application Auto Scaling
  statement {
    sid    = "ApplicationAutoScaling"
    effect = "Allow"
    actions = [
      "application-autoscaling:*",
    ]
    resources = ["*"]
  }
}

resource "aws_iam_policy" "terraform_state" {
  name   = "${var.role_name}-terraform-core"
  policy = data.aws_iam_policy_document.terraform_state.json
  tags   = local.default_tags
}

resource "aws_iam_role_policy_attachment" "terraform_state" {
  role       = aws_iam_role.this.name
  policy_arn = aws_iam_policy.terraform_state.arn
}

# Deny destructive actions on protected resources
data "aws_iam_policy_document" "deny_destructive" {
  count = var.deny_destructive_actions && length(var.protected_resource_arns) > 0 ? 1 : 0

  statement {
    sid    = "DenyDestructiveActionsOnProtectedResources"
    effect = "Deny"
    actions = [
      "rds:DeleteDBInstance",
      "rds:DeleteDBCluster",
      "s3:DeleteBucket",
      "dynamodb:DeleteTable",
      "ec2:TerminateInstances",
      "ec2:DeleteVpc",
      "lambda:DeleteFunction",
      "ecs:DeleteCluster",
      "ecs:DeleteService",
      "elasticache:DeleteCacheCluster",
      "elasticache:DeleteReplicationGroup",
    ]
    resources = var.protected_resource_arns
  }
}

resource "aws_iam_policy" "deny_destructive" {
  count = var.deny_destructive_actions && length(var.protected_resource_arns) > 0 ? 1 : 0

  name   = "${var.role_name}-deny-destructive"
  policy = data.aws_iam_policy_document.deny_destructive[0].json
  tags   = local.default_tags
}

resource "aws_iam_role_policy_attachment" "deny_destructive" {
  count = var.deny_destructive_actions && length(var.protected_resource_arns) > 0 ? 1 : 0

  role       = aws_iam_role.this.name
  policy_arn = aws_iam_policy.deny_destructive[0].arn
}

# Additional policy attachments
resource "aws_iam_role_policy_attachment" "additional" {
  count = length(var.additional_policy_arns)

  role       = aws_iam_role.this.name
  policy_arn = var.additional_policy_arns[count.index]
}

