import "@openzeppelin/contracts/utils/ReentrancyGuard.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

contract DecentralizedExchange is ReentrancyGuard, Ownable {
    using SafeERC20 for IERC20;

    struct LiquidityPool {
        address tokenA;
        address tokenB;
        uint256 reserveA;
        uint256 reserveB;
        uint256 totalLPTokens;
        mapping(address => uint256) lpBalances;
        bool exists;
    }

    uint256 public constant FEE_NUMERATOR = 3; // 0.3% fee
    uint256 public constant FEE_DENOMINATOR = 1000;
    uint256 public constant MINIMUM_LIQUIDITY = 1000;

    mapping(bytes32 => LiquidityPool) public pools;
    bytes32[] public poolIds;

    event PoolCreated(address indexed tokenA, address indexed tokenB, bytes32 poolId);
    event LiquidityAdded(bytes32 indexed poolId, address indexed provider, uint256 amountA, uint256 amountB, uint256 lpTokens);
    event LiquidityRemoved(bytes32 indexed poolId, address indexed provider, uint256 amountA, uint256 amountB, uint256 lpTokens);
    event Swap(bytes32 indexed poolId, address indexed user, address tokenIn, address tokenOut, uint256 amountIn, uint256 amountOut);

    constructor() Ownable(msg.sender) {}

    function getPoolId(address tokenA, address tokenB) public pure returns (bytes32) {
        require(tokenA != tokenB, "Identical tokens");
        (address token0, address token1) = tokenA < tokenB ? (tokenA, tokenB) : (tokenB, tokenA);
        return keccak256(abi.encodePacked(token0, token1));
    }

    function createPool(address tokenA, address tokenB) external returns (bytes32 poolId) {
        require(tokenA != address(0) && tokenB != address(0), "Zero address");
        require(tokenA != tokenB, "Identical tokens");

        poolId = getPoolId(tokenA, tokenB);
        require(!pools[poolId].exists, "Pool already exists");

        (address token0, address token1) = tokenA < tokenB ? (tokenA, tokenB) : (tokenB, tokenA);

        LiquidityPool storage pool = pools[poolId];
        pool.tokenA = token0;
        pool.tokenB = token1;
        pool.exists = true;

        poolIds.push(poolId);

        emit PoolCreated(token0, token1, poolId);
    }

    function addLiquidity(
        address tokenA,
        address tokenB,
        uint256 amountADesired,
        uint256 amountBDesired,
        uint256 amountAMin,
        uint256 amountBMin
    ) external nonReentrant returns (uint256 amountA, uint256 amountB, uint256 lpTokens) {
        bytes32 poolId = getPoolId(tokenA, tokenB);
        LiquidityPool storage pool = pools[poolId];
        require(pool.exists, "Pool does not exist");

        (amountA, amountB) = _calculateLiquidityAmounts(
            pool, tokenA, amountADesired, amountBDesired, amountAMin, amountBMin
        );

        IERC20(tokenA).safeTransferFrom(msg.sender, address(this), amountA);
        IERC20(tokenB).safeTransferFrom(msg.sender, address(this), amountB);

        uint256 depositA;
        uint256 depositB;
        if (tokenA == pool.tokenA) {
            depositA = amountA;
            depositB = amountB;
        } else {
            depositA = amountB;
            depositB = amountA;
        }

        if (pool.totalLPTokens == 0) {
            lpTokens = _sqrt(depositA * depositB);
            require(lpTokens > MINIMUM_LIQUIDITY, "Insufficient initial liquidity");
            lpTokens -= MINIMUM_LIQUIDITY;
            pool.totalLPTokens = MINIMUM_LIQUIDITY;
            pool.lpBalances[address(0)] = MINIMUM_LIQUIDITY; // permanently lock minimum liquidity
        } else {
            uint256 lpFromA = (depositA * pool.totalLPTokens) / pool.reserveA;
            uint256 lpFromB = (depositB * pool.totalLPTokens) / pool.reserveB;
            lpTokens = lpFromA < lpFromB ? lpFromA : lpFromB;
        }

        require(lpTokens > 0, "Insufficient LP tokens minted");

        pool.reserveA += depositA;
        pool.reserveB += depositB;
        pool.totalLPTokens += lpTokens;
        pool.lpBalances[msg.sender] += lpTokens;

        emit LiquidityAdded(poolId, msg.sender, amountA, amountB, lpTokens);
    }

    function _calculateLiquidityAmounts(
        LiquidityPool storage pool,
        address tokenA,
        uint256 amountADesired,
        uint256 amountBDesired,
        uint256 amountAMin,
        uint256 amountBMin
    ) internal view returns (uint256 amountA, uint256 amountB) {
        if (pool.reserveA == 0 && pool.reserveB == 0) {
            return (amountADesired, amountBDesired);
        }

        uint256 reserveA;
        uint256 reserveB;
        if (tokenA == pool.tokenA) {
            reserveA = pool.reserveA;
            reserveB = pool.reserveB;
        } else {
            reserveA = pool.reserveB;
            reserveB = pool.reserveA;
        }

        uint256 amountBOptimal = (amountADesired * reserveB) / reserveA;
        if (amountBOptimal <= amountBDesired) {
            require(amountBOptimal >= amountBMin, "Insufficient B amount");
            return (amountADesired, amountBOptimal);
        } else {
            uint256 amountAOptimal = (amountBDesired * reserveA) / reserveB;
            require(amountAOptimal <= amountADesired, "Excessive A amount");
            require(amountAOptimal >= amountAMin, "Insufficient A amount");
            return (amountAOptimal, amountBDesired);
        }
    }

    function removeLiquidity(
        address tokenA,
        address tokenB,
        uint256 lpTokenAmount,
        uint256 amountAMin,
        uint256 amountBMin
    ) external nonReentrant returns (uint256 amountA, uint256 amountB) {
        bytes32 poolId = getPoolId(tokenA, tokenB);
        LiquidityPool storage pool = pools[poolId];
        require(pool.exists, "Pool does not exist");
        require(pool.lpBalances[msg.sender] >= lpTokenAmount, "Insufficient LP balance");
        require(lpTokenAmount > 0, "Zero LP tokens");

        uint256 withdrawA = (lpTokenAmount * pool.reserveA) / pool.totalLPTokens;
        uint256 withdrawB = (lpTokenAmount * pool.reserveB) / pool.totalLPTokens;

        require(withdrawA > 0 && withdrawB > 0, "Insufficient liquidity burned");

        uint256 outA;
        uint256 outB;
        if (tokenA == pool.tokenA) {
            outA = withdrawA;
            outB = withdrawB;
        } else {
            outA = withdrawB;
            outB = withdrawA;
        }

        require(outA >= amountAMin, "Slippage: amount A");
        require(outB >= amountBMin, "Slippage: amount B");

        pool.lpBalances[msg.sender] -= lpTokenAmount;
        pool.totalLPTokens -= lpTokenAmount;
        pool.reserveA -= withdrawA;
        pool.reserveB -= withdrawB;

        IERC20(tokenA).safeTransfer(msg.sender, outA);
        IERC20(tokenB).safeTransfer(msg.sender, outB);

        amountA = outA;
        amountB = outB;

        emit LiquidityRemoved(poolId, msg.sender, amountA, amountB, lpTokenAmount);
    }

    function swap(
        address tokenIn,
        address tokenOut,
        uint256 amountIn,
        uint256 amountOutMin
    ) external nonReentrant returns (uint256 amountOut) {
        require(amountIn > 0, "Zero input amount");
        require(tokenIn != tokenOut, "Identical tokens");

        bytes32 poolId = getPoolId(tokenIn, tokenOut);
        LiquidityPool storage pool = pools[poolId];
        require(pool.exists, "Pool does not exist");
        require(pool.reserveA > 0 && pool.reserveB > 0, "Insufficient liquidity");

        uint256 reserveIn;
        uint256 reserveOut;

        if (tokenIn == pool.tokenA) {
            reserveIn = pool.reserveA;
            reserveOut = pool.reserveB;
        } else {
            reserveIn = pool.reserveB;
            reserveOut = pool.reserveA;
        }

        amountOut = getAmountOut(amountIn, reserveIn, reserveOut);
        require(amountOut >= amountOutMin, "Slippage exceeded");
        require(amountOut < reserveOut, "Insufficient liquidity for swap");

        IERC20(tokenIn).safeTransferFrom(msg.sender, address(this), amountIn);

        if (tokenIn == pool.tokenA) {
            pool.reserveA += amountIn;
            pool.reserveB -= amountOut;
        } else {
            pool.reserveB += amountIn;
            pool.reserveA -= amountOut;
        }

        // Verify constant product invariant (k should not decrease)
        // k_new >= k_old is guaranteed by the fee mechanism

        IERC20(tokenOut).safeTransfer(msg.sender, amountOut);

        emit Swap(poolId, msg.sender, tokenIn, tokenOut, amountIn, amountOut);
    }

    function swapMultiHop(
        address[] calldata path,
        uint256 amountIn,
        uint256 amountOutMin
    ) external nonReentrant returns (uint256 amountOut) {
        require(path.length >= 2, "Invalid path");
        require(amountIn > 0, "Zero input amount");

        IERC20(path[0]).safeTransferFrom(msg.sender, address(this), amountIn);

        uint256 currentAmount = amountIn;

        for (uint256 i = 0; i < path.length - 1; i++) {
            address tokenIn = path[i];
            address tokenOut = path[i + 1];

            bytes32 poolId = getPoolId(tokenIn, tokenOut);
            LiquidityPool storage pool = pools[poolId];
            require(pool.exists, "Pool does not exist in path");

            uint256 reserveIn;
            uint256 reserveOut;

            if (tokenIn == pool.tokenA) {
                reserveIn = pool.reserveA;
                reserveOut = pool.reserveB;
            } else {
                reserveIn = pool.reserveB;
                reserveOut = pool.reserveA;
            }

            uint256 swapOut = getAmountOut(currentAmount, reserveIn, reserveOut);
            require(swapOut < reserveOut, "Insufficient liquidity in path");

            if (tokenIn == pool.tokenA) {
                pool.reserveA += currentAmount;
                pool.reserveB -= swapOut;
            } else {
                pool.reserveB += currentAmount;
                pool.reserveA -= swapOut;
            }

            currentAmount = swapOut;
        }

        require(currentAmount >= amountOutMin, "Slippage exceeded");

        IERC20(path[path.length - 1]).safeTransfer(msg.sender, currentAmount);

        amountOut = currentAmount;

        emit Swap(
            getPoolId(path[0], path[path.length - 1]),
            msg.sender,
            path[0],
            path[path.length - 1],
            amountIn,
            amountOut
        );
    }

    function getAmountOut(
        uint256 amountIn,
        uint256 reserveIn,
        uint256 reserveOut
    ) public pure returns (uint256 amountOut) {
        require(amountIn > 0, "Insufficient input amount");
        require(reserveIn > 0 && reserveOut > 0, "Insufficient liquidity");

        uint256 amountInWithFee = amountIn * (FEE_DENOMINATOR - FEE_NUMERATOR);
        uint256 numerator = amountInWithFee * reserveOut;
        uint256 denominator = (reserveIn * FEE_DENOMINATOR) + amountInWithFee;
        amountOut = numerator / denominator;
    }

    function getAmountIn(
        uint256 amountOut,
        uint256 reserveIn,
        uint256 reserveOut
    ) public pure returns (uint256 amountIn) {
        require(amountOut > 0, "Insufficient output amount");
        require(reserveIn > 0 && reserveOut > amountOut, "Insufficient liquidity");

        uint256 numerator = reserveIn * amountOut * FEE_DENOMINATOR;
        uint256 denominator = (reserveOut - amountOut) * (FEE_DENOMINATOR - FEE_NUMERATOR);
        amountIn = (numerator / denominator) + 1;
    }

    function getPrice(address tokenA, address tokenB) external view returns (uint256 priceAinB, uint256 priceBinA) {
        bytes32 poolId = getPoolId(tokenA, tokenB);
        LiquidityPool storage pool = pools[poolId];
        require(pool.exists, "Pool does not exist");
        require(pool.reserveA > 0 && pool.reserveB > 0, "No liquidity");

        uint256 reserveA;
        uint256 reserveB;

        if (tokenA == pool.tokenA) {
            reserveA = pool.reserveA;
            reserveB = pool.reserveB;
        } else {
            reserveA = pool.reserveB;
            reserveB = pool.reserveA;
        }

        // Returns price scaled by 1e18
        priceAinB = (reserveB * 1e18) / reserveA;
        priceBinA = (reserveA * 1e18) / reserveB;
    }

    function getPoolReserves(bytes32 poolId) external view returns (
        address tokenA,
