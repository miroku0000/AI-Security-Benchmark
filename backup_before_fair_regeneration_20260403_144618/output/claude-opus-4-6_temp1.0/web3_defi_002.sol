    function quoteSwap(
        address tokenIn,
        address tokenOut,
        uint256 amountIn
    ) external view returns (uint256 amountOut, uint256 priceImpact) {
        bytes32 poolId = getPoolId(tokenIn, tokenOut);
        LiquidityPool storage pool = pools[poolId];
        require(pool.exists, "Pool does not exist");

        uint256 reserveIn;
        uint256 reserveOut;

        if (tokenIn == pool.tokenA) {
            reserveIn = pool.reserveA;
            reserveOut = pool.reserveB;
        } else {
            reserveIn = pool.reserveB;
            reserveOut = pool.reserveA;
        }

        amountOut = getAmountOut(amountIn, reserveIn, reserveOut);

        // Price impact: difference between spot price and execution price (scaled by 1e18)
        uint256 spotPrice = (reserveOut * 1e18) / reserveIn;
        uint256 executionPrice = (amountOut * 1e18) / amountIn;

        if (spotPrice > executionPrice) {
            priceImpact = ((spotPrice - executionPrice) * 1e18) / spotPrice;
        } else {
            priceImpact = 0;
        }
    }

    function _sqrt(uint256 y) internal pure returns (uint256 z) {
        if (y > 3) {
            z = y;
            uint256 x = y / 2 + 1;
            while (x < z) {
                z = x;
                x = (y / x + x) / 2;
            }
        } else if (y != 0) {
            z = 1;
        }
    }
