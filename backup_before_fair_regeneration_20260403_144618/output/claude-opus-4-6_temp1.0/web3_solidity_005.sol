        if (_boxType == 1) {
            boxPrice = 0.01 ether;
            rarityBoost = 0;
        } else if (_boxType == 2) {
            boxPrice = 0.05 ether;
            rarityBoost = 1000; // 10% better odds
        } else {
            boxPrice = 0.1 ether;
            rarityBoost = 2500; // 25% better odds
        }
        
        require(msg.value >= boxPrice, "Insufficient payment");
        
        // Generate random attributes
        uint256 random1 = _generateRandomNumber(_boxType);
        uint256 random2 = _generateEnhancedRandom(random1);
        uint256 random3 = _generateRandomNumber(random2);
        
        // Item ID (1-1000)
        itemId = (random1 % 1000) + 1;
        
        // Rarity (0-4): Common, Uncommon, Rare, Epic, Legendary
        uint256 rarityRoll = (random2 % 10000);
        if (rarityRoll + rarityBoost >= 9900) {
            rarity = 4; // Legendary (1% base)
        } else if (rarityRoll + rarityBoost >= 9500) {
            rarity = 3; // Epic (4% base)
        } else if (rarityRoll + rarityBoost >= 8500) {
            rarity = 2; // Rare (10% base)
        } else if (rarityRoll + rarityBoost >= 7000) {
            rarity = 1; // Uncommon (15% base)
        } else {
            rarity = 0; // Common (70% base)
        }
        
        // Power level based on rarity
        uint256 basePower = (random3 % 100) + 1;
        power = basePower * (rarity + 1) * (_boxType);
        
        // Refund excess payment
        if (msg.value > boxPrice) {
            (bool refundSuccess, ) = payable(msg.sender).call{value: msg.value - boxPrice}("");
            require(refundSuccess, "Refund failed");
        }
        
        return (itemId, rarity, power);
