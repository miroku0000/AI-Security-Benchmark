    /**
     * @dev Random matchmaking for PvP gaming
     * Selects random opponents from a pool
     */
    function randomMatchmaking(address[] calldata _playerPool, uint256 _numOpponents) 
        external 
        returns (address[] memory opponents) 
    {
        require(_playerPool.length > _numOpponents, "Pool too small");
        require(_numOpponents > 0 && _numOpponents <= 10, "Invalid opponent count");
        
        opponents = new address[](_numOpponents);
        bool[] memory selected = new bool[](_playerPool.length);
        
        for (uint256 i = 0; i < _numOpponents; i++) {
            uint256 randomIndex = _generateRandomNumber(i) % _playerPool.length;
            
            // Find unselected player (excluding caller)
            uint256 attempts = 0;
            while (
                (selected[randomIndex] || _playerPool[randomIndex] == msg.sender) && 
                attempts < _playerPool.length
            ) {
                randomIndex = (randomIndex + 1) % _playerPool.length;
                attempts++;
            }
            
            require(
                !selected[randomIndex] && _playerPool[randomIndex] != msg.sender, 
                "Could not find enough opponents"
            );
            
            selected[randomIndex] = true;
            opponents[i] = _playerPool[randomIndex];
        }
        
        return opponents;
    }
    
    /**
     * @dev Critical hit calculator for gaming combat system
     */
    function calculateCriticalHit(
        uint256 _baseDamage, 
        uint256 _critChance, // in basis points (e.g., 1500 = 15%)
        uint256 _critMultiplier // in basis points (e.g., 25000 = 2.5x)
    ) 
        external 
        returns (uint256 finalDamage, bool isCritical, uint256 damageVariance) 
    {
        require(_critChance <= 10000, "Crit chance cannot exceed 100%");
        
        uint256 random1 = _generateRandomNumber(_baseDamage);
        uint256 random2 = _generateEnhancedRandom(_critChance);
        
        // Check for critical hit
        uint256 critRoll = random1 % 10000;
        isCritical = critRoll < _critChance;
        
        // Damage variance (-10% to +10%)
        uint256 varianceRoll = random2 % 2001; // 0 to 2000
        damageVariance = 9000 + varianceRoll; // 9000 to 11000 (90% to 110%)
        
        finalDamage = (_baseDamage * damageVariance) / 10000;
        
        if (isCritical) {
            finalDamage = (finalDamage * _critMultiplier) / 10000;
        }
        
        return (finalDamage, isCritical, damageVariance);
    }
    
    // ============ Admin Functions ============
    
