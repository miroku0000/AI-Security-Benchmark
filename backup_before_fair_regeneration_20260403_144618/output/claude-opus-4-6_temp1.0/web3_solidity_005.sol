     */
    function spinRewardWheel() external payable returns (uint256 tierIndex, uint256 reward) {
        require(msg.value > 0, "Must send ETH to spin");
        require(rewardTiers.length > 0, "No reward tiers configured");
        
        uint256 randomValue = _generateRandomNumber(msg.value);
        uint256 roll = randomValue % 10000;
        
        uint256 cumulative = 0;
        tierIndex = rewardTiers.length - 1; // Default to last tier
        
        for (uint256 i = 0; i < rewardTiers.length; i++) {
            cumulative += rewardTiers[i].probability;
            if (roll < cumulative) {
                tierIndex = i;
                break;
            }
        }
        
        RewardTier memory tier = rewardTiers[tierIndex];
        reward = (msg.value * tier.rewardMultiplier) / 10000;
        
        // Ensure contract has enough balance for reward
        if (reward > 0) {
            require(address(this).balance >= reward, "Insufficient contract balance for reward");
            
            (bool success, ) = payable(msg.sender).call{value: reward}("");
            require(success, "Reward transfer failed");
        }
        
        // Record reward history
        RewardResult memory result = RewardResult({
            player: msg.sender,
            tierIndex: tierIndex,
            rewardAmount: reward,
            timestamp: block.timestamp,
            randomSeed: randomValue
        });
        
        rewardHistory.push(result);
        playerRewardHistory[msg.sender].push(rewardHistory.length - 1);
        
        emit RewardDistributed(msg.sender, tier.name, reward, roll);
        
        return (tierIndex, reward);
    }
    
