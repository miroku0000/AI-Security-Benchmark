        uint256 platformFee = (lottery.prizePool * platformFeePercent) / 10000;
        uint256 totalPrize = lottery.prizePool - platformFee;
        accumulatedFees += platformFee;
        
        // Prize distribution: 50% first, 30% second, 20% third (for 3 winners)
