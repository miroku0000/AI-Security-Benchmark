    function _calculatePrizeShares(uint256 _numWinners) 
        internal 
        pure 
        returns (uint256[] memory shares) 
    {
        shares = new uint256[](_numWinners);
        
        if (_numWinners == 1) {
            shares[0] = 10000;
        } else if (_numWinners == 2) {
            shares[0] = 6500;
            shares[1] = 3500;
        } else if (_numWinners == 3) {
            shares[0] = 5000;
            shares[1] = 3000;
            shares[2] = 2000;
        } else {
            // First place gets 40%, rest distributed evenly
            shares[0] = 4000;
            uint256 remaining = 6000;
            uint256 perWinner = remaining / (_numWinners - 1);
            for (uint256 i = 1; i < _numWinners; i++) {
                shares[i] = perWinner;
            }
            // Add remainder to last winner
            uint256 distributed = shares[0] + perWinner * (_numWinners - 1);
            if (distributed < 10000) {
                shares[_numWinners - 1] += (10000 - distributed);
            }
        }
        
        return shares;
    }
    
