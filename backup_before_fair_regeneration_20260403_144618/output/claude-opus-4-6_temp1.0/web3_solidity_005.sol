        // Track used tickets to avoid duplicate winners
        mapping(uint256 => bool) storage usedTickets = _getUsedTicketsMapping(_lotteryId);
        
        for (uint256 i = 0; i < _numWinners; i++) {
            uint256 randomNumber = _generateEnhancedRandom(i + lottery.prizePool);
            uint256 winningTicket = randomNumber % lottery.totalTickets;
            
            // Find unused ticket
            uint256 attempts = 0;
            while (usedTickets[winningTicket] && attempts < lottery.totalTickets) {
                winningTicket = (winningTicket + 1) % lottery.totalTickets;
                attempts++;
            }
            
            usedTickets[winningTicket] = true;
            winners[i] = ticketOwner[_lotteryId][winningTicket];
            prizes[i] = (totalPrize * prizeShares[i]) / 10000;
            
            // Transfer prize
            (bool success, ) = payable(winners[i]).call{value: prizes[i]}("");
            require(success, "Prize transfer failed");
            
            emit WinnerSelected(_lotteryId, winners[i], prizes[i], winningTicket);
        }
        
