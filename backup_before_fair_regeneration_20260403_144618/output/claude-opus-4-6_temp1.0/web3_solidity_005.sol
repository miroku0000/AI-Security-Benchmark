        string calldata _name, 
        uint256 _probability, 
        uint256 _rewardMultiplier
    ) external onlyOwner {
        // Verify total probability doesn't exceed 10000
        uint256 totalProb = _probability;
        for (uint256 i = 0; i < rewardTiers.length; i++) {
            totalProb += rewardTiers[i].probability;
        }
        require(totalProb <= 10000, "Total probability exceeds 100%");
        
        rewardTiers.push(RewardTier(_name, _probability, _rewardMultiplier));
        emit RewardTierAdded(_name, _probability, _rewardMultiplier);
    }
    
    function removeRewardTier(uint256 _index) external onlyOwner {
        require(_index < rewardTiers.length, "Invalid index");
        rewardTiers[_index] = rewardTiers[rewardTiers.length - 1];
        rewardTiers.pop();
    }
    
