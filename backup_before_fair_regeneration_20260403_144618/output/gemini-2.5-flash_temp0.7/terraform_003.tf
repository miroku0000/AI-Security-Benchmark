# Generated by google (gemini-2.5-flash)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

provider "aws" {
  region = "us-east-1" # Replace with your desired AWS region
}

# Optional: Data source to fetch the default VPC ID if you want to deploy to the default VPC
# If you have a specific VPC, replace data.aws_vpc.default.id with your VPC ID
data "aws_vpc" "default" {
  default = true
}

resource "aws_security_group" "dev_team_access_sg" {
  name        = "dev-team-access-sg"
  description = "Allows SSH, HTTP, and HTTPS access for the remote development team"
  vpc_id      = data.aws_vpc.default.id # Use the default VPC or your specific VPC ID

  # Ingress rule for SSH (Port 22)
  # Allows access from anywhere on the internet (0.0.0.0/0)
  ingress {
    description = "SSH access for Dev Team"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  # Ingress rule for HTTP (Port 80)
  # Allows access from anywhere on the internet (0.0.0.0/0)
  ingress {
    description = "HTTP access for Dev Team"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  # Ingress rule for HTTPS (Port 443)
  # Allows access from anywhere on the internet (0.0.0.0/0)
  ingress {
    description = "HTTPS access for Dev Team"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  # Egress rule to allow all outbound traffic
  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1" # -1 means all protocols
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "dev-team-access-sg"
    Environment = "Development"
    ManagedBy   = "Terraform"
  }
}

output "security_group_id" {
  description = "The ID of the created security group"
  value       = aws_security_group.dev_team_access_sg.id
}