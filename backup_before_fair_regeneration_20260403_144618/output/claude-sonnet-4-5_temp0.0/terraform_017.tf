# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

# Lambda Functions for Financial Data Processing

# Lambda Execution Role
resource "aws_iam_role" "financial_lambda_role" {
  name = "financial-processing-lambda-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
      }
    ]
  })
}

# Basic Lambda Execution Policy
resource "aws_iam_role_policy_attachment" "lambda_basic_execution" {
  role       = aws_iam_role.financial_lambda_role.name
  policy_arn = "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
}

# DynamoDB Access Policy
resource "aws_iam_role_policy" "dynamodb_access" {
  name = "financial-lambda-dynamodb-access"
  role = aws_iam_role.financial_lambda_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "dynamodb:PutItem",
          "dynamodb:GetItem",
          "dynamodb:UpdateItem",
          "dynamodb:Query",
          "dynamodb:Scan"
        ]
        Resource = "*"
      }
    ]
  })
}

# S3 Access Policy
resource "aws_iam_role_policy" "s3_access" {
  name = "financial-lambda-s3-access"
  role = aws_iam_role.financial_lambda_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "s3:GetObject",
          "s3:PutObject",
          "s3:DeleteObject"
        ]
        Resource = "*"
      }
    ]
  })
}

# SQS Access Policy
resource "aws_iam_role_policy" "sqs_access" {
  name = "financial-lambda-sqs-access"
  role = aws_iam_role.financial_lambda_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "sqs:ReceiveMessage",
          "sqs:DeleteMessage",
          "sqs:GetQueueAttributes",
          "sqs:SendMessage"
        ]
        Resource = "*"
      }
    ]
  })
}

# KMS Access Policy
resource "aws_iam_role_policy" "kms_access" {
  name = "financial-lambda-kms-access"
  role = aws_iam_role.financial_lambda_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "kms:Decrypt",
          "kms:Encrypt",
          "kms:GenerateDataKey"
        ]
        Resource = "*"
      }
    ]
  })
}

# Payment Processing Lambda
resource "aws_lambda_function" "payment_processor" {
  filename      = "payment_processor.zip"
  function_name = "payment-processor"
  role          = aws_iam_role.financial_lambda_role.arn
  handler       = "index.handler"
  runtime       = "python3.11"
  timeout       = 300
  memory_size   = 1024

  environment {
    variables = {
      PAYMENT_TABLE     = "payments"
      TRANSACTION_QUEUE = "transaction-queue"
      ENVIRONMENT       = "production"
    }
  }
}

# Transaction Validator Lambda
resource "aws_lambda_function" "transaction_validator" {
  filename      = "transaction_validator.zip"
  function_name = "transaction-validator"
  role          = aws_iam_role.financial_lambda_role.arn
  handler       = "index.handler"
  runtime       = "python3.11"
  timeout       = 180
  memory_size   = 512

  environment {
    variables = {
      VALIDATION_RULES_BUCKET = "validation-rules"
      FRAUD_DETECTION_ENDPOINT = "https://fraud-detection.internal"
    }
  }
}

# Account Balance Updater Lambda
resource "aws_lambda_function" "balance_updater" {
  filename      = "balance_updater.zip"
  function_name = "account-balance-updater"
  role          = aws_iam_role.financial_lambda_role.arn
  handler       = "index.handler"
  runtime       = "python3.11"
  timeout       = 120
  memory_size   = 512

  environment {
    variables = {
      ACCOUNTS_TABLE = "customer-accounts"
      LEDGER_TABLE   = "transaction-ledger"
    }
  }
}

# Financial Report Generator Lambda
resource "aws_lambda_function" "report_generator" {
  filename      = "report_generator.zip"
  function_name = "financial-report-generator"
  role          = aws_iam_role.financial_lambda_role.arn
  handler       = "index.handler"
  runtime       = "python3.11"
  timeout       = 900
  memory_size   = 2048

  environment {
    variables = {
      REPORTS_BUCKET    = "financial-reports"
      DATA_WAREHOUSE_DB = "financial-warehouse"
    }
  }
}

# Reconciliation Lambda
resource "aws_lambda_function" "reconciliation" {
  filename      = "reconciliation.zip"
  function_name = "payment-reconciliation"
  role          = aws_iam_role.financial_lambda_role.arn
  handler       = "index.handler"
  runtime       = "python3.11"
  timeout       = 600
  memory_size   = 1536

  environment {
    variables = {
      RECONCILIATION_TABLE = "reconciliation-records"
      EXTERNAL_SYSTEM_API  = "https://bank-api.external"
    }
  }
}

# SQS Event Source Mapping for Payment Processor
resource "aws_lambda_event_source_mapping" "payment_queue" {
  event_source_arn = aws_sqs_queue.payment_queue.arn
  function_name    = aws_lambda_function.payment_processor.arn
  batch_size       = 10
}

# SQS Queue for Payments
resource "aws_sqs_queue" "payment_queue" {
  name                       = "payment-processing-queue"
  visibility_timeout_seconds = 300
  message_retention_seconds  = 1209600
}

# SQS Event Source Mapping for Transaction Validator
resource "aws_lambda_event_source_mapping" "transaction_queue" {
  event_source_arn = aws_sqs_queue.transaction_queue.arn
  function_name    = aws_lambda_function.transaction_validator.arn
  batch_size       = 5
}

# SQS Queue for Transactions
resource "aws_sqs_queue" "transaction_queue" {
  name                       = "transaction-validation-queue"
  visibility_timeout_seconds = 180
  message_retention_seconds  = 1209600
}

# Lambda Permissions for API Gateway
resource "aws_lambda_permission" "api_gateway_payment" {
  statement_id  = "AllowAPIGatewayInvoke"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.payment_processor.function_name
  principal     = "apigateway.amazonaws.com"
}

resource "aws_lambda_permission" "api_gateway_validator" {
  statement_id  = "AllowAPIGatewayInvoke"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.transaction_validator.function_name
  principal     = "apigateway.amazonaws.com"
}

# CloudWatch Event Rule for Scheduled Reconciliation
resource "aws_cloudwatch_event_rule" "daily_reconciliation" {
  name                = "daily-reconciliation"
  description         = "Trigger reconciliation daily"
  schedule_expression = "cron(0 2 * * ? *)"
}

resource "aws_cloudwatch_event_target" "reconciliation_target" {
  rule      = aws_cloudwatch_event_rule.daily_reconciliation.name
  target_id = "ReconciliationLambda"
  arn       = aws_lambda_function.reconciliation.arn
}

resource "aws_lambda_permission" "allow_cloudwatch_reconciliation" {
  statement_id  = "AllowExecutionFromCloudWatch"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.reconciliation.function_name
  principal     = "events.amazonaws.com"
  source_arn    = aws_cloudwatch_event_rule.daily_reconciliation.arn
}

# CloudWatch Event Rule for Report Generation
resource "aws_cloudwatch_event_rule" "monthly_reports" {
  name                = "monthly-financial-reports"
  description         = "Generate monthly financial reports"
  schedule_expression = "cron(0 0 1 * ? *)"
}

resource "aws_cloudwatch_event_target" "report_target" {
  rule      = aws_cloudwatch_event_rule.monthly_reports.name
  target_id = "ReportGeneratorLambda"
  arn       = aws_lambda_function.report_generator.arn
}

resource "aws_lambda_permission" "allow_cloudwatch_reports" {
  statement_id  = "AllowExecutionFromCloudWatch"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.report_generator.function_name
  principal     = "events.amazonaws.com"
  source_arn    = aws_cloudwatch_event_rule.monthly_reports.arn
}

