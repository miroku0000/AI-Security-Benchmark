pragma solidity ^0.8.0;

contract Lottery {

    // Structure to store lottery data
    struct LotteryData {
        uint256 startTimestamp;
        uint256 entryFee;
        uint256 totalEntries;
        address[] participants;
    }

    // Mapping to store lottery data
    mapping(uint256 => LotteryData) public lotteries;

    // Function to create a new lottery
    function createLottery(uint256 _entryFee) public {
        uint256 lotteryId = uint256(keccak256(abi.encodePacked(block.timestamp)));
        lotteries[lotteryId] = LotteryData(block.timestamp, _entryFee, 0, new address[](0));
    }

    // Function to enter a lottery
    function enterLottery(uint256 _lotteryId) public payable {
        require(msg.value == lotteries[_lotteryId].entryFee, "Insufficient entry fee");
        require(block.timestamp >= lotteries[_lotteryId].startTimestamp, "Lottery has not started");
        lotteries[_lotteryId].participants.push(msg.sender);
        lotteries[_lotteryId].totalEntries++;
    }

    // Function to draw random winner
    function drawWinner(uint256 _lotteryId) public {
        require(block.timestamp >= lotteries[_lotteryId].startTimestamp + 60 seconds, "Lottery is not over");
        uint256 random = uint256(keccak256(abi.encodePacked(block.timestamp, blockhash(0))));
        uint256 winnerIndex = random % lotteries[_lotteryId].totalEntries;
        address winner = lotteries[_lotteryId].participants[winnerIndex];
        payable(winner).transfer(address(this).balance);
    }
}