# Generated by openai (gpt-5.4)
# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
    archive = {
      source  = "hashicorp/archive"
      version = ">= 2.4.0"
    }
  }
}

variable "name_prefix" {
  type        = string
  description = "Prefix for all resources"
  default     = "payment-processing"
}

variable "aws_region" {
  type        = string
  description = "AWS region"
  default     = "us-east-1"
}

variable "lambda_runtime" {
  type        = string
  description = "Lambda runtime"
  default     = "python3.12"
}

variable "kms_key_arn" {
  type        = string
  description = "KMS key ARN for environment variable encryption and data protection"
}

variable "transaction_queue_arn" {
  type        = string
  description = "ARN of the SQS queue containing payment transactions"
}

variable "transaction_queue_url" {
  type        = string
  description = "URL of the SQS queue containing payment transactions"
}

variable "ledger_table_arn" {
  type        = string
  description = "ARN of the DynamoDB ledger table"
}

variable "ledger_table_name" {
  type        = string
  description = "Name of the DynamoDB ledger table"
}

variable "payment_secrets_arn" {
  type        = string
  description = "ARN of the Secrets Manager secret containing payment processor credentials"
}

variable "vpc_subnet_ids" {
  type        = list(string)
  description = "Private subnet IDs for Lambda VPC attachment"
}

variable "vpc_security_group_ids" {
  type        = list(string)
  description = "Security group IDs for Lambda VPC attachment"
}

variable "dlq_arn" {
  type        = string
  description = "ARN of the dead-letter queue"
}

provider "aws" {
  region = var.aws_region

  default_tags {
    tags = {
      System      = "payments"
      DataClass   = "sensitive-financial"
      ManagedBy   = "terraform"
      Environment = "production"
    }
  }
}

data "aws_caller_identity" "current" {}

data "aws_region" "current" {}

locals {
  processor_function_name = "${var.name_prefix}-transaction-processor"
  reconciler_function_name = "${var.name_prefix}-settlement-reconciler"
}

resource "aws_cloudwatch_log_group" "processor" {
  name              = "/aws/lambda/${local.processor_function_name}"
  retention_in_days = 30
  kms_key_id        = var.kms_key_arn
}

resource "aws_cloudwatch_log_group" "reconciler" {
  name              = "/aws/lambda/${local.reconciler_function_name}"
  retention_in_days = 30
  kms_key_id        = var.kms_key_arn
}

resource "aws_iam_role" "lambda_execution" {
  name = "${var.name_prefix}-lambda-execution-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "LambdaAssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
        Action = "sts:AssumeRole"
      }
    ]
  })
}

resource "aws_iam_role_policy" "lambda_execution" {
  name = "${var.name_prefix}-lambda-inline-policy"
  role = aws_iam_role.lambda_execution.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "WriteEncryptedLogs"
        Effect = "Allow"
        Action = [
          "logs:CreateLogStream",
          "logs:PutLogEvents"
        ]
        Resource = [
          "${aws_cloudwatch_log_group.processor.arn}:*",
          "${aws_cloudwatch_log_group.reconciler.arn}:*"
        ]
      },
      {
        Sid    = "ReadPaymentSecrets"
        Effect = "Allow"
        Action = [
          "secretsmanager:GetSecretValue",
          "secretsmanager:DescribeSecret"
        ]
        Resource = var.payment_secrets_arn
      },
      {
        Sid    = "UseKmsForSecretsAndEnv"
        Effect = "Allow"
        Action = [
          "kms:Decrypt",
          "kms:Encrypt",
          "kms:GenerateDataKey",
          "kms:DescribeKey"
        ]
        Resource = var.kms_key_arn
      },
      {
        Sid    = "ProcessTransactionQueue"
        Effect = "Allow"
        Action = [
          "sqs:ReceiveMessage",
          "sqs:DeleteMessage",
          "sqs:ChangeMessageVisibility",
          "sqs:GetQueueAttributes"
        ]
        Resource = var.transaction_queue_arn
      },
      {
        Sid    = "SendToDeadLetterQueue"
        Effect = "Allow"
        Action = [
          "sqs:SendMessage"
        ]
        Resource = var.dlq_arn
      },
      {
        Sid    = "WriteLedgerRecords"
        Effect = "Allow"
        Action = [
          "dynamodb:PutItem",
          "dynamodb:UpdateItem",
          "dynamodb:GetItem",
          "dynamodb:Query",
          "dynamodb:DescribeTable"
        ]
        Resource = var.ledger_table_arn
      },
      {
        Sid    = "VpcNetworking"
        Effect = "Allow"
        Action = [
          "ec2:CreateNetworkInterface",
          "ec2:DescribeNetworkInterfaces",
          "ec2:DeleteNetworkInterface",
          "ec2:AssignPrivateIpAddresses",
          "ec2:UnassignPrivateIpAddresses"
        ]
        Resource = "*"
      }
    ]
  })
}

data "archive_file" "processor_zip" {
  type        = "zip"
  output_path = "${path.module}/build/transaction_processor.zip"

  source {
    filename = "lambda_function.py"
    content  = <<-PYTHON
import json
import os
import boto3
import decimal
from datetime import datetime, timezone

dynamodb = boto3.resource("dynamodb")
secretsmanager = boto3.client("secretsmanager")

table = dynamodb.Table(os.environ["LEDGER_TABLE_NAME"])
secret_arn = os.environ["PAYMENT_SECRET_ARN"]

def _decimal_default(obj):
    if isinstance(obj, decimal.Decimal):
        return float(obj)
    raise TypeError

def _load_processor_secret():
    response = secretsmanager.get_secret_value(SecretId=secret_arn)
    secret_string = response.get("SecretString", "{}")
    return json.loads(secret_string)

def _mask_pan(pan):
    if not pan or len(pan) < 4:
        return "****"
    return "*" * max(len(pan) - 4, 0) + pan[-4:]

def _validate_transaction(txn):
    required = ["transaction_id", "account_id", "amount", "currency", "merchant_id", "card_last4"]
    for field in required:
        if field not in txn or txn[field] in [None, ""]:
            raise ValueError(f"missing required field: {field}")

    amount = decimal.Decimal(str(txn["amount"]))
    if amount <= 0:
        raise ValueError("amount must be positive")

    if len(str(txn["currency"])) != 3:
        raise ValueError("currency must be ISO-4217 alpha-3")

    return amount

def _write_ledger(txn, amount, processor_config):
    now = datetime.now(timezone.utc).isoformat()
    item = {
        "transaction_id": txn["transaction_id"],
        "account_id": txn["account_id"],
        "merchant_id": txn["merchant_id"],
        "currency": txn["currency"].upper(),
        "amount": amount,
        "status": "AUTHORIZED",
        "processor": processor_config.get("processor_name", "external-gateway"),
        "card_last4": txn["card_last4"],
        "created_at": now,
        "updated_at": now
    }
    table.put_item(
        Item=item,
        ConditionExpression="attribute_not_exists(transaction_id)"
    )
    return item

def lambda_handler(event, context):
    processor_config = _load_processor_secret()
    results = []

    for record in event.get("Records", []):
        body = json.loads(record["body"])
        amount = _validate_transaction(body)
        ledger_item = _write_ledger(body, amount, processor_config)

        results.append({
            "transaction_id": ledger_item["transaction_id"],
            "status": ledger_item["status"],
            "amount": float(ledger_item["amount"]),
            "currency": ledger_item["currency"],
            "card": _mask_pan(ledger_item["card_last4"])
        })

    return {
        "processed_count": len(results),
        "results": results
    }
PYTHON
  }
}

data "archive_file" "reconciler_zip" {
  type        = "zip"
  output_path = "${path.module}/build/settlement_reconciler.zip"

  source {
    filename = "lambda_function.py"
    content  = <<-PYTHON
import json
import os
import boto3
from datetime import datetime, timezone

dynamodb = boto3.resource("dynamodb")
table = dynamodb.Table(os.environ["LEDGER_TABLE_NAME"])

def lambda_handler(event, context):
    transaction_id = event["transaction_id"]
    settlement_status = event["settlement_status"]
    settled_at = datetime.now(timezone.utc).isoformat()

    response = table.update_item(
        Key={"transaction_id": transaction_id},
        UpdateExpression="SET #status = :status, settled_at = :settled_at, updated_at = :updated_at",
        ExpressionAttributeNames={
            "#status": "status"
        },
        ExpressionAttributeValues={
            ":status": settlement_status,
            ":settled_at": settled_at,
            ":updated_at": settled_at
        },
        ConditionExpression="attribute_exists(transaction_id)",
        ReturnValues="ALL_NEW"
    )

    attrs = response["Attributes"]
    return {
        "transaction_id": attrs["transaction_id"],
        "status": attrs["status"],
        "settled_at": attrs["settled_at"]
    }
PYTHON
  }
}

resource "aws_lambda_function" "transaction_processor" {
  function_name = local.processor_function_name
  role          = aws_iam_role.lambda_execution.arn
  runtime       = var.lambda_runtime
  handler       = "lambda_function.lambda_handler"
  filename      = data.archive_file.processor_zip.output_path
  source_code_hash = data.archive_file.processor_zip.output_base64sha256
  timeout       = 30
  memory_size   = 512
  kms_key_arn   = var.kms_key_arn

  reserved_concurrent_executions = 20

  environment {
    variables = {
      LEDGER_TABLE_NAME   = var.ledger_table_name
      PAYMENT_SECRET_ARN  = var.payment_secrets_arn
      AWS_REGION          = data.aws_region.current.name
    }
  }

  vpc_config {
    subnet_ids         = var.vpc_subnet_ids
    security_group_ids = var.vpc_security_group_ids
  }

  dead_letter_config {
    target_arn = var.dlq_arn
  }

  tracing_config {
    mode = "PassThrough"
  }

  depends_on = [
    aws_cloudwatch_log_group.processor
  ]
}

resource "aws_lambda_function" "settlement_reconciler" {
  function_name = local.reconciler_function_name
  role          = aws_iam_role.lambda_execution.arn
  runtime       = var.lambda_runtime
  handler       = "lambda_function.lambda_handler"
  filename      = data.archive_file.reconciler_zip.output_path
  source_code_hash = data.archive_file.reconciler_zip.output_base64sha256
  timeout       = 30
  memory_size   = 256
  kms_key_arn   = var.kms_key_arn

  reserved_concurrent_executions = 10

  environment {
    variables = {
      LEDGER_TABLE_NAME = var.ledger_table_name
      AWS_REGION        = data.aws_region.current.name
    }
  }

  vpc_config {
    subnet_ids         = var.vpc_subnet_ids
    security_group_ids = var.vpc_security_group_ids
  }

  dead_letter_config {
    target_arn = var.dlq_arn
  }

  tracing_config {
    mode = "PassThrough"
  }

  depends_on = [
    aws_cloudwatch_log_group.reconciler
  ]
}

resource "aws_lambda_event_source_mapping" "transaction_queue" {
  event_source_arn                   = var.transaction_queue_arn
  function_name                      = aws_lambda_function.transaction_processor.arn
  enabled                            = true
  batch_size                         = 10
  maximum_batching_window_in_seconds = 5
  function_response_types            = ["ReportBatchItemFailures"]
}

output "transaction_processor_lambda_arn" {
  value = aws_lambda_function.transaction_processor.arn
}

output "settlement_reconciler_lambda_arn" {
  value = aws_lambda_function.settlement_reconciler.arn
}

output "lambda_execution_role_arn" {
  value = aws_iam_role.lambda_execution.arn
}