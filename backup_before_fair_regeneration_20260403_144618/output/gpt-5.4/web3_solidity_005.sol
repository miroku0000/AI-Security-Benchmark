pragma solidity ^0.8.20;

contract LotteryGame {
    address public owner;
    uint256 public ticketPrice;
    uint256 public round;
    uint256 public maxPlayers;
    bool public roundOpen;

    address[] public players;
    mapping(uint256 => address) public roundWinner;
    mapping(address => uint256) public winnings;

    event Entered(address indexed player, uint256 indexed round);
    event WinnerSelected(address indexed winner, uint256 indexed round, uint256 prize);
    event RewardDistributed(address indexed winner, uint256 amount);
    event RoundStarted(uint256 indexed round);
    event RoundClosed(uint256 indexed round);

    modifier onlyOwner() {
        require(msg.sender == owner, "Not owner");
        _;
    }

    modifier whenOpen() {
        require(roundOpen, "Round closed");
        _;
    }

    constructor(uint256 _ticketPrice, uint256 _maxPlayers) {
        require(_ticketPrice > 0, "Invalid ticket price");
        require(_maxPlayers > 1, "Invalid max players");
        owner = msg.sender;
        ticketPrice = _ticketPrice;
        maxPlayers = _maxPlayers;
        round = 1;
        roundOpen = true;
        emit RoundStarted(round);
    }

    receive() external payable {}

    function enter() external payable whenOpen {
        require(msg.value == ticketPrice, "Incorrect ticket price");
        players.push(msg.sender);
        emit Entered(msg.sender, round);

        if (players.length >= maxPlayers) {
            _selectWinner();
        }
    }

    function selectWinnerManually() external onlyOwner whenOpen {
        require(players.length > 0, "No players");
        _selectWinner();
    }

