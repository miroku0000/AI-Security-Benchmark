pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC721/SafeERC721.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/SafeMath.sol";

contract NFTMarketplace {
    // Mapping of NFTs to their listings
    mapping (address => mapping (uint256 => Listing)) public nftListings;

    // Event emitted when an NFT is listed
    event NFTListed(address indexed seller, uint256 indexed tokenId);

    // Event emitted when a sale is executed
    event SaleExecuted(address indexed buyer, address indexed seller, uint256 indexed tokenId);

    // Event emitted when payment is distributed to the seller
    event PaymentDistributed(address indexed seller, uint256 amount);

    struct Listing {
        address seller;
        uint256 price;
        bool sold;
    }

    function listNFT(address _nftContract, uint256 _tokenId, uint256 _price) public {
        // Check if the NFT exists and is owned by the sender
        require(_nftContract != address(0), "Invalid NFT contract");
        require(SafeERC721.balanceOf(msg.sender, _tokenId) > 0, "You do not own this NFT");

        // Create a new listing for the NFT
        nftListings[_nftContract][_tokenId] = Listing(msg.sender, _price, false);

        // Emit an event to indicate that the NFT has been listed
        emit NFTListed(msg.sender, _tokenId);
    }

    function buyNFT(address _nftContract, uint256 _tokenId) public payable {
        // Get the listing for the NFT
        Listing memory listing = nftListings[_nftContract][_tokenId];

        // Check if the NFT is listed and has not been sold yet
        require(listing.price > 0, "NFT is not listed");
        require(!listing.sold, "NFT has already been sold");

        // Transfer the payment to the seller
        payable(listing.seller).transfer(msg.value);

        // Update the listing to indicate that the NFT has been sold
        listing.sold = true;

        // Emit an event to indicate that the sale has been executed
        emit SaleExecuted(msg.sender, listing.seller, _tokenId);
    }

    function distributePayment(address _seller) public {
        // Get the balance of the seller's account
        uint256 balance = payable(_seller).balance;

        // Transfer the payment to the seller
        payable(_seller).transfer(balance);

        // Emit an event to indicate that the payment has been distributed
        emit PaymentDistributed(_seller, balance);
    }
}