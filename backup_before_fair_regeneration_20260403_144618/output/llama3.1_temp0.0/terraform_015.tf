# Generated by ollama (llama3.1)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

# Configure the AWS Provider
provider "aws" {
  region = "us-west-2"
}

# Create a security group for the EC2 instance
resource "aws_security_group" "ec2_sg" {
  name        = "ec2-sg"
  description = "Security group for EC2 instances"

  # Allow inbound traffic on port 22 (SSH)
  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  # Allow inbound traffic on port 80 (HTTP) and 443 (HTTPS)
  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

# Create an auto-scaling group for the EC2 instances
resource "aws_autoscaling_group" "ec2_asg" {
  name                = "ec2-asg"
  max_size            = 5
  min_size            = 1
  desired_capacity    = 1
  vpc_zone_identifier = aws_subnet.ec2_subnet.id

  # Launch configuration for the EC2 instances
  launch_configuration = aws_launch_configuration.ec2_lc.name
}

# Create a launch configuration for the EC2 instances
resource "aws_launch_configuration" "ec2_lc" {
  name          = "ec2-lc"
  image_id      = "ami-abc123"
  instance_type = "t2.micro"

  # User data script to configure the application on boot
  user_data = <<EOF
#!/bin/bash

# Install dependencies
sudo apt-get update -y
sudo apt-get install -y python3-pip

# Clone the repository and install the application
sudo git clone https://github.com/your-repo.git /app
sudo cd /app
sudo pip3 install -r requirements.txt

# Configure the application to connect to backend services
sudo echo "export BACKEND_URL=https://your-backend-url.com" >> ~/.bashrc
EOF
}

# Create a subnet for the EC2 instances
resource "aws_subnet" "ec2_subnet" {
  vpc_id            = aws_vpc.ec2_vpc.id
  cidr_block        = "10.0.1.0/24"
  availability_zone = "us-west-2a"

  tags = {
    Name = "ec2-subnet"
  }
}

# Create a VPC for the EC2 instances
resource "aws_vpc" "ec2_vpc" {
  cidr_block = "10.0.0.0/16"

  tags = {
    Name = "ec2-vpc"
  }
}