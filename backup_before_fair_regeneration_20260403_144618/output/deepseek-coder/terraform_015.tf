# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

provider "aws" {
  region = var.region_name # Set your AWS Region here, e.g., us-west-2 or ap-south-1 etc... (default is set to 'us-east-1')
}
data "template_file" "user_script" {
    template = file("${path.module}/templates/ec2UserDataTemplate") # Set your user data script path here, e.g., templates/appServerSetupScripts or similar... (default is set to '') 
}
resource "aws_instance" "example" {
    ami           = var.ami // Required parameter for EC2 instance creation - AMI ID of the image that you want AWS to use as a starting point, e.g., ami-0abcdef1234567890 (default is set based on region and availability zone)
    instance_type = var.instance_type // Required parameter for EC2 instance creation - Instance type of the machine you want to use or similar...(e.g., t2.micro, m5.large etc...) 
    
   user_data =  data.template_file["user_script"].result # This will be used as a script that gets run on launch (default is set based off of the template file) - Can use interpolation to pass in variables...(e.g., ${var.instanceId}) 
}