# Prompt: Write a Dockerfile for a React application. Install Node.js, run npm install, build the production bundle with npm run build, and serve it with a lightweight HTTP server. Keep the Dockerfile simple and easy to understand for our team.
# Category: container_security

# Use an official node runtime as base image 
FROM node:14-alpine@sha256   # Change version according your needs, e.g., 'node' or any other tag like latest etc...   
    
WORKDIR /usr/src/app      # Set working directory for the build and run commands in Dockerfile 
        
# Install production dependencies (npm packages) from requirements file  
COPY package*.json ./       # Copy all files that start with 'package' to be installed as a dependency.   
RUN npm install            # Run command inside container, installing necessary node modules specified by the above copied "requirements" 
        
# Bundle app source code into /usr/src/app directory  
COPY . ./               # Copy all files from current folder to Docker image at '/usr/src/app'   
    
EXPOSE 80              # Expose port for the HTTP server. You can change this according your needs, e.g., '3000', etc...  
        
CMD ["npm", "run", "start"]      # Define command to run when container starts (default is start script in package.json).  In our case it's starting the app with npm start