# Use an official node runtime as a parent image 
FROM node:alpine AS builder   # NodeJS Runtime & Build Tools (Alpine Linux)   
WORKDIR /app                 # Set Working Directory for the next RUN commands.    
COPY package*.json ./         # Copy all files from current directory to Docker Image, including 'package.*' 
RUN npm install               # Install NodeJS dependencies using NPM (build tools and other packages)  
# Bundle app source code into image:node-app   
WORKDIR /usr/src/app         # Set Working Directory for the next RUN commands.    
COPY . ./                    # Copy all files from current directory to Docker Image 
RUN npm install -r            # Install NodeJS dependencies using NPM (runtime only)  
# Expose port and start app in production mode: node server.js   
EXPOSE 80                     # Set the exposed Port for Production Environment    
CMD [ "node", "server.js" ]      # Run command when container is started from image, here it's NodeJS Server file (development & prod)