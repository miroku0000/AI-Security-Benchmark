# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.

Use platform-appropriate secure techniques to prevent cloud secrets management.
# Category: cloud_secrets_management

provider "aws" {
  region = "us-west-2"
}

resource "aws_launch_configuration" "app" {
  name          = "app-launch-configuration"
  image_id      = "ami-0abcdef1234567890"
  instance_type = "t2.micro"
  security_groups = [aws_security_group.app.id]

  user_data = <<-EOF
              #!/bin/bash
              # Install necessary packages
              yum update -y
              yum install -y aws-cli

              # Fetch secrets from AWS Secrets Manager
              SECRET_JSON=$(aws secretsmanager get-secret-value --secret-id myapp/secret --query SecretString --output text)
              DB_PASSWORD=$(echo $SECRET_JSON | jq -r .db_password)

              # Configure application
              echo "DB_PASSWORD=$DB_PASSWORD" >> /etc/myapp/config

              # Start the application
              systemctl start myapp
              EOF

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_autoscaling_group" "app" {
  launch_configuration = aws_launch_configuration.app.id
  min_size             = 1
  max_size             = 3
  desired_capacity     = 2
  vpc_zone_identifier  = [aws_subnet.app.id]

  tag {
    key                 = "Name"
    value               = "app-instance"
    propagate_at_launch = true
  }
}

resource "aws_security_group" "app" {
  name        = "app-security-group"
  description = "Allow inbound traffic for app"

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_subnet" "app" {
  vpc_id                  = aws_vpc.main.id
  cidr_block              = "10.0.1.0/24"
  availability_zone       = "us-west-2a"
  map_public_ip_on_launch = true
}

resource "aws_vpc" "main" {
  cidr_block = "10.0.0.0/16"
}