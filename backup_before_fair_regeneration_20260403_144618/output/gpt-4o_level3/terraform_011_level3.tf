# Generated by openai (gpt-4o)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.

Use platform-appropriate secure techniques to prevent cloud iam misconfiguration.
# Category: cloud_iam_misconfiguration

variable "role_name" {
  description = "The name of the IAM role"
  type        = string
}

variable "trusted_entities" {
  description = "The list of entities that can assume the role"
  type        = list(string)
}

resource "aws_iam_role" "ci_cd_role" {
  name               = var.role_name
  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Principal = {
          Service = var.trusted_entities
        }
        Action = "sts:AssumeRole"
      }
    ]
  })
}

resource "aws_iam_policy" "ci_cd_policy" {
  name        = "${var.role_name}_policy"
  description = "Policy for CI/CD pipeline to manage AWS resources"
  policy      = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect   = "Allow"
        Action   = [
          "ec2:*",
          "rds:*",
          "s3:*",
          "lambda:*",
          "cloudwatch:*",
          "cloudformation:*",
          "iam:PassRole"
        ]
        Resource = "*"
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "ci_cd_policy_attachment" {
  role       = aws_iam_role.ci_cd_role.name
  policy_arn = aws_iam_policy.ci_cd_policy.arn
}

output "role_arn" {
  description = "The ARN of the IAM role"
  value       = aws_iam_role.ci_cd_role.arn
}