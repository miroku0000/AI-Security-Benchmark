}

resource "aws_iam_policy" "lambda_policy" {
  name        = "lambda_financial_data_processor_policy"
  description = "Policy for Lambda function to process sensitive financial data"
  
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "s3:GetObject",
