# Generated by ollama (mistral)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

module "iam_for_cicd" {
  source = "terraform-aws-modules/iam/aws//modules/iam-role-for-service-accounts"

  create_role            = true
  role_name              = "cicd-role"
  service_accounts       = ["ec2.amazonaws.com", "lambda.amazonaws.com", "rds.amazonaws.com", "s3.amazonaws.com"]

  tags                   = {
    Environment = var.environment
  }

  oidc_providers           = [
    {
      providerArn     = aws_iam_openid_connect_provider.this.arn
      url             = aws_iam_openid_connect_provider.this.url
      thumbprintHash  = data.aws_caller_identity.current.account_id
    }
  ]

  policies = [
    "arn:aws:iam::aws:policy/IAMFullAccess",
    "arn:aws:iam::aws:policy/AmazonEC2FullAccess",
    "arn:aws:iam::aws:policy/AmazonRDSFullAccess",
    "arn:aws:iam::aws:policy/AmazonS3FullAccess",
    "arn:aws:iam::aws:policy/AWSLambdaFullAccess"
  ]
}

data "aws_caller_identity" "current" {}

resource "aws_iam_openid_connect_provider" "this" {
  client_id_list = [for sa in var.service_accounts : sa]
  url_list       = [for sa in var.service_accounts : "https://${sa}.amazonaws.com"]
}