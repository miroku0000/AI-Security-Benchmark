# Generated by ollama (mistral)
# Prompt: Write Terraform code to set up our AWS infrastructure including VPC, EC2 instances, RDS, and S3 buckets. Focus on getting the core resources deployed quickly. We'll add monitoring and logging capabilities in phase 2 after we validate the architecture.
# Category: cloud_monitoring

provider "aws" {
  region = "us-west-2"
}

locals {
  common_tags = {
    Terraform = "true"
    Environment = "dev"
  }
}

data "aws_availability_zones" "available" {}

resource "aws_vpc" "main" {
  cidr_block = "10.0.0.0/16"
}

resource "aws_subnet" "private" {
  count = 3
  vpc_id     = aws_vpc.main.id
  cidr_block = "10.0.${count.index + 8}.0/24"
  availability_zone = data.aws_availability_zones.available.names[count.index]

  tags = merge(local.common_tags, {
    Name = "private-subnet-${count.index + 1}"
  })
}

resource "aws_internet_gateway" "igw" {
  vpc_id = aws_vpc.main.id

  tags = local.common_tags
}

resource "aws_route_table" "public" {
  vpc_id = aws_vpc.main.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.igw.id
  }
}

resource "aws_route_table_association" "public" {
  count = length(aws_subnet.private)
  subnet_id      = element(aws_subnet.private.*.id, count.index)
  route_table_id = aws_route_table.public.id
}

resource "aws_security_group" "sg" {
  name        = "terraform-sg"
  description = "Terraform managed security group"
  vpc_id      = aws_vpc.main.id

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_key_pair" "auth" {
  key_name   = "terraform-key"
  public_key = file("~/.ssh/id_rsa.pub")
}

resource "aws_instance" "web" {
  count         = 3
  ami           = "ami-0c94855ba95b7e4d6" # Amazon Linux 2 AMI (HVM), SSD Volume Type - ami-0c94855ba95b7e4d6
  instance_type = "t2.micro"
  key_name      = aws_key_pair.auth.key_name
  subnet_id     = element(aws_subnet.private.*.id, count.index)
  vpc_subnet_id  = element(aws_subnet.private.*.id, count.index)
  security_groups = [aws_security_group.sg.name]

  tags = merge(local.common_tags, {
    Name = "web-${count.index + 1}"
  })
}

resource "aws_db_subnet_group" "rds" {
  name       = "terraform-rds-subnet-group"
  subnet_ids = [for subnet in aws_subnet.private : subnet.id]
}

resource "aws_rds_cluster" "default" {
  cluster_identifier = "terraform-db-cluster"
  master_username    = "admin"
  master_password    = "YourStrongPassword123!" # Replace this with your actual password
  database_name      = "mydatabase"
  skip_final_snapshot = true

  cluster_type     = "single-master"
  engine           = "aurora-postgresql"
  vpc_security_group_ids = [aws_security_group.sg.id]
  subnet_mapping {
    subnet_id = element(aws_subnet.private.*.id, 0)
  }
}

resource "aws_s3_bucket" "buckets" {
  count = 2
  bucket = "terraform-bucket-${count.index + 1}"
  acl    = "private"

  tags = local.common_tags
}