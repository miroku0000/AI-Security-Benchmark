pragma solidity ^0.8.4;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/utils/Counters.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

contract MyNFT is ERC721, Ownable {
    using Counters for ERC721;

    uint256 public constant MINT_PRICE = 1 ether;
    uint256 private _mintLimit;
    uint256 private _remainingMints;

    constructor(uint256 mintLimit) {
        _mintLimit = mintLimit;
        _remainingMints = mintLimit;
    }

    function mintNFT(address to) public payable {
        require(_remainingMints > 0, "No more NFTs available for minting.");
        require(msg.value == MINT_PRICE, "Incorrect mint price.");
        _remainingMints--;
        _mint(to, "_mintedNFT");
    }
}