# Category: cloud_monitoring

# KMS key for encryption
resource "aws_kms_key" "lambda_encryption" {
  description             = "KMS key for Lambda environment variables and data encryption"
  deletion_window_in_days = 30
  enable_key_rotation     = true

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "Enable IAM User Permissions"
        Effect = "Allow"
        Principal = {
          AWS = "arn:aws:iam::${data.aws_caller_identity.current.account_id}:root"
        }
        Action   = "kms:*"
        Resource = "*"
      },
      {
        Sid    = "Allow Lambda to use the key"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
        Action = [
          "kms:Decrypt",
          "kms:DescribeKey"
        ]
        Resource = "*"
      }
    ]
  })
}

resource "aws_kms_alias" "lambda_encryption" {
  name          = "alias/lambda-financial-processing"
  target_key_id = aws_kms_key.lambda_encryption.key_id
}

# Secrets Manager for sensitive credentials
resource "aws_secretsmanager_secret" "payment_api_credentials" {
  name                    = "payment-processing/api-credentials"
  description             = "API credentials for payment gateway"
  kms_key_id              = aws_kms_key.lambda_encryption.id
  recovery_window_in_days = 30
}

# IAM role for Lambda execution
resource "aws_iam_role" "payment_processor_lambda" {
  name = "payment-processor-lambda-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
      }
    ]
  })
}

# Least privilege IAM policy for Lambda
resource "aws_iam_role_policy" "payment_processor_policy" {
  name = "payment-processor-policy"
  role = aws_iam_role.payment_processor_lambda.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "CloudWatchLogsAccess"
        Effect = "Allow"
        Action = [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents"
        ]
        Resource = [
          "arn:aws:logs:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:log-group:/aws/lambda/payment-processor:*"
        ]
      },
      {
        Sid    = "SecretsManagerAccess"
        Effect = "Allow"
        Action = [
          "secretsmanager:GetSecretValue"
        ]
        Resource = [
          aws_secretsmanager_secret.payment_api_credentials.arn
        ]
      },
      {
        Sid    = "KMSDecryptAccess"
        Effect = "Allow"
        Action = [
          "kms:Decrypt",
          "kms:DescribeKey"
        ]
        Resource = [
          aws_kms_key.lambda_encryption.arn
        ]
      },
      {
        Sid    = "DynamoDBAccess"
        Effect = "Allow"
        Action = [
          "dynamodb:PutItem",
          "dynamodb:GetItem",
          "dynamodb:UpdateItem",
          "dynamodb:Query"
        ]
        Resource = [
          aws_dynamodb_table.transactions.arn,
          "${aws_dynamodb_table.transactions.arn}/index/*"
        ]
      },
      {
        Sid    = "VPCNetworkAccess"
        Effect = "Allow"
        Action = [
          "ec2:CreateNetworkInterface",
          "ec2:DescribeNetworkInterfaces",
          "ec2:DeleteNetworkInterface"
        ]
        Resource = "*"
        Condition = {
          StringEquals = {
            "ec2:Vpc" = aws_vpc.payment_processing.arn
          }
        }
      }
    ]
  })
}

# DynamoDB table for transaction records
resource "aws_dynamodb_table" "transactions" {
  name           = "financial-transactions"
  billing_mode   = "PAY_PER_REQUEST"
  hash_key       = "transaction_id"
  range_key      = "timestamp"

  attribute {
    name = "transaction_id"
    type = "S"
  }

  attribute {
    name = "timestamp"
    type = "N"
  }

  attribute {
    name = "user_id"
    type = "S"
  }

  global_secondary_index {
    name            = "user-index"
    hash_key        = "user_id"
    range_key       = "timestamp"
    projection_type = "ALL"
  }

  server_side_encryption {
    enabled     = true
    kms_key_arn = aws_kms_key.lambda_encryption.arn
  }

  point_in_time_recovery {
    enabled = true
  }

  tags = {
    Environment = "production"
    DataClass   = "sensitive"
  }
}

# VPC for Lambda isolation
resource "aws_vpc" "payment_processing" {
  cidr_block           = "10.0.0.0/16"
  enable_dns_hostnames = true
  enable_dns_support   = true

  tags = {
    Name = "payment-processing-vpc"
  }
}

resource "aws_subnet" "private_a" {
  vpc_id            = aws_vpc.payment_processing.id
  cidr_block        = "10.0.1.0/24"
  availability_zone = "${data.aws_region.current.name}a"

  tags = {
    Name = "payment-processing-private-a"
  }
}

resource "aws_subnet" "private_b" {
  vpc_id            = aws_vpc.payment_processing.id
  cidr_block        = "10.0.2.0/24"
  availability_zone = "${data.aws_region.current.name}b"

  tags = {
    Name = "payment-processing-private-b"
  }
}

resource "aws_security_group" "lambda_sg" {
  name        = "payment-processor-lambda-sg"
  description = "Security group for payment processing Lambda"
  vpc_id      = aws_vpc.payment_processing.id

  egress {
    description = "HTTPS to payment gateway"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "payment-processor-lambda-sg"
  }
}

# Lambda function for payment processing
resource "aws_lambda_function" "payment_processor" {
  filename         = "payment_processor.zip"
  function_name    = "payment-processor"
  role             = aws_iam_role.payment_processor_lambda.arn
  handler          = "index.handler"
  source_code_hash = filebase64sha256("payment_processor.zip")
  runtime          = "python3.11"
  timeout          = 30
  memory_size      = 512

  vpc_config {
    subnet_ids         = [aws_subnet.private_a.id, aws_subnet.private_b.id]
    security_group_ids = [aws_security_group.lambda_sg.id]
  }

  environment {
    variables = {
      DYNAMODB_TABLE        = aws_dynamodb_table.transactions.name
      SECRET_ARN            = aws_secretsmanager_secret.payment_api_credentials.arn
      ENCRYPTION_KEY_ID     = aws_kms_key.lambda_encryption.key_id
      LOG_LEVEL             = "INFO"
      MASK_SENSITIVE_DATA   = "true"
    }
  }

  kms_key_arn = aws_kms_key.lambda_encryption.arn

  tracing_config {
    mode = "Active"
  }

  reserved_concurrent_executions = 100

  tags = {
    Environment = "production"
    Function    = "payment-processing"
  }
}

# CloudWatch Log Group with encryption and retention
resource "aws_cloudwatch_log_group" "payment_processor" {
  name              = "/aws/lambda/${aws_lambda_function.payment_processor.function_name}"
  retention_in_days = 90
  kms_key_id        = aws_kms_key.lambda_encryption.arn

  tags = {
    Environment = "production"
    Function    = "payment-processing"
  }
}

# Lambda function for transaction validation
resource "aws_lambda_function" "transaction_validator" {
  filename         = "transaction_validator.zip"
  function_name    = "transaction-validator"
  role             = aws_iam_role.payment_processor_lambda.arn
  handler          = "validator.handler"
  source_code_hash = filebase64sha256("transaction_validator.zip")
  runtime          = "python3.11"
  timeout          = 15
  memory_size      = 256

  vpc_config {
    subnet_ids         = [aws_subnet.private_a.id, aws_subnet.private_b.id]
    security_group_ids = [aws_security_group.lambda_sg.id]
  }

  environment {
    variables = {
      DYNAMODB_TABLE      = aws_dynamodb_table.transactions.name
      MAX_TRANSACTION_AMT = "10000"
      VALIDATION_STRICT   = "true"
      LOG_LEVEL           = "INFO"
    }
  }

  kms_key_arn = aws_kms_key.lambda_encryption.arn

  tracing_config {
    mode = "Active"
  }

  reserved_concurrent_executions = 50

  tags = {
    Environment = "production"
    Function    = "transaction-validation"
  }
}

resource "aws_cloudwatch_log_group" "transaction_validator" {
  name              = "/aws/lambda/${aws_lambda_function.transaction_validator.function_name}"
  retention_in_days = 90
  kms_key_id        = aws_kms_key.lambda_encryption.arn

  tags = {
    Environment = "production"
    Function    = "transaction-validation"
  }
}

# Lambda function URL with IAM authentication
resource "aws_lambda_function_url" "payment_processor" {
  function_name      = aws_lambda_function.payment_processor.function_name
  authorization_type = "AWS_IAM"

  cors {
    allow_origins     = ["https://secure.example.com"]
    allow_methods     = ["POST"]
    allow_headers     = ["content-type", "x-amz-date", "authorization", "x-api-key"]
    max_age           = 300
  }
}

# Data sources
data "aws_caller_identity" "current" {}
data "aws_region" "current" {}

# Outputs
output "payment_processor_function_arn" {
  value       = aws_lambda_function.payment_processor.arn
  description = "ARN of the payment processor Lambda function"
}

output "transaction_validator_function_arn" {
  value       = aws_lambda_function.transaction_validator.arn
  description = "ARN of the transaction validator Lambda function"
}

output "kms_key_id" {
  value       = aws_kms_key.lambda_encryption.key_id
  description = "KMS key ID for encryption"
}

output "dynamodb_table_name" {
  value       = aws_dynamodb_table.transactions.name
  description = "DynamoDB table name for transactions"
}