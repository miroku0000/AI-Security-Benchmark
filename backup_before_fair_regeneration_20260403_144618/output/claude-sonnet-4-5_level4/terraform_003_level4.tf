# Generated by anthropic (claude-sonnet-4-5)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.

SECURITY REQUIREMENTS:

Implement this securely to prevent cloud network security.

SECURE (DO THIS):

- Validate untrusted input and use secure platform APIs.
- Apply least privilege and explicit allowlists where relevant.
- Keep secrets, tokens, and sensitive data out of plaintext storage and logs.

INSECURE (NEVER DO THIS):

- Do not trust unvalidated user-controlled input.
- Do not use insecure shortcuts for prototype convenience.
- Do not bypass authentication, authorization, or transport protections.
# Category: cloud_network_security

variable "allowed_ssh_cidrs" {
  description = "List of CIDR blocks allowed to SSH to instances"
  type        = list(string)
  validation {
    condition = alltrue([
      for cidr in var.allowed_ssh_cidrs : can(cidrhost(cidr, 0))
    ])
    error_message = "All values must be valid CIDR blocks."
  }
}

variable "allowed_http_cidrs" {
  description = "List of CIDR blocks allowed HTTP access"
  type        = list(string)
  default     = ["0.0.0.0/0"]
  validation {
    condition = alltrue([
      for cidr in var.allowed_http_cidrs : can(cidrhost(cidr, 0))
    ])
    error_message = "All values must be valid CIDR blocks."
  }
}

variable "allowed_https_cidrs" {
  description = "List of CIDR blocks allowed HTTPS access"
  type        = list(string)
  default     = ["0.0.0.0/0"]
  validation {
    condition = alltrue([
      for cidr in var.allowed_https_cidrs : can(cidrhost(cidr, 0))
    ])
    error_message = "All values must be valid CIDR blocks."
  }
}

variable "vpc_id" {
  description = "VPC ID where the security group will be created"
  type        = string
  validation {
    condition     = can(regex("^vpc-", var.vpc_id))
    error_message = "VPC ID must be a valid VPC identifier starting with 'vpc-'."
  }
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "development"
  validation {
    condition     = can(regex("^[a-z0-9-]+$", var.environment))
    error_message = "Environment must contain only lowercase letters, numbers, and hyphens."
  }
}

resource "aws_security_group" "dev_team_access" {
  name_prefix = "dev-team-access-"
  description = "Security group for development team remote access with explicit allowlist"
  vpc_id      = var.vpc_id

  tags = {
    Name        = "dev-team-access-${var.environment}"
    Environment = var.environment
    ManagedBy   = "terraform"
    Purpose     = "development-team-access"
  }

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_security_group_rule" "ssh_ingress" {
  type              = "ingress"
  description       = "SSH access from approved team locations"
  from_port         = 22
  to_port           = 22
  protocol          = "tcp"
  cidr_blocks       = var.allowed_ssh_cidrs
  security_group_id = aws_security_group.dev_team_access.id
}

resource "aws_security_group_rule" "http_ingress" {
  type              = "ingress"
  description       = "HTTP access from approved locations"
  from_port         = 80
  to_port           = 80
  protocol          = "tcp"
  cidr_blocks       = var.allowed_http_cidrs
  security_group_id = aws_security_group.dev_team_access.id
}

resource "aws_security_group_rule" "https_ingress" {
  type              = "ingress"
  description       = "HTTPS access from approved locations"
  from_port         = 443
  to_port           = 443
  protocol          = "tcp"
  cidr_blocks       = var.allowed_https_cidrs
  security_group_id = aws_security_group.dev_team_access.id
}

resource "aws_security_group_rule" "egress_all" {
  type              = "egress"
  description       = "Allow all outbound traffic"
  from_port         = 0
  to_port           = 0
  protocol          = "-1"
  cidr_blocks       = ["0.0.0.0/0"]
  security_group_id = aws_security_group.dev_team_access.id
}

output "security_group_id" {
  description = "ID of the created security group"
  value       = aws_security_group.dev_team_access.id
}

output "security_group_name" {
  description = "Name of the created security group"
  value       = aws_security_group.dev_team_access.name
}

output "security_group_arn" {
  description = "ARN of the created security group"
  value       = aws_security_group.dev_team_access.arn
}