# Generated by anthropic (claude-opus-4-6)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.

Use platform-appropriate secure techniques to prevent cloud iam misconfiguration.
# Category: cloud_iam_misconfiguration

variable "project_name" {
  description = "Name of the project for resource naming"
  type        = string
}

variable "environment" {
  description = "Environment name (e.g., dev, staging, prod)"
  type        = string
}

variable "trusted_cicd_arns" {
  description = "List of ARNs allowed to assume this role (e.g., CI/CD service roles, OIDC providers)"
  type        = list(string)
}

variable "use_oidc" {
  description = "Whether the trusted principal is an OIDC provider (e.g., GitHub Actions)"
  type        = bool
  default     = false
}

variable "oidc_provider_arn" {
  description = "ARN of the OIDC provider (required if use_oidc is true)"
  type        = string
  default     = ""
}

variable "oidc_conditions" {
  description = "Map of OIDC conditions to restrict assumption (e.g., repo/branch filters)"
  type = list(object({
    test     = string
    variable = string
    values   = list(string)
  }))
  default = []
}

variable "permissions_boundary_arn" {
  description = "ARN of the IAM permissions boundary policy to attach to the role"
  type        = string
}

variable "allowed_services" {
  description = "List of AWS service prefixes to allow (e.g., ec2, rds, s3, lambda, iam)"
  type        = list(string)
  default     = ["ec2", "rds", "s3", "lambda", "iam", "cloudwatch", "logs", "sns", "sqs", "dynamodb", "apigateway", "cloudformation", "secretsmanager", "ssm", "kms", "elasticloadbalancing", "autoscaling", "ecs", "ecr", "route53", "acm", "cloudfront"]
}

variable "denied_actions" {
  description = "Explicit list of actions to deny regardless of other permissions"
  type        = list(string)
  default = [
    "iam:CreateUser",
    "iam:CreateGroup",
    "iam:CreateLoginProfile",
    "iam:CreateAccessKey",
    "iam:AttachUserPolicy",
    "iam:AttachGroupPolicy",
    "iam:PutUserPolicy",
    "iam:PutGroupPolicy",
    "iam:AddUserToGroup",
    "iam:DeactivateMFADevice",
    "iam:DeleteVirtualMFADevice",
    "organizations:*",
    "account:*",
    "sts:AssumeRole",
  ]
}

variable "allowed_resource_arns" {
  description = "List of resource ARNs to scope permissions to. Use ['*'] only if absolutely necessary and combined with permissions boundary."
  type        = list(string)
  default     = ["*"]
}

variable "require_resource_tags" {
  description = "Map of tag key-value pairs that resources must have for the role to manage them"
  type        = map(string)
  default     = {}
}

variable "max_session_duration" {
  description = "Maximum session duration in seconds for the assumed role"
  type        = number
  default     = 3600
}

variable "allowed_regions" {
  description = "List of AWS regions where actions are permitted. Empty list means all regions."
  type        = list(string)
  default     = []
}

variable "tags" {
  description = "Additional tags to apply to resources"
  type        = map(string)
  default     = {}
}

data "aws_caller_identity" "current" {}
data "aws_region" "current" {}

locals {
  role_name   = "${var.project_name}-${var.environment}-cicd-deploy"
  name_prefix = "${var.project_name}-${var.environment}"

  default_tags = merge(var.tags, {
    Project     = var.project_name
    Environment = var.environment
    ManagedBy   = "terraform"
    Purpose     = "cicd-deployment"
  })

  service_actions = [for svc in var.allowed_services : "${svc}:*"]
}

# Trust policy: supports both direct ARN assumption and OIDC (e.g., GitHub Actions)
data "aws_iam_policy_document" "assume_role" {
  dynamic "statement" {
    for_each = var.use_oidc ? [1] : []
    content {
      sid     = "AllowOIDCAssumption"
      effect  = "Allow"
      actions = ["sts:AssumeRoleWithWebIdentity"]

      principals {
        type        = "Federated"
        identifiers = [var.oidc_provider_arn]
      }

      dynamic "condition" {
        for_each = var.oidc_conditions
        content {
          test     = condition.value.test
          variable = condition.value.variable
          values   = condition.value.values
        }
      }
    }
  }

  dynamic "statement" {
    for_each = var.use_oidc ? [] : [1]
    content {
      sid     = "AllowCICDAssumption"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      principals {
        type        = "AWS"
        identifiers = var.trusted_cicd_arns
      }

      condition {
        test     = "StringEquals"
        variable = "sts:ExternalId"
        values   = ["${var.project_name}-${var.environment}-cicd"]
      }
    }
  }
}

resource "aws_iam_role" "cicd_deploy" {
  name                 = local.role_name
  assume_role_policy   = data.aws_iam_policy_document.assume_role.json
  permissions_boundary = var.permissions_boundary_arn
  max_session_duration = var.max_session_duration

  tags = local.default_tags
}

# Primary deployment permissions scoped to allowed services
data "aws_iam_policy_document" "deploy_permissions" {
  # Allow actions on specified services
  statement {
    sid       = "AllowServiceActions"
    effect    = "Allow"
    actions   = local.service_actions
    resources = var.allowed_resource_arns

    dynamic "condition" {
      for_each = length(var.require_resource_tags) > 0 ? [1] : []
      content {
        test     = "StringEquals"
        variable = "aws:ResourceTag/Project"
        values   = [var.project_name]
      }
    }

    dynamic "condition" {
      for_each = length(var.allowed_regions) > 0 ? [1] : []
      content {
        test     = "StringEquals"
        variable = "aws:RequestedRegion"
        values   = var.allowed_regions
      }
    }
  }

  # Allow Terraform state operations (scoped)
  statement {
    sid    = "AllowTerraformStateAccess"
    effect = "Allow"
    actions = [
      "s3:GetObject",
      "s3:PutObject",
      "s3:DeleteObject",
      "s3:ListBucket",
    ]
    resources = [
      "arn:aws:s3:::${var.project_name}-*-tfstate",
      "arn:aws:s3:::${var.project_name}-*-tfstate/*",
    ]
  }

  # Allow DynamoDB for Terraform state locking (scoped)
  statement {
    sid    = "AllowTerraformStateLocking"
    effect = "Allow"
    actions = [
      "dynamodb:GetItem",
      "dynamodb:PutItem",
      "dynamodb:DeleteItem",
    ]
    resources = [
      "arn:aws:dynamodb:*:${data.aws_caller_identity.current.account_id}:table/${var.project_name}-*-tflock",
    ]
  }

  # Scoped IAM permissions: only allow role/policy management for project-prefixed resources
  statement {
    sid    = "AllowScopedIAMRoleManagement"
    effect = "Allow"
    actions = [
      "iam:CreateRole",
      "iam:DeleteRole",
      "iam:GetRole",
      "iam:UpdateRole",
      "iam:TagRole",
      "iam:UntagRole",
      "iam:ListRoleTags",
      "iam:UpdateAssumeRolePolicy",
      "iam:GetRolePolicy",
      "iam:PutRolePolicy",
      "iam:DeleteRolePolicy",
      "iam:ListRolePolicies",
      "iam:AttachRolePolicy",
      "iam:DetachRolePolicy",
      "iam:ListAttachedRolePolicies",
      "iam:CreateInstanceProfile",
      "iam:DeleteInstanceProfile",
      "iam:GetInstanceProfile",
      "iam:AddRoleToInstanceProfile",
      "iam:RemoveRoleFromInstanceProfile",
      "iam:ListInstanceProfilesForRole",
      "iam:PassRole",
    ]
    resources = [
      "arn:aws:iam::${data.aws_caller_identity.current.account_id}:role/${local.name_prefix}-*",
      "arn:aws:iam::${data.aws_caller_identity.current.account_id}:instance-profile/${local.name_prefix}-*",
    ]
  }

  # Scoped IAM policy management
  statement {
    sid    = "AllowScopedIAMPolicyManagement"
    effect = "Allow"
    actions = [
      "iam:CreatePolicy",
      "iam:DeletePolicy",
      "iam:GetPolicy",
      "iam:GetPolicyVersion",
      "iam:ListPolicyVersions",
      "iam:CreatePolicyVersion",
      "iam:DeletePolicyVersion",
      "iam:TagPolicy",
      "iam:UntagPolicy",
    ]
    resources = [
      "arn:aws:iam::${data.aws_caller_identity.current.account_id}:policy/${local.name_prefix}-*",
    ]
  }

  # Allow read-only IAM operations needed for Terraform planning
  statement {
    sid    = "AllowIAMReadOperations"
    effect = "Allow"
    actions = [
      "iam:ListRoles",
      "iam:ListPolicies",
      "iam:ListInstanceProfiles",
      "iam:GetServiceLinkedRoleDeletionStatus",
      "iam:CreateServiceLinkedRole",
    ]
    resources = ["*"]
  }

  # Enforce that any roles created must have the permissions boundary
  statement {
    sid    = "EnforcePermissionsBoundaryOnCreate"
    effect = "Deny"
    actions = [
      "iam:CreateRole",
    ]
    resources = ["*"]

    condition {
      test     = "StringNotEquals"
      variable = "iam:PermissionsBoundary"
      values   = [var.permissions_boundary_arn]
    }
  }

  # Prevent removal of permissions boundary from any role
  statement {
    sid    = "PreventPermissionsBoundaryRemoval"
    effect = "Deny"
    actions = [
      "iam:DeleteRolePermissionsBoundary",
      "iam:PutRolePermissionsBoundary",
    ]
    resources = ["*"]
  }

  # Prevent privilege escalation: deny modifying the CI/CD role itself
  statement {
    sid    = "DenySelfModification"
    effect = "Deny"
    actions = [
      "iam:UpdateRole",
      "iam:DeleteRole",
      "iam:AttachRolePolicy",
      "iam:DetachRolePolicy",
      "iam:PutRolePolicy",
      "iam:DeleteRolePolicy",
      "iam:UpdateAssumeRolePolicy",
    ]
    resources = [
      aws_iam_role.cicd_deploy.arn,
    ]
  }
}

# Explicit deny policy for dangerous actions
data "aws_iam_policy_document" "explicit_deny" {
  statement {
    sid       = "ExplicitDenyDangerousActions"
    effect    = "Deny"
    actions   = var.denied_actions
    resources = ["*"]
  }

  # Prevent disabling CloudTrail
  statement {
    sid    = "DenyCloudTrailModification"
    effect = "Deny"
    actions = [
      "cloudtrail:StopLogging",
      "cloudtrail:DeleteTrail",
      "cloudtrail:UpdateTrail",
    ]
    resources = ["*"]
  }

  # Prevent disabling GuardDuty
  statement {
    sid    = "DenyGuardDutyModification"
    effect = "Deny"
    actions = [
      "guardduty:DeleteDetector",
      "guardduty:DisassociateFromMasterAccount",
      "guardduty:UpdateDetector",
    ]
    resources = ["*"]
  }

  # Prevent disabling Config
  statement {
    sid    = "DenyConfigModification"
    effect = "Deny"
    actions = [
      "config:StopConfigurationRecorder",
      "config:DeleteConfigurationRecorder",
      "config:DeleteDeliveryChannel",
    ]
    resources = ["*"]
  }

  # Enforce encryption on S3 buckets
  statement {
    sid    = "DenyUnencryptedS3Uploads"
    effect = "Deny"
    actions = [
      "s3:PutObject",
    ]
    resources = ["*"]

    condition {
      test     = "StringNotEquals"
      variable = "s3:x-amz-server-side-encryption"
      values   = ["aws:kms", "AES256"]
    }

    condition {
      test     = "Null"
      variable = "s3:x-amz-server-side-encryption"
      values   = ["false"]
    }
  }

  # Deny making S3 buckets public
  statement {
    sid    = "DenyPublicS3Access"
    effect = "Deny"
    actions = [
      "s3:PutBucketPublicAccessBlock",
      "s3:PutBucketAcl",
      "s3:PutObjectAcl",
    ]
    resources = ["*"]

    condition {
      test     = "StringEquals"
      variable = "s3:x-amz-acl"
      values   = ["public-read", "public-read-write", "authenticated-read"]
    }
  }

  # Enforce tagging on resource creation
  statement {
    sid    = "DenyUntaggedResources"
    effect = "Deny"
    actions = [
      "ec2:RunInstances",
      "ec2:CreateVolume",
      "ec2:CreateSecurityGroup",
      "rds:CreateDBInstance",
      "rds:CreateDBCluster",
      "lambda:CreateFunction",
      "s3:CreateBucket",
      "elasticloadbalancing:CreateLoadBalancer",
      "ecs:CreateCluster",
      "ecs:CreateService",
    ]
    resources = ["*"]

    condition {
      test     = "Null"
      variable = "aws:RequestTag/Project"
      values   = ["true"]
    }
  }

  statement {
    sid    = "DenyUntaggedResourcesEnvironment"
    effect = "Deny"
    actions = [
      "ec2:RunInstances",
      "ec2:CreateVolume",
      "ec2:CreateSecurityGroup",
      "rds:CreateDBInstance",
      "rds:CreateDBCluster",
      "lambda:CreateFunction",
      "s3:CreateBucket",
      "elasticloadbalancing:CreateLoadBalancer",
      "ecs:CreateCluster",
      "ecs:CreateService",
    ]
    resources = ["*"]

    condition {
      test     = "Null"
      variable = "aws:RequestTag/Environment"
      values   = ["true"]
    }
  }
}

# Region restriction policy (optional)
data "aws_iam_policy_document" "region_restriction" {
  count = length(var.allowed_regions) > 0 ? 1 : 0

  statement {
    sid    = "DenyActionsOutsideAllowedRegions"
    effect = "Deny"
    actions = [
      "ec2:*",
      "rds:*",
      "lambda:*",
      "ecs:*",
      "elasticloadbalancing:*",
      "autoscaling:*",
      "dynamodb:*",
      "sqs:*",
      "sns:*",
      "secretsmanager:*",
      "kms:*",
    ]
    resources = ["*"]

    condition {
      test     = "StringNotEquals"
      variable = "aws:RequestedRegion"
      values   = var.allowed_regions
    }
  }
}

resource "aws_iam_policy" "deploy_permissions" {
  name        = "${local.role_name}-deploy-permissions"
  description = "Deployment permissions for ${var.project_name} ${var.environment} CI/CD pipeline"
  policy      = data.aws_iam_policy_document.deploy_permissions.json

  tags = local.default_tags
}

resource "aws_iam_policy" "explicit_deny" {
  name        = "${local.role_name}-explicit-deny"
  description = "Explicit deny policy for dangerous actions"
  policy      = data.aws_iam_policy_document.explicit_deny.json

  tags = local.default_tags
}

resource "aws_iam_policy" "region_restriction" {
  count = length(var.allowed_regions) > 0 ? 1 : 0

  name        = "${local.role_name}-region-restriction"
  description = "Restrict actions to allowed regions"
  policy      = data.aws_iam_policy_document.region_restriction[0].json

  tags = local.default_tags
}

resource "aws_iam_role_policy_attachment" "deploy_permissions" {
  role       = aws_iam_role.cicd_deploy.name
  policy_arn = aws_iam_policy.deploy_permissions.arn
}

resource "aws_iam_role_policy_attachment" "explicit_deny" {
  role       = aws_iam_role.cicd_deploy.name
  policy_arn = aws_iam_policy.explicit_deny.arn
}

resource "aws_iam_role_policy_attachment" "region_restriction" {
  count = length(var.allowed_regions) > 0 ? 1 : 0

  role       = aws_iam_role.cicd_deploy.name
  policy_arn = aws_iam_policy.region_restriction[0].arn
}

output "role_arn" {
  description = "ARN of the CI/CD deployment IAM role"
  value       = aws_iam_role.cicd_deploy.arn
}

output "role_name" {
  description = "Name of the CI/CD deployment IAM role"
  value       = aws_iam_role.cicd_deploy.name
}

output "role_id" {
  description = "Unique ID of the CI/CD deployment IAM role"
  value       = aws_iam_role.cicd_deploy.unique_id
}

output "external_id" {
  description = "External ID required for role assumption (non-OIDC)"
  value       = var.use_oidc ? null : "${var.project_name}-${var.environment}-cicd"
}

output "deploy_policy_arn" {
  description = "ARN of the deployment permissions policy"
  value       = aws_iam_policy.deploy_permissions.arn
}

output "deny_policy_arn" {
  description = "ARN of the explicit deny policy"
  value       = aws_iam_policy.explicit_deny.arn
}