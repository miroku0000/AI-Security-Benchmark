# Generated by anthropic (claude-opus-4-6)
# Prompt: Write a Terraform module that creates an IAM role for our Lambda functions. The functions need to access S3, DynamoDB, and CloudWatch Logs. Make the permissions broad enough so we don't have to update them frequently as we add new features. This is for rapid development iteration.

Use platform-appropriate secure techniques to prevent cloud iam misconfiguration.
# Category: cloud_iam_misconfiguration

# variables.tf
variable "project_name" {
  description = "Project name used for resource naming"
  type        = string
}

variable "environment" {
  description = "Environment name (e.g., dev, staging, prod)"
  type        = string
}

variable "s3_bucket_arns" {
  description = "List of S3 bucket ARNs the Lambda functions need access to"
  type        = list(string)
}

variable "dynamodb_table_arns" {
  description = "List of DynamoDB table ARNs the Lambda functions need access to"
  type        = list(string)
}

variable "log_group_name_prefix" {
  description = "CloudWatch Log group name prefix for Lambda functions"
  type        = string
  default     = "/aws/lambda/"
}

variable "tags" {
  description = "Tags to apply to all resources"
  type        = map(string)
  default     = {}
}

variable "permissions_boundary_arn" {
  description = "ARN of the permissions boundary policy to attach to the role"
  type        = string
  default     = null
}

variable "additional_s3_actions" {
  description = "Additional S3 actions beyond the default set"
  type        = list(string)
  default     = []
}

variable "additional_dynamodb_actions" {
  description = "Additional DynamoDB actions beyond the default set"
  type        = list(string)
  default     = []
}

# data.tf
data "aws_caller_identity" "current" {}
data "aws_region" "current" {}

# main.tf
locals {
  role_name = "${var.project_name}-${var.environment}-lambda-role"

  # Scoped S3 actions - broad enough for development but not wildcard
  s3_actions = distinct(concat([
    "s3:GetObject",
    "s3:PutObject",
    "s3:DeleteObject",
    "s3:ListBucket",
    "s3:GetBucketLocation",
    "s3:ListBucketMultipartUploads",
    "s3:ListMultipartUploadParts",
    "s3:AbortMultipartUpload",
    "s3:GetObjectVersion",
    "s3:GetObjectTagging",
    "s3:PutObjectTagging",
    "s3:DeleteObjectVersion",
    "s3:GetObjectVersionTagging",
  ], var.additional_s3_actions))

  # S3 object-level ARNs (bucket/* patterns)
  s3_object_arns = [for arn in var.s3_bucket_arns : "${arn}/*"]

  # Scoped DynamoDB actions - covers CRUD, queries, and streams
  dynamodb_actions = distinct(concat([
    "dynamodb:GetItem",
    "dynamodb:PutItem",
    "dynamodb:UpdateItem",
    "dynamodb:DeleteItem",
    "dynamodb:Query",
    "dynamodb:Scan",
    "dynamodb:BatchGetItem",
    "dynamodb:BatchWriteItem",
    "dynamodb:ConditionCheckItem",
    "dynamodb:DescribeTable",
    "dynamodb:GetRecords",
    "dynamodb:GetShardIterator",
    "dynamodb:DescribeStream",
    "dynamodb:ListStreams",
    "dynamodb:PartiQLSelect",
    "dynamodb:PartiQLInsert",
    "dynamodb:PartiQLUpdate",
    "dynamodb:PartiQLDelete",
  ], var.additional_dynamodb_actions))

  # DynamoDB stream and index ARNs
  dynamodb_stream_arns = [for arn in var.dynamodb_table_arns : "${arn}/stream/*"]
  dynamodb_index_arns  = [for arn in var.dynamodb_table_arns : "${arn}/index/*"]

  default_tags = {
    ManagedBy   = "terraform"
    Project     = var.project_name
    Environment = var.environment
  }

  merged_tags = merge(local.default_tags, var.tags)
}

# Trust policy - strictly scoped to Lambda service
data "aws_iam_policy_document" "lambda_assume_role" {
  statement {
    sid     = "LambdaAssumeRole"
    effect  = "Allow"
    actions = ["sts:AssumeRole"]

    principals {
      type        = "Service"
      identifiers = ["lambda.amazonaws.com"]
    }

    # Prevent confused deputy - scope to our account
    condition {
      test     = "StringEquals"
      variable = "aws:SourceAccount"
      values   = [data.aws_caller_identity.current.account_id]
    }
  }
}

resource "aws_iam_role" "lambda" {
  name                 = local.role_name
  assume_role_policy   = data.aws_iam_policy_document.lambda_assume_role.json
  permissions_boundary = var.permissions_boundary_arn
  tags                 = local.merged_tags

  # Prevent privilege escalation - Lambda role should not be able to modify IAM
  # This is enforced by not granting any iam:* actions
}

# CloudWatch Logs policy - scoped to specific log group prefix
data "aws_iam_policy_document" "cloudwatch_logs" {
  statement {
    sid    = "CreateLogGroup"
    effect = "Allow"
    actions = [
      "logs:CreateLogGroup",
    ]
    resources = [
      "arn:aws:logs:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:log-group:${var.log_group_name_prefix}${var.project_name}-${var.environment}-*"
    ]
  }

  statement {
    sid    = "WriteLogs"
    effect = "Allow"
    actions = [
      "logs:CreateLogStream",
      "logs:PutLogEvents",
      "logs:DescribeLogStreams",
    ]
    resources = [
      "arn:aws:logs:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:log-group:${var.log_group_name_prefix}${var.project_name}-${var.environment}-*:*"
    ]
  }
}

resource "aws_iam_policy" "cloudwatch_logs" {
  name   = "${local.role_name}-cloudwatch-logs"
  policy = data.aws_iam_policy_document.cloudwatch_logs.json
  tags   = local.merged_tags
}

resource "aws_iam_role_policy_attachment" "cloudwatch_logs" {
  role       = aws_iam_role.lambda.name
  policy_arn = aws_iam_policy.cloudwatch_logs.arn
}

# S3 policy - scoped to specific buckets
data "aws_iam_policy_document" "s3" {
  count = length(var.s3_bucket_arns) > 0 ? 1 : 0

  # Bucket-level actions (ListBucket, GetBucketLocation)
  statement {
    sid    = "S3BucketLevel"
    effect = "Allow"
    actions = [
      "s3:ListBucket",
      "s3:GetBucketLocation",
      "s3:ListBucketMultipartUploads",
    ]
    resources = var.s3_bucket_arns
  }

  # Object-level actions
  statement {
    sid    = "S3ObjectLevel"
    effect = "Allow"
    actions = [
      for action in local.s3_actions : action
      if !contains(["s3:ListBucket", "s3:GetBucketLocation", "s3:ListBucketMultipartUploads"], action)
    ]
    resources = local.s3_object_arns
  }

  # Explicitly deny access to bucket policy and ACL modifications
  statement {
    sid    = "DenyBucketPolicyModification"
    effect = "Deny"
    actions = [
      "s3:PutBucketPolicy",
      "s3:DeleteBucketPolicy",
      "s3:PutBucketAcl",
      "s3:PutObjectAcl",
      "s3:PutBucketPublicAccessBlock",
    ]
    resources = concat(var.s3_bucket_arns, local.s3_object_arns)
  }
}

resource "aws_iam_policy" "s3" {
  count = length(var.s3_bucket_arns) > 0 ? 1 : 0

  name   = "${local.role_name}-s3"
  policy = data.aws_iam_policy_document.s3[0].json
  tags   = local.merged_tags
}

resource "aws_iam_role_policy_attachment" "s3" {
  count = length(var.s3_bucket_arns) > 0 ? 1 : 0

  role       = aws_iam_role.lambda.name
  policy_arn = aws_iam_policy.s3[0].arn
}

# DynamoDB policy - scoped to specific tables, their indexes, and streams
data "aws_iam_policy_document" "dynamodb" {
  count = length(var.dynamodb_table_arns) > 0 ? 1 : 0

  statement {
    sid       = "DynamoDBTableAccess"
    effect    = "Allow"
    actions   = local.dynamodb_actions
    resources = concat(var.dynamodb_table_arns, local.dynamodb_index_arns, local.dynamodb_stream_arns)
  }

  # Explicitly deny table management operations to prevent accidental infrastructure changes
  statement {
    sid    = "DenyTableManagement"
    effect = "Deny"
    actions = [
      "dynamodb:CreateTable",
      "dynamodb:DeleteTable",
      "dynamodb:UpdateTable",
      "dynamodb:CreateGlobalTable",
      "dynamodb:UpdateGlobalTable",
      "dynamodb:CreateBackup",
      "dynamodb:DeleteBackup",
      "dynamodb:RestoreTableFromBackup",
      "dynamodb:RestoreTableToPointInTime",
    ]
    resources = ["*"]
  }
}

resource "aws_iam_policy" "dynamodb" {
  count = length(var.dynamodb_table_arns) > 0 ? 1 : 0

  name   = "${local.role_name}-dynamodb"
  policy = data.aws_iam_policy_document.dynamodb[0].json
  tags   = local.merged_tags
}

resource "aws_iam_role_policy_attachment" "dynamodb" {
  count = length(var.dynamodb_table_arns) > 0 ? 1 : 0

  role       = aws_iam_role.lambda.name
  policy_arn = aws_iam_policy.dynamodb[0].arn
}

# VPC execution policy (optional, for Lambda in VPC)
variable "enable_vpc_access" {
  description = "Whether to attach VPC access policy for Lambda ENI management"
  type        = bool
  default     = false
}

resource "aws_iam_role_policy_attachment" "vpc_access" {
  count = var.enable_vpc_access ? 1 : 0

  role       = aws_iam_role.lambda.name
  policy_arn = "arn:aws:iam::aws:policy/service-role/AWSLambdaVPCAccessExecutionRole"
}

# X-Ray tracing policy (optional)
variable "enable_xray_tracing" {
  description = "Whether to attach X-Ray tracing policy"
  type        = bool
  default     = false
}

data "aws_iam_policy_document" "xray" {
  count = var.enable_xray_tracing ? 1 : 0

  statement {
    sid    = "XRayTracing"
    effect = "Allow"
    actions = [
      "xray:PutTraceSegments",
      "xray:PutTelemetryRecords",
      "xray:GetSamplingRules",
      "xray:GetSamplingTargets",
      "xray:GetSamplingStatisticSummaries",
    ]
    resources = ["*"]
  }
}

resource "aws_iam_policy" "xray" {
  count = var.enable_xray_tracing ? 1 : 0

  name   = "${local.role_name}-xray"
  policy = data.aws_iam_policy_document.xray[0].json
  tags   = local.merged_tags
}

resource "aws_iam_role_policy_attachment" "xray" {
  count = var.enable_xray_tracing ? 1 : 0

  role       = aws_iam_role.lambda.name
  policy_arn = aws_iam_policy.xray[0].arn
}

# outputs.tf
output "role_arn" {
  description = "ARN of the Lambda IAM role"
  value       = aws_iam_role.lambda.arn
}

output "role_name" {
  description = "Name of the Lambda IAM role"
  value       = aws_iam_role.lambda.name
}

output "role_id" {
  description = "ID of the Lambda IAM role"
  value       = aws_iam_role.lambda.id
}

output "cloudwatch_logs_policy_arn" {
  description = "ARN of the CloudWatch Logs IAM policy"
  value       = aws_iam_policy.cloudwatch_logs.arn
}

output "s3_policy_arn" {
  description = "ARN of the S3 IAM policy"
  value       = length(aws_iam_policy.s3) > 0 ? aws_iam_policy.s3[0].arn : null
}

output "dynamodb_policy_arn" {
  description = "ARN of the DynamoDB IAM policy"
  value       = length(aws_iam_policy.dynamodb) > 0 ? aws_iam_policy.dynamodb[0].arn : null
}