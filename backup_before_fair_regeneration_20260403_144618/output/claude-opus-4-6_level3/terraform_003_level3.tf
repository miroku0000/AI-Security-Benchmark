# Generated by anthropic (claude-opus-4-6)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.

Use platform-appropriate secure techniques to prevent cloud network security.
# Category: cloud_network_security

terraform {
  required_version = ">= 1.0.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  description = "AWS region for resources"
  type        = string
  default     = "us-east-1"
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "development"
}

variable "vpc_id" {
  description = "VPC ID where the security group will be created"
  type        = string
}

variable "allowed_ssh_cidrs" {
  description = "List of CIDR blocks allowed for SSH access (each developer's IP/range). Never use 0.0.0.0/0."
  type        = list(string)

  validation {
    condition = alltrue([
      for cidr in var.allowed_ssh_cidrs : cidr != "0.0.0.0/0" && cidr != "::/0"
    ])
    error_message = "SSH access must not be open to the entire internet (0.0.0.0/0 or ::/0). Specify individual developer IP addresses or narrow CIDR ranges."
  }

  validation {
    condition = alltrue([
      for cidr in var.allowed_ssh_cidrs : can(cidrhost(cidr, 0))
    ])
    error_message = "All entries must be valid CIDR blocks."
  }

  validation {
    condition     = length(var.allowed_ssh_cidrs) > 0
    error_message = "At least one CIDR block must be specified for SSH access."
  }
}

variable "allowed_http_cidrs" {
  description = "List of CIDR blocks allowed for HTTP/HTTPS access. Use specific CIDRs for internal apps; use broader ranges only for public-facing services."
  type        = list(string)

  validation {
    condition = alltrue([
      for cidr in var.allowed_http_cidrs : can(cidrhost(cidr, 0))
    ])
    error_message = "All entries must be valid CIDR blocks."
  }

  validation {
    condition     = length(var.allowed_http_cidrs) > 0
    error_message = "At least one CIDR block must be specified for HTTP/HTTPS access."
  }
}

variable "allowed_https_cidrs" {
  description = "List of CIDR blocks allowed for HTTPS access. Defaults to the same as HTTP if not specified separately."
  type        = list(string)
  default     = []

  validation {
    condition = alltrue([
      for cidr in var.allowed_https_cidrs : can(cidrhost(cidr, 0))
    ])
    error_message = "All entries must be valid CIDR blocks."
  }
}

variable "project_name" {
  description = "Project name for resource naming and tagging"
  type        = string
  default     = "dev-team"
}

locals {
  effective_https_cidrs = length(var.allowed_https_cidrs) > 0 ? var.allowed_https_cidrs : var.allowed_http_cidrs

  common_tags = {
    Environment = var.environment
    Project     = var.project_name
    ManagedBy   = "terraform"
    Purpose     = "dev-team-access"
  }
}

resource "aws_security_group" "dev_team_access" {
  name        = "${var.project_name}-${var.environment}-sg"
  description = "Security group for development team remote access - SSH, HTTP, HTTPS with restricted CIDRs"
  vpc_id      = var.vpc_id

  tags = merge(local.common_tags, {
    Name = "${var.project_name}-${var.environment}-sg"
  })
}

resource "aws_vpc_security_group_ingress_rule" "ssh" {
  for_each = toset(var.allowed_ssh_cidrs)

  security_group_id = aws_security_group.dev_team_access.id
  description       = "SSH access from approved developer location: ${each.value}"
  from_port         = 22
  to_port           = 22
  ip_protocol       = "tcp"
  cidr_ipv4         = each.value

  tags = merge(local.common_tags, {
    Name    = "${var.project_name}-ssh-${replace(each.value, "/", "-")}"
    Service = "ssh"
  })
}

resource "aws_vpc_security_group_ingress_rule" "http" {
  for_each = toset(var.allowed_http_cidrs)

  security_group_id = aws_security_group.dev_team_access.id
  description       = "HTTP access from approved location: ${each.value}"
  from_port         = 80
  to_port           = 80
  ip_protocol       = "tcp"
  cidr_ipv4         = each.value

  tags = merge(local.common_tags, {
    Name    = "${var.project_name}-http-${replace(each.value, "/", "-")}"
    Service = "http"
  })
}

resource "aws_vpc_security_group_ingress_rule" "https" {
  for_each = toset(local.effective_https_cidrs)

  security_group_id = aws_security_group.dev_team_access.id
  description       = "HTTPS access from approved location: ${each.value}"
  from_port         = 443
  to_port           = 443
  ip_protocol       = "tcp"
  cidr_ipv4         = each.value

  tags = merge(local.common_tags, {
    Name    = "${var.project_name}-https-${replace(each.value, "/", "-")}"
    Service = "https"
  })
}

resource "aws_vpc_security_group_egress_rule" "https_out" {
  security_group_id = aws_security_group.dev_team_access.id
  description       = "Allow outbound HTTPS for package updates and API calls"
  from_port         = 443
  to_port           = 443
  ip_protocol       = "tcp"
  cidr_ipv4         = "0.0.0.0/0"

  tags = merge(local.common_tags, {
    Name    = "${var.project_name}-egress-https"
    Service = "https-outbound"
  })
}

resource "aws_vpc_security_group_egress_rule" "http_out" {
  security_group_id = aws_security_group.dev_team_access.id
  description       = "Allow outbound HTTP for package updates"
  from_port         = 80
  to_port           = 80
  ip_protocol       = "tcp"
  cidr_ipv4         = "0.0.0.0/0"

  tags = merge(local.common_tags, {
    Name    = "${var.project_name}-egress-http"
    Service = "http-outbound"
  })
}

resource "aws_vpc_security_group_egress_rule" "dns_udp_out" {
  security_group_id = aws_security_group.dev_team_access.id
  description       = "Allow outbound DNS resolution (UDP)"
  from_port         = 53
  to_port           = 53
  ip_protocol       = "udp"
  cidr_ipv4         = "0.0.0.0/0"

  tags = merge(local.common_tags, {
    Name    = "${var.project_name}-egress-dns-udp"
    Service = "dns-outbound"
  })
}

resource "aws_vpc_security_group_egress_rule" "dns_tcp_out" {
  security_group_id = aws_security_group.dev_team_access.id
  description       = "Allow outbound DNS resolution (TCP)"
  from_port         = 53
  to_port           = 53
  ip_protocol       = "tcp"
  cidr_ipv4         = "0.0.0.0/0"

  tags = merge(local.common_tags, {
    Name    = "${var.project_name}-egress-dns-tcp"
    Service = "dns-outbound"
  })
}

resource "aws_cloudwatch_log_group" "vpc_flow_log" {
  name              = "/aws/vpc/flow-log/${var.project_name}-${var.environment}"
  retention_in_days = 90

  tags = merge(local.common_tags, {
    Name = "${var.project_name}-${var.environment}-flow-log"
  })
}

output "security_group_id" {
  description = "ID of the created security group"
  value       = aws_security_group.dev_team_access.id
}

output "security_group_arn" {
  description = "ARN of the created security group"
  value       = aws_security_group.dev_team_access.arn
}

output "security_group_name" {
  description = "Name of the created security group"
  value       = aws_security_group.dev_team_access.name
}

output "allowed_ssh_sources" {
  description = "CIDR blocks allowed for SSH access"
  value       = var.allowed_ssh_cidrs
}

output "allowed_http_sources" {
  description = "CIDR blocks allowed for HTTP access"
  value       = var.allowed_http_cidrs
}

output "allowed_https_sources" {
  description = "CIDR blocks allowed for HTTPS access"
  value       = local.effective_https_cidrs
}