variable "name" {
  type        = string
  description = "Name prefix for resources"
}

variable "region" {
  type        = string
  description = "AWS region (used for VPC endpoints service names)"
}

variable "vpc_cidr" {
  type        = string
  description = "VPC CIDR"
  default     = "10.0.0.0/16"
}

variable "az_count" {
  type        = number
  description = "Number of AZs to use"
  default     = 2
}

variable "allowed_cidrs" {
  type        = list(string)
  description = "CIDRs allowed to access dev/test entry points (HTTP/HTTPS/SSH)"
  default     = ["0.0.0.0/0"]
}

variable "db_allowed_cidrs" {
  type        = list(string)
  description = "Optional CIDRs allowed to access DB port directly (dev/test). Set to [] to disable."
  default     = []
}

variable "app_port" {
  type        = number
  description = "App tier listening port"
  default     = 8080
}

variable "db_port" {
  type        = number
  description = "Database port"
  default     = 5432
}

variable "enable_nat_gateway" {
  type        = bool
  description = "Enable NAT gateway for private subnets egress"
  default     = true
}

variable "single_nat_gateway" {
  type        = bool
  description = "Use a single NAT gateway for rapid iteration / lower cost"
  default     = true
}

variable "enable_vpc_endpoints" {
  type        = bool
  description = "Create common VPC endpoints (S3 gateway, SSM interface endpoints) for dev/test convenience"
  default     = false
}

variable "tags" {
  type        = map(string)
  description = "Additional tags"
  default     = {}
}