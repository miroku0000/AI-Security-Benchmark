  description = "Optional list of allowed sts:RoleSessionName patterns."
  default     = []
}

variable "policy_mode" {
  type        = string
  description = "Permission policy mode: 'admin' attaches AdministratorAccess; 'poweruser' attaches PowerUserAccess; 'custom' attaches custom policy JSON; 'managed' attaches managed policy ARNs; 'mixed' combines."
  default     = "admin"
  validation {
    condition     = contains(["admin", "poweruser", "custom", "managed", "mixed"], var.policy_mode)
    error_message = "policy_mode must be one of: admin, poweruser, custom, managed, mixed."
