locals {
  assume_principals_aws = distinct(concat(
    var.trusted_principal_arns,
    [for id in var.trusted_account_ids : "arn:aws:iam::${id}:root"]
  ))

  assume_conditions = merge(
    var.external_id != null ? {
      StringEquals = {
        "sts:ExternalId" = var.external_id
      }
    } : {},
    length(var.allowed_session_name_patterns) > 0 ? {
      StringLike = {
        "sts:RoleSessionName" = var.allowed_session_name_patterns
      }
    } : {},
    var.require_mfa ? {
      Bool = {
        "aws:MultiFactorAuthPresent" = "true"
      }
    } : {}
  )

  attach_admin     = contains(["admin", "mixed"], var.policy_mode)
  attach_poweruser = contains(["poweruser", "mixed"], var.policy_mode)
  attach_managed   = contains(["managed", "mixed"], var.policy_mode) && length(var.managed_policy_arns) > 0
  attach_custom    = contains(["custom", "mixed"], var.policy_mode) && var.custom_policy_json != null

  passrole_resources = length(var.passrole_arns) > 0 ? var.passrole_arns : ["*"]
  kms_resources      = length(var.kms_key_arns) > 0 ? var.kms_key_arns : ["*"]
  secrets_resources  = length(var.secrets_arns) > 0 ? var.secrets_arns : ["*"]
  ssm_resources      = length(var.ssm_parameter_arns) > 0 ? var.ssm_parameter_arns : ["*"]
}

data "aws_iam_policy_document" "assume_role" {
  dynamic "statement" {
    for_each = length(local.assume_principals_aws) > 0 ? [1] : []
    content {
      sid     = "AssumeRoleAWSPrincipals"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]
      principals {
        type        = "AWS"
        identifiers = local.assume_principals_aws
      }
      dynamic "condition" {
        for_each = length(keys(local.assume_conditions)) > 0 ? [1] : []
        content {
          test     = keys(local.assume_conditions)[0]
          variable = ""
          values   = []
        }
      }
    }
  }

  dynamic "statement" {
    for_each = length(var.trusted_services) > 0 ? [1] : []
    content {
      sid     = "AssumeRoleServicePrincipals"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]
      principals {
        type        = "Service"
        identifiers = var.trusted_services
      }
    }
  }
}

data "aws_iam_policy_document" "assume_role_with_conditions" {
  source_policy_documents = [data.aws_iam_policy_document.assume_role.json]

  dynamic "statement" {
    for_each = length(local.assume_principals_aws) > 0 && length(keys(local.assume_conditions)) > 0 ? [1] : []
    content {
      sid     = "AssumeRoleAWSPrincipalsWithConditions"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]
      principals {
        type        = "AWS"
        identifiers = local.assume_principals_aws
      }

      dynamic "condition" {
        for_each = try(local.assume_conditions.StringEquals, null) != null ? [1] : []
        content {
          test     = "StringEquals"
          variable = "sts:ExternalId"
          values   = [local.assume_conditions.StringEquals["sts:ExternalId"]]
        }
      }

      dynamic "condition" {
        for_each = try(local.assume_conditions.StringLike, null) != null ? [1] : []
        content {
          test     = "StringLike"
          variable = "sts:RoleSessionName"
          values   = local.assume_conditions.StringLike["sts:RoleSessionName"]
        }
      }

      dynamic "condition" {
        for_each = try(local.assume_conditions.Bool, null) != null ? [1] : []
        content {
          test     = "Bool"
          variable = "aws:MultiFactorAuthPresent"
          values   = [local.assume_conditions.Bool["aws:MultiFactorAuthPresent"]]
        }
      }
    }
  }
}

resource "aws_iam_role" "this" {
  name                 = var.name
  path                 = var.path
  description          = var.description
  max_session_duration = var.max_session_duration
  assume_role_policy   = data.aws_iam_policy_document.assume_role_with_conditions.json
  permissions_boundary = var.permissions_boundary_arn
  tags                 = var.tags
}

resource "aws_iam_role_policy_attachment" "admin" {
  count      = local.attach_admin ? 1 : 0
  role       = aws_iam_role.this.name
  policy_arn = "arn:aws:iam::aws:policy/AdministratorAccess"
}

resource "aws_iam_role_policy_attachment" "poweruser" {
  count      = local.attach_poweruser ? 1 : 0
  role       = aws_iam_role.this.name
  policy_arn = "arn:aws:iam::aws:policy/PowerUserAccess"
}

resource "aws_iam_role_policy_attachment" "managed" {
  for_each   = local.attach_managed ? toset(var.managed_policy_arns) : toset([])
  role       = aws_iam_role.this.name
  policy_arn = each.value
}

data "aws_iam_policy_document" "custom" {
  count = local.attach_custom ? 1 : 0
  source_policy_documents = [
    var.custom_policy_json
  ]
}

resource "aws_iam_policy" "custom" {
  count       = local.attach_custom ? 1 : 0
  name_prefix = "${var.name}-custom-"
  path        = var.path
  policy      = data.aws_iam_policy_document.custom[0].json
  tags        = var.tags
}

resource "aws_iam_role_policy_attachment" "custom" {
  count      = local.attach_custom ? 1 : 0
  role       = aws_iam_role.this.name
  policy_arn = aws_iam_policy.custom[0].arn
}

data "aws_iam_policy_document" "baseline" {
  dynamic "statement" {
    for_each = var.allow_passrole ? [1] : []
    content {
      sid     = "AllowPassRole"
      effect  = "Allow"
      actions = ["iam:PassRole"]
      resources = local.passrole_resources

      dynamic "condition" {
        for_each = length(var.passrole_services) > 0 ? [1] : []
        content {
          test     = "StringEquals"
          variable = "iam:PassedToService"
          values   = var.passrole_services
        }
      }
    }
  }

  dynamic "statement" {
    for_each = var.allow_kms ? [1] : []
    content {
      sid    = "AllowKMS"
      effect = "Allow"
      actions = [
        "kms:Create*",
        "kms:Describe*",
        "kms:Enable*",
        "kms:List*",
        "kms:Put*",
        "kms:Update*",
        "kms:Revoke*",
        "kms:Disable*",
        "kms:Get*",
        "kms:Delete*",
        "kms:TagResource",
        "kms:UntagResource",
        "kms:ScheduleKeyDeletion",
        "kms:CancelKeyDeletion",
        "kms:Encrypt",
        "kms:Decrypt",
        "kms:ReEncrypt*",
        "kms:GenerateDataKey*"
      ]
      resources = local.kms_resources
    }
  }

  dynamic "statement" {
    for_each = var.allow_secretsmanager ? [1] : []
    content {
      sid    = "AllowSecretsManager"
      effect = "Allow"
      actions = [
        "secretsmanager:CreateSecret",
        "secretsmanager:DeleteSecret",
        "secretsmanager:DescribeSecret",
        "secretsmanager:GetResourcePolicy",
        "secretsmanager:GetSecretValue",
        "secretsmanager:ListSecrets",
        "secretsmanager:PutSecretValue",
        "secretsmanager:RestoreSecret",
        "secretsmanager:RotateSecret",
        "secretsmanager:TagResource",
        "secretsmanager:UntagResource",
        "secretsmanager:UpdateSecret",
        "secretsmanager:UpdateSecretVersionStage"
      ]
      resources = local.secrets_resources
    }
  }

  dynamic "statement" {
    for_each = var.allow_ssm ? [1] : []
    content {
      sid    = "AllowSSM"
      effect = "Allow"
      actions = [
        "ssm:Describe*",
        "ssm:Get*",
        "ssm:List*",
        "ssm:PutParameter",
        "ssm:DeleteParameter",
        "ssm:DeleteParameters",
        "ssm:AddTagsToResource",
        "ssm:RemoveTagsFromResource"
      ]
      resources = local.ssm_resources
    }
  }

  statement {
    sid    = "AllowReadAccountInfo"
    effect = "Allow"
    actions = [
      "sts:GetCallerIdentity",
      "iam:GetAccountSummary",
      "organizations:DescribeOrganization",
      "account:ListRegions"
    ]
