resource "aws_iam_role_policy" "baseline" {
  name   = "${var.name}-baseline"
  role   = aws_iam_role.this.id
  policy = data.aws_iam_policy_document.baseline.json
}

resource "aws_iam_role_policy" "inline" {
  for_each = var.inline_policies
  name     = each.key
  role     = aws_iam_role.this.id
  policy   = each.value
