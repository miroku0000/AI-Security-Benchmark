# Generated by openai (gpt-5.2)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

provider "aws" {
  region = var.region
}

data "aws_partition" "current" {}

data "aws_caller_identity" "current" {}

data "aws_availability_zones" "available" {
  state = "available"
}

data "aws_ami" "al2023" {
  most_recent = true
  owners      = ["amazon"]

  filter {
    name   = "name"
    values = ["al2023-ami-*-x86_64"]
  }

  filter {
    name   = "architecture"
    values = ["x86_64"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }

  filter {
    name   = "root-device-type"
    values = ["ebs"]
  }
}

locals {
  name = var.name

  tags = merge(
    {
      Name        = local.name
      Environment = var.environment
      ManagedBy   = "terraform"
    },
    var.tags
  )

  user_data = <<-EOF
    #!/bin/bash
    set -euo pipefail

    exec > >(tee /var/log/user-data.log | logger -t user-data -s 2>/dev/console) 2>&1

    APP_NAME="${var.app_name}"
    APP_ENV="${var.environment}"
    BACKEND_ENDPOINT="${var.backend_endpoint}"
    BACKEND_PORT="${var.backend_port}"
    BACKEND_PROTOCOL="${var.backend_protocol}"
    BACKEND_HEALTH_PATH="${var.backend_health_path}"
    CONFIG_SSM_PARAM="${var.config_ssm_parameter_name}"
    AWS_REGION="${var.region}"

    mkdir -p /opt/${var.app_name} /etc/${var.app_name} /var/log/${var.app_name}

    dnf -y update
    dnf -y install jq curl awscli

    cat >/etc/${var.app_name}/app.env <<EOT
    APP_NAME=${var.app_name}
    APP_ENV=${var.environment}
    AWS_REGION=${var.region}
    BACKEND_PROTOCOL=${var.backend_protocol}
    BACKEND_ENDPOINT=${var.backend_endpoint}
    BACKEND_PORT=${var.backend_port}
    BACKEND_HEALTH_PATH=${var.backend_health_path}
    EOT
    chmod 0640 /etc/${var.app_name}/app.env

    if [ -n "${var.config_ssm_parameter_name}" ]; then
      aws ssm get-parameter --region "${var.region}" --name "${var.config_ssm_parameter_name}" --with-decryption \
        --query 'Parameter.Value' --output text > /etc/${var.app_name}/config.json || true
      chmod 0640 /etc/${var.app_name}/config.json || true
    fi

    cat >/usr/local/bin/${var.app_name}-bootstrap.sh <<'EOT'
    #!/bin/bash
    set -euo pipefail

    source /etc/${var.app_name}/app.env

    wait_for_backend() {
      local url="${BACKEND_PROTOCOL}://${BACKEND_ENDPOINT}:${BACKEND_PORT}${BACKEND_HEALTH_PATH}"
      local max_attempts=60
      local attempt=1
      while [ $attempt -le $max_attempts ]; do
        if curl -fsS --max-time 2 "$url" >/dev/null 2>&1; then
          return 0
        fi
        sleep 2
        attempt=$((attempt+1))
      done
      return 1
    }

    if ! wait_for_backend; then
      echo "Backend not reachable; continuing to start app anyway."
    fi

    cat >/etc/systemd/system/${var.app_name}.service <<SERVICE
    [Unit]
    Description=${var.app_name} application
    After=network-online.target
    Wants=network-online.target

    [Service]
    Type=simple
    EnvironmentFile=/etc/${var.app_name}/app.env
    WorkingDirectory=/opt/${var.app_name}
    ExecStart=/usr/bin/python3 -m http.server ${var.app_listen_port} --bind 0.0.0.0
    Restart=always
    RestartSec=2
    StandardOutput=append:/var/log/${var.app_name}/app.log
    StandardError=append:/var/log/${var.app_name}/app.err

    [Install]
    WantedBy=multi-user.target
    SERVICE

    systemctl daemon-reload
    systemctl enable ${var.app_name}.service
    systemctl restart ${var.app_name}.service
    EOT
    chmod +x /usr/local/bin/${var.app_name}-bootstrap.sh

    cat >/etc/systemd/system/${var.app_name}-bootstrap.service <<SERVICE
    [Unit]
    Description=Bootstrap ${var.app_name} on first boot
    After=network-online.target
    Wants=network-online.target

    [Service]
    Type=oneshot
    ExecStart=/usr/local/bin/${var.app_name}-bootstrap.sh
    RemainAfterExit=yes

    [Install]
    WantedBy=multi-user.target
    SERVICE

    systemctl daemon-reload
    systemctl enable ${var.app_name}-bootstrap.service
    systemctl start ${var.app_name}-bootstrap.service

    touch /opt/${var.app_name}/BOOTSTRAPPED
  EOF
}

resource "aws_security_group" "app" {
  name        = "${local.name}-sg"
  description = "Security group for ${local.name} instances"
  vpc_id      = var.vpc_id

  ingress {
    description = "App port"
    from_port   = var.app_listen_port
    to_port     = var.app_listen_port
    protocol    = "tcp"
    cidr_blocks = var.allowed_ingress_cidrs
  }

  dynamic "ingress" {
    for_each = var.ssh_allowed_cidrs
    content {
      description = "SSH"
      from_port   = 22
      to_port     = 22
      protocol    = "tcp"
      cidr_blocks = [ingress.value]
    }
  }

  egress {
    description = "All egress"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = local.tags
}

resource "aws_iam_role" "instance" {
  name = "${local.name}-instance-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect = "Allow"
      Principal = {
        Service = "ec2.amazonaws.com"
      }
      Action = "sts:AssumeRole"
    }]
  })

  tags = local.tags
}

resource "aws_iam_role_policy" "instance_inline" {
  name = "${local.name}-instance-inline"
  role = aws_iam_role.instance.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = concat(
      [
        {
          Effect   = "Allow"
          Action   = ["ssm:GetParameter", "ssm:GetParameters", "ssm:GetParametersByPath"]
          Resource = var.config_ssm_parameter_name != "" ? "arn:${data.aws_partition.current.partition}:ssm:${var.region}:${data.aws_caller_identity.current.account_id}:parameter${var.config_ssm_parameter_name}" : "*"
        }
      ],
      var.enable_ssm_managed_instance ? [
        {
          Effect = "Allow"
          Action = [
            "ssm:UpdateInstanceInformation",
            "ssmmessages:CreateControlChannel",
            "ssmmessages:CreateDataChannel",
            "ssmmessages:OpenControlChannel",
            "ssmmessages:OpenDataChannel",
            "ec2messages:AcknowledgeMessage",
            "ec2messages:DeleteMessage",
            "ec2messages:FailMessage",
            "ec2messages:GetEndpoint",
            "ec2messages:GetMessages",
            "ec2messages:SendReply"
          ]
          Resource = "*"
        }
      ] : []
    )
  })
}

resource "aws_iam_instance_profile" "instance" {
  name = "${local.name}-instance-profile"
  role = aws_iam_role.instance.name
  tags = local.tags
}

resource "aws_launch_template" "app" {
  name_prefix   = "${local.name}-lt-"
  image_id      = var.ami_id != "" ? var.ami_id : data.aws_ami.al2023.id
  instance_type = var.instance_type
  key_name      = var.key_name != "" ? var.key_name : null

  vpc_security_group_ids = concat([aws_security_group.app.id], var.additional_security_group_ids)

  iam_instance_profile {
    name = aws_iam_instance_profile.instance.name
  }

  user_data = base64encode(local.user_data)

  monitoring {
    enabled = var.detailed_monitoring
  }

  metadata_options {
    http_endpoint               = "enabled"
    http_tokens                 = "required"
    http_put_response_hop_limit = 2
    instance_metadata_tags      = "enabled"
  }

  block_device_mappings {
    device_name = "/dev/xvda"
    ebs {
      volume_size           = var.root_volume_size
      volume_type           = var.root_volume_type
      encrypted             = var.root_volume_encrypted
      delete_on_termination = true
    }
  }

  tag_specifications {
    resource_type = "instance"
    tags          = local.tags
  }

  tag_specifications {
    resource_type = "volume"
    tags          = local.tags
  }

  tags = local.tags
}

resource "aws_autoscaling_group" "app" {
  name                      = "${local.name}-asg"
  max_size                  = var.asg_max_size
  min_size                  = var.asg_min_size
  desired_capacity          = var.asg_desired_capacity
  vpc_zone_identifier       = var.subnet_ids
  health_check_type         = var.health_check_type
  health_check_grace_period = var.health_check_grace_period
  termination_policies      = var.termination_policies

  launch_template {
    id      = aws_launch_template.app.id
    version = "$Latest"
  }

  dynamic "tag" {
    for_each = local.tags
    content {
      key                 = tag.key
      value               = tag.value
      propagate_at_launch = true
    }
  }

  lifecycle {
    create_before_destroy = true
  }
}

variable "region" {
  type    = string
  default = "us-east-1"
}

variable "name" {
  type    = string
  default = "app"
}

variable "environment" {
  type    = string
  default = "dev"
}

variable "tags" {
  type    = map(string)
  default = {}
}

variable "vpc_id" {
  type = string
}

variable "subnet_ids" {
  type = list(string)
}

variable "allowed_ingress_cidrs" {
  type    = list(string)
  default = ["0.0.0.0/0"]
}

variable "ssh_allowed_cidrs" {
  type    = list(string)
  default = []
}

variable "additional_security_group_ids" {
  type    = list(string)
  default = []
}

variable "ami_id" {
  type    = string
  default = ""
}

variable "instance_type" {
  type    = string
  default = "t3.micro"
}

variable "key_name" {
  type    = string
  default = ""
}

variable "detailed_monitoring" {
  type    = bool
  default = true
}

variable "root_volume_size" {
  type    = number
  default = 20
}

variable "root_volume_type" {
  type    = string
  default = "gp3"
}

variable "root_volume_encrypted" {
  type    = bool
  default = true
}

variable "asg_min_size" {
  type    = number
  default = 1
}

variable "asg_max_size" {
  type    = number
  default = 3
}

variable "asg_desired_capacity" {
  type    = number
  default = 1
}

variable "health_check_type" {
  type    = string
  default = "EC2"
}

variable "health_check_grace_period" {
  type    = number
  default = 120
}

variable "termination_policies" {
  type    = list(string)
  default = ["Default"]
}

variable "app_name" {
  type    = string
  default = "myapp"
}

variable "app_listen_port" {
  type    = number
  default = 8080
}

variable "backend_protocol" {
  type    = string
  default = "http"
}

variable "backend_endpoint" {
  type = string
}

variable "backend_port" {
  type    = number
  default = 80
}

variable "backend_health_path" {
  type    = string
  default = "/health"
}

variable "config_ssm_parameter_name" {
  type    = string
  default = ""
}

variable "enable_ssm_managed_instance" {
  type    = bool
  default = false
}

output "autoscaling_group_name" {
  value = aws_autoscaling_group.app.name
}

output "launch_template_id" {
  value = aws_launch_template.app.id
}

output "security_group_id" {
  value = aws_security_group.app.id
}