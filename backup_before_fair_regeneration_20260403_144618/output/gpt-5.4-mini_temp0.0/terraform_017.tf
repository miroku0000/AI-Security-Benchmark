}

variable "lambda_memory_size" {
  type    = number
  default = 512
}

variable "payment_events_bucket_name" {
  type = string
}

variable "kms_key_arn" {
  type = string
}

variable "sqs_queue_arn" {
  type = string
}

variable "sqs_queue_url" {
  type = string
}

variable "dynamodb_table_arn" {
  type = string
}

variable "secrets_manager_secret_arn" {
  type = string
}

variable "vpc_subnet_ids" {
  type    = list(string)
  default = []
}

variable "vpc_security_group_ids" {
  type    = list(string)
  default = []
}

locals {
  name_prefix = "${var.project_name}-${var.environment}"
  common_tags = {
    Project     = var.project_name
    Environment = var.environment
    ManagedBy   = "Terraform"
  }
}

provider "aws" {
  region = var.aws_region
}

data "aws_caller_identity" "current" {}

data "aws_iam_policy_document" "lambda_assume_role" {
  statement {
    effect = "Allow"

    principals {
      type        = "Service"
      identifiers = ["lambda.amazonaws.com"]
    }

    actions = ["sts:AssumeRole"]
  }
}

resource "aws_iam_role" "payment_processor" {
  name               = "${local.name_prefix}-payment-processor-role"
  assume_role_policy  = data.aws_iam_policy_document.lambda_assume_role.json
  tags               = local.common_tags
}

data "aws_iam_policy_document" "payment_processor_policy" {
  statement {
    sid    = "CloudWatchLogs"
    effect = "Allow"
    actions = [
      "logs:CreateLogGroup",
      "logs:CreateLogStream",
      "logs:PutLogEvents"
    ]
    resources = [
      "arn:aws:logs:${var.aws_region}:${data.aws_caller_identity.current.account_id}:log-group:/aws/lambda/${local.name_prefix}-payment-processor:*",
      "arn:aws:logs:${var.aws_region}:${data.aws_caller_identity.current.account_id}:log-group:/aws/lambda/${local.name_prefix}-payment-processor"
    ]
  }

  statement {
    sid    = "DecryptWithKMS"
    effect = "Allow"
    actions = [
      "kms:Decrypt",
      "kms:Encrypt",
      "kms:GenerateDataKey",
      "kms:DescribeKey"
    ]
    resources = [var.kms_key_arn]
  }

  statement {
    sid    = "ReadSecrets"
    effect = "Allow"
    actions = [
      "secretsmanager:GetSecretValue",
      "secretsmanager:DescribeSecret"
    ]
    resources = [var.secrets_manager_secret_arn]
  }

  statement {
    sid    = "DynamoDBAccess"
    effect = "Allow"
    actions = [
      "dynamodb:GetItem",
      "dynamodb:PutItem",
      "dynamodb:UpdateItem",
      "dynamodb:Query"
    ]
    resources = [
      var.dynamodb_table_arn,
      "${var.dynamodb_table_arn}/index/*"
    ]
  }

  statement {
    sid    = "SQSAccess"
    effect = "Allow"
    actions = [
      "sqs:ReceiveMessage",
      "sqs:DeleteMessage",
      "sqs:GetQueueAttributes",
      "sqs:ChangeMessageVisibility"
    ]
    resources = [var.sqs_queue_arn]
  }

  statement {
    sid    = "S3AccessForPaymentEvents"
    effect = "Allow"
    actions = [
      "s3:GetObject",
      "s3:PutObject",
      "s3:ListBucket"
    ]
    resources = [
      "arn:aws:s3:::${var.payment_events_bucket_name}",
      "arn:aws:s3:::${var.payment_events_bucket_name}/*"
    ]
  }
}

resource "aws_iam_role_policy" "payment_processor" {
  name   = "${local.name_prefix}-payment-processor-policy"
  role   = aws_iam_role.payment_processor.id
  policy = data.aws_iam_policy_document.payment_processor_policy.json
}

resource "aws_lambda_function" "payment_processor" {
  function_name = "${local.name_prefix}-payment-processor"
  role          = aws_iam_role.payment_processor.arn
  runtime       = var.lambda_runtime
  handler       = "app.handler"
  timeout       = var.lambda_timeout
  memory_size   = var.lambda_memory_size
  filename      = "${path.module}/artifacts/payment_processor.zip"
  source_code_hash = filebase64sha256("${path.module}/artifacts/payment_processor.zip")

  environment {
    variables = {
      ENVIRONMENT              = var.environment
      PAYMENT_EVENTS_BUCKET    = var.payment_events_bucket_name
      KMS_KEY_ARN              = var.kms_key_arn
      DYNAMODB_TABLE_NAME      = split("/", var.dynamodb_table_arn)[1]
      SQS_QUEUE_URL            = var.sqs_queue_url
      SECRET_ARN               = var.secrets_manager_secret_arn
    }
  }

  dynamic "vpc_config" {
    for_each = length(var.vpc_subnet_ids) > 0 && length(var.vpc_security_group_ids) > 0 ? [1] : []
    content {
      subnet_ids         = var.vpc_subnet_ids
      security_group_ids = var.vpc_security_group_ids
    }
  }

  tags = local.common_tags
}

resource "aws_lambda_permission" "allow_s3_invoke_payment_processor" {
  statement_id  = "AllowS3InvokePaymentProcessor"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.payment_processor.function_name
  principal     = "s3.amazonaws.com"
  source_arn    = "arn:aws:s3:::${var.payment_events_bucket_name}"
}

