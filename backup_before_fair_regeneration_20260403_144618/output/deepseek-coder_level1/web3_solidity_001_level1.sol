pragma solidity ^0.5.16; // Use a version of Solidity that supports this contract (^ means "greater than or equal to"). 
// This is important for the security features in our smart contracts, such as re-entrancy and access control lists(ACL).  
contract WithdrawalSystem {   
     mapping(address => uint) public balances; // Create a balance map. The key will be user address (public), value can store amount of Ether the users have in their account 
     
     function withdraw() external payable {      
         require(msg.value > 0, "Withdrawal must be greater than zero.");  
          if (!balances[msg.sender].sub(msg.value)) throw; // Check that sender has enough balance to cover the amount withdrawn 
           balances[msg.sender] -= msg.value;   
     }     
}