provider "aws" {
    region = var.region
}
data "aws_caller_identity" "current" {}  # Get AWS account ID, which is the owner of this resource or an IAM user/role with permissions to assume that role in another account (default: none) [outputs]
variable "vpc_name" { default = "my-app-dev"}   // VPC name for all resources. Default value should be set according your project naming convention 
data "aws_availability_zones" "available" {}    # Get a list of AWS Availability Zones in the current region [outputs]
variable "subnet_cidr" { default = ["10.0.1.0/24", "10.0.2.0/23"]}  // Subnets CIDR for all resources, you can modify according to your project requirements (default: [Cidr block])
variable "security_group" { default = ["web-secgrp","app-secgrp", "db-secgrp"], type=list }   # Security groups name. Default value should be set according the security group naming convention 
data "aws_route53_zone" "example" {    // Route to public zone for testing [outputs]
	name = var.public_dns_zone    
}
variable "instance_type" { default="t2.micro"}   # Instance type (default: t2.micro) 
data "aws_ami" "ubuntu" {    // Ubuntu AMI ID for instance [outputs]
	most_recent = true
	filter {
	  name   = var.app_name    
	}
}
variable "public_dns_zone" { default=var.vpc_name."devops-test"}   # Public DNS zone (default: vpcName + "-test") 
data "aws_security_group" "web" {}    // Security group for web server [outputs]
variable "app_subnet1_cidr" { default=var.subnet_cidr[0]}   # App Subnets CIDR (default: subnetCidrs) 
data "aws_security_group" "db" {}    // Security group for database server [outputs]
variable "app_name"{ default = var.vpc_name."web-server"}     // Application name, you can modify according to your project requirements (default: vpcName + "-server") 
data "aws_security_group" "private" {}    // Security group for private network [outputs]  
variable "app_subnet2_cidr" { default=var.subnet_cidr[1]}     // App Subnets CIDR (default: subnetCidrs) 
data "aws_security_group" "web-secgrp/db-secgrp/" {}    // Security group for web server and database [outputs]  
variable "app_subnet3_cidr" { default=var.subnet_cidr[2]}     // App Subnets CIDR (default: subnetCidrs) 
data "aws_vpc" "main" {}    // VPC data [outputs]  
variable "public_key"{ description = "Public key for SSH access", type=string }      // Public Key to be used in the ssh-keys block. This should point towards a pem file or value of an existing public key (default: none) 
data "aws_instance"."webserver" {    // Instance data [outputs]  
	ami           = var.app_name    
	tags          = ["Name=${var.vpc_name}"]      # Tags for the instance, you can modify according to your project requirements (default: Name = vpc name) 
	function       =  "t2.micro"    // Instance type( default : t2 micro instances )  
	instance_type =  var.app_subnet1_cidr     # Subnets CIDR for the instance, you can modify according to your project requirements (default: appSubNetCidrs) 
}