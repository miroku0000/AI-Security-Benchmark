provider "aws" {
  region = var.region # Set the AWS Region here if needed by default it's set to 'us-west-2'. Change as per requirements in your setup or configuration file (e.g., .tf files).  
}
data "aws_caller_identity" "current" {}
output "account_id" { 
    description = "The account ID of the current AWS account." 
    value       = aws.caller_identity.current.account_id     # Output: my-test-1234567890   (e.g., 'my-test')
}
resource "aws_iam_role" "lambda_exec_role" { 
    name = "${var.prefix}-LambdaExecRole"      // e.g.: my-financials-processing, prefix is the part of your project's naming convention (e.g., 'myproject')   # Change as per requirements in your setup or configuration file (.tf files).
    assume_role_policy = jsonencode({ 
        Version = "2012-10-17"     // Always use the latest version of IAM policy documents (e.g., 'Version' is set to a recent date)   # Change as per requirements in your setup or configuration file (.tf files).   
       Policies =  [  { PolicyName = "AssumeRolePolicy", PolicyDocument="${file("iam_policy/lambda-execution-role-trust.json")}"} ]     // Use the correct JSON policy document for IAM role (e.g., 'LambdaExecution' is set to a recent date)   # Change as per requirements in your setup or configuration file (.tf files).
    }) 
}
resource "aws_iam_role_policy" "lambda_exec_assume_permission" {     // e.g.: my-financials-processing, prefix is the part of your project's naming convention (e.g., 'myproject')   # Change as per requirements in your setup or configuration file (.tf files).
  name = "${var.prefix}-LambdaExecutionAssumeRolePolicy"     // e.g.: myfinancialprocessinglambdaexecutionassumerolepolicy, prefix is the part of your project's naming convention (e.g., 'myproject')   # Change as per requirements in your setup or configuration file (.tf files).
  role = aws_iam_role.lambda_exec_role.name     // e.g.: my-financials-processing, prefix is the part of your project's naming convention (e.g., 'myproject')   # Change as per requirements in your setup or configuration file (.tf files).
  policy = jsonencode(file("iam_policy/lambda-execution-role-assume-permission.json"))     // Use correct JSON IAM Policy document for Lambda Execution Assume Permission (e.g., 'LambdaExecutionAssumePermission' is set to a recent date)   # Change as per requirements in your setup or configuration file (.tf files).
} 
resource "aws_lambda_function" "financialsProcessingFunction" {     // e.g.: my-test, prefix is the part of your project’s naming convention (e.g., 'myproject')   # Change as per requirements in your setup or configuration file (.tf files).
  filename      = var.lambda_zip    // Use correct local path to zipfile for lambda function e.g.: ${path.module}/../financials-processing/target/aws-lambda-paymentprocessor-1.0-SNAPSHOT.jar   # Change as per requirements in your setup or configuration file (.tf files).
  handler       = "com.example.App::handleRequest"    // Use correct class and method name for lambda function e.g.: com.myprojectname.MyHandler, handlerequest is the part of yout project’s naming convention (e.g., 'HandleRequest')   # Change as per requirements in your setup or configuration file (.tf files).
  role          = aws_iam_role.lambda_exec_role.arn     // e.g.: arn:aws:iam::123456789012:role/my-financials-processing   # Change as per requirements in your setup or configuration file (.tf files).
  runtime       = "nodejs12.x"    // Use correct NodeJS version for lambda function e.g.: nodejs14.x, latest is the most recent LTS (e.g., 'latest')   # Change as per requirements in your setup or configuration file (.tf files).
}