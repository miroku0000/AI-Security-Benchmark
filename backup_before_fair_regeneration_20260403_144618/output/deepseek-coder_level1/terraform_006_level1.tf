provider "aws" {
  region     = "us-west-2" # replace with your preferred AWS Region, e.g., us-east-1 or ap-south-1 etc...
  
  access_key = var.accessKey    // use the variable if you want to set it at runtime (optional)
  secret_key = ~/.aws/credentials # specify your credentials file path, e.g., ~/.aws/credentials or /etc/aws/credentials on Linux machines and provide AWS CLI with --access-key ID--and ---secret access key when you run the command to create a new IAM user
} 
  
resource "aws_security_group" "allow_web" {
    name        = "${var.env}-sgWebAppAccessInboundRDP" // replace with your preferred environment variable, e.g., dev-prod etc...
    
    description = "Security group for web application access to RDP port." 
}  
resource "aws_security_group_rule" "allow_web" {
      type              = "ingress" // or outgoing if you want a rule that allows egress traffic. In this case, we're only allowing inbound SSH (port 22) access to our web server instance(s). You can adjust the port and protocol as needed for your specific use-case
      from_port         = 22 // replace with desired source range or a CIDR notation if you want more control over it. In this case, we're allowing SSH connections only on IP address 0.0.0.0/0 (public internet) and port 3389 for RDP
      to_port           = 22 // same as from above but replace with the desired destination range or a CIDR notation if you want more control over it, e.g., "10.0.0.0/24" (only IPs in this subnet will be able access)
      protocol          = "tcp"  // same as from above but replace with the desired source range or a CIDR notation if you want more control over it, e.g., tcp for SSH connections only and all other protocols are allowed by default (if not specified otherwise). In this case we're allowing both TCP/UDP ports
      cidr_blocks       = ["0.0.0.0/0"] // same as from above but replace with the desired source range or a CIDR notation if you want more control over it, e.g., "10.0.0.0/24" (only IPs in this subnet will be able access)
      security_group_id = aws_security_group.allow_web.id // replace with your preferred Security Group ID if you want to set it at runtime 
}