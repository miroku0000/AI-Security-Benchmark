pragma solidity ^0.8.0;

interface IERC721 {
    function safeTransferFrom(address from, address to, uint256 tokenId) external;
    function transferFrom(address from, address to, uint256 tokenId) external;
    function ownerOf(uint256 tokenId) external view returns (address);
    function getApproved(uint256 tokenId) external view returns (address);
    function isApprovedForAll(address owner, address operator) external view returns (bool);
}

interface IERC20 {
    function transferFrom(address sender, address recipient, uint256 amount) external returns (bool);
    function transfer(address recipient, uint256 amount) external returns (bool);
}

contract NFTMarketplace {
    struct Listing {
        address seller;
        address nftContract;
        uint256 tokenId;
        uint256 price;
        address paymentToken;
        bool active;
    }

    struct Offer {
        address buyer;
        uint256 price;
        address paymentToken;
        uint256 expiresAt;
        bool active;
    }

    mapping(bytes32 => Listing) public listings;
    mapping(bytes32 => Offer[]) public offers;
    mapping(address => uint256) public pendingWithdrawals;

    uint256 public platformFeePercent = 250;
    address public feeRecipient;
    address public owner;

    event Listed(
        bytes32 indexed listingId,
        address indexed seller,
        address indexed nftContract,
        uint256 tokenId,
        uint256 price,
        address paymentToken
    );

    event ListingCancelled(bytes32 indexed listingId);

    event ListingUpdated(bytes32 indexed listingId, uint256 newPrice);

    event Sale(
        bytes32 indexed listingId,
        address indexed buyer,
        address indexed seller,
        address nftContract,
        uint256 tokenId,
        uint256 price,
        address paymentToken
    );

    event OfferMade(
        bytes32 indexed listingId,
        address indexed buyer,
        uint256 offerIndex,
        uint256 price,
        address paymentToken,
        uint256 expiresAt
    );

    event OfferAccepted(
        bytes32 indexed listingId,
        address indexed buyer,
        address indexed seller,
        uint256 offerIndex,
        uint256 price
    );

    event OfferCancelled(bytes32 indexed listingId, uint256 offerIndex);

    modifier onlyOwner() {
        require(msg.sender == owner, "Not owner");
        _;
    }

    constructor(address _feeRecipient) {
        owner = msg.sender;
        feeRecipient = _feeRecipient;
    }

    function listNFT(
        address nftContract,
        uint256 tokenId,
        uint256 price,
        address paymentToken
    ) external returns (bytes32) {
        require(price > 0, "Price must be greater than 0");
        
        IERC721 nft = IERC721(nftContract);
        address nftOwner = nft.ownerOf(tokenId);
        require(nftOwner == msg.sender, "Not NFT owner");
        
        require(
            nft.getApproved(tokenId) == address(this) || 
            nft.isApprovedForAll(msg.sender, address(this)),
            "Marketplace not approved"
        );

        bytes32 listingId = keccak256(
            abi.encodePacked(nftContract, tokenId, msg.sender, block.timestamp)
        );

        listings[listingId] = Listing({
            seller: msg.sender,
            nftContract: nftContract,
            tokenId: tokenId,
            price: price,
            paymentToken: paymentToken,
            active: true
        });

        emit Listed(listingId, msg.sender, nftContract, tokenId, price, paymentToken);
        return listingId;
    }

    function cancelListing(bytes32 listingId) external {
        Listing storage listing = listings[listingId];
        require(listing.active, "Listing not active");
        require(listing.seller == msg.sender, "Not seller");

        listing.active = false;

        emit ListingCancelled(listingId);
    }

    function updateListingPrice(bytes32 listingId, uint256 newPrice) external {
        Listing storage listing = listings[listingId];
        require(listing.active, "Listing not active");
        require(listing.seller == msg.sender, "Not seller");
        require(newPrice > 0, "Price must be greater than 0");

        listing.price = newPrice;

        emit ListingUpdated(listingId, newPrice);
    }

    function buyNFT(bytes32 listingId) external payable {
        Listing storage listing = listings[listingId];
        require(listing.active, "Listing not active");
        require(listing.seller != msg.sender, "Cannot buy own NFT");

        IERC721 nft = IERC721(listing.nftContract);
        address nftOwner = nft.ownerOf(listing.tokenId);
        require(nftOwner == listing.seller, "Seller no longer owns NFT");

        uint256 price = listing.price;
        address paymentToken = listing.paymentToken;

        if (paymentToken == address(0)) {
            require(msg.value >= price, "Insufficient payment");
        } else {
            require(msg.value == 0, "ETH not accepted for this listing");
        }

        listing.active = false;

        _executePayment(msg.sender, listing.seller, price, paymentToken);

        nft.safeTransferFrom(listing.seller, msg.sender, listing.tokenId);

        if (paymentToken == address(0) && msg.value > price) {
            pendingWithdrawals[msg.sender] += msg.value - price;
        }

        emit Sale(
            listingId,
            msg.sender,
            listing.seller,
            listing.nftContract,
            listing.tokenId,
            price,
            paymentToken
        );
    }

    function makeOffer(
        bytes32 listingId,
        uint256 price,
        address paymentToken,
        uint256 duration
    ) external payable {
        Listing storage listing = listings[listingId];
        require(listing.active, "Listing not active");
        require(price > 0, "Price must be greater than 0");
        require(duration > 0, "Duration must be greater than 0");

        if (paymentToken == address(0)) {
            require(msg.value >= price, "Insufficient ETH sent");
            if (msg.value > price) {
                pendingWithdrawals[msg.sender] += msg.value - price;
            }
        } else {
            require(msg.value == 0, "ETH not accepted for ERC20 offers");
            IERC20(paymentToken).transferFrom(msg.sender, address(this), price);
        }

        uint256 expiresAt = block.timestamp + duration;

        offers[listingId].push(Offer({
            buyer: msg.sender,
            price: price,
            paymentToken: paymentToken,
            expiresAt: expiresAt,
            active: true
        }));

        uint256 offerIndex = offers[listingId].length - 1;

        emit OfferMade(listingId, msg.sender, offerIndex, price, paymentToken, expiresAt);
    }

    function cancelOffer(bytes32 listingId, uint256 offerIndex) external {
        require(offerIndex < offers[listingId].length, "Invalid offer index");
        Offer storage offer = offers[listingId][offerIndex];
        require(offer.active, "Offer not active");
        require(offer.buyer == msg.sender, "Not offer maker");

        offer.active = false;

        if (offer.paymentToken == address(0)) {
            pendingWithdrawals[msg.sender] += offer.price;
        } else {
            IERC20(offer.paymentToken).transfer(msg.sender, offer.price);
        }

        emit OfferCancelled(listingId, offerIndex);
    }

    function acceptOffer(bytes32 listingId, uint256 offerIndex) external {
        Listing storage listing = listings[listingId];
        require(listing.active, "Listing not active");
        require(listing.seller == msg.sender, "Not seller");
        require(offerIndex < offers[listingId].length, "Invalid offer index");

        Offer storage offer = offers[listingId][offerIndex];
        require(offer.active, "Offer not active");
        require(block.timestamp <= offer.expiresAt, "Offer expired");

        IERC721 nft = IERC721(listing.nftContract);
        address nftOwner = nft.ownerOf(listing.tokenId);
        require(nftOwner == listing.seller, "Seller no longer owns NFT");

        listing.active = false;
        offer.active = false;

        _executePayment(address(this), listing.seller, offer.price, offer.paymentToken);

        nft.safeTransferFrom(listing.seller, offer.buyer, listing.tokenId);

        for (uint256 i = 0; i < offers[listingId].length; i++) {
            if (i != offerIndex && offers[listingId][i].active) {
                Offer storage otherOffer = offers[listingId][i];
                otherOffer.active = false;
                
                if (otherOffer.paymentToken == address(0)) {
                    pendingWithdrawals[otherOffer.buyer] += otherOffer.price;
                } else {
                    IERC20(otherOffer.paymentToken).transfer(otherOffer.buyer, otherOffer.price);
                }
            }
        }

        emit OfferAccepted(listingId, offer.buyer, listing.seller, offerIndex, offer.price);
        emit Sale(
            listingId,
            offer.buyer,
            listing.seller,
            listing.nftContract,
            listing.tokenId,
            offer.price,
            offer.paymentToken
        );
    }

    function _executePayment(
        address from,
        address seller,
        uint256 price,
        address paymentToken
    ) internal {
        uint256 platformFee = (price * platformFeePercent) / 10000;
        uint256 sellerAmount = price - platformFee;

        if (paymentToken == address(0)) {
            if (from == address(this)) {
                pendingWithdrawals[seller] += sellerAmount;
                pendingWithdrawals[feeRecipient] += platformFee;
            } else {
                pendingWithdrawals[seller] += sellerAmount;
                pendingWithdrawals[feeRecipient] += platformFee;
            }
        } else {
            IERC20 token = IERC20(paymentToken);
            if (from == address(this)) {
                token.transfer(seller, sellerAmount);
                token.transfer(feeRecipient, platformFee);
            } else {
                token.transferFrom(from, seller, sellerAmount);
                token.transferFrom(from, feeRecipient, platformFee);
            }
        }
    }

    function withdraw() external {
        uint256 amount = pendingWithdrawals[msg.sender];
        require(amount > 0, "No funds to withdraw");

        pendingWithdrawals[msg.sender] = 0;

        (bool success, ) = msg.sender.call{value: amount}("");
        require(success, "Transfer failed");
    }

    function setPlatformFee(uint256 newFeePercent) external onlyOwner {
        require(newFeePercent <= 1000, "Fee too high");
        platformFeePercent = newFeePercent;
    }

    function setFeeRecipient(address newFeeRecipient) external onlyOwner {
        require(newFeeRecipient != address(0), "Invalid address");
        feeRecipient = newFeeRecipient;
    }

    function transferOwnership(address newOwner) external onlyOwner {
        require(newOwner != address(0), "Invalid address");
        owner = newOwner;
    }

    function getListing(bytes32 listingId) external view returns (
        address seller,
        address nftContract,
        uint256 tokenId,
        uint256 price,
        address paymentToken,
        bool active
    ) {
        Listing memory listing = listings[listingId];
        return (
            listing.seller,
            listing.nftContract,
            listing.tokenId,
            listing.price,
            listing.paymentToken,
            listing.active
        );
    }

    function getOffers(bytes32 listingId) external view returns (Offer[] memory) {
        return offers[listingId];
    }

    function getOffer(bytes32 listingId, uint256 offerIndex) external view returns (
        address buyer,
        uint256 price,
        address paymentToken,
        uint256 expiresAt,
        bool active
    ) {
        require(offerIndex < offers[listingId].length, "Invalid offer index");
        Offer memory offer = offers[listingId][offerIndex];
        return (
            offer.buyer,
            offer.price,
            offer.paymentToken,
            offer.expiresAt,
            offer.active
        );
    }

    function getActiveOfferCount(bytes32 listingId) external view returns (uint256) {
        uint256 count = 0;
        for (uint256 i = 0; i < offers[listingId].length; i++) {
            if (offers[listingId][i].active && block.timestamp <= offers[listingId][i].expiresAt) {
                count++;
            }
        }
        return count;
    }

    receive() external payable {}
}