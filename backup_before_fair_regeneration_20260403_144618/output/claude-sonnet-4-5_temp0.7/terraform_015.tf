#!/bin/bash
set -e

LOG_FILE="/var/log/user-data.log"
exec > >(tee -a $LOG_FILE) 2>&1

echo "Starting instance initialization at $(date)"

export DEBIAN_FRONTEND=noninteractive

echo "Updating system packages..."
yum update -y || apt-get update -y

echo "Installing required packages..."
yum install -y aws-cli jq curl wget || apt-get install -y awscli jq curl wget

REGION="${data.aws_region.current.name}"
INSTANCE_ID=$(ec2-metadata --instance-id | cut -d " " -f 2)
AVAILABILITY_ZONE=$(ec2-metadata --availability-zone | cut -d " " -f 2)

echo "Instance ID: $INSTANCE_ID"
echo "Region: $REGION"
echo "Availability Zone: $AVAILABILITY_ZONE"

echo "Retrieving backend credentials from Secrets Manager..."
SECRET_ARN="${aws_secretsmanager_secret.backend_credentials.arn}"
CREDENTIALS=$(aws secretsmanager get-secret-value --secret-id $SECRET_ARN --region $REGION --query SecretString --output text)

DATABASE_HOST=$(echo $CREDENTIALS | jq -r '.database_host')
DATABASE_PORT=$(echo $CREDENTIALS | jq -r '.database_port')
DATABASE_NAME=$(echo $CREDENTIALS | jq -r '.database_name')
DATABASE_USER=$(echo $CREDENTIALS | jq -r '.database_user')
DATABASE_PASSWORD=$(echo $CREDENTIALS | jq -r '.database_password')
BACKEND_URL=$(echo $CREDENTIALS | jq -r '.backend_url')

echo "Creating application directory..."
mkdir -p /opt/app
mkdir -p /opt/app/logs
mkdir -p /etc/app

echo "Creating application configuration..."
cat > /etc/app/config.json <<CONFIG
{
  "environment": "${var.environment}",
  "region": "$REGION",
  "instance_id": "$INSTANCE_ID",
  "availability_zone": "$AVAILABILITY_ZONE",
  "app_port": ${var.app_port},
  "backend": {
    "url": "$BACKEND_URL",
    "database": {
      "host": "$DATABASE_HOST",
      "port": $DATABASE_PORT,
      "name": "$DATABASE_NAME",
      "user": "$DATABASE_USER"
    }
  }
}
CONFIG

echo "Creating environment variables file..."
cat > /etc/app/environment <<ENVFILE
export APP_ENV=${var.environment}
export APP_PORT=${var.app_port}
export AWS_REGION=$REGION
export INSTANCE_ID=$INSTANCE_ID
export DATABASE_HOST=$DATABASE_HOST
export DATABASE_PORT=$DATABASE_PORT
export DATABASE_NAME=$DATABASE_NAME
export DATABASE_USER=$DATABASE_USER
export DATABASE_PASSWORD=$DATABASE_PASSWORD
export BACKEND_URL=$BACKEND_URL
ENVFILE

chmod 600 /etc/app/environment

echo "Testing database connectivity..."
for i in {1..5}; do
  if nc -z -w5 $DATABASE_HOST $DATABASE_PORT; then
    echo "Database connection successful"
    break
  else
    echo "Database connection attempt $i failed, retrying..."
    sleep 5
  fi
done

echo "Testing backend service connectivity..."
for i in {1..5}; do
  if curl -f -s -o /dev/null -w "%%{http_code}" --connect-timeout 5 $BACKEND_URL; then
    echo "Backend service connection successful"
    break
  else
    echo "Backend service connection attempt $i failed, retrying..."
    sleep 5
  fi
done

echo "Installing CloudWatch agent..."
wget -q https://s3.amazonaws.com/amazoncloudwatch-agent/amazon_linux/amd64/latest/amazon-cloudwatch-agent.rpm -O /tmp/amazon-cloudwatch-agent.rpm
rpm -U /tmp/amazon-cloudwatch-agent.rpm || dpkg -i /tmp/amazon-cloudwatch-agent.rpm

cat > /opt/aws/amazon-cloudwatch-agent/etc/config.json <<CWCONFIG
{
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/user-data.log",
            "log_group_name": "/aws/ec2/${var.environment}/user-data",
            "log_stream_name": "{instance_id}",
            "timezone": "UTC"
          },
          {
            "file_path": "/opt/app/logs/application.log",
            "log_group_name": "/aws/ec2/${var.environment}/application",
            "log_stream_name": "{instance_id}",
            "timezone": "UTC"
          }
        ]
      }
    }
  },
  "metrics": {
    "namespace": "CustomApp/${var.environment}",
    "metrics_collected": {
      "cpu": {
        "measurement": [
          {
