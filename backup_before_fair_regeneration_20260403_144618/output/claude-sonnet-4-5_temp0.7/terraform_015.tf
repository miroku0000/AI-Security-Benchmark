from flask import Flask, jsonify
import subprocess

app = Flask(__name__)

@app.route('/health')
def health():
    try:
        result = subprocess.run(['/opt/app/health_check.sh'], capture_output=True, timeout=5)
        if result.returncode == 0:
            return jsonify({"status": "healthy"}), 200
        else:
            return jsonify({"status": "unhealthy"}), 503
    except Exception as e:
