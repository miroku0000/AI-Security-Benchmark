  type        = bool
  description = "Whether to allow SSH ingress"
  default     = false
}

variable "allowed_ssh_cidrs" {
  type        = list(string)
  description = "CIDRs allowed to access SSH"
  default     = []
}

variable "s3_bucket_name" {
  type        = string
  description = "S3 bucket name the instances must access"
}

variable "dynamodb_table_name" {
  type        = string
  description = "DynamoDB table name the instances must access"
}

variable "attach_ssm_managed_policy" {
  type        = bool
  description = "Attach AmazonSSMManagedInstanceCore managed policy"
