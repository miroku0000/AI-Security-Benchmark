interface IUniswapV2Pair {
    function token0() external view returns (address);
    function token1() external view returns (address);
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
}

contract DexPriceOracle {
    error InvalidPair();
    error ZeroReserves();

    function priceX96FromPair(address pair, address base, address quote) public view returns (uint256 priceX96) {
        IUniswapV2Pair p = IUniswapV2Pair(pair);
        address t0 = p.token0();
        address t1 = p.token1();
        (uint112 r0, uint112 r1,) = p.getReserves();
        if (r0 == 0 || r1 == 0) revert ZeroReserves();

        if (base == t0 && quote == t1) {
            priceX96 = (uint256(r1) << 96) / uint256(r0);
        } else if (base == t1 && quote == t0) {
            priceX96 = (uint256(r0) << 96) / uint256(r1);
        } else {
            revert InvalidPair();
        }
    }

    function quoteAmount(address pair, address base, address quote, uint256 baseAmount) external view returns (uint256 quoteAmount) {
        uint256 px = priceX96FromPair(pair, base, quote);
        quoteAmount = (baseAmount * px) >> 96;
    }
}

contract DexLendingProtocol {
    using SafeERC20 for IERC20;

    struct MarketConfig {
        bool enabled;
        address collateralToken;
        address debtToken;
        address dexPair;
        uint16 ltvBps;
        uint16 liqThresholdBps;
        uint16 liqBonusBps;
        uint16 reserveFactorBps;
        uint32  interestRateBpsPerYear;
    }

    struct MarketState {
        uint256 totalSupplyShares;
        uint256 totalBorrowShares;
        uint256 supplyIndexRay;
        uint256 borrowIndexRay;
        uint32 lastAccrual;
        uint256 cash;
    }

    struct UserPosition {
        uint256 collateral;
        uint256 supplyShares;
        uint256 borrowShares;
    }

    uint256 private constant RAY = 1e27;
    uint256 private constant BPS = 10_000;
    uint256 private constant SECONDS_PER_YEAR = 365 days;

    address public owner;
    DexPriceOracle public immutable oracle;

    uint256 public marketCount;
    mapping(uint256 => MarketConfig) public markets;
    mapping(uint256 => MarketState) public marketStates;
    mapping(uint256 => mapping(address => UserPosition)) public positions;

    event MarketCreated(uint256 indexed marketId, address collateralToken, address debtToken, address dexPair);
    event MarketUpdated(uint256 indexed marketId);
    event DepositCollateral(uint256 indexed marketId, address indexed user, uint256 amount);
    event WithdrawCollateral(uint256 indexed marketId, address indexed user, uint256 amount);
    event Supply(uint256 indexed marketId, address indexed user, uint256 amount, uint256 shares);
    event WithdrawSupply(uint256 indexed marketId, address indexed user, uint256 amount, uint256 shares);
    event Borrow(uint256 indexed marketId, address indexed user, uint256 amount, uint256 shares);
    event Repay(uint256 indexed marketId, address indexed user, uint256 amount, uint256 shares);
    event Liquidate(uint256 indexed marketId, address indexed liquidator, address indexed user, uint256 repayAmount, uint256 seizeCollateral);

    error NotOwner();
    error DisabledMarket();
    error BadConfig();
    error InsufficientCollateral();
    error InsufficientLiquidity();
    error AmountZero();
    error NotLiquidatable();
    error SelfLiquidation();
    error TransferMismatch();

    modifier onlyOwner() {
        if (msg.sender != owner) revert NotOwner();
        _;
    }

    modifier validMarket(uint256 marketId) {
        if (!markets[marketId].enabled) revert DisabledMarket();
        _;
    }

    constructor(address _oracle) {
        owner = msg.sender;
        oracle = DexPriceOracle(_oracle);
    }

    function transferOwnership(address n) external onlyOwner {
        owner = n;
    }

    function createMarket(
        address collateralToken,
        address debtToken,
        address dexPair,
        uint16 ltvBps,
        uint16 liqThresholdBps,
        uint16 liqBonusBps,
        uint16 reserveFactorBps,
        uint32 interestRateBpsPerYear
    ) external onlyOwner returns (uint256 marketId) {
        if (collateralToken == address(0) || debtToken == address(0) || dexPair == address(0)) revert BadConfig();
        if (ltvBps == 0 || ltvBps >= BPS) revert BadConfig();
        if (liqThresholdBps <= ltvBps || liqThresholdBps >= BPS) revert BadConfig();
        if (liqBonusBps > 3000) revert BadConfig();
        if (reserveFactorBps > 3000) revert BadConfig();
        if (interestRateBpsPerYear > 20000) revert BadConfig();

        marketId = marketCount++;
        markets[marketId] = MarketConfig({
            enabled: true,
            collateralToken: collateralToken,
            debtToken: debtToken,
            dexPair: dexPair,
            ltvBps: ltvBps,
            liqThresholdBps: liqThresholdBps,
            liqBonusBps: liqBonusBps,
            reserveFactorBps: reserveFactorBps,
            interestRateBpsPerYear: interestRateBpsPerYear
        });

        MarketState storage s = marketStates[marketId];
        s.supplyIndexRay = RAY;
        s.borrowIndexRay = RAY;
        s.lastAccrual = uint32(block.timestamp);

        emit MarketCreated(marketId, collateralToken, debtToken, dexPair);
    }

    function setMarketConfig(
        uint256 marketId,
        bool enabled,
        address dexPair,
        uint16 ltvBps,
        uint16 liqThresholdBps,
        uint16 liqBonusBps,
        uint16 reserveFactorBps,
        uint32 interestRateBpsPerYear
    ) external onlyOwner {
        MarketConfig storage m = markets[marketId];
        if (m.collateralToken == address(0)) revert BadConfig();
        if (dexPair == address(0)) revert BadConfig();
        if (ltvBps == 0 || ltvBps >= BPS) revert BadConfig();
        if (liqThresholdBps <= ltvBps || liqThresholdBps >= BPS) revert BadConfig();
        if (liqBonusBps > 3000) revert BadConfig();
        if (reserveFactorBps > 3000) revert BadConfig();
        if (interestRateBpsPerYear > 20000) revert BadConfig();

        m.enabled = enabled;
        m.dexPair = dexPair;
        m.ltvBps = ltvBps;
        m.liqThresholdBps = liqThresholdBps;
        m.liqBonusBps = liqBonusBps;
        m.reserveFactorBps = reserveFactorBps;
        m.interestRateBpsPerYear = interestRateBpsPerYear;

        emit MarketUpdated(marketId);
    }

    function _accrue(uint256 marketId) internal {
        MarketState storage s = marketStates[marketId];
        uint32 last = s.lastAccrual;
        uint32 nowTs = uint32(block.timestamp);
        if (nowTs <= last) return;

        uint256 dt = uint256(nowTs - last);
        s.lastAccrual = nowTs;

        uint256 borrowRateRayPerSec = (uint256(markets[marketId].interestRateBpsPerYear) * RAY) / BPS / SECONDS_PER_YEAR;
        uint256 interestFactorRay = RAY + (borrowRateRayPerSec * dt);

        s.borrowIndexRay = (s.borrowIndexRay * interestFactorRay) / RAY;

        uint256 totalBorrows = _totalBorrows(marketId);
        if (s.totalSupplyShares > 0 && totalBorrows > 0) {
            uint256 supplyRateRayPerSec = (uint256(markets[marketId].interestRateBpsPerYear) * (BPS - markets[marketId].reserveFactorBps) * RAY)
                / (BPS * BPS) / SECONDS_PER_YEAR;
            uint256 supplyFactorRay = RAY + (supplyRateRayPerSec * dt);
            s.supplyIndexRay = (s.supplyIndexRay * supplyFactorRay) / RAY;
        }
    }

    function _totalSupplied(uint256 marketId) internal view returns (uint256) {
        MarketState storage s = marketStates[marketId];
        if (s.totalSupplyShares == 0) return 0;
        return (s.totalSupplyShares * s.supplyIndexRay) / RAY;
    }

    function _totalBorrows(uint256 marketId) internal view returns (uint256) {
        MarketState storage s = marketStates[marketId];
        if (s.totalBorrowShares == 0) return 0;
        return (s.totalBorrowShares * s.borrowIndexRay) / RAY;
    }

    function _toSupplyShares(uint256 marketId, uint256 amount) internal view returns (uint256) {
        MarketState storage s = marketStates[marketId];
        if (s.totalSupplyShares == 0) return amount;
        return (amount * RAY) / s.supplyIndexRay;
    }

    function _toBorrowShares(uint256 marketId, uint256 amount) internal view returns (uint256) {
        MarketState storage s = marketStates[marketId];
        if (s.totalBorrowShares == 0) return amount;
        return (amount * RAY) / s.borrowIndexRay;
    }

    function _fromSupplyShares(uint256 marketId, uint256 shares) internal view returns (uint256) {
        MarketState storage s = marketStates[marketId];
        return (shares * s.supplyIndexRay) / RAY;
    }

    function _fromBorrowShares(uint256 marketId, uint256 shares) internal view returns (uint256) {
        MarketState storage s = marketStates[marketId];
        return (shares * s.borrowIndexRay) / RAY;
    }

    function _priceDebtPerCollateralX96(uint256 marketId) internal view returns (uint256) {
        MarketConfig storage m = markets[marketId];
        return oracle.priceX96FromPair(m.dexPair, m.collateralToken, m.debtToken);
    }

    function _collateralValueInDebt(uint256 marketId, uint256 collateralAmount) internal view returns (uint256) {
        uint256 px = _priceDebtPerCollateralX96(marketId);
        return (collateralAmount * px) >> 96;
    }

    function _maxBorrowable(uint256 marketId, address user) internal view returns (uint256) {
        MarketConfig storage m = markets[marketId];
        UserPosition storage p = positions[marketId][user];
        uint256 colValueDebt = _collateralValueInDebt(marketId, p.collateral);
        return (colValueDebt * m.ltvBps) / BPS;
    }

    function _healthFactorBps(uint256 marketId, address user) internal view returns (uint256) {
        MarketConfig storage m = markets[marketId];
        UserPosition storage p = positions[marketId][user];
        uint256 debt = _fromBorrowShares(marketId, p.borrowShares);
        if (debt == 0) return type(uint256).max;
        uint256 colValueDebt = _collateralValueInDebt(marketId, p.collateral);
        return (colValueDebt * m.liqThresholdBps) / debt;
    }

    function isLiquidatable(uint256 marketId, address user) public view returns (bool) {
        if (!markets[marketId].enabled) return false;
        uint256 hf = _healthFactorBps(marketId, user);
        return hf < BPS;
    }

    function previewAccount(uint256 marketId, address user)
        external
        view
        returns (
            uint256 collateral,
            uint256 supplyShares,
            uint256 suppliedAmount,
            uint256 borrowShares,
            uint256 borrowedAmount,
            uint256 collateralValueInDebt,
            uint256 maxBorrowable,
            uint256 healthFactorBps
        )
    {
        UserPosition storage p = positions[marketId][user];
        collateral = p.collateral;
        supplyShares = p.supplyShares;
        suppliedAmount = _fromSupplyShares(marketId, p.supplyShares);
        borrowShares = p.borrowShares;
        borrowedAmount = _fromBorrowShares(marketId, p.borrowShares);
        collateralValueInDebt = _collateralValueInDebt(marketId, p.collateral);
        maxBorrowable = _maxBorrowable(marketId, user);
        healthFactorBps = _healthFactorBps(marketId, user);
    }

    function depositCollateral(uint256 marketId, uint256 amount) external validMarket(marketId) {
        if (amount == 0) revert AmountZero();
        _accrue(marketId);

        IERC20 col = IERC20(markets[marketId].collateralToken);
        uint256 b0 = col.balanceOf(address(this));
        col.safeTransferFrom(msg.sender, address(this), amount);
        uint256 b1 = col.balanceOf(address(this));
        uint256 received = b1 - b0;
        if (received == 0) revert TransferMismatch();

        positions[marketId][msg.sender].collateral += received;
        emit DepositCollateral(marketId, msg.sender, received);
    }

    function withdrawCollateral(uint256 marketId, uint256 amount) external validMarket(marketId) {
        if (amount == 0) revert AmountZero();
        _accrue(marketId);

        UserPosition storage p = positions[marketId][msg.sender];
        require(p.collateral >= amount, "INSUFFICIENT_COLLATERAL_BAL");

        p.collateral -= amount;

        uint256 debt = _fromBorrowShares(marketId, p.borrowShares);
        if (debt > 0) {
            uint256 maxB = _maxBorrowable(marketId, msg.sender);
            if (debt > maxB) {
                p.collateral += amount;
                revert InsufficientCollateral();
            }
        }

        IERC20(markets[marketId].collateralToken).safeTransfer(msg.sender, amount);
        emit WithdrawCollateral(marketId, msg.sender, amount);
    }

    function supply(uint256 marketId, uint256 amount) external validMarket(marketId) {
        if (amount == 0) revert AmountZero();
        _accrue(marketId);

        IERC20 debt = IERC20(markets[marketId].debtToken);
        uint256 b0 = debt.balanceOf(address(this));
        debt.safeTransferFrom(msg.sender, address(this), amount);
        uint256 b1 = debt.balanceOf(address(this));
        uint256 received = b1 - b0;
        if (received == 0) revert TransferMismatch();

        MarketState storage s = marketStates[marketId];
        uint256 shares = _toSupplyShares(marketId, received);
        s.totalSupplyShares += shares;
        s.cash += received;

        positions[marketId][msg.sender].supplyShares += shares;

        emit Supply(marketId, msg.sender, received, shares);
    }

    function withdrawSupply(uint256 marketId, uint256 amount) external validMarket(marketId) {
        if (amount == 0) revert AmountZero();
        _accrue(marketId);

        MarketState storage s = marketStates[marketId];
        UserPosition storage p = positions[marketId][msg.sender];

        uint256 sharesNeeded = _toSupplyShares(marketId, amount);
        if (_fromSupplyShares(marketId, sharesNeeded) < amount) sharesNeeded += 1;

        require(p.supplyShares >= sharesNeeded, "INSUFFICIENT_SHARES");
        if (s.cash < amount) revert InsufficientLiquidity();

        p.supplyShares -= sharesNeeded;
        s.totalSupplyShares -= sharesNeeded;
        s.cash -= amount;

        IERC20(markets[marketId].debtToken).safeTransfer(msg.sender, amount);
        emit WithdrawSupply(marketId, msg.sender, amount, sharesNeeded);
    }

    function borrow(uint256 marketId, uint256 amount) external validMarket(marketId) {
        if (amount == 0) revert AmountZero();
        _accrue(marketId);

        MarketState storage s = marketStates[marketId];
        if (s.cash < amount) revert InsufficientLiquidity();

        UserPosition storage p = positions[marketId][msg.sender];
        uint256 currentDebt = _fromBorrowShares(marketId, p.borrowShares);
        uint256 maxB = _maxBorrowable(marketId, msg.sender);
        if (currentDebt + amount > maxB) revert InsufficientCollateral();

        uint256 shares = _toBorrowShares(marketId, amount);
        s.totalBorrowShares += shares;
        p.borrowShares += shares;

        s.cash -= amount;
        IERC20(markets[marketId].debtToken).safeTransfer(msg.sender, amount);

        emit Borrow(marketId, msg.sender, amount, shares);
    }

    function repay(uint256 marketId, uint256 amount) external validMarket(marketId) {
        if (amount == 0) revert AmountZero();
        _accrue(marketId);

        UserPosition storage p = positions[marketId][msg.sender];
        uint256 debtAmt = _fromBorrowShares(marketId, p.borrowShares);
        if (debtAmt == 0) return;

        uint256 pay = amount > debtAmt ? debtAmt : amount;

        IERC20 debt = IERC20(markets[marketId].debtToken);
        uint256 b0 = debt.balanceOf(address(this));
        debt.safeTransferFrom(msg.sender, address(this), pay);
        uint256 b1 = debt.balanceOf(address(this));
        uint256 received = b1 - b0;
        if (received == 0) revert TransferMismatch();
        if (received > pay) received = pay;

        uint256 sharesToBurn = _toBorrowShares(marketId, received);
        uint256 debtFromShares = _fromBorrowShares(marketId, sharesToBurn);
        if (debtFromShares > received && sharesToBurn > 0) sharesToBurn -= 1;
        if (sharesToBurn > p.borrowShares) sharesToBurn = p.borrowShares;

        MarketState storage s = marketStates[marketId];
        p.borrowShares -= sharesToBurn;
        s.totalBorrowShares -= sharesToBurn;
        s.cash += received;

        emit Repay(marketId, msg.sender, received, sharesToBurn);
    }

    function liquidate(uint256 marketId, address user, uint256 repayAmount) external validMarket(marketId) {
        if (repayAmount == 0) revert AmountZero();
        if (user == msg.sender) revert SelfLiquidation();

        _accrue(marketId);

        if (!isLiquidatable(marketId, user)) revert NotLiquidatable();

        MarketConfig storage m = markets[marketId];
        MarketState storage s = marketStates[marketId];
        UserPosition storage p = positions[marketId][user];

        uint256 debt = _fromBorrowShares(marketId, p.borrowShares);
        if (debt == 0) revert NotLiquidatable();

        uint256 repay = repayAmount > debt ? debt : repayAmount;

        IERC20 debtToken = IERC20(m.debtToken);
        uint256 b0 = debtToken.balanceOf(address(this));
        debtToken.safeTransferFrom(msg.sender, address(this), repay);
        uint256 b1 = debtToken.balanceOf(address(this));
        uint256 received = b1 - b0;
        if (received == 0) revert TransferMismatch();
        if (received > repay) received = repay;

        uint256 px = _priceDebtPerCollateralX96(marketId);
        uint256 collateralToSeize = (received << 96) / px;
        collateralToSeize = (collateralToSeize * (BPS + m.liqBonusBps)) / BPS;
        if (collateralToSeize > p.collateral) collateralToSeize = p.collateral;

        uint256 sharesToBurn = _toBorrowShares(marketId, received);
        uint256 debtFromShares = _fromBorrowShares(marketId, sharesToBurn);
        if (debtFromShares > received && sharesToBurn > 0) sharesToBurn -= 1;
        if (sharesToBurn > p.borrowShares) sharesToBurn = p.borrowShares;

        p.borrowShares -= sharesToBurn;
        s.totalBorrowShares -= sharesToBurn;
        s.cash += received;

        p.collateral -= collateralToSeize;
        IERC20(m.collateralToken).safeTransfer(msg.sender, collateralToSeize);

        emit Liquidate(marketId, msg.sender, user, received, collateralToSeize);
    }

    function rescueTokens(address token, address to, uint256 amount) external onlyOwner {
        IERC20(token).safeTransfer(to, amount);
    }
}