resource "aws_iam_role_policy_attachment" "app_s3_attach" {
  role       = aws_iam_role.app_s3_role.name
  policy_arn = aws_iam_policy.app_s3_policy.arn
}

provider "aws" {
  alias  = "replica"
  region = var.replica_region
}

resource "aws_s3_bucket" "documents_replica" {
  count         = var.enable_replication ? 1 : 0
  provider      = aws.replica
  bucket        = coalesce(var.replica_bucket_name, "${var.bucket_name}-replica")
  force_destroy = var.force_destroy

  tags = {
    Application = var.app_name
    Purpose     = "critical-business-documents-replica"
