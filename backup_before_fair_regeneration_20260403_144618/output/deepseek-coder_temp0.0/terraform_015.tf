provider "aws" {
  region = var.region // Set your AWS Region here, e.g., us-west-2 or ap-south-1 etc... (default is set in the provider block)
}
data "aws_ami" "ubuntu" {
  most_recent = true
  
  filter {
    name   = "name"
    values = ["ubuntu/images/*ubuntu-xenial-16.04.*"] # Ubuntu Xenial Server version, adjust as per your requirement (default is set in the data block)
  }
}
resource "aws_instance" "example" {
  
  ami           = aws_ami.ubuntu.id // Set AMI ID here based on above filter criteria or default will be used if not specified, adjust as per your requirement (default is set in the resource block)
   
  instance_type = var.instanceType // Instance type to use for this example - e.g., t2.micro OR desired ASG size etc...(required and must match with auto-scaling group settings), default will be used if not specified, adjust as per your requirement (default is set in the resource block)
  
  key_name = var.keyName // Name of an existing EC2 KeyPair to enable SSH access to this instance - e.g., myKey or desired name etc...(required and must match with auto-scaling group settings), default will be used if not specified, adjust as per your requirement (default is set in the resource block)
  
  user_data = <<EOF // User data script to run on instance boot - e.g., file("user_data/installation") OR desired content etc...(required and must match with auto-scaling group settings), default will be used if not specified, adjust as per your requirement (default is set in the resource block)
    #!/usr/bin/bash