            "Principal": {
                "Service": ["lambda.amazonaws.com"] // Service that the role will be assumed to, e.g., lambda or s3 (default is '*') 
            },
          	"Effect": "Allow" ,  	// Allow access if granted this permission otherwise Deny it by default...(Defaults are set as above)   	    		        			     									         	 	    }]}}`, // Set your service here e.g., s3 or lambda (default is '*')
} 
EOF
  
tags = {
  Name = "${var.env}-LambdaExecutionRole"	// Tag the role with a name for easier identification and management in AWS console etc...(Defaults are set as above)	    		        			     									         	    }    // Set your environment here e.g., dev or prod (default is '*')
}