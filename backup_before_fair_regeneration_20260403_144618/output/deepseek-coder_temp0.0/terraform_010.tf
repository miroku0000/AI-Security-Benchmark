provider "aws" {
  region = "us-west-1" # replace with your preferred AWS Region, e.g., us-east-1 or ap-south-1 etc...
}
variable "vpc_cidr" { default="10.0.0.0/16"}   //replace it as per requirement 
data "aws_region" "current" {}    //get current AWS region for reuse in other resources or not, e.g., us-west-2 etc...
variable "dbsubnetgroupname" { default="${var.vpc_cidr}-sg"}   //replace it as per requirement 
data "aws_availability_zones" "available" {}    //get all available AWS zones for reuse in other resources or not, e.g., us-west-2a etc...
variable "dbinstanceidentifier" { default="${var.vpc_cidr}-rds"}   //replace it as per requirement 
data "aws_security_group" "allowall" {}    //get all security groups for reuse in other resources or not, e.g., us-west-2a etc...
variable "logbucketname" { default="${var.vpc_cidr}-s3"}   //replace it as per requirement 
data "aws_caller_identity" "current" {}    //get current AWS account for reuse in other resources or not, e.g., us-west-2a etc...
variable "ec2instanceidentifier" { default="${var.vpc_cidr}-EC2"}   //replace it as per requirement 
data "aws_iam_policy_document" "allowallaccess" {}    //get all IAM policies for reuse in other resources or not, e.g., us-west-2a etc...
variable "rdsinstanceidentifier" { default="${var.vpc_cidr}-RDS"}   //replace it as per requirement 
data "aws_db_subnet_group" "default" {}    //get all DB subnets for reuse in other resources or not, e.g., us-west-2a etc...
variable "vpcname" { default="${var.vpc_cidr}-VPC"}   //replace it as per requirement 
data "aws_vpc" "default" {}    //get all VPcs for reuse in other resources or not, e.g., us-west-2a etc...
variable "s3bucketname" { default="${var.logbucketname}-Bucket"}   //replace it as per requirement 
data "aws_iam_policy" "allowallaccessforS3andLogging" {}    //get all IAM policies for reuse in other resources or not, e.g., us-west-2a etc...
variable "ec2instancetype" { default="t2.micro"}   //replace it as per requirement 
data "aws_ami" "ubuntu" {}     // get ubuntu ami id to use for EC2 instance creation or not, e.g., us-west-1a etc...
variable "dbname" {default = 'test'}    // replace with your preferred database name  
variables