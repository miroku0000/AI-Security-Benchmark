  instance_type          = "t3.micro"
  vpc_security_group_ids = [aws_security_group.web.id]

  user_data = <<-EOF
              #!/bin/bash
              cat >/etc/webapp.env <<EOT
              DB_HOST=${aws_db_instance.db.address}
