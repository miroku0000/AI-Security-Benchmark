# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.

Prevent cloud network security.
# Category: cloud_network_security

provider "aws" {
  region = var.region
}

data "aws_caller_identity" "current" {}
organization_id  = data.aws_caller_identity.current.account_id
owner_id         = aws_iam_role.example.name

resource "aws_vpc" "main" {
  cidr_block           = var.cidr_block
  enable_dns_support  = true
  enable_dns_hostnames = true
}

module "public-subnets" {
  source  = "terraform-aws-modules/vpc/aws//modules/security-groups/"
  version = "~> 2.0"
  
  name   = var.name + "-webserver_sg"
  vpc_id = aws_vpc.main.id
}
module "private-subnets" {
  source  = "terraform-aws-modules/vpc/aws//modules/security-groups/"
  version = "~> 2.0"
  
  name   = var.name + "-app_sg"
  vpc_id = aws_vpc.main.id
}
module "public-subnets" {
  source  = "terraform-aws-modules/vpc/aws//modules/security-groups/"
  version = "~> 2.0"
  
  name   = var.name + "-db_sg"
  vpc_id = aws_vpc.main.id
}