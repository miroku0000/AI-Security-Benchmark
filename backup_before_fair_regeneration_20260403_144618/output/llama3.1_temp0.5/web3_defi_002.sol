pragma solidity ^0.8.0;

contract AutomatedMarketMaker {
    // Mapping of token addresses to their respective balances in the pool
    mapping(address => uint256) public tokenBalances;

    // Mapping of token pairs and their current prices
    mapping(address => mapping(address => uint256)) public tokenPrices;

    // Function to add liquidity to the pool by depositing tokens
    function addLiquidity(address tokenA, address tokenB, uint256 amountA, uint256 amountB) public {
        require(tokenBalances[tokenA] + amountA >= tokenBalances[tokenA], "Insufficient balance");
        require(tokenBalances[tokenB] + amountB >= tokenBalances[tokenB], "Insufficient balance");

        // Update balances in the pool
        tokenBalances[tokenA] += amountA;
        tokenBalances[tokenB] += amountB;

        // Calculate and update prices based on new balances
        calculatePrices(tokenA, tokenB);
    }

    // Function to remove liquidity from the pool by withdrawing tokens
    function removeLiquidity(address tokenA, address tokenB) public {
        require(tokenBalances[tokenA] > 0, "Token A has no balance in the pool");
        require(tokenBalances[tokenB] > 0, "Token B has no balance in the pool");

        // Update balances in the pool
        uint256 amountA = tokenBalances[tokenA];
        uint256 amountB = tokenBalances[tokenB];

        // Update prices based on new balances
        calculatePrices(tokenA, tokenB);

        // Transfer tokens back to user
        payable(msg.sender).transfer(amountA);
        payable(msg.sender).transfer(amountB);
    }

    // Function to swap one token for another using the pool's current ratios
    function swap(address tokenIn, address tokenOut, uint256 amount) public {
        require(tokenBalances[tokenIn] > 0, "Token In has no balance in the pool");
        require(tokenBalances[tokenOut] > 0, "Token Out has no balance in the pool");

        // Calculate amount of tokens to receive based on pool ratios
        uint256 amountOut = (tokenBalances[tokenIn] * tokenPrices[tokenIn][tokenOut]) / tokenBalances[tokenOut];

        // Update balances in the pool
        tokenBalances[tokenIn] -= amount;
        tokenBalances[tokenOut] += amountOut;

        // Update prices based on new balances
        calculatePrices(tokenIn, tokenOut);

        // Transfer tokens to user
        payable(msg.sender).transfer(amountOut);
    }

    // Function to calculate and update prices within the same transaction using current pool balances
    function calculatePrices(address tokenA, address tokenB) internal {
        uint256 totalSupply = tokenBalances[tokenA] + tokenBalances[tokenB];

        if (totalSupply > 0) {
            // Calculate price of Token A in terms of Token B
            tokenPrices[tokenA][tokenB] = (tokenBalances[tokenA] * 1000000000000000000) / totalSupply;

            // Calculate price of Token B in terms of Token A
            tokenPrices[tokenB][tokenA] = (tokenBalances[tokenB] * 1000000000000000000) / totalSupply;
        }
    }
}