pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC721/SafeERC721.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/SafeMath.sol";

contract NFTMarketplace {
    // Mapping of token IDs to listings
    mapping (uint256 => Listing) public listings;
    
    // Mapping of seller addresses to their balances
    mapping (address => uint256) public balances;
    
    // Event emitted when a new listing is created
    event NewListing(uint256 tokenId, address seller, uint256 price);
    
    // Event emitted when an NFT sale is executed
    event SaleExecuted(address buyer, address seller, uint256 tokenId, uint256 price);

    struct Listing {
        address seller;
        uint256 price;
        bool sold;
    }

    function listNFT(uint256 _tokenId, uint256 _price) public {
        // Check if the token ID is valid
        require(_tokenId > 0);
        
        // Get the current owner of the NFT
        address owner = ERC721(address(this)).ownerOf(_tokenId);
        
        // Require that the sender is the owner
        require(owner == msg.sender, "Only the owner can list their NFT");
        
        // Create a new listing for the token ID
        listings[_tokenId] = Listing({
            seller: owner,
            price: _price,
            sold: false
        });
        
        // Emit an event indicating that a new listing has been created
        emit NewListing(_tokenId, owner, _price);
    }

    function executeSale(uint256 _tokenId) public payable {
        // Get the current listing for the token ID
        Listing memory listing = listings[_tokenId];
        
        // Require that the listing exists and is not sold
        require(listing.price > 0 && !listing.sold, "Listing does not exist or has already been sold");
        
        // Check if the sender has sufficient balance to pay for the NFT
        require(msg.value >= listing.price, "Insufficient funds to purchase NFT");
        
        // Transfer the NFT from the seller to the buyer
        ERC721(address(this)).safeTransferFrom(listing.seller, msg.sender, _tokenId);
        
        // Update the balances of the buyer and seller
        balances[msg.sender] += listing.price;
        balances[listing.seller] -= listing.price;
        
        // Mark the listing as sold
        listings[_tokenId].sold = true;
        
        // Emit an event indicating that a sale has been executed
        emit SaleExecuted(msg.sender, listing.seller, _tokenId, listing.price);
    }
}