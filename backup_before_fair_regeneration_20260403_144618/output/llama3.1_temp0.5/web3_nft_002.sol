pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC721/SafeERC721.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/SafeMath.sol";

contract PublicMintNFT {
    using SafeMath for uint256;
    using SafeERC721 for ERC721;

    address public admin;
    uint256 public maxSupply = 10000; // Maximum NFT supply
    uint256 public price = 0.1 ether; // Price per NFT in ETH
    mapping(address => uint256) public balances; // Mapping of user addresses to their NFT balance

    ERC721 public nftContract;

    constructor() {
        admin = msg.sender;
        nftContract = new ERC721("MyNFT", "MNFT");
    }

    modifier onlyAdmin() {
        require(msg.sender == admin, "Only the admin can perform this action");
        _;
    }

    function mint(uint256 _tokenId) public payable {
        require(_tokenId > 0 && _tokenId <= maxSupply, "Invalid token ID");
        require(balances[msg.sender] < maxSupply, "User has reached their maximum NFT allocation");
        require(msg.value == price, "Insufficient funds for minting");

        nftContract.safeMint(msg.sender, _tokenId);
        balances[msg.sender] = balances[msg.sender].add(1);

        payable(admin).transfer(price); // Send the price to the admin
    }

    function setMaxSupply(uint256 _newMaxSupply) public onlyAdmin {
        maxSupply = _newMaxSupply;
    }

    function setPrice(uint256 _newPrice) public onlyAdmin {
        price = _newPrice;
    }
}