# Generated by openai (gpt-5.2)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  type    = string
  default = "us-east-1"
}

variable "name" {
  type    = string
  default = "app"
}

variable "vpc_id" {
  type = string
}

variable "private_subnet_ids" {
  type = list(string)
}

variable "instance_type" {
  type    = string
  default = "t3.micro"
}

variable "ami_id" {
  type    = string
  default = ""
}

variable "key_name" {
  type    = string
  default = null
}

variable "backend_url" {
  type = string
}

variable "backend_api_key" {
  type      = string
  sensitive = true
}

variable "app_port" {
  type    = number
  default = 8080
}

variable "health_check_path" {
  type    = string
  default = "/health"
}

variable "desired_capacity" {
  type    = number
  default = 2
}

variable "min_size" {
  type    = number
  default = 2
}

variable "max_size" {
  type    = number
  default = 6
}

variable "target_group_arn" {
  type    = string
  default = null
}

variable "enable_ssm" {
  type    = bool
  default = true
}

variable "additional_security_group_ids" {
  type    = list(string)
  default = []
}

variable "tags" {
  type    = map(string)
  default = {}
}

data "aws_caller_identity" "current" {}

data "aws_region" "current" {}

data "aws_ssm_parameter" "al2023_ami" {
  name = "/aws/service/ami-amazon-linux-latest/al2023-ami-kernel-6.1-x86_64"
}

locals {
  resolved_ami_id = var.ami_id != "" ? var.ami_id : data.aws_ssm_parameter.al2023_ami.value
  common_tags     = merge(var.tags, { Name = var.name, ManagedBy = "terraform" })
}

data "aws_iam_policy_document" "assume_ec2" {
  statement {
    actions = ["sts:AssumeRole"]
    principals {
      type        = "Service"
      identifiers = ["ec2.amazonaws.com"]
    }
  }
}

resource "aws_iam_role" "ec2" {
  name               = "${var.name}-ec2-role"
  assume_role_policy = data.aws_iam_policy_document.assume_ec2.json
  tags               = local.common_tags
}

resource "aws_iam_role_policy_attachment" "ssm" {
  count      = var.enable_ssm ? 1 : 0
  role       = aws_iam_role.ec2.name
  policy_arn = "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore"
}

resource "aws_iam_instance_profile" "ec2" {
  name = "${var.name}-instance-profile"
  role = aws_iam_role.ec2.name
  tags = local.common_tags
}

resource "aws_security_group" "app" {
  name        = "${var.name}-sg"
  description = "Security group for ${var.name} instances"
  vpc_id      = var.vpc_id
  tags        = local.common_tags

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    from_port   = var.app_port
    to_port     = var.app_port
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "App port"
  }
}

data "aws_ami" "al2023" {
  most_recent = true
  owners      = ["amazon"]

  filter {
    name   = "name"
    values = ["al2023-ami-*-x86_64"]
  }

  filter {
    name   = "state"
    values = ["available"]
  }
}

resource "aws_cloudwatch_log_group" "app" {
  name              = "/${var.name}/app"
  retention_in_days = 14
  tags              = local.common_tags
}

resource "aws_launch_template" "app" {
  name_prefix   = "${var.name}-lt-"
  image_id      = local.resolved_ami_id
  instance_type = var.instance_type
  key_name      = var.key_name

  iam_instance_profile {
    name = aws_iam_instance_profile.ec2.name
  }

  vpc_security_group_ids = concat([aws_security_group.app.id], var.additional_security_group_ids)

  metadata_options {
    http_endpoint               = "enabled"
    http_tokens                 = "required"
    http_put_response_hop_limit = 2
  }

  monitoring {
    enabled = true
  }

  user_data = base64encode(templatefile("${path.module}/user_data.sh.tpl", {
    name              = var.name
    app_port          = var.app_port
    backend_url       = var.backend_url
    backend_api_key   = var.backend_api_key
    health_check_path = var.health_check_path
    aws_region        = data.aws_region.current.name
    log_group_name    = aws_cloudwatch_log_group.app.name
  }))

  tag_specifications {
    resource_type = "instance"
    tags          = local.common_tags
  }

  tag_specifications {
    resource_type = "volume"
    tags          = local.common_tags
  }

  tags = local.common_tags

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_autoscaling_group" "app" {
  name                      = "${var.name}-asg"
  max_size                  = var.max_size
  min_size                  = var.min_size
  desired_capacity          = var.desired_capacity
  vpc_zone_identifier       = var.private_subnet_ids
  health_check_type         = "EC2"
  health_check_grace_period = 120

  launch_template {
    id      = aws_launch_template.app.id
    version = "$Latest"
  }

  dynamic "target_group_arns" {
    for_each = var.target_group_arn == null ? [] : [var.target_group_arn]
    content  = [target_group_arns.value]
  }

  termination_policies = ["OldestLaunchTemplate", "Default"]

  tag {
    key                 = "Name"
    value               = var.name
    propagate_at_launch = true
  }

  dynamic "tag" {
    for_each = var.tags
    content {
      key                 = tag.key
      value               = tag.value
      propagate_at_launch = true
    }
  }

  lifecycle {
    create_before_destroy = true
  }
}

output "autoscaling_group_name" {
  value = aws_autoscaling_group.app.name
}

output "launch_template_id" {
  value = aws_launch_template.app.id
}

output "security_group_id" {
  value = aws_security_group.app.id
}

# --- user_data template file written by Terraform (optional convenience) ---
resource "local_file" "user_data_tpl" {
  filename = "${path.module}/user_data.sh.tpl"
  content  = <<-EOT
#!/usr/bin/env bash
set -euo pipefail

exec > >(tee /var/log/user-data.log | logger -t user-data -s 2>/dev/console) 2>&1

APP_NAME="${name}"
APP_PORT="${app_port}"
BACKEND_URL="${backend_url}"
BACKEND_API_KEY="${backend_api_key}"
HEALTH_PATH="${health_check_path}"
AWS_REGION="${aws_region}"
LOG_GROUP="${log_group_name}"

dnf -y update || true
dnf -y install curl jq awscli unzip ca-certificates || true

mkdir -p /etc/${name}
cat >/etc/${name}/app.env <<EOF
APP_NAME=${name}
APP_PORT=${app_port}
BACKEND_URL=${backend_url}
BACKEND_API_KEY=${backend_api_key}
HEALTH_PATH=${health_check_path}
EOF
chmod 600 /etc/${name}/app.env

cat >/usr/local/bin/${name}-app <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
source /etc/${name}/app.env

RESPOND() {
  local msg="$1"
  printf '%s\n' "$msg"
}

until curl -fsS --connect-timeout 2 --max-time 5 "${BACKEND_URL}/health" >/dev/null 2>&1; do
  RESPOND "Waiting for backend at ${BACKEND_URL}..."
  sleep 2
done

RESPOND "Backend reachable. Starting ${APP_NAME}..."

python3 - <<PY
import http.server, socketserver, os, json
port = int(os.environ.get("APP_PORT","8080"))
health = os.environ.get("HEALTH_PATH","/health")
backend = os.environ.get("BACKEND_URL","")
class H(http.server.BaseHTTPRequestHandler):
  def do_GET(self):
    if self.path == health:
      self.send_response(200); self.send_header("Content-Type","application/json"); self.end_headers()
      self.wfile.write(json.dumps({"status":"ok","backend":backend}).encode())
      return
    self.send_response(200); self.send_header("Content-Type","text/plain"); self.end_headers()
    self.wfile.write(b"ok")
  def log_message(self, format, *args): return
with socketserver.TCPServer(("", port), H) as httpd:
  httpd.serve_forever()
PY
EOF

chmod +x /usr/local/bin/${name}-app

cat >/etc/systemd/system/${name}.service <<EOF
[Unit]
Description=${name} application
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/etc/${name}/app.env
ExecStart=/usr/local/bin/${name}-app
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable --now ${name}.service

if command -v systemctl >/dev/null 2>&1; then
  systemctl is-active --quiet ${name}.service && echo "${name} service is running"
fi

for i in $(seq 1 60); do
  if curl -fsS "http://127.0.0.1:${app_port}${health_check_path}" >/dev/null 2>&1; then
    echo "Local health check passed"
    exit 0
  fi
  sleep 1
done

echo "Local health check failed"
exit 1
EOT
}