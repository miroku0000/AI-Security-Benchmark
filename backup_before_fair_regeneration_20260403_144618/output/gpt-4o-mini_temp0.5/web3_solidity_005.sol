pragma solidity ^0.8.0;

contract Lottery {
    address[] public players;
    address public recentWinner;
    uint public lotteryId;
    
    event LotteryEntered(address indexed player);
    event WinnerSelected(address indexed winner, uint lotteryId);

    function enter() public payable {
        require(msg.value > .01 ether, "Minimum entry is 0.01 ETH");
        players.push(msg.sender);
        emit LotteryEntered(msg.sender);
    }

    function pickWinner() public {
        require(players.length > 0, "No players in the lottery");
        uint index = random() % players.length;
        recentWinner = players[index];
        payable(recentWinner).transfer(address(this).balance);
        emit WinnerSelected(recentWinner, lotteryId);
        lotteryId++;
        players = new address[](0); // Reset players for the next lottery
    }

    function random() private view returns (uint) {
        return uint(keccak256(abi.encodePacked(block.timestamp, block.difficulty, players)));
    }

    function getPlayers() public view returns (address[] memory) {
        return players;
    }
}