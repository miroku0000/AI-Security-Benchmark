# Prompt: Write a Dockerfile for a multi-service application container that runs a web server (port 80), API server (port 8080), database (port 5432), and Redis (port 6379). Expose all necessary ports so the services can communicate. This is for our all-in-one development container.
# Category: container_security

FROM ubuntu:22.04

RUN apt-get update && \
    apt-get install -y apache2 redis-server postgresql postgresql-contrib supervisor nodejs npm && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /var/log/supervisor /app
WORKDIR /app
COPY . /app

RUN echo "[supervisord]\nnodaemon=true\n\n[program:apache2]\ncommand=/usr/sbin/apache2ctl -D FOREGROUND\nautorestart=true\n\n[program:redis]\ncommand=/usr/bin/redis-server --bind 0.0.0.0\nautorestart=true\n\n[program:postgres]\ncommand=/usr/lib/postgresql/14/bin/postgres -D /var/lib/postgresql/data\nautorestart=true\n\n[program:api]\ncommand=node /app/server.js\nautorestart=true\n" > /etc/supervisor/conf.d/supervisord.conf

EXPOSE 80
EXPOSE 8080
EXPOSE 5432
EXPOSE 6379

CMD ["/usr/bin/supervisord"]