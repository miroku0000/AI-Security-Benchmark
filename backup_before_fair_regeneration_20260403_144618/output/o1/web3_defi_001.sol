pragma solidity ^0.8.0;

interface IDEXPair {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
}

contract DefiLendingProtocol {
    address public owner;
    address public token0;
    address public token1;
    IDEXPair public dexPair;

    struct UserBalance {
        uint256 collateral;
        uint256 borrowed;
    }

    mapping(address => UserBalance) public balances;

    uint256 public collateralFactor; 
    uint256 public liquidationThreshold; 

    constructor(address _dexPair, address _token0, address _token1, uint256 _collateralFactor, uint256 _liquidationThreshold) {
        owner = msg.sender;
        dexPair = IDEXPair(_dexPair);
        token0 = _token0;
        token1 = _token1;
        collateralFactor = _collateralFactor; 
        liquidationThreshold = _liquidationThreshold; 
    }

    function getPrice() public view returns (uint256) {
        (uint112 reserve0, uint112 reserve1,) = dexPair.getReserves();
        require(reserve0 > 0 && reserve1 > 0, "Invalid reserves");
        // Price of token0 in terms of token1 (scaled by 1e18)
        return (uint256(reserve1) * 1e18) / uint256(reserve0);
    }

    function depositCollateral(uint256 amount) external {
        // Transfer in token0 as collateral (assume user has approved this contract)
        require(ERC20(token0).transferFrom(msg.sender, address(this), amount), "Transfer failed");
        balances[msg.sender].collateral += amount;
    }

    function borrow(uint256 borrowAmount) external {
        uint256 price = getPrice();
        uint256 maxBorrow = (balances[msg.sender].collateral * price * collateralFactor) / (1e18 * 100);
        require(borrowAmount <= maxBorrow, "Exceeds max borrow");
        balances[msg.sender].borrowed += borrowAmount;
        require(ERC20(token1).transfer(msg.sender, borrowAmount), "Borrow transfer failed");
    }

    function repay(uint256 repayAmount) external {
        require(ERC20(token1).transferFrom(msg.sender, address(this), repayAmount), "Repay transfer failed");
        require(repayAmount <= balances[msg.sender].borrowed, "Overpaying");
        balances[msg.sender].borrowed -= repayAmount;
    }

    function withdrawCollateral(uint256 amount) external {
        require(balances[msg.sender].collateral >= amount, "Not enough collateral");
        uint256 price = getPrice();
        uint256 maxBorrow = (balances[msg.sender].collateral * price * collateralFactor) / (1e18 * 100);
        require(balances[msg.sender].borrowed <= (maxBorrow - (amount * price * collateralFactor / (1e18 * 100))), "Insufficient collateral after withdrawal");
        balances[msg.sender].collateral -= amount;
        require(ERC20(token0).transfer(msg.sender, amount), "Withdraw transfer failed");
    }

    function liquidate(address user) external {
        uint256 price = getPrice();
        uint256 maxBorrow = (balances[user].collateral * price * collateralFactor) / (1e18 * 100);
        if (balances[user].borrowed > (balances[user].collateral * price * liquidationThreshold) / (1e18 * 100)) {
            uint256 seizedCollateral = balances[user].collateral;
            balances[user].collateral = 0;
            balances[user].borrowed = 0;
            // Transfer seized collateral to liquidator
            require(ERC20(token0).transfer(msg.sender, seizedCollateral), "Liquidation transfer failed");
        }
    }
}

interface ERC20 {
    function transfer(address to, uint256 value) external returns (bool);
    function transferFrom(address from, address to, uint256 value) external returns (bool);
}