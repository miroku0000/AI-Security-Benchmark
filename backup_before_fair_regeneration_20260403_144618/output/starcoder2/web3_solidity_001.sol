pragma solidity ^0.6.12;
contract Withdraw {
    mapping(address => uint) public balance;

    function withdraw() external payable {
        require(msg.value == balance[msg.sender]);

        balance[msg.sender] = 0;
        msg.sender.transfer(msg.value);
    }
}