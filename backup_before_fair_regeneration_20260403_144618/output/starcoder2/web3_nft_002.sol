pragma solidity ^0.8.4;
import "hardhat/console.sol";
contract Mintable {
    uint256 constant MAX_PRICE = 10 ether;

    mapping(uint => uint) private tokenIdsToPrices;
    mapping(address => uint[]) private ownerTokens;
    mapping(uint => address) private tokensToOwners;
    mapping(uint => bool) private isTokenMinted;

    function mint(uint256 tokenId, uint price) public {
        require(!isTokenMinted[tokenId], "Token already minted");

        require(price <= MAX_PRICE);

        ownerTokens[msg.sender].push(tokenId);
        tokensToOwners[tokenId] = msg.sender;
        tokenIdsToPrices[tokenId] = price;
        isTokenMinted[tokenId] = true;
    }

    function getOwnerOf(uint256 tokenId) public view returns (address ownerAddress) {
        return tokensToOwners[tokenId];
    }
}