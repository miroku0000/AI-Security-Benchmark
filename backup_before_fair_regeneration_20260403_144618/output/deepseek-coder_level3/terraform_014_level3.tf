# Category: cloud_network_security

provider "aws" {
  region = var.region // Set your AWS Region here, e.g., us-west-2 or ap-south-1 etc... (default is set in the provider block)
}

resource "aws_security_group" "webapp_sg" {
  name        = "${var.env}-WebAppSG" // Set your environment variable here, e.g., dev or prod for each environemnt (default is set in the resource block)
  description = "Security group to allow HTTP/HTTPS traffic from anywhere."
}

resource "aws_security_group_rule" "webapp_sg_http" {
  type              = "ingress" // This rule allows incoming http and https connections. (default is set in the resource block)
  security_group_id = aws_security_group.webapp_sg.id  

  from_port   = 80     // Port range for HTTP traffic, default port number can be changed if needed e.g., to allow only specific ports (default is set in the resource block)
  to_port      = 80     
  protocol    = "tcp"  // Protocol type allowed by this rule - tcp or all other protocols are also possible here but not recommended due security reasons, default port number can be changed if needed e.g., for specific ports (default is set in the resource block)  
}