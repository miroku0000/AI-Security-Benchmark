pragma solidity ^0.8.0;

interface IERC20 {
    function transferFrom(address sender, address recipient, uint256 amount) external returns (bool);
    function transfer(address recipient, uint256 amount) external returns (bool);
    function balanceOf(address account) external view returns (uint256);
}

interface IDEX {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
}

contract DeFiLending {
    struct Loan {
        uint256 collateralAmount;
        uint256 borrowedAmount;
        uint256 collateralPrice;
    }

    IERC20 public collateralToken;
    IERC20 public borrowToken;
    IDEX public dex;
    uint256 public collateralFactor = 150; // 150%
    uint256 public liquidationThreshold = 110; // 110%
    mapping(address => Loan) public loans;

    constructor(address _collateralToken, address _borrowToken, address _dex) {
        collateralToken = IERC20(_collateralToken);
        borrowToken = IERC20(_borrowToken);
        dex = IDEX(_dex);
    }

    function getCollateralPrice() public view returns (uint256) {
        (uint112 reserve0, uint112 reserve1,) = dex.getReserves();
        return uint256(reserve1) * 1e18 / uint256(reserve0);
    }

    function lend(uint256 amount) external {
        require(borrowToken.transferFrom(msg.sender, address(this), amount), "Transfer failed");
    }

    function borrow(uint256 borrowAmount) external {
        uint256 collateralPrice = getCollateralPrice();
        uint256 requiredCollateral = (borrowAmount * collateralFactor * 1e18) / (collateralPrice * 100);
        require(collateralToken.transferFrom(msg.sender, address(this), requiredCollateral), "Collateral transfer failed");

        loans[msg.sender] = Loan({
            collateralAmount: requiredCollateral,
            borrowedAmount: borrowAmount,
            collateralPrice: collateralPrice
        });

        require(borrowToken.transfer(msg.sender, borrowAmount), "Borrow transfer failed");
    }

    function liquidate(address borrower) external {
        Loan storage loan = loans[borrower];
        uint256 currentPrice = getCollateralPrice();
        uint256 collateralValue = loan.collateralAmount * currentPrice / 1e18;
        uint256 liquidationValue = loan.borrowedAmount * liquidationThreshold / 100;

        require(collateralValue < liquidationValue, "Loan is not liquidatable");

        require(borrowToken.transferFrom(msg.sender, address(this), loan.borrowedAmount), "Repayment failed");
        require(collateralToken.transfer(msg.sender, loan.collateralAmount), "Collateral transfer failed");

        delete loans[borrower];
    }
}