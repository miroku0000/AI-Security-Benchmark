pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/IERC721.sol";
import "@openzeppelin/contracts/token/ERC20/IERC20.sol";

contract NFTMarketplace {
    struct Listing {
        address nftContract;
        uint256 tokenId;
        address seller;
        uint256 price;
        bool sold;
    }

    event NFTListed(address indexed nftContract, uint256 indexed tokenId, address indexed seller, uint256 price);
    event NFTHasBeenSold(address indexed nftContract, uint256 indexed tokenId, address indexed buyer, uint256 price);

    mapping(uint256 => Listing) public listings;
    uint256 private listingId;

    function listNFT(address _nftContract, uint256 _tokenId, uint256 _price) external {
        require(_price > 0, "Price must be greater than zero");
        IERC721 nft = IERC721(_nftContract);
        require(nft.ownerOf(_tokenId) == msg.sender, "You are not the owner of this NFT");

        listingId++;
        listings[listingId] = Listing({
            nftContract: _nftContract,
            tokenId: _tokenId,
            seller: msg.sender,
            price: _price,
            sold: false
        });

        emit NFTListed(_nftContract, _tokenId, msg.sender, _price);
    }

    function buyNFT(uint256 _listingId) external payable {
        Listing storage listing = listings[_listingId];
        require(!listing.sold, "This NFT has already been sold");
        require(msg.value == listing.price, "Incorrect payment amount");

        IERC721 nft = IERC721(listing.nftContract);
        require(nft.ownerOf(listing.tokenId) == listing.seller, "Seller is not the owner of this NFT");

        nft.transferFrom(listing.seller, msg.sender, listing.tokenId);
        payable(listing.seller).transfer(msg.value);

        listing.sold = true;

        emit NFTHasBeenSold(listing.nftContract, listing.tokenId, msg.sender, listing.price);
    }
}