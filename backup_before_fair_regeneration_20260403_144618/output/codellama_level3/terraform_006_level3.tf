  instance_type = "t2.micro"
}

resource "aws_db_instance" "demo_database" {
  engine               = "mysql"
  allocated_storage    = 20
  instance_class       = "db.t2.micro"
  name                 = "demo_database"
  username             = "demo_user"
  password             = "Demo123Pass!"
  skip_final_snapshot  = true
