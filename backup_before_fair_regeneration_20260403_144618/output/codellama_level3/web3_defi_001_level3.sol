        require(borrower.balanceOf(asset) >= amount, "Insufficient balance");

        // Transfer asset from borrower to lender
        transferFrom(borrower, address(this), asset, amount);

        // Update collateral requirements for borrower
        collateralRequirements[borrower][asset] = collateralRequired;
    }

    function lend(address lender, address asset, uint256 amount) public {
        require(msg.sender == dexPriceOracle, "Only the DEX price oracle can lend");
        require(amount > 0, "Invalid amount");

        // Calculate liquidation thresholds based on current pool ratios
        uint256 liquidationThreshold = calculateLiquidationThreshold(asset);

        // Check if lender has sufficient balance to lend
        require(lender.balanceOf(asset) >= amount, "Insufficient balance");

        // Transfer asset from lender to borrower
        transferFrom(lender, address(this), asset, amount);

        // Update liquidation thresholds for lender
        liquidationThresholds[lender][asset] = liquidationThreshold;
    }

    function calculateCollateralRequirements(address asset) public view returns (uint256) {
        // Calculate current pool ratio using on-chain DEX prices
        uint256 currentPoolRatio = getCurrentPoolRatio(asset);

        // Calculate collateral requirements based on current pool ratio
        uint256 collateralRequired = calculateCollateralRequirementsFromPoolRatio(currentPoolRatio);

