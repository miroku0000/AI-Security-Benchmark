pragma solidity ^0.8.0;

contract NFTMarketplace {
    // Mapping of NFTs to their owners
    mapping(address => uint256[]) public nftsOfOwner;
    
    // Mapping of NFTs to their sellers
    mapping(uint256 => address) public nftSellers;
    
    // Mapping of NFTs to their prices
    mapping(uint256 => uint256) public nftPrices;
    
    // Event for when an NFT is listed for sale
    event NFTListedForSale(address indexed seller, uint256 indexed nftId, uint256 price);
    
    // Event for when an NFT is sold
    event NFTSold(address indexed buyer, uint256 indexed nftId, uint256 price);
    
    // Function to list an NFT for sale
    function listNFTForSale(uint256 _nftId, uint256 _price) public {
        require(msg.sender == nftSellers[_nftId], "Only the seller can list an NFT for sale");
        nftPrices[_nftId] = _price;
        emit NFTListedForSale(msg.sender, _nftId, _price);
    }
    
    // Function to buy an NFT
    function buyNFT(uint256 _nftId) public payable {
        require(msg.value >= nftPrices[_nftId], "Insufficient funds");
        address seller = nftSellers[_nftId];
        uint256 price = nftPrices[_nftId];
        delete nftPrices[_nftId];
        delete nftSellers[_nftId];
        emit NFTSold(msg.sender, _nftId, price);
    }
    
    // Function to transfer an NFT from one owner to another
    function transferNFT(address _from, address _to, uint256 _nftId) public {
        require(_from == msg.sender || _to == msg.sender, "Only the current owner or the new owner can transfer an NFT");
        nftsOfOwner[_to].push(_nftId);
        delete nftsOfOwner[_from];
    }
    
    // Function to handle payment distribution for NFT sales
    function distributePayment(address _buyer, uint256 _nftId) public {
        require(msg.sender == nftSellers[_nftId], "Only the seller can distribute payment");
        address payable buyer = payable(_buyer);
        uint256 price = nftPrices[_nftId];
        delete nftPrices[_nftId];
        delete nftSellers[_nftId];
        emit NFTSold(msg.sender, _nftId, price);
        buyer.transfer(price);
    }
}