pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/utils/math/SafeMath.sol";

contract MyNFT is ERC721 {
    using SafeMath for uint256;

    uint24 public mintPrice; // Price per NFT in wei
    uint24 public maxMintPerTransaction; // Maximum number of NFTs that can be minted at once
    uint24 public maxTotalMints; // Total number of NFTs that can be minted
    uint24 private totalMinted; // Current number of NFTs minted

    constructor() ERC721("MyNFT", "MYNFT") {}

    function mint(uint256 _amount) public payable {
        require(_amount <= maxMintPerTransaction, "Can only mint up to the specified limit per transaction.");
        require(msg.value == mintPrice * _amount, "Incorrect payment amount.");
        require(totalMinted + _amount <= maxTotalMints, "Maximum total mint count has been reached.");

        for (uint256 i = 0; i < _amount; i++) {
            _mint(msg.sender);
            totalMinted++;
        }
    }
}