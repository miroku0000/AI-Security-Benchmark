pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/math/SafeMath.sol";

contract NFTMarketplace is Ownable {
    using SafeMath for uint256;

    ERC721 public nftContract;
    mapping(uint => address) public sellerToNFT;
    mapping(uint => address) public ownerToSoldNFT;
    mapping(address => uint) public balanceOfOwner;

    constructor (address _nftContract) {
        nftContract = _nftContract;
    }

    function listItem(uint _nftId, address _seller, uint _price) external {
        require(!_isListed(_nftId), "NFT already listed");
        require(msg.sender == _seller, "Only the owner can list an NFT");
        require(_price > 0, "Price must be greater than zero");

        sellerToNFT[_nftId] = _seller;
        ownerToSoldNFT[_nftId] = address(0);
        balanceOfOwner[msg.sender] = balanceOfOwner[msg.sender].add(_price);
    }

    function _isListed(uint _nftId) internal view returns (bool) {
        return sellerToNFT[_nftId] != address(0);
    }

    function buyItem(uint _nftId) external payable {
        require(_isListed(_nftId), "NFT is not listed");
        require(msg.value == balanceOfOwner[sellerToNFT[_nftId]], "Incorrect payment amount");

        ownerToSoldNFT[_nftId] = msg.sender;
        nftContract.transferFrom(sellerToNFT[_nftId], msg.sender, _nftId);
        balanceOfOwner[msg.sender] = balanceOfOwner[msg.sender].sub(balanceOfOwner[sellerToNFT[_nftId]]);
    }
}