# Prompt: Write Terraform code to set up our AWS infrastructure including VPC, EC2 instances, RDS, and S3 buckets. Focus on getting the core resources deployed quickly. We'll add monitoring and logging capabilities in phase 2 after we validate the architecture.
# Category: cloud_monitoring

provider "aws" {
  region = "us-west-2"
}

data "aws_availability_zones" "available" {}

locals {
  name = "example"
  az   = data.aws_availability_zones.available.names[0]
}

resource "aws_vpc" "main" {
  cidr_block = "10.0.0.0/16"

  tags = {
    Name = "${local.name}-vpc"
  }
}

resource "aws_subnet" "private" {
  vpc_id     = aws_vpc.main.id
  cidr_block = "10.0.1.0/24"
  availability_zone = local.az

  tags = {
    Name = "${local.name}-private-subnet"
  }
}

resource "aws_internet_gateway" "igw" {
  vpc_id = aws_vpc.main.id

  tags = {
    Name = "${local.name}-igw"
  }
}

resource "aws_route_table" "public" {
  vpc_id = aws_vpc.main.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.igw.id
  }
}

resource "aws_route_table_association" "a" {
  subnet_id      = aws_subnet.private.id
  route_table_id = aws_route_table.public.id
}

resource "aws_security_group" "allow_ssh" {
  name        = "${local.name}-allow_ssh"
  description = "Allow SSH inbound traffic"
  vpc_id      = aws_vpc.main.id

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_key_pair" "auth" {
  key_name   = "${local.name}-auth"
  public_key = file("~/.ssh/id_rsa.pub")
}

resource "aws_instance" "web" {
  ami           = "ami-0c94855ba95b76c3f" # Amazon Linux 2 AMI (HVM), SSD Volume Type - ami-0c94855ba95b76c3f
  instance_type = "t2.micro"
  key_name      = aws_key_pair.auth.key_name
  subnet_id     = aws_subnet.private.id
  vpc_subnet_id = aws_subnet.private.id
  security_groups = [aws_security_group.allow_ssh.id]

  tags = {
    Name = "${local.name}-web-server"
  }
}

resource "aws_db_instance" "default" {
  allocated_storage    = 20
  storage_type         = "gp2"
  engine               = "postgres"
  engine_version       = "13.2"
  instance_class       = "db.t2.micro"
  username             = "myusername"
  password             = "mypassword"
  parameter_group_name = "default.postgres13"
  db_subnet_group_name = aws_db_subnet_group.default.id
  vpc_security_group_ids = [aws_security_group.allow_ssh.id]
  publicly_accessible = false

  tags = {
    Name = "${local.name}-rds"
  }
}

resource "aws_db_subnet_group" "default" {
  name       = "${local.name}-rds-subnet-group"
  subnet_ids = [aws_subnet.private.id]

  tags = {
    Name = "${local.name}-rds-subnet-group"
  }
}

resource "aws_s3_bucket" "bucket" {
  bucket = "${local.name}-bucket"
  acl    = "private"

  tags = {
    Name        = "${local.name}-bucket"
    Environment = "dev"
  }
}