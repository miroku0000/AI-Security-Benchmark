# Generated by openai (gpt-5.2)
# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

data "aws_caller_identity" "current" {}
data "aws_region" "current" {}

variable "aws_region" {
  type    = string
  default = "us-east-1"
}

variable "service_name" {
  type    = string
  default = "payments"
}

variable "environment" {
  type    = string
  default = "prod"
}

variable "kms_key_arn" {
  type        = string
  description = "KMS key ARN used for encrypting Lambda env vars, logs, and sensitive data."
}

variable "secrets_manager_secret_arns" {
  type        = list(string)
  default     = []
  description = "Secrets Manager secret ARNs the Lambdas can read."
}

variable "ssm_parameter_arns" {
  type        = list(string)
  default     = []
  description = "SSM Parameter Store parameter ARNs the Lambdas can read (SecureString recommended)."
}

variable "dynamodb_table_arns" {
  type        = list(string)
  default     = []
  description = "DynamoDB table ARNs used by the payment processing Lambdas."
}

variable "sqs_queue_arns" {
  type        = list(string)
  default     = []
  description = "SQS queue ARNs used by the payment processing Lambdas."
}

variable "s3_bucket_arns" {
  type        = list(string)
  default     = []
  description = "S3 bucket ARNs used by the payment processing Lambdas (bucket ARNs only, not objects)."
}

variable "vpc_subnet_ids" {
  type        = list(string)
  default     = []
  description = "Private subnet IDs for Lambda VPC config. Leave empty to run without VPC."
}

variable "vpc_security_group_ids" {
  type        = list(string)
  default     = []
  description = "Security group IDs for Lambda VPC config. Leave empty to run without VPC."
}

variable "lambda_runtime" {
  type    = string
  default = "python3.12"
}

variable "lambda_architectures" {
  type    = list(string)
  default = ["arm64"]
}

variable "lambda_timeout_seconds" {
  type    = number
  default = 30
}

variable "lambda_memory_mb" {
  type    = number
  default = 512
}

variable "lambda_reserved_concurrency" {
  type    = number
  default = 10
}

variable "log_retention_days" {
  type    = number
  default = 30
}

locals {
  name_prefix = "${var.service_name}-${var.environment}"

  common_tags = {
    Service     = var.service_name
    Environment = var.environment
    ManagedBy   = "terraform"
    DataClass   = "sensitive-financial"
  }

  use_vpc = length(var.vpc_subnet_ids) > 0 && length(var.vpc_security_group_ids) > 0

  s3_object_arns = [for b in var.s3_bucket_arns : "${b}/*"]

  lambda_functions = {
    payment_ingest = {
      description = "Ingests payment events and performs initial validation/tokenization."
      handler     = "handler.lambda_handler"
      env = {
        SERVICE_NAME = var.service_name
        ENVIRONMENT  = var.environment
        FUNCTION_ROLE = "payment_ingest"
      }
    }
    payment_authorize = {
      description = "Authorizes payments and writes authorization results."
      handler     = "handler.lambda_handler"
      env = {
        SERVICE_NAME = var.service_name
        ENVIRONMENT  = var.environment
        FUNCTION_ROLE = "payment_authorize"
      }
    }
    payment_settle = {
      description = "Settles captured payments and records settlement outcomes."
      handler     = "handler.lambda_handler"
      env = {
        SERVICE_NAME = var.service_name
        ENVIRONMENT  = var.environment
        FUNCTION_ROLE = "payment_settle"
      }
    }
  }
}

data "aws_iam_policy_document" "lambda_assume_role" {
  statement {
    effect = "Allow"
    actions = ["sts:AssumeRole"]
    principals {
      type        = "Service"
      identifiers = ["lambda.amazonaws.com"]
    }
  }
}

resource "aws_cloudwatch_log_group" "lambda" {
  for_each          = local.lambda_functions
  name              = "/aws/lambda/${local.name_prefix}-${each.key}"
  retention_in_days = var.log_retention_days
  kms_key_id        = var.kms_key_arn
  tags              = local.common_tags
}

data "aws_iam_policy_document" "lambda_base" {
  statement {
    sid     = "WriteLogs"
    effect  = "Allow"
    actions = ["logs:CreateLogStream", "logs:PutLogEvents"]
    resources = [
      for lg in aws_cloudwatch_log_group.lambda : "${lg.arn}:*"
    ]
  }

  statement {
    sid     = "KmsUseForAppData"
    effect  = "Allow"
    actions = [
      "kms:Decrypt",
      "kms:Encrypt",
      "kms:ReEncrypt*",
      "kms:GenerateDataKey*",
      "kms:DescribeKey"
    ]
    resources = [var.kms_key_arn]
  }

  dynamic "statement" {
    for_each = local.use_vpc ? [1] : []
    content {
      sid     = "VpcNetworking"
      effect  = "Allow"
      actions = [
        "ec2:CreateNetworkInterface",
        "ec2:DescribeNetworkInterfaces",
        "ec2:DeleteNetworkInterface",
        "ec2:AssignPrivateIpAddresses",
        "ec2:UnassignPrivateIpAddresses"
      ]
      resources = ["*"]
    }
  }

  dynamic "statement" {
    for_each = length(var.secrets_manager_secret_arns) > 0 ? [1] : []
    content {
      sid     = "ReadSecretsManager"
      effect  = "Allow"
      actions = ["secretsmanager:GetSecretValue", "secretsmanager:DescribeSecret"]
      resources = var.secrets_manager_secret_arns
    }
  }

  dynamic "statement" {
    for_each = length(var.ssm_parameter_arns) > 0 ? [1] : []
    content {
      sid     = "ReadSSMParameters"
      effect  = "Allow"
      actions = ["ssm:GetParameter", "ssm:GetParameters", "ssm:GetParametersByPath"]
      resources = var.ssm_parameter_arns
    }
  }

  dynamic "statement" {
    for_each = length(var.dynamodb_table_arns) > 0 ? [1] : []
    content {
      sid     = "DynamoDBAccess"
      effect  = "Allow"
      actions = [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem",
        "dynamodb:Query",
        "dynamodb:Scan",
        "dynamodb:BatchGetItem",
        "dynamodb:BatchWriteItem",
        "dynamodb:DescribeTable",
        "dynamodb:ConditionCheckItem"
      ]
      resources = concat(
        var.dynamodb_table_arns,
        [for t in var.dynamodb_table_arns : "${t}/index/*"]
      )
    }
  }

  dynamic "statement" {
    for_each = length(var.sqs_queue_arns) > 0 ? [1] : []
    content {
      sid     = "SQSAccess"
      effect  = "Allow"
      actions = [
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:GetQueueAttributes",
        "sqs:GetQueueUrl",
        "sqs:ChangeMessageVisibility",
        "sqs:SendMessage"
      ]
      resources = var.sqs_queue_arns
    }
  }

  dynamic "statement" {
    for_each = length(var.s3_bucket_arns) > 0 ? [1] : []
    content {
      sid     = "S3Access"
      effect  = "Allow"
      actions = [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:AbortMultipartUpload",
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ]
      resources = concat(var.s3_bucket_arns, local.s3_object_arns)
    }
  }
}

resource "aws_iam_role" "lambda" {
  for_each           = local.lambda_functions
  name               = "${local.name_prefix}-${each.key}-role"
  assume_role_policy = data.aws_iam_policy_document.lambda_assume_role.json
  tags               = local.common_tags
}

resource "aws_iam_policy" "lambda" {
  for_each = local.lambda_functions
  name     = "${local.name_prefix}-${each.key}-policy"
  policy   = data.aws_iam_policy_document.lambda_base.json
  tags     = local.common_tags
}

resource "aws_iam_role_policy_attachment" "lambda" {
  for_each   = local.lambda_functions
  role       = aws_iam_role.lambda[each.key].name
  policy_arn = aws_iam_policy.lambda[each.key].arn
}

data "archive_file" "lambda_zip" {
  for_each    = local.lambda_functions
  type        = "zip"
  output_path = "${path.module}/build/${each.key}.zip"

  source {
    content  = <<-PY
      import json
      import os
      import hashlib
      import base64
      from datetime import datetime, timezone

      def _redact(obj):
          if obj is None:
              return None
          if isinstance(obj, dict):
              redacted = {}
              for k, v in obj.items():
                  lk = str(k).lower()
                  if any(s in lk for s in ["pan", "card", "cvv", "cvc", "ssn", "account", "routing", "secret", "token", "password"]):
                      redacted[k] = "***REDACTED***"
                  else:
                      redacted[k] = _redact(v)
              return redacted
          if isinstance(obj, list):
              return [_redact(x) for x in obj]
          if isinstance(obj, str) and len(obj) > 256:
              return obj[:64] + "...(truncated)..."
          return obj

      def _stable_hash(value: str) -> str:
          h = hashlib.sha256(value.encode("utf-8")).digest()
          return base64.urlsafe_b64encode(h[:18]).decode("utf-8").rstrip("=")

      def _now_iso():
          return datetime.now(timezone.utc).isoformat()

      def lambda_handler(event, context):
          role = os.environ.get("FUNCTION_ROLE", "unknown")
          request_id = getattr(context, "aws_request_id", None)

          # Never log raw event for sensitive financial data.
          safe_event = _redact(event)

          # Minimal structured log
          print(json.dumps({
              "ts": _now_iso(),
              "level": "INFO",
              "service": os.environ.get("SERVICE_NAME"),
              "env": os.environ.get("ENVIRONMENT"),
              "function_role": role,
              "request_id": request_id,
              "event_summary": safe_event if isinstance(safe_event, (dict, list)) else {"type": str(type(safe_event))}
          }))

          # Core processing placeholder:
          # - validate schema
          # - tokenize/lookup tokens
          # - authorize/settle based on role
          # - write results to DynamoDB/SQS/S3 as configured by the application
          #
          # Return only non-sensitive identifiers.
          correlation_source = json.dumps(safe_event, sort_keys=True)[:2048]
          correlation_id = _stable_hash(correlation_source)

          return {
              "ok": True,
              "function_role": role,
              "correlation_id": correlation_id,
              "request_id": request_id
          }
    PY
    filename = "handler.py"
  }
}

resource "aws_lambda_function" "lambda" {
  for_each = local.lambda_functions

  function_name = "${local.name_prefix}-${each.key}"
  description   = each.value.description
  role          = aws_iam_role.lambda[each.key].arn

  runtime       = var.lambda_runtime
  handler       = each.value.handler
  architectures = var.lambda_architectures
  timeout       = var.lambda_timeout_seconds
  memory_size   = var.lambda_memory_mb

  filename         = data.archive_file.lambda_zip[each.key].output_path
  source_code_hash = data.archive_file.lambda_zip[each.key].output_base64sha256

  kms_key_arn = var.kms_key_arn

  reserved_concurrent_executions = var.lambda_reserved_concurrency

  environment {
    variables = merge(each.value.env, {
      LOG_LEVEL = "INFO"
    })
  }

  dynamic "vpc_config" {
    for_each = local.use_vpc ? [1] : []
    content {
      subnet_ids         = var.vpc_subnet_ids
      security_group_ids = var.vpc_security_group_ids
    }
  }

  tracing_config {
    mode = "Active"
  }

  depends_on = [
    aws_cloudwatch_log_group.lambda
  ]

  tags = local.common_tags
}

output "lambda_function_arns" {
  value = { for k, v in aws_lambda_function.lambda : k => v.arn }
}

output "lambda_role_arns" {
  value = { for k, v in aws_iam_role.lambda : k => v.arn }
}