resource "aws_iam_role" "this" {
  name                 = var.name
  path                 = var.path
  description          = var.description
  max_session_duration = var.max_session_duration
  assume_role_policy   = data.aws_iam_policy_document.assume_role.json
  permissions_boundary = var.permissions_boundary_arn
  tags                 = var.tags
}

resource "aws_iam_role_policy_attachment" "admin" {
  count      = var.policy_mode == "admin" ? 1 : 0
  role       = aws_iam_role.this.name
  policy_arn = "arn:aws:iam::aws:policy/AdministratorAccess"
}

resource "aws_iam_role_policy_attachment" "managed" {
  for_each = toset(var.policy_mode == "managed" || var.policy_mode == "mixed" ? var.managed_policy_arns : [])
  role     = aws_iam_role.this.name
  policy_arn = each.value
}

resource "aws_iam_policy" "custom" {
  count       = var.policy_mode == "custom" || var.policy_mode == "mixed" ? 1 : 0
  name        = "${var.name}-${var.custom_policy_name}"
  path        = var.path
  description = "Custom CI/CD deployment policy for ${var.name}"
  policy      = jsonencode(local.custom_policy_doc_clean)
  tags        = var.tags
}

resource "aws_iam_role_policy_attachment" "custom" {
  count      = var.policy_mode == "custom" || var.policy_mode == "mixed" ? 1 : 0
  role       = aws_iam_role.this.name
  policy_arn = aws_iam_policy.custom[0].arn
}

output "role_name" {
  value = aws_iam_role.this.name
}

output "role_arn" {
  value = aws_iam_role.this.arn
}

output "role_id" {
  value = aws_iam_role.this.id
}

output "custom_policy_arn" {
  value       = try(aws_iam_policy.custom[0].arn, null)
  description = "ARN of the custom policy if created."
}