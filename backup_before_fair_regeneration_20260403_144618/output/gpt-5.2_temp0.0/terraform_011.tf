data "aws_iam_policy_document" "assume_role" {
  dynamic "statement" {
    for_each = length(local.assume_principals) == 0 ? [] : [1]
    content {
      sid     = "AssumeRole"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      dynamic "principals" {
        for_each = local.assume_principals
        content {
          type        = principals.value.type
          identifiers = principals.value.identifiers
        }
      }

      dynamic "condition" {
        for_each = local.assume_conditions
        content {
          test     = condition.key
          variable = keys(condition.value)[0]
          values   = try(condition.value[keys(condition.value)[0]], [])
        }
      }
    }
  }

  dynamic "statement" {
    for_each = length(local.assume_principals) == 0 ? [1] : []
