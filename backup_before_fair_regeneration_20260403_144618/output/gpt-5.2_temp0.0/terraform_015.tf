# Generated by openai (gpt-5.2)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

provider "aws" {
  region = var.region
}

data "aws_partition" "current" {}
data "aws_region" "current" {}
data "aws_caller_identity" "current" {}

data "aws_ami" "al2023" {
  most_recent = true
  owners      = ["amazon"]

  filter {
    name   = "name"
    values = ["al2023-ami-*-x86_64"]
  }

  filter {
    name   = "architecture"
    values = ["x86_64"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
}

locals {
  backend_endpoints = join(",", var.backend_endpoints)

  user_data = <<-EOF
    #!/bin/bash
    set -euo pipefail

    APP_NAME="${var.app_name}"
    APP_USER="${var.app_user}"
    APP_GROUP="${var.app_group}"
    APP_DIR="${var.app_dir}"
    CONFIG_DIR="${var.config_dir}"
    LOG_DIR="${var.log_dir}"
    ENV_FILE="${var.env_file_path}"
    HEALTH_URL="${var.health_url}"
    BACKEND_ENDPOINTS="${local.backend_endpoints}"
    BACKEND_PORT="${var.backend_port}"
    AWS_REGION="${data.aws_region.current.name}"

    exec > >(tee -a /var/log/user-data.log | logger -t user-data -s 2>/dev/console) 2>&1

    echo "Bootstrapping ${var.app_name}..."

    if command -v dnf >/dev/null 2>&1; then
      PKG=dnf
    else
      PKG=yum
    fi

    $PKG -y update
    $PKG -y install curl jq awscli ca-certificates

    if ! id -u "$APP_USER" >/dev/null 2>&1; then
      groupadd -r "$APP_GROUP" || true
      useradd -r -g "$APP_GROUP" -d "$APP_DIR" -s /sbin/nologin "$APP_USER" || true
    fi

    mkdir -p "$APP_DIR" "$CONFIG_DIR" "$LOG_DIR"
    chown -R "$APP_USER:$APP_GROUP" "$APP_DIR" "$CONFIG_DIR" "$LOG_DIR"
    chmod 0755 "$APP_DIR" "$CONFIG_DIR"
    chmod 0755 "$LOG_DIR"

    cat > "$ENV_FILE" <<ENVVARS
    APP_NAME=${var.app_name}
    ENVIRONMENT=${var.environment}
    AWS_REGION=${data.aws_region.current.name}
    BACKEND_ENDPOINTS=${local.backend_endpoints}
    BACKEND_PORT=${var.backend_port}
    HEALTH_URL=${var.health_url}
    CONFIG_DIR=${var.config_dir}
    LOG_DIR=${var.log_dir}
    ENVVARS

    chmod 0640 "$ENV_FILE"
    chown "$APP_USER:$APP_GROUP" "$ENV_FILE"

    if [ -n "${var.ssm_parameter_prefix}" ]; then
      echo "Fetching SSM parameters under prefix: ${var.ssm_parameter_prefix}"
      PARAMS_JSON="$(aws ssm get-parameters-by-path --region "$AWS_REGION" --path "${var.ssm_parameter_prefix}" --with-decryption --recursive --output json || true)"
      if [ -n "$PARAMS_JSON" ]; then
        echo "$PARAMS_JSON" | jq -r '.Parameters[] | "\(.Name)=\(.Value)"' | while IFS='=' read -r k v; do
          key="$(basename "$k")"
          printf '%s=%q\n' "$key" "$v" >> "$ENV_FILE"
        done
      fi
    fi

    if [ -n "${var.secrets_manager_secret_arn}" ]; then
      echo "Fetching Secrets Manager secret: ${var.secrets_manager_secret_arn}"
      SECRET_STR="$(aws secretsmanager get-secret-value --region "$AWS_REGION" --secret-id "${var.secrets_manager_secret_arn}" --query SecretString --output text 2>/dev/null || true)"
      if [ -n "$SECRET_STR" ] && echo "$SECRET_STR" | jq -e . >/dev/null 2>&1; then
        echo "$SECRET_STR" | jq -r 'to_entries[] | "\(.key)=\(.value|tostring)"' | while IFS='=' read -r k v; do
          printf '%s=%q\n' "$k" "$v" >> "$ENV_FILE"
        done
      fi
    fi

    cat > /usr/local/bin/${var.app_name}-bootstrap <<'BOOT'
    #!/bin/bash
    set -euo pipefail
    source "${var.env_file_path}"

    wait_for_backend() {
      local endpoints_csv="$1"
      local port="$2"
      local timeout="${var.backend_wait_timeout_seconds}"
      local start
      start="$(date +%s)"

      IFS=',' read -r -a endpoints <<< "$endpoints_csv"
      for ep in "${endpoints[@]}"; do
        ep="$(echo "$ep" | xargs)"
        [ -z "$ep" ] && continue
        echo "Waiting for backend $ep:$port ..."
        while true; do
          if timeout 2 bash -c ">/dev/tcp/$ep/$port" 2>/dev/null; then
            echo "Backend reachable: $ep:$port"
            break
          fi
          now="$(date +%s)"
          if (( now - start > timeout )); then
            echo "Timed out waiting for backend $ep:$port after ${var.backend_wait_timeout_seconds}s"
            exit 1
          fi
          sleep 2
        done
      done
    }

    wait_for_health() {
      local url="$1"
      local timeout="${var.health_wait_timeout_seconds}"
      local start
      start="$(date +%s)"
      echo "Waiting for health URL: $url"
      while true; do
        if curl -fsS --max-time 2 "$url" >/dev/null 2>&1; then
          echo "Health check OK"
          return 0
        fi
        now="$(date +%s)"
        if (( now - start > timeout )); then
          echo "Timed out waiting for health URL after ${var.health_wait_timeout_seconds}s"
          return 1
        fi
        sleep 2
      done
    }

    if [ -n "${local.backend_endpoints}" ] && [ "${var.backend_port}" != "0" ]; then
      wait_for_backend "$BACKEND_ENDPOINTS" "$BACKEND_PORT"
    fi

    if [ -n "${var.health_url}" ]; then
      wait_for_health "$HEALTH_URL"
    fi

    exit 0
    BOOT

    chmod 0755 /usr/local/bin/${var.app_name}-bootstrap

    cat > /etc/systemd/system/${var.app_name}.service <<SERVICE
    [Unit]
    Description=${var.app_name} application
    After=network-online.target
    Wants=network-online.target

    [Service]
    Type=simple
    User=${var.app_user}
    Group=${var.app_group}
    EnvironmentFile=${var.env_file_path}
    WorkingDirectory=${var.app_dir}
    ExecStartPre=/usr/local/bin/${var.app_name}-bootstrap
    ExecStart=${var.app_start_command}
    Restart=always
    RestartSec=2
    StandardOutput=append:${var.log_dir}/${var.app_name}.log
    StandardError=append:${var.log_dir}/${var.app_name}.err

    [Install]
    WantedBy=multi-user.target
    SERVICE

    systemctl daemon-reload
    systemctl enable ${var.app_name}.service
    systemctl restart ${var.app_name}.service

    echo "Bootstrap complete."
  EOF
}

resource "aws_iam_role" "instance_role" {
  name               = "${var.name_prefix}-ec2-role"
  assume_role_policy = data.aws_iam_policy_document.instance_assume_role.json
}

data "aws_iam_policy_document" "instance_assume_role" {
  statement {
    effect = "Allow"
    principals {
      type        = "Service"
      identifiers = ["ec2.amazonaws.com"]
    }
    actions = ["sts:AssumeRole"]
  }
}

resource "aws_iam_role_policy" "instance_inline" {
  name = "${var.name_prefix}-ec2-inline"
  role = aws_iam_role.instance_role.id

  policy = data.aws_iam_policy_document.instance_policy.json
}

data "aws_iam_policy_document" "instance_policy" {
  statement {
    effect = "Allow"
    actions = [
      "ssm:GetParametersByPath",
      "ssm:GetParameter",
      "ssm:GetParameters",
      "kms:Decrypt"
    ]
    resources = ["*"]
    condition {
      test     = "StringEquals"
      variable = "aws:RequestedRegion"
      values   = [data.aws_region.current.name]
    }
  }

  statement {
    effect = "Allow"
    actions = [
      "secretsmanager:GetSecretValue",
      "secretsmanager:DescribeSecret"
    ]
    resources = ["*"]
  }

  statement {
    effect = "Allow"
    actions = [
      "logs:CreateLogStream",
      "logs:PutLogEvents",
      "logs:CreateLogGroup"
    ]
    resources = ["*"]
  }
}

resource "aws_iam_instance_profile" "instance_profile" {
  name = "${var.name_prefix}-ec2-profile"
  role = aws_iam_role.instance_role.name
}

resource "aws_launch_template" "app" {
  name_prefix   = "${var.name_prefix}-lt-"
  image_id      = var.ami_id != "" ? var.ami_id : data.aws_ami.al2023.id
  instance_type = var.instance_type
  key_name      = var.key_name != "" ? var.key_name : null

  vpc_security_group_ids = var.security_group_ids

  iam_instance_profile {
    name = aws_iam_instance_profile.instance_profile.name
  }

  user_data = base64encode(local.user_data)

  metadata_options {
    http_endpoint               = "enabled"
    http_tokens                 = "required"
    http_put_response_hop_limit = 2
  }

  monitoring {
    enabled = var.detailed_monitoring
  }

  block_device_mappings {
    device_name = "/dev/xvda"
    ebs {
      volume_size           = var.root_volume_size
      volume_type           = var.root_volume_type
      encrypted             = var.root_volume_encrypted
      delete_on_termination = true
    }
  }

  tag_specifications {
    resource_type = "instance"
    tags = merge(var.tags, {
      Name = "${var.name_prefix}-app"
    })
  }

  tag_specifications {
    resource_type = "volume"
    tags          = var.tags
  }

  tags = var.tags
}

resource "aws_autoscaling_group" "app" {
  name                      = "${var.name_prefix}-asg"
  max_size                  = var.asg_max_size
  min_size                  = var.asg_min_size
  desired_capacity          = var.asg_desired_capacity
  vpc_zone_identifier       = var.subnet_ids
  health_check_type         = var.health_check_type
  health_check_grace_period = var.health_check_grace_period
  termination_policies      = var.termination_policies

  launch_template {
    id      = aws_launch_template.app.id
    version = "$Latest"
  }

  dynamic "target_group_arns" {
    for_each = length(var.target_group_arns) > 0 ? [1] : []
    content  = var.target_group_arns
  }

  dynamic "tag" {
    for_each = merge(var.tags, { Name = "${var.name_prefix}-app" })
    content {
      key                 = tag.key
      value               = tag.value
      propagate_at_launch = true
    }
  }

  lifecycle {
    create_before_destroy = true
  }
}

