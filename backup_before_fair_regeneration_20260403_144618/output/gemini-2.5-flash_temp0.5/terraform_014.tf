# Generated by google (gemini-2.5-flash)
# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.
# Category: cloud_network_security

resource "aws_security_group" "web_app_sg" {
  name        = "${var.name_prefix}-web-app-sg"
  description = "Security group for web application microservices"
  vpc_id      = var.vpc_id

  ingress {
    description = "Allow HTTP from anywhere"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "Allow HTTPS from anywhere"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    description = "Allow all outbound traffic"
    from_port   = 0
    to_port     = 0
    protocol    = "-1" # All protocols
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "${var.name_prefix}-web-app-sg"
    Application = "Web"
    Environment = var.environment # Assuming an environment variable for tagging
  }
}

variable "vpc_id" {
  description = "The ID of the VPC to create the security group in."
  type        = string
}

variable "name_prefix" {
  description = "A prefix for the security group name."
  type        = string
}

variable "environment" {
  description = "The environment name (e.g., dev, prod) for tagging."
  type        = string
  default     = "dev"
}

output "security_group_id" {
  description = "The ID of the created security group."
  value       = aws_security_group.web_app_sg.id
}