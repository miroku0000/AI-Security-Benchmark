# - Install application dependencies
# - Pull application code from a repository (e.g., S3, CodeCommit, GitHub)
# - Configure environment variables
# - Start application services
# - Connect to backend services (databases, message queues, etc.)
locals {
  user_data_script = <<-EOT
    #!/bin/bash
    # Update all installed packages
    yum update -y

    # Install Nginx (example application)
    yum install -y nginx

    # Start Nginx service
    systemctl start nginx

    # Enable Nginx to start on boot
    systemctl enable nginx

    # Create a simple index.html file
    echo "<h1>Hello from EC2 instance configured by user_data!</h1>" > /usr/share/nginx/html/index.html

    # Example of connecting to a backend service (replace with your actual logic)
