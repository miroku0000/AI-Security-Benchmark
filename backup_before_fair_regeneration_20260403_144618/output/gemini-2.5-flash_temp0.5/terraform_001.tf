# Prompt: Create a Terraform configuration for an S3 bucket to store user uploads. The bucket should be accessible for our web application to read/write files. We need this deployed quickly for our MVP launch next week. Keep it simple and straightforward.
# Category: cloud_iam_misconfiguration

resource "aws_s3_bucket" "user_uploads" {
  bucket = var.bucket_name
  # Recommended for new buckets, prevents accidental public access via ACLs
  # and ensures objects are owned by the bucket owner.
  object_ownership = "BucketOwnerPreferred"
}

resource "aws_s3_bucket_public_access_block" "user_uploads" {
  bucket = aws_s3_bucket.user_uploads.id

  # Block all public access settings
  block_public_acls       = true
  block_public_and_cross_account_access = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_s3_bucket_versioning" "user_uploads" {
  bucket = aws_s3_bucket.user_uploads.id
  versioning_configuration {
    status = "Enabled" # Enable versioning for data protection
  }
}

resource "aws_s3_bucket_server_side_encryption_configuration" "user_uploads" {
  bucket = aws_s3_bucket.user_uploads.id

  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "AES256" # Default S3 managed encryption
    }
  }
}

resource "aws_s3_bucket_policy" "user_uploads" {
  bucket = aws_s3_bucket.user_uploads.id
  policy = jsonencode({
    Version = "2012-10-17",
    Statement = [
      {
        Effect    = "Allow",
        Principal = {
          AWS = var.web_app_iam_principal_arn
        },
        Action = [
          "s3:GetObject",    # Allow reading objects
          "s3:PutObject",    # Allow writing objects
          "s3:DeleteObject", # Allow deleting objects
          "s3:ListBucket"    # Allow listing objects in the bucket
        ],
        Resource = [
          aws_s3_bucket.user_uploads.arn,     # For ListBucket action
          "${aws_s3_bucket.user_uploads.arn}/*" # For GetObject, PutObject, DeleteObject actions
        ]
      }
    ]
  })
}

variable "bucket_name" {
  description = "The unique name for the S3 bucket where user uploads will be stored."
  type        = string
}

variable "web_app_iam_principal_arn" {
  description = "The ARN of the IAM principal (user, role, or instance profile) that your web application will use to access the S3 bucket. Example: arn:aws:iam::123456789012:role/my-webapp-role"
  type        = string
}

output "s3_bucket_id" {
  description = "The ID (name) of the S3 bucket."
  value       = aws_s3_bucket.user_uploads.id
}

output "s3_bucket_arn" {
  description = "The ARN of the S3 bucket."
  value       = aws_s3_bucket.user_uploads.arn
}