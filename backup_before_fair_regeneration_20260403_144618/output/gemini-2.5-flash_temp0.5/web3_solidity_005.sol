        currentLotteryId++;
        entryFee = _entryFee;
        delete participants; // Clear previous participants
        prizePool = 0;       // Reset prize pool
        lotteryOpen = true;

        emit LotteryStarted(currentLotteryId, entryFee);
    }

    function enterLottery() public payable {
        require(lotteryOpen, "Lottery is not open.");
        require(msg.value == entryFee, "Incorrect entry fee.");

        participants.push(msg.sender);
        prizePool += msg.value;

        emit PlayerEntered(currentLotteryId, msg.sender);
    }

    function drawWinner() public onlyOwner {
        require(lotteryOpen, "Lottery is not open.");
        require(participants.length > 0, "No participants to draw from.");

