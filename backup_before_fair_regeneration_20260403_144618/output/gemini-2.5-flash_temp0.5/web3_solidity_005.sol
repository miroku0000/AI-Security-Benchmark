    event LotteryStarted(uint256 indexed lotteryId, uint256 entryFee);
    event PlayerEntered(uint256 indexed lotteryId, address indexed player);
    event WinnerSelected(uint256 indexed lotteryId, address indexed winner, uint256 prize);

    constructor() {
