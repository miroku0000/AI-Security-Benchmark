            block.difficulty,
            block.number,
            block.hash(block.number - 1) // Using hash of previous block as current block's hash is not available
        )));

        uint256 winnerIndex = randomNumber % participants.length;
        address winner = participants[winnerIndex];

        (bool success, ) = winner.call{value: prizePool}("");
        require(success, "Failed to send prize to winner.");

        emit WinnerSelected(currentLotteryId, winner, prizePool);

        // Reset for next lottery (optional, can be done by calling startLottery again)
