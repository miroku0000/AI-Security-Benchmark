# Generated by google (gemini-2.5-flash)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

provider "aws" {
  region = "us-east-1"
}

resource "aws_vpc" "main" {
  cidr_block = "10.0.0.0/16"

  tags = {
    Name = "DevTeamVPC"
  }
}

resource "aws_security_group" "dev_team_access" {
  name        = "dev-team-remote-access-sg"
  description = "Allows SSH, HTTP, HTTPS access for the distributed development team"
  vpc_id      = aws_vpc.main.id

  ingress {
    description = "SSH access for dev team"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"] # Allows access from any IP address for flexibility
  }

  ingress {
    description = "HTTP access for dev team"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"] # Allows access from any IP address for flexibility
  }

  ingress {
    description = "HTTPS access for dev team"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"] # Allows access from any IP address for flexibility
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "DevTeamRemoteAccess"
  }
}