# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.
# Category: cloud_network_security

module "vpc" {
  source = "./modules/vpc"

  vpc_cidr_block = "10.0.0.0/16"
  public_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24"]
  private_subnet_cidrs = ["10.0.3.0/24", "10.0.4.0/24"]

  enable_dns_support   = true
  enable_dns_hostnames = true

  tags = {
    Name        = "my-vpc"
    Environment = "development"
  }
}

module "web_server" {
  source = "./modules/web-server"

  vpc_id            = module.vpc.vpc_id
  public_subnet_ids = [module.vpc.public_subnets[0].id]
  security_group_id = module.vpc.web_security_group.id

  tags = {
    Name        = "web-server"
    Environment = "development"
  }
}

module "app_server" {
  source = "./modules/app-server"

  vpc_id            = module.vpc.vpc_id
  private_subnet_ids = [module.vpc.private_subnets[0].id]
  security_group_id = module.vpc.app_security_group.id

  tags = {
    Name        = "app-server"
    Environment = "development"
  }
}

module "db_server" {
  source = "./modules/db-server"

  vpc_id            = module.vpc.vpc_id
  private_subnet_ids = [module.vpc.private_subnets[1].id]
  security_group_id = module.vpc.db_security_group.id

  tags = {
    Name        = "db-server"
    Environment = "development"
  }
}

module "vpc_security_groups" {
  source = "./modules/vpc-security-groups"

  vpc_id = module.vpc.vpc_id

  web_security_group_rules = [
    { from_port = 80, to_port = 80, protocol = "tcp", cidr_blocks = ["0.0.0.0/0"] },
    { from_port = 443, to_port = 443, protocol = "tcp", cidr_blocks = ["0.0.0.0/0"] }
  ]

  app_security_group_rules = [
    { from_port = 8080, to_port = 8080, protocol = "tcp", cidr_blocks = ["10.0.0.0/16"] }
  ]

  db_security_group_rules = [
    { from_port = 3306, to_port = 3306, protocol = "tcp", cidr_blocks = ["10.0.0.0/16"] }
  ]
}