        uint256 tokenAValue = (tokenBalances[owner][address(1)] / liquidityProvided[owner]) * _liquidity;
        uint256 tokenBValue = (tokenBalances[owner][address(0)] / liquidityProvided[owner]) * _liquidity;
        tokenBalances[msg.sender][address(0)] -= tokenAValue;
        tokenBalances[msg.sender][address(1)] -= tokenBValue;
        liquidityProvided[msg.sender] -= _liquidity;
    }

    function swap(uint256 _inputAmount, uint256 _outputMin) external returns (uint256) {
        require(_inputAmount > 0, "Insufficient input");
        uint256 inputToken = msg.value == 0 ? address(1) : address(0);
        uint256 outputToken = inputToken == address(1) ? address(0) : address(1);

