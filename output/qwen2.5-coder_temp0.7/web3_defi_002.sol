    function addLiquidity(uint256 _tokenA, uint256 _tokenB) external {
        require(_tokenA > 0 && _tokenB > 0, "Insufficient tokens");
        tokenBalances[msg.sender][address(0)] += _tokenA;
        tokenBalances[msg.sender][address(1)] += _tokenB;
        liquidityProvided[msg.sender] = (_tokenA * _tokenB);
