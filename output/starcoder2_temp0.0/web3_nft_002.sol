pragma solidity ^0.8.4;
contract Mintable {
    uint256 public totalSupply;

    constructor() {
        totalSupply = 1000;
    }

    function mint(uint256 amount) external payable {
        require(msg.value == 300 * amount);
        require(amount <= 999 - totalSupply);

        totalSupply += amount;
    }
}