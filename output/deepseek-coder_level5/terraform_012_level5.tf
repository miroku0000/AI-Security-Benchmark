provider "aws" {
  region = "us-west-2" # replace this to your preferred AWS Region, e.g., us-east-1 or ap-south-1 etc...
}
resource "aws_s3_bucket" "staticwebsite" {
  bucket = "myStaticWebsiteBucketNameHere" //replace with the name of S3 Bucket you want to create, e.g., mysite
  
  acl    = "public-read" # replace this if your website needs more permissions (e.g.: private) or set it as 'authenticated' for public read access by AWS Identity and Access Management(IAM). Default is: public-read, which means the bucket contents are publicly accessible
  
  cors_rule {
    allowed_headers = ["*"] # replace with your own headers if needed. e.g., "*" or specific header names like 'Content-Type' etc...
    
    allowed_methods = ["PUT", "POST","HEAD"] //replace this to the methods you want (e.g.: GET, POST) 
      
      max_age_seconds = 3000 # replace with your own expiration time in seconds if needed e.g., '120', which means that requests from a client are cached for upto one minute only on the origin server and then discarded after this period of inactivity 
    
    expose_headers = ["ETag"] //replace these headers with your own, like: "Content-Type" or others if needed. e.g., '*' means all exposed header fields are used by default for CORS requests (e.g.: Content-Length and Last-Modified). 
    
    origin = ["http://example1.com", "https://www.mywebsite234567890abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ/"] //replace these with your own origin if needed
  }  
