# Generated by ollama (qwen2.5-coder:14b)
# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.
# Category: cloud_network_security

provider "aws" {
  region = var.region
}

module "vpc" {
  source              = "terraform-aws-modules/vpc/aws"
  version             = "~> 3.0"
  name                = var.vpc_name
  cidr_block          = var.vpc_cidr_block
  azs                 = var.availability_zones
  public_subnets      = var.public_subnets
  private_subnets     = var.private_subnets
  enable_nat_gateway  = true
  single_nat_gateway  = true
  create_igw          = true
}

resource "aws_security_group" "web_sg" {
  name        = "${var.vpc_name}-web-sg"
  description = "Allow web traffic"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group" "app_sg" {
  name        = "${var.vpc_name}-app-sg"
  description = "Allow app traffic"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port   = var.app_ingress_from_port
    to_port     = var.app_ingress_to_port
    protocol    = "tcp"
    cidr_blocks = ["${aws_security_group.web_sg.id}/32"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group" "db_sg" {
  name        = "${var.vpc_name}-db-sg"
  description = "Allow database traffic"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port   = var.db_ingress_from_port
    to_port     = var.db_ingress_to_port
    protocol    = "tcp"
    cidr_blocks = ["${aws_security_group.app_sg.id}/32"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

variable "region" {
  description = "The AWS region to deploy the VPC in"
  type        = string
}

variable "vpc_name" {
  description = "Name of the VPC"
  type        = string
}

variable "vpc_cidr_block" {
  description = "CIDR block for the VPC"
  type        = string
}

variable "availability_zones" {
  description = "List of availability zones"
  type        = list(string)
}

variable "public_subnets" {
  description = "List of public subnet CIDR blocks"
  type        = list(string)
}

variable "private_subnets" {
  description = "List of private subnet CIDR blocks"
  type        = list(string)
}

variable "app_ingress_from_port" {
  description = "Start of the port range for app ingress traffic"
  type        = number
}

variable "app_ingress_to_port" {
  description = "End of the port range for app ingress traffic"
  type        = number
}

variable "db_ingress_from_port" {
  description = "Start of the port range for database ingress traffic"
  type        = number
}

variable "db_ingress_to_port" {
  description = "End of the port range for database ingress traffic"
  type        = number
}