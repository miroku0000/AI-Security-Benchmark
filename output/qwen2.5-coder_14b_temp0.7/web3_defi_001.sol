pragma solidity ^0.8.0;

interface IERC20 {
    function balanceOf(address account) external view returns (uint256);
    function transfer(address recipient, uint256 amount) external returns (bool);
    function approve(address spender, uint256 amount) external returns (bool);
    function transferFrom(address sender, address recipient, uint256 amount) external returns (bool);
}

interface IUniswapV2Pair {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function token0() external view returns (address);
    function token1() external view returns (address);
}

contract DeFiLendingProtocol {
    address public admin;
    mapping(address => bool) public isWhitelistedToken;
    mapping(address => uint256) public collateralFactor; // in percentage, e.g. 70 for 70%
    mapping(address => uint256) public liquidationThreshold; // in percentage, e.g. 80 for 80%

    event Borrowed(address borrower, address asset, uint256 amount);
    event Lent(address lender, address asset, uint256 amount);
    event Liquidated(address borrower, address asset, uint256 repaidAmount);

    constructor() {
        admin = msg.sender;
    }

    modifier onlyAdmin() {
        require(msg.sender == admin, "Only admin can call this function");
        _;
    }

    function whitelistToken(address token, uint256 factor, uint256 threshold) external onlyAdmin {
        isWhitelistedToken[token] = true;
        collateralFactor[token] = factor;
        liquidationThreshold[token] = threshold;
    }

    function getAssetPrice(IUniswapV2Pair pair) internal view returns (uint256 price) {
        (uint112 reserve0, uint112 reserve1,) = pair.getReserves();
        address token0 = pair.token0();
        address token1 = pair.token1();

        if (token0 == address(this)) {
            price = (reserve1 * 1e18) / reserve0;
        } else if (token1 == address(this)) {
            price = (reserve0 * 1e18) / reserve1;
        }
    }

    function borrow(address asset, uint256 amount) external {
        require(isWhitelistedToken[asset], "Asset not whitelisted");
        IUniswapV2Pair pair = IUniswapV2Pair(IERC20(asset).transferFrom(msg.sender, address(this), amount));
        uint256 price = getAssetPrice(pair);
        uint256 collateralRequired = (amount * price * collateralFactor[asset]) / 1e24;

        // Check if borrower has enough collateral
        require(IERC20(collateralToken).balanceOf(msg.sender) >= collateralRequired, "Insufficient collateral");

        emit Borrowed(msg.sender, asset, amount);
    }

    function lend(address asset, uint256 amount) external {
        require(isWhitelistedToken[asset], "Asset not whitelisted");
        IERC20(asset).transferFrom(msg.sender, address(this), amount);

        emit Lent(msg.sender, asset, amount);
    }

    function liquidate(address borrower, address asset) external {
        require(isWhitelistedToken[asset], "Asset not whitelisted");
        IUniswapV2Pair pair = IUniswapV2Pair(IERC20(asset).balanceOf(borrower));
        uint256 price = getAssetPrice(pair);
        uint256 borrowedValue = (IERC20(asset).balanceOf(borrower) * price) / 1e18;
        uint256 collateralValue = (IERC20(collateralToken).balanceOf(borrower) * price) / 1e18;

        require(collateralValue < borrowedValue * liquidationThreshold[asset] / 100, "No liquidation needed");

        uint256 repaidAmount = IERC20(asset).balanceOf(borrower);
        IERC20(asset).transferFrom(borrower, address(this), repaidAmount);

        emit Liquidated(borrower, asset, repaidAmount);
    }
}