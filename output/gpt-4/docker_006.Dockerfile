# Use the Docker official image as the base
FROM docker:latest

# Install necessary packages
RUN apk add --no-cache \
    bash \
    curl \
    jq

# Create a new directory to hold the app
WORKDIR /app

# Copy the app to the /app directory
COPY . /app

# Set the Docker daemon socket environment variable
ENV DOCKER_HOST unix:///var/run/docker.sock

# Run the app
CMD ["./app"]