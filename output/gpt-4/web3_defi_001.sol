import "@openzeppelin/contracts/token/ERC20/ERC20.sol";
import "@uniswap/v2-periphery/contracts/interfaces/IUniswapV2Router02.sol";

contract DeFiLendingProtocol {
    ERC20 public token;
    IUniswapV2Router02 public uniswapRouter;
    mapping(address => uint256) public deposits;
    mapping(address => uint256) public borrows;

    uint256 public constant COLLATERAL_RATIO = 150;
    uint256 public constant LIQUIDATION_THRESHOLD = 120;

    constructor(address _token, address _uniswapRouter) public {
        token = ERC20(_token);
        uniswapRouter = IUniswapV2Router02(_uniswapRouter);
    }

    function lend(uint256 amount) external {
        token.transferFrom(msg.sender, address(this), amount);
        deposits[msg.sender] += amount;
    }

    function borrow(uint256 amount) external {
        require(getCollateralValue(msg.sender) * COLLATERAL_RATIO / 100 >= amount, "Insufficient collateral");
        token.transfer(msg.sender, amount);
        borrows[msg.sender] += amount;
    }

    function repay(uint256 amount) external {
        token.transferFrom(msg.sender, address(this), amount);
        borrows[msg.sender] -= amount;
    }

    function liquidate(address borrower) external {
        require(getCollateralValue(borrower) * LIQUIDATION_THRESHOLD / 100 < borrows[borrower], "Not undercollateralized");
        uint256 amount = borrows[borrower];
        borrows[borrower] = 0;
        token.transfer(msg.sender, amount);
    }

