pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/math/SafeMath.sol";

contract DeFiLendingProtocol {
    using SafeMath for uint256;

    struct Loan {
        address borrower;
        IERC20 asset;
        uint256 amount;
        uint256 collateralAmount;
        uint256 borrowTime;
    }

    mapping(address => Loan[]) public loans;
    IERC20[] public supportedAssets;
    uint256 public collateralFactor = 75; // 75% collateral required

    constructor(IERC20[] memory _supportedAssets) {
        for (uint i = 0; i < _supportedAssets.length; i++) {
            supportedAssets.push(_supportedAssets[i]);
        }
    }

    function getAssetPrice(IERC20 asset, IERC20 usdPair) public view returns (uint256 price) {
        // Assume an on-chain DEX with a method to get the pool ratio
        (uint256 reserve0, uint256 reserve1,) = IUniswapV2Pair(address(usdPair)).getReserves();
        if (asset == usdPair) {
            return reserve0.div(reserve1);
        } else {
            return reserve1.div(reserve0);
        }
    }

    function borrow(IERC20 asset, uint256 amount) public {
        require(isSupportedAsset(asset), "Unsupported asset");
        uint256 collateralRequired = calculateCollateralRequirement(amount, asset);

        // Transfer collateral to contract
        asset.transferFrom(msg.sender, address(this), collateralRequired);
        loans[msg.sender].push(Loan({
            borrower: msg.sender,
            asset: asset,
            amount: amount,
            collateralAmount: collateralRequired,
            borrowTime: block.timestamp
        }));
    }

    function lend(IERC20 asset, uint256 amount) public {
        require(isSupportedAsset(asset), "Unsupported asset");
        asset.transferFrom(msg.sender, address(this), amount);
    }

    function repayLoan(IERC20 asset, uint256 loanIndex) public {
        Loan storage loan = loans[msg.sender][loanIndex];
        loan.asset.transferFrom(msg.sender, address(this), loan.amount);

        // Transfer collateral back to borrower
        loan.asset.transfer(msg.sender, loan.collateralAmount);
        delete loans[msg.sender][loanIndex];
    }

    function isSupportedAsset(IERC20 asset) public view returns (bool) {
        for (uint i = 0; i < supportedAssets.length; i++) {
            if (asset == supportedAssets[i]) {
                return true;
            }
        }
        return false;
    }

    function calculateCollateralRequirement(uint256 amount, IERC20 asset) public view returns (uint256) {
        uint256 price = getAssetPrice(asset, IERC20(address(0))); // Assuming USD as pair token for simplicity
        uint256 collateralAmount = price.mul(amount).mul(collateralFactor).div(100);
        return collateralAmount;
    }

    function calculateLiquidationThreshold(uint256 amount, IERC20 asset) public view returns (uint256) {
        uint256 liquidationPrice = getAssetPrice(asset, IERC20(address(0))); // Assuming USD as pair token for simplicity
        return liquidationPrice.mul(amount).mul(130).div(100); // Liquidate when price falls below 70% of collateral value
    }
}