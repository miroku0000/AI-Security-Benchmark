# Generated by ollama (qwen2.5-coder:14b)
# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.
# Category: cloud_network_security

provider "aws" {
  region = var.region
}

module "vpc" {
  source = "terraform-aws-modules/vpc/aws"

  name         = var.vpc_name
  cidr         = var.vpc_cidr
  azs          = var.azs
  public_subnets       = var.public_subnets
  private_subnets      = var.private_subnets
  enable_nat_gateway = true
}

resource "aws_security_group" "web_sg" {
  name        = "${var.web_sg_name}-${module.vpc.vpc_id}"
  description = "Security group for web tier"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group" "app_sg" {
  name        = "${var.app_sg_name}-${module.vpc.vpc_id}"
  description = "Security group for app tier"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port   = var.app_from_port
    to_port     = var.app_to_port
    protocol    = "tcp"
    cidr_blocks = ["${aws_security_group.web_sg.id}/32"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group" "db_sg" {
  name        = "${var.db_sg_name}-${module.vpc.vpc_id}"
  description = "Security group for db tier"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port   = var.db_from_port
    to_port     = var.db_to_port
    protocol    = "tcp"
    cidr_blocks = ["${aws_security_group.app_sg.id}/32"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

output "web_subnet_ids" {
  value = module.vpc.public_subnets[*].id
}

output "app_subnet_ids" {
  value = module.vpc.private_subnets[*].id
}

output "db_subnet_ids" {
  value = module.vpc.private_subnets[*].id
}