pragma solidity ^0.8.0;

import "@uniswap/v2-core/contracts/presets/UniswapV2Library.sol";
import "@openzeppelin/contracts/token/ERC20/SafeERC20.sol";

contract LendingProtocol {
    // Mapping of collateral tokens to their respective assets
    mapping(address => address) public collateralTokens;

    // Mapping of asset tokens to their respective prices
    mapping(address => uint256) public assetPrices;

    // Mapping of borrowers' addresses to their loan information
    mapping(address => LoanInfo) public borrowerLoans;

    // Mapping of lenders' addresses to their deposited assets
    mapping(address => mapping(address => uint256)) public lenderDeposits;

    struct LoanInfo {
        address collateralToken;
        address assetToken;
        uint256 principalAmount;
        uint256 interestRate;
        uint256 liquidationThreshold;
        bool isBorrower;
    }

    function borrowAsset(
        address _collateralToken,
        address _assetToken,
        uint256 _principalAmount
    ) public {
        // Get current pool ratios from UniswapV2Library
        (uint256 reserve0, uint256 reserve1) = UniswapV2Library.getReserves(address(0), _collateralToken, _assetToken);

        // Calculate collateral requirements based on current prices
        uint256 collateralRequired = (_principalAmount * 10000) / assetPrices[_assetToken];

        // Check if borrower has sufficient collateral
        require(lenderDeposits[msg.sender][_collateralToken] >= collateralRequired, "Insufficient Collateral");

        // Update loan information
        LoanInfo memory newLoan;
        newLoan.collateralToken = _collateralToken;
        newLoan.assetToken = _assetToken;
        newLoan.principalAmount = _principalAmount;
        newLoan.interestRate = 10; // fixed interest rate for simplicity
        newLoan.liquidationThreshold = (newLoan.principalAmount * 110) / 10000;
        borrowerLoans[msg.sender] = newLoan;

        // Transfer asset to borrower
        SafeERC20.safeTransferFrom(address(this), msg.sender, _assetToken, _principalAmount);
    }

    function lendAsset(
        address _collateralToken,
        address _assetToken,
        uint256 _amountToLend
    ) public {
        // Update lender's deposited assets
        lenderDeposits[msg.sender][_collateralToken] += _amountToLend;

        // Calculate asset price based on current pool ratios
        (uint256 reserve0, uint256 reserve1) = UniswapV2Library.getReserves(address(0), _collateralToken, _assetToken);
        assetPrices[_assetToken] = (_amountToLend * 10000) / reserve1;
    }

    function liquidateBorrower(
        address _borrower,
        uint256 _liquidationAmount
    ) public {
        // Get loan information for borrower
        LoanInfo storage loan = borrowerLoans[_borrower];

        // Calculate collateral value based on current prices
        (uint256 reserve0, uint256 reserve1) = UniswapV2Library.getReserves(address(0), loan.collateralToken, loan.assetToken);
        uint256 collateralValue = (_liquidationAmount * 10000) / reserve1;

        // Check if liquidation threshold is exceeded
        require(collateralValue > loan.liquidationThreshold, "Liquidation Threshold Not Exceeded");

        // Update borrower's loan information
        loan.isBorrower = false;
    }
}