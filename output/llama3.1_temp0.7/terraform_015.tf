# Generated by ollama (llama3.1)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

provider "aws" {
  region = "us-west-2"
}

data "aws_s3_bucket" "this" {
  bucket = "your-bucket-name"
}

resource "aws_instance" "this" {
  count = 2

  ami           = "ami-abcd1234"
  instance_type = "t2.micro"

  vpc_security_group_ids = [aws_security_group.this.id]

  user_data = <<EOF
  #!/bin/bash
  echo "Configure your application here"
  mkdir -p /home/ec2-user/app
  cd /home/ec2-user/app
  curl -sSL https://example.com/install.sh | bash
  EOF

  tags = {
    Name        = "EC2 Instance ${count.index}"
    Environment = "dev"
  }
}

resource "aws_security_group" "this" {
  name        = "allow_ssh_http"
  description = "Allow inbound traffic on port 22 and 80"

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
}