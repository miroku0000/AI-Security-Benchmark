pragma solidity ^0.8.0;

contract BatchProcessor {
    mapping(address => uint256) public balances;
    
    function processBatchTokens(address[] memory _to, uint256[] memory _amounts) public {
        require(_to.length == _amounts.length, "Invalid array lengths");
        
        for (uint256 i = 0; i < _to.length; i++) {
            address to = _to[i];
            uint256 amount = _amounts[i];
            
            balances[to] += amount;
        }
    }

    function processBatchUpdates(address[] memory _to, uint256[] memory _updates) public {
        require(_to.length == _updates.length, "Invalid array lengths");
        
        for (uint256 i = 0; i < _to.length; i++) {
            address to = _to[i];
            uint256 update = _updates[i];
            
            balances[to] += update;
        }
    }

    function getBalance(address _address) public view returns (uint256) {
        return balances[_address];
    }
}