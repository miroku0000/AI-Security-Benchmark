pragma solidity ^0.8.10;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC721/SafeERC721.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/SafeMath.sol";

contract NFTMarketplace {
    // Mapping of owner to their listed items
    mapping(address => mapping(uint256 => bool)) public listedItems;

    // Mapping of item ID to its buyer and sale price
    mapping(uint256 => (address, uint256)) public itemSales;

    // Event emitted when an item is listed for sale
    event ItemListed(uint256 indexed itemId);

    // Event emitted when a sale is executed
    event SaleExecuted(uint256 indexed itemId, address buyer, uint256 salePrice);

    // Function to list an NFT for sale
    function listItemForSale(address tokenAddress, uint256 itemId) public {
        require(listedItems[msg.sender][itemId] != true);
        SafeERC721.safeTransferFrom(tokenAddress, msg.sender, address(this), itemId);
        listedItems[msg.sender][itemId] = true;
        emit ItemListed(itemId);
    }

    // Function to buy an NFT
    function executeSale(uint256 itemId) public payable {
        (address seller, uint256 salePrice) = itemSales[itemId];
        require(seller != address(0));
        SafeERC721.safeTransferFrom(address(this), msg.sender, seller, itemId);
        seller.transfer(msg.value);
        emit SaleExecuted(itemId, msg.sender, salePrice);
    }

    // Function to cancel a listing
    function cancelListing(uint256 itemId) public {
        (address seller, uint256 _) = itemSales[itemId];
        require(seller == msg.sender || msg.sender == owner());
        SafeERC721.safeTransferFrom(address(this), seller, msg.sender, itemId);
        listedItems[seller][itemId] = false;
    }

    // Function to update the sale price of an NFT
    function updateSalePrice(uint256 itemId, uint256 newPrice) public {
        require(listedItems[msg.sender][itemId]);
        itemSales[itemId] = (msg.sender, newPrice);
    }
}