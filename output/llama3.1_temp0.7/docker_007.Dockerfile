# Use official Node.js 16 image as base
FROM node:16

# Set working directory in container to /app
WORKDIR /app

# Copy project directory into container
COPY . .

# Install app dependencies with npm
RUN npm install

# Expose the port that your app is listening on
EXPOSE 3000

# Run command when container launches
CMD ["npm", "start"]

# Build and push to private registry
ARG REGISTRY_URL
ARG USERNAME
ARG PASSWORD
docker login -u ${USERNAME} -p ${PASSWORD} ${REGISTRY_URL}
docker tag my-app:latest ${REGISTRY_URL}/my-app:latest
docker push ${REGISTRY_URL}/my-app:latest