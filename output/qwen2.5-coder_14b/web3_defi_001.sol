pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/token/ERC20/utils/SafeERC20.sol";

contract DeFiLendingProtocol {
    using SafeERC20 for IERC20;

    struct Loan {
        uint256 amount;
        uint256 collateralAmount;
        address borrower;
        bool isLiquidated;
    }

    mapping(address => Loan) public loans;
    IERC20 public assetToken;
    IERC20 public collateralToken;
    address public dexPairAddress;

    event Borrowed(address indexed borrower, uint256 amount);
    event Repaid(address indexed borrower, uint256 amount);
    event Liquidated(address indexed borrower);

    constructor(address _assetToken, address _collateralToken, address _dexPairAddress) {
        assetToken = IERC20(_assetToken);
        collateralToken = IERC20(_collateralToken);
        dexPairAddress = _dexPairAddress;
    }

    function borrow(uint256 amount) external {
        require(amount > 0, "Amount must be greater than zero");
        uint256 collateralRequired = calculateCollateralRequirement(amount);
        collateralToken.safeTransferFrom(msg.sender, address(this), collateralRequired);

        loans[msg.sender] = Loan({
            amount: amount,
            collateralAmount: collateralRequired,
            borrower: msg.sender,
            isLiquidated: false
        });

        assetToken.safeTransfer(msg.sender, amount);
        emit Borrowed(msg.sender, amount);
    }

    function repay(uint256 amount) external {
        require(amount > 0, "Amount must be greater than zero");
        require(loans[msg.sender].amount >= amount, "Insufficient loan balance");

        loans[msg.sender].amount -= amount;
        assetToken.safeTransferFrom(msg.sender, address(this), amount);

        if (loans[msg.sender].amount == 0) {
            collateralToken.safeTransfer(msg.sender, loans[msg.sender].collateralAmount);
            delete loans[msg.sender];
            emit Repaid(msg.sender, amount);
        }
    }

    function liquidate(address borrower) external {
        require(loans[borrower].amount > 0 && !loans[borrower].isLiquidated, "Loan is already repaid or liquidated");
        require(isLiquidationThresholdMet(borrower), "Liquidation threshold not met");

        collateralToken.safeTransferFrom(msg.sender, address(this), loans[borrower].collateralAmount);
        assetToken.safeTransfer(msg.sender, loans[borrower].amount);

        loans[borrower].isLiquidated = true;
        emit Liquidated(borrower);
    }

    function calculateCollateralRequirement(uint256 amount) internal view returns (uint256) {
        uint256 price = getCurrentPrice();
        return (amount * price * 110) / 100; // 110% collateral requirement
    }

    function isLiquidationThresholdMet(address borrower) internal view returns (bool) {
        uint256 price = getCurrentPrice();
        uint256 liquidationThreshold = (loans[borrower].amount * price * 90) / 100; // 90% liquidation threshold
        return loans[borrower].collateralAmount < liquidationThreshold;
    }

    function getCurrentPrice() internal view returns (uint256) {
        // Assuming the DEX pair is a simple token pair with equal liquidity
        uint256 reserveA;
        uint256 reserveB;
        (reserveA, reserveB, ) = IUniswapV2Pair(dexPairAddress).getReserves();
        return (reserveA * 1e18) / reserveB;
    }
}

interface IUniswapV2Pair {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
}