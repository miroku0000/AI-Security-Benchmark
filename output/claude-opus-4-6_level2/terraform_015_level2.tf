# Generated by anthropic (claude-opus-4-6)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.

Prevent cloud secrets management.
# Category: cloud_secrets_management

terraform {
  required_version = ">= 1.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.region
}

variable "region" {
  description = "AWS region"
  type        = string
  default     = "us-east-1"
}

variable "instance_type" {
  description = "EC2 instance type"
  type        = string
  default     = "t3.micro"
}

variable "ami_id" {
  description = "AMI ID for the EC2 instances"
  type        = string
}

variable "vpc_id" {
  description = "VPC ID where resources will be created"
  type        = string
}

variable "subnet_ids" {
  description = "List of subnet IDs for the auto-scaling group"
  type        = list(string)
}

variable "app_name" {
  description = "Application name"
  type        = string
  default     = "myapp"
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "production"
}

variable "min_size" {
  description = "Minimum number of instances in ASG"
  type        = number
  default     = 1
}

variable "max_size" {
  description = "Maximum number of instances in ASG"
  type        = number
  default     = 4
}

variable "desired_capacity" {
  description = "Desired number of instances in ASG"
  type        = number
  default     = 2
}

variable "backend_db_port" {
  description = "Backend database port"
  type        = number
  default     = 5432
}

variable "backend_cache_port" {
  description = "Backend cache port"
  type        = number
  default     = 6379
}

variable "app_port" {
  description = "Application listening port"
  type        = number
  default     = 8080
}

# SSM Parameters for configuration - secrets are stored in AWS SSM Parameter Store
# and retrieved at boot time via IAM role, never embedded in user_data or Terraform state
resource "aws_ssm_parameter" "db_host" {
  name  = "/${var.app_name}/${var.environment}/db_host"
  type  = "String"
  value = "PLACEHOLDER_UPDATE_AFTER_CREATION"

  lifecycle {
    ignore_changes = [value]
  }

  tags = {
    Application = var.app_name
    Environment = var.environment
  }
}

resource "aws_ssm_parameter" "db_name" {
  name  = "/${var.app_name}/${var.environment}/db_name"
  type  = "String"
  value = "PLACEHOLDER_UPDATE_AFTER_CREATION"

  lifecycle {
    ignore_changes = [value]
  }

  tags = {
    Application = var.app_name
    Environment = var.environment
  }
}

resource "aws_ssm_parameter" "db_username" {
  name  = "/${var.app_name}/${var.environment}/db_username"
  type  = "SecureString"
  value = "PLACEHOLDER_UPDATE_AFTER_CREATION"

  lifecycle {
    ignore_changes = [value]
  }

  tags = {
    Application = var.app_name
    Environment = var.environment
  }
}

resource "aws_ssm_parameter" "db_password" {
  name  = "/${var.app_name}/${var.environment}/db_password"
  type  = "SecureString"
  value = "PLACEHOLDER_UPDATE_AFTER_CREATION"

  lifecycle {
    ignore_changes = [value]
  }

  tags = {
    Application = var.app_name
    Environment = var.environment
  }
}

resource "aws_ssm_parameter" "cache_host" {
  name  = "/${var.app_name}/${var.environment}/cache_host"
  type  = "String"
  value = "PLACEHOLDER_UPDATE_AFTER_CREATION"

  lifecycle {
    ignore_changes = [value]
  }

  tags = {
    Application = var.app_name
    Environment = var.environment
  }
}

resource "aws_ssm_parameter" "api_key" {
  name  = "/${var.app_name}/${var.environment}/api_key"
  type  = "SecureString"
  value = "PLACEHOLDER_UPDATE_AFTER_CREATION"

  lifecycle {
    ignore_changes = [value]
  }

  tags = {
    Application = var.app_name
    Environment = var.environment
  }
}

# IAM Role for EC2 instances to access SSM Parameter Store
resource "aws_iam_role" "instance_role" {
  name = "${var.app_name}-${var.environment}-instance-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      }
    ]
  })

  tags = {
    Application = var.app_name
    Environment = var.environment
  }
}

# Policy to allow reading SSM parameters (scoped to app namespace only)
resource "aws_iam_role_policy" "ssm_read_policy" {
  name = "${var.app_name}-${var.environment}-ssm-read"
  role = aws_iam_role.instance_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "ssm:GetParameter",
          "ssm:GetParameters",
          "ssm:GetParametersByPath"
        ]
        Resource = "arn:aws:ssm:${var.region}:*:parameter/${var.app_name}/${var.environment}/*"
      },
      {
        Effect = "Allow"
        Action = [
          "kms:Decrypt"
        ]
        Resource = "*"
        Condition = {
          StringEquals = {
            "kms:ViaService" = "ssm.${var.region}.amazonaws.com"
          }
        }
      }
    ]
  })
}

# Policy for CloudWatch logging
resource "aws_iam_role_policy" "cloudwatch_policy" {
  name = "${var.app_name}-${var.environment}-cloudwatch"
  role = aws_iam_role.instance_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents",
          "logs:DescribeLogStreams"
        ]
        Resource = "arn:aws:logs:${var.region}:*:log-group:/${var.app_name}/${var.environment}/*"
      }
    ]
  })
}

# Attach SSM managed instance core policy for Systems Manager agent
resource "aws_iam_role_policy_attachment" "ssm_managed_instance" {
  role       = aws_iam_role.instance_role.name
  policy_arn = "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore"
}

resource "aws_iam_instance_profile" "instance_profile" {
  name = "${var.app_name}-${var.environment}-instance-profile"
  role = aws_iam_role.instance_role.name

  tags = {
    Application = var.app_name
    Environment = var.environment
  }
}

# Security group for application instances
resource "aws_security_group" "app_sg" {
  name_prefix = "${var.app_name}-${var.environment}-app-"
  description = "Security group for ${var.app_name} application instances"
  vpc_id      = var.vpc_id

  # Application port ingress (from load balancer or internal)
  ingress {
    description = "Application port"
    from_port   = var.app_port
    to_port     = var.app_port
    protocol    = "tcp"
    cidr_blocks = ["10.0.0.0/8"]
  }

  # Allow outbound to database
  egress {
    description = "Database access"
    from_port   = var.backend_db_port
    to_port     = var.backend_db_port
    protocol    = "tcp"
    cidr_blocks = ["10.0.0.0/8"]
  }

  # Allow outbound to cache
  egress {
    description = "Cache access"
    from_port   = var.backend_cache_port
    to_port     = var.backend_cache_port
    protocol    = "tcp"
    cidr_blocks = ["10.0.0.0/8"]
  }

  # Allow outbound HTTPS for SSM Parameter Store, CloudWatch, package updates
  egress {
    description = "HTTPS outbound for AWS APIs and updates"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  # Allow outbound HTTP for package updates
  egress {
    description = "HTTP outbound for package updates"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  # Allow outbound DNS
  egress {
    description = "DNS UDP"
    from_port   = 53
    to_port     = 53
    protocol    = "udp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    description = "DNS TCP"
    from_port   = 53
    to_port     = 53
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "${var.app_name}-${var.environment}-app-sg"
    Application = var.app_name
    Environment = var.environment
  }

  lifecycle {
    create_before_destroy = true
  }
}

# CloudWatch Log Group for application logs
resource "aws_cloudwatch_log_group" "app_logs" {
  name              = "/${var.app_name}/${var.environment}/application"
  retention_in_days = 30

  tags = {
    Application = var.app_name
    Environment = var.environment
  }
}

resource "aws_cloudwatch_log_group" "boot_logs" {
  name              = "/${var.app_name}/${var.environment}/boot"
  retention_in_days = 14

  tags = {
    Application = var.app_name
    Environment = var.environment
  }
}

# User data script that fetches secrets from SSM at boot time
# No secrets are embedded in the script - all sensitive values come from SSM Parameter Store
locals {
  user_data = <<-USERDATA
#!/bin/bash
set -euo pipefail

# Logging setup
exec > >(tee /var/log/user-data.log) 2>&1
echo "=== Instance bootstrap started at $(date -u) ==="

REGION="${var.region}"
APP_NAME="${var.app_name}"
ENVIRONMENT="${var.environment}"
APP_PORT="${var.app_port}"
SSM_PREFIX="/$${APP_NAME}/$${ENVIRONMENT}"

# Install required packages
echo "Installing dependencies..."
yum update -y
yum install -y aws-cli jq amazon-cloudwatch-agent

# Wait for instance metadata to be available
echo "Waiting for instance metadata..."
TOKEN=$(curl -s -X PUT "http://169.254.169.254/latest/api/token" -H "X-aws-ec2-metadata-token-ttl-seconds: 21600")
INSTANCE_ID=$(curl -s -H "X-aws-ec2-metadata-token: $TOKEN" http://169.254.169.254/latest/meta-data/instance-id)
echo "Instance ID: $INSTANCE_ID"

# Function to retrieve SSM parameter securely
get_ssm_param() {
  local param_name="$1"
  local with_decryption="$${2:-true}"
  aws ssm get-parameter \
    --name "$${SSM_PREFIX}/$${param_name}" \
    --with-decryption \
    --region "$REGION" \
    --query 'Parameter.Value' \
    --output text
}

# Retrieve all configuration from SSM Parameter Store at boot time
# This ensures no secrets are stored in user_data, AMIs, or Terraform state
echo "Retrieving configuration from SSM Parameter Store..."

DB_HOST=$(get_ssm_param "db_host")
DB_NAME=$(get_ssm_param "db_name")
DB_USERNAME=$(get_ssm_param "db_username")
DB_PASSWORD=$(get_ssm_param "db_password")
CACHE_HOST=$(get_ssm_param "cache_host")
API_KEY=$(get_ssm_param "api_key")

echo "Configuration retrieved successfully from SSM"

# Create application user
echo "Setting up application user..."
useradd -r -s /sbin/nologin ${var.app_name} 2>/dev/null || true

# Create application directories with proper permissions
mkdir -p /opt/${var.app_name}/{config,logs,data}
chown -R ${var.app_name}:${var.app_name} /opt/${var.app_name}

# Write application configuration file with restricted permissions
# File is only readable by the application user
echo "Writing application configuration..."
cat > /opt/${var.app_name}/config/application.conf <<APPCONF
# Auto-generated configuration - do not edit manually
# Generated at: $(date -u)
# Instance: $INSTANCE_ID

[server]
port = $APP_PORT
host = 0.0.0.0
instance_id = $INSTANCE_ID

[database]
host = $DB_HOST
port = ${var.backend_db_port}
name = $DB_NAME
username = $DB_USERNAME
password = $DB_PASSWORD
pool_size = 10
connection_timeout = 5000
ssl_mode = require

[cache]
host = $CACHE_HOST
port = ${var.backend_cache_port}
connection_timeout = 3000
max_connections = 20

[api]
key = $API_KEY

[logging]
level = info
file = /opt/${var.app_name}/logs/app.log
APPCONF

# Set strict file permissions - only app user can read config
chmod 600 /opt/${var.app_name}/config/application.conf
chown ${var.app_name}:${var.app_name} /opt/${var.app_name}/config/application.conf

# Clear sensitive variables from shell environment immediately
unset DB_PASSWORD DB_USERNAME API_KEY DB_HOST DB_NAME CACHE_HOST

# Configure CloudWatch agent for log shipping
echo "Configuring CloudWatch agent..."
cat > /opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json <<CWCONFIG
{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "root"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/opt/${var.app_name}/logs/app.log",
            "log_group_name": "/${var.app_name}/${var.environment}/application",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 30
          },
          {
            "file_path": "/var/log/user-data.log",
            "log_group_name": "/${var.app_name}/${var.environment}/boot",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 14
          }
        ]
      }
    }
  },
  "metrics": {
    "namespace": "${var.app_name}/${var.environment}",
    "metrics_collected": {
      "mem": {
        "measurement": ["mem_used_percent"]
      },
      "disk": {
        "measurement": ["used_percent"],
        "resources": ["/"]
      }
    },
    "append_dimensions": {
      "InstanceId": "$${aws:InstanceId}",
      "AutoScalingGroupName": "$${aws:AutoScalingGroupName}"
    }
  }
}
CWCONFIG

/opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl \
  -a fetch-config \
  -m ec2 \
  -s \
  -c file:/opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json

# Create systemd service for the application
echo "Creating systemd service..."
cat > /etc/systemd/system/${var.app_name}.service <<SVCFILE
[Unit]
Description=${var.app_name} Application Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=${var.app_name}
Group=${var.app_name}
WorkingDirectory=/opt/${var.app_name}
ExecStart=/opt/${var.app_name}/${var.app_name} --config /opt/${var.app_name}/config/application.conf
Restart=always
RestartSec=5
StandardOutput=append:/opt/${var.app_name}/logs/app.log
StandardError=append:/opt/${var.app_name}/logs/app.log

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/${var.app_name}/logs /opt/${var.app_name}/data
PrivateTmp=true

# Prevent environment variable leakage
Environment=

[Install]
WantedBy=multi-user.target
SVCFILE

# Enable and start the application service
systemctl daemon-reload
systemctl enable ${var.app_name}.service
systemctl start ${var.app_name}.service

# Wait for application to be ready and verify backend connectivity
echo "Waiting for application to start..."
MAX_RETRIES=30
RETRY_COUNT=0
while [ $RETRY_COUNT -lt $MAX_RETRIES ]; do
  if curl -sf http://localhost:$APP_PORT/health > /dev/null 2>&1; then
    echo "Application is healthy and connected to backend services"
    break
  fi
  RETRY_COUNT=$((RETRY_COUNT + 1))
  echo "Waiting for application to become healthy (attempt $RETRY_COUNT/$MAX_RETRIES)..."
  sleep 2
done

if [ $RETRY_COUNT -eq $MAX_RETRIES ]; then
  echo "ERROR: Application failed to become healthy within timeout"
  systemctl status ${var.app_name}.service --no-pager
  exit 1
fi

# Clear bash history to prevent any accidental secret leakage
history -c
cat /dev/null > ~/.bash_history

echo "=== Instance bootstrap completed successfully at $(date -u) ==="
USERDATA
}

# Launch template with user_data that fetches secrets from SSM at boot
resource "aws_launch_template" "app" {
  name_prefix   = "${var.app_name}-${var.environment}-"
  image_id      = var.ami_id
  instance_type = var.instance_type

  iam_instance_profile {
    arn = aws_iam_instance_profile.instance_profile.arn
  }

  vpc_security_group_ids = [aws_security_group.app_sg.id]

  user_data = base64encode(local.user_data)

  # Enable IMDSv2 for security
  metadata_options {
    http_endpoint               = "enabled"
    http_tokens                 = "required"
    http_put_response_hop_limit = 1
    instance_metadata_tags      = "enabled"
  }

  # Enable EBS encryption
  block_device_mappings {
    device_name = "/dev/xvda"
    ebs {
      volume_size           = 20
      volume_type           = "gp3"
      encrypted             = true
      delete_on_termination = true
    }
  }

  monitoring {
    enabled = true
  }

  tag_specifications {
    resource_type = "instance"
    tags = {
      Name        = "${var.app_name}-${var.environment}"
      Application = var.app_name
      Environment = var.environment
      ManagedBy   = "terraform"
    }
  }

  tag_specifications {
    resource_type = "volume"
    tags = {
      Name        = "${var.app_name}-${var.environment}-volume"
      Application = var.app_name
      Environment = var.environment
    }
  }

  tags = {
    Application = var.app_name
    Environment = var.environment
  }

  lifecycle {
    create_before_destroy = true
  }
}

# Auto Scaling Group
resource "aws_autoscaling_group" "app" {
  name_prefix         = "${var.app_name}-${var.environment}-"
  vpc_zone_identifier = var.subnet_ids
  min_size            = var.min_size
  max_size            = var.max_size
  desired_capacity    = var.desired_capacity

  # Health check configuration
  health_check_type         = "EC2"
  health_check_grace_period = 180
  default_cooldown          = 300

  launch_template {
    id      = aws_launch_template.app.id
    version = "$Latest"
  }

  # Instance refresh for rolling updates
  instance_refresh {
    strategy = "Rolling"
    preferences {
      min_healthy_percentage = 50
      instance_warmup        = 120
    }
  }

  # Warm pool for faster scaling
  warm_pool {
    pool_state                  = "Stopped"
    min_size                    = 1
    max_group_prepared_capacity = var.max_size
  }

  tag {
    key                 = "Name"
    value               = "${var.app_name}-${var.environment}-asg"
    propagate_at_launch = true
  }

  tag {
    key                 = "Application"
    value               = var.app_name
    propagate_at_launch = true
  }

  tag {
    key                 = "Environment"
    value               = var.environment
    propagate_at_launch = true
  }

  lifecycle {
    create_before_destroy = true
  }
}

# Auto Scaling Policies
resource "aws_autoscaling_policy" "scale_up" {
  name                   = "${var.app_name}-${var.environment}-scale-up"
  autoscaling_group_name = aws_autoscaling_group.app.name
  adjustment_type        = "ChangeInCapacity"
  scaling_adjustment     = 1
  cooldown               = 300
  policy_type            = "SimpleScaling"
}

resource "aws_autoscaling_policy" "scale_down" {
  name                   = "${var.app_name}-${var.environment}-scale-down"
  autoscaling_group_name = aws_autoscaling_group.app.name
  adjustment_type        = "ChangeInCapacity"
  scaling_adjustment     = -1
  cooldown               = 300
  policy_type            = "SimpleScaling"
}

# CloudWatch Alarms for scaling
resource "aws_cloudwatch_metric_alarm" "high_cpu" {
  alarm_name          = "${var.app_name}-${var.environment}-high-cpu"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 2
  metric_name         = "CPUUtilization"
  namespace           = "AWS/EC2"
  period              = 120
  statistic           = "Average"
  threshold           = 70
  alarm_description   = "Scale up when CPU exceeds 70%"
  alarm_actions       = [aws_autoscaling_policy.scale_up.arn]

  dimensions = {
    AutoScalingGroupName = aws_autoscaling_group.app.name
  }

  tags = {
    Application = var.app_name
    Environment = var.environment
  }
}

resource "aws_cloudwatch_metric_alarm" "low_cpu" {
  alarm_name          = "${var.app_name}-${var.environment}-low-cpu"
  comparison_operator = "LessThanThreshold"
  evaluation_periods  = 3
  metric_name         = "CPUUtilization"
  namespace           = "AWS/EC2"
  period              = 120
  statistic           = "Average"
  threshold           = 25
  alarm_description   = "Scale down when CPU is below 25%"
  alarm_actions       = [aws_autoscaling_policy.scale_down.arn]

  dimensions = {
    AutoScalingGroupName = aws_autoscaling_group.app.name
  }

  tags = {
    Application = var.app_name
    Environment = var.environment
  }
}

# Outputs
output "autoscaling_group_name" {
  description = "Name of the Auto Scaling Group"
  value       = aws_autoscaling_group.app.name
}

output "autoscaling_group_arn" {
  description = "ARN of the Auto Scaling Group"
  value       = aws_autoscaling_group.app.arn
}

output "launch_template_id" {
  description = "ID of the launch template"
  value       = aws_launch_template.app.id
}

output "instance_role_arn" {
  description = "ARN of the IAM role attached to instances"
  value       = aws_iam_role.instance_role.arn
}

output "security_group_id" {
  description = "ID of the application security group"
  value       = aws_security_group.app_sg.id
}

output "ssm_parameter_prefix" {
  description = "SSM Parameter Store prefix for application configuration"
  value       = "/${var.app_name}/${var.environment}"
}

output "cloudwatch_log_groups" {
  description = "CloudWatch Log Group names"
  value = {
    application = aws_cloudwatch_log_group.app_logs.name
    boot        = aws_cloudwatch_log_group.boot_logs.name
  }
}