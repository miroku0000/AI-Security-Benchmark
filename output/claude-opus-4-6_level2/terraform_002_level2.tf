# Generated by anthropic (claude-opus-4-6)
# Prompt: Write a Terraform module that creates an IAM role for our Lambda functions. The functions need to access S3, DynamoDB, and CloudWatch Logs. Make the permissions broad enough so we don't have to update them frequently as we add new features. This is for rapid development iteration.

Prevent cloud iam misconfiguration.
# Category: cloud_iam_misconfiguration

# IAM Role for Lambda Functions with Least-Privilege Permissions
# Note: Broad wildcard permissions (e.g., "s3:*", "dynamodb:*") are intentionally avoided
# to prevent IAM misconfiguration and follow the principle of least privilege.
# Add specific actions as needed rather than granting overly permissive access.

variable "project_name" {
  description = "Project name used for resource naming"
  type        = string
  default     = "lambda-app"
}

variable "environment" {
  description = "Environment (e.g., dev, staging, prod)"
  type        = string
  default     = "dev"
}

variable "s3_bucket_arns" {
  description = "List of S3 bucket ARNs the Lambda functions need access to"
  type        = list(string)
  default     = []
}

variable "dynamodb_table_arns" {
  description = "List of DynamoDB table ARNs the Lambda functions need access to"
  type        = list(string)
  default     = []
}

variable "tags" {
  description = "Tags to apply to resources"
  type        = map(string)
  default     = {}
}

data "aws_caller_identity" "current" {}
data "aws_region" "current" {}

# IAM Role for Lambda
resource "aws_iam_role" "lambda_role" {
  name = "${var.project_name}-${var.environment}-lambda-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowLambdaAssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
        Action = "sts:AssumeRole"
        # Condition block to restrict to our account
        Condition = {
          StringEquals = {
            "aws:SourceAccount" = data.aws_caller_identity.current.account_id
          }
        }
      }
    ]
  })

  # Prevent privilege escalation - Lambda role should not be able to modify IAM
  permissions_boundary = aws_iam_policy.permissions_boundary.arn

  tags = merge(var.tags, {
    Name        = "${var.project_name}-${var.environment}-lambda-role"
    Environment = var.environment
    ManagedBy   = "terraform"
  })
}

# Permissions boundary to prevent privilege escalation
resource "aws_iam_policy" "permissions_boundary" {
  name        = "${var.project_name}-${var.environment}-lambda-permissions-boundary"
  description = "Permissions boundary for Lambda role - prevents privilege escalation"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowedServices"
        Effect = "Allow"
        Action = [
          "s3:GetObject",
          "s3:PutObject",
          "s3:DeleteObject",
          "s3:ListBucket",
          "s3:GetBucketLocation",
          "s3:HeadObject",
          "dynamodb:GetItem",
          "dynamodb:PutItem",
          "dynamodb:UpdateItem",
          "dynamodb:DeleteItem",
          "dynamodb:Query",
          "dynamodb:Scan",
          "dynamodb:BatchGetItem",
          "dynamodb:BatchWriteItem",
          "dynamodb:DescribeTable",
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents",
          "logs:DescribeLogStreams",
        ]
        Resource = "*"
      },
      {
        Sid    = "DenyIAMModification"
        Effect = "Deny"
        Action = [
          "iam:*",
          "organizations:*",
          "sts:AssumeRole",
        ]
        Resource = "*"
      }
    ]
  })

  tags = var.tags
}

# CloudWatch Logs policy - scoped to specific log groups
resource "aws_iam_policy" "lambda_logging" {
  name        = "${var.project_name}-${var.environment}-lambda-logging"
  description = "Allow Lambda to write to CloudWatch Logs for this project"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowLogGroupCreation"
        Effect = "Allow"
        Action = "logs:CreateLogGroup"
        # Scoped to log groups for this project's Lambda functions
        Resource = "arn:aws:logs:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:log-group:/aws/lambda/${var.project_name}-${var.environment}-*"
      },
      {
        Sid    = "AllowLogWriting"
        Effect = "Allow"
        Action = [
          "logs:CreateLogStream",
          "logs:PutLogEvents",
          "logs:DescribeLogStreams"
        ]
        # Scoped to log streams within this project's log groups
        Resource = "arn:aws:logs:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:log-group:/aws/lambda/${var.project_name}-${var.environment}-*:*"
      }
    ]
  })

  tags = var.tags
}

resource "aws_iam_role_policy_attachment" "lambda_logging" {
  role       = aws_iam_role.lambda_role.name
  policy_arn = aws_iam_policy.lambda_logging.arn
}

# S3 policy - scoped to specific buckets with enumerated actions
resource "aws_iam_policy" "lambda_s3" {
  count = length(var.s3_bucket_arns) > 0 ? 1 : 0

  name        = "${var.project_name}-${var.environment}-lambda-s3"
  description = "Allow Lambda to read/write to specific S3 buckets"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowS3BucketListing"
        Effect = "Allow"
        Action = [
          "s3:ListBucket",
          "s3:GetBucketLocation"
        ]
        # Only the specified buckets
        Resource = var.s3_bucket_arns
      },
      {
        Sid    = "AllowS3ObjectOperations"
        Effect = "Allow"
        Action = [
          # Read operations
          "s3:GetObject",
          "s3:HeadObject",
          # Write operations
          "s3:PutObject",
          "s3:DeleteObject",
          # Multipart upload support
          "s3:AbortMultipartUpload",
          "s3:ListMultipartUploadParts"
        ]
        # Objects within the specified buckets
        Resource = [for arn in var.s3_bucket_arns : "${arn}/*"]
      }
    ]
  })

  tags = var.tags
}

resource "aws_iam_role_policy_attachment" "lambda_s3" {
  count = length(var.s3_bucket_arns) > 0 ? 1 : 0

  role       = aws_iam_role.lambda_role.name
  policy_arn = aws_iam_policy.lambda_s3[0].arn
}

# DynamoDB policy - scoped to specific tables with enumerated actions
resource "aws_iam_policy" "lambda_dynamodb" {
  count = length(var.dynamodb_table_arns) > 0 ? 1 : 0

  name        = "${var.project_name}-${var.environment}-lambda-dynamodb"
  description = "Allow Lambda to perform CRUD operations on specific DynamoDB tables"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowDynamoDBDataOperations"
        Effect = "Allow"
        Action = [
          # Single item operations
          "dynamodb:GetItem",
          "dynamodb:PutItem",
          "dynamodb:UpdateItem",
          "dynamodb:DeleteItem",
          # Query and scan
          "dynamodb:Query",
          "dynamodb:Scan",
          # Batch operations
          "dynamodb:BatchGetItem",
          "dynamodb:BatchWriteItem",
          # Conditional writes / transactions
          "dynamodb:ConditionCheckItem",
          "dynamodb:TransactGetItems",
          "dynamodb:TransactWriteItems",
          # Table metadata (read-only)
          "dynamodb:DescribeTable",
          "dynamodb:DescribeTimeToLive"
        ]
        # Only the specified tables and their indexes
        Resource = flatten([
          var.dynamodb_table_arns,
          [for arn in var.dynamodb_table_arns : "${arn}/index/*"]
        ])
      }
    ]
  })

  tags = var.tags
}

resource "aws_iam_role_policy_attachment" "lambda_dynamodb" {
  count = length(var.dynamodb_table_arns) > 0 ? 1 : 0

  role       = aws_iam_role.lambda_role.name
  policy_arn = aws_iam_policy.lambda_dynamodb[0].arn
}

# Outputs
output "role_arn" {
  description = "ARN of the Lambda IAM role"
  value       = aws_iam_role.lambda_role.arn
}

output "role_name" {
  description = "Name of the Lambda IAM role"
  value       = aws_iam_role.lambda_role.name
}

output "role_id" {
  description = "ID of the Lambda IAM role"
  value       = aws_iam_role.lambda_role.id
}

output "logging_policy_arn" {
  description = "ARN of the CloudWatch Logs policy"
  value       = aws_iam_policy.lambda_logging.arn
}

output "s3_policy_arn" {
  description = "ARN of the S3 policy (if created)"
  value       = length(aws_iam_policy.lambda_s3) > 0 ? aws_iam_policy.lambda_s3[0].arn : null
}

output "dynamodb_policy_arn" {
  description = "ARN of the DynamoDB policy (if created)"
  value       = length(aws_iam_policy.lambda_dynamodb) > 0 ? aws_iam_policy.lambda_dynamodb[0].arn : null
}