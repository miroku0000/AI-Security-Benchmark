# Generated by anthropic (claude-opus-4-6)
# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.

Prevent cloud network security.
# Category: cloud_network_security

# variables.tf
variable "vpc_id" {
  description = "VPC ID where security groups will be created"
  type        = string
}

variable "environment" {
  description = "Environment name (e.g., dev, staging, prod)"
  type        = string
  default     = "dev"
}

variable "application_name" {
  description = "Name of the web application"
  type        = string
  default     = "web-app"
}

variable "allowed_cidr_blocks" {
  description = "CIDR blocks allowed for HTTP/HTTPS ingress. Use specific ranges instead of 0.0.0.0/0 where possible."
  type        = list(string)
  default     = ["0.0.0.0/0"]
}

variable "restrict_outbound" {
  description = "Whether to restrict outbound traffic to specific ports (recommended for production)"
  type        = bool
  default     = true
}

variable "allowed_outbound_ports" {
  description = "List of allowed outbound ports when restrict_outbound is true"
  type        = list(number)
  default     = [443, 53, 5432, 6379]
  # 443 = HTTPS APIs, 53 = DNS, 5432 = PostgreSQL, 6379 = Redis
}

variable "allowed_outbound_cidrs" {
  description = "CIDR blocks for restricted outbound traffic"
  type        = list(string)
  default     = ["0.0.0.0/0"]
}

variable "tags" {
  description = "Additional tags for resources"
  type        = map(string)
  default     = {}
}

# main.tf
locals {
  common_tags = merge(var.tags, {
    Environment = var.environment
    Application = var.application_name
    ManagedBy   = "terraform"
  })
}

resource "aws_security_group" "web_alb" {
  name_prefix = "${var.application_name}-${var.environment}-alb-"
  description = "Security group for web application load balancer - allows HTTP/HTTPS ingress"
  vpc_id      = var.vpc_id

  tags = merge(local.common_tags, {
    Name = "${var.application_name}-${var.environment}-alb-sg"
    Tier = "public"
  })

  lifecycle {
    create_before_destroy = true
  }
}

# Inbound HTTP
resource "aws_security_group_rule" "alb_ingress_http" {
  type              = "ingress"
  from_port         = 80
  to_port           = 80
  protocol          = "tcp"
  cidr_blocks       = var.allowed_cidr_blocks
  security_group_id = aws_security_group.web_alb.id
  description       = "Allow HTTP inbound traffic"
}

# Inbound HTTPS
resource "aws_security_group_rule" "alb_ingress_https" {
  type              = "ingress"
  from_port         = 443
  to_port           = 443
  protocol          = "tcp"
  cidr_blocks       = var.allowed_cidr_blocks
  security_group_id = aws_security_group.web_alb.id
  description       = "Allow HTTPS inbound traffic"
}

# ALB outbound to application tier only
resource "aws_security_group_rule" "alb_egress_to_app" {
  type                     = "egress"
  from_port                = 8080
  to_port                  = 8080
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.web_app.id
  security_group_id        = aws_security_group.web_alb.id
  description              = "Allow outbound to application tier"
}

# Application tier security group
resource "aws_security_group" "web_app" {
  name_prefix = "${var.application_name}-${var.environment}-app-"
  description = "Security group for web application instances/containers"
  vpc_id      = var.vpc_id

  tags = merge(local.common_tags, {
    Name = "${var.application_name}-${var.environment}-app-sg"
    Tier = "application"
  })

  lifecycle {
    create_before_destroy = true
  }
}

# App ingress from ALB only
resource "aws_security_group_rule" "app_ingress_from_alb" {
  type                     = "ingress"
  from_port                = 8080
  to_port                  = 8080
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.web_alb.id
  security_group_id        = aws_security_group.web_app.id
  description              = "Allow inbound from ALB only"
}

# App ingress from other microservices in same security group
resource "aws_security_group_rule" "app_ingress_from_self" {
  type              = "ingress"
  from_port         = 8080
  to_port           = 8099
  protocol          = "tcp"
  self              = true
  security_group_id = aws_security_group.web_app.id
  description       = "Allow inter-microservice communication"
}

# RESTRICTED outbound (recommended) - per-port rules
resource "aws_security_group_rule" "app_egress_restricted" {
  count = var.restrict_outbound ? length(var.allowed_outbound_ports) : 0

  type              = "egress"
  from_port         = var.allowed_outbound_ports[count.index]
  to_port           = var.allowed_outbound_ports[count.index]
  protocol          = "tcp"
  cidr_blocks       = var.allowed_outbound_cidrs
  security_group_id = aws_security_group.web_app.id
  description       = "Allow outbound on port ${var.allowed_outbound_ports[count.index]}"
}

# DNS UDP outbound (needed for name resolution)
resource "aws_security_group_rule" "app_egress_dns_udp" {
  count = var.restrict_outbound ? 1 : 0

  type              = "egress"
  from_port         = 53
  to_port           = 53
  protocol          = "udp"
  cidr_blocks       = var.allowed_outbound_cidrs
  security_group_id = aws_security_group.web_app.id
  description       = "Allow DNS UDP outbound"
}

# Microservice-to-microservice egress (self)
resource "aws_security_group_rule" "app_egress_self" {
  type              = "egress"
  from_port         = 8080
  to_port           = 8099
  protocol          = "tcp"
  self              = true
  security_group_id = aws_security_group.web_app.id
  description       = "Allow outbound to other microservices"
}

# UNRESTRICTED outbound (use only if restrict_outbound = false)
resource "aws_security_group_rule" "app_egress_all" {
  count = var.restrict_outbound ? 0 : 1

  type              = "egress"
  from_port         = 0
  to_port           = 0
  protocol          = "-1"
  cidr_blocks       = ["0.0.0.0/0"]
  security_group_id = aws_security_group.web_app.id
  description       = "Allow all outbound - NOT RECOMMENDED for production"
}

# outputs.tf
output "alb_security_group_id" {
  description = "Security group ID for the ALB"
  value       = aws_security_group.web_alb.id
}

output "app_security_group_id" {
  description = "Security group ID for the application tier"
  value       = aws_security_group.web_app.id
}

output "alb_security_group_arn" {
  description = "Security group ARN for the ALB"
  value       = aws_security_group.web_alb.arn
}

output "app_security_group_arn" {
  description = "Security group ARN for the application tier"
  value       = aws_security_group.web_app.arn
}

output "security_posture_warning" {
  description = "Security posture information"
  value       = var.restrict_outbound ? "Outbound traffic is restricted to specific ports - GOOD" : "WARNING: All outbound traffic is allowed - consider restricting for production"
}