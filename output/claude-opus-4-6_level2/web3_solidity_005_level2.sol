import "@openzeppelin/contracts/security/Pausable.sol";

/**
 * @title SecureLottery
 * @notice A lottery/randomized reward system for a blockchain gaming platform.
 * 
 * IMPORTANT SECURITY NOTE:
 * On-chain randomness using block.timestamp or blockhash is inherently insecure
 * because miners/validators can manipulate these values. This contract implements
 * a commit-reveal scheme to mitigate smart contract manipulation of randomness.
 * 
 * For production use, integrate Chainlink VRF or another verifiable random function oracle.
 * The commit-reveal scheme here prevents other smart contracts from predicting outcomes
 * within the same transaction, but does NOT prevent miner/validator manipulation.
 */
contract SecureLottery is Ownable, ReentrancyGuard, Pausable {

    // ============ Structs ============

    struct LotteryRound {
        uint256 roundId;
        uint256 ticketPrice;
        uint256 maxTickets;
        uint256 ticketsSold;
        uint256 prizePool;
        uint256 startTime;
        uint256 endTime;
        uint256 revealDeadline;
        address winner;
        bool finalized;
        bool cancelled;
    }

    struct Commitment {
        bytes32 commitHash;
        uint256 commitBlock;
        bool revealed;
        bool used;
    }

    // ============ State Variables ============

    uint256 public currentRoundId;
    uint256 public platformFeePercent = 5; // 5% platform fee
    uint256 public constant MAX_FEE_PERCENT = 10;
    uint256 public constant MIN_REVEAL_DELAY = 2; // Minimum blocks between commit and reveal
    uint256 public constant MAX_REVEAL_DELAY = 256; // blockhash only available for last 256 blocks
    uint256 public constant REVEAL_WINDOW = 1 hours;

    mapping(uint256 => LotteryRound) public rounds;
    mapping(uint256 => address[]) public roundTickets;
    mapping(uint256 => mapping(address => uint256)) public userTicketCount;
    mapping(address => Commitment) public commitments;

    uint256 public accumulatedFees;

    // Entropy accumulator - combines multiple sources
    bytes32 private entropyAccumulator;

    // ============ Events ============

    event RoundCreated(uint256 indexed roundId, uint256 ticketPrice, uint256 maxTickets, uint256 endTime);
    event TicketPurchased(uint256 indexed roundId, address indexed buyer, uint256 ticketCount);
    event CommitmentMade(address indexed user, bytes32 commitHash, uint256 commitBlock);
    event RevealAndFinalize(uint256 indexed roundId, address indexed winner, uint256 prize);
    event RoundCancelled(uint256 indexed roundId);
    event RefundClaimed(uint256 indexed roundId, address indexed user, uint256 amount);
    event FeesWithdrawn(address indexed to, uint256 amount);
    event RewardDistributed(address indexed recipient, uint256 amount, string rewardType);

    // ============ Modifiers ============

    modifier onlyEOA() {
        require(msg.sender == tx.origin, "Smart contracts cannot participate directly");
        _;
    }

    modifier roundExists(uint256 _roundId) {
        require(rounds[_roundId].startTime != 0, "Round does not exist");
        _;
    }

    // ============ Constructor ============

    constructor() {
        entropyAccumulator = keccak256(abi.encodePacked(block.timestamp, block.prevrandao, msg.sender));
    }

    // ============ Admin Functions ============

    /**
     * @notice Create a new lottery round
     * @param _ticketPrice Price per ticket in wei
     * @param _maxTickets Maximum number of tickets
     * @param _duration Duration of the round in seconds
     */
    function createRound(
        uint256 _ticketPrice,
        uint256 _maxTickets,
        uint256 _duration
    ) external onlyOwner whenNotPaused {
        require(_ticketPrice > 0, "Ticket price must be > 0");
        require(_maxTickets > 1, "Need at least 2 tickets");
        require(_duration >= 1 hours, "Duration too short");

        currentRoundId++;
        uint256 endTime = block.timestamp + _duration;

        rounds[currentRoundId] = LotteryRound({
            roundId: currentRoundId,
            ticketPrice: _ticketPrice,
            maxTickets: _maxTickets,
            ticketsSold: 0,
            prizePool: 0,
            startTime: block.timestamp,
            endTime: endTime,
            revealDeadline: endTime + REVEAL_WINDOW,
            winner: address(0),
            finalized: false,
            cancelled: false
        });

        emit RoundCreated(currentRoundId, _ticketPrice, _maxTickets, endTime);
    }

    /**
     * @notice Cancel a round (only if not finalized)
     */
    function cancelRound(uint256 _roundId) external onlyOwner roundExists(_roundId) {
        LotteryRound storage round = rounds[_roundId];
        require(!round.finalized, "Round already finalized");
        require(!round.cancelled, "Round already cancelled");

        round.cancelled = true;
        emit RoundCancelled(_roundId);
    }

    function setPlatformFee(uint256 _feePercent) external onlyOwner {
        require(_feePercent <= MAX_FEE_PERCENT, "Fee too high");
        platformFeePercent = _feePercent;
    }

    function withdrawFees(address payable _to) external onlyOwner {
        require(accumulatedFees > 0, "No fees to withdraw");
        uint256 amount = accumulatedFees;
        accumulatedFees = 0;
        (bool success, ) = _to.call{value: amount}("");
        require(success, "Transfer failed");
        emit FeesWithdrawn(_to, amount);
    }

    function pause() external onlyOwner {
        _pause();
    }

    function unpause() external onlyOwner {
        _unpause();
    }

    // ============ User Functions ============

    /**
     * @notice Purchase tickets for a lottery round
     * @param _roundId The round to purchase tickets for
     * @param _ticketCount Number of tickets to purchase
     */
    function purchaseTickets(uint256 _roundId, uint256 _ticketCount)
        external
        payable
        nonReentrant
        whenNotPaused
        onlyEOA
        roundExists(_roundId)
    {
        LotteryRound storage round = rounds[_roundId];
        require(!round.cancelled, "Round cancelled");
        require(!round.finalized, "Round finalized");
        require(block.timestamp < round.endTime, "Round ended");
        require(_ticketCount > 0, "Must buy at least 1 ticket");
        require(round.ticketsSold + _ticketCount <= round.maxTickets, "Exceeds max tickets");
        require(msg.value == round.ticketPrice * _ticketCount, "Incorrect payment");

        for (uint256 i = 0; i < _ticketCount; i++) {
            roundTickets[_roundId].push(msg.sender);
        }

        round.ticketsSold += _ticketCount;
        round.prizePool += msg.value;
        userTicketCount[_roundId][msg.sender] += _ticketCount;

        // Add entropy from each purchase
        entropyAccumulator = keccak256(
            abi.encodePacked(entropyAccumulator, msg.sender, block.timestamp, round.ticketsSold)
        );

        emit TicketPurchased(_roundId, msg.sender, _ticketCount);
    }

    /**
     * @notice Phase 1 of commit-reveal: Submit a commitment hash
     * @dev The commitment prevents same-transaction randomness exploitation.
     *      User commits hash(secret) now, then reveals secret later.
     * @param _commitHash keccak256(abi.encodePacked(secret, msg.sender))
     */
    function commitRandomness(bytes32 _commitHash) external onlyEOA whenNotPaused {
        require(_commitHash != bytes32(0), "Invalid commit hash");
        require(!commitments[msg.sender].used || commitments[msg.sender].revealed, "Previous commitment pending");

        commitments[msg.sender] = Commitment({
            commitHash: _commitHash,
            commitBlock: block.number,
            revealed: false,
            used: true
        });

        emit CommitmentMade(msg.sender, _commitHash, block.number);
    }

    /**
     * @notice Phase 2 of commit-reveal: Reveal the secret and finalize the round
     * @dev Must be called after MIN_REVEAL_DELAY blocks and before MAX_REVEAL_DELAY blocks
     * @param _roundId The round to finalize
     * @param _secret The secret that was committed
     */
    function revealAndFinalize(uint256 _roundId, bytes32 _secret)
        external
        nonReentrant
        whenNotPaused
        onlyEOA
        roundExists(_roundId)
    {
        LotteryRound storage round = rounds[_roundId];
        require(!round.finalized, "Already finalized");
        require(!round.cancelled, "Round cancelled");
        require(block.timestamp >= round.endTime, "Round not ended");
        require(block.timestamp <= round.revealDeadline, "Reveal deadline passed");
        require(round.ticketsSold > 0, "No tickets sold");

        // Verify commitment
        Commitment storage commitment = commitments[msg.sender];
        require(commitment.used, "No commitment found");
        require(!commitment.revealed, "Already revealed");
        require(
            block.number >= commitment.commitBlock + MIN_REVEAL_DELAY,
            "Reveal too early - wait more blocks"
        );
        require(
            block.number <= commitment.commitBlock + MAX_REVEAL_DELAY,
            "Reveal too late - blockhash expired, recommit"
        );

        // Verify the secret matches the commitment
        bytes32 expectedHash = keccak256(abi.encodePacked(_secret, msg.sender));
        require(expectedHash == commitment.commitHash, "Invalid secret");

        commitment.revealed = true;

        // Generate random number using multiple entropy sources
        // This combines:
        // 1. The revealed secret (unknown at commit time)
        // 2. The blockhash of the commit block (unknown at commit time)
        // 3. Accumulated entropy from all ticket purchases
        // 4. Current block data
        bytes32 commitBlockHash = blockhash(commitment.commitBlock);
        require(commitBlockHash != bytes32(0), "Commit block hash unavailable");

        uint256 randomNumber = uint256(
            keccak256(
                abi.encodePacked(
                    _secret,
                    commitBlockHash,
                    entropyAccumulator,
                    block.timestamp,
                    block.prevrandao,
                    round.ticketsSold,
                    _roundId
                )
            )
        );

        // Select winner
        uint256 winnerIndex = randomNumber % round.ticketsSold;
        address winner = roundTickets[_roundId][winnerIndex];

        round.winner = winner;
        round.finalized = true;

        // Calculate prize and fee
        uint256 fee = (round.prizePool * platformFeePercent) / 100;
        uint256 prize = round.prizePool - fee;
        accumulatedFees += fee;

        // Transfer prize to winner
        (bool success, ) = payable(winner).call{value: prize}("");
        require(success, "Prize transfer failed");

        // Update entropy for future rounds
        entropyAccumulator = keccak256(abi.encodePacked(entropyAccumulator, randomNumber));

        emit RevealAndFinalize(_roundId, winner, prize);
    }

    /**
     * @notice Claim refund for a cancelled round
     * @param _roundId The cancelled round
     */
    function claimRefund(uint256 _roundId) external nonReentrant roundExists(_roundId) {
        LotteryRound storage round = rounds[_roundId];
        require(round.cancelled, "Round not cancelled");

        uint256 tickets = userTicketCount[_roundId][msg.sender];
        require(tickets > 0, "No tickets to refund");

        userTicketCount[_roundId][msg.sender] = 0;
        uint256 refundAmount = tickets * round.ticketPrice;

        (bool success, ) = payable(msg.sender).call{value: refundAmount}("");
        require(success, "Refund transfer failed");

        emit RefundClaimed(_roundId, msg.sender, refundAmount);
    }

    /**
