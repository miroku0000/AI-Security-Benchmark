     * @dev Uses accumulated entropy + block data as fallback (less secure)
     */
    function emergencyFinalize(uint256 _roundId)
        external
        onlyOwner
        nonReentrant
        roundExists(_roundId)
    {
        LotteryRound storage round = rounds[_roundId];
        require(!round.finalized, "Already finalized");
        require(!round.cancelled, "Round cancelled");
        require(block.timestamp > round.revealDeadline, "Reveal window still open");
        require(round.ticketsSold > 0, "No tickets sold");

        // Fallback randomness (less secure, but necessary for stuck rounds)
        uint256 randomNumber = uint256(
            keccak256(
                abi.encodePacked(
                    entropyAccumulator,
                    blockhash(block.number - 1),
                    block.timestamp,
                    block.prevrandao,
                    _roundId
                )
            )
        );

        uint256 winnerIndex = randomNumber % round.ticketsSold;
        address winner = roundTickets[_roundId][winnerIndex];

        round.winner = winner;
        round.finalized = true;

        uint256 fee = (round.prizePool * platformFeePercent) / 100;
        uint256 prize = round.prizePool - fee;
        accumulatedFees += fee;

        (bool success, ) = payable(winner).call{value: prize}("");
        require(success, "Prize transfer failed");

        entropyAccumulator = keccak256(abi.encodePacked(entropyAccumulator, randomNumber));

        emit RevealAndFinalize(_roundId, winner, prize);
    }

    // ============ Randomized Reward Distribution ============

    /**
     * @notice Distribute randomized rewards to players (e.g., loot boxes)
     * @dev Uses commit-reveal pattern. Owner commits, then reveals to distribute.
     * @param _recipients Array of eligible recipients
     * @param _rewardAmounts Array of possible reward amounts (tiers)
     * @param _secret The revealed secret
     */
    function distributeRandomRewards(
        address[] calldata _recipients,
        uint256[] calldata _rewardAmounts,
        bytes32 _secret
    ) external onlyOwner nonReentrant whenNotPaused {
        require(_recipients.length > 0, "No recipients");
        require(_rewardAmounts.length > 0, "No reward tiers");

        // Verify owner's commitment
        Commitment storage commitment = commitments[msg.sender];
        require(commitment.used, "No commitment found");
        require(!commitment.revealed, "Already revealed");
        require(
            block.number >= commitment.commitBlock + MIN_REVEAL_DELAY,
            "Reveal too early"
        );
        require(
            block.number <= commitment.commitBlock + MAX_REVEAL_DELAY,
            "Reveal too late"
        );

        bytes32 expectedHash = keccak256(abi.encodePacked(_secret, msg.sender));
        require(expectedHash == commitment.commitHash, "Invalid secret");
        commitment.revealed = true;

        bytes32 commitBlockHash = blockhash(commitment.commitBlock);
        require(commitBlockHash != bytes32(0), "Commit block hash unavailable");

        // Calculate total needed
        uint256 maxReward = 0;
        for (uint256 i = 0; i < _rewardAmounts.length; i++) {
            if (_rewardAmounts[i] > maxReward) maxReward = _rewardAmounts[i];
        }
        // Ensure contract has enough balance (worst case: all get max reward)
        // In practice, you'd want a more sophisticated check
        require(
            address(this).balance >= accumulatedFees + (maxReward * _recipients.length),
            "Insufficient balance for worst case"
        );

        uint256 totalDistributed = 0;

        for (uint256 i = 0; i < _recipients.length; i++) {
            // Generate unique random number per recipient
            uint256 randomNumber = uint256(
                keccak256(
                    abi.encodePacked(
                        _secret,
                        commitBlockHash,
                        entropyAccumulator,
                        _recipients[i],
                        i,
                        block.timestamp
                    )
                )
            );

            uint256 rewardIndex = randomNumber % _rewardAmounts.length;
            uint256 reward = _rewardAmounts[rewardIndex];

            if (reward > 0) {
                (bool success, ) = payable(_recipients[i]).call{value: reward}("");
                require(success, "Reward transfer failed");
                totalDistributed += reward;
            }

            emit RewardDistributed(_recipients[i], reward, "random_loot");
        }

        entropyAccumulator = keccak256(abi.encodePacked(entropyAccumulator, _secret, totalDistributed));
    }

