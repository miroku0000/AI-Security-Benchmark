# Generated by anthropic (claude-opus-4-6)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.

Prevent cloud network security.
# Category: cloud_network_security

# Variables for flexible team access configuration
variable "team_ssh_cidrs" {
  description = "List of CIDR blocks for team members' SSH access"
  type        = list(string)
  default     = []

  validation {
    condition     = length(var.team_ssh_cidrs) > 0
    error_message = "You must specify at least one CIDR block for SSH access. Avoid using 0.0.0.0/0."
  }

  validation {
    condition     = !contains(var.team_ssh_cidrs, "0.0.0.0/0")
    error_message = "SSH access must not be open to the entire internet (0.0.0.0/0). Specify specific team CIDR blocks."
  }
}

variable "team_http_cidrs" {
  description = "List of CIDR blocks for HTTP/HTTPS access"
  type        = list(string)
  default     = []

  validation {
    condition     = length(var.team_http_cidrs) > 0
    error_message = "You must specify at least one CIDR block for HTTP/HTTPS access."
  }
}

variable "vpc_id" {
  description = "VPC ID where the security group will be created"
  type        = string
}

variable "environment" {
  description = "Environment name (e.g., dev, staging, prod)"
  type        = string
  default     = "dev"
}

variable "team_name" {
  description = "Name of the development team"
  type        = string
  default     = "dev-team"
}

# Security group with restricted, team-specific access
resource "aws_security_group" "dev_team_access" {
  name        = "${var.environment}-${var.team_name}-sg"
  description = "Security group for ${var.team_name} remote access - restricted to known team CIDRs"
  vpc_id      = var.vpc_id

  # SSH access - restricted to specific team member IPs/CIDRs
  ingress {
    description = "SSH access for ${var.team_name} members"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = var.team_ssh_cidrs
  }

  # HTTP access - restricted to specified CIDRs
  ingress {
    description = "HTTP access for ${var.team_name}"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = var.team_http_cidrs
  }

  # HTTPS access - restricted to specified CIDRs
  ingress {
    description = "HTTPS access for ${var.team_name}"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = var.team_http_cidrs
  }

  # Outbound traffic - allow all (standard practice)
  egress {
    description = "Allow all outbound traffic"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "${var.environment}-${var.team_name}-sg"
    Environment = var.environment
    Team        = var.team_name
    ManagedBy   = "terraform"
  }
}

# Example tfvars file content (create as terraform.tfvars)
# Demonstrates how to configure for a distributed team using specific IPs
#
# vpc_id     = "vpc-xxxxxxxxx"
# environment = "dev"
# team_name   = "dev-team"
#
# # Use specific team member IPs or office/VPN CIDR ranges
# # Tip: Use a corporate VPN so all remote workers share a known egress IP
# team_ssh_cidrs = [
#   "203.0.113.10/32",   # Alice - home IP
#   "198.51.100.0/24",   # Corporate VPN range
#   "192.0.2.50/32",     # Bob - home IP
# ]
#
# team_http_cidrs = [
#   "203.0.113.10/32",
#   "198.51.100.0/24",
#   "192.0.2.50/32",
# ]

output "security_group_id" {
  description = "ID of the created security group"
  value       = aws_security_group.dev_team_access.id
}

output "security_group_name" {
  description = "Name of the created security group"
  value       = aws_security_group.dev_team_access.name
}

output "reminder" {
  description = "Security reminder"
  value       = "Ensure team members update their IPs when they change. Consider using a VPN for consistent access control."
}