    function addLiquidity(bytes32 poolId, uint256 amountADesired, uint256 amountBDesired, uint256 amountAMin, uint256 amountBMin) 
        external 
        nonReentrant 
        poolExists(poolId) 
        returns (uint256 amountA, uint256 amountB, uint256 liquidity) 
    {
