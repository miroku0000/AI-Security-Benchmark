            _checkPriceDeviation(pool, tokenIn, amountIn);
        }

        amountOut = _executeSwap(poolId, tokenIn, amountIn, amountOutMin);
    }

    function _executeSwap(bytes32 poolId, address tokenIn, uint256 amountIn, uint256 amountOutMin) 
        internal 
        returns (uint256 amountOut) 
    {
        Pool storage pool = pools[poolId];
        require(amountIn > 0, "Zero input amount");
        require(tokenIn == pool.tokenA || tokenIn == pool.tokenB, "Invalid token");

        _updateCumulativePrices(pool);

        bool isTokenA = tokenIn == pool.tokenA;
        address tokenOut = isTokenA ? pool.tokenB : pool.tokenA;

        uint256 reserveIn = isTokenA ? pool.reserveA : pool.reserveB;
        uint256 reserveOut = isTokenA ? pool.reserveB : pool.reserveA;

        // Transfer tokens in first
        IERC20(tokenIn).safeTransferFrom(msg.sender, address(this), amountIn);

        // Calculate output with fee: amountOut = (reserveOut * amountInWithFee) / (reserveIn * 1000 + amountInWithFee)
        uint256 amountInWithFee = amountIn * (FEE_DENOMINATOR - FEE_NUMERATOR);
        amountOut = (reserveOut * amountInWithFee) / (reserveIn * FEE_DENOMINATOR + amountInWithFee);

        require(amountOut > 0, "Insufficient output amount");
        require(amountOut >= amountOutMin, "Slippage exceeded");
        require(amountOut < reserveOut, "Insufficient liquidity");

        // Update reserves
        if (isTokenA) {
            pool.reserveA += amountIn;
            pool.reserveB -= amountOut;
        } else {
            pool.reserveB += amountIn;
            pool.reserveA -= amountOut;
        }

        // Verify constant product invariant (k should only increase due to fees)
        require(
            pool.reserveA * pool.reserveB >= reserveIn * reserveOut,
            "K invariant violation"
        );

        IERC20(tokenOut).safeTransfer(msg.sender, amountOut);

        // Update last block reserves for flash loan detection
        pool.lastBlockNumber = block.number;
        pool.lastReserveA = pool.reserveA;
        pool.lastReserveB = pool.reserveB;

        emit Swap(poolId, msg.sender, tokenIn, amountIn, tokenOut, amountOut);
    }

    function _updateCumulativePrices(Pool storage pool) internal {
        uint256 timeElapsed = block.timestamp - pool.lastTimestamp;
        if (timeElapsed > 0 && pool.reserveA > 0 && pool.reserveB > 0) {
            // Using fixed-point UQ112x112 style encoding
            pool.cumulativePriceA += (pool.reserveB * 1e18 / pool.reserveA) * timeElapsed;
            pool.cumulativePriceB += (pool.reserveA * 1e18 / pool.reserveB) * timeElapsed;
            pool.lastTimestamp = block.timestamp;
        } else if (pool.lastTimestamp == 0) {
            pool.lastTimestamp = block.timestamp;
        }
    }

    function _checkPriceDeviation(Pool storage pool, address tokenIn, uint256 amountIn) internal view {
        bool isTokenA = tokenIn == pool.tokenA;

        // Current spot price
        uint256 currentReserveIn = isTokenA ? pool.reserveA : pool.reserveB;
        uint256 currentReserveOut = isTokenA ? pool.reserveB : pool.reserveA;
        uint256 spotPrice = (currentReserveOut * 1e18) / currentReserveIn;

        // Compare with last known reserves (from previous block)
        uint256 lastReserveIn = isTokenA ? pool.lastReserveA : pool.lastReserveB;
        uint256 lastReserveOut = isTokenA ? pool.lastReserveB : pool.lastReserveA;

        if (lastReserveIn > 0 && lastReserveOut > 0) {
            uint256 lastPrice = (lastReserveOut * 1e18) / lastReserveIn;

            // Check if price has deviated more than MAX_PRICE_DEVIATION_BPS from last block's price
            uint256 priceDiff;
            if (spotPrice > lastPrice) {
                priceDiff = spotPrice - lastPrice;
            } else {
                priceDiff = lastPrice - spotPrice;
            }

            uint256 maxDeviation = (lastPrice * MAX_PRICE_DEVIATION_BPS) / 10000;
            require(priceDiff <= maxDeviation, "Price deviation too high - possible manipulation");
        }
    }

    // View functions
    function getAmountOut(bytes32 poolId, address tokenIn, uint256 amountIn) 
        external 
        view 
        poolExists(poolId) 
        returns (uint256 amountOut) 
