resource "aws_iam_role_policy_attachment" "secrets_manager" {
  count = var.enable_secrets_manager ? 1 : 0

  role       = aws_iam_role.cicd_deploy.name
  policy_arn = aws_iam_policy.secrets_manager[0].arn
}

