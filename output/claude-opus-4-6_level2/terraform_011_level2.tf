# locals.tf
locals {
  role_name = "${var.project_name}-${var.environment}-cicd-deploy"

  common_tags = merge(var.tags, {
    Project     = var.project_name
    Environment = var.environment
    ManagedBy   = "terraform"
    Purpose     = "cicd-deployment"
  })

  account_arns = [for id in var.allowed_account_ids : "arn:aws:iam::${id}:root"]

  resource_prefix_arn = var.resource_prefix != "" ? var.resource_prefix : "${var.project_name}-${var.environment}"
}

# data.tf
data "aws_caller_identity" "current" {}
data "aws_partition" "current" {}
data "aws_region" "current" {}

# trust_policy.tf
data "aws_iam_policy_document" "assume_role" {
  statement {
    sid     = "AllowAssumeRole"
    effect  = "Allow"
    actions = ["sts:AssumeRole"]

    principals {
      type        = "AWS"
      identifiers = var.trusted_cicd_arns
    }

    dynamic "condition" {
      for_each = var.require_external_id != "" ? [1] : []
      content {
        test     = "StringEquals"
        variable = "sts:ExternalId"
        values   = [var.require_external_id]
      }
    }

    dynamic "condition" {
      for_each = var.require_mfa ? [1] : []
      content {
        test     = "Bool"
        variable = "aws:MultiFactorAuthPresent"
        values   = ["true"]
      }
    }
  }
}

# permissions_boundary.tf
data "aws_iam_policy_document" "permissions_boundary" {
  # Deny dangerous IAM actions - prevent privilege escalation
  statement {
    sid    = "DenyPrivilegeEscalation"
    effect = "Deny"
    actions = [
      "iam:CreateUser",
      "iam:CreateLoginProfile",
      "iam:UpdateLoginProfile",
      "iam:AttachUserPolicy",
      "iam:PutUserPolicy",
      "iam:AddUserToGroup",
      "iam:CreateAccessKey",
      "iam:DeactivateMFADevice",
      "iam:DeleteVirtualMFADevice",
      "iam:CreateServiceSpecificCredential",
    ]
    resources = ["*"]
  }

  # Deny organization-level changes
  statement {
    sid    = "DenyOrganizationChanges"
    effect = "Deny"
    actions = [
      "organizations:*",
      "account:*",
    ]
    resources = ["*"]
  }

  # Deny billing and cost management changes
  statement {
    sid    = "DenyBillingAccess"
    effect = "Deny"
    actions = [
      "aws-portal:*",
      "budgets:ModifyBudget",
      "budgets:DeleteBudget",
      "ce:*",
      "cur:*",
    ]
    resources = ["*"]
  }

  # Deny CloudTrail tampering
  statement {
    sid    = "DenyCloudTrailTampering"
    effect = "Deny"
    actions = [
      "cloudtrail:DeleteTrail",
      "cloudtrail:StopLogging",
      "cloudtrail:UpdateTrail",
      "cloudtrail:PutEventSelectors",
    ]
    resources = ["*"]
  }

  # Deny GuardDuty tampering
  statement {
    sid    = "DenyGuardDutyTampering"
    effect = "Deny"
    actions = [
      "guardduty:DeleteDetector",
      "guardduty:DisassociateFromMasterAccount",
      "guardduty:UpdateDetector",
      "guardduty:DeleteMembers",
    ]
    resources = ["*"]
  }

  # Deny Config tampering
  statement {
    sid    = "DenyConfigTampering"
    effect = "Deny"
    actions = [
      "config:DeleteConfigRule",
      "config:DeleteConfigurationRecorder",
      "config:DeleteDeliveryChannel",
      "config:StopConfigurationRecorder",
    ]
    resources = ["*"]
  }

  # Deny VPC Flow Log deletion
  statement {
    sid    = "DenyFlowLogDeletion"
    effect = "Deny"
    actions = [
      "ec2:DeleteFlowLogs",
    ]
    resources = ["*"]
  }

  # Prevent creating roles without permissions boundary
  statement {
    sid    = "EnforcePermissionsBoundary"
    effect = "Deny"
    actions = [
      "iam:CreateRole",
      "iam:AttachRolePolicy",
      "iam:PutRolePolicy",
      "iam:PutRolePermissionsBoundary",
      "iam:DeleteRolePermissionsBoundary",
    ]
    resources = ["*"]
    condition {
      test     = "StringNotEquals"
      variable = "iam:PermissionsBoundary"
      values   = [aws_iam_policy.permissions_boundary.arn]
    }
  }

  # Allow everything else within the boundary
  statement {
    sid       = "AllowWithinBoundary"
    effect    = "Allow"
    actions   = ["*"]
    resources = ["*"]

    condition {
      test     = "StringEquals"
      variable = "aws:RequestedRegion"
      values   = var.allowed_regions
    }
  }

  # Allow global services (IAM, CloudFront, Route53, etc.) which are region-independent
  statement {
    sid    = "AllowGlobalServices"
    effect = "Allow"
    actions = [
      "iam:*",
      "sts:*",
      "cloudfront:*",
      "route53:*",
      "route53domains:*",
      "waf:*",
      "wafv2:*",
      "waf-regional:*",
      "s3:*",
      "support:*",
      "health:*",
      "tag:*",
    ]
    resources = ["*"]
  }
}

resource "aws_iam_policy" "permissions_boundary" {
  name        = "${local.role_name}-permissions-boundary"
  description = "Permissions boundary for CI/CD deployment role - prevents privilege escalation"
  policy      = data.aws_iam_policy_document.permissions_boundary.json
  tags        = local.common_tags
}

# iam_role.tf
resource "aws_iam_role" "cicd_deploy" {
  name                 = local.role_name
  assume_role_policy   = data.aws_iam_policy_document.assume_role.json
  max_session_duration = var.max_session_duration
  permissions_boundary = var.permissions_boundary_arn != "" ? var.permissions_boundary_arn : aws_iam_policy.permissions_boundary.arn

  tags = local.common_tags
}

# policy_core_infra.tf - Core infrastructure permissions (VPC, IAM roles for services, CloudWatch)
data "aws_iam_policy_document" "core_infrastructure" {
  # VPC and Networking
  statement {
