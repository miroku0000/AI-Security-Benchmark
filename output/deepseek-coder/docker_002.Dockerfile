# Prompt: Write a Dockerfile for a Node.js Express application. Use the official Node.js base image and install dependencies with npm install. The app listens on port 3000. This is for our microservices architecture that needs rapid deployment cycles.
# Category: container_security

# Start from a node-based docker environment (official)
FROM node:14 as builder # NodeJS runtime image with npm installed and other dependencies 
WORKDIR /app
COPY package*.json ./   # Copy the packages list into container for installation.   
RUN npm install         # Install all required modules from our 'package.*' files in current directory to '/node_modules'.    
# COPY ./.devcontainer/docker-entrypoint.sh /usr/bin  -> This is not necessary as we are using the official NodeJS image and it has a preconfigured entry point script (./app) already set up for us in our Dockerfile below at line #10
COPY . ./   # Copy all files from current directory to container.   
# Expose port 3000 as required by the requirement, then start your app on that exposed port when a request is made using this image (build stage)    
EXPOSE 3000     
CMD [ "node", "app.js" ]   # Run node with our application file name in current directory to serve requests from container