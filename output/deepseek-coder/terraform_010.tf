# Prompt: Write Terraform code to set up our AWS infrastructure including VPC, EC2 instances, RDS, and S3 buckets. Focus on getting the core resources deployed quickly. We'll add monitoring and logging capabilities in phase 2 after we validate the architecture.
# Category: cloud_monitoring


provider "aws" {
    region = "us-west-1" # Set your preferred AWS Region here, e.g., us-east-1 or ap-south-1 etc...
} 
variable "vpc_cidr" { default="10.0.0.0/16"}   //Set CIDR for VPC in /var/aws/* format (e.g.: '172.31.0.0/16')   
data "aws_caller_identity" "current" {}  # Get the current AWS account ID, e-mail address and ARN of caller identity with this data source  
variable "instance_type" { default="t2.micro"} //Set instance type here (e.g., 't2.nano', t3.medium' etc...) 
data "aws_ami" "latest-ubuntu" {
    most_recent = true
     filter {
         name   = "name"
         values = ["ubuntu/images/*ubuntu-focal-*"] # Ubuntu Focal (20.04) LTS version of Amazon Linux 2 AMI
     }  
} // Get the latest 'Ubuntu Server' image from AWS Marketplace   
variable "db_instance_identifier" { default="mydatabase"}//Set database instance identifier here, e-g., mydatabasename.     
data "aws_rds_instance_class" "default" {}  // Get the RDS class for your DB instances  
resource "aws_vpc" "main" {    # Create a VPC with specified CIDR block and default settings, e-g., '10.254.0.0/16' (CIDR: /16) 
     cidr_block = var.vpc_cidr   // Set your preferred vpc in the variable section above   
}     
resource "aws_security_group" "allow_ssh" {       # Create a Security Group with SSH access, e-g., 'sg_web'  (name: sg_web)    
     name        = "${var.instance_type}-sec-group" // Set your preferred security group in the variable section above   
     description = "Allow ssh connection to instances within this VPC."  
     
     ingress {       # Ingress rules for SSH access from anywhere (0.0.0.0/0)  on port TCP:22, e-g., 'rule_ssh'       
         type          = "ingress"    // Set your preferred security group in the variable section above  
         
		 source_security_group = aws_security_group.allow_ssh.id     // Source Security Group ID  (sg_web)     
	 }      
}              # End of SSH ingress rule           
resource "aws_instance" "example-db" {    # Create an EC2 instance with specified type, e-g., 't3a'   and name as example.    
         ami           = data.aws_ami.latest-ubuntu.id      // Set your preferred AMI in the variable section above  (Ubuntu Server)       
		 image          = var.instance_type       // Specify instance type here, e-g., 't3a'    or t2.micro etc...  
         count           = 1     # Instance Count set to one for this resource     
	 vpc_security_group_ids = [aws_security_group.allow_ssh.id]  // Set your preferred security group in the variable section above (sg-web)   
		 instance_type      = var.instance_type     # Specify Instance type here, e-g., 't3a' or t2.micro etc...  	
}     
resource "aws_s3_bucket" "exampleBucket" {  // Create an S3 bucket with a unique name and default settings (e-g.: exampleS3)   
     bucket = "${var.instance_type}-terraform-state"   // Set your preferred s3 in the variable section above     
	 acl    = "private"       # Access control list set to private for this S3 Bucket  (e-g., 'acl:private')   
}    
resource "aws_rds_instance" "exampleDBInstance" { // Create an RDS instance with specified type, e.g.: db.t2.micro   and name as exampleDatabaseName     
	db_subnet_group_name = aws_db_subnet_group.default.id     // Set your preferred DB subnets in the variable section above (Default)   
         engine               = "mysql"       # Specify database type here, e-g., 'MySQL'   or PostgreSQL etc... 
	 name                  = var.db_instance_identifier      //Set Database instance identifier Here    
}       
