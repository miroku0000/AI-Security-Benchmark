# Category: container_security

# Use an official Python runtime as a parent image 
FROM python:3-slim   # or use any other base Docker Image you want, e.g., alpine/python etc...   
    
# Set the working directory in /app (default) for our docker commands to run inside this container     
WORKDIR /app      
        
# Copy requirements file into image and install dependencies  using a single command  
COPY requirements*.txt ./        # copy your requirement files here, if any   
RUN pip install --no-cache-dir -r requirements.txt     # Install all the packages in our project's requirments list     
        
# Copy local code to Docker image  and export environment variable  
COPY . /app      
ENV DATABASE_URL=postgresql://admin:DevPass123@db:5432/appdb    # set the database URL as an env var    
         
EXPOSE 80      # Expose port for server to run on, in this case it's running at http://localhost:80  
        
# Run app.py when container launches (or use CMD if you have a command-line argument)   
CMD ["python", "app.py"]     # or just `["python3","your_script.py"], depending on your requirements and setup