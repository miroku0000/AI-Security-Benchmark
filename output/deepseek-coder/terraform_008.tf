        Environment = "Dev-${count}"   // This is used when you want more granular control over your resource groups or tags to make the management easier in a multi-tenant environment, it should be updated with each new instance added and changed as per requirements. e.g., Dev1 for first tier app; Dev2 for second tier web etc
    vpc_opts = [  # VPC options are optional parameters that allow us to configure the main attributes of our resource (e.g.: enableDnsSupport, enableDnsHostnames), it's not required but can serve as an additional way if needed and provide more granular control over your resources
        "enable_dns" = true  # This is used when you want to add DNS support in the VPC (optional) e.g., Enable or Disable dns Support for vpc main, it should be updated with each new instance added as per requirements and provide more granular control over your resources
    ]   // End of optional parameters list – Tags are used above to manage resource groups in a logical manner (optional) e.g., Environment: Dev1 or "Environment":Dev2 for the first tier app etc, it should be updated with each new instance added and changed as per requirements
}
