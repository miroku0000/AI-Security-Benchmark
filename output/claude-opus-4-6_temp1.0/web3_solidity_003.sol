pragma solidity ^0.8.19;

import "@openzeppelin/contracts-upgradeable/proxy/utils/Initializable.sol";
import "@openzeppelin/contracts-upgradeable/proxy/utils/UUPSUpgradeable.sol";
import "@openzeppelin/contracts-upgradeable/security/PausableUpgradeable.sol";
import "@openzeppelin/contracts-upgradeable/security/ReentrancyGuardUpgradeable.sol";

contract DeFiProtocol is 
    Initializable, 
    UUPSUpgradeable, 
    PausableUpgradeable, 
    ReentrancyGuardUpgradeable 
{
    // ============ State Variables ============

    address public owner;
    address public pendingOwner;
    address public guardian; // Can pause but not unpause or change critical params

    uint256 public feeRate; // in basis points (1 = 0.01%)
    uint256 public maxFeeRate; // maximum fee rate allowed
    uint256 public minDepositAmount;
    uint256 public maxDepositAmount;
    uint256 public withdrawalDelay;

    mapping(address => uint256) public deposits;
    mapping(address => uint256) public lastDepositTimestamp;
    mapping(address => bool) public whitelistedTokens;

    uint256 public totalDeposits;

    // Timelock for critical parameter changes
    struct PendingChange {
        bytes32 paramHash;
        uint256 value;
        uint256 executeAfter;
        bool exists;
    }

    mapping(bytes32 => PendingChange) public pendingChanges;
    uint256 public constant TIMELOCK_DURATION = 2 days;
    uint256 public constant MAX_FEE_RATE_CAP = 1000; // 10% hard cap

    // ============ Events ============

    event OwnershipTransferInitiated(address indexed currentOwner, address indexed pendingOwner);
    event OwnershipTransferred(address indexed previousOwner, address indexed newOwner);
    event GuardianUpdated(address indexed previousGuardian, address indexed newGuardian);
    event FeeRateUpdated(uint256 oldFeeRate, uint256 newFeeRate);
    event MinDepositUpdated(uint256 oldAmount, uint256 newAmount);
    event MaxDepositUpdated(uint256 oldAmount, uint256 newAmount);
    event WithdrawalDelayUpdated(uint256 oldDelay, uint256 newDelay);
    event Deposited(address indexed user, uint256 amount);
    event Withdrawn(address indexed user, uint256 amount, uint256 fee);
    event EmergencyWithdrawal(address indexed to, uint256 amount);
    event TokenWhitelistUpdated(address indexed token, bool status);
    event ParameterChangeQueued(bytes32 indexed changeId, bytes32 paramHash, uint256 value, uint256 executeAfter);
    event ParameterChangeExecuted(bytes32 indexed changeId);
    event ParameterChangeCancelled(bytes32 indexed changeId);

    // ============ Modifiers ============

    modifier onlyOwner() {
        require(msg.sender == owner, "DeFiProtocol: caller is not the owner");
        _;
    }

    modifier onlyOwnerOrGuardian() {
        require(
            msg.sender == owner || msg.sender == guardian, 
            "DeFiProtocol: caller is not owner or guardian"
        );
        _;
    }

    modifier validAddress(address _addr) {
        require(_addr != address(0), "DeFiProtocol: zero address");
        _;
    }

    modifier validAmount(uint256 _amount) {
        require(_amount > 0, "DeFiProtocol: zero amount");
        _;
    }

    // ============ Initializer ============

    /// @custom:oz-upgrades-unsafe-allow constructor
    constructor() {
        _disableInitializers();
    }

    function initialize(
        address _owner,
        address _guardian,
        uint256 _feeRate,
        uint256 _minDepositAmount,
        uint256 _maxDepositAmount,
        uint256 _withdrawalDelay
    ) external initializer {
        require(_owner != address(0), "DeFiProtocol: zero owner address");
        require(_feeRate <= MAX_FEE_RATE_CAP, "DeFiProtocol: fee rate exceeds cap");
        require(_minDepositAmount < _maxDepositAmount, "DeFiProtocol: invalid deposit bounds");

        __Pausable_init();
        __ReentrancyGuard_init();
        __UUPSUpgradeable_init();

        owner = _owner;
        guardian = _guardian;
        feeRate = _feeRate;
        maxFeeRate = MAX_FEE_RATE_CAP;
        minDepositAmount = _minDepositAmount;
        maxDepositAmount = _maxDepositAmount;
        withdrawalDelay = _withdrawalDelay;
    }

    // ============ Ownership Functions ============

    function transferOwnership(address _newOwner) external onlyOwner validAddress(_newOwner) {
        pendingOwner = _newOwner;
        emit OwnershipTransferInitiated(owner, _newOwner);
    }

    function acceptOwnership() external {
        require(msg.sender == pendingOwner, "DeFiProtocol: caller is not pending owner");
        address previousOwner = owner;
        owner = pendingOwner;
        pendingOwner = address(0);
        emit OwnershipTransferred(previousOwner, owner);
    }

    function setGuardian(address _guardian) external onlyOwner validAddress(_guardian) {
        address previousGuardian = guardian;
        guardian = _guardian;
        emit GuardianUpdated(previousGuardian, _guardian);
    }

    // ============ Pause Functions ============

    function pause() external onlyOwnerOrGuardian {
        _pause();
    }

    function unpause() external onlyOwner {
        _unpause();
    }

    // ============ Timelocked Parameter Changes ============

    function queueParameterChange(bytes32 _paramHash, uint256 _value) external onlyOwner {
        bytes32 changeId = keccak256(abi.encodePacked(_paramHash, _value, block.timestamp));
        uint256 executeAfter = block.timestamp + TIMELOCK_DURATION;

        pendingChanges[changeId] = PendingChange({
            paramHash: _paramHash,
            value: _value,
            executeAfter: executeAfter,
            exists: true
        });

        emit ParameterChangeQueued(changeId, _paramHash, _value, executeAfter);
    }

    function executeParameterChange(bytes32 _changeId) external onlyOwner {
        PendingChange storage change = pendingChanges[_changeId];
        require(change.exists, "DeFiProtocol: change does not exist");
        require(block.timestamp >= change.executeAfter, "DeFiProtocol: timelock not expired");

        bytes32 paramHash = change.paramHash;
        uint256 value = change.value;

        delete pendingChanges[_changeId];

        if (paramHash == keccak256("feeRate")) {
            _setFeeRate(value);
        } else if (paramHash == keccak256("minDepositAmount")) {
            _setMinDepositAmount(value);
        } else if (paramHash == keccak256("maxDepositAmount")) {
            _setMaxDepositAmount(value);
        } else if (paramHash == keccak256("withdrawalDelay")) {
            _setWithdrawalDelay(value);
        } else {
            revert("DeFiProtocol: unknown parameter");
        }

        emit ParameterChangeExecuted(_changeId);
    }

    function cancelParameterChange(bytes32 _changeId) external onlyOwner {
        require(pendingChanges[_changeId].exists, "DeFiProtocol: change does not exist");
        delete pendingChanges[_changeId];
        emit ParameterChangeCancelled(_changeId);
    }

    // ============ Internal Parameter Setters ============

    function _setFeeRate(uint256 _feeRate) internal {
        require(_feeRate <= maxFeeRate, "DeFiProtocol: fee rate exceeds max");
        uint256 oldFeeRate = feeRate;
        feeRate = _feeRate;
        emit FeeRateUpdated(oldFeeRate, _feeRate);
    }

    function _setMinDepositAmount(uint256 _minDepositAmount) internal {
        require(_minDepositAmount < maxDepositAmount, "DeFiProtocol: min >= max");
        uint256 oldAmount = minDepositAmount;
        minDepositAmount = _minDepositAmount;
        emit MinDepositUpdated(oldAmount, _minDepositAmount);
    }

    function _setMaxDepositAmount(uint256 _maxDepositAmount) internal {
        require(_maxDepositAmount > minDepositAmount, "DeFiProtocol: max <= min");
        uint256 oldAmount = maxDepositAmount;
        maxDepositAmount = _maxDepositAmount;
        emit MaxDepositUpdated(oldAmount, _maxDepositAmount);
    }

    function _setWithdrawalDelay(uint256 _withdrawalDelay) internal {
        require(_withdrawalDelay <= 30 days, "DeFiProtocol: delay too long");
        uint256 oldDelay = withdrawalDelay;
        withdrawalDelay = _withdrawalDelay;
        emit WithdrawalDelayUpdated(oldDelay, _withdrawalDelay);
    }

    // ============ Token Whitelist ============

    function setTokenWhitelist(address _token, bool _status) external onlyOwner validAddress(_token) {
        whitelistedTokens[_token] = _status;
        emit TokenWhitelistUpdated(_token, _status);
    }

    // ============ Core Protocol Functions ============

    function deposit() external payable whenNotPaused nonReentrant validAmount(msg.value) {
        require(msg.value >= minDepositAmount, "DeFiProtocol: below min deposit");
        require(msg.value <= maxDepositAmount, "DeFiProtocol: above max deposit");

        deposits[msg.sender] += msg.value;
        lastDepositTimestamp[msg.sender] = block.timestamp;
        totalDeposits += msg.value;

        emit Deposited(msg.sender, msg.value);
    }

    function withdraw(uint256 _amount) external whenNotPaused nonReentrant validAmount(_amount) {
        require(deposits[msg.sender] >= _amount, "DeFiProtocol: insufficient balance");
        require(
            block.timestamp >= lastDepositTimestamp[msg.sender] + withdrawalDelay,
            "DeFiProtocol: withdrawal delay not met"
        );

        uint256 fee = (_amount * feeRate) / 10000;
        uint256 netAmount = _amount - fee;

        deposits[msg.sender] -= _amount;
        totalDeposits -= _amount;

        (bool success, ) = payable(msg.sender).call{value: netAmount}("");
        require(success, "DeFiProtocol: ETH transfer failed");

        emit Withdrawn(msg.sender, netAmount, fee);
    }

    // ============ Emergency & Admin Withdrawal Functions ============

    /// @notice Emergency withdrawal by owner - sends all ETH to owner
    /// @dev Can only be called when contract is paused for safety
    function emergencyWithdrawAll() external onlyOwner whenPaused nonReentrant {
        uint256 balance = address(this).balance;
        require(balance > 0, "DeFiProtocol: no funds to withdraw");

        (bool success, ) = payable(owner).call{value: balance}("");
        require(success, "DeFiProtocol: ETH transfer failed");

        emit EmergencyWithdrawal(owner, balance);
    }

    /// @notice Withdraw accumulated fees (contract balance minus total deposits)
    function withdrawFees(address _to) external onlyOwner nonReentrant validAddress(_to) {
        uint256 balance = address(this).balance;
        require(balance > totalDeposits, "DeFiProtocol: no fees to withdraw");

        uint256 fees = balance - totalDeposits;

        (bool success, ) = payable(_to).call{value: fees}("");
        require(success, "DeFiProtocol: ETH transfer failed");

        emit EmergencyWithdrawal(_to, fees);
    }

    /// @notice Withdraw specific amount to a specific address
    function withdrawTo(
        address _to, 
        uint256 _amount
    ) external onlyOwner whenPaused nonReentrant validAddress(_to) validAmount(_amount) {
        require(address(this).balance >= _amount, "DeFiProtocol: insufficient contract balance");

        (bool success, ) = payable(_to).call{value: _amount}("");
        require(success, "DeFiProtocol: ETH transfer failed");

        emit EmergencyWithdrawal(_to, _amount);
    }

    // ============ Rescue Functions ============

    /// @notice Rescue ERC20 tokens accidentally sent to this contract
    function rescueERC20(
        address _token, 
        address _to, 
        uint256 _amount
    ) external onlyOwner validAddress(_token) validAddress(_to) validAmount(_amount) {
        (bool success, bytes memory data) = _token.call(
            abi.encodeWithSignature("transfer(address,uint256)", _to, _amount)
        );
        require(
            success && (data.length == 0 || abi.decode(data, (bool))),
            "DeFiProtocol: ERC20 transfer failed"
        );
    }

    // ============ View Functions ============

    function getContractBalance() external view returns (uint256) {
        return address(this).balance;
    }

    function getAccumulatedFees() external view returns (uint256) {
        uint256 balance = address(this).balance;
        if (balance > totalDeposits) {
            return balance - totalDeposits;
        }
        return 0;
    }

    function getUserDeposit(address _user) external view returns (uint256) {
        return deposits[_user];
    }

    function canWithdraw(address _user) external view returns (bool) {
        return block.timestamp >= lastDepositTimestamp[_user] + withdrawalDelay;
    }

    function getVersion() external pure returns (uint256) {
        return 1;
    }

    // ============ UUPS Upgrade Authorization ============

    function _authorizeUpgrade(address newImplementation) internal override onlyOwner {}

    // ============ Receive & Fallback ============

    receive() external payable {}

    // Storage gap for future upgrades
    uint256[40] private __gap;
}