pragma solidity ^0.8.20;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/token/ERC20/utils/SafeERC20.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/ReentrancyGuard.sol";

contract BatchProcessor is Ownable, ReentrancyGuard {
    using SafeERC20 for IERC20;

    // Internal balance tracking for users
    mapping(address => mapping(address => uint256)) public balances; // token => user => balance

    // ETH balances
    mapping(address => uint256) public ethBalances;

    event BatchTokenTransfer(address indexed token, uint256 totalRecipients, uint256 totalAmount);
    event BatchETHTransfer(uint256 totalRecipients, uint256 totalAmount);
    event BatchBalanceUpdate(address indexed token, uint256 totalRecipients);
    event AirdropCompleted(address indexed token, uint256 totalRecipients, uint256 totalAmount);
    event BalanceWithdrawn(address indexed user, address indexed token, uint256 amount);
    event ETHBalanceWithdrawn(address indexed user, uint256 amount);

    uint256 public constant MAX_BATCH_SIZE = 500;

    constructor() Ownable(msg.sender) {}

    // --- Batch Token Distribution (Direct Transfer) ---

    /// @notice Distributes ERC20 tokens to multiple recipients with individual amounts
    /// @param token The ERC20 token address
    /// @param recipients Array of recipient addresses
    /// @param amounts Array of amounts corresponding to each recipient
    function batchTransferToken(
        address token,
        address[] calldata recipients,
        uint256[] calldata amounts
    ) external nonReentrant {
        require(recipients.length == amounts.length, "Array length mismatch");
        require(recipients.length > 0, "Empty arrays");
        require(recipients.length <= MAX_BATCH_SIZE, "Batch size exceeds maximum");

        uint256 totalAmount = 0;
        for (uint256 i = 0; i < amounts.length; i++) {
            require(recipients[i] != address(0), "Zero address recipient");
            require(amounts[i] > 0, "Zero amount");
            totalAmount += amounts[i];
        }

        // Transfer tokens from sender to this contract first
        IERC20(token).safeTransferFrom(msg.sender, address(this), totalAmount);

        // Distribute to each recipient
        for (uint256 i = 0; i < recipients.length; i++) {
            IERC20(token).safeTransfer(recipients[i], amounts[i]);
        }

        emit BatchTokenTransfer(token, recipients.length, totalAmount);
    }

    /// @notice Distributes the same amount of ERC20 tokens to multiple recipients (airdrop)
    /// @param token The ERC20 token address
    /// @param recipients Array of recipient addresses
    /// @param amountPerRecipient The amount each recipient receives
    function airdropToken(
        address token,
        address[] calldata recipients,
        uint256 amountPerRecipient
    ) external nonReentrant {
        require(recipients.length > 0, "Empty array");
        require(recipients.length <= MAX_BATCH_SIZE, "Batch size exceeds maximum");
        require(amountPerRecipient > 0, "Zero amount");

        uint256 totalAmount = amountPerRecipient * recipients.length;

        IERC20(token).safeTransferFrom(msg.sender, address(this), totalAmount);

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Zero address recipient");
            IERC20(token).safeTransfer(recipients[i], amountPerRecipient);
        }

        emit AirdropCompleted(token, recipients.length, totalAmount);
    }

    // --- Batch ETH Distribution ---

    /// @notice Distributes ETH to multiple recipients with individual amounts
    /// @param recipients Array of recipient addresses
    /// @param amounts Array of amounts corresponding to each recipient
    function batchTransferETH(
        address[] calldata recipients,
        uint256[] calldata amounts
    ) external payable nonReentrant {
        require(recipients.length == amounts.length, "Array length mismatch");
        require(recipients.length > 0, "Empty arrays");
        require(recipients.length <= MAX_BATCH_SIZE, "Batch size exceeds maximum");

        uint256 totalAmount = 0;
        for (uint256 i = 0; i < amounts.length; i++) {
            require(recipients[i] != address(0), "Zero address recipient");
            require(amounts[i] > 0, "Zero amount");
            totalAmount += amounts[i];
        }
        require(msg.value == totalAmount, "Incorrect ETH amount");

        for (uint256 i = 0; i < recipients.length; i++) {
            (bool success, ) = payable(recipients[i]).call{value: amounts[i]}("");
            require(success, "ETH transfer failed");
        }

        emit BatchETHTransfer(recipients.length, totalAmount);
    }

    /// @notice Distributes the same amount of ETH to multiple recipients
    /// @param recipients Array of recipient addresses
    /// @param amountPerRecipient The amount each recipient receives
    function airdropETH(
        address[] calldata recipients,
        uint256 amountPerRecipient
    ) external payable nonReentrant {
        require(recipients.length > 0, "Empty array");
        require(recipients.length <= MAX_BATCH_SIZE, "Batch size exceeds maximum");
        require(amountPerRecipient > 0, "Zero amount");

        uint256 totalAmount = amountPerRecipient * recipients.length;
        require(msg.value == totalAmount, "Incorrect ETH amount");

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Zero address recipient");
            (bool success, ) = payable(recipients[i]).call{value: amountPerRecipient}("");
            require(success, "ETH transfer failed");
        }

        emit BatchETHTransfer(recipients.length, totalAmount);
    }

    // --- Batch Balance Updates (Credit System) ---

    /// @notice Updates internal token balances for multiple users (owner only)
    /// @param token The token address for balance tracking
    /// @param users Array of user addresses
    /// @param amounts Array of amounts to credit
    function batchUpdateBalances(
        address token,
        address[] calldata users,
        uint256[] calldata amounts
    ) external onlyOwner {
        require(users.length == amounts.length, "Array length mismatch");
        require(users.length > 0, "Empty arrays");
        require(users.length <= MAX_BATCH_SIZE, "Batch size exceeds maximum");

        for (uint256 i = 0; i < users.length; i++) {
            require(users[i] != address(0), "Zero address user");
            balances[token][users[i]] += amounts[i];
        }

        emit BatchBalanceUpdate(token, users.length);
    }

    /// @notice Updates internal ETH balances for multiple users (owner only)
    /// @param users Array of user addresses
    /// @param amounts Array of amounts to credit
    function batchUpdateETHBalances(
        address[] calldata users,
        uint256[] calldata amounts
    ) external onlyOwner {
        require(users.length == amounts.length, "Array length mismatch");
        require(users.length > 0, "Empty arrays");
        require(users.length <= MAX_BATCH_SIZE, "Batch size exceeds maximum");

        for (uint256 i = 0; i < users.length; i++) {
            require(users[i] != address(0), "Zero address user");
            ethBalances[users[i]] += amounts[i];
        }

        emit BatchBalanceUpdate(address(0), users.length);
    }

    // --- Withdrawal Functions (Pull Pattern) ---

    /// @notice Allows a user to withdraw their credited token balance
    /// @param token The token address to withdraw
    function withdrawTokenBalance(address token) external nonReentrant {
        uint256 amount = balances[token][msg.sender];
        require(amount > 0, "No balance to withdraw");

        balances[token][msg.sender] = 0;
        IERC20(token).safeTransfer(msg.sender, amount);

        emit BalanceWithdrawn(msg.sender, token, amount);
    }

    /// @notice Allows a user to withdraw their credited ETH balance
    function withdrawETHBalance() external nonReentrant {
        uint256 amount = ethBalances[msg.sender];
        require(amount > 0, "No ETH balance to withdraw");

        ethBalances[msg.sender] = 0;
        (bool success, ) = payable(msg.sender).call{value: amount}("");
        require(success, "ETH withdrawal failed");

        emit ETHBalanceWithdrawn(msg.sender, amount);
    }

    // --- Multi-token Batch Transfer ---

    /// @notice Distributes multiple different tokens to multiple recipients in one transaction
    /// @param tokens Array of token addresses
    /// @param recipients Array of recipient addresses
    /// @param amounts Array of amounts
    function batchMultiTokenTransfer(
        address[] calldata tokens,
        address[] calldata recipients,
        uint256[] calldata amounts
    ) external nonReentrant {
        require(
            tokens.length == recipients.length && recipients.length == amounts.length,
            "Array length mismatch"
        );
        require(tokens.length > 0, "Empty arrays");
        require(tokens.length <= MAX_BATCH_SIZE, "Batch size exceeds maximum");

        for (uint256 i = 0; i < tokens.length; i++) {
            require(recipients[i] != address(0), "Zero address recipient");
            require(amounts[i] > 0, "Zero amount");

            IERC20(tokens[i]).safeTransferFrom(msg.sender, recipients[i], amounts[i]);
        }

        emit BatchTokenTransfer(address(0), tokens.length, 0);
    }

    // --- Admin Functions ---

    /// @notice Allows owner to recover accidentally sent tokens
    /// @param token The token address to recover
    /// @param to The address to send recovered tokens to
    /// @param amount The amount to recover
    function recoverToken(address token, address to, uint256 amount) external onlyOwner {
        require(to != address(0), "Zero address");
        IERC20(token).safeTransfer(to, amount);
    }

    /// @notice Allows owner to recover accidentally sent ETH
    /// @param to The address to send recovered ETH to
    /// @param amount The amount to recover
    function recoverETH(address to, uint256 amount) external onlyOwner {
        require(to != address(0), "Zero address");
        (bool success, ) = payable(to).call{value: amount}("");
        require(success, "ETH recovery failed");
    }

    /// @notice Allows the contract to receive ETH
    receive() external payable {}
}