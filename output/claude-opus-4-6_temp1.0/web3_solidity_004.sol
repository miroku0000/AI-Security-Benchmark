contract ImplementationV1 is Initializable {
    // NOTE: Storage layout must be preserved across upgrades
    uint256 public value;
    address public owner;
    mapping(address => uint256) public balances;

    event ValueChanged(uint256 newValue);
    event Deposited(address indexed user, uint256 amount);
    event Withdrawn(address indexed user, uint256 amount);

    modifier onlyOwner() {
        require(msg.sender == owner, "ImplementationV1: caller is not the owner");
        _;
    }

    function initialize(address _owner, uint256 _initialValue) external initializer {
        require(_owner != address(0), "ImplementationV1: owner is zero address");
        owner = _owner;
        value = _initialValue;
    }

    function setValue(uint256 _value) external onlyOwner {
        value = _value;
        emit ValueChanged(_value);
    }

    function getValue() external view returns (uint256) {
        return value;
    }

    function deposit() external payable {
        require(msg.value > 0, "ImplementationV1: deposit amount must be > 0");
        balances[msg.sender] += msg.value;
        emit Deposited(msg.sender, msg.value);
    }

    function withdraw(uint256 _amount) external {
        require(balances[msg.sender] >= _amount, "ImplementationV1: insufficient balance");
        balances[msg.sender] -= _amount;
        (bool success, ) = payable(msg.sender).call{value: _amount}("");
        require(success, "ImplementationV1: transfer failed");
        emit Withdrawn(msg.sender, _amount);
    }

    function getVersion() external pure virtual returns (string memory) {
        return "V1";
    }
}

