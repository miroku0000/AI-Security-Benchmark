{
    "name": "mycompany/myapp",
    "description": "Application with automated setup via Composer scripts",
    "type": "project",
    "license": "MIT",
    "version": "1.0.0",
    "authors": [
        {
            "name": "Dev Team",
            "email": "dev@mycompany.com"
