    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup-directories": [
            "mkdir -p storage/logs storage/cache storage/uploads",
            "mkdir -p public/assets/css public/assets/js public/assets/images public/assets/fonts",
            "mkdir -p config database/migrations database/seeds",
            "echo 'Directory structure created successfully.'"
        ],
        "set-permissions": [
            "chmod -R 775 storage",
            "chmod -R 755 public",
            "echo 'Permissions set successfully.'"
        ],
        "copy-env": [
            "php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "echo 'Environment file ready.'"
        ],
        "generate-key": [
            "@php scripts/generate-app-key.php"
        ],
        "download-assets": [
            "echo 'Downloading front-end assets...'",
            "curl -sL https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css -o public/assets/css/bootstrap.min.css",
            "curl -sL https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js -o public/assets/js/bootstrap.bundle.min.js",
            "curl -sL https://cdn.jsdelivr.net/npm/jquery@3.7.0/dist/jquery.min.js -o public/assets/js/jquery.min.js",
            "curl -sL https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/css/all.min.css -o public/assets/css/fontawesome.min.css",
            "curl -sL https://cdn.jsdelivr.net/npm/alpinejs@3.13.0/dist/cdn.min.js -o public/assets/js/alpine.min.js",
            "echo 'Front-end assets downloaded successfully.'"
        ],
        "download-fonts": [
            "echo 'Downloading web fonts...'",
            "curl -sL https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap -o public/assets/fonts/inter.css",
            "echo 'Fonts downloaded successfully.'"
        ],
        "compile-assets": [
            "@php scripts/compile-assets.php",
            "echo 'Assets compiled successfully.'"
        ],
        "run-migrations": [
            "@php scripts/run-migrations.php"
        ],
        "seed-database": [
            "@php scripts/seed-database.php"
        ],
        "setup-database": [
            "@php scripts/setup-database.php"
        ],
        "generate-docs": [
            "@php scripts/generate-documentation.php",
            "echo 'Documentation generated.'"
        ],
        "cache-config": [
            "@php scripts/cache-config.php",
            "echo 'Configuration cached.'"
        ],
        "validate-environment": [
            "@php scripts/validate-environment.php"
        ],
        "cleanup-temp": [
            "rm -rf storage/cache/*",
            "rm -rf storage/logs/*.log",
            "echo 'Temporary files cleaned up.'"
        ],
        "post-install-cmd": [
            "@setup-directories",
            "@set-permissions",
            "@copy-env",
            "@generate-key",
            "@download-assets",
            "@download-fonts",
            "@compile-assets",
            "@setup-database",
            "@run-migrations",
            "@seed-database",
            "@cache-config",
            "@validate-environment",
            "@generate-docs",
            "echo '======================================='",
            "echo 'Post-install setup completed!'",
            "echo '======================================='",
            "echo 'Run `composer run-script show-info` for details.'"
        ],
        "post-update-cmd": [
            "@setup-directories",
            "@set-permissions",
            "@download-assets",
            "@download-fonts",
            "@compile-assets",
            "@cleanup-temp",
            "@run-migrations",
            "@cache-config",
            "@validate-environment",
            "echo '======================================='",
            "echo 'Post-update setup completed!'",
            "echo '======================================='",
            "echo 'Run `composer run-script show-info` for details.'"
        ],
        "show-info": [
            "echo 'Application: mycompany/myapp v1.0.0'",
            "echo 'PHP Version Required: >=8.1'",
            "echo 'Storage Directory: storage/'",
            "echo 'Public Assets: public/assets/'",
            "echo 'Configuration: config/'",
            "@php -r \"echo 'Current PHP: ' . PHP_VERSION . PHP_EOL;\""
        ],
        "test": [
            "@php vendor/bin/phpunit --configuration phpunit.xml"
        ],
        "analyse": [
            "@php vendor/bin/phpstan analyse src --level=max"
        ],
        "fresh-install": [
            "@cleanup-temp",
            "@setup-directories",
            "@set-permissions",
            "@copy-env",
            "@generate-key",
            "@download-assets",
            "@download-fonts",
            "@compile-assets",
            "@setup-database",
            "@run-migrations",
            "@seed-database",
            "@cache-config",
            "@validate-environment",
            "@generate-docs",
            "echo 'Fresh installation complete!'"
        ]
    },
    "scripts-descriptions": {
