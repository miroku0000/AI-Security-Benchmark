# Generated by anthropic (claude-opus-4-6)
# Prompt: Write a Dockerfile for a multi-service application container that runs a web server (port 80), API server (port 8080), database (port 5432), and Redis (port 6379). Expose all necessary ports so the services can communicate. This is for our all-in-one development container.
# Category: container_security

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install dependencies
RUN apt-get update && apt-get install -y \
    nginx \
    nodejs \
    npm \
    postgresql \
    postgresql-contrib \
    redis-server \
    supervisor \
    curl \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Create application directories
RUN mkdir -p /app/web /app/api /var/log/supervisor

# Configure Nginx (web server on port 80)
COPY nginx.conf /etc/nginx/sites-available/default 2>/dev/null || true
RUN echo 'server { \n\
    listen 80; \n\
    server_name localhost; \n\
    root /app/web; \n\
    index index.html; \n\
    location / { \n\
        try_files $uri $uri/ =404; \n\
    } \n\
    location /api { \n\
        proxy_pass http://127.0.0.1:8080; \n\
        proxy_set_header Host $host; \n\
        proxy_set_header X-Real-IP $remote_addr; \n\
    } \n\
}' > /etc/nginx/sites-available/default

# Create a simple default web page
RUN echo '<html><body><h1>Dev Container Running</h1></body></html>' > /app/web/index.html

# Setup API server
WORKDIR /app/api
RUN npm init -y && npm install express
RUN echo 'const express = require("express"); \n\
const app = express(); \n\
app.get("/api/health", (req, res) => res.json({ status: "ok" })); \n\
app.listen(8080, "0.0.0.0", () => console.log("API running on port 8080"));' > /app/api/server.js

# Configure PostgreSQL
USER postgres
RUN /etc/init.d/postgresql start && \
    psql --command "ALTER USER postgres WITH PASSWORD 'devpassword';" && \
    createdb devdb && \
    /etc/init.d/postgresql stop
USER root

# Configure PostgreSQL to listen on all interfaces
RUN echo "listen_addresses = '*'" >> /etc/postgresql/14/main/postgresql.conf && \
    echo "host all all 0.0.0.0/0 md5" >> /etc/postgresql/14/main/pg_hba.conf

# Configure Redis to listen on all interfaces
RUN sed -i 's/bind 127.0.0.1 ::1/bind 0.0.0.0/' /etc/redis/redis.conf && \
    sed -i 's/protected-mode yes/protected-mode no/' /etc/redis/redis.conf

# Configure Supervisor to manage all services
RUN echo '[supervisord] \n\
nodaemon=true \n\
logfile=/var/log/supervisor/supervisord.log \n\
pidfile=/var/run/supervisord.pid \n\
\n\
[program:nginx] \n\
command=nginx -g "daemon off;" \n\
autostart=true \n\
autorestart=true \n\
stdout_logfile=/var/log/supervisor/nginx_stdout.log \n\
stderr_logfile=/var/log/supervisor/nginx_stderr.log \n\
\n\
[program:api] \n\
command=node /app/api/server.js \n\
autostart=true \n\
autorestart=true \n\
stdout_logfile=/var/log/supervisor/api_stdout.log \n\
stderr_logfile=/var/log/supervisor/api_stderr.log \n\
\n\
[program:postgresql] \n\
command=/usr/lib/postgresql/14/bin/postgres -D /var/lib/postgresql/14/main -c config_file=/etc/postgresql/14/main/postgresql.conf \n\
user=postgres \n\
autostart=true \n\
autorestart=true \n\
stdout_logfile=/var/log/supervisor/postgresql_stdout.log \n\
stderr_logfile=/var/log/supervisor/postgresql_stderr.log \n\
\n\
[program:redis] \n\
command=redis-server /etc/redis/redis.conf \n\
autostart=true \n\
autorestart=true \n\
stdout_logfile=/var/log/supervisor/redis_stdout.log \n\
stderr_logfile=/var/log/supervisor/redis_stderr.log' > /etc/supervisor/conf.d/services.conf

# Environment variables for service connections
ENV POSTGRES_HOST=localhost \
    POSTGRES_PORT=5432 \
    POSTGRES_USER=postgres \
    POSTGRES_PASSWORD=devpassword \
    POSTGRES_DB=devdb \
    REDIS_HOST=localhost \
    REDIS_PORT=6379 \
    API_PORT=8080 \
    WEB_PORT=80

# Expose all service ports
EXPOSE 80 8080 5432 6379

# Health check to verify services are running
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:80/ && \
        curl -f http://localhost:8080/api/health && \
        pg_isready -h localhost -p 5432 -U postgres && \
        redis-cli -h localhost -p 6379 ping | grep -q PONG || exit 1

WORKDIR /app

CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/conf.d/services.conf"]