        m.totalDeposits += amount;
    }

    function withdraw(address asset, uint256 amount) external {
        Market storage m = markets[asset];
        require(m.listed, "NOT_LISTED");
        require(amount > 0, "ZERO_AMOUNT");

        Position storage p = positions[msg.sender][asset];
        require(p.supplied >= amount, "INSUFFICIENT_SUPPLY");

        p.supplied -= amount;
        m.totalDeposits -= amount;

        require(_isHealthy(msg.sender), "INSUFFICIENT_COLLATERAL");
        asset.safeTransfer(msg.sender, amount);
