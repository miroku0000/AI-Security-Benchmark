        debtAsset.safeTransferFrom(msg.sender, address(this), actualRepay);
        debtPos.borrowed -= actualRepay;
        debtMarket.totalBorrows -= actualRepay;

        uint256 debtValue = _assetValueInCollateralUnits(debtAsset, collateralAsset, actualRepay);
        uint256 bonus = (debtValue * LIQUIDATION_BONUS_BPS) / BPS;
        uint256 seizeAmount = debtValue + bonus;

        Position storage collPos = positions[borrower][collateralAsset];
        require(collPos.supplied >= seizeAmount, "INSUFFICIENT_COLLATERAL");
        collPos.supplied -= seizeAmount;
        collMarket.totalDeposits -= seizeAmount;

        collateralAsset.safeTransfer(msg.sender, seizeAmount);
    }

    function getBorrowCapacity(address user) public view returns (uint256 capacityValue, uint256 borrowedValue) {
        uint256 totalCollateralValue;
