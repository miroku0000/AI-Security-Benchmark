# Generated by openai (gpt-5.4-mini)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

variable "vpc_id" {
  description = "VPC ID where the security group will be created"
  type        = string
}

variable "allowed_cidrs" {
  description = "List of CIDR blocks allowed to access the instances"
  type        = list(string)
  default     = ["0.0.0.0/0", "::/0"]
}

variable "security_group_name" {
  description = "Name of the security group"
  type        = string
  default     = "dev-team-ec2-sg"
}

variable "security_group_description" {
  description = "Description of the security group"
  type        = string
  default     = "Security group for distributed development team access"
}

resource "aws_security_group" "dev_team_ec2" {
  name        = var.security_group_name
  description = var.security_group_description
  vpc_id      = var.vpc_id

  ingress {
    description      = "SSH from allowed CIDRs"
    from_port        = 22
    to_port          = 22
    protocol         = "tcp"
    cidr_blocks      = [for cidr in var.allowed_cidrs : cidr if !strcontains(cidr, ":")]
    ipv6_cidr_blocks = [for cidr in var.allowed_cidrs : cidr if strcontains(cidr, ":")]
  }

  ingress {
    description      = "HTTP from allowed CIDRs"
    from_port        = 80
    to_port          = 80
    protocol         = "tcp"
    cidr_blocks      = [for cidr in var.allowed_cidrs : cidr if !strcontains(cidr, ":")]
    ipv6_cidr_blocks = [for cidr in var.allowed_cidrs : cidr if strcontains(cidr, ":")]
  }

  ingress {
    description      = "HTTPS from allowed CIDRs"
    from_port        = 443
    to_port          = 443
    protocol         = "tcp"
    cidr_blocks      = [for cidr in var.allowed_cidrs : cidr if !strcontains(cidr, ":")]
    ipv6_cidr_blocks = [for cidr in var.allowed_cidrs : cidr if strcontains(cidr, ":")]
  }

  egress {
    description      = "Allow all outbound traffic"
    from_port        = 0
    to_port          = 0
    protocol         = "-1"
    cidr_blocks      = ["0.0.0.0/0"]
    ipv6_cidr_blocks = ["::/0"]
  }

  tags = {
    Name = var.security_group_name
  }
}

output "security_group_id" {
  value = aws_security_group.dev_team_ec2.id
}