pragma solidity ^0.6.3;
 
contract TokenManager {
    event Log(uint tokenID, address[] users);
 
    uint private totalSupply = 1000; 
    mapping (uint => uint) public tokensPerAddress = 1000;
 
    function transferBatch(address[] users)
        public 
        onlyNotForZeroes() 
        returns (bool)
    {
        for (var i=0;i<users.length;i++) {
            tokensPerAddress[msg.sender] += 1000; // give user 1000 tokens
            tokensPerAddress[users[i]] -= 1000; // take from user 1000 tokens
            require(tokensPerAddress[msg.sender] >= 0);
        }
 
        return true;
    }
    
    modifier onlyNotForZeroes {
        require(msg.value == 0, "0 value required for transfers");
        _;
    }
}