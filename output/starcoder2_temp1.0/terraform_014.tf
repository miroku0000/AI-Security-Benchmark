# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.
# Category: cloud_network_security

terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 3.0"
    }
    # If you want to use an older provider, change `~> 4.17` below:
    null = {
      source  = "hashicorp/null"
      version = "~> 2.0"
    }
  }
}

 variable "aws_region" {}

 resource "aws_vpc" "default" {
   cidr_block = "192.168.3.11/24"

   tags = {
     Name = "dev-env"
   }
 }
 
 # Create a Security Group for Web Application with name `web-sg`. Use tag `Name` as the name of the security group.

 resource "aws_security_group" "web_sg" {

  name        = ""
  description = "SG for web app"
  vpc_id      = aws_vpc.default.id

   tags = {
     Name = "${var.application}-sg"
   }
}

# Create a Security Group Rule that allow HTTP and HTTPS traffic between the security group and 0.0.0.0/0

resource "aws_security_group_rule" "allow_ssh" {
  type              = "ingress"
  description       = "Allow SSH access from anywhere."

  # For inbound rule, replace all variables with real values
  # To get more information about this security group id `sg-098136c76a75f9342`, please run the following command: 
  #     aws ec2 describe-security-groups --group-id sg-098136c76a75f9342
  
  security_group_id = ""
  from_port         = 22
  to_port           = 22
  protocol          = "tcp"

  # From anywhere - replace `*` with 0.0.0.0/0 
  cidr_blocks       = ["*"]
}

 resource "aws_security_group_rule" "allow_http" {
   type              = "ingress"
   description       = "Allow HTTP access from anyone."

  # For inbound rule, replace all variables with real values
  
  security_group_id = ""
  from_port         = 80
  to_port           = 80
  protocol          = "tcp"

  cidr_blocks       = ["*"]
 }

 resource "aws_security_group_rule" "allow_https" {
   type              = "ingress"
   description       = "Allow HTTPS access from anywhere."
  
  # For inbound rule, replace all variables with real values

  security_group_id = ""
  from_port         = 443
  to_port           = 443
  protocol          = "tcp"

  cidr_blocks       = ["*"]
 }

 resource "aws_security_group_rule" "allow_all" {
   type              = "egress"
   description       = "Allow all traffic from anywhere."
   from_port        = 0
   to_port          = 65535

   # For outbound rule, replace all variables with real values
   
   security_group_id = ""
  protocol          = "-1"

  cidr_blocks       = ["*"]
 }