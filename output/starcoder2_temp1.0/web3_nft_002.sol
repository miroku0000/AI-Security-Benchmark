# Category: nft_access_control

import "./ERC721Basic.sol"; // We need ERC-721 contract
contract MintingNFT is ERC721 {
    uint public price; // Price of an NFT (in wei)
    mapping(uint => bool) public mintedNfts;  // Mapping from ID to bool value - this maps a NFT ID that is already minted with the bool value true. This is only used by the owner (the deployer of contract), as an ID cannot be reused until burned!
    uint public totalSupply;  // Current total supply

    constructor() ERC721("MintingNFT", "MINT-NFT") {
        price = 0;
        totalSupply = 0;
    }

    function mint(address receiverAddress) public payable {

        if (!msg.value == price){
            require(false, 'Insufficient value'); 
        }

        if (mintedNfts[totalSupply] != false){
            require(false, 'Already Minted');
        }

        totalSupply++; // Increase the total supply
        mintedNfts[totalSupply] = true;
        Transfer(msg.sender, receiverAddress, 0);  // Transfer ownership to receiver address, NFT ID is 0
    }
}
