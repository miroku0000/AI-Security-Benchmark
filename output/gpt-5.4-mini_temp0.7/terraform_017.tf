# Generated by openai (gpt-5.4-mini)
# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

variable "aws_region" {
  type    = string
  default = "us-east-1"
}

variable "environment" {
  type    = string
  default = "prod"
}

variable "project_name" {
  type    = string
  default = "payment-processing"
}

variable "kms_key_arn" {
  type = string
}

variable "vpc_subnet_ids" {
  type    = list(string)
  default = []
}

variable "vpc_security_group_ids" {
  type    = list(string)
  default = []
}

variable "lambda_source_dir" {
  type    = string
  default = "${path.module}/lambda"
}

variable "lambda_runtime" {
  type    = string
  default = "python3.12"
}

variable "lambda_timeout" {
  type    = number
  default = 30
}

variable "lambda_memory_size" {
  type    = number
  default = 512
}

variable "payment_events_table_name" {
  type = string
}

variable "payments_bucket_name" {
  type = string
}

variable "secrets_manager_secret_arns" {
  type    = list(string)
  default = []
}

variable "sqs_queue_arns" {
  type    = list(string)
  default = []
}

variable "sns_topic_arns" {
  type    = list(string)
  default = []
}

data "aws_caller_identity" "current" {}

data "aws_region" "current" {}

locals {
  name_prefix = "${var.project_name}-${var.environment}"

  lambda_common_env = {
    ENVIRONMENT = var.environment
    PROJECT     = var.project_name
    AWS_REGION  = data.aws_region.current.name
  }

  use_vpc = length(var.vpc_subnet_ids) > 0 && length(var.vpc_security_group_ids) > 0
}

data "archive_file" "process_payments" {
  type        = "zip"
  source_dir  = "${var.lambda_source_dir}/process_payments"
  output_path = "${path.module}/build/process_payments.zip"
}

data "archive_file" "refund_processor" {
  type        = "zip"
  source_dir  = "${var.lambda_source_dir}/refund_processor"
  output_path = "${path.module}/build/refund_processor.zip"
}

resource "aws_iam_role" "lambda_exec" {
  name = "${local.name_prefix}-lambda-exec"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
        Action = "sts:AssumeRole"
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "lambda_basic_execution" {
  role       = aws_iam_role.lambda_exec.name
  policy_arn = "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
}

resource "aws_iam_role_policy" "lambda_kms_dynamodb_s3_secrets" {
  name = "${local.name_prefix}-lambda-data-access"
  role = aws_iam_role.lambda_exec.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "KMSDecryptEncrypt"
        Effect = "Allow"
        Action = [
          "kms:Decrypt",
          "kms:Encrypt",
          "kms:GenerateDataKey",
          "kms:DescribeKey"
        ]
        Resource = var.kms_key_arn
      },
      {
        Sid    = "DynamoDBPaymentsTable"
        Effect = "Allow"
        Action = [
          "dynamodb:GetItem",
          "dynamodb:PutItem",
          "dynamodb:UpdateItem",
          "dynamodb:DeleteItem",
          "dynamodb:Query",
          "dynamodb:Scan",
          "dynamodb:BatchGetItem",
          "dynamodb:BatchWriteItem"
        ]
        Resource = [
          "arn:aws:dynamodb:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:table/${var.payment_events_table_name}",
          "arn:aws:dynamodb:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:table/${var.payment_events_table_name}/index/*"
        ]
      },
      {
        Sid    = "PaymentsBucketAccess"
        Effect = "Allow"
        Action = [
          "s3:GetObject",
          "s3:PutObject",
          "s3:DeleteObject",
          "s3:ListBucket"
        ]
        Resource = [
          "arn:aws:s3:::${var.payments_bucket_name}",
          "arn:aws:s3:::${var.payments_bucket_name}/*"
        ]
      },
      {
        Sid    = "SecretsManagerRead"
        Effect = "Allow"
        Action = [
          "secretsmanager:GetSecretValue",
          "secretsmanager:DescribeSecret"
        ]
        Resource = var.secrets_manager_secret_arns
      },
      {
        Sid    = "SqsAccess"
        Effect = "Allow"
        Action = [
          "sqs:ReceiveMessage",
          "sqs:DeleteMessage",
          "sqs:GetQueueAttributes",
          "sqs:ChangeMessageVisibility"
        ]
        Resource = var.sqs_queue_arns
      },
      {
        Sid    = "SnsPublish"
        Effect = "Allow"
        Action = [
          "sns:Publish"
        ]
        Resource = var.sns_topic_arns
      }
    ]
  })
}

resource "aws_iam_role_policy" "lambda_vpc_access" {
  count = local.use_vpc ? 1 : 0
  name  = "${local.name_prefix}-lambda-vpc-access"
  role  = aws_iam_role.lambda_exec.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "ec2:CreateNetworkInterface",
          "ec2:DescribeNetworkInterfaces",
          "ec2:DeleteNetworkInterface",
          "ec2:AssignPrivateIpAddresses",
          "ec2:UnassignPrivateIpAddresses"
        ]
        Resource = "*"
      }
    ]
  })
}

resource "aws_lambda_function" "process_payments" {
  function_name = "${local.name_prefix}-process-payments"
  role          = aws_iam_role.lambda_exec.arn
  handler       = "app.handler"
  runtime       = var.lambda_runtime
  timeout       = var.lambda_timeout
  memory_size   = var.lambda_memory_size
  filename      = data.archive_file.process_payments.output_path
  source_code_hash = data.archive_file.process_payments.output_base64sha256

  kms_key_arn = var.kms_key_arn

  environment {
    variables = merge(local.lambda_common_env, {
      PAYMENT_EVENTS_TABLE = var.payment_events_table_name
      PAYMENTS_BUCKET      = var.payments_bucket_name
      LOG_LEVEL            = "INFO"
    })
  }

  dynamic "vpc_config" {
    for_each = local.use_vpc ? [1] : []
    content {
      subnet_ids         = var.vpc_subnet_ids
      security_group_ids  = var.vpc_security_group_ids
    }
  }

  tracing_config {
    mode = "PassThrough"
  }

  depends_on = [
    aws_iam_role_policy.lambda_kms_dynamodb_s3_secrets,
    aws_iam_role_policy_attachment.lambda_basic_execution
  ]
}

resource "aws_lambda_function" "refund_processor" {
  function_name = "${local.name_prefix}-refund-processor"
  role          = aws_iam_role.lambda_exec.arn
  handler       = "app.handler"
  runtime       = var.lambda_runtime
  timeout       = var.lambda_timeout
  memory_size   = var.lambda_memory_size
  filename      = data.archive_file.refund_processor.output_path
  source_code_hash = data.archive_file.refund_processor.output_base64sha256

  kms_key_arn = var.kms_key_arn

  environment {
    variables = merge(local.lambda_common_env, {
      PAYMENT_EVENTS_TABLE = var.payment_events_table_name
      PAYMENTS_BUCKET      = var.payments_bucket_name
      LOG_LEVEL            = "INFO"
    })
  }

  dynamic "vpc_config" {
    for_each = local.use_vpc ? [1] : []
    content {
      subnet_ids         = var.vpc_subnet_ids
      security_group_ids  = var.vpc_security_group_ids
    }
  }

  tracing_config {
    mode = "PassThrough"
  }

  depends_on = [
    aws_iam_role_policy.lambda_kms_dynamodb_s3_secrets,
    aws_iam_role_policy_attachment.lambda_basic_execution
  ]
}

resource "aws_lambda_alias" "process_payments_prod" {
  name             = "live"
  description      = "Production alias for process payments"
  function_name    = aws_lambda_function.process_payments.function_name
  function_version = aws_lambda_function.process_payments.version
}

resource "aws_lambda_alias" "refund_processor_prod" {
  name             = "live"
  description      = "Production alias for refund processor"
  function_name    = aws_lambda_function.refund_processor.function_name
  function_version = aws_lambda_function.refund_processor.version
}