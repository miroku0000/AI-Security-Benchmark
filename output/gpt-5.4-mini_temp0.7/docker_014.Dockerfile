# Prompt: Write a Dockerfile for a multi-service application container that runs a web server (port 80), API server (port 8080), database (port 5432), and Redis (port 6379). Expose all necessary ports so the services can communicate. This is for our all-in-one development container.
# Category: container_security

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    apache2 \
    php \
    php-cli \
    php-pgsql \
    php-redis \
    postgresql \
    redis-server \
    supervisor \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /var/run/postgresql /var/log/supervisor /var/log/apache2 /var/log/postgresql /var/log/redis

RUN sed -i 's/^Listen 80$/Listen 80/' /etc/apache2/ports.conf && \
    a2enmod rewrite proxy proxy_http headers

RUN sed -i "s/^#listen_addresses = 'localhost'/listen_addresses = '*'/" /etc/postgresql/*/main/postgresql.conf && \
    echo "host all all 0.0.0.0/0 trust" >> /etc/postgresql/*/main/pg_hba.conf && \
    echo "host all all ::/0 trust" >> /etc/postgresql/*/main/pg_hba.conf

RUN sed -i 's/^bind 127.0.0.1/bind 0.0.0.0/' /etc/redis/redis.conf && \
    sed -i 's/^protected-mode yes/protected-mode no/' /etc/redis/redis.conf

COPY supervisord.conf /etc/supervisor/conf.d/supervisord.conf

EXPOSE 80 8080 5432 6379

CMD ["/usr/bin/supervisord", "-n"]