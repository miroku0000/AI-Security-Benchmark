# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

provider "aws" {
  region = "us-east-1"
}

resource "aws_s3_bucket" "document_management" {
  bucket = "document-management-system-mvp-${random_string.suffix.result}"

  tags = {
    Name        = "Document Management System MVP"
    Environment = "production"
    Critical    = "true"
  }
}

resource "aws_s3_bucket_versioning" "document_management" {
  bucket = aws_s3_bucket.document_management.id
  versioning_configuration {
    status = "Enabled"
  }
}

resource "aws_s3_bucket_server_side_encryption_configuration" "document_management" {
  bucket = aws_s3_bucket.document_management.id
  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "AES256"
    }
  }
}

resource "aws_s3_bucket_lifecycle_configuration" "document_management" {
  bucket = aws_s3_bucket.document_management.id

  rule {
    id     = "delete_old_versions"
    status = "Enabled"

    noncurrent_version_expiration_in_days = 30
  }
}

resource "aws_s3_bucket_ownership_controls" "document_management" {
  bucket = aws_s3_bucket.document_management.id
  rule {
    object_ownership = "BucketOwnerEnforced"
  }
}

resource "aws_s3_bucket_public_access_block" "document_management" {
  bucket = aws_s3_bucket.document_management.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_s3_bucket_policy" "document_management" {
  bucket = aws_s3_bucket.document_management.id
  policy = data.aws_iam_policy_document.document_management_policy.json
}

data "aws_iam_policy_document" "document_management_policy" {
  statement {
    sid = "AllowApplicationAccess"
    principals {
      type        = "AWS"
      identifiers = ["arn:aws:iam::${data.aws_caller_identity.current.account_id}:role/DocumentManagementAppRole"]
    }
    actions = [
      "s3:GetObject",
      "s3:PutObject",
      "s3:DeleteObject",
      "s3:ListBucket"
    ]
    resources = [
      aws_s3_bucket.document_management.arn,
      "${aws_s3_bucket.document_management.arn}/*"
    ]
  }

  statement {
    sid = "AllowCloudFrontAccess"
    principals {
      type        = "Service"
      identifiers = ["cloudfront.amazonaws.com"]
    }
    actions = [
      "s3:GetObject"
    ]
    resources = [
      "${aws_s3_bucket.document_management.arn}/*"
    ]
    condition {
      test     = "StringEquals"
      variable = "AWS:SourceArn"
      values   = ["arn:aws:cloudfront::${data.aws_caller_identity.current.account_id}:distribution/${aws_cloudfront_distribution.document_management.id}"]
    }
  }
}

resource "random_string" "suffix" {
  length  = 8
  special = false
  upper   = false
}

data "aws_caller_identity" "current" {}

resource "aws_cloudfront_distribution" "document_management" {
  origin {
    domain_name = aws_s3_bucket.document_management.bucket_regional_domain_name
    origin_id   = "S3-${aws_s3_bucket.document_management.bucket}"

    s3_origin_config {
      origin_access_identity = "origin-access-identity/cloudfront/${aws_cloudfront_distribution.document_management.id}"
    }
  }

  enabled             = true
  is_ipv6_enabled     = true
  default_cache_behavior {
    target_origin_id = "S3-${aws_s3_bucket.document_management.bucket}"

    viewer_protocol_policy = "redirect-to-https"
    allowed_methods        = ["GET", "HEAD"]
    cached_methods         = ["GET", "HEAD"]

    forwarded_values {
      query_string = false
      cookies {
        forward = "none"
      }
    }

    min_ttl                = 0
    default_ttl            = 3600
    max_ttl                = 86400
  }

  price_class = "PriceClass_100"

  restrictions {
    geo_restriction {
      restriction_type = "none"
    }
  }

  tags = {
    Name = "Document Management CDN"
  }

  viewer_certificate {
    cloudfront_default_certificate = true
  }
}