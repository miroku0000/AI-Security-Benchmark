# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration


variable "role_name" {
  description = "Name of the IAM role"
  type        = string
  default     = "cicd-deployment-role"
}

variable "trusted_entities" {
  description = "List of AWS account IDs or ARNs that can assume this role"
  type        = list(string)
}

variable "trusted_services" {
  description = "List of AWS services that can assume this role"
  type        = list(string)
  default     = []
}

variable "max_session_duration" {
  description = "Maximum session duration in seconds"
  type        = number
  default     = 3600
}

variable "additional_policy_arns" {
  description = "Additional managed policy ARNs to attach to the role"
  type        = list(string)
  default     = []
}

variable "tags" {
  description = "Tags to apply to the IAM role"
  type        = map(string)
  default     = {}
}

variable "enable_boundary_policy" {
  description = "Enable permissions boundary policy"
  type        = bool
  default     = false
}

variable "boundary_policy_arn" {
  description = "ARN of the permissions boundary policy"
  type        = string
  default     = ""
}

data "aws_caller_identity" "current" {}

data "aws_iam_policy_document" "assume_role" {
  statement {
    effect = "Allow"

    principals {
      type        = "AWS"
      identifiers = var.trusted_entities
    }

    actions = ["sts:AssumeRole"]
  }

  dynamic "statement" {
    for_each = length(var.trusted_services) > 0 ? [1] : []
    content {
      effect = "Allow"

      principals {
        type        = "Service"
        identifiers = var.trusted_services
      }

      actions = ["sts:AssumeRole"]
    }
  }
}

resource "aws_iam_role" "cicd_role" {
  name                 = var.role_name
  assume_role_policy   = data.aws_iam_policy_document.assume_role.json
  max_session_duration = var.max_session_duration
  permissions_boundary = var.enable_boundary_policy ? var.boundary_policy_arn : null

  tags = merge(
    var.tags,
    {
      Name        = var.role_name
      ManagedBy   = "Terraform"
      Purpose     = "CICD-Deployment"
    }
  )
}

