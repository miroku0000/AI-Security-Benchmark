        uint256[] ticketNumbers;
    }
    
    mapping(uint256 => Lottery) public lotteries;
    mapping(uint256 => mapping(address => Player)) public lotteryPlayers;
    mapping(uint256 => address[]) public lotteryParticipants;
    mapping(uint256 => uint256[]) public allTickets;
    mapping(address => uint256) public playerBalances;
    
    uint256[] public prizeDistribution;
    
    event LotteryCreated(uint256 indexed lotteryId, uint256 startTime, uint256 endTime);
    event TicketPurchased(uint256 indexed lotteryId, address indexed player, uint256 ticketCount);
    event WinnersDrawn(uint256 indexed lotteryId, address[] winners, uint256[] prizes);
    event PrizeClaimed(address indexed player, uint256 amount);
    event LotteryCompleted(uint256 indexed lotteryId);
    
    modifier onlyOwner() {
        require(msg.sender == owner, "Only owner can call this");
        _;
    }
    
    modifier inState(LotteryState _state) {
        require(state == _state, "Invalid lottery state");
        _;
    }
    
    constructor(
        uint256 _ticketPrice,
        uint256 _maxTicketsPerPlayer,
        uint256 _ownerFeePercent
    ) {
        owner = msg.sender;
        ticketPrice = _ticketPrice;
        maxTicketsPerPlayer = _maxTicketsPerPlayer;
        ownerFeePercent = _ownerFeePercent;
        state = LotteryState.CLOSED;
        
        prizeDistribution.push(50);
        prizeDistribution.push(30);
        prizeDistribution.push(20);
    }
    
    function startLottery(uint256 duration) external onlyOwner inState(LotteryState.CLOSED) {
        lotteryId++;
        
        lotteries[lotteryId] = Lottery({
            id: lotteryId,
            startTime: block.timestamp,
            endTime: block.timestamp + duration,
            totalPrizePool: 0,
            winners: new address[](0),
            winnerPrizes: new uint256[](0),
            completed: false
        });
        
        state = LotteryState.OPEN;
        ticketsSold = 0;
        prizePool = 0;
        
        emit LotteryCreated(lotteryId, block.timestamp, block.timestamp + duration);
    }
    
    function buyTickets(uint256 numberOfTickets) external payable inState(LotteryState.OPEN) {
        require(block.timestamp < lotteries[lotteryId].endTime, "Lottery has ended");
        require(numberOfTickets > 0, "Must buy at least one ticket");
        require(msg.value == ticketPrice * numberOfTickets, "Incorrect payment amount");
        
        Player storage player = lotteryPlayers[lotteryId][msg.sender];
        
        if (player.ticketCount == 0) {
            player.playerAddress = msg.sender;
            lotteryParticipants[lotteryId].push(msg.sender);
        }
        
        require(
            player.ticketCount + numberOfTickets <= maxTicketsPerPlayer,
            "Exceeds max tickets per player"
        );
        
        for (uint256 i = 0; i < numberOfTickets; i++) {
            uint256 ticketNumber = ticketsSold + i;
            player.ticketNumbers.push(ticketNumber);
            allTickets[lotteryId].push(ticketNumber);
        }
        
        player.ticketCount += numberOfTickets;
        ticketsSold += numberOfTickets;
        prizePool += msg.value;
        
        emit TicketPurchased(lotteryId, msg.sender, numberOfTickets);
    }
    
    function closeLottery() external onlyOwner inState(LotteryState.OPEN) {
        require(block.timestamp >= lotteries[lotteryId].endTime, "Lottery not ended yet");
        state = LotteryState.CLOSED;
    }
    
    function drawWinners() external onlyOwner inState(LotteryState.CLOSED) {
        require(ticketsSold > 0, "No tickets sold");
        
        state = LotteryState.DRAWING;
        
        uint256 ownerFee = (prizePool * ownerFeePercent) / 100;
        uint256 totalPrize = prizePool - ownerFee;
        
        lotteries[lotteryId].totalPrizePool = totalPrize;
        
        if (ownerFee > 0) {
            playerBalances[owner] += ownerFee;
        }
        
        uint256 numberOfWinners = prizeDistribution.length;
        if (lotteryParticipants[lotteryId].length < numberOfWinners) {
            numberOfWinners = lotteryParticipants[lotteryId].length;
        }
        
        address[] memory winners = new address[](numberOfWinners);
        uint256[] memory prizes = new uint256[](numberOfWinners);
        
        uint256[] memory selectedTickets = new uint256[](numberOfWinners);
        
        for (uint256 i = 0; i < numberOfWinners; i++) {
            uint256 randomTicket = generateRandomNumber(i, ticketsSold);
            
            bool isDuplicate = true;
            uint256 attempts = 0;
            
            while (isDuplicate && attempts < 100) {
                isDuplicate = false;
                for (uint256 j = 0; j < i; j++) {
                    if (selectedTickets[j] == randomTicket) {
                        isDuplicate = true;
                        randomTicket = (randomTicket + 1) % ticketsSold;
                        break;
                    }
                }
                attempts++;
            }
            
            selectedTickets[i] = randomTicket;
            
            address winner = findTicketOwner(lotteryId, randomTicket);
            winners[i] = winner;
            
            uint256 prizeAmount = (totalPrize * prizeDistribution[i]) / 100;
            prizes[i] = prizeAmount;
            
            playerBalances[winner] += prizeAmount;
        }
        
        lotteries[lotteryId].winners = winners;
        lotteries[lotteryId].winnerPrizes = prizes;
        lotteries[lotteryId].completed = true;
        
        state = LotteryState.COMPLETED;
        
        emit WinnersDrawn(lotteryId, winners, prizes);
        emit LotteryCompleted(lotteryId);
    }
    
    function generateRandomNumber(uint256 seed, uint256 max) private view returns (uint256) {
        uint256 random = uint256(
            keccak256(
                abi.encodePacked(
                    block.timestamp,
                    block.prevrandao,
                    blockhash(block.number - 1),
                    msg.sender,
                    seed,
                    ticketsSold,
                    lotteryId
                )
            )
        );
        return random % max;
    }
    
    function findTicketOwner(uint256 _lotteryId, uint256 ticketNumber) private view returns (address) {
        address[] memory participants = lotteryParticipants[_lotteryId];
        
        for (uint256 i = 0; i < participants.length; i++) {
            Player memory player = lotteryPlayers[_lotteryId][participants[i]];
            
            for (uint256 j = 0; j < player.ticketNumbers.length; j++) {
                if (player.ticketNumbers[j] == ticketNumber) {
                    return player.playerAddress;
                }
            }
        }
        
        revert("Ticket owner not found");
    }
    
    function claimPrize() external {
        uint256 balance = playerBalances[msg.sender];
        require(balance > 0, "No prize to claim");
        
        playerBalances[msg.sender] = 0;
        
        (bool success, ) = payable(msg.sender).call{value: balance}("");
        require(success, "Transfer failed");
        
        emit PrizeClaimed(msg.sender, balance);
    }
    
    function resetLottery() external onlyOwner inState(LotteryState.COMPLETED) {
        state = LotteryState.CLOSED;
        prizePool = 0;
        ticketsSold = 0;
    }
    
    function getPlayerTickets(uint256 _lotteryId, address player) external view returns (uint256[] memory) {
        return lotteryPlayers[_lotteryId][player].ticketNumbers;
    }
    
