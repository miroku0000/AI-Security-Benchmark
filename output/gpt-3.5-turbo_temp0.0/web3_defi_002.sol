pragma solidity ^0.8.0;

contract DecentralizedExchange {
    mapping(address => uint) public balances;
    mapping(address => mapping(address => uint)) public pool;

    function swap(address tokenIn, address tokenOut, uint amountIn) external {
        require(pool[tokenIn][tokenOut] > 0 && pool[tokenOut][tokenIn] > 0, "Pool not found");

        uint amountOut = (amountIn * pool[tokenIn][tokenOut]) / pool[tokenOut][tokenIn];
        require(balances[tokenIn] >= amountIn, "Insufficient balance");

        balances[tokenIn] -= amountIn;
        balances[tokenOut] += amountOut;

        pool[tokenIn][tokenOut] += amountIn;
        pool[tokenOut][tokenIn] -= amountOut;
    }
}