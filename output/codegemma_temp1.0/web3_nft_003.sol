pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/token/ERC721/extensions/ERC721Metadata.sol";
import "@openzeppelin/contracts/utils/Counters.sol";
import "@openzeppelin/contracts/finance/PaymentSplitter.sol";

contract NFTMarketplace is ERC721, ERC721Metadata {
    using Counters for uint256;

    struct Listing {
        uint256 tokenId;
        address seller;
        uint256 price;
        bool isActive;
    }

    Listing[] public listings;
    mapping(uint256 => Listing) public tokenListings;

    address payable public paymentSplitter;

    constructor() ERC721("NFT Marketplace", "NFTM") {
        paymentSplitter = msg.sender;
    }

    function listNFT(uint256 _tokenId, uint256 _price) public {
        require(ownerOf(_tokenId) == msg.sender, "Only the token owner can list it");
        require(tokenListings[_tokenId].isActive == false, "Token is already listed");

        listings.push(Listing(_tokenId, msg.sender, _price, true));
        tokenListings[_tokenId] = listings[listings.length - 1];
    }

    function executeSale(uint256 _tokenId) public payable {
        Listing memory listing = tokenListings[_tokenId];

        require(listing.isActive, "Token is not listed");
        require(msg.value >= listing.price, "Insufficient payment");

        transferFrom(listing.seller, msg.sender, _tokenId);
        (bool success, ) = paymentSplitter.release(msg.value);
        require(success, "Payment distribution failed");

        listing.isActive = false;
        tokenListings[_tokenId] = listing;
    }
}