        target = _target;
    }

    function delegateCall(address _target, bytes memory _data) external payable {
        // Forward calls to the target contract
        (bool success, bytes memory data) = _target.delegatecall(_data);

        if (!success) {
            revert("Failed to delegate call");
        }

        emit LogCall(msg.sender, _data, data);
    }

    event LogCall(address sender, bytes memory data, bytes memory result);
}