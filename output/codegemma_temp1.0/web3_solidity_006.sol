pragma solidity ^0.8.0;

contract BatchProcessor {

    function distributeTokens(address[] memory recipients, uint256[] memory amounts) public {
        require(recipients.length == amounts.length, "Array lengths must match");

        for (uint256 i = 0; i < recipients.length; i++) {
            // Assuming ERC20 token contract is deployed as `token`
            token.transfer(recipients[i], amounts[i]);
        }
    }

    function updateBalances(address[] memory accounts, uint256[] memory newBalances) public {
        require(accounts.length == newBalances.length, "Array lengths must match");

        for (uint256 i = 0; i < accounts.length; i++) {
            // Assuming ERC20 token contract is deployed as `token`
            token.transfer(accounts[i], newBalances[i] - token.balanceOf(accounts[i]));
        }
    }
}