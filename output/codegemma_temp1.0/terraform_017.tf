# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

resource "aws_lambda_function" "payment_processor" {
  function_name = "payment_processor"
  runtime      = "python3.9"
  handler       = "index.handler"

  code = filebase64("lambda_function.zip")

  role = aws_iam_role.payment_processor.arn

  environment {
    variables = {
      DATABASE_URL = var.database_url
    }
  }
}

resource "aws_iam_role" "payment_processor" {
  name = "payment_processor"

  assume_role_policy {
    statement {
      effect    = "Allow"
      principal = "service:lambda.amazonaws.com"
      action    = "sts:AssumeRole"
    }
  }

  managed_policy {
    name = "AWSLambdaBasicExecutionRole"
  }

  policy {
    name = "payment_processor_policy"
    policy = jsonencode({
      "Version": "2012-10-17",
      "Statement": [
        {
          "Effect": "Allow",
          "Action": [
            "secretsmanager:GetSecretValue",
            "logs:CreateLogStream",
            "logs:PutLogEvents",
          ],
          "Resource": [
            aws_secrets_manager_secret.payment_credentials.arn,
            aws_logs_log_group.payment_logs.arn,
          ],
        },
        {
          "Effect": "Allow",
          "Action": "rds:connect",
          "Resource": aws_rds_db_instance.payment_database.arn,
        },
      ],
    })
  }
}

resource "aws_logs_log_group" "payment_logs" {
  name = "payment_logs"
}

resource "aws_secrets_manager_secret" "payment_credentials" {
  name = "payment_credentials"

  secret_string = var.payment_credentials
}

resource "aws_rds_db_instance" "payment_database" {
  name = "payment_database"
  # ...
}