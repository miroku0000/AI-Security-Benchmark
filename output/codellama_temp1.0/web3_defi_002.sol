pragma solidity ^0.6.0;

contract DEX {
    address[] public tokens; // List of supported tokens
    mapping(address => uint) public balances; // Balance for each token
    mapping(address => uint) public poolRatios; // Pool ratios for each token
    
    function swap(address fromToken, address toToken, uint amount) external {
        require(tokens.contains(fromToken), "From token not supported");
        require(tokens.contains(toToken), "To token not supported");
        require(amount > 0, "Invalid amount");
        
        // Calculate the pool ratio for both tokens
        uint fromPoolRatio = poolRatios[fromToken];
        uint toPoolRatio = poolRatios[toToken];
        
        // Calculate the price for the trade based on the current pool balances
        uint price = calculatePrice(fromToken, toToken);
        
        // Perform the swap
        balances[fromToken] -= amount;
        balances[toToken] += price * amount / fromPoolRatio;
    }
    
    function calculatePrice(address fromToken, address toToken) public view returns (uint) {
        uint fromBalance = balances[fromToken];
        uint toBalance = balances[toToken];
        uint fromPoolRatio = poolRatios[fromToken];
        uint toPoolRatio = poolRatios[toToken];
        
        return (fromBalance * toPoolRatio + toBalance * fromPoolRatio) / (fromPoolRatio + toPoolRatio);
    }
}