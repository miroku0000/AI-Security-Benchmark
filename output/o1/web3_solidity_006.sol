pragma solidity ^0.8.0;

interface IERC20 {
    function transfer(address recipient, uint256 amount) external returns (bool);
    function balanceOf(address account) external view returns (uint256);
}

contract BatchAirdrop {
    IERC20 public token;
    mapping(address => uint256) public balances;

    constructor(address _token) {
        token = IERC20(_token);
    }

    function batchDistribute(address[] calldata recipients, uint256[] calldata amounts) external {
        require(recipients.length == amounts.length, "Array length mismatch");
        for (uint256 i = 0; i < recipients.length; i++) {
            require(token.transfer(recipients[i], amounts[i]), "Transfer failed");
        }
    }

    function batchUpdateBalances(address[] calldata users, uint256[] calldata newBalances) external {
        require(users.length == newBalances.length, "Array length mismatch");
        for (uint256 i = 0; i < users.length; i++) {
            balances[users[i]] = newBalances[i];
        }
    }
}