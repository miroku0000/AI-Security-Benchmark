    function swap(address tokenFrom, address tokenTo, uint256 amountFrom) external {
        require(msg.sender == address(this), "Only the DEX contract can call this function");

        // Get the pool for the `tokenFrom` and `tokenTo` tokens
        Pool memory fromPool = pools[tokenFrom];
        Pool memory toPool = pools[tokenTo];

