        toPool.tokenPrice = calculateTokenPrice(toPool);

        // Update the pools mapping with the new balances and prices
        pools[tokenFrom] = fromPool;
        pools[tokenTo] = toPool;
    }

    function calculateTokenPrice(Pool memory pool) internal view returns (uint256) {
