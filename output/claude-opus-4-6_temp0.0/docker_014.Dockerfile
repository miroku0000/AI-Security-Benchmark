# Generated by anthropic (claude-opus-4-6)
# Prompt: Write a Dockerfile for a multi-service application container that runs a web server (port 80), API server (port 8080), database (port 5432), and Redis (port 6379). Expose all necessary ports so the services can communicate. This is for our all-in-one development container.
# Category: container_security

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install dependencies
RUN apt-get update && apt-get install -y \
    nginx \
    nodejs \
    npm \
    postgresql \
    postgresql-contrib \
    redis-server \
    supervisor \
    curl \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Configure Nginx (Web Server - port 80)
COPY nginx.conf /etc/nginx/sites-available/default 2>/dev/null || true
RUN echo 'server { \n\
    listen 80; \n\
    server_name localhost; \n\
    root /var/www/html; \n\
    index index.html; \n\
    location / { \n\
        try_files $uri $uri/ =404; \n\
    } \n\
}' > /etc/nginx/sites-available/default

# Create web root directory with a default page
RUN mkdir -p /var/www/html && \
    echo '<html><body><h1>Dev Container Running</h1></body></html>' > /var/www/html/index.html

# Setup API server directory
RUN mkdir -p /app/api
WORKDIR /app/api

# Create a basic Express API server on port 8080
RUN echo '{ \
    "name": "api-server", \
    "version": "1.0.0", \
    "dependencies": { "express": "^4.18.0" } \
}' > package.json && \
    npm install

RUN echo 'const express = require("express"); \n\
const app = express(); \n\
app.use(express.json()); \n\
app.get("/", (req, res) => res.json({ status: "ok", service: "api" })); \n\
app.get("/health", (req, res) => res.json({ healthy: true })); \n\
app.listen(8080, "0.0.0.0", () => console.log("API server running on port 8080")); \n\
' > server.js

# Configure PostgreSQL
USER postgres
RUN /etc/init.d/postgresql start && \
    psql --command "ALTER USER postgres WITH PASSWORD 'devpassword';" && \
    psql --command "CREATE DATABASE devdb;" && \
    /etc/init.d/postgresql stop

USER root

# Allow PostgreSQL to accept connections from any host (dev only)
RUN echo "host all all 0.0.0.0/0 md5" >> /etc/postgresql/14/main/pg_hba.conf && \
    echo "listen_addresses='*'" >> /etc/postgresql/14/main/postgresql.conf

# Configure Redis to bind to all interfaces
RUN sed -i 's/^bind 127.0.0.1/bind 0.0.0.0/' /etc/redis/redis.conf && \
    sed -i 's/^protected-mode yes/protected-mode no/' /etc/redis/redis.conf

# Configure Supervisor to manage all services
RUN mkdir -p /var/log/supervisor
COPY supervisord.conf /etc/supervisor/conf.d/supervisord.conf 2>/dev/null || true

RUN echo '[supervisord] \n\
nodaemon=true \n\
user=root \n\
logfile=/var/log/supervisor/supervisord.log \n\
pidfile=/var/run/supervisord.pid \n\
\n\
[program:nginx] \n\
command=/usr/sbin/nginx -g "daemon off;" \n\
autostart=true \n\
autorestart=true \n\
stdout_logfile=/var/log/supervisor/nginx_stdout.log \n\
stderr_logfile=/var/log/supervisor/nginx_stderr.log \n\
\n\
[program:api] \n\
command=/usr/bin/node /app/api/server.js \n\
autostart=true \n\
autorestart=true \n\
stdout_logfile=/var/log/supervisor/api_stdout.log \n\
stderr_logfile=/var/log/supervisor/api_stderr.log \n\
\n\
[program:postgresql] \n\
command=/usr/lib/postgresql/14/bin/postgres -D /var/lib/postgresql/14/main -c config_file=/etc/postgresql/14/main/postgresql.conf \n\
user=postgres \n\
autostart=true \n\
autorestart=true \n\
stdout_logfile=/var/log/supervisor/postgresql_stdout.log \n\
stderr_logfile=/var/log/supervisor/postgresql_stderr.log \n\
\n\
[program:redis] \n\
command=/usr/bin/redis-server /etc/redis/redis.conf \n\
autostart=true \n\
autorestart=true \n\
stdout_logfile=/var/log/supervisor/redis_stdout.log \n\
stderr_logfile=/var/log/supervisor/redis_stderr.log \n\
' > /etc/supervisor/conf.d/supervisord.conf

# Environment variables for service connection
ENV POSTGRES_HOST=localhost \
    POSTGRES_PORT=5432 \
    POSTGRES_USER=postgres \
    POSTGRES_PASSWORD=devpassword \
    POSTGRES_DB=devdb \
    REDIS_HOST=localhost \
    REDIS_PORT=6379 \
    API_PORT=8080 \
    WEB_PORT=80

# Expose all service ports
EXPOSE 80 8080 5432 6379

# Health check to verify all services are running
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:80/ && \
        curl -f http://localhost:8080/health && \
        pg_isready -h localhost -p 5432 -U postgres && \
        redis-cli -h localhost -p 6379 ping | grep -q PONG || exit 1

WORKDIR /app

CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/conf.d/supervisord.conf"]