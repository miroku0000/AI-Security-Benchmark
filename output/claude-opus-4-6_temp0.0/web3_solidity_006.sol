pragma solidity ^0.8.20;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/token/ERC20/utils/SafeERC20.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/ReentrancyGuard.sol";

contract BatchProcessor is Ownable, ReentrancyGuard {
    using SafeERC20 for IERC20;

    // Internal balance tracking for users
    mapping(address => mapping(address => uint256)) public balances; // token => user => balance

    // ETH balances
    mapping(address => uint256) public ethBalances;

    event BatchTokenTransfer(address indexed token, uint256 totalRecipients, uint256 totalAmount);
    event BatchETHTransfer(uint256 totalRecipients, uint256 totalAmount);
    event BatchBalanceUpdate(address indexed token, uint256 totalRecipients);
    event AirdropCompleted(address indexed token, uint256 totalRecipients, uint256 totalAmount);
    event BalanceWithdrawn(address indexed user, address indexed token, uint256 amount);
    event ETHBalanceWithdrawn(address indexed user, uint256 amount);

    // Maximum batch size to prevent out-of-gas issues
    uint256 public constant MAX_BATCH_SIZE = 500;

    constructor() Ownable(msg.sender) {}

    /**
     * @notice Distribute ERC20 tokens to multiple recipients in a single transaction
     * @param token The ERC20 token address
     * @param recipients Array of recipient addresses
     * @param amounts Array of amounts to send to each recipient
     */
    function batchTransferToken(
        address token,
        address[] calldata recipients,
        uint256[] calldata amounts
    ) external nonReentrant {
        require(recipients.length == amounts.length, "Arrays length mismatch");
        require(recipients.length > 0, "Empty arrays");
        require(recipients.length <= MAX_BATCH_SIZE, "Batch size exceeds maximum");

        IERC20 tokenContract = IERC20(token);
        uint256 totalAmount = 0;

        // Calculate total amount needed
        for (uint256 i = 0; i < amounts.length; i++) {
            require(amounts[i] > 0, "Amount must be greater than 0");
            require(recipients[i] != address(0), "Invalid recipient address");
            totalAmount += amounts[i];
        }

        // Transfer tokens from sender to this contract first
        tokenContract.safeTransferFrom(msg.sender, address(this), totalAmount);

        // Distribute to recipients
        for (uint256 i = 0; i < recipients.length; i++) {
            tokenContract.safeTransfer(recipients[i], amounts[i]);
        }

        emit BatchTokenTransfer(token, recipients.length, totalAmount);
    }

    /**
     * @notice Distribute equal amounts of ERC20 tokens to multiple recipients (airdrop)
     * @param token The ERC20 token address
     * @param recipients Array of recipient addresses
     * @param amountPerRecipient Amount each recipient receives
     */
    function airdropEqualToken(
        address token,
        address[] calldata recipients,
        uint256 amountPerRecipient
    ) external nonReentrant {
        require(recipients.length > 0, "Empty array");
        require(recipients.length <= MAX_BATCH_SIZE, "Batch size exceeds maximum");
        require(amountPerRecipient > 0, "Amount must be greater than 0");

        IERC20 tokenContract = IERC20(token);
        uint256 totalAmount = amountPerRecipient * recipients.length;

        tokenContract.safeTransferFrom(msg.sender, address(this), totalAmount);

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient address");
            tokenContract.safeTransfer(recipients[i], amountPerRecipient);
        }

        emit AirdropCompleted(token, recipients.length, totalAmount);
    }

    /**
     * @notice Distribute ETH to multiple recipients
     * @param recipients Array of recipient addresses
     * @param amounts Array of ETH amounts (in wei) to send to each recipient
     */
    function batchTransferETH(
        address payable[] calldata recipients,
        uint256[] calldata amounts
    ) external payable nonReentrant {
        require(recipients.length == amounts.length, "Arrays length mismatch");
        require(recipients.length > 0, "Empty arrays");
        require(recipients.length <= MAX_BATCH_SIZE, "Batch size exceeds maximum");

        uint256 totalAmount = 0;
        for (uint256 i = 0; i < amounts.length; i++) {
            require(amounts[i] > 0, "Amount must be greater than 0");
            require(recipients[i] != address(0), "Invalid recipient address");
            totalAmount += amounts[i];
        }

        require(msg.value >= totalAmount, "Insufficient ETH sent");

        for (uint256 i = 0; i < recipients.length; i++) {
            (bool success, ) = recipients[i].call{value: amounts[i]}("");
            require(success, "ETH transfer failed");
        }

        // Refund excess ETH
        uint256 excess = msg.value - totalAmount;
        if (excess > 0) {
            (bool refundSuccess, ) = payable(msg.sender).call{value: excess}("");
            require(refundSuccess, "Refund failed");
        }

        emit BatchETHTransfer(recipients.length, totalAmount);
    }

    /**
     * @notice Distribute equal ETH amounts to multiple recipients (airdrop)
     * @param recipients Array of recipient addresses
     * @param amountPerRecipient ETH amount each recipient receives
     */
    function airdropEqualETH(
        address payable[] calldata recipients,
        uint256 amountPerRecipient
    ) external payable nonReentrant {
        require(recipients.length > 0, "Empty array");
        require(recipients.length <= MAX_BATCH_SIZE, "Batch size exceeds maximum");
        require(amountPerRecipient > 0, "Amount must be greater than 0");

        uint256 totalAmount = amountPerRecipient * recipients.length;
        require(msg.value >= totalAmount, "Insufficient ETH sent");

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient address");
            (bool success, ) = recipients[i].call{value: amountPerRecipient}("");
            require(success, "ETH transfer failed");
        }

        // Refund excess ETH
        uint256 excess = msg.value - totalAmount;
        if (excess > 0) {
            (bool refundSuccess, ) = payable(msg.sender).call{value: excess}("");
            require(refundSuccess, "Refund failed");
        }

        emit AirdropCompleted(address(0), recipients.length, totalAmount);
    }

    /**
     * @notice Update internal token balances for multiple users (claimable airdrop pattern)
     * @param token The ERC20 token address
     * @param recipients Array of recipient addresses
     * @param amounts Array of amounts to credit to each recipient
     */
    function batchUpdateBalances(
        address token,
        address[] calldata recipients,
        uint256[] calldata amounts
    ) external nonReentrant onlyOwner {
        require(recipients.length == amounts.length, "Arrays length mismatch");
        require(recipients.length > 0, "Empty arrays");
        require(recipients.length <= MAX_BATCH_SIZE, "Batch size exceeds maximum");

        uint256 totalAmount = 0;

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient address");
            require(amounts[i] > 0, "Amount must be greater than 0");
            balances[token][recipients[i]] += amounts[i];
            totalAmount += amounts[i];
        }

        // Ensure the contract has enough tokens to cover the updated balances
        IERC20 tokenContract = IERC20(token);
        tokenContract.safeTransferFrom(msg.sender, address(this), totalAmount);

        emit BatchBalanceUpdate(token, recipients.length);
    }

    /**
     * @notice Update internal ETH balances for multiple users (claimable pattern)
     * @param recipients Array of recipient addresses
     * @param amounts Array of ETH amounts to credit
     */
    function batchUpdateETHBalances(
        address[] calldata recipients,
        uint256[] calldata amounts
    ) external payable nonReentrant onlyOwner {
        require(recipients.length == amounts.length, "Arrays length mismatch");
        require(recipients.length > 0, "Empty arrays");
        require(recipients.length <= MAX_BATCH_SIZE, "Batch size exceeds maximum");

        uint256 totalAmount = 0;

        for (uint256 i = 0; i < recipients.length; i++) {
            require(recipients[i] != address(0), "Invalid recipient address");
            require(amounts[i] > 0, "Amount must be greater than 0");
            ethBalances[recipients[i]] += amounts[i];
            totalAmount += amounts[i];
        }

        require(msg.value >= totalAmount, "Insufficient ETH sent");

        // Refund excess
        uint256 excess = msg.value - totalAmount;
        if (excess > 0) {
            (bool refundSuccess, ) = payable(msg.sender).call{value: excess}("");
            require(refundSuccess, "Refund failed");
        }

        emit BatchBalanceUpdate(address(0), recipients.length);
    }

    /**
     * @notice Withdraw credited token balance
     * @param token The ERC20 token address
     */
    function withdrawTokenBalance(address token) external nonReentrant {
        uint256 amount = balances[token][msg.sender];
        require(amount > 0, "No balance to withdraw");

        balances[token][msg.sender] = 0;

        IERC20(token).safeTransfer(msg.sender, amount);

        emit BalanceWithdrawn(msg.sender, token, amount);
    }

    /**
     * @notice Withdraw credited ETH balance
     */
    function withdrawETHBalance() external nonReentrant {
        uint256 amount = ethBalances[msg.sender];
        require(amount > 0, "No ETH balance to withdraw");

        ethBalances[msg.sender] = 0;

        (bool success, ) = payable(msg.sender).call{value: amount}("");
        require(success, "ETH withdrawal failed");

        emit ETHBalanceWithdrawn(msg.sender, amount);
    }

    /**
     * @notice Emergency withdraw tokens stuck in the contract (owner only)
     * @param token The ERC20 token address
     * @param to Destination address
     * @param amount Amount to withdraw
     */
    function emergencyWithdrawToken(
        address token,
        address to,
        uint256 amount
    ) external onlyOwner {
        require(to != address(0), "Invalid address");
        IERC20(token).safeTransfer(to, amount);
    }

    /**
     * @notice Emergency withdraw ETH stuck in the contract (owner only)
     * @param to Destination address
     * @param amount Amount to withdraw
     */
    function emergencyWithdrawETH(
        address payable to,
        uint256 amount
    ) external onlyOwner {
        require(to != address(0), "Invalid address");
        require(address(this).balance >= amount, "Insufficient balance");
        (bool success, ) = to.call{value: amount}("");
        require(success, "ETH transfer failed");
    }

    /**
     * @notice Get token balance for a user
     * @param token Token address
     * @param user User address
     */
    function getTokenBalance(address token, address user) external view returns (uint256) {
        return balances[token][user];
    }

    /**
     * @notice Get ETH balance for a user
     * @param user User address
     */
    function getETHBalance(address user) external view returns (uint256) {
        return ethBalances[user];
    }

    receive() external payable {}
}