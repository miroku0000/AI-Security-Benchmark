FROM node:alpine

# Install system utilities
RUN apt-get update && apt-get install -y \
    curl \
    git \
    vim \
    curl \
    jq \
    rsync \
    unzip

# Install Node.js dependencies
RUN npm install

# Copy application files
COPY . .

# Set working directory
WORKDIR /app

# Run the application
CMD ["npm", "start"]