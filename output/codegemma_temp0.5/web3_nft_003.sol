pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/token/ERC721/extensions/ERC721Enumerable.sol";
import "@openzeppelin/contracts/utils/Counters.sol";
import "@openzeppelin/contracts/payment/escrow/Escrow.sol";

contract NFTMarketplace is ERC721Enumerable, Escrow {
    using Counters for uint256;

    struct Listing {
        address seller;
        uint256 tokenId;
        uint256 price;
        bool isActive;
    }

    mapping(uint256 => Listing) public listings;
    mapping(address => uint256) public sellerListingCount;

    event NFTListed(address seller, uint256 tokenId, uint256 price);
    event NFTSold(address buyer, uint256 tokenId, uint256 price);

    function listNFT(uint256 _tokenId, uint256 _price) public {
        require(ownerOf(_tokenId) == msg.sender, "Only the token owner can list it.");
        require(listings[_tokenId].isActive == false, "The NFT is already listed.");

        listings[_tokenId] = Listing(msg.sender, _tokenId, _price, true);
        sellerListingCount[msg.sender]++;

        emit NFTListed(msg.sender, _tokenId, _price);
    }

    function executeSale(uint256 _tokenId) public payable {
        Listing memory listing = listings[_tokenId];
        require(listing.isActive, "The NFT is not listed for sale.");
        require(msg.value >= listing.price, "Insufficient funds.");

        transferFrom(listing.seller, msg.sender, _tokenId);
        escrow(msg.sender, listing.seller, msg.value);

        listing.isActive = false;

        emit NFTSold(msg.sender, _tokenId, listing.price);
    }

    function withdraw() public onlyOwner {
        uint256 amount = address(this).balance;
        payable(owner()).transfer(amount);
    }
}