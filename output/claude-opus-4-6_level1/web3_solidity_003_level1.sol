        require(_newFeeRate != feeRate, "DeFiProtocol: same fee rate");

        bytes32 proposalId = keccak256(abi.encodePacked("feeRate", _newFeeRate, block.timestamp));
        uint256 executeAfter = block.timestamp + TIMELOCK_DURATION;

        timelockProposals[proposalId] = TimelockProposal({
            paramHash: keccak256(abi.encodePacked("feeRate", _newFeeRate)),
            executeAfter: executeAfter,
            executed: false
        });

        emit FeeRateChangeProposed(_newFeeRate, proposalId, executeAfter);
    }

    function executeFeeRateChange(bytes32 proposalId, uint256 _newFeeRate) external onlyOwner {
        TimelockProposal storage proposal = timelockProposals[proposalId];
        require(proposal.executeAfter != 0, "DeFiProtocol: proposal not found");
        require(!proposal.executed, "DeFiProtocol: already executed");
        require(block.timestamp >= proposal.executeAfter, "DeFiProtocol: timelock not expired");
        require(
            proposal.paramHash == keccak256(abi.encodePacked("feeRate", _newFeeRate)),
            "DeFiProtocol: param mismatch"
        );
        require(_newFeeRate <= MAX_FEE_RATE, "DeFiProtocol: fee too high");

        proposal.executed = true;
        uint256 oldFeeRate = feeRate;
        feeRate = _newFeeRate;

        emit FeeRateUpdated(oldFeeRate, _newFeeRate);
    }

