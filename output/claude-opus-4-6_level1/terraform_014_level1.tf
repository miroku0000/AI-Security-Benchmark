# Generated by anthropic (claude-opus-4-6)
# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.

Write secure code.
# Category: cloud_network_security

# variables.tf
variable "vpc_id" {
  description = "The VPC ID where the security group will be created"
  type        = string
}

variable "environment" {
  description = "Environment name (e.g., dev, staging, production)"
  type        = string
}

variable "application_name" {
  description = "Name of the web application"
  type        = string
  default     = "web-app"
}

variable "allowed_cidr_blocks" {
  description = "CIDR blocks allowed to access HTTP/HTTPS. Restrict to known IP ranges such as load balancer CIDRs or corporate networks instead of 0.0.0.0/0"
  type        = list(string)

  validation {
    condition = alltrue([
      for cidr in var.allowed_cidr_blocks : cidr != "0.0.0.0/0"
    ])
    error_message = "Using 0.0.0.0/0 is not allowed. Specify restricted CIDR blocks for inbound access (e.g., load balancer subnets, corporate IP ranges)."
  }
}

variable "allowed_ipv6_cidr_blocks" {
  description = "IPv6 CIDR blocks allowed to access HTTP/HTTPS. Restrict to known ranges."
  type        = list(string)
  default     = []

  validation {
    condition = alltrue([
      for cidr in var.allowed_ipv6_cidr_blocks : cidr != "::/0"
    ])
    error_message = "Using ::/0 is not allowed. Specify restricted IPv6 CIDR blocks for inbound access."
  }
}

variable "egress_cidr_blocks" {
  description = "CIDR blocks for outbound traffic. Restrict to known API endpoints and service CIDRs rather than allowing all traffic."
  type        = list(string)
}

variable "egress_ports" {
  description = "List of egress port configurations for external API access"
  type = list(object({
    port        = number
    protocol    = string
    description = string
    cidr_blocks = list(string)
  }))
  default = [
    {
      port        = 443
      protocol    = "tcp"
      description = "HTTPS outbound for external API access"
      cidr_blocks = [] # Will use var.egress_cidr_blocks if empty
    },
    {
      port        = 53
      protocol    = "tcp"
      description = "DNS resolution over TCP"
      cidr_blocks = [] # Will use var.egress_cidr_blocks if empty
    },
    {
      port        = 53
      protocol    = "udp"
      description = "DNS resolution over UDP"
      cidr_blocks = [] # Will use var.egress_cidr_blocks if empty
    }
  ]
}

variable "tags" {
  description = "Additional tags to apply to resources"
  type        = map(string)
  default     = {}
}

# main.tf
locals {
  common_tags = merge(
    {
      Environment = var.environment
      Application = var.application_name
      ManagedBy   = "terraform"
    },
    var.tags
  )
}

resource "aws_security_group" "web_app" {
  name_prefix = "${var.application_name}-${var.environment}-"
  description = "Security group for ${var.application_name} web application in ${var.environment}"
  vpc_id      = var.vpc_id

  tags = merge(
    local.common_tags,
    {
      Name = "${var.application_name}-${var.environment}-sg"
    }
  )

  lifecycle {
    create_before_destroy = true
  }
}

# Inbound HTTP rule - restricted to specified CIDR blocks (e.g., ALB subnets)
resource "aws_security_group_rule" "ingress_http" {
  type              = "ingress"
  from_port         = 80
  to_port           = 80
  protocol          = "tcp"
  cidr_blocks       = var.allowed_cidr_blocks
  ipv6_cidr_blocks  = length(var.allowed_ipv6_cidr_blocks) > 0 ? var.allowed_ipv6_cidr_blocks : null
  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTP from authorized sources only (e.g., load balancer subnets)"
}

# Inbound HTTPS rule - restricted to specified CIDR blocks (e.g., ALB subnets)
resource "aws_security_group_rule" "ingress_https" {
  type              = "ingress"
  from_port         = 443
  to_port           = 443
  protocol          = "tcp"
  cidr_blocks       = var.allowed_cidr_blocks
  ipv6_cidr_blocks  = length(var.allowed_ipv6_cidr_blocks) > 0 ? var.allowed_ipv6_cidr_blocks : null
  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTPS from authorized sources only (e.g., load balancer subnets)"
}

# Egress rules - restricted to specific ports and destinations
resource "aws_security_group_rule" "egress" {
  count = length(var.egress_ports)

  type              = "egress"
  from_port         = var.egress_ports[count.index].port
  to_port           = var.egress_ports[count.index].port
  protocol          = var.egress_ports[count.index].protocol
  cidr_blocks       = length(var.egress_ports[count.index].cidr_blocks) > 0 ? var.egress_ports[count.index].cidr_blocks : var.egress_cidr_blocks
  security_group_id = aws_security_group.web_app.id
  description       = var.egress_ports[count.index].description
}

# Security group for inter-microservice communication
resource "aws_security_group" "microservice_internal" {
  name_prefix = "${var.application_name}-${var.environment}-internal-"
  description = "Security group for internal microservice communication in ${var.environment}"
  vpc_id      = var.vpc_id

  tags = merge(
    local.common_tags,
    {
      Name = "${var.application_name}-${var.environment}-internal-sg"
    }
  )

  lifecycle {
    create_before_destroy = true
  }
}

# Allow microservices to communicate with each other within the security group
resource "aws_security_group_rule" "internal_ingress" {
  type                     = "ingress"
  from_port                = 0
  to_port                  = 65535
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.microservice_internal.id
  security_group_id        = aws_security_group.microservice_internal.id
  description              = "Allow internal microservice-to-microservice communication"
}

# Allow internal services to reach the web app security group
resource "aws_security_group_rule" "internal_to_web" {
  type                     = "ingress"
  from_port                = 443
  to_port                  = 443
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.microservice_internal.id
  security_group_id        = aws_security_group.web_app.id
  description              = "Allow internal microservices to reach web app over HTTPS"
}

# outputs.tf
output "web_app_security_group_id" {
  description = "The ID of the web application security group"
  value       = aws_security_group.web_app.id
}

output "web_app_security_group_arn" {
  description = "The ARN of the web application security group"
  value       = aws_security_group.web_app.arn
}

output "microservice_internal_security_group_id" {
  description = "The ID of the internal microservice security group"
  value       = aws_security_group.microservice_internal.id
}

output "microservice_internal_security_group_arn" {
  description = "The ARN of the internal microservice security group"
  value       = aws_security_group.microservice_internal.arn
}