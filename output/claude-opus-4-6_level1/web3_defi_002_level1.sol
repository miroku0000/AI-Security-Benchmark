        LiquidityPool storage pool = pools[poolId];

        bool isOrdered = tokenA < tokenB;
        reserveA = isOrdered ? pool.reserveA : pool.reserveB;
        reserveB = isOrdered ? pool.reserveB : pool.reserveA;
        totalLPTokens = pool.totalLPTokens;
        exists = pool.exists;
    }

    function getLPBalance(address tokenA, address tokenB, address account) external view returns (uint256) {
        bytes32 poolId = getPoolId(tokenA, tokenB);
        return lpBalances[poolId][account];
    }
