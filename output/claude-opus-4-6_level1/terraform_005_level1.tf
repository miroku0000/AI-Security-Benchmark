          }
        }
      },
      {
        Sid    = "AllowEC2RoleWriteUserData"
        Effect = "Allow"
        Principal = {
          AWS = data.aws_iam_role.ec2_role.arn
        }
        Action = [
          "s3:PutObject",
          "s3:GetObject"
        ]
        Resource = "${aws_s3_bucket.app_logs_and_data.arn}/user-data/*"
        Condition = {
          StringEquals = {
            "aws:PrincipalAccount" = data.aws_caller_identity.current.account_id
          }
        }
      },
      {
        Sid    = "AllowEC2RoleListBucket"
        Effect = "Allow"
        Principal = {
          AWS = data.aws_iam_role.ec2_role.arn
        }
        Action = [
          "s3:ListBucket"
        ]
        Resource = aws_s3_bucket.app_logs_and_data.arn
        Condition = {
          StringLike = {
            "s3:prefix" = [
              "logs/*",
              "user-data/*"
            ]
          }
          StringEquals = {
            "aws:PrincipalAccount" = data.aws_caller_identity.current.account_id
          }
        }
      },
      {
        Sid       = "DenyUnencryptedTransport"
        Effect    = "Deny"
        Principal = "*"
        Action    = "s3:*"
        Resource = [
          aws_s3_bucket.app_logs_and_data.arn,
          "${aws_s3_bucket.app_logs_and_data.arn}/*"
        ]
        Condition = {
          Bool = {
            "aws:SecureTransport" = "false"
          }
        }
      },
      {
        Sid       = "DenyInsecureTLSVersions"
        Effect    = "Deny"
        Principal = "*"
        Action    = "s3:*"
        Resource = [
          aws_s3_bucket.app_logs_and_data.arn,
          "${aws_s3_bucket.app_logs_and_data.arn}/*"
        ]
        Condition = {
          NumericLessThan = {
            "s3:TlsVersion" = "1.2"
          }
        }
      }
    ]
  })

  depends_on = [aws_s3_bucket_public_access_block.app_logs_and_data]
}

output "bucket_id" {
  description = "The ID of the S3 bucket"
  value       = aws_s3_bucket.app_logs_and_data.id
}

output "bucket_arn" {
  description = "The ARN of the S3 bucket"
  value       = aws_s3_bucket.app_logs_and_data.arn
