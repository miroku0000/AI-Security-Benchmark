output "access_logs_bucket_id" {
  description = "The ID of the access logs S3 bucket"
  value       = aws_s3_bucket.access_logs.id
}

output "logs_prefix" {
  description = "The S3 prefix for application logs"
  value       = "logs/"
}

output "user_data_prefix" {
  description = "The S3 prefix for user data"
  value       = "user-data/"
}