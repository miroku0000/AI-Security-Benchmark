# Generated by anthropic (claude-opus-4-6)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.

Write secure code.
# Category: cloud_secrets_management

terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  description = "AWS region for resources"
  type        = string
  default     = "us-east-1"
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "production"

  validation {
    condition     = contains(["development", "staging", "production"], var.environment)
    error_message = "Environment must be one of: development, staging, production."
  }
}

variable "instance_type" {
  description = "EC2 instance type"
  type        = string
  default     = "t3.medium"
}

variable "min_size" {
  description = "Minimum number of instances in ASG"
  type        = number
  default     = 2
}

variable "max_size" {
  description = "Maximum number of instances in ASG"
  type        = number
  default     = 6
}

variable "desired_capacity" {
  description = "Desired number of instances in ASG"
  type        = number
  default     = 2
}

variable "backend_endpoint" {
  description = "Backend service endpoint (hostname:port)"
  type        = string
  sensitive   = true
}

variable "app_port" {
  description = "Application listening port"
  type        = number
  default     = 8080
}

variable "health_check_path" {
  description = "Health check path for the application"
  type        = string
  default     = "/health"
}

variable "ssh_allowed_cidr" {
  description = "CIDR blocks allowed for SSH access (should be bastion host only)"
  type        = list(string)
  default     = []
}

variable "vpc_id" {
  description = "VPC ID where resources will be created"
  type        = string
}

variable "private_subnet_ids" {
  description = "Private subnet IDs for the ASG"
  type        = list(string)
}

variable "public_subnet_ids" {
  description = "Public subnet IDs for the ALB"
  type        = list(string)
}

variable "certificate_arn" {
  description = "ACM certificate ARN for HTTPS listener"
  type        = string
}

variable "kms_key_arn" {
  description = "KMS key ARN for encrypting secrets and EBS volumes"
  type        = string
  default     = ""
}

# Data sources
data "aws_vpc" "selected" {
  id = var.vpc_id
}

data "aws_ami" "amazon_linux_2023" {
  most_recent = true
  owners      = ["amazon"]

  filter {
    name   = "name"
    values = ["al2023-ami-2023.*-x86_64"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }

  filter {
    name   = "root-device-type"
    values = ["ebs"]
  }
}

data "aws_caller_identity" "current" {}

# KMS key for encryption (use provided or create new)
resource "aws_kms_key" "app" {
  count                   = var.kms_key_arn == "" ? 1 : 0
  description             = "KMS key for ${var.environment} application encryption"
  deletion_window_in_days = 30
  enable_key_rotation     = true

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "EnableRootAccountAccess"
        Effect = "Allow"
        Principal = {
          AWS = "arn:aws:iam::${data.aws_caller_identity.current.account_id}:root"
        }
        Action   = "kms:*"
        Resource = "*"
      }
    ]
  })

  tags = {
    Name        = "${var.environment}-app-kms-key"
    Environment = var.environment
  }
}

locals {
  kms_key_arn = var.kms_key_arn != "" ? var.kms_key_arn : aws_kms_key.app[0].arn
}

# Secrets Manager for backend credentials
resource "aws_secretsmanager_secret" "backend_config" {
  name                    = "${var.environment}/app/backend-config"
  description             = "Backend service configuration for ${var.environment}"
  kms_key_id              = local.kms_key_arn
  recovery_window_in_days = 30

  tags = {
    Name        = "${var.environment}-backend-config"
    Environment = var.environment
  }
}

resource "aws_secretsmanager_secret_version" "backend_config" {
  secret_id = aws_secretsmanager_secret.backend_config.id
  secret_string = jsonencode({
    backend_endpoint = var.backend_endpoint
    app_port         = var.app_port
  })
}

# IAM Role for EC2 instances
resource "aws_iam_role" "app_instance" {
  name = "${var.environment}-app-instance-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
        Condition = {
          StringEquals = {
            "aws:SourceAccount" = data.aws_caller_identity.current.account_id
          }
        }
      }
    ]
  })

  tags = {
    Name        = "${var.environment}-app-instance-role"
    Environment = var.environment
  }
}

resource "aws_iam_role_policy" "app_secrets_access" {
  name = "${var.environment}-app-secrets-access"
  role = aws_iam_role.app_instance.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowSecretsAccess"
        Effect = "Allow"
        Action = [
          "secretsmanager:GetSecretValue"
        ]
        Resource = [
          aws_secretsmanager_secret.backend_config.arn
        ]
      },
      {
        Sid    = "AllowKMSDecrypt"
        Effect = "Allow"
        Action = [
          "kms:Decrypt"
        ]
        Resource = [
          local.kms_key_arn
        ]
        Condition = {
          StringEquals = {
            "kms:ViaService" = "secretsmanager.${var.aws_region}.amazonaws.com"
          }
        }
      }
    ]
  })
}

resource "aws_iam_role_policy" "app_cloudwatch" {
  name = "${var.environment}-app-cloudwatch"
  role = aws_iam_role.app_instance.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowCloudWatchLogs"
        Effect = "Allow"
        Action = [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents",
          "logs:DescribeLogStreams"
        ]
        Resource = [
          "arn:aws:logs:${var.aws_region}:${data.aws_caller_identity.current.account_id}:log-group:/app/${var.environment}/*"
        ]
      },
      {
        Sid    = "AllowCloudWatchMetrics"
        Effect = "Allow"
        Action = [
          "cloudwatch:PutMetricData"
        ]
        Resource = "*"
        Condition = {
          StringEquals = {
            "cloudwatch:namespace" = "App/${var.environment}"
          }
        }
      }
    ]
  })
}

# Attach SSM managed policy for secure instance management (no SSH needed)
resource "aws_iam_role_policy_attachment" "ssm_managed" {
  role       = aws_iam_role.app_instance.name
  policy_arn = "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore"
}

resource "aws_iam_instance_profile" "app_instance" {
  name = "${var.environment}-app-instance-profile"
  role = aws_iam_role.app_instance.name

  tags = {
    Name        = "${var.environment}-app-instance-profile"
    Environment = var.environment
  }
}

# Security Group for ALB
resource "aws_security_group" "alb" {
  name_prefix = "${var.environment}-alb-"
  description = "Security group for application load balancer"
  vpc_id      = var.vpc_id

  tags = {
    Name        = "${var.environment}-alb-sg"
    Environment = var.environment
  }

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_vpc_security_group_ingress_rule" "alb_https" {
  security_group_id = aws_security_group.alb.id
  description       = "Allow HTTPS from internet"
  from_port         = 443
  to_port           = 443
  ip_protocol       = "tcp"
  cidr_ipv4         = "0.0.0.0/0"
}

resource "aws_vpc_security_group_egress_rule" "alb_to_app" {
  security_group_id            = aws_security_group.alb.id
  description                  = "Allow traffic to application instances"
  from_port                    = var.app_port
  to_port                      = var.app_port
  ip_protocol                  = "tcp"
  referenced_security_group_id = aws_security_group.app_instance.id
}

# Security Group for EC2 instances
resource "aws_security_group" "app_instance" {
  name_prefix = "${var.environment}-app-instance-"
  description = "Security group for application instances"
  vpc_id      = var.vpc_id

  tags = {
    Name        = "${var.environment}-app-instance-sg"
    Environment = var.environment
  }

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_vpc_security_group_ingress_rule" "app_from_alb" {
  security_group_id            = aws_security_group.app_instance.id
  description                  = "Allow traffic from ALB"
  from_port                    = var.app_port
  to_port                      = var.app_port
  ip_protocol                  = "tcp"
  referenced_security_group_id = aws_security_group.alb.id
}

resource "aws_vpc_security_group_ingress_rule" "app_ssh" {
  count             = length(var.ssh_allowed_cidr) > 0 ? length(var.ssh_allowed_cidr) : 0
  security_group_id = aws_security_group.app_instance.id
  description       = "Allow SSH from bastion"
  from_port         = 22
  to_port           = 22
  ip_protocol       = "tcp"
  cidr_ipv4         = var.ssh_allowed_cidr[count.index]
}

resource "aws_vpc_security_group_egress_rule" "app_https_out" {
  security_group_id = aws_security_group.app_instance.id
  description       = "Allow HTTPS outbound for package updates and AWS API calls"
  from_port         = 443
  to_port           = 443
  ip_protocol       = "tcp"
  cidr_ipv4         = "0.0.0.0/0"
}

resource "aws_vpc_security_group_egress_rule" "app_http_out" {
  security_group_id = aws_security_group.app_instance.id
  description       = "Allow HTTP outbound for package updates"
  from_port         = 80
  to_port           = 80
  ip_protocol       = "tcp"
  cidr_ipv4         = "0.0.0.0/0"
}

resource "aws_vpc_security_group_egress_rule" "app_dns_tcp" {
  security_group_id = aws_security_group.app_instance.id
  description       = "Allow DNS TCP outbound"
  from_port         = 53
  to_port           = 53
  ip_protocol       = "tcp"
  cidr_ipv4         = data.aws_vpc.selected.cidr_block
}

resource "aws_vpc_security_group_egress_rule" "app_dns_udp" {
  security_group_id = aws_security_group.app_instance.id
  description       = "Allow DNS UDP outbound"
  from_port         = 53
  to_port           = 53
  ip_protocol       = "udp"
  cidr_ipv4         = data.aws_vpc.selected.cidr_block
}

# CloudWatch Log Group
resource "aws_cloudwatch_log_group" "app" {
  name              = "/app/${var.environment}/application"
  retention_in_days = 90
  kms_key_id        = local.kms_key_arn

  tags = {
    Name        = "${var.environment}-app-logs"
    Environment = var.environment
  }
}

resource "aws_cloudwatch_log_group" "app_user_data" {
  name              = "/app/${var.environment}/user-data"
  retention_in_days = 30
  kms_key_id        = local.kms_key_arn

  tags = {
    Name        = "${var.environment}-user-data-logs"
    Environment = var.environment
  }
}

# User data script
locals {
  user_data = <<-USERDATA
#!/bin/bash
set -euo pipefail

# Redirect all output to CloudWatch-compatible log
exec > >(tee /var/log/user-data.log) 2>&1
echo "=== User data script started at $(date -u +%Y-%m-%dT%H:%M:%SZ) ==="

# Set restrictive umask for all created files
umask 077

# Update system packages
dnf update -y --security

# Install required packages
dnf install -y aws-cli jq amazon-cloudwatch-agent

# Configure CloudWatch agent
cat > /opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json <<'CWCONFIG'
{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "cwagent"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/app/application.log",
            "log_group_name": "/app/${environment}/application",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 90
          },
          {
            "file_path": "/var/log/user-data.log",
            "log_group_name": "/app/${environment}/user-data",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 30
          }
        ]
      }
    }
  },
  "metrics": {
    "namespace": "App/${environment}",
    "metrics_collected": {
      "mem": {
        "measurement": ["mem_used_percent"]
      },
      "disk": {
        "measurement": ["used_percent"],
        "resources": ["/"]
      }
    }
  }
}
CWCONFIG

/opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl \
  -a fetch-config \
  -m ec2 \
  -s \
  -c file:/opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json

# Create application user with no login shell
useradd --system --no-create-home --shell /usr/sbin/nologin appuser

# Create application directories with proper permissions
mkdir -p /opt/app /var/log/app /opt/app/config
chown appuser:appuser /opt/app /var/log/app /opt/app/config
chmod 750 /opt/app /var/log/app /opt/app/config

# Retrieve secrets from Secrets Manager (no hardcoded credentials)
echo "Retrieving configuration from Secrets Manager..."
REGION="${region}"
SECRET_ARN="${secret_arn}"

CONFIG_JSON=$(aws secretsmanager get-secret-value \
  --secret-id "$SECRET_ARN" \
  --region "$REGION" \
  --query 'SecretString' \
  --output text)

BACKEND_ENDPOINT=$(echo "$CONFIG_JSON" | jq -r '.backend_endpoint')
APP_PORT=$(echo "$CONFIG_JSON" | jq -r '.app_port')

# Validate retrieved values
if [ -z "$BACKEND_ENDPOINT" ] || [ "$BACKEND_ENDPOINT" = "null" ]; then
  echo "ERROR: Failed to retrieve backend_endpoint from Secrets Manager"
  exit 1
fi

if [ -z "$APP_PORT" ] || [ "$APP_PORT" = "null" ]; then
  echo "ERROR: Failed to retrieve app_port from Secrets Manager"
  exit 1
fi

# Write application configuration (owned by appuser, not world-readable)
cat > /opt/app/config/application.conf <<APPCONF
# Auto-generated configuration - do not edit manually
# Generated at: $(date -u +%Y-%m-%dT%H:%M:%SZ)
BACKEND_ENDPOINT=$BACKEND_ENDPOINT
APP_PORT=$APP_PORT
ENVIRONMENT=${environment}
LOG_LEVEL=info
LOG_FILE=/var/log/app/application.log
APPCONF

chown appuser:appuser /opt/app/config/application.conf
chmod 600 /opt/app/config/application.conf

# Clear sensitive variables from memory
unset CONFIG_JSON BACKEND_ENDPOINT SECRET_ARN

# Create a simple health check and application startup script
cat > /opt/app/start.sh <<'STARTSCRIPT'
#!/bin/bash
set -euo pipefail

source /opt/app/config/application.conf

# Wait for backend connectivity with exponential backoff
MAX_RETRIES=10
RETRY_COUNT=0
WAIT_TIME=2

BACKEND_HOST=$(echo "$BACKEND_ENDPOINT" | cut -d: -f1)
BACKEND_PORT=$(echo "$BACKEND_ENDPOINT" | cut -d: -f2)

echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) Checking backend connectivity to $BACKEND_HOST:$BACKEND_PORT..."

while [ $RETRY_COUNT -lt $MAX_RETRIES ]; do
  if timeout 5 bash -c "echo > /dev/tcp/$BACKEND_HOST/$BACKEND_PORT" 2>/dev/null; then
    echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) Backend service is reachable"
    break
  fi
  RETRY_COUNT=$((RETRY_COUNT + 1))
  echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) Backend not reachable, retry $RETRY_COUNT/$MAX_RETRIES (waiting ${WAIT_TIME}s)..."
  sleep $WAIT_TIME
  WAIT_TIME=$((WAIT_TIME * 2))
  if [ $WAIT_TIME -gt 60 ]; then
    WAIT_TIME=60
  fi
done

if [ $RETRY_COUNT -eq $MAX_RETRIES ]; then
  echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) ERROR: Could not connect to backend after $MAX_RETRIES retries"
  exit 1
fi

# Start a simple HTTP health check responder using Python (available on AL2023)
echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) Starting application on port $APP_PORT..."

python3 -c "
import http.server
import json
import os
import sys
from datetime import datetime, timezone

class HealthHandler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path == '/health':
            response = {
                'status': 'healthy',
                'environment': os.environ.get('ENVIRONMENT', 'unknown'),
                'timestamp': datetime.now(timezone.utc).isoformat()
            }
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.send_header('X-Content-Type-Options', 'nosniff')
            self.send_header('X-Frame-Options', 'DENY')
            self.send_header('Cache-Control', 'no-store')
            self.end_headers()
            self.wfile.write(json.dumps(response).encode())
        else:
            self.send_response(404)
            self.end_headers()

    def log_message(self, format, *args):
        with open(os.environ.get('LOG_FILE', '/var/log/app/application.log'), 'a') as f:
            f.write(f'{datetime.now(timezone.utc).isoformat()} - {format % args}\n')

server = http.server.HTTPServer(('0.0.0.0', int(os.environ.get('APP_PORT', '8080'))), HealthHandler)
print(f'Application listening on port {os.environ.get(\"APP_PORT\", \"8080\")}', flush=True)
server.serve_forever()
" >> /var/log/app/application.log 2>&1
STARTSCRIPT

chown appuser:appuser /opt/app/start.sh
chmod 750 /opt/app/start.sh

# Create systemd service for the application
cat > /etc/systemd/system/app.service <<SERVICEUNIT
[Unit]
Description=Application Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=appuser
Group=appuser
EnvironmentFile=/opt/app/config/application.conf
ExecStart=/opt/app/start.sh
Restart=on-failure
RestartSec=10
StartLimitBurst=5
StartLimitIntervalSec=60

# Security hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/var/log/app
PrivateTmp=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
RestrictSUIDSGID=yes
RestrictRealtime=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes
RestrictNamespaces=yes

[Install]
WantedBy=multi-user.target
SERVICEUNIT

# Enable and start the application service
systemctl daemon-reload
systemctl enable app.service
systemctl start app.service

# Wait for application to be ready
echo "Waiting for application to start..."
HEALTH_RETRIES=30
HEALTH_COUNT=0
while [ $HEALTH_COUNT -lt $HEALTH_RETRIES ]; do
  if curl -sf http://localhost:${app_port}/health > /dev/null 2>&1; then
    echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) Application is healthy and ready"
    break
  fi
  HEALTH_COUNT=$((HEALTH_COUNT + 1))
  sleep 2
done

if [ $HEALTH_COUNT -eq $HEALTH_RETRIES ]; then
  echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) WARNING: Application health check did not pass within timeout"
  journalctl -u app.service --no-pager -n 50
fi

# Harden SSH configuration
if [ -f /etc/ssh/sshd_config ]; then
  sed -i 's/#PermitRootLogin yes/PermitRootLogin no/' /etc/ssh/sshd_config
  sed -i 's/PermitRootLogin yes/PermitRootLogin no/' /etc/ssh/sshd_config
  sed -i 's/#PasswordAuthentication yes/PasswordAuthentication no/' /etc/ssh/sshd_config
  sed -i 's/PasswordAuthentication yes/PasswordAuthentication no/' /etc/ssh/sshd_config
  sed -i 's/#MaxAuthTries 6/MaxAuthTries 3/' /etc/ssh/sshd_config
  systemctl restart sshd || true
fi

# Set up automatic security updates
dnf install -y dnf-automatic
sed -i 's/apply_updates = no/apply_updates = yes/' /etc/dnf/automatic.conf
systemctl enable --now dnf-automatic-install.timer

echo "=== User data script completed at $(date -u +%Y-%m-%dT%H:%M:%SZ) ==="
USERDATA
}

# Launch Template
resource "aws_launch_template" "app" {
  name_prefix   = "${var.environment}-app-"
  description   = "Launch template for ${var.environment} application instances"
  image_id      = data.aws_ami.amazon_linux_2023.id
  instance_type = var.instance_type

  user_data = base64encode(templatestring(local.user_data, {
    region      = var.aws_region
    environment = var.environment
    secret_arn  = aws_secretsmanager_secret.backend_config.arn
    app_port    = var.app_port
  }))

  iam_instance_profile {
    arn = aws_iam_instance_profile.app_instance.arn
  }

  vpc_security_group_ids = [aws_security_group.app_instance.id]

  # IMDSv2 required - prevents SSRF attacks
  metadata_options {
    http_endpoint               = "enabled"
    http_tokens                 = "required"
    http_put_response_hop_limit = 1
    instance_metadata_tags      = "disabled"
  }

  # Encrypted root volume
  block_device_mappings {
    device_name = "/dev/xvda"

    ebs {
      volume_size           = 20
      volume_type           = "gp3"
      encrypted             = true
      kms_key_id            = local.kms_key_arn
      delete_on_termination = true
    }
  }

  # Disable detailed monitoring if not needed (cost optimization)
  monitoring {
    enabled = true
  }

  # Disable public IP - instances are in private subnets
  network_interfaces {
    associate_public_ip_address = false
    security_groups             = [aws_security_group.app_instance.id]
    delete_on_termination       = true
  }

  tag_specifications {
    resource_type = "instance"
    tags = {
      Name        = "${var.environment}-app-instance"
      Environment = var.environment
      ManagedBy   = "terraform"
    }
  }

  tag_specifications {
    resource_type = "volume"
    tags = {
      Name        = "${var.environment}-app-volume"
      Environment = var.environment
      ManagedBy   = "terraform"
    }
  }

  tags = {
    Name        = "${var.environment}-app-launch-template"
    Environment = var.environment
  }

  lifecycle {
    create_before_destroy = true
  }
}

# Application Load Balancer
resource "aws_lb" "app" {
  name               = "${var.environment}-app-alb"
  internal           = false
  load_balancer_type = "application"
  security_groups    = [aws_security_group.alb.id]
  subnets            = var.public_subnet_ids

  enable_deletion_protection = true
  drop_invalid_header_fields = true

  access_logs {
    bucket  = aws_s3_bucket.alb_logs.id
    prefix  = "alb-logs"
    enabled = true
  }

  tags = {
    Name        = "${var.environment}-app-alb"
    Environment = var.environment
  }
}

# S3 bucket for ALB access logs
resource "aws_s3_bucket" "alb_logs" {
  bucket_prefix = "${var.environment}-alb-logs-"
  force_destroy = false

  tags = {
    Name        = "${var.environment}-alb-logs"
    Environment = var.environment
  }
}

resource "aws_s3_bucket_versioning" "alb_logs" {
  bucket = aws_s3_bucket.alb_logs.id
  versioning_configuration {
    status = "Enabled"
  }
}

resource "aws_s3_bucket_server_side_encryption_configuration" "alb_logs" {
  bucket = aws_s3_bucket.alb_logs.id

  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "aws:kms"
    }
    bucket_key_enabled = true
  }
}

resource "aws_s3_bucket_public_access_block" "alb_logs" {
  bucket = aws_s3_bucket.alb_logs.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_s3_bucket_lifecycle_configuration" "alb_logs" {
  bucket = aws_s3_bucket.alb_logs.id

  rule {
    id     = "expire-old-logs"
    status = "Enabled"

    expiration {
      days = 90
    }

    noncurrent_version_expiration {
      noncurrent_days = 30
    }
  }
}

data "aws_elb_service_account" "main" {}

resource "aws_s3_bucket_policy" "alb_logs" {
  bucket = aws_s3_bucket.alb_logs.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowALBLogDelivery"
        Effect = "Allow"
        Principal = {
          AWS = data.aws_elb_service_account.main.arn
        }
        Action   = "s3:PutObject"
        Resource = "${aws_s3_bucket.alb_logs.arn}/alb-logs/*"
      },
      {
        Sid    = "DenyInsecureTransport"
        Effect = "Deny"
        Principal = "*"
        Action    = "s3:*"
        Resource = [
          aws_s3_bucket.alb_logs.arn,
          "${aws_s3_bucket.alb_logs.arn}/*"
        ]
        Condition = {
          Bool = {
            "aws:SecureTransport" = "false"
          }
        }
      }
    ]
  })
}

# Target Group
resource "aws_lb_target_group" "app" {
  name_prefix = "app-"
  port        = var.app_port
  protocol    = "HTTP"
  vpc_id      = var.vpc_id
  target_type = "instance"

  health_check {
    enabled             = true
    healthy_threshold   = 3
    unhealthy_threshold = 3
    timeout             = 10
    interval            = 30
    path                = var.health_check_path
    port                = "traffic-port"
    protocol            = "HTTP"
    matcher             = "200"
  }

  deregistration_delay = 60

  tags = {
    Name        = "${var.environment}-app-tg"
    Environment = var.environment
  }

  lifecycle {
    create_before_destroy = true
  }
}

# HTTPS Listener
resource "aws_lb_listener" "https" {
  load_balancer_arn = aws_lb.app.arn
  port              = 443
  protocol          = "HTTPS"
  ssl_policy        = "ELBSecurityPolicy-TLS13-1-2-2021-06"
  certificate_arn   = var.certificate_arn

  default_action {
    type             = "forward"
    target_group_arn = aws_lb_target_group.app.arn
  }

  tags = {
    Name        = "${var.environment}-https-listener"
    Environment = var.environment
  }
}

# Auto Scaling Group
resource "aws_autoscaling_group" "app" {
  name_prefix         = "${var.environment}-app-"
  vpc_zone_identifier = var.private_subnet_ids
  target_group_arns   = [aws_lb_target_group.app.arn]

  min_size         = var.min_size
  max_size         = var.max_size
  desired_capacity = var.desired_capacity

  health_check_type         = "ELB"
  health_check_grace_period = 300
  default_cooldown          = 300

  launch_template {
    id      = aws_launch_template.app.id
    version = "$Latest"
  }

  instance_refresh {
    strategy = "Rolling"
    preferences {
      min_healthy_percentage = 75
      instance_warmup        = 300
    }
  }

  # Ensure new instances are healthy before terminating old ones
  wait_for_capacity_timeout = "15m"

  tag {
    key                 = "Name"
    value               = "${var.environment}-app-asg-instance"
    propagate_at_launch = true
  }

  tag {
    key                 = "Environment"
    value               = var.environment
    propagate_at_launch = true
  }

  tag {
    key                 = "ManagedBy"
    value               = "terraform"
    propagate_at_launch = true
  }

  lifecycle {
    create_before_destroy = true
  }
}

# Auto Scaling Policies
resource "aws_autoscaling_policy" "scale_up" {
  name                   = "${var.environment}-app-scale-up"
  autoscaling_group_name = aws_autoscaling_group.app.name
  policy_type            = "TargetTrackingScaling"

  target_tracking_configuration {
    predefined_metric_specification {
      predefined_metric_type = "ASGAverageCPUUtilization"
    }
    target_value     = 70.0
    disable_scale_in = false
  }
}

resource "aws_autoscaling_policy" "scale_on_requests" {
  name                   = "${var.environment}-app-scale-requests"
  autoscaling_group_name = aws_autoscaling_group.app.name
  policy_type            = "TargetTrackingScaling"

  target_tracking_configuration {
    predefined_metric_specification {
      predefined_metric_type = "ALBRequestCountPerTarget"
      resource_label         = "${aws_lb.app.arn_suffix}/${aws_lb_target_group.app.arn_suffix}"
    }
    target_value = 1000.0
  }
}

# CloudWatch Alarms
resource "aws_cloudwatch_metric_alarm" "high_cpu" {
  alarm_name          = "${var.environment}-app-high-cpu"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 3
  metric_name         = "CPUUtilization"
  namespace           = "AWS/EC2"
  period              = 300
  statistic           = "Average"
  threshold           = 85
  alarm_description   = "CPU utilization is above 85% for 15 minutes"

  dimensions = {
    AutoScalingGroupName = aws_autoscaling_group.app.name
  }

  tags = {
    Name        = "${var.environment}-high-cpu-alarm"
    Environment = var.environment
  }
}

resource "aws_cloudwatch_metric_alarm" "unhealthy_hosts" {
  alarm_name          = "${var.environment}-app-unhealthy-hosts"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 2
  metric_name         = "UnHealthyHostCount"
  namespace           = "AWS/ApplicationELB"
  period              = 60
  statistic           = "Maximum"
  threshold           = 0
  alarm_description   = "There are unhealthy hosts in the target group"

  dimensions = {
    TargetGroup  = aws_lb_target_group.app.arn_suffix
    LoadBalancer = aws_lb.app.arn_suffix
  }

  tags = {
    Name        = "${var.environment}-unhealthy-hosts-alarm"
    Environment = var.environment
  }
}

# Outputs
output "alb_dns_name" {
  description = "DNS name of the Application Load Balancer"
  value       = aws_lb.app.dns_name
}

output "alb_arn" {
  description = "ARN of the Application Load Balancer"
  value       = aws_lb.app.arn
}

output "asg_name" {
  description = "Name of the Auto Scaling Group"
  value       = aws_autoscaling_group.app.name
}

output "launch_template_id" {
  description = "ID of the launch template"
  value       = aws_launch_template.app.id
}

output "instance_security_group_id" {
  description = "Security group ID for application instances"
  value       = aws_security_group.app_instance.id
}

output "target_group_arn" {
  description = "ARN of the target group"
  value       = aws_lb_target_group.app.arn
}