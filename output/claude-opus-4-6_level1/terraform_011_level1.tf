      "wafv2:ListLoggingConfigurations",
      "wafv2:TagResource",
      "wafv2:UntagResource",
      "wafv2:ListTagsForResource",
    ]
    resources = ["*"]
  }

  # Terraform state management
  statement {
    sid    = "TerraformStateManagement"
    effect = "Allow"
    actions = [
      "dynamodb:GetItem",
      "dynamodb:PutItem",
      "dynamodb:DeleteItem",
    ]
    resources = [
      "arn:${local.partition}:dynamodb:*:${local.account_id}:table/terraform-*",
    ]
  }
}

resource "aws_iam_policy" "additional_services" {
  name   = "${var.role_name}-additional-services"
  policy = data.aws_iam_policy_document.additional_services.json
  tags   = local.default_tags
}

resource "aws_iam_role_policy_attachment" "additional_services" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.additional_services.arn
}

