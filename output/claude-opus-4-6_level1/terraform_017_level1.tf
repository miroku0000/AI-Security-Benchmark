  kms_key_arn = aws_kms_key.lambda_encryption.arn

  tracing_config {
    mode = "Active"
  }

  vpc_config {
    subnet_ids         = var.allowed_vpc_subnet_ids
    security_group_ids = var.allowed_vpc_security_group_ids
  }

  environment {
    variables = {
      ENVIRONMENT             = var.environment
      LOG_LEVEL               = "INFO"
      POWERTOOLS_SERVICE_NAME = "payment-validator"
    }
  }

  code_signing_config_arn = aws_lambda_code_signing_config.payment_signing.arn

  depends_on = [
    aws_cloudwatch_log_group.payment_validator,
