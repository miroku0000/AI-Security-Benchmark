# Payment Processor Lambda
resource "aws_lambda_function" "payment_processor" {
  function_name = "payment-processor-${var.environment}"
  description   = "Processes payment transactions"
  role          = aws_iam_role.payment_processor_role.arn
  handler       = "index.handler"
  runtime       = "python3.12"
  timeout       = var.lambda_timeout
  memory_size   = var.lambda_memory_size

  filename         = data.archive_file.payment_processor.output_path
  source_code_hash = data.archive_file.payment_processor.output_base64sha256

  reserved_concurrent_executions = var.reserved_concurrent_executions

  kms_key_arn = aws_kms_key.lambda_encryption.arn

  dead_letter_config {
    target_arn = aws_sqs_queue.payment_dlq.arn
  }

  tracing_config {
    mode = "Active"
  }

  vpc_config {
    subnet_ids         = var.allowed_vpc_subnet_ids
    security_group_ids = var.allowed_vpc_security_group_ids
  }

  environment {
    variables = {
      ENVIRONMENT          = var.environment
      DYNAMODB_TABLE       = aws_dynamodb_table.payment_transactions.name
      LOG_LEVEL            = "INFO"
      POWERTOOLS_SERVICE_NAME = "payment-processor"
    }
  }

  code_signing_config_arn = aws_lambda_code_signing_config.payment_signing.arn

  depends_on = [
    aws_cloudwatch_log_group.payment_processor,
    aws_iam_role_policy.payment_processor_logging,
    aws_iam_role_policy.payment_processor_vpc
  ]
}

