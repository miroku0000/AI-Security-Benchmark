  ]
}

# Payment Settlement Lambda
resource "aws_lambda_function" "payment_settlement" {
  function_name = "payment-settlement-${var.environment}"
  description   = "Handles payment settlement processing"
  role          = aws_iam_role.payment_processor_role.arn
  handler       = "index.handler"
  runtime       = "python3.12"
