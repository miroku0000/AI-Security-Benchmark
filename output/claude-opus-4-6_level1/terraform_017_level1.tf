# Code signing configuration
resource "aws_signer_signing_profile" "payment_lambda" {
  platform_id = "AWSLambda-SHA384-ECDSA"
  name_prefix = "payment_lambda_"

  signature_validity_period {
    value = 12
    type  = "MONTHS"
  }
}

resource "aws_lambda_code_signing_config" "payment_signing" {
  allowed_publishers {
    signing_profile_version_arns = [aws_signer_signing_profile.payment_lambda.version_arn]
  }

  policies {
    untrusted_artifact_on_deployment = "Enforce"
  }

  description = "Code signing config for payment processing Lambda functions"
}

# SQS event source mapping for payment processor
resource "aws_lambda_event_source_mapping" "payment_queue_trigger" {
  event_source_arn                   = aws_sqs_queue.payment_queue.arn
  function_name                      = aws_lambda_function.payment_processor.arn
  batch_size                         = 10
  maximum_batching_window_in_seconds = 5
  enabled                            = true

  function_response_types = ["ReportBatchItemFailures"]
}

# CloudWatch Alarms - Critical alarms for financial processing should NOT be deferred
resource "aws_cloudwatch_metric_alarm" "payment_processor_errors" {
  alarm_name          = "payment-processor-errors-${var.environment}"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 1
  metric_name         = "Errors"
  namespace           = "AWS/Lambda"
  period              = 60
  statistic           = "Sum"
  threshold           = 0
  alarm_description   = "Payment processor Lambda errors detected"
  treat_missing_data  = "notBreaching"

  dimensions = {
    FunctionName = aws_lambda_function.payment_processor.function_name
  }

  alarm_actions = [aws_sns_topic.payment_alerts.arn]
  ok_actions    = [aws_sns_topic.payment_alerts.arn]
}

