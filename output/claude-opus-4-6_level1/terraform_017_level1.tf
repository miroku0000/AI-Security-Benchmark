  alarm_actions = [aws_sns_topic.payment_alerts.arn]
}

resource "aws_cloudwatch_metric_alarm" "payment_processor_duration" {
  alarm_name          = "payment-processor-duration-${var.environment}"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 3
  metric_name         = "Duration"
  namespace           = "AWS/Lambda"
  period              = 60
  statistic           = "Average"
  threshold           = var.lambda_timeout * 1000 * 0.8 # 80% of timeout
  alarm_description   = "Payment processor approaching timeout threshold"
  treat_missing_data  = "notBreaching"

  dimensions = {
    FunctionName = aws_lambda_function.payment_processor.function_name
  }

  alarm_actions = [aws_sns_topic.payment_alerts.arn]
}

# SNS topic for alerts with encryption
resource "aws_sns_topic" "payment_alerts" {
  name              = "payment-processing-alerts-${var.environment}"
  kms_master_key_id = aws_kms_key.lambda_encryption.id
}

resource "aws_sns_topic_policy" "payment_alerts" {
  arn = aws_sns_topic.payment_alerts.arn

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowCloudWatchAlarms"
        Effect = "Allow"
        Principal = {
          Service = "cloudwatch.amazonaws.com"
        }
        Action   = "SNS:Publish"
        Resource = aws_sns_topic.payment_alerts.arn
        Condition = {
          StringEquals = {
            "aws:SourceAccount" = data.aws_caller_identity.current.account_id
          }
        }
      },
      {
        Sid    = "DenyInsecureTransport"
        Effect = "Deny"
        Principal = "*"
        Action = "SNS:Publish"
        Resource = aws_sns_topic.payment_alerts.arn
        Condition = {
          Bool = {
            "aws:SecureTransport" = "false"
          }
        }
      }
    ]
  })
}

# Lambda function URL disabled - use API Gateway with WAF for external access
# Resource policy to prevent public invocation
resource "aws_lambda_permission" "payment_processor_sqs" {
  statement_id  = "AllowSQSInvocation"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.payment_processor.function_name
  principal     = "sqs.amazonaws.com"
  source_arn    = aws_sqs_queue.payment_queue.arn
}

# Outputs
output "payment_processor_function_arn" {
  description = "ARN of the payment processor Lambda function"
  value       = aws_lambda_function.payment_processor.arn
}

output "payment_validator_function_arn" {
  description = "ARN of the payment validator Lambda function"
  value       = aws_lambda_function.payment_validator.arn
}

output "payment_settlement_function_arn" {
  description = "ARN of the payment settlement Lambda function"
  value       = aws_lambda_function.payment_settlement.arn
}

output "payment_queue_url" {
  description = "URL of the payment processing SQS queue"
  value       = aws_sqs_queue.payment_queue.url
}

output "payment_dlq_url" {
  description = "URL of the payment processing dead letter queue"
  value       = aws_sqs_queue.payment_dlq.url
}

output "dynamodb_table_name" {
  description = "Name of the payment transactions DynamoDB table"
  value       = aws_dynamodb_table.payment_transactions.name
}

output "sns_alerts_topic_arn" {
  description = "ARN of the payment alerts SNS topic"
  value       = aws_sns_topic.payment_alerts.arn
}