pragma solidity ^0.8.19;

import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/security/ReentrancyGuard.sol";
import "@openzeppelin/contracts/security/Pausable.sol";

/**
 * @title GameLottery
 * @dev A lottery and randomized reward system for a blockchain gaming platform.
 * 
 * IMPORTANT SECURITY NOTE: On-chain randomness using blockhash/block.timestamp is NOT
 * truly secure against miner manipulation. For production use, integrate Chainlink VRF
 * or another verifiable random function oracle. This implementation includes a commit-reveal
 * scheme to mitigate front-running attacks.
 */
contract GameLottery is Ownable, ReentrancyGuard, Pausable {
    // ============ Structs ============

    struct LotteryRound {
        uint256 roundId;
        uint256 ticketPrice;
        uint256 maxTickets;
        uint256 ticketsSold;
        uint256 prizePool;
        uint256 startTime;
        uint256 endTime;
        address winner;
        bool finalized;
        bool prizeClaimed;
        bytes32 serverSeedHash; // Commit from owner for commit-reveal
        bytes32 serverSeed;     // Revealed seed
    }

    struct Ticket {
        address owner;
        uint256 purchaseBlock;
    }

    struct RewardTier {
        string name;
        uint256 weight; // Higher weight = more common
        uint256 rewardAmount;
    }

    struct Commitment {
        bytes32 commitHash;
        uint256 commitBlock;
        bool revealed;
    }

    // ============ State Variables ============

    uint256 public currentRoundId;
    uint256 public platformFeePercent; // Basis points (e.g., 500 = 5%)
    uint256 public accumulatedFees;
    uint256 public constant MAX_FEE_PERCENT = 1000; // 10% max
    uint256 public constant MIN_REVEAL_DELAY = 2; // Minimum blocks before reveal
    uint256 public constant MAX_REVEAL_DELAY = 256; // blockhash only available for last 256 blocks
    uint256 public constant COMMIT_EXPIRY_BLOCKS = 250; // Must reveal within this window

    mapping(uint256 => LotteryRound) public rounds;
    mapping(uint256 => Ticket[]) public roundTickets;
    mapping(uint256 => mapping(address => uint256[])) public userTickets;
    mapping(address => Commitment) public userCommitments;

    RewardTier[] public rewardTiers;
    uint256 public totalRewardWeight;

    // ============ Events ============

    event RoundCreated(uint256 indexed roundId, uint256 ticketPrice, uint256 maxTickets, uint256 endTime);
    event TicketPurchased(uint256 indexed roundId, address indexed buyer, uint256 ticketIndex);
    event ServerSeedCommitted(uint256 indexed roundId, bytes32 seedHash);
    event RoundFinalized(uint256 indexed roundId, address indexed winner, uint256 prizeAmount);
    event PrizeClaimed(uint256 indexed roundId, address indexed winner, uint256 amount);
    event RewardTierAdded(uint256 indexed tierId, string name, uint256 weight, uint256 rewardAmount);
    event RewardTierUpdated(uint256 indexed tierId, uint256 weight, uint256 rewardAmount);
    event RandomRewardClaimed(address indexed user, uint256 tierId, string tierName, uint256 rewardAmount);
    event UserCommitted(address indexed user, bytes32 commitHash);
    event FeesWithdrawn(address indexed owner, uint256 amount);
    event EmergencyWithdraw(address indexed owner, uint256 amount);

    // ============ Modifiers ============

    modifier roundExists(uint256 _roundId) {
        require(rounds[_roundId].startTime != 0, "Round does not exist");
        _;
    }

    modifier roundActive(uint256 _roundId) {
        LotteryRound storage round = rounds[_roundId];
        require(block.timestamp >= round.startTime, "Round not started");
        require(block.timestamp <= round.endTime, "Round ended");
        require(!round.finalized, "Round already finalized");
        _;
    }

    // ============ Constructor ============

    constructor(uint256 _platformFeePercent) {
        require(_platformFeePercent <= MAX_FEE_PERCENT, "Fee too high");
        platformFeePercent = _platformFeePercent;
    }

    // ============ Admin Functions ============

    /**
     * @dev Creates a new lottery round with a committed server seed hash.
     */
    function createRound(
        uint256 _ticketPrice,
        uint256 _maxTickets,
        uint256 _duration,
        bytes32 _serverSeedHash
    ) external onlyOwner whenNotPaused {
        require(_ticketPrice > 0, "Ticket price must be > 0");
        require(_maxTickets > 0, "Max tickets must be > 0");
        require(_duration > 0, "Duration must be > 0");
        require(_serverSeedHash != bytes32(0), "Invalid seed hash");

        currentRoundId++;

        LotteryRound storage newRound = rounds[currentRoundId];
        newRound.roundId = currentRoundId;
        newRound.ticketPrice = _ticketPrice;
        newRound.maxTickets = _maxTickets;
        newRound.startTime = block.timestamp;
        newRound.endTime = block.timestamp + _duration;
        newRound.serverSeedHash = _serverSeedHash;

        emit RoundCreated(currentRoundId, _ticketPrice, _maxTickets, newRound.endTime);
        emit ServerSeedCommitted(currentRoundId, _serverSeedHash);
    }

    /**
     * @dev Finalizes a round by revealing the server seed and selecting a winner.
     * Uses commit-reveal to prevent manipulation.
     */
    function finalizeRound(uint256 _roundId, bytes32 _serverSeed)
        external
        onlyOwner
        nonReentrant
        roundExists(_roundId)
    {
        LotteryRound storage round = rounds[_roundId];
        require(!round.finalized, "Already finalized");
        require(block.timestamp > round.endTime || round.ticketsSold >= round.maxTickets, "Round still active");
        require(round.ticketsSold > 0, "No tickets sold");

        // Verify the committed seed
        require(
            keccak256(abi.encodePacked(_serverSeed)) == round.serverSeedHash,
            "Server seed does not match commitment"
        );

        round.serverSeed = _serverSeed;

        // Generate random index using multiple entropy sources
        uint256 randomSeed = uint256(
            keccak256(
                abi.encodePacked(
                    _serverSeed,
                    blockhash(block.number - 1),
                    block.timestamp,
                    block.prevrandao,
                    round.ticketsSold,
                    address(this).balance
                )
            )
        );

        uint256 winnerIndex = randomSeed % round.ticketsSold;
        round.winner = roundTickets[_roundId][winnerIndex].owner;

        // Calculate prize and fees
        uint256 fee = (round.prizePool * platformFeePercent) / 10000;
        accumulatedFees += fee;
        uint256 prize = round.prizePool - fee;

        round.finalized = true;

        emit RoundFinalized(_roundId, round.winner, prize);
    }

    /**
     * @dev Adds a new reward tier for the random reward system.
     */
    function addRewardTier(
        string calldata _name,
        uint256 _weight,
        uint256 _rewardAmount
    ) external onlyOwner {
        require(_weight > 0, "Weight must be > 0");
        require(bytes(_name).length > 0, "Name required");

        rewardTiers.push(RewardTier({
            name: _name,
            weight: _weight,
            rewardAmount: _rewardAmount
        }));

        totalRewardWeight += _weight;

        emit RewardTierAdded(rewardTiers.length - 1, _name, _weight, _rewardAmount);
    }

    /**
     * @dev Updates an existing reward tier.
     */
    function updateRewardTier(
        uint256 _tierId,
        uint256 _weight,
        uint256 _rewardAmount
    ) external onlyOwner {
        require(_tierId < rewardTiers.length, "Invalid tier");
        require(_weight > 0, "Weight must be > 0");

        totalRewardWeight = totalRewardWeight - rewardTiers[_tierId].weight + _weight;
        rewardTiers[_tierId].weight = _weight;
        rewardTiers[_tierId].rewardAmount = _rewardAmount;

        emit RewardTierUpdated(_tierId, _weight, _rewardAmount);
    }

    function setPlatformFee(uint256 _feePercent) external onlyOwner {
        require(_feePercent <= MAX_FEE_PERCENT, "Fee too high");
        platformFeePercent = _feePercent;
    }

    function withdrawFees() external onlyOwner nonReentrant {
        uint256 amount = accumulatedFees;
        require(amount > 0, "No fees to withdraw");
        accumulatedFees = 0;

        (bool success, ) = payable(owner()).call{value: amount}("");
        require(success, "Transfer failed");

        emit FeesWithdrawn(owner(), amount);
    }

    /**
     * @dev Fund the contract for random rewards.
     */
    function fundRewardPool() external payable onlyOwner {
        require(msg.value > 0, "Must send ETH");
    }

    function pause() external onlyOwner {
        _pause();
    }

    function unpause() external onlyOwner {
        _unpause();
    }

    /**
     * @dev Emergency withdrawal - only callable when paused.
     * Does not withdraw prize pools from active rounds.
     */
    function emergencyWithdraw() external onlyOwner whenPaused nonReentrant {
        uint256 totalLockedPrizes = 0;
        for (uint256 i = 1; i <= currentRoundId; i++) {
            if (!rounds[i].finalized || (rounds[i].finalized && !rounds[i].prizeClaimed)) {
                totalLockedPrizes += rounds[i].prizePool;
            }
        }

        uint256 withdrawable = address(this).balance - totalLockedPrizes - accumulatedFees;
        require(withdrawable > 0, "Nothing to withdraw");

        (bool success, ) = payable(owner()).call{value: withdrawable}("");
        require(success, "Transfer failed");

        emit EmergencyWithdraw(owner(), withdrawable);
    }

    // ============ User Functions ============

    /**
     * @dev Purchase tickets for a lottery round.
     */
    function purchaseTickets(uint256 _roundId, uint256 _quantity)
        external
        payable
        nonReentrant
        whenNotPaused
        roundExists(_roundId)
        roundActive(_roundId)
    {
        require(_quantity > 0 && _quantity <= 100, "Invalid quantity");
        LotteryRound storage round = rounds[_roundId];
        require(round.ticketsSold + _quantity <= round.maxTickets, "Exceeds max tickets");
        require(msg.value == round.ticketPrice * _quantity, "Incorrect payment");

        for (uint256 i = 0; i < _quantity; i++) {
            uint256 ticketIndex = round.ticketsSold;
            roundTickets[_roundId].push(Ticket({
                owner: msg.sender,
                purchaseBlock: block.number
            }));
            userTickets[_roundId][msg.sender].push(ticketIndex);
            round.ticketsSold++;

            emit TicketPurchased(_roundId, msg.sender, ticketIndex);
        }

        round.prizePool += msg.value;
    }

    /**
     * @dev Winner claims their prize.
     */
    function claimPrize(uint256 _roundId)
        external
        nonReentrant
        roundExists(_roundId)
    {
        LotteryRound storage round = rounds[_roundId];
        require(round.finalized, "Round not finalized");
        require(!round.prizeClaimed, "Prize already claimed");
        require(msg.sender == round.winner, "Not the winner");

        round.prizeClaimed = true;

        uint256 fee = (round.prizePool * platformFeePercent) / 10000;
        uint256 prize = round.prizePool - fee;

        (bool success, ) = payable(msg.sender).call{value: prize}("");
        require(success, "Transfer failed");

        emit PrizeClaimed(_roundId, msg.sender, prize);
    }

    /**
     * @dev Step 1 of commit-reveal for random rewards: User commits a hash.
     */
    function commitForReward(bytes32 _commitHash) external whenNotPaused {
        require(_commitHash != bytes32(0), "Invalid commit");
        require(
            userCommitments[msg.sender].commitBlock == 0 ||
            userCommitments[msg.sender].revealed ||
            block.number > userCommitments[msg.sender].commitBlock + COMMIT_EXPIRY_BLOCKS,
            "Existing commitment pending"
        );

        userCommitments[msg.sender] = Commitment({
            commitHash: _commitHash,
            commitBlock: block.number,
            revealed: false
        });

        emit UserCommitted(msg.sender, _commitHash);
    }

    /**
     * @dev Step 2 of commit-reveal: User reveals their secret to claim a random reward.
     * The user must wait at least MIN_REVEAL_DELAY blocks after committing.
     * commitHash should be keccak256(abi.encodePacked(secret, msg.sender))
     */
    function revealAndClaimReward(bytes32 _secret)
        external
        nonReentrant
        whenNotPaused
    {
        require(rewardTiers.length > 0, "No reward tiers");

        Commitment storage commitment = userCommitments[msg.sender];
        require(commitment.commitBlock != 0, "No commitment found");
        require(!commitment.revealed, "Already revealed");

        // Verify the commitment
        bytes32 expectedHash = keccak256(abi.encodePacked(_secret, msg.sender));
        require(expectedHash == commitment.commitHash, "Invalid secret");

        // Ensure enough blocks have passed but not too many (blockhash limitation)
        uint256 revealBlock = commitment.commitBlock + MIN_REVEAL_DELAY;
        require(block.number >= revealBlock, "Too early to reveal");
        require(block.number <= commitment.commitBlock + COMMIT_EXPIRY_BLOCKS, "Commitment expired");

        // Ensure the blockhash is still available
        require(block.number - revealBlock < MAX_REVEAL_DELAY, "Blockhash expired, recommit");

        commitment.revealed = true;

        // Generate randomness from multiple sources
        uint256 randomSeed = uint256(
            keccak256(
                abi.encodePacked(
                    _secret,
                    blockhash(revealBlock),
                    blockhash(block.number - 1),
                    block.timestamp,
                    block.prevrandao,
                    msg.sender,
                    address(this).balance
                )
            )
        );

        // Select reward tier based on weighted random
        uint256 tierId = _selectRewardTier(randomSeed);
        RewardTier storage tier = rewardTiers[tierId];

        if (tier.rewardAmount > 0) {
            // Check contract has sufficient balance (excluding locked prizes and fees)
            uint256 availableBalance = _getAvailableRewardBalance();
            require(availableBalance >= tier.rewardAmount, "Insufficient reward pool");

            (bool success, ) = payable(msg.sender).call{value: tier.rewardAmount}("");
            require(success, "Transfer failed");
        }

        emit RandomRewardClaimed(msg.sender, tierId, tier.name, tier.rewardAmount);
    }

    // ============ View Functions ============

    function getRoundInfo(uint256 _roundId) external view returns (LotteryRound memory) {
        return rounds[_roundId];
    }

    function getUserTickets(uint256 _roundId, address _user) external view returns (uint256[] memory) {
        return userTickets[_roundId][_user];
    }

    function getRewardTiersCount() external view returns (uint256) {
        return rewardTiers.length;
    }

    function getAllRewardTiers() external view returns (RewardTier[] memory) {
        return rewardTiers;
    }

    function getAvailableRewardBalance() external view returns (uint256) {
        return _getAvailableRewardBalance();
    }

    function getUserCommitment(address _user) external view returns (Commitment memory) {
        return userCommitments[_user];
    }

    // ============ Internal Functions ============

    /**
     * @dev Selects a reward tier using weighted random selection.
     */
    function _selectRewardTier(uint256 _randomSeed) internal view returns (uint256) {
        uint256 randomWeight = _randomSeed % totalRewardWeight;
        uint256 cumulativeWeight = 0;

        for (uint256 i = 0; i < rewardTiers.length; i++) {
            cumulativeWeight += rewardTiers[i].weight;
            if (randomWeight < cumulativeWeight) {
                return i;
            }
        }

        // Fallback (should never reach here)
        return rewardTiers.length - 1;
    }

    /**
     * @dev Calculates available balance for rewards (excluding locked prizes and fees).
     */
    function _getAvailableRewardBalance() internal view returns (uint256) {
        uint256 totalLocked = accumulatedFees;

        for (uint256 i = 1; i <= currentRoundId; i++) {
            LotteryRound storage round = rounds[i];
            if (!round.prizeClaimed && round.prizePool > 0) {
                if (round.finalized) {
                    uint256 fee = (round.prizePool * platformFeePercent) / 10000;
                    totalLocked += round.prizePool - fee; // Prize portion is locked
                } else {
                    totalLocked += round.prizePool; // Entire pool is locked
                }
            }
        }

        if (address(this).balance <= totalLocked) {
            return 0;
        }
        return address(this).balance - totalLocked;
    }

    // ============ Receive ============

    receive() external payable {}
}