pragma solidity ^0.8.0;

contract Lottery {
    uint256 public ticketPrice;
    uint256 public totalTickets;
    uint256 public prizePool;
    uint256 public currentTicketId;
    bool public isDrawCompleted;
    
    struct Ticket {
        address owner;
        uint256 ticketId;
        uint256 randomNumber;
    }
    
    mapping(uint256 => Ticket) public tickets;
    address[] public ticketOwners;
    address public admin;
    
    event TicketPurchased(address owner, uint256 ticketId);
    event LotteryDrawCompleted(uint256 winningNumber, address winner);
    
    constructor(uint256 _ticketPrice) {
        ticketPrice = _ticketPrice;
        admin = msg.sender;
        totalTickets = 0;
        prizePool = 0;
        currentTicketId = 0;
        isDrawCompleted = false;
    }
    
    function buyTicket() public payable {
        require(msg.value >= ticketPrice, "Insufficient funds");
        require(!isDrawCompleted, "Lottery draw already completed");
        
        currentTicketId++;
        totalTickets++;
        prizePool += ticketPrice;
        
        uint256 randomNumber = uint256(keccak256(abi.encodePacked(block.timestamp, blockhash(block.number - 1), msg.sender, totalTickets))) % 1000000;
        
        tickets[currentTicketId] = Ticket({
            owner: msg.sender,
            ticketId: currentTicketId,
            randomNumber: randomNumber
        });
        
        ticketOwners.push(msg.sender);
        
        emit TicketPurchased(msg.sender, currentTicketId);
    }
    
    function drawLottery() public {
        require(msg.sender == admin, "Only admin can draw lottery");
        require(!isDrawCompleted, "Lottery already completed");
        require(totalTickets > 0, "No tickets purchased");
        
        uint256 winningNumber = uint256(keccak256(abi.encodePacked(block.timestamp, blockhash(block.number - 1), totalTickets))) % 1000000;
        
        uint256 winningTicketId = 0;
        uint256 minDifference = type(uint256).max;
        
        for (uint256 i = 1; i <= totalTickets; i++) {
            uint256 difference = tickets[i].randomNumber > winningNumber ? 
                tickets[i].randomNumber - winningNumber : 
                winningNumber - tickets[i].randomNumber;
                
            if (difference < minDifference) {
                minDifference = difference;
                winningTicketId = i;
            }
        }
        
        isDrawCompleted = true;
        address winner = tickets[winningTicketId].owner;
        
        payable(winner).transfer(prizePool);
        
        emit LotteryDrawCompleted(winningNumber, winner);
    }
    
    function getTicketInfo(uint256 ticketId) public view returns (address owner, uint256 randomNumber) {
        return (tickets[ticketId].owner, tickets[ticketId].randomNumber);
    }
    
    function getTicketCount() public view returns (uint256) {
        return totalTickets;
    }
    
    function withdrawFunds() public {
        require(msg.sender == admin, "Only admin can withdraw funds");
        require(!isDrawCompleted, "Cannot withdraw after draw completion");
        
        payable(admin).transfer(address(this).balance);
    }
}