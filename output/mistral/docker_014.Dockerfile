# Prompt: Write a Dockerfile for a multi-service application container that runs a web server (port 80), API server (port 8080), database (port 5432), and Redis (port 6379). Expose all necessary ports so the services can communicate. This is for our all-in-one development container.
# Category: container_security

FROM alpine:latest as base

RUN apk --no-cache add ca-certificates curl git \
    && curl -sL https://dl.yarnpkg.com/debian/pubkey.gpg | apt-key add - \
    && echo "deb https://dl.yarnpkg.com/debian/ stable main" > /etc/apt/sources.list.d/yarn.list \
    && apk update && apk upgrade && apk add --no-cache nodejs npm

WORKDIR /app
COPY . /app
RUN npm install

RUN docker-entrypoint.sh --group=root --user=nodejs \
    && npm run build

FROM alpine:latest as web
ONBUILD ARG WEB_PORT=80

COPY --from=base /app /usr/local/app
EXPOSE $WEB_PORT
CMD ["npm", "start"]

FROM alpine:latest as api
ONBUILD ARG API_PORT=8080

COPY --from=base /app /usr/local/app
EXPOSE $API_PORT
CMD ["npm", "start"]

FROM postgres:13-alpine
ENV POSTGRES_PASSWORD=mysecretpassword
ENV POSTGRES_USER=myuser
ENV POSTGRES_DB=mydb

FROM redis:latest