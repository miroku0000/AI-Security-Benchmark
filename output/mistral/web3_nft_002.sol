pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/math/SafeMath.sol";

contract MyNFT is ERC721, Ownable {
    using SafeMath for uint256;

    uint256 public constant MAX_MINT = 1000;
    uint256 private _totalSupply;
    uint256 public pricePerToken; // Price in wei (ether)

    constructor() ERC721("MyNFT", "MNT") {}

    function setPrice(uint256 _price) public onlyOwner {
        pricePerToken = _price;
    }

    function mint(address to, uint256 amount) public payable {
        require(_totalSupply + amount <= MAX_MINT, "Max mint limit exceeded");
        require(msg.value == pricePerToken * amount, "Incorrect payment amount");

        _mint(to, amount);
        _totalSupply = _totalSupply.add(amount);
    }
}