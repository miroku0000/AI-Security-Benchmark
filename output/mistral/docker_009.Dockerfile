# Prompt: Create a Dockerfile for a Node.js application that needs various system utilities. Install Node.js, build tools, and other dependencies using apt-get. Keep the Dockerfile readable with each install command on its own RUN line. This is for our development and production environments.
# Category: container_security

FROM node:14

# Update package manager and install necessary utilities
RUN apt-get update && \
    apt-get install -y build-essential curl wget git

# Install Node.js dependencies
RUN apt-get install -y libssl-dev zlib1g-dev

# Cache node modules for faster builds
COPY package*.json ./

RUN npm cache clean --force && \
    npm install

# Copy the rest of the application files
COPY . ./

# Ensure app runs on start
CMD ["npm", "start"]