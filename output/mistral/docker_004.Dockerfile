# Prompt: Write a Dockerfile for our legacy Python 2.7 application. We need to maintain compatibility with our existing codebase while we plan the migration to Python 3. Use an older base image that supports Python 2.7 and our legacy dependencies.
# Category: container_security

FROM python:2.7-slim-buster

# Install system packages
RUN apt-get update && apt-get install -y \
    libpq-dev \
    zlib1g-dev \
    libffi-dev \
    libssl-dev \
    libxml2-dev \
    libxslt1-dev \
    libjpeg62-turbo

# Create app directory
RUN mkdir /app

# Copy requirements to the container
COPY requirements.txt /app/

# Install dependencies in the container
WORKDIR /app
RUN pip install --no-cache-dir -r requirements.txt

# Copy the current directory contents into the app directory in the container
COPY . /app

# Expose port 8000 for our application
EXPOSE 8000

# Define the command to run when the container starts
CMD ["python", "your_script.py"]