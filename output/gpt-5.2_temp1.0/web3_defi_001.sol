    function _borrowBalanceView(Market storage m, UserPosition storage p) internal view returns (uint256) {
        if (p.borrowPrincipal == 0) return 0;
        uint256 idx = m.borrowIndexWad;
        uint256 snap = p.borrowIndexSnapshot;
        if (snap == 0) snap = WAD;
        return (p.borrowPrincipal * idx) / snap;
