        uint256 idx = m.borrowIndexWad;
        p.borrowPrincipal = (newDebtCurrent * (p.borrowIndexSnapshot == 0 ? WAD : p.borrowIndexSnapshot)) / idx;
        p.borrowIndexSnapshot = idx;
