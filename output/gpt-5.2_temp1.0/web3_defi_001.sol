        uint256 normAsset = reserveAsset * (10 ** (18 - assetDec));
        uint256 normCol = reserveCol * (10 ** (18 - colDec));

        colPerAssetWad = (normCol * WAD) / normAsset;
        assetPerColWad = (normAsset * WAD) / normCol;
    }

    function _dexPriceWadView(Market storage m) internal view returns (uint256 colPerAssetWad, uint256 assetPerColWad) {
        (uint112 r0, uint112 r1, ) = m.dexPair.getReserves();
        if (r0 == 0 || r1 == 0) return (0, 0);
        if (uint256(r0) < m.reservesMin || uint256(r1) < m.reservesMin) return (0, 0);

        address t0 = m.dexPair.token0();
        address t1 = m.dexPair.token1();

        uint8 assetDec = _decimals(m.asset);
        uint8 colDec = _decimals(m.collateral);

