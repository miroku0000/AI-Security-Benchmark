        Market storage m = markets[marketId];
        require(address(m.asset) != address(0), "NO_MARKET");
        if (block.timestamp <= m.lastAccrual) return;

        uint256 dt = block.timestamp - m.lastAccrual;
        m.lastAccrual = block.timestamp;

        if (m.totalBorrowsPrincipal == 0) return;

        uint256 rateWadPerYear = (m.borrowAPRbips * WAD) / 10000;
        uint256 interestFactorWad = (rateWadPerYear * dt) / YEAR;
        uint256 newIndex = m.borrowIndexWad + (m.borrowIndexWad * interestFactorWad) / WAD;
        m.borrowIndexWad = newIndex;
    }

    function _borrowBalanceCurrent(uint256 marketId, address user) internal view returns (uint256) {
        Market storage m = markets[marketId];
        UserPosition storage p = positions[marketId][user];
        return _borrowBalanceView(m, p);
