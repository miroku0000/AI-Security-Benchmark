    function _totalBorrowsCurrentFromPrincipal(Market storage m) internal view returns (uint256) {
        if (m.totalBorrowsPrincipal == 0) return 0;
        uint256 idx = m.borrowIndexWad;
        return (m.totalBorrowsPrincipal * idx) / WAD;
    }

    function _syncTotalBorrowsPrincipalFromCurrent(Market storage m) internal {
        uint256 current = _totalBorrowsCurrentFromPrincipal(m);
        m.totalBorrowsPrincipal = (current * WAD) / m.borrowIndexWad;
