    function _isHealthy(uint256 marketId, address user, uint256 bps) internal view returns (bool) {
        Market storage m = markets[marketId];
        UserPosition storage p = positions[marketId][user];

        uint256 debt = _borrowBalanceView(m, p);
        if (debt == 0) return true;

        uint256 colAmt = p.collateralAmount;
        if (colAmt == 0) return false;

        (uint256 colPerAssetWad, ) = _dexPriceWad(m);

        uint256 colValueInAsset = (colAmt * WAD) / colPerAssetWad;
        uint256 maxBorrow = (colValueInAsset * bps) / 10000;

        return debt <= maxBorrow;
