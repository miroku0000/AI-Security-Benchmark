    function _dexPriceWad(Market storage m) internal view returns (uint256 colPerAssetWad, uint256 assetPerColWad) {
        (uint112 r0, uint112 r1, ) = m.dexPair.getReserves();
        require(r0 > 0 && r1 > 0, "NO_RESERVES");

        require(uint256(r0) >= m.reservesMin && uint256(r1) >= m.reservesMin, "RESERVES_TOO_LOW");

