        uint256 prizeAmount = lottery.prizePool;
        players[winner].totalWon += prizeAmount;
        totalPrizesDistributed += prizeAmount;
        
        payable(winner).transfer(prizeAmount);
        
        currentState = LotteryState.COMPLETED;
        
        emit WinnerSelected(lotteryId, winner, prizeAmount, winningNumber);
    }
    
    function generateRandomNumber(uint256 _max) private view returns (uint256) {
        uint256 random = uint256(keccak256(abi.encodePacked(
            block.timestamp,
            block.difficulty,
            blockhash(block.number - 1),
            lotteryId,
            msg.sender,
            _max
        )));
        return random % _max;
    }
    
    function selectWinnerByNumber(uint256 _winningNumber) private view returns (address) {
        Lottery storage lottery = lotteries[lotteryId];
        uint256 closestDistance = type(uint256).max;
        address winner = lottery.players[0];
        
        for (uint256 i = 0; i < lottery.players.length; i++) {
            address participant = lottery.players[i];
            uint256[] memory tickets = lotteryTickets[lotteryId][participant];
            
            for (uint256 j = 0; j < tickets.length; j++) {
                uint256 distance = tickets[j] > _winningNumber 
                    ? tickets[j] - _winningNumber 
                    : _winningNumber - tickets[j];
                
                if (distance < closestDistance) {
                    closestDistance = distance;
                    winner = participant;
                }
            }
        }
        
        return winner;
    }
    
    function spinRewardWheel() external returns (uint256, string memory, uint256) {
        require(hasParticipated[msg.sender], "Must participate in lottery first");
        
        uint256 randomValue = uint256(keccak256(abi.encodePacked(
            block.timestamp,
            block.difficulty,
            blockhash(block.number - 1),
            msg.sender,
            block.number
        ))) % 100;
        
        uint256 cumulativeProbability = 0;
        uint256 selectedRewardId = 0;
        
        for (uint256 i = 1; i <= rewardCount; i++) {
            if (rewards[i].isActive) {
                cumulativeProbability += rewards[i].probability;
                if (randomValue < cumulativeProbability) {
                    selectedRewardId = i;
                    break;
                }
            }
        }
        
        if (selectedRewardId > 0) {
            Reward memory selectedReward = rewards[selectedRewardId];
            
            if (selectedReward.rewardAmount > 0 && address(this).balance >= selectedReward.rewardAmount) {
                payable(msg.sender).transfer(selectedReward.rewardAmount);
                players[msg.sender].totalWon += selectedReward.rewardAmount;
                totalPrizesDistributed += selectedReward.rewardAmount;
            }
            
            emit RewardDistributed(msg.sender, selectedRewardId, selectedReward.rewardName, selectedReward.rewardAmount);
            return (selectedRewardId, selectedReward.rewardName, selectedReward.rewardAmount);
        }
        
        return (0, "No reward", 0);
    }
    
    function addReward(string memory _name, uint256 _probability, uint256 _amount) external onlyOwner {
        rewardCount++;
        rewards[rewardCount] = Reward({
            rewardId: rewardCount,
            rewardName: _name,
            probability: _probability,
