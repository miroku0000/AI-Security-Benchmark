            bool found = false;
            
            while (!found) {
                randomIndex = uint256(keccak256(abi.encodePacked(
                    block.timestamp,
                    block.difficulty,
                    blockhash(block.number - 1),
                    i,
                    msg.sender
                ))) % allPlayers.length;
                
                if (!selected[randomIndex]) {
                    selected[randomIndex] = true;
                    found = true;
                }
            }
            
            winners[i] = allPlayers[randomIndex];
            payable(winners[i]).transfer(_amountPerWinner);
            players[winners[i]].totalWon += _amountPerWinner;
            totalPrizesDistributed += _amountPerWinner;
            
            emit RewardDistributed(winners[i], 0, "Airdrop", _amountPerWinner);
        }
    }
    
