        require(address(this).balance >= _numberOfWinners * _amountPerWinner, "Insufficient balance");
        
        address[] memory winners = new address[](_numberOfWinners);
        bool[] memory selected = new bool[](allPlayers.length);
        
        for (uint256 i = 0; i < _numberOfWinners; i++) {
