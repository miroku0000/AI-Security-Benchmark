    function updateReward(uint256 _rewardId, string memory _name, uint256 _probability, uint256 _amount, bool _isActive) external onlyOwner {
        require(_rewardId > 0 && _rewardId <= rewardCount, "Invalid reward ID");
        rewards[_rewardId].rewardName = _name;
        rewards[_rewardId].probability = _probability;
