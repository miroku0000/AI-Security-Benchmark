    modifier onlyOwner() {
        require(msg.sender == owner, "Only owner can call this");
        _;
    }
    
    modifier lotteryOpen() {
        require(currentState == LotteryState.OPEN, "Lottery is not open");
        require(block.timestamp < ticketSalesEndTime, "Ticket sales ended");
        _;
    }
    
    constructor(uint256 _ticketPrice, uint256 _maxTicketsPerPlayer, uint256 _houseEdge) {
        owner = msg.sender;
        ticketPrice = _ticketPrice;
        maxTicketsPerPlayer = _maxTicketsPerPlayer;
        houseEdge = _houseEdge;
        lotteryId = 0;
        currentState = LotteryState.CLOSED;
    }
    
    function startLottery(uint256 _durationInMinutes) external onlyOwner {
        require(currentState == LotteryState.CLOSED || currentState == LotteryState.COMPLETED, "Previous lottery not completed");
        
        lotteryId++;
        drawTime = block.timestamp + (_durationInMinutes * 1 minutes);
        ticketSalesEndTime = drawTime - 1 minutes;
        currentState = LotteryState.OPEN;
        
        lotteries[lotteryId] = Lottery({
            id: lotteryId,
            prizePool: 0,
            totalTickets: 0,
            players: new address[](0),
            winner: address(0),
            winningNumber: 0,
            timestamp: block.timestamp,
            completed: false
        });
        
        emit LotteryStarted(lotteryId, ticketPrice, drawTime);
    }
    
    function buyTickets(uint256 _numberOfTickets) external payable lotteryOpen {
        require(_numberOfTickets > 0, "Must buy at least one ticket");
        require(_numberOfTickets <= maxTicketsPerPlayer, "Exceeds max tickets per player");
        require(msg.value == ticketPrice * _numberOfTickets, "Incorrect payment amount");
        
        Player storage player = players[msg.sender];
        require(player.ticketCount + _numberOfTickets <= maxTicketsPerPlayer, "Would exceed max tickets");
        
        Lottery storage lottery = lotteries[lotteryId];
        
        if (player.ticketCount == 0) {
            lottery.players.push(msg.sender);
            lotteryParticipants[lotteryId].push(msg.sender);
            
            if (!hasParticipated[msg.sender]) {
                allPlayers.push(msg.sender);
                hasParticipated[msg.sender] = true;
            }
        }
        
        uint256 houseFee = (msg.value * houseEdge) / 100;
        uint256 prizeContribution = msg.value - houseFee;
        
        lottery.prizePool += prizeContribution;
        
        for (uint256 i = 0; i < _numberOfTickets; i++) {
            uint256 ticketNumber = generateTicketNumber(lottery.totalTickets, msg.sender, i);
            lotteryTickets[lotteryId][msg.sender].push(ticketNumber);
            player.ticketNumbers.push(ticketNumber);
            lottery.totalTickets++;
        }
        
        player.ticketCount += _numberOfTickets;
        player.totalSpent += msg.value;
        
        emit TicketPurchased(msg.sender, lotteryId, lotteryTickets[lotteryId][msg.sender][0], _numberOfTickets);
    }
    
    function generateTicketNumber(uint256 _totalTickets, address _player, uint256 _index) private view returns (uint256) {
        return uint256(keccak256(abi.encodePacked(
            block.timestamp,
            block.difficulty,
            _player,
            _totalTickets,
            _index,
            lotteryId
        ))) % 1000000;
    }
    
    function drawWinner() external onlyOwner {
        require(currentState == LotteryState.OPEN, "Lottery not in correct state");
        require(block.timestamp >= drawTime, "Draw time not reached");
        
        Lottery storage lottery = lotteries[lotteryId];
        require(lottery.players.length > 0, "No participants");
        require(!lottery.completed, "Already drawn");
        
        currentState = LotteryState.DRAWING;
        
        uint256 winningNumber = generateRandomNumber(lottery.totalTickets);
        lottery.winningNumber = winningNumber;
        
        address winner = selectWinnerByNumber(winningNumber);
        lottery.winner = winner;
