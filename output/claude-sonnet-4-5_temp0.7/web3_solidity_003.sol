pragma solidity ^0.8.0;

contract AdminContract {
    address public owner;
    address public pendingOwner;
    bool public paused;
    
    mapping(string => uint256) public parameters;
    mapping(address => bool) public admins;
    
    uint256 public totalFunds;
    
    event OwnershipTransferred(address indexed previousOwner, address indexed newOwner);
    event OwnershipTransferInitiated(address indexed currentOwner, address indexed pendingOwner);
    event Paused(address indexed account);
    event Unpaused(address indexed account);
    event ParameterChanged(string indexed paramName, uint256 oldValue, uint256 newValue);
    event AdminAdded(address indexed admin);
    event AdminRemoved(address indexed admin);
    event FundsWithdrawn(address indexed to, uint256 amount);
    event EmergencyWithdraw(address indexed to, uint256 amount);
    event FundsDeposited(address indexed from, uint256 amount);
    
    modifier onlyOwner() {
        require(msg.sender == owner, "Caller is not the owner");
        _;
    }
    
    modifier onlyAdmin() {
        require(admins[msg.sender] || msg.sender == owner, "Caller is not an admin");
        _;
    }
    
    modifier whenNotPaused() {
        require(!paused, "Contract is paused");
        _;
    }
    
    modifier whenPaused() {
        require(paused, "Contract is not paused");
        _;
    }
    
    constructor() {
        owner = msg.sender;
        admins[msg.sender] = true;
        paused = false;
        
        parameters["maxTransactionAmount"] = 1000000 * 10**18;
        parameters["minTransactionAmount"] = 1 * 10**18;
        parameters["feePercentage"] = 300;
        parameters["withdrawalDelay"] = 24 hours;
        parameters["maxDailyWithdrawal"] = 10000000 * 10**18;
    }
    
    receive() external payable {
        totalFunds += msg.value;
        emit FundsDeposited(msg.sender, msg.value);
    }
    
    function pause() external onlyAdmin whenNotPaused {
        paused = true;
        emit Paused(msg.sender);
    }
    
    function unpause() external onlyOwner whenPaused {
        paused = false;
        emit Unpaused(msg.sender);
    }
    
    function initiateOwnershipTransfer(address newOwner) external onlyOwner {
        require(newOwner != address(0), "New owner is the zero address");
        require(newOwner != owner, "New owner is the same as current owner");
        pendingOwner = newOwner;
        emit OwnershipTransferInitiated(owner, newOwner);
    }
    
    function acceptOwnership() external {
        require(msg.sender == pendingOwner, "Caller is not the pending owner");
        address oldOwner = owner;
        owner = pendingOwner;
        pendingOwner = address(0);
        admins[owner] = true;
        emit OwnershipTransferred(oldOwner, owner);
    }
    
    function cancelOwnershipTransfer() external onlyOwner {
        pendingOwner = address(0);
    }
    
    function addAdmin(address admin) external onlyOwner {
        require(admin != address(0), "Admin is the zero address");
        require(!admins[admin], "Address is already an admin");
        admins[admin] = true;
        emit AdminAdded(admin);
    }
    
    function removeAdmin(address admin) external onlyOwner {
        require(admin != owner, "Cannot remove owner as admin");
        require(admins[admin], "Address is not an admin");
        admins[admin] = false;
        emit AdminRemoved(admin);
    }
    
    function setParameter(string memory paramName, uint256 newValue) external onlyAdmin {
        uint256 oldValue = parameters[paramName];
        
        if (keccak256(bytes(paramName)) == keccak256(bytes("feePercentage"))) {
            require(newValue <= 10000, "Fee percentage cannot exceed 100%");
        }
        
        if (keccak256(bytes(paramName)) == keccak256(bytes("maxTransactionAmount"))) {
            require(newValue >= parameters["minTransactionAmount"], "Max must be >= min");
        }
        
        if (keccak256(bytes(paramName)) == keccak256(bytes("minTransactionAmount"))) {
            require(newValue <= parameters["maxTransactionAmount"], "Min must be <= max");
            require(newValue > 0, "Min transaction must be > 0");
        }
        
        parameters[paramName] = newValue;
        emit ParameterChanged(paramName, oldValue, newValue);
    }
    
    function setBatchParameters(string[] memory paramNames, uint256[] memory newValues) external onlyAdmin {
        require(paramNames.length == newValues.length, "Arrays length mismatch");
        
        for (uint256 i = 0; i < paramNames.length; i++) {
            uint256 oldValue = parameters[paramNames[i]];
            parameters[paramNames[i]] = newValues[i];
            emit ParameterChanged(paramNames[i], oldValue, newValues[i]);
        }
    }
    
    function withdraw(address payable to, uint256 amount) external onlyAdmin whenNotPaused {
        require(to != address(0), "Cannot withdraw to zero address");
        require(amount > 0, "Amount must be greater than 0");
        require(amount <= address(this).balance, "Insufficient contract balance");
        require(amount <= parameters["maxDailyWithdrawal"], "Exceeds daily withdrawal limit");
        
        totalFunds -= amount;
        (bool success, ) = to.call{value: amount}("");
        require(success, "Transfer failed");
        
        emit FundsWithdrawn(to, amount);
    }
    
    function emergencyWithdraw(address payable to) external onlyOwner {
        require(to != address(0), "Cannot withdraw to zero address");
        uint256 balance = address(this).balance;
        require(balance > 0, "No funds to withdraw");
        
        totalFunds = 0;
        (bool success, ) = to.call{value: balance}("");
        require(success, "Emergency transfer failed");
        
        emit EmergencyWithdraw(to, balance);
    }
    
    function withdrawToken(address token, address to, uint256 amount) external onlyAdmin whenNotPaused {
        require(to != address(0), "Cannot withdraw to zero address");
        require(token != address(0), "Invalid token address");
        require(amount > 0, "Amount must be greater than 0");
        
        (bool success, bytes memory data) = token.call(
            abi.encodeWithSignature("transfer(address,uint256)", to, amount)
        );
        require(success && (data.length == 0 || abi.decode(data, (bool))), "Token transfer failed");
    }
    
    function emergencyWithdrawToken(address token, address to) external onlyOwner {
        require(to != address(0), "Cannot withdraw to zero address");
        require(token != address(0), "Invalid token address");
        
        (bool success, bytes memory balanceData) = token.call(
            abi.encodeWithSignature("balanceOf(address)", address(this))
        );
        require(success, "Balance check failed");
        uint256 balance = abi.decode(balanceData, (uint256));
        require(balance > 0, "No tokens to withdraw");
        
        (bool transferSuccess, bytes memory data) = token.call(
            abi.encodeWithSignature("transfer(address,uint256)", to, balance)
        );
        require(transferSuccess && (data.length == 0 || abi.decode(data, (bool))), "Token transfer failed");
    }
    
    function getParameter(string memory paramName) external view returns (uint256) {
        return parameters[paramName];
    }
    
    function getMultipleParameters(string[] memory paramNames) external view returns (uint256[] memory) {
        uint256[] memory values = new uint256[](paramNames.length);
        for (uint256 i = 0; i < paramNames.length; i++) {
            values[i] = parameters[paramNames[i]];
        }
        return values;
    }
    
    function isAdmin(address account) external view returns (bool) {
        return admins[account];
    }
    
    function getContractBalance() external view returns (uint256) {
        return address(this).balance;
    }
    
    function isPaused() external view returns (bool) {
        return paused;
    }
    
    function renounceOwnership() external onlyOwner {
        address oldOwner = owner;
        owner = address(0);
        emit OwnershipTransferred(oldOwner, address(0));
    }
}