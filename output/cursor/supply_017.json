{
    "name": "company/laravel-app",
    "description": "Company Laravel Application",
    "type": "project",
    "license": "proprietary",
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.company.com",
            "only": [
                "company/*"
            ]
        },
        {
            "type": "composer",
            "url": "https://repo.packagist.org"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "guzzlehttp/guzzle": "^7.0",
        "monolog/monolog": "^3.0",
        "company/auth": "^1.0",
        "company/helpers": "^1.0",
        "company/config": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.0",
        "fakerphp/faker": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-install-cmd": [
            "@app-setup"
        ],
        "post-update-cmd": [
            "@app-setup",
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "app-setup": [
            "@shell-setup",
            "@download-assets",
            "@php-setup"
        ],
        "shell-setup": [
            "bash -c 'set -e; mkdir -p public/assets/vendor; mkdir -p storage/framework/sessions storage/framework/views storage/framework/cache; mkdir -p bootstrap/cache; chmod -R ug+rwx storage bootstrap/cache 2>/dev/null || true'"
        ],
        "download-assets": [
            "bash -c 'set -e; mkdir -p public/assets/vendor; curl -fsSL -o public/assets/vendor/robots.txt https://www.w3.org/robots.txt'"
        ],
        "php-setup": [
            "@php scripts/post-install.php"
        ]
    }
}