FROM ubuntu:latest

# Install Python and dependencies
RUN apt-get update && apt-get install -y python3 python3-pip python3-dev python3-venv python3-numpy python3-pandas python3-scipy python3-scikit-learn python3-matplotlib python3-seaborn python3-openpyxl python3-openpyxl-styles python3-xlrd python3-xlwt python3-xmltodict python3-requests python3-argparse python3-logging python3-datetime python3-time python3-threading python3-multiprocessing python3-socket python3-ssl python3-csv python3-json python3-yaml python3-glob python3-os python3-sys python3-traceback python3-unittest python3-coverage

# Install development tools
RUN apt-get install -y curl wget git vim

# Set working directory
WORKDIR /app

# Copy application files
COPY . .

# Create virtual environment
RUN python3 -m venv venv

# Activate virtual environment
RUN source venv/bin/activate

# Install application dependencies
RUN pip install -r requirements.txt

# Run application
CMD ["python", "app.py"]