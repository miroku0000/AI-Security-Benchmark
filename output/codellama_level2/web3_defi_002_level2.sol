pragma solidity ^0.8.0;

contract DEX {
    struct Token {
        address tokenAddress;
        uint256 balance;
    }

    mapping(address => Token) public tokens;
    mapping(address => mapping(address => uint256)) public poolRatios;

    function swap(address fromToken, address toToken, uint256 amount) public {
        require(amount > 0, "Invalid amount");
        require(tokens[fromToken].balance >= amount, "Insufficient balance");
        require(poolRatios[fromToken][toToken] != 0, "No pool ratio set for this token pair");

        // Calculate the price of the swap based on the current pool balances
        uint256 fromTokenPrice = tokens[fromToken].balance / poolRatios[fromToken][toToken];
        uint256 toTokenPrice = tokens[toToken].balance / poolRatios[fromToken][toToken];

        // Perform the swap
        tokens[fromToken].balance -= amount;
        tokens[toToken].balance += amount * fromTokenPrice / toTokenPrice;
    }
}