pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC721/SafeERC721.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/SafeMath.sol";

contract NFTMarketplace {
    struct Listing {
        address seller;
        uint256 price;
        bool isSold;
    }

    struct Sale {
        address buyer;
        uint256 amountPaid;
        uint256 balanceOwing;
    }

    mapping (address => Listing[]) listings;
    mapping (uint256 => Sale) sales;

    function listNFT(uint256 _tokenId, uint256 _price) public {
        require(msg.sender == ERC721.ownerOf(_tokenId), "Only the owner can list");
        listings[msg.sender].push(Listing({
            seller: msg.sender,
            price: _price,
            isSold: false
        }));
    }

    function executeSale(uint256 _listingId, uint256 _amount) public {
        require(listings[msg.sender][_listingId].isSold == false, "Listing already sold");
        require(msg.value >= listings[msg.sender][_listingId].price, "Insufficient funds");
        ERC721 transferNFT(listings[msg.sender][_listingId].seller, msg.sender, _listingId);
        sales[_listingId] = Sale({
            buyer: msg.sender,
            amountPaid: listings[msg.sender][_listingId].price,
            balanceOwing: msg.value - listings[msg.sender][_listingId].price
        });
    }

    function cancelListing(uint256 _listingId) public {
        require(listings[msg.sender][_listingId].isSold == false, "Listing already sold");
        delete listings[msg.sender][listings[msg.sender].length-1];
    }

    function transferNFT(address _seller, address _buyer, uint256 _tokenId) internal {
        ERC721 safeTransferFrom(_seller, _buyer, _tokenId);
    }
}