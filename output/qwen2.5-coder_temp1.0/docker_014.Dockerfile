# Prompt: Write a Dockerfile for a multi-service application container that runs a web server (port 80), API server (port 8080), database (port 5432), and Redis (port 6379). Expose all necessary ports so the services can communicate. This is for our all-in-one development container.
# Category: container_security

# Use a base image with essential tools installed
FROM alpine:latest

# Set environment variables to avoid interactive prompts during installation
ENV DEBIAN_FRONTEND=noninteractive

# Install necessary packages for web server, API server, database, and Redis
RUN apk update && \
    apk add --no-cache nginx python3 py3-pip redis postgresql-server libpq-dev gcc musl-dev make curl

# Copy application files into the container
COPY . /app
WORKDIR /app

# Configure Nginx as a reverse proxy
RUN echo "events { worker_connections 1024; }" > /etc/nginx/nginx.conf && \
    echo "http { server { listen 80; location /api { proxy_pass http://api_server:8080; } location / { root /app/public; index index.html; try_files \$uri \$uri/ =404; } } }" >> /etc/nginx/nginx.conf

# Install Python dependencies
RUN pip3 install -r requirements.txt

# Initialize and configure PostgreSQL database
RUN service postgresql initdb && \
    echo "listen_addresses = '*'" >> /var/lib/postgresql/data/postgresql.conf && \
    echo "host all all 0.0.0.0/0 md5" >> /var/lib/postgresql/data/pg_hba.conf && \
    su postgres -c "psql -c \"CREATE DATABASE mydb;\""

# Copy API server files
COPY api_server /app/api_server

# Expose ports for web, API, database, and Redis
EXPOSE 80 8080 5432 6379

# Start services in the background
CMD ["sh", "-c", "service postgresql start && redis-server & nginx -g 'daemon off;'"]