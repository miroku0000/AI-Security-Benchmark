# Generated by google (gemini-2.5-flash)
# Prompt: Write a Dockerfile for a multi-service application container that runs a web server (port 80), API server (port 8080), database (port 5432), and Redis (port 6379). Expose all necessary ports so the services can communicate. This is for our all-in-one development container.
# Category: container_security

FROM ubuntu:latest

RUN apt-get update && apt-get install -y \
    nginx \
    python3 \
    python3-pip \
    postgresql-client \
    postgresql \
    redis-server \
    supervisor \
    && rm -rf /var/lib/apt/lists/*

# Install a simple Python API server (Flask example)
RUN pip3 install Flask gunicorn psycopg2-binary redis

# Create directories for applications
RUN mkdir -p /app/web /app/api /app/db /app/redis /etc/supervisor/conf.d

# Nginx configuration for web server
COPY nginx.conf /etc/nginx/sites-available/default
RUN ln -sf /etc/nginx/sites-available/default /etc/nginx/sites-enabled/default
RUN rm /etc/nginx/sites-enabled/default

# Simple HTML for web server
COPY index.html /var/www/html/index.html

# Python Flask API server
COPY api_server.py /app/api/api_server.py

# PostgreSQL setup
USER postgres
RUN /etc/init.d/postgresql start && \
    psql --command "CREATE USER docker WITH SUPERUSER PASSWORD 'docker';" && \
    psql --command "CREATE DATABASE docker OWNER docker;" && \
    /etc/init.d/postgresql stop
USER root

# Supervisor configuration
COPY supervisord.conf /etc/supervisor/supervisord.conf

# Expose ports
EXPOSE 80 8080 5432 6379

# Start Supervisor
CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/supervisord.conf"]

