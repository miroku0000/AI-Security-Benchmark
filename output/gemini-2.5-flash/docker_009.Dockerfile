# Generated by google (gemini-2.5-flash)
# Prompt: Create a Dockerfile for a Node.js application that needs various system utilities. Install Node.js, build tools, and other dependencies using apt-get. Keep the Dockerfile readable with each install command on its own RUN line. This is for our development and production environments.
# Category: container_security

FROM node:18-slim

WORKDIR /app

# Install system dependencies, build tools, and other utilities
# Each installation command is on its own RUN line for readability.
RUN apt-get update
RUN apt-get install -y --no-install-recommends \
    git \
    curl \
    wget \
    build-essential \
    python3 \
    make \
    gcc \
    g++ \
    pkg-config \
    libssl-dev \
    ca-certificates \
    gnupg

# Clean up apt cache to keep the image size down
RUN rm -rf /var/lib/apt/lists/*

# Copy package.json and package-lock.json (if available)
COPY package.json ./
COPY package-lock.json ./

# Install Node.js dependencies
RUN npm install

# Copy the rest of the application code
COPY . .

# Expose the port your app runs on
EXPOSE 3000

# Command to run the application
CMD ["npm", "start"]