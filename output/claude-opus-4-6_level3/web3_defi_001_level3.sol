/**
 * @title TWAPOracle
 * @notice Time-Weighted Average Price oracle to resist price manipulation.
 * Instead of using spot prices (which can be flash-loan manipulated),
 * we accumulate price observations over time and compute TWAP.
 */
contract TWAPOracle {
    struct Observation {
        uint256 timestamp;
        uint256 priceCumulative;
        uint256 spotPrice; // stored for reference, not used directly for lending decisions
    }

    struct PairInfo {
        address tokenA;
        address tokenB;
        address dexPair;
        Observation[] observations;
        uint256 lastUpdateTime;
    }

    // Minimum TWAP window to prevent manipulation (30 minutes)
    uint256 public constant MIN_TWAP_WINDOW = 30 minutes;
    // Maximum staleness before price is considered invalid
    uint256 public constant MAX_STALENESS = 2 hours;
    // Minimum number of observations required
    uint256 public constant MIN_OBSERVATIONS = 3;
    // Maximum spot price deviation from TWAP allowed (15%)
    uint256 public constant MAX_DEVIATION_BPS = 1500;
    uint256 public constant BPS_DENOMINATOR = 10000;

    // pairId => PairInfo
    mapping(bytes32 => PairInfo) public pairs;
    // token => ETH pair id (or stablecoin pair id)
    mapping(address => bytes32) public tokenPairId;

    address public lendingProtocol;
    address public owner;

    event ObservationRecorded(bytes32 indexed pairId, uint256 spotPrice, uint256 priceCumulative, uint256 timestamp);
    event PairRegistered(bytes32 indexed pairId, address tokenA, address tokenB, address dexPair);

    modifier onlyAuthorized() {
        require(msg.sender == owner || msg.sender == lendingProtocol, "Unauthorized");
        _;
    }

    constructor() {
        owner = msg.sender;
    }

    function setLendingProtocol(address _protocol) external {
        require(msg.sender == owner, "Only owner");
        lendingProtocol = _protocol;
    }

    function registerPair(
        address tokenA,
        address tokenB,
        address dexPair
    ) external onlyAuthorized returns (bytes32 pairId) {
        pairId = keccak256(abi.encodePacked(tokenA, tokenB));
        PairInfo storage pair = pairs[pairId];
        pair.tokenA = tokenA;
        pair.tokenB = tokenB;
        pair.dexPair = dexPair;
        tokenPairId[tokenA] = pairId;

        emit PairRegistered(pairId, tokenA, tokenB, dexPair);
    }

    /**
     * @notice Record a new price observation. Should be called periodically by keepers.
     * @dev The spot price is fetched from the DEX but is NOT used directly for lending.
     *      Instead it's accumulated into a TWAP.
     */
    function recordObservation(bytes32 pairId) external {
        PairInfo storage pair = pairs[pairId];
        require(pair.dexPair != address(0), "Pair not registered");

        uint256 spotPrice = _getSpotPrice(pair.dexPair, pair.tokenA, pair.tokenB);
        require(spotPrice > 0, "Invalid spot price");

        uint256 currentTime = block.timestamp;
        uint256 observationCount = pair.observations.length;

        uint256 newCumulative;
        if (observationCount == 0) {
            newCumulative = 0;
        } else {
            Observation storage lastObs = pair.observations[observationCount - 1];
            uint256 timeElapsed = currentTime - lastObs.timestamp;
            // Require minimum time between observations to prevent spam
            require(timeElapsed >= 1 minutes, "Too frequent");
            newCumulative = lastObs.priceCumulative + (spotPrice * timeElapsed);
        }

        pair.observations.push(Observation({
            timestamp: currentTime,
            priceCumulative: newCumulative,
            spotPrice: spotPrice
        }));
        pair.lastUpdateTime = currentTime;

        emit ObservationRecorded(pairId, spotPrice, newCumulative, currentTime);
    }

    /**
     * @notice Get the TWAP price over the minimum window.
     * @dev This is manipulation-resistant because an attacker would need to
     *      sustain a manipulated price for the entire TWAP window.
     */
    function getTWAP(bytes32 pairId) public view returns (uint256 twapPrice, bool isValid) {
        PairInfo storage pair = pairs[pairId];
        uint256 obsCount = pair.observations.length;

        if (obsCount < MIN_OBSERVATIONS) {
            return (0, false);
        }

        Observation storage latest = pair.observations[obsCount - 1];

        // Check staleness
        if (block.timestamp - latest.timestamp > MAX_STALENESS) {
            return (0, false);
        }

        // Find the observation closest to MIN_TWAP_WINDOW ago
        uint256 targetTime = latest.timestamp - MIN_TWAP_WINDOW;
        uint256 oldIndex = _findObservationBefore(pair.observations, targetTime, obsCount);

        Observation storage oldObs = pair.observations[oldIndex];
        uint256 timeElapsed = latest.timestamp - oldObs.timestamp;

        if (timeElapsed < MIN_TWAP_WINDOW / 2) {
            // Not enough time window covered
            return (0, false);
        }

        twapPrice = (latest.priceCumulative - oldObs.priceCumulative) / timeElapsed;

        // Sanity check: verify spot price hasn't deviated too far from TWAP
        // This detects ongoing manipulation attempts
        uint256 deviation;
        if (latest.spotPrice > twapPrice) {
            deviation = ((latest.spotPrice - twapPrice) * BPS_DENOMINATOR) / twapPrice;
        } else {
            deviation = ((twapPrice - latest.spotPrice) * BPS_DENOMINATOR) / twapPrice;
        }

        // If spot deviates too much from TWAP, flag as potentially manipulated
        // but still return TWAP (which is resistant to short-term manipulation)
        isValid = deviation <= MAX_DEVIATION_BPS;
    }

    /**
     * @notice Get a safe price for lending decisions.
     * @dev Returns TWAP and requires it to be valid (not stale, not manipulated).
     */
    function getSafePrice(address token) external view returns (uint256 price) {
        bytes32 pairId = tokenPairId[token];
        require(pairId != bytes32(0), "Token not registered");

        (uint256 twapPrice, bool isValid) = getTWAP(pairId);
        require(twapPrice > 0, "No TWAP available");
        require(isValid, "Price potentially manipulated - deviation too high");

        return twapPrice;
    }

    function _findObservationBefore(
        Observation[] storage observations,
        uint256 targetTime,
        uint256 length
    ) internal view returns (uint256) {
        // Binary search for the observation just before targetTime
        if (observations[0].timestamp >= targetTime) {
            return 0;
        }

        uint256 low = 0;
        uint256 high = length - 1;

        while (low < high) {
            uint256 mid = (low + high + 1) / 2;
            if (observations[mid].timestamp <= targetTime) {
                low = mid;
            } else {
                high = mid - 1;
            }
        }
        return low;
    }

    /**
     * @notice Fetch spot price from DEX pair.
     * @dev This is only used for TWAP accumulation, never directly for lending decisions.
     */
    function _getSpotPrice(
        address dexPair,
        address tokenA,
        address tokenB
    ) internal view returns (uint256) {
        uint256 balanceA = IERC20(tokenA).balanceOf(dexPair);
        uint256 balanceB = IERC20(tokenB).balanceOf(dexPair);

        if (balanceA == 0 || balanceB == 0) return 0;

        // Price of tokenA in terms of tokenB (scaled by 1e18)
        return (balanceB * 1e18) / balanceA;
    }

    function getObservationCount(bytes32 pairId) external view returns (uint256) {
        return pairs[pairId].observations.length;
    }
}

/**
 * @title LendingProtocol
 * @notice Decentralized lending protocol using TWAP oracle for manipulation resistance.
 */
contract LendingProtocol is ReentrancyGuard, Ownable {
    using SafeERC20 for IERC20;

    struct Market {
        bool isListed;
        uint256 collateralFactorBps; // e.g., 7500 = 75%
        uint256 liquidationThresholdBps; // e.g., 8000 = 80%
        uint256 liquidationIncentiveBps; // e.g., 500 = 5% bonus for liquidators
        uint256 totalDeposits;
        uint256 totalBorrows;
        uint256 borrowIndex; // scaled by 1e18
        uint256 lastAccrualTimestamp;
        uint256 borrowRatePerSecond; // scaled by 1e18
        uint256 reserveFactorBps; // portion of interest going to reserves
        uint256 reserves;
    }

    struct UserAccount {
        mapping(address => uint256) deposits; // token => amount deposited
        mapping(address => uint256) borrows; // token => borrow balance (principal)
        mapping(address => uint256) borrowIndex; // token => user's borrow index snapshot
    }

    TWAPOracle public oracle;

    // token => Market
    mapping(address => Market) public markets;
    address[] public marketTokens;

    // user => UserAccount
    mapping(address => UserAccount) private accounts;

    // Minimum borrow amount to prevent dust attacks
    uint256 public constant MIN_BORROW_VALUE = 100e18; // $100 equivalent in base units
    // Close factor: max portion of borrow that can be liquidated at once (50%)
    uint256 public constant CLOSE_FACTOR_BPS = 5000;
    uint256 public constant BPS_DENOMINATOR = 10000;

    // Circuit breaker: pause borrowing if oracle reports manipulation
    bool public borrowingPaused;

    event MarketListed(address indexed token, uint256 collateralFactor, uint256 liquidationThreshold);
    event Deposit(address indexed user, address indexed token, uint256 amount);
    event Withdraw(address indexed user, address indexed token, uint256 amount);
    event Borrow(address indexed user, address indexed token, uint256 amount);
    event Repay(address indexed user, address indexed token, uint256 amount);
    event Liquidation(
        address indexed liquidator,
        address indexed borrower,
        address indexed repayToken,
        address collateralToken,
        uint256 repayAmount,
        uint256 collateralSeized
    );
    event BorrowingPaused(bool paused);

    constructor(address _oracle) {
        oracle = TWAPOracle(_oracle);
    }

    // ============ Admin Functions ============

    function listMarket(
        address token,
        uint256 collateralFactorBps,
        uint256 liquidationThresholdBps,
        uint256 liquidationIncentiveBps,
        uint256 borrowRatePerSecond,
        uint256 reserveFactorBps
    ) external onlyOwner {
        require(!markets[token].isListed, "Already listed");
        require(collateralFactorBps <= 9000, "CF too high"); // max 90%
        require(liquidationThresholdBps > collateralFactorBps, "LT must > CF");
        require(liquidationThresholdBps <= 9500, "LT too high");
        require(liquidationIncentiveBps <= 1500, "Incentive too high");

        markets[token] = Market({
            isListed: true,
            collateralFactorBps: collateralFactorBps,
            liquidationThresholdBps: liquidationThresholdBps,
            liquidationIncentiveBps: liquidationIncentiveBps,
            totalDeposits: 0,
            totalBorrows: 0,
            borrowIndex: 1e18,
            lastAccrualTimestamp: block.timestamp,
            borrowRatePerSecond: borrowRatePerSecond,
            reserveFactorBps: reserveFactorBps,
            reserves: 0
        });
        marketTokens.push(token);

        emit MarketListed(token, collateralFactorBps, liquidationThresholdBps);
    }

    function setPauseBorrowing(bool _paused) external onlyOwner {
        borrowingPaused = _paused;
        emit BorrowingPaused(_paused);
    }

    // ============ Interest Accrual ============

    function accrueInterest(address token) public {
        Market storage market = markets[token];
        if (!market.isListed) return;

        uint256 timeElapsed = block.timestamp - market.lastAccrualTimestamp;
        if (timeElapsed == 0) return;

        if (market.totalBorrows > 0) {
            uint256 interestAccumulated = (market.totalBorrows * market.borrowRatePerSecond * timeElapsed) / 1e18;
            uint256 reserveShare = (interestAccumulated * market.reserveFactorBps) / BPS_DENOMINATOR;

            market.totalBorrows += interestAccumulated;
            market.reserves += reserveShare;

            // Update borrow index
            uint256 indexDelta = (market.borrowIndex * market.borrowRatePerSecond * timeElapsed) / 1e18;
            market.borrowIndex += indexDelta;
        }

        market.lastAccrualTimestamp = block.timestamp;
    }

    function _currentBorrowBalance(address user, address token) internal view returns (uint256) {
        UserAccount storage account = accounts[user];
        uint256 principal = account.borrows[token];
        if (principal == 0) return 0;

        uint256 userIndex = account.borrowIndex[token];
        if (userIndex == 0) return principal;

        Market storage market = markets[token];
        // Calculate current index including unaccrued interest
        uint256 timeElapsed = block.timestamp - market.lastAccrualTimestamp;
        uint256 currentIndex = market.borrowIndex;
        if (timeElapsed > 0 && market.totalBorrows > 0) {
            uint256 indexDelta = (currentIndex * market.borrowRatePerSecond * timeElapsed) / 1e18;
            currentIndex += indexDelta;
        }

        return (principal * currentIndex) / userIndex;
    }

    // ============ Core Lending Functions ============

    /**
     * @notice Deposit tokens as collateral / lending supply.
     */
    function deposit(address token, uint256 amount) external nonReentrant {
        Market storage market = markets[token];
        require(market.isListed, "Market not listed");
        require(amount > 0, "Zero amount");

        accrueInterest(token);

        IERC20(token).safeTransferFrom(msg.sender, address(this), amount);

        accounts[msg.sender].deposits[token] += amount;
        market.totalDeposits += amount;

        emit Deposit(msg.sender, token, amount);
    }

    /**
     * @notice Withdraw deposited tokens.
     */
    function withdraw(address token, uint256 amount) external nonReentrant {
        Market storage market = markets[token];
        require(market.isListed, "Market not listed");

        accrueInterest(token);

        UserAccount storage account = accounts[msg.sender];
        require(account.deposits[token] >= amount, "Insufficient deposit");

        // Temporarily reduce deposit to check health
        account.deposits[token] -= amount;
        market.totalDeposits -= amount;

        // Verify account remains healthy after withdrawal
        require(_isHealthy(msg.sender), "Would become undercollateralized");

        // Check liquidity
        require(
            IERC20(token).balanceOf(address(this)) >= amount,
            "Insufficient liquidity"
        );

        IERC20(token).safeTransfer(msg.sender, amount);

        emit Withdraw(msg.sender, token, amount);
    }

    /**
     * @notice Borrow tokens against deposited collateral.
     * @dev Uses TWAP oracle price to prevent flash loan manipulation.
     */
    function borrow(address token, uint256 amount) external nonReentrant {
        require(!borrowingPaused, "Borrowing paused");

        Market storage market = markets[token];
        require(market.isListed, "Market not listed");
        require(amount > 0, "Zero amount");

        accrueInterest(token);

        // Check available liquidity
        uint256 available = IERC20(token).balanceOf(address(this)) - market.reserves;
        require(amount <= available, "Insufficient liquidity");

        UserAccount storage account = accounts[msg.sender];

        // Update user borrow
        uint256 currentBorrow = _currentBorrowBalance(msg.sender, token);
        account.borrows[token] = currentBorrow + amount;
        account.borrowIndex[token] = market.borrowIndex;
        market.totalBorrows += amount;

        // Verify account is healthy after borrow
        require(_isHealthy(msg.sender), "Undercollateralized");

        // Verify minimum borrow value to prevent dust attacks
        uint256 borrowPrice = _getSafePrice(token);
        uint256 borrowValue = (amount * borrowPrice) / 1e18;
        require(borrowValue >= MIN_BORROW_VALUE, "Borrow too small");

        IERC20(token).safeTransfer(msg.sender, amount);

        emit Borrow(msg.sender, token, amount);
    }

    /**
     * @notice Repay borrowed tokens.
     */
    function repay(address token, uint256 amount) external nonReentrant {
        Market storage market = markets[token];
        require(market.isListed, "Market not listed");

        accrueInterest(token);

        UserAccount storage account = accounts[msg.sender];
        uint256 currentBorrow = _currentBorrowBalance(msg.sender, token);
        require(currentBorrow > 0, "No borrow to repay");

        uint256 repayAmount = amount > currentBorrow ? currentBorrow : amount;

        IERC20(token).safeTransferFrom(msg.sender, address(this), repayAmount);

        account.borrows[token] = currentBorrow - repayAmount;
        account.borrowIndex[token] = market.borrowIndex;

        // Safely reduce totalBorrows
        if (market.totalBorrows >= repayAmount) {
            market.totalBorrows -= repayAmount;
        } else {
            market.totalBorrows = 0;
        }

        emit Repay(msg.sender, token, repayAmount);
    }

    /**
     * @notice Liquidate an undercollateralized position.
     * @dev Uses TWAP prices to prevent manipulation-based liquidations.
     */
    function liquidate(
        address borrower,
        address repayToken,
        address collateralToken,
        uint256 repayAmount
    ) external nonReentrant {
        require(borrower != msg.sender, "Cannot self-liquidate");

        accrueInterest(repayToken);
        accrueInterest(collateralToken);

        // Verify borrower is actually undercollateralized using TWAP
        require(!_isHealthyForLiquidation(borrower), "Account is healthy");

        UserAccount storage borrowerAccount = accounts[borrower];
        uint256 currentBorrow = _currentBorrowBalance(borrower, repayToken);
        require(currentBorrow > 0, "No borrow");

        // Enforce close factor
        uint256 maxRepay = (currentBorrow * CLOSE_FACTOR_BPS) / BPS_DENOMINATOR;
        require(repayAmount <= maxRepay, "Exceeds close factor");
        require(repayAmount > 0, "Zero repay");

        // Calculate collateral to seize using TWAP prices
        uint256 repayPrice = _getSafePrice(repayToken);
        uint256 collateralPrice = _getSafePrice(collateralToken);

        Market storage collateralMarket = markets[collateralToken];
        uint256 incentive = BPS_DENOMINATOR + collateralMarket.liquidationIncentiveBps;

        // collateralToSeize = (repayAmount * repayPrice * incentive) / (collateralPrice * BPS_DENOMINATOR)
        uint256 collateralToSeize = (repayAmount * repayPrice * incentive) / (collateralPrice * BPS_DENOMINATOR);

        require(borrowerAccount.deposits[collateralToken] >= collateralToSeize, "Insufficient collateral to seize");

        // Execute liquidation
        IERC20(repayToken).safeTransferFrom(msg.sender, address(this), repayAmount);

        // Update borrower's borrow
        borrowerAccount.borrows[repayToken] = currentBorrow - repayAmount;
        borrowerAccount.borrowIndex[repayToken] = markets[repayToken].borrowIndex;
        if (markets[repayToken].totalBorrows >= repayAmount) {
            markets[repayToken].totalBorrows -= repayAmount;
        } else {
            markets[repayToken].totalBorrows = 0;
        }

        // Seize collateral
        borrowerAccount.deposits[collateralToken] -= collateralToSeize;
        collateralMarket.totalDeposits -= collateralToSeize;

        // Transfer seized collateral to liquidator
        IERC20(collateralToken).safeTransfer(msg.sender, collateralToSeize);

        emit Liquidation(msg.sender, borrower, repayToken, collateralToken, repayAmount, collateralToSeize);
    }

    // ============ Health Check Functions ============

    /**
     * @notice Check if an account is healthy (collateral value > borrow value adjusted by CF).
     * @dev Uses TWAP oracle to prevent price manipulation attacks.
     */
    function _isHealthy(address user) internal view returns (bool) {
        (uint256 totalCollateralValue, uint256 totalBorrowValue) = _getAccountValues(user, false);

        if (totalBorrowValue == 0) return true;
        return totalCollateralValue >= totalBorrowValue;
    }

    /**
     * @notice Check health for liquidation purposes using liquidation threshold.
     */
    function _isHealthyForLiquidation(address user) internal view returns (bool) {
        (uint256 totalCollateralValue, uint256 totalBorrowValue) = _getAccountValues(user, true);

        if (totalBorrowValue == 0) return true;
        return totalCollateralValue >= totalBorrowValue;
    }

    /**
     * @notice Calculate total collateral and borrow values for an account.
     * @param useLiquidationThreshold If true, use liquidation threshold; otherwise use collateral factor.
     */
    function _getAccountValues(
        address user,
        bool useLiquidationThreshold
    ) internal view returns (uint256 totalCollateralValue, uint256 totalBorrowValue) {
        UserAccount storage account = accounts[user];

        for (uint256 i = 0; i < marketTokens.length; i++) {
            address token = marketTokens[i];
            Market storage market = markets[token];

            uint256 price = _getSafePrice(token);

            // Collateral value (adjusted by collateral factor or liquidation threshold)
            uint256 depositAmount = account.deposits[token];
            if (depositAmount > 0) {
                uint256 rawValue = (depositAmount * price) / 1e18;
                uint256 factor = useLiquidationThreshold
                    ? market.liquidationThresholdBps
                    : market.collateralFactorBps;
                totalCollateralValue += (rawValue * factor) / BPS_DENOMINATOR;
            }

            // Borrow value (at full value)
            uint256 borrowAmount = _currentBorrowBalance(user, token);
            if (borrowAmount > 0) {
                totalBorrowValue += (borrowAmount * price) / 1e18;
            }
        }
    }

    /**
     * @notice Get manipulation-resistant price from TWAP oracle.
     * @dev Reverts if price is stale or potentially manipulated.
     */
    function _getSafePrice(address token) internal view returns (uint256) {
        return oracle.getSafePrice(token);
    }

    // ============ View Functions ============

    function getAccountHealth(address user) external view returns (
        uint256 totalCollateralValue,
        uint256 totalBorrowValue,
        bool isHealthy
    ) {
        (totalCollateralValue, totalBorrowValue) = _getAccountValues(user, false);
        isHealthy = totalBorrowValue == 0 || totalCollateralValue >= totalBorrowValue;
    }

    function getUserDeposit(address user, address token) external view returns (uint256) {
        return accounts[user].deposits[token];
    }

    function getUserBorrow(address user, address token) external view returns (uint256) {
        return _currentBorrowBalance(user, token);
    }

    function getMarketCount() external view returns (uint256) {
        return marketTokens.length;
    }

    function isLiquidatable(address user) external view returns (bool) {
        return !_isHealthyForLiquidation(user);
    }

    /**
     * @notice Emergency function to withdraw reserves.
     */
    function withdrawReserves(address token, uint256 amount) external onlyOwner {
        Market storage market = markets[token];
        require(amount <= market.reserves, "Exceeds reserves");
        market.reserves -= amount;
        IERC20(token).safeTransfer(owner(), amount);
    }
