pragma solidity ^0.8.19;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/token/ERC20/utils/SafeERC20.sol";
import "@openzeppelin/contracts/security/ReentrancyGuard.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

contract DecentralizedExchange is ReentrancyGuard, Ownable {
    using SafeERC20 for IERC20;

    struct Pool {
        address token0;
        address token1;
        uint256 reserve0;
        uint256 reserve1;
        uint256 totalLiquidity;
        uint256 lastBlockNumber;
        uint256 cumulativePrice0;
        uint256 cumulativePrice1;
        uint256 lastTimestamp;
        // TWAP oracle data
        uint256 price0CumulativeLast;
        uint256 price1CumulativeLast;
    }

    struct TWAPObservation {
        uint256 timestamp;
        uint256 price0Cumulative;
        uint256 price1Cumulative;
    }

    // Pool ID => Pool
    mapping(bytes32 => Pool) public pools;
    // Pool ID => provider => liquidity
    mapping(bytes32 => mapping(address => uint256)) public liquidity;
    // Pool ID => TWAP observations
    mapping(bytes32 => TWAPObservation[]) public observations;

    uint256 public constant MINIMUM_LIQUIDITY = 1000;
    uint256 public constant FEE_NUMERATOR = 3; // 0.3% fee
    uint256 public constant FEE_DENOMINATOR = 1000;
    uint256 public constant TWAP_PERIOD = 10 minutes;
    uint256 public constant MAX_PRICE_DEVIATION_BPS = 500; // 5% max deviation from TWAP
    uint256 public constant PRICE_PRECISION = 1e18;

    event PoolCreated(bytes32 indexed poolId, address token0, address token1);
    event LiquidityAdded(bytes32 indexed poolId, address indexed provider, uint256 amount0, uint256 amount1, uint256 liquidityMinted);
    event LiquidityRemoved(bytes32 indexed poolId, address indexed provider, uint256 amount0, uint256 amount1, uint256 liquidityBurned);
    event Swap(bytes32 indexed poolId, address indexed sender, address tokenIn, address tokenOut, uint256 amountIn, uint256 amountOut);
    event OracleUpdated(bytes32 indexed poolId, uint256 price0Cumulative, uint256 price1Cumulative);

    modifier ensureDeadline(uint256 deadline) {
        require(block.timestamp <= deadline, "DEX: EXPIRED");
        _;
    }

    // Prevent same-block manipulation: disallow swap if liquidity was added in the same block
    modifier flashLoanProtection(bytes32 poolId) {
        require(pools[poolId].lastBlockNumber != block.number, "DEX: SAME_BLOCK_OPERATION");
        _;
    }

    function getPoolId(address tokenA, address tokenB) public pure returns (bytes32) {
        require(tokenA != tokenB, "DEX: IDENTICAL_ADDRESSES");
        (address token0, address token1) = tokenA < tokenB ? (tokenA, tokenB) : (tokenB, tokenA);
        return keccak256(abi.encodePacked(token0, token1));
    }

    function createPool(address tokenA, address tokenB) external returns (bytes32 poolId) {
        require(tokenA != address(0) && tokenB != address(0), "DEX: ZERO_ADDRESS");
        require(tokenA != tokenB, "DEX: IDENTICAL_ADDRESSES");

        (address token0, address token1) = tokenA < tokenB ? (tokenA, tokenB) : (tokenB, tokenA);
        poolId = getPoolId(token0, token1);
        require(pools[poolId].token0 == address(0), "DEX: POOL_EXISTS");

        pools[poolId] = Pool({
            token0: token0,
            token1: token1,
            reserve0: 0,
            reserve1: 0,
            totalLiquidity: 0,
            lastBlockNumber: 0,
            cumulativePrice0: 0,
            cumulativePrice1: 0,
            lastTimestamp: block.timestamp,
            price0CumulativeLast: 0,
            price1CumulativeLast: 0
        });

        // Initialize first observation
        observations[poolId].push(TWAPObservation({
            timestamp: block.timestamp,
            price0Cumulative: 0,
            price1Cumulative: 0
        }));

        emit PoolCreated(poolId, token0, token1);
    }

    function _updateOracle(bytes32 poolId) internal {
        Pool storage pool = pools[poolId];
        uint256 timeElapsed = block.timestamp - pool.lastTimestamp;

        if (timeElapsed > 0 && pool.reserve0 > 0 && pool.reserve1 > 0) {
            // Accumulate price * time
            pool.price0CumulativeLast += (pool.reserve1 * PRICE_PRECISION / pool.reserve0) * timeElapsed;
            pool.price1CumulativeLast += (pool.reserve0 * PRICE_PRECISION / pool.reserve1) * timeElapsed;

            observations[poolId].push(TWAPObservation({
                timestamp: block.timestamp,
                price0Cumulative: pool.price0CumulativeLast,
                price1Cumulative: pool.price1CumulativeLast
            }));

            pool.lastTimestamp = block.timestamp;

            emit OracleUpdated(poolId, pool.price0CumulativeLast, pool.price1CumulativeLast);
        }
    }

    function getTWAPPrice(bytes32 poolId, bool isToken0) public view returns (uint256) {
        TWAPObservation[] storage obs = observations[poolId];
        require(obs.length > 0, "DEX: NO_OBSERVATIONS");

        Pool storage pool = pools[poolId];

        // Get current cumulative price
        uint256 currentCumulative;
        uint256 timeElapsed = block.timestamp - pool.lastTimestamp;

        if (isToken0) {
            currentCumulative = pool.price0CumulativeLast;
            if (timeElapsed > 0 && pool.reserve0 > 0) {
                currentCumulative += (pool.reserve1 * PRICE_PRECISION / pool.reserve0) * timeElapsed;
            }
        } else {
            currentCumulative = pool.price1CumulativeLast;
            if (timeElapsed > 0 && pool.reserve1 > 0) {
                currentCumulative += (pool.reserve0 * PRICE_PRECISION / pool.reserve1) * timeElapsed;
            }
        }

        // Find observation closest to TWAP_PERIOD ago
        uint256 targetTimestamp = block.timestamp > TWAP_PERIOD ? block.timestamp - TWAP_PERIOD : 0;
        uint256 oldCumulative;
        uint256 oldTimestamp;

        // Search backwards for the right observation
        for (uint256 i = obs.length; i > 0; i--) {
            if (obs[i - 1].timestamp <= targetTimestamp) {
                oldTimestamp = obs[i - 1].timestamp;
                oldCumulative = isToken0 ? obs[i - 1].price0Cumulative : obs[i - 1].price1Cumulative;
                break;
            }
            if (i == 1) {
                // Use the oldest observation available
                oldTimestamp = obs[0].timestamp;
                oldCumulative = isToken0 ? obs[0].price0Cumulative : obs[0].price1Cumulative;
            }
        }

        uint256 elapsed = block.timestamp - oldTimestamp;
        if (elapsed == 0) {
            // Fallback to spot price if no time has elapsed
            if (isToken0) {
                return pool.reserve0 > 0 ? pool.reserve1 * PRICE_PRECISION / pool.reserve0 : 0;
            } else {
                return pool.reserve1 > 0 ? pool.reserve0 * PRICE_PRECISION / pool.reserve1 : 0;
            }
        }

        return (currentCumulative - oldCumulative) / elapsed;
    }

    function _checkPriceDeviation(bytes32 poolId, uint256 spotPrice, bool isToken0) internal view {
        Pool storage pool = pools[poolId];

        // Skip TWAP check if pool is new (not enough observations)
        if (observations[poolId].length < 2) {
            return;
        }

        // Skip if pool was just created (need time for TWAP to be meaningful)
        if (block.timestamp - observations[poolId][0].timestamp < TWAP_PERIOD / 2) {
            return;
        }

        uint256 twapPrice = getTWAPPrice(poolId, isToken0);
        if (twapPrice == 0) return;

        uint256 deviation;
        if (spotPrice > twapPrice) {
            deviation = ((spotPrice - twapPrice) * 10000) / twapPrice;
        } else {
            deviation = ((twapPrice - spotPrice) * 10000) / twapPrice;
        }

        require(deviation <= MAX_PRICE_DEVIATION_BPS, "DEX: PRICE_DEVIATION_TOO_HIGH");
    }

    function addLiquidity(
        address tokenA,
        address tokenB,
        uint256 amountADesired,
        uint256 amountBDesired,
        uint256 amountAMin,
        uint256 amountBMin,
        uint256 deadline
    ) external nonReentrant ensureDeadline(deadline) returns (uint256 amountA, uint256 amountB, uint256 liquidityMinted) {
        bytes32 poolId = getPoolId(tokenA, tokenB);
        Pool storage pool = pools[poolId];
        require(pool.token0 != address(0), "DEX: POOL_NOT_EXISTS");

        // Determine correct ordering
        (uint256 amount0Desired, uint256 amount1Desired, uint256 amount0Min, uint256 amount1Min) = 
            tokenA < tokenB 
                ? (amountADesired, amountBDesired, amountAMin, amountBMin) 
                : (amountBDesired, amountADesired, amountBMin, amountAMin);

        _updateOracle(poolId);

        uint256 amount0;
        uint256 amount1;

        if (pool.totalLiquidity == 0) {
            amount0 = amount0Desired;
            amount1 = amount1Desired;
            liquidityMinted = _sqrt(amount0 * amount1) - MINIMUM_LIQUIDITY;
            require(liquidityMinted > 0, "DEX: INSUFFICIENT_LIQUIDITY_MINTED");
            // Lock minimum liquidity forever to prevent division by zero
            pool.totalLiquidity = MINIMUM_LIQUIDITY;
        } else {
            uint256 amount1Optimal = (amount0Desired * pool.reserve1) / pool.reserve0;
            if (amount1Optimal <= amount1Desired) {
                require(amount1Optimal >= amount1Min, "DEX: INSUFFICIENT_B_AMOUNT");
                amount0 = amount0Desired;
                amount1 = amount1Optimal;
            } else {
                uint256 amount0Optimal = (amount1Desired * pool.reserve0) / pool.reserve1;
                require(amount0Optimal <= amount0Desired, "DEX: EXCESSIVE_A_AMOUNT");
                require(amount0Optimal >= amount0Min, "DEX: INSUFFICIENT_A_AMOUNT");
                amount0 = amount0Optimal;
                amount1 = amount1Desired;
            }

            liquidityMinted = _min(
                (amount0 * pool.totalLiquidity) / pool.reserve0,
                (amount1 * pool.totalLiquidity) / pool.reserve1
            );
            require(liquidityMinted > 0, "DEX: INSUFFICIENT_LIQUIDITY_MINTED");
        }

        IERC20(pool.token0).safeTransferFrom(msg.sender, address(this), amount0);
        IERC20(pool.token1).safeTransferFrom(msg.sender, address(this), amount1);

        pool.reserve0 += amount0;
        pool.reserve1 += amount1;
        pool.totalLiquidity += liquidityMinted;
        pool.lastBlockNumber = block.number;
        liquidity[poolId][msg.sender] += liquidityMinted;

        // Return amounts in caller's token order
        (amountA, amountB) = tokenA < tokenB ? (amount0, amount1) : (amount1, amount0);

        emit LiquidityAdded(poolId, msg.sender, amount0, amount1, liquidityMinted);
    }

    function removeLiquidity(
        address tokenA,
        address tokenB,
        uint256 liquidityAmount,
        uint256 amountAMin,
        uint256 amountBMin,
        uint256 deadline
    ) external nonReentrant ensureDeadline(deadline) returns (uint256 amountA, uint256 amountB) {
        bytes32 poolId = getPoolId(tokenA, tokenB);
        Pool storage pool = pools[poolId];
        require(pool.token0 != address(0), "DEX: POOL_NOT_EXISTS");
        require(liquidity[poolId][msg.sender] >= liquidityAmount, "DEX: INSUFFICIENT_LIQUIDITY");

        _updateOracle(poolId);

        uint256 amount0 = (liquidityAmount * pool.reserve0) / pool.totalLiquidity;
        uint256 amount1 = (liquidityAmount * pool.reserve1) / pool.totalLiquidity;

        (uint256 minA, uint256 minB) = tokenA < tokenB ? (amountAMin, amountBMin) : (amountBMin, amountAMin);
        require(amount0 >= minA, "DEX: INSUFFICIENT_A_AMOUNT");
        require(amount1 >= minB, "DEX: INSUFFICIENT_B_AMOUNT");

        liquidity[poolId][msg.sender] -= liquidityAmount;
        pool.totalLiquidity -= liquidityAmount;
        pool.reserve0 -= amount0;
        pool.reserve1 -= amount1;
        pool.lastBlockNumber = block.number;

        IERC20(pool.token0).safeTransfer(msg.sender, amount0);
        IERC20(pool.token1).safeTransfer(msg.sender, amount1);

        (amountA, amountB) = tokenA < tokenB ? (amount0, amount1) : (amount1, amount0);

        emit LiquidityRemoved(poolId, msg.sender, amount0, amount1, liquidityAmount);
    }

    function swap(
        address tokenIn,
        address tokenOut,
        uint256 amountIn,
        uint256 amountOutMin,
        uint256 deadline
    ) external nonReentrant ensureDeadline(deadline) flashLoanProtection(getPoolId(tokenIn, tokenOut)) returns (uint256 amountOut) {
        require(amountIn > 0, "DEX: INSUFFICIENT_INPUT_AMOUNT");
        require(tokenIn != tokenOut, "DEX: IDENTICAL_ADDRESSES");

        bytes32 poolId = getPoolId(tokenIn, tokenOut);
        Pool storage pool = pools[poolId];
        require(pool.token0 != address(0), "DEX: POOL_NOT_EXISTS");
        require(pool.reserve0 > 0 && pool.reserve1 > 0, "DEX: INSUFFICIENT_LIQUIDITY");

        _updateOracle(poolId);

        bool isToken0In = tokenIn == pool.token0;
        (uint256 reserveIn, uint256 reserveOut) = isToken0In 
            ? (pool.reserve0, pool.reserve1) 
            : (pool.reserve1, pool.reserve0);

        // Calculate amount out using constant product formula with fee
        uint256 amountInWithFee = amountIn * (FEE_DENOMINATOR - FEE_NUMERATOR);
        amountOut = (amountInWithFee * reserveOut) / (reserveIn * FEE_DENOMINATOR + amountInWithFee);

        require(amountOut > 0, "DEX: INSUFFICIENT_OUTPUT_AMOUNT");
        require(amountOut >= amountOutMin, "DEX: SLIPPAGE_EXCEEDED");
        require(amountOut < reserveOut, "DEX: INSUFFICIENT_LIQUIDITY");

        // Check spot price against TWAP to detect flash loan manipulation
        // Spot price after swap
        uint256 newReserveIn = reserveIn + amountIn;
        uint256 newReserveOut = reserveOut - amountOut;
        uint256 spotPriceAfter = isToken0In 
            ? (newReserveOut * PRICE_PRECISION / newReserveIn)
            : (newReserveIn * PRICE_PRECISION / newReserveOut);

        _checkPriceDeviation(poolId, spotPriceAfter, true);

        // Transfer tokens
        IERC20(tokenIn).safeTransferFrom(msg.sender, address(this), amountIn);

        // Verify K invariant (with fee accounted for)
        uint256 balance0After;
        uint256 balance1After;
        if (isToken0In) {
            pool.reserve0 += amountIn;
            pool.reserve1 -= amountOut;
            balance0After = pool.reserve0;
            balance1After = pool.reserve1;
        } else {
            pool.reserve1 += amountIn;
            pool.reserve0 -= amountOut;
            balance0After = pool.reserve0;
            balance1After = pool.reserve1;
        }

        // Verify constant product invariant (accounting for fees)
        // (reserve0 * FEE_DENOMINATOR - fee0) * (reserve1 * FEE_DENOMINATOR - fee1) >= old_k * FEE_DENOMINATOR^2
        require(
            balance0After * balance1After >= reserveIn * reserveOut,
            "DEX: K_INVARIANT_VIOLATED"
        );

        IERC20(tokenOut).safeTransfer(msg.sender, amountOut);

        emit Swap(poolId, msg.sender, tokenIn, tokenOut, amountIn, amountOut);
    }

    function getAmountOut(
        address tokenIn,
        address tokenOut,
        uint256 amountIn
    ) external view returns (uint256 amountOut) {
        bytes32 poolId = getPoolId(tokenIn, tokenOut);
        Pool storage pool = pools[poolId];
        require(pool.reserve0 > 0 && pool.reserve1 > 0, "DEX: INSUFFICIENT_LIQUIDITY");

        bool isToken0In = tokenIn == pool.token0;
        (uint256 reserveIn, uint256 reserveOut) = isToken0In 
            ? (pool.reserve0, pool.reserve1) 
            : (pool.reserve1, pool.reserve0);

        uint256 amountInWithFee = amountIn * (FEE_DENOMINATOR - FEE_NUMERATOR);
        amountOut = (amountInWithFee * reserveOut) / (reserveIn * FEE_DENOMINATOR + amountInWithFee);
    }

    function getPoolInfo(bytes32 poolId) external view returns (
        address token0,
        address token1,
        uint256 reserve0,
        uint256 reserve1,
        uint256 totalLiq
    ) {
        Pool storage pool = pools[poolId];
        return (pool.token0, pool.token1, pool.reserve0, pool.reserve1, pool.totalLiquidity);
    }

    function getSpotPrice(bytes32 poolId, bool token0PerToken1) external view returns (uint256) {
        Pool storage pool = pools[poolId];
        require(pool.reserve0 > 0 && pool.reserve1 > 0, "DEX: NO_RESERVES");
        if (token0PerToken1) {
            return pool.reserve0 * PRICE_PRECISION / pool.reserve1;
        } else {
            return pool.reserve1 * PRICE_PRECISION / pool.reserve0;
        }
    }

    function _sqrt(uint256 y) internal pure returns (uint256 z) {
        if (y > 3) {
            z = y;
            uint256 x = y / 2 + 1;
            while (x < z) {
                z = x;
                x = (y / x + x) / 2;
            }
        } else if (y != 0) {
            z = 1;
        }
    }

    function _min(uint256 a, uint256 b) internal pure returns (uint256) {
        return a < b ? a : b;
    }
