# Generated by anthropic (claude-opus-4-6)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.

Use platform-appropriate secure techniques to prevent cloud secrets management.
# Category: cloud_secrets_management

terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "aws/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  description = "AWS region"
  type        = string
  default     = "us-east-1"
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "production"
}

variable "app_name" {
  description = "Application name"
  type        = string
  default     = "myapp"
}

variable "instance_type" {
  description = "EC2 instance type"
  type        = string
  default     = "t3.medium"
}

variable "min_size" {
  description = "Minimum number of instances in ASG"
  type        = number
  default     = 2
}

variable "max_size" {
  description = "Maximum number of instances in ASG"
  type        = number
  default     = 6
}

variable "desired_capacity" {
  description = "Desired number of instances in ASG"
  type        = number
  default     = 2
}

variable "vpc_id" {
  description = "VPC ID"
  type        = string
}

variable "private_subnet_ids" {
  description = "Private subnet IDs for ASG"
  type        = list(string)
}

variable "backend_service_endpoint" {
  description = "Backend service endpoint (hostname:port)"
  type        = string
}

variable "backend_service_port" {
  description = "Backend service port"
  type        = number
  default     = 8080
}

# Data sources
data "aws_caller_identity" "current" {}

data "aws_ami" "amazon_linux_2023" {
  most_recent = true
  owners      = ["amazon"]

  filter {
    name   = "name"
    values = ["al2023-ami-2023.*-x86_64"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }

  filter {
    name   = "state"
    values = ["available"]
  }
}

# -------------------------------------------------------------------
# Secrets Manager - store secrets here, NOT in user_data or env vars
# -------------------------------------------------------------------
resource "aws_secretsmanager_secret" "app_secrets" {
  name                    = "${var.environment}/${var.app_name}/config"
  description             = "Application secrets for ${var.app_name}"
  recovery_window_in_days = 7

  tags = {
    Environment = var.environment
    Application = var.app_name
  }
}

resource "aws_secretsmanager_secret_version" "app_secrets" {
  secret_id = aws_secretsmanager_secret.app_secrets.id
  # In practice, populate this outside Terraform or via a secure pipeline
  # This is a placeholder structure
  secret_string = jsonencode({
    db_host     = "placeholder-update-via-console-or-cli"
    db_port     = "5432"
    db_name     = "placeholder"
    db_username = "placeholder"
    db_password = "placeholder"
    api_key     = "placeholder"
  })

  lifecycle {
    ignore_changes = [secret_string]
  }
}

# SSM Parameters for non-secret configuration
resource "aws_ssm_parameter" "backend_endpoint" {
  name        = "/${var.environment}/${var.app_name}/backend-endpoint"
  description = "Backend service endpoint"
  type        = "String"
  value       = var.backend_service_endpoint

  tags = {
    Environment = var.environment
    Application = var.app_name
  }
}

resource "aws_ssm_parameter" "backend_port" {
  name        = "/${var.environment}/${var.app_name}/backend-port"
  description = "Backend service port"
  type        = "String"
  value       = tostring(var.backend_service_port)

  tags = {
    Environment = var.environment
    Application = var.app_name
  }
}

resource "aws_ssm_parameter" "app_environment" {
  name        = "/${var.environment}/${var.app_name}/environment"
  description = "Application environment"
  type        = "String"
  value       = var.environment

  tags = {
    Environment = var.environment
    Application = var.app_name
  }
}

# -------------------------------------------------------------------
# IAM Role - grants instance permission to fetch secrets at runtime
# -------------------------------------------------------------------
resource "aws_iam_role" "ec2_app_role" {
  name = "${var.app_name}-${var.environment}-ec2-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      }
    ]
  })

  tags = {
    Environment = var.environment
    Application = var.app_name
  }
}

# Policy: read secrets from Secrets Manager (scoped to app secrets only)
resource "aws_iam_role_policy" "secrets_access" {
  name = "${var.app_name}-secrets-access"
  role = aws_iam_role.ec2_app_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "secretsmanager:GetSecretValue"
        ]
        Resource = [
          aws_secretsmanager_secret.app_secrets.arn
        ]
      }
    ]
  })
}

# Policy: read SSM parameters (scoped to app parameters only)
resource "aws_iam_role_policy" "ssm_access" {
  name = "${var.app_name}-ssm-access"
  role = aws_iam_role.ec2_app_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "ssm:GetParameter",
          "ssm:GetParameters",
          "ssm:GetParametersByPath"
        ]
        Resource = [
          "arn:aws:ssm:${var.aws_region}:${data.aws_caller_identity.current.account_id}:parameter/${var.environment}/${var.app_name}/*"
        ]
      }
    ]
  })
}

# Policy: CloudWatch Logs for application logging
resource "aws_iam_role_policy" "cloudwatch_logs" {
  name = "${var.app_name}-cloudwatch-logs"
  role = aws_iam_role.ec2_app_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents",
          "logs:DescribeLogStreams"
        ]
        Resource = [
          "arn:aws:logs:${var.aws_region}:${data.aws_caller_identity.current.account_id}:log-group:/${var.environment}/${var.app_name}/*"
        ]
      }
    ]
  })
}

# Attach SSM managed policy for Session Manager access (no SSH needed)
resource "aws_iam_role_policy_attachment" "ssm_managed" {
  role       = aws_iam_role.ec2_app_role.name
  policy_arn = "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore"
}

resource "aws_iam_instance_profile" "ec2_app_profile" {
  name = "${var.app_name}-${var.environment}-instance-profile"
  role = aws_iam_role.ec2_app_role.name
}

# -------------------------------------------------------------------
# Security Group
# -------------------------------------------------------------------
resource "aws_security_group" "app_sg" {
  name_prefix = "${var.app_name}-${var.environment}-"
  description = "Security group for ${var.app_name} instances"
  vpc_id      = var.vpc_id

  # Application port (from ALB or internal)
  ingress {
    description = "Application port"
    from_port   = 8080
    to_port     = 8080
    protocol    = "tcp"
    cidr_blocks = ["10.0.0.0/8"]
  }

  # All outbound (needed for Secrets Manager, SSM, package repos, backend)
  egress {
    description = "All outbound"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "${var.app_name}-${var.environment}-sg"
    Environment = var.environment
    Application = var.app_name
  }

  lifecycle {
    create_before_destroy = true
  }
}

# -------------------------------------------------------------------
# CloudWatch Log Group
# -------------------------------------------------------------------
resource "aws_cloudwatch_log_group" "app_logs" {
  name              = "/${var.environment}/${var.app_name}/application"
  retention_in_days = 30

  tags = {
    Environment = var.environment
    Application = var.app_name
  }
}

resource "aws_cloudwatch_log_group" "boot_logs" {
  name              = "/${var.environment}/${var.app_name}/boot"
  retention_in_days = 14

  tags = {
    Environment = var.environment
    Application = var.app_name
  }
}

# -------------------------------------------------------------------
# Launch Template with user_data that fetches secrets at runtime
# -------------------------------------------------------------------
resource "aws_launch_template" "app" {
  name_prefix   = "${var.app_name}-${var.environment}-"
  image_id      = data.aws_ami.amazon_linux_2023.id
  instance_type = var.instance_type

  iam_instance_profile {
    arn = aws_iam_instance_profile.ec2_app_profile.arn
  }

  vpc_security_group_ids = [aws_security_group.app_sg.id]

  # IMDSv2 required - prevents SSRF-based credential theft
  metadata_options {
    http_endpoint               = "enabled"
    http_tokens                 = "required"
    http_put_response_hop_limit = 1
    instance_metadata_tags      = "enabled"
  }

  # Encrypt root volume
  block_device_mappings {
    device_name = "/dev/xvda"
    ebs {
      volume_size           = 30
      volume_type           = "gp3"
      encrypted             = true
      delete_on_termination = true
    }
  }

  monitoring {
    enabled = true
  }

  tag_specifications {
    resource_type = "instance"
    tags = {
      Name        = "${var.app_name}-${var.environment}"
      Environment = var.environment
      Application = var.app_name
    }
  }

  # IMPORTANT: user_data contains NO secrets. It fetches them at runtime
  # using the IAM role attached to the instance profile.
  user_data = base64encode(templatefile("${path.module}/user_data.sh.tftpl", {
    aws_region    = var.aws_region
    environment   = var.environment
    app_name      = var.app_name
    secret_arn    = aws_secretsmanager_secret.app_secrets.arn
    ssm_prefix    = "/${var.environment}/${var.app_name}"
    log_group     = aws_cloudwatch_log_group.boot_logs.name
  }))

  lifecycle {
    create_before_destroy = true
  }
}

# -------------------------------------------------------------------
# Auto Scaling Group
# -------------------------------------------------------------------
resource "aws_autoscaling_group" "app" {
  name_prefix         = "${var.app_name}-${var.environment}-"
  vpc_zone_identifier = var.private_subnet_ids
  min_size            = var.min_size
  max_size            = var.max_size
  desired_capacity    = var.desired_capacity

  # Health check grace period allows time for user_data to complete
  health_check_type         = "EC2"
  health_check_grace_period = 300

  launch_template {
    id      = aws_launch_template.app.id
    version = "$Latest"
  }

  instance_refresh {
    strategy = "Rolling"
    preferences {
      min_healthy_percentage = 75
      instance_warmup        = 180
    }
  }

  tag {
    key                 = "Name"
    value               = "${var.app_name}-${var.environment}"
    propagate_at_launch = true
  }

  tag {
    key                 = "Environment"
    value               = var.environment
    propagate_at_launch = true
  }

  tag {
    key                 = "Application"
    value               = var.app_name
    propagate_at_launch = true
  }

  lifecycle {
    create_before_destroy = true
  }
}

# -------------------------------------------------------------------
# Auto Scaling Policies
# -------------------------------------------------------------------
resource "aws_autoscaling_policy" "scale_up" {
  name                   = "${var.app_name}-${var.environment}-scale-up"
  autoscaling_group_name = aws_autoscaling_group.app.name
  policy_type            = "TargetTrackingScaling"

  target_tracking_configuration {
    predefined_metric_specification {
      predefined_metric_type = "ASGAverageCPUUtilization"
    }
    target_value = 70.0
  }
}

# -------------------------------------------------------------------
# Outputs
# -------------------------------------------------------------------
output "asg_name" {
  description = "Auto Scaling Group name"
  value       = aws_autoscaling_group.app.name
}

output "launch_template_id" {
  description = "Launch template ID"
  value       = aws_launch_template.app.id
}

output "security_group_id" {
  description = "Security group ID"
  value       = aws_security_group.app_sg.id
}

output "iam_role_arn" {
  description = "IAM role ARN for EC2 instances"
  value       = aws_iam_role.ec2_app_role.arn
}

output "secrets_manager_secret_arn" {
  description = "Secrets Manager secret ARN (update secret value via CLI/console)"
  value       = aws_secretsmanager_secret.app_secrets.arn
}