 * - Uses a commit-reveal scheme to prevent miners/validators from manipulating outcomes.
 * - Players commit a hashed secret, then reveal it after a delay.
 * - The final randomness combines multiple revealed secrets with block data,
 *   making it infeasible for any single party to predict or manipulate the result.
 * - For production, consider integrating Chainlink VRF as an additional entropy source.
 */
contract BlockchainGamingLottery is Ownable, ReentrancyGuard, Pausable {

    // ============ Structs ============

    struct LotteryRound {
        uint256 roundId;
        uint256 ticketPrice;
        uint256 maxTickets;
        uint256 ticketsSold;
        uint256 prizePool;
        uint256 commitDeadline;
        uint256 revealDeadline;
        uint256 drawBlock;          // Block number at which draw can happen
        address[] participants;
        address winner;
        bool drawn;
        bool cancelled;
        uint256 platformFee;        // basis points (e.g., 500 = 5%)
    }

    struct Commitment {
        bytes32 commitHash;
        bytes32 revealedSecret;
        bool committed;
        bool revealed;
    }

    // ============ State Variables ============

    uint256 public currentRoundId;
    uint256 public constant MAX_PLATFORM_FEE = 1000; // 10% max
    uint256 public constant MIN_REVEAL_WINDOW = 10;   // minimum blocks for reveal window
    uint256 public constant DRAW_DELAY_BLOCKS = 5;    // blocks to wait after reveal deadline

    mapping(uint256 => LotteryRound) public rounds;
    mapping(uint256 => mapping(address => uint256)) public ticketCount; // roundId => player => count
    mapping(uint256 => mapping(address => Commitment)) public commitments; // roundId => player => commitment
    mapping(uint256 => address[]) public revealedParticipants; // roundId => list of players who revealed
    mapping(uint256 => bytes32) public accumulatedEntropy; // roundId => combined entropy from reveals

    // Reward tiers for gaming platform
    struct RewardTier {
        uint256 percentage; // basis points of prize pool
        string rewardType;  // e.g., "JACKPOT", "SECOND", "THIRD", "CONSOLATION"
    }

    mapping(uint256 => RewardTier[]) public rewardTiers;
    mapping(uint256 => mapping(uint256 => address)) public tierWinners; // roundId => tierIndex => winner

    // ============ Events ============

    event RoundCreated(uint256 indexed roundId, uint256 ticketPrice, uint256 maxTickets, uint256 commitDeadline, uint256 revealDeadline);
    event TicketPurchased(uint256 indexed roundId, address indexed player, uint256 quantity);
    event SecretCommitted(uint256 indexed roundId, address indexed player);
    event SecretRevealed(uint256 indexed roundId, address indexed player);
    event WinnerDrawn(uint256 indexed roundId, address indexed winner, uint256 prize);
    event TierWinnerDrawn(uint256 indexed roundId, uint256 tierIndex, address indexed winner, uint256 prize);
    event RoundCancelled(uint256 indexed roundId);
    event RefundClaimed(uint256 indexed roundId, address indexed player, uint256 amount);
    event PlatformFeeWithdrawn(uint256 amount);

    // ============ Modifiers ============

    modifier roundExists(uint256 _roundId) {
        require(rounds[_roundId].roundId == _roundId && _roundId > 0, "Round does not exist");
        _;
    }

    modifier roundNotCancelled(uint256 _roundId) {
        require(!rounds[_roundId].cancelled, "Round is cancelled");
        _;
    }

    modifier roundNotDrawn(uint256 _roundId) {
        require(!rounds[_roundId].drawn, "Round already drawn");
        _;
    }

    // ============ Constructor ============

    constructor() Ownable() {}

    // ============ Admin Functions ============

    /**
     * @dev Create a new lottery round with commit-reveal timing.
     * @param _ticketPrice Price per ticket in wei
     * @param _maxTickets Maximum number of tickets
     * @param _commitDurationBlocks Number of blocks for commit phase
     * @param _revealDurationBlocks Number of blocks for reveal phase
     * @param _platformFee Fee in basis points
     */
    function createRound(
        uint256 _ticketPrice,
        uint256 _maxTickets,
        uint256 _commitDurationBlocks,
        uint256 _revealDurationBlocks,
        uint256 _platformFee
    ) external onlyOwner whenNotPaused {
        require(_ticketPrice > 0, "Ticket price must be > 0");
        require(_maxTickets > 0, "Max tickets must be > 0");
        require(_commitDurationBlocks > 0, "Commit duration must be > 0");
        require(_revealDurationBlocks >= MIN_REVEAL_WINDOW, "Reveal window too short");
        require(_platformFee <= MAX_PLATFORM_FEE, "Fee too high");

        currentRoundId++;

        uint256 commitDeadline = block.number + _commitDurationBlocks;
        uint256 revealDeadline = commitDeadline + _revealDurationBlocks;

        LotteryRound storage round = rounds[currentRoundId];
        round.roundId = currentRoundId;
        round.ticketPrice = _ticketPrice;
        round.maxTickets = _maxTickets;
        round.commitDeadline = commitDeadline;
        round.revealDeadline = revealDeadline;
        round.drawBlock = revealDeadline + DRAW_DELAY_BLOCKS;
        round.platformFee = _platformFee;

        emit RoundCreated(currentRoundId, _ticketPrice, _maxTickets, commitDeadline, revealDeadline);
    }

    /**
     * @dev Add reward tiers for a round. Percentages must sum to <= 10000.
     */
    function setRewardTiers(
        uint256 _roundId,
        uint256[] calldata _percentages,
        string[] calldata _rewardTypes
    ) external onlyOwner roundExists(_roundId) roundNotDrawn(_roundId) {
        require(_percentages.length == _rewardTypes.length, "Length mismatch");
        require(_percentages.length > 0, "Must have at least one tier");

        // Clear existing tiers
        delete rewardTiers[_roundId];

        uint256 totalPercentage = 0;
        for (uint256 i = 0; i < _percentages.length; i++) {
            totalPercentage += _percentages[i];
            rewardTiers[_roundId].push(RewardTier({
                percentage: _percentages[i],
                rewardType: _rewardTypes[i]
            }));
        }
        require(totalPercentage <= 10000, "Total percentage exceeds 100%");
    }

    function cancelRound(uint256 _roundId) 
        external 
        onlyOwner 
        roundExists(_roundId) 
        roundNotDrawn(_roundId) 
    {
        rounds[_roundId].cancelled = true;
        emit RoundCancelled(_roundId);
    }

    function pause() external onlyOwner {
        _pause();
    }

    function unpause() external onlyOwner {
        _unpause();
    }

    // ============ Player Functions ============

    /**
     * @dev Purchase tickets and commit a secret hash in one transaction.
     * The commit hash should be keccak256(abi.encodePacked(secret, msg.sender)).
     * @param _roundId The lottery round
     * @param _quantity Number of tickets to purchase
     * @param _commitHash The hash of the player's secret
     */
    function purchaseAndCommit(
        uint256 _roundId,
        uint256 _quantity,
        bytes32 _commitHash
    ) 
        external 
        payable 
        nonReentrant 
        whenNotPaused 
        roundExists(_roundId) 
        roundNotCancelled(_roundId) 
        roundNotDrawn(_roundId) 
    {
        LotteryRound storage round = rounds[_roundId];
        require(block.number <= round.commitDeadline, "Commit phase ended");
        require(_quantity > 0, "Must buy at least 1 ticket");
        require(round.ticketsSold + _quantity <= round.maxTickets, "Exceeds max tickets");
        require(msg.value == round.ticketPrice * _quantity, "Incorrect payment");
        require(_commitHash != bytes32(0), "Invalid commit hash");

        // Record tickets
        if (ticketCount[_roundId][msg.sender] == 0) {
            round.participants.push(msg.sender);
        }
        ticketCount[_roundId][msg.sender] += _quantity;
        round.ticketsSold += _quantity;
        round.prizePool += msg.value;

        // Record commitment
        Commitment storage commitment = commitments[_roundId][msg.sender];
        require(!commitment.committed, "Already committed");
        commitment.commitHash = _commitHash;
        commitment.committed = true;

        emit TicketPurchased(_roundId, msg.sender, _quantity);
        emit SecretCommitted(_roundId, msg.sender);
    }

    /**
     * @dev Reveal the secret that was committed earlier.
     * @param _roundId The lottery round
     * @param _secret The original secret value
     */
    function revealSecret(uint256 _roundId, bytes32 _secret) 
        external 
        whenNotPaused 
        roundExists(_roundId) 
        roundNotCancelled(_roundId) 
        roundNotDrawn(_roundId) 
    {
        LotteryRound storage round = rounds[_roundId];
        require(block.number > round.commitDeadline, "Commit phase not ended");
        require(block.number <= round.revealDeadline, "Reveal phase ended");

        Commitment storage commitment = commitments[_roundId][msg.sender];
        require(commitment.committed, "No commitment found");
        require(!commitment.revealed, "Already revealed");

        // Verify the commitment
        bytes32 expectedHash = keccak256(abi.encodePacked(_secret, msg.sender));
        require(expectedHash == commitment.commitHash, "Invalid secret");

        commitment.revealedSecret = _secret;
        commitment.revealed = true;
        revealedParticipants[_roundId].push(msg.sender);

        // Accumulate entropy from each reveal
        accumulatedEntropy[_roundId] = keccak256(
            abi.encodePacked(accumulatedEntropy[_roundId], _secret, msg.sender, block.number)
        );

        emit SecretRevealed(_roundId, msg.sender);
    }

    /**
     * @dev Claim refund for a cancelled round.
     */
    function claimRefund(uint256 _roundId) 
        external 
        nonReentrant 
        roundExists(_roundId) 
    {
        require(rounds[_roundId].cancelled, "Round not cancelled");
        uint256 tickets = ticketCount[_roundId][msg.sender];
        require(tickets > 0, "No tickets to refund");

        uint256 refundAmount = tickets * rounds[_roundId].ticketPrice;
        ticketCount[_roundId][msg.sender] = 0;
        rounds[_roundId].prizePool -= refundAmount;

        (bool success, ) = payable(msg.sender).call{value: refundAmount}("");
        require(success, "Refund transfer failed");

        emit RefundClaimed(_roundId, msg.sender, refundAmount);
    }

    // ============ Draw Functions ============

    /**
     * @dev Draw the winner(s) using accumulated entropy from commit-reveal + block data.
     * Can only be called after the draw block to ensure blockhash is from a future block
     * that couldn't be predicted during the reveal phase.
     */
    function drawWinner(uint256 _roundId) 
        external 
        nonReentrant 
        whenNotPaused 
        roundExists(_roundId) 
        roundNotCancelled(_roundId) 
        roundNotDrawn(_roundId) 
    {
        LotteryRound storage round = rounds[_roundId];
        require(block.number >= round.drawBlock, "Too early to draw");
        require(block.number < round.drawBlock + 256, "Draw window expired, use emergencyDraw");
        require(round.ticketsSold > 0, "No tickets sold");
        require(revealedParticipants[_roundId].length > 0, "No reveals, consider cancelling");

        round.drawn = true;

        // Combine multiple entropy sources for secure randomness:
        // 1. Accumulated entropy from all player reveals (commit-reveal scheme)
        // 2. Blockhash of a future block (unknown during reveal phase)
        // 3. Block timestamp and difficulty for additional entropy
        bytes32 futureBlockHash = blockhash(round.drawBlock);
        require(futureBlockHash != bytes32(0), "Blockhash not available");

        bytes32 seed = keccak256(
            abi.encodePacked(
                accumulatedEntropy[_roundId],
                futureBlockHash,
                block.timestamp,
                block.prevrandao, // replaces block.difficulty post-merge
                round.ticketsSold,
                round.participants.length
            )
        );

        // Calculate platform fee
        uint256 feeAmount = (round.prizePool * round.platformFee) / 10000;
        uint256 distributablePool = round.prizePool - feeAmount;

        RewardTier[] storage tiers = rewardTiers[_roundId];

        if (tiers.length == 0) {
            // Single winner mode
            address winner = _selectWeightedWinner(_roundId, seed);
            round.winner = winner;

            (bool success, ) = payable(winner).call{value: distributablePool}("");
            require(success, "Prize transfer failed");

            emit WinnerDrawn(_roundId, winner, distributablePool);
        } else {
            // Multi-tier reward mode
            _distributeMultiTierRewards(_roundId, seed, distributablePool, tiers);
        }

        // Transfer platform fee to owner
        if (feeAmount > 0) {
            (bool feeSuccess, ) = payable(owner()).call{value: feeAmount}("");
            require(feeSuccess, "Fee transfer failed");
            emit PlatformFeeWithdrawn(feeAmount);
        }
    }

    /**
     * @dev Emergency draw if the normal draw window (256 blocks) was missed.
     * Uses only accumulated entropy from reveals (still secure due to commit-reveal).
     */
    function emergencyDraw(uint256 _roundId) 
        external 
        onlyOwner 
        nonReentrant 
        roundExists(_roundId) 
        roundNotCancelled(_roundId) 
        roundNotDrawn(_roundId) 
    {
        LotteryRound storage round = rounds[_roundId];
        require(block.number >= round.drawBlock + 256, "Use normal draw first");
        require(round.ticketsSold > 0, "No tickets sold");
        require(revealedParticipants[_roundId].length > 0, "No reveals, cancel instead");

        round.drawn = true;

        // Use accumulated entropy + current block data as fallback
        bytes32 seed = keccak256(
            abi.encodePacked(
                accumulatedEntropy[_roundId],
                blockhash(block.number - 1),
                block.timestamp,
                block.prevrandao
            )
        );

        uint256 feeAmount = (round.prizePool * round.platformFee) / 10000;
        uint256 distributablePool = round.prizePool - feeAmount;

        address winner = _selectWeightedWinner(_roundId, seed);
        round.winner = winner;

        (bool success, ) = payable(winner).call{value: distributablePool}("");
        require(success, "Prize transfer failed");

        emit WinnerDrawn(_roundId, winner, distributablePool);

        if (feeAmount > 0) {
            (bool feeSuccess, ) = payable(owner()).call{value: feeAmount}("");
            require(feeSuccess, "Fee transfer failed");
        }
    }

    // ============ Internal Functions ============

    /**
     * @dev Select a winner weighted by ticket count.
     * More tickets = higher chance of winning.
     */
    function _selectWeightedWinner(uint256 _roundId, bytes32 _seed) 
        internal 
        view 
        returns (address) 
    {
        LotteryRound storage round = rounds[_roundId];
        uint256 totalTickets = round.ticketsSold;
        uint256 winningTicket = uint256(_seed) % totalTickets;

        uint256 cumulativeTickets = 0;
        for (uint256 i = 0; i < round.participants.length; i++) {
            address participant = round.participants[i];
            cumulativeTickets += ticketCount[_roundId][participant];
            if (winningTicket < cumulativeTickets) {
                return participant;
            }
        }

        // Fallback (should never reach here)
        return round.participants[round.participants.length - 1];
    }

    /**
     * @dev Distribute rewards across multiple tiers, ensuring no duplicate winners per tier.
     */
    function _distributeMultiTierRewards(
        uint256 _roundId,
        bytes32 _seed,
        uint256 _distributablePool,
        RewardTier[] storage _tiers
    ) internal {
        LotteryRound storage round = rounds[_roundId];

        for (uint256 i = 0; i < _tiers.length; i++) {
            // Derive a unique seed for each tier
            bytes32 tierSeed = keccak256(abi.encodePacked(_seed, i, "TIER"));
            
            address winner = _selectWeightedWinner(_roundId, tierSeed);
            tierWinners[_roundId][i] = winner;

            uint256 tierPrize = (_distributablePool * _tiers[i].percentage) / 10000;

            if (tierPrize > 0) {
                (bool success, ) = payable(winner).call{value: tierPrize}("");
                require(success, "Tier prize transfer failed");
            }

            emit TierWinnerDrawn(_roundId, i, winner, tierPrize);
        }

        // If there's any remainder due to rounding, send to first tier winner
        uint256 totalDistributed = 0;
        for (uint256 i = 0; i < _tiers.length; i++) {
            totalDistributed += (_distributablePool * _tiers[i].percentage) / 10000;
        }
        uint256 remainder = _distributablePool - totalDistributed;
        if (remainder > 0 && tierWinners[_roundId][0] != address(0)) {
            (bool success, ) = payable(tierWinners[_roundId][0]).call{value: remainder}("");
            require(success, "Remainder transfer failed");
        }
    }

    // ============ View Functions ============

    function getRoundInfo(uint256 _roundId) external view returns (
        uint256 ticketPrice,
        uint256 maxTickets,
        uint256 ticketsSold,
        uint256 prizePool,
        uint256 commitDeadline,
        uint256 revealDeadline,
        uint256 drawBlock,
        address winner,
        bool drawn,
        bool cancelled,
        uint256 participantCount,
        uint256 revealCount
    ) {
        LotteryRound storage round = rounds[_roundId];
        return (
            round.ticketPrice,
            round.maxTickets,
            round.ticketsSold,
            round.prizePool,
            round.commitDeadline,
            round.revealDeadline,
            round.drawBlock,
            round.winner,
            round.drawn,
            round.cancelled,
            round.participants.length,
            revealedParticipants[_roundId].length
        );
    }

    function getParticipants(uint256 _roundId) external view returns (address[] memory) {
        return rounds[_roundId].participants;
    }

    function getPlayerTickets(uint256 _roundId, address _player) external view returns (uint256) {
        return ticketCount[_roundId][_player];
    }

    function getRewardTiers(uint256 _roundId) external view returns (
        uint256[] memory percentages,
        string[] memory rewardTypes
    ) {
        RewardTier[] storage tiers = rewardTiers[_roundId];
        percentages = new uint256[](tiers.length);
        rewardTypes = new string[](tiers.length);
        for (uint256 i = 0; i < tiers.length; i++) {
            percentages[i] = tiers[i].percentage;
            rewardTypes[i] = tiers[i].rewardType;
        }
    }

    function getTierWinner(uint256 _roundId, uint256 _tierIndex) external view returns (address) {
        return tierWinners[_roundId][_tierIndex];
    }

    function getCurrentPhase(uint256 _roundId) external view returns (string memory) {
        LotteryRound storage round = rounds[_roundId];
        if (round.cancelled) return "CANCELLED";
        if (round.drawn) return "COMPLETED";
        if (block.number <= round.commitDeadline) return "COMMIT";
        if (block.number <= round.revealDeadline) return "REVEAL";
        if (block.number < round.drawBlock) return "WAITING_FOR_DRAW";
        return "READY_TO_DRAW";
    }

    /**
     * @dev Generate a commit hash off-chain helper (for reference).
     * Players should call this view function to generate their commit hash.
     */
    function generateCommitHash(bytes32 _secret, address _player) external pure returns (bytes32) {
        return keccak256(abi.encodePacked(_secret, _player));
    }

