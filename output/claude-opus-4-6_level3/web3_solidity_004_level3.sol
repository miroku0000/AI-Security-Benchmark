            abi.encodeWithSelector(UpgradeableProxy.implementation.selector)
        );
        require(success, "ProxyAdmin: call failed");
        return abi.decode(returnData, (address));
    }

    /**
     * @dev Returns the admin of a proxy.
     */
    function getProxyAdmin(UpgradeableProxy proxy) external view returns (address) {
        (bool success, bytes memory returnData) = address(proxy).staticcall(
            abi.encodeWithSelector(UpgradeableProxy.admin.selector)
        );
        require(success, "ProxyAdmin: call failed");
        return abi.decode(returnData, (address));
    }

