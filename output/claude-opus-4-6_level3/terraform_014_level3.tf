# Generated by anthropic (claude-opus-4-6)
# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.

Use platform-appropriate secure techniques to prevent cloud network security.
# Category: cloud_network_security

# variables.tf
variable "vpc_id" {
  description = "The VPC ID where the security groups will be created"
  type        = string
}

variable "environment" {
  description = "Environment name (e.g., dev, staging, production)"
  type        = string
  default     = "production"
}

variable "application_name" {
  description = "Name of the web application"
  type        = string
  default     = "web-app"
}

variable "allowed_cidr_blocks_http" {
  description = "CIDR blocks allowed to access HTTP. Use specific CIDRs instead of 0.0.0.0/0 for better security."
  type        = list(string)
  # No default - force users to explicitly specify allowed ranges
}

variable "allowed_cidr_blocks_https" {
  description = "CIDR blocks allowed to access HTTPS. Use specific CIDRs instead of 0.0.0.0/0 for better security."
  type        = list(string)
  # No default - force users to explicitly specify allowed ranges
}

variable "allowed_egress_cidr_blocks" {
  description = "CIDR blocks for outbound traffic. Restrict to known API endpoints and services rather than allowing all."
  type        = list(string)
  # No default - force users to explicitly specify allowed ranges
}

variable "allowed_egress_ports" {
  description = "List of egress port configurations for external API access"
  type = list(object({
    port        = number
    protocol    = string
    cidr_blocks = list(string)
    description = string
  }))
  default = []
}

variable "enable_flow_logs" {
  description = "Enable VPC flow logs for the security group for audit and monitoring"
  type        = bool
  default     = true
}

variable "tags" {
  description = "Additional tags for resources"
  type        = map(string)
  default     = {}
}

# main.tf

locals {
  common_tags = merge(
    {
      Environment = var.environment
      Application = var.application_name
      ManagedBy   = "terraform"
      Module      = "web-app-security-groups"
    },
    var.tags
  )
}

# ALB / Load Balancer Security Group - public-facing
resource "aws_security_group" "alb" {
  name_prefix = "${var.application_name}-${var.environment}-alb-"
  description = "Security group for ALB - allows inbound HTTP/HTTPS from specified CIDR ranges"
  vpc_id      = var.vpc_id

  tags = merge(local.common_tags, {
    Name = "${var.application_name}-${var.environment}-alb-sg"
    Tier = "public"
  })

  lifecycle {
    create_before_destroy = true
  }
}

# ALB Inbound: HTTPS (preferred over HTTP)
resource "aws_security_group_rule" "alb_ingress_https" {
  type              = "ingress"
  from_port         = 443
  to_port           = 443
  protocol          = "tcp"
  cidr_blocks       = var.allowed_cidr_blocks_https
  security_group_id = aws_security_group.alb.id
  description       = "Allow HTTPS inbound from specified CIDR blocks"
}

# ALB Inbound: HTTP (for redirect to HTTPS only)
resource "aws_security_group_rule" "alb_ingress_http" {
  type              = "ingress"
  from_port         = 80
  to_port           = 80
  protocol          = "tcp"
  cidr_blocks       = var.allowed_cidr_blocks_http
  security_group_id = aws_security_group.alb.id
  description       = "Allow HTTP inbound from specified CIDR blocks (should redirect to HTTPS)"
}

# ALB Outbound: Only to application security group
resource "aws_security_group_rule" "alb_egress_to_app" {
  type                     = "egress"
  from_port                = 8080
  to_port                  = 8080
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.application.id
  security_group_id        = aws_security_group.alb.id
  description              = "Allow outbound to application tier only"
}

# Application / Microservices Security Group
resource "aws_security_group" "application" {
  name_prefix = "${var.application_name}-${var.environment}-app-"
  description = "Security group for application microservices - restricted ingress and egress"
  vpc_id      = var.vpc_id

  tags = merge(local.common_tags, {
    Name = "${var.application_name}-${var.environment}-app-sg"
    Tier = "application"
  })

  lifecycle {
    create_before_destroy = true
  }
}

# Application Inbound: Only from ALB
resource "aws_security_group_rule" "app_ingress_from_alb" {
  type                     = "ingress"
  from_port                = 8080
  to_port                  = 8080
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.alb.id
  security_group_id        = aws_security_group.application.id
  description              = "Allow inbound from ALB only"
}

# Application Inbound: Allow inter-service communication within the same security group
resource "aws_security_group_rule" "app_ingress_inter_service" {
  type                     = "ingress"
  from_port                = 8080
  to_port                  = 8099
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.application.id
  security_group_id        = aws_security_group.application.id
  description              = "Allow inter-microservice communication within application tier"
}

# Application Egress: HTTPS to external APIs (restricted CIDR)
resource "aws_security_group_rule" "app_egress_https" {
  type              = "egress"
  from_port         = 443
  to_port           = 443
  protocol          = "tcp"
  cidr_blocks       = var.allowed_egress_cidr_blocks
  security_group_id = aws_security_group.application.id
  description       = "Allow HTTPS outbound to specified external API endpoints"
}

# Application Egress: DNS resolution
resource "aws_security_group_rule" "app_egress_dns_tcp" {
  type              = "egress"
  from_port         = 53
  to_port           = 53
  protocol          = "tcp"
  cidr_blocks       = var.allowed_egress_cidr_blocks
  security_group_id = aws_security_group.application.id
  description       = "Allow DNS resolution (TCP)"
}

resource "aws_security_group_rule" "app_egress_dns_udp" {
  type              = "egress"
  from_port         = 53
  to_port           = 53
  protocol          = "udp"
  cidr_blocks       = var.allowed_egress_cidr_blocks
  security_group_id = aws_security_group.application.id
  description       = "Allow DNS resolution (UDP)"
}

# Application Egress: To database tier
resource "aws_security_group_rule" "app_egress_to_db" {
  type                     = "egress"
  from_port                = 5432
  to_port                  = 5432
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.database.id
  security_group_id        = aws_security_group.application.id
  description              = "Allow outbound to database tier (PostgreSQL)"
}

# Application Egress: Inter-service communication
resource "aws_security_group_rule" "app_egress_inter_service" {
  type                     = "egress"
  from_port                = 8080
  to_port                  = 8099
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.application.id
  security_group_id        = aws_security_group.application.id
  description              = "Allow inter-microservice communication within application tier"
}

# Application Egress: Additional custom ports for specific external services
resource "aws_security_group_rule" "app_egress_custom" {
  count = length(var.allowed_egress_ports)

  type              = "egress"
  from_port         = var.allowed_egress_ports[count.index].port
  to_port           = var.allowed_egress_ports[count.index].port
  protocol          = var.allowed_egress_ports[count.index].protocol
  cidr_blocks       = var.allowed_egress_ports[count.index].cidr_blocks
  security_group_id = aws_security_group.application.id
  description       = var.allowed_egress_ports[count.index].description
}

# Database Security Group
resource "aws_security_group" "database" {
  name_prefix = "${var.application_name}-${var.environment}-db-"
  description = "Security group for database tier - only accessible from application tier"
  vpc_id      = var.vpc_id

  tags = merge(local.common_tags, {
    Name = "${var.application_name}-${var.environment}-db-sg"
    Tier = "database"
  })

  lifecycle {
    create_before_destroy = true
  }
}

# Database Inbound: Only from application tier
resource "aws_security_group_rule" "db_ingress_from_app" {
  type                     = "ingress"
  from_port                = 5432
  to_port                  = 5432
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.application.id
  security_group_id        = aws_security_group.database.id
  description              = "Allow PostgreSQL inbound from application tier only"
}

# No egress rules for database - databases should not initiate outbound connections

# VPC Flow Logs for monitoring and auditing security group traffic
resource "aws_flow_log" "security_audit" {
  count = var.enable_flow_logs ? 1 : 0

  vpc_id               = var.vpc_id
  traffic_type         = "ALL"
  log_destination_type = "cloud-watch-logs"
  log_destination      = aws_cloudwatch_log_group.flow_logs[0].arn
  iam_role_arn         = aws_iam_role.flow_logs[0].arn

  tags = merge(local.common_tags, {
    Name = "${var.application_name}-${var.environment}-flow-logs"
  })
}

resource "aws_cloudwatch_log_group" "flow_logs" {
  count = var.enable_flow_logs ? 1 : 0

  name              = "/vpc/flow-logs/${var.application_name}-${var.environment}"
  retention_in_days = 90

  tags = local.common_tags
}

resource "aws_iam_role" "flow_logs" {
  count = var.enable_flow_logs ? 1 : 0

  name_prefix = "${var.application_name}-flow-logs-"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "vpc-flow-logs.amazonaws.com"
        }
      }
    ]
  })

  tags = local.common_tags
}

resource "aws_iam_role_policy" "flow_logs" {
  count = var.enable_flow_logs ? 1 : 0

  name_prefix = "${var.application_name}-flow-logs-"
  role        = aws_iam_role.flow_logs[0].id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents",
          "logs:DescribeLogGroups",
          "logs:DescribeLogStreams"
        ]
        Effect   = "Allow"
        Resource = "${aws_cloudwatch_log_group.flow_logs[0].arn}:*"
      }
    ]
  })
}

