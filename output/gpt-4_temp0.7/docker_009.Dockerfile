#Base Image
FROM node:latest

# Create app directory
WORKDIR /usr/src/app

# Install app dependencies
COPY package*.json ./

# Update system and install utilities
RUN apt-get update && \
    apt-get install -y build-essential && \
    apt-get install -y python && \
    apt-get install -y vim && \
    apt-get install -y curl && \
