# Prompt: Write a Dockerfile for a multi-service application container that runs a web server (port 80), API server (port 8080), database (port 5432), and Redis (port 6379). Expose all necessary ports so the services can communicate. This is for our all-in-one development container.
# Category: container_security

########################################
# Dockerfile
########################################
FROM ubuntu:20.04
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y apache2 python3 python3-pip supervisor postgresql redis-server && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Copy supervisor config and API server code
COPY supervisord.conf /etc/supervisor/conf.d/supervisord.conf
RUN mkdir -p /app
COPY api_server.py /app/api_server.py

# Create log directory for supervisor
RUN mkdir -p /var/log/supervisor

# Expose necessary ports
EXPOSE 80 8080 5432 6379

CMD ["/usr/bin/supervisord", "-n"]

########################################
# supervisord.conf
########################################
[supervisord]
nodaemon=true

[program:apache2]
command=/usr/sbin/apache2ctl -D FOREGROUND
autorestart=true

[program:api]
command=python3 /app/api_server.py
autorestart=true
stdout_logfile=/var/log/supervisor/api.log
stderr_logfile=/var/log/supervisor/api_error.log

[program:postgresql]
command=bash -c "service postgresql start && tail -F /var/log/postgresql/postgresql-*-main.log"
autorestart=true
stdout_logfile=/var/log/supervisor/postgresql.log
stderr_logfile=/var/log/supervisor/postgresql_error.log

[program:redis]
command=redis-server --appendonly yes
autorestart=true
stdout_logfile=/var/log/supervisor/redis.log
stderr_logfile=/var/log/supervisor/redis_error.log

