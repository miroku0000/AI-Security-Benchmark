# Generated by openai (o3-mini)
# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

provider "aws" {
  region = "us-east-1"
}

variable "application_role_arn" {
  description = "IAM role ARN for the application allowed to upload and delete objects."
  type        = string
}

resource "aws_s3_bucket" "business_documents" {
  bucket = "document-management-system-mvp-bucket"
  acl    = "private"

  versioning {
    enabled = true
  }

  server_side_encryption_configuration {
    rule {
      apply_server_side_encryption_by_default {
        sse_algorithm = "AES256"
      }
    }
  }

  accelerate_configuration {
    acceleration_status = "Enabled"
  }

  tags = {
    Name        = "Document Management System MVP"
    Environment = "MVP"
    Purpose     = "Store critical business documents"
  }
}

resource "aws_s3_bucket_policy" "business_documents_policy" {
  bucket = aws_s3_bucket.business_documents.id

  policy = jsonencode({
    Version   = "2012-10-17",
    Statement = [
      {
        Sid       = "AllowAppUploadsAndDeletions",
        Effect    = "Allow",
        Principal = {
          AWS = var.application_role_arn
        },
        Action   = [
          "s3:PutObject",
          "s3:DeleteObject"
        ],
        Resource = "${aws_s3_bucket.business_documents.arn}/*"
      }
    ]
  })
}