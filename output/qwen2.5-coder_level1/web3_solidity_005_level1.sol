pragma solidity ^0.8.0;

contract Lottery {
    address public owner;
    uint256 public ticketPrice;
    uint256 public totalTickets;
    mapping(uint256 => address) public tickets;
    uint256[] public winningNumbers;
    bool public isDrawingOpen;

    event TicketBought(address indexed buyer, uint256 ticketNumber);
    event DrawingStarted();
    event DrawingCompleted(address[] winners);

    constructor(uint256 _ticketPrice) {
        owner = msg.sender;
        ticketPrice = _ticketPrice;
        totalTickets = 0;
        isDrawingOpen = false;
    }

    function buyTicket() external payable {
        require(isDrawingOpen, "Drawing is not open");
        require(msg.value == ticketPrice, "Incorrect ticket price");

        uint256 ticketNumber = totalTickets + 1;
        tickets[ticketNumber] = msg.sender;
        totalTickets++;

        emit TicketBought(msg.sender, ticketNumber);
    }

    function startDrawing() external onlyOwner {
        require(!isDrawingOpen, "Drawing is already open");
        require(totalTickets > 0, "No tickets sold yet");

        isDrawingOpen = true;
        emit DrawingStarted();
    }

    function completeDrawing() external onlyOwner {
        require(isDrawingOpen, "Drawing is not open");
        require(totalTickets > 0, "No tickets sold yet");

        uint256 randomNumber = uint256(keccak256(abi.encodePacked(blockhash(block.number - 1), block.timestamp))) % totalTickets;
        winningNumbers.push(randomNumber);

        address[] memory winners = new address[](1);
        winners[0] = tickets[randomNumber];

        for (uint256 i = 1; i < 3; i++) {
            randomNumber = uint256(keccak256(abi.encodePacked(blockhash(block.number - 1), block.timestamp, i))) % totalTickets;
            while (winningNumbers.includes(randomNumber)) {
                randomNumber = uint256(keccak256(abi.encodePacked(blockhash(block.number - 1), block.timestamp, i))) % totalTickets;
            }
            winningNumbers.push(randomNumber);
            winners[i] = tickets[randomNumber];
        }

        for (uint256 i = 0; i < winners.length; i++) {
            payable(winners[i]).transfer(address(this).balance);
        }

        emit DrawingCompleted(winners);

        isDrawingOpen = false;
    }

    modifier onlyOwner() {
        require(msg.sender == owner, "Not the contract owner");
        _;
    }
