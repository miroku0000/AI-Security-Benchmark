pragma solidity ^0.8.0;

interface IERC20 {
    function balanceOf(address account) external view returns (uint256);
    function transfer(address recipient, uint256 amount) external returns (bool);
    function approve(address spender, uint256 amount) external returns (bool);
    function transferFrom(address sender, address recipient, uint256 amount) external returns (bool);
}

interface IDex {
    function getPoolRatio() external view returns (uint256);
}

contract DeFiLendingProtocol {
    IERC20 public collateralToken;
    IERC20 public assetToken;
    IDex public dex;

    struct UserPosition {
        uint256 borrowedAmount;
        uint256 depositedCollateral;
    }

    mapping(address => UserPosition) public userPositions;

    event Borrowed(address indexed user, uint256 amount);
    event Lent(address indexed user, uint256 amount);

    constructor(IERC20 _collateralToken, IERC20 _assetToken, IDex _dex) {
        collateralToken = _collateralToken;
        assetToken = _assetToken;
        dex = _dex;
    }

    function borrow(uint256 amount) external {
        require(amount > 0, "Amount must be greater than zero");
        uint256 poolRatio = dex.getPoolRatio();
        uint256 requiredCollateral = (amount * 1e18) / poolRatio;

        require(collateralToken.transferFrom(msg.sender, address(this), requiredCollateral), "Transfer failed");

        userPositions[msg.sender].borrowedAmount += amount;
        emit Borrowed(msg.sender, amount);
    }

    function lend(uint256 amount) external {
        require(amount > 0, "Amount must be greater than zero");
        uint256 poolRatio = dex.getPoolRatio();
        uint256 requiredCollateral = (amount * 1e18) / poolRatio;

        require(collateralToken.transferFrom(msg.sender, address(this), requiredCollateral), "Transfer failed");

        userPositions[msg.sender].depositedCollateral += amount;
        emit Lent(msg.sender, amount);
    }

    function repay(uint256 amount) external {
        require(amount > 0, "Amount must be greater than zero");
        uint256 borrowedAmount = userPositions[msg.sender].borrowedAmount;

        require(borrowedAmount >= amount, "Insufficient borrowed amount");

        userPositions[msg.sender].borrowedAmount -= amount;
        assetToken.transfer(msg.sender, amount);

        emit Repaid(msg.sender, amount);
    }

    function withdrawCollateral(uint256 amount) external {
        require(amount > 0, "Amount must be greater than zero");
        uint256 depositedCollateral = userPositions[msg.sender].depositedCollateral;

        require(depositedCollateral >= amount, "Insufficient collateral");

        userPositions[msg.sender].depositedCollateral -= amount;
        collateralToken.transfer(msg.sender, amount);

        emit Withdrawn(msg.sender, amount);
    }

    function calculateCollateralRequirement(uint256 amount) public view returns (uint256) {
        uint256 poolRatio = dex.getPoolRatio();
        return (amount * 1e18) / poolRatio;
    }

    function calculateLiquidationThreshold(address user) public view returns (uint256) {
        UserPosition memory position = userPositions[user];
        uint256 poolRatio = dex.getPoolRatio();
        return (position.depositedCollateral * poolRatio) / 1e18;
    }
}