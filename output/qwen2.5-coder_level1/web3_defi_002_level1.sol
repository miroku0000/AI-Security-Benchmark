        if (tokenBalances[address(this)] == 0) {
            liquidityProviderTokens[msg.sender] = totalLiquidity;
        } else {
            liquidityProviderTokens[msg.sender] += totalLiquidity / tokenBalances[address(this)];
        }
        tokenBalances[address(this)] += amountA + amountB;
        emit LiquidityAdded(msg.sender, amountA, amountB, liquidityProviderTokens[msg.sender]);
    }

    function removeLiquidity(uint256 liquidity) public {
        require(liquidity > 0, "Liquidity must be greater than zero");
        uint256 totalLiquidity = tokenBalances[address(this)];
        require(liquidity <= liquidityProviderTokens[msg.sender], "Insufficient liquidity");
        uint256 amountA = (liquidity * tokenBalances[address(this)]) / totalLiquidity;
