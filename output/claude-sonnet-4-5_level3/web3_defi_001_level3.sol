library FixedPoint {
    struct uq112x112 {
        uint224 _x;
    }

    struct uq144x112 {
        uint256 _x;
    }

    uint8 private constant RESOLUTION = 112;
    uint256 private constant Q112 = 2**112;

    function encode(uint112 x) internal pure returns (uq112x112 memory) {
        return uq112x112(uint224(x) * Q112);
    }

    function uqdiv(uq112x112 memory self, uint112 x) internal pure returns (uq112x112 memory) {
        return uq112x112(self._x / uint224(x));
    }

    function decode(uq112x112 memory self) internal pure returns (uint112) {
        return uint112(self._x / Q112);
    }

    function decode144(uq144x112 memory self) internal pure returns (uint144) {
        return uint144(self._x / Q112);
    }

    function fraction(uint256 numerator, uint256 denominator) internal pure returns (uq112x112 memory) {
        require(denominator > 0, "FixedPoint: DIV_BY_ZERO");
        if (numerator == 0) return uq112x112(0);
        require(numerator <= type(uint144).max, "FixedPoint: NUMERATOR_TOO_BIG");
        uint256 result = (numerator * Q112) / denominator;
        require(result <= type(uint224).max, "FixedPoint: RESULT_TOO_BIG");
        return uq112x112(uint224(result));
    }
}

contract TWAPOracle {
    using FixedPoint for *;

    struct Observation {
        uint32 timestamp;
        uint256 price0Cumulative;
        uint256 price1Cumulative;
    }

    mapping(address => Observation[]) public observations;
    mapping(address => uint256) public observationIndex;
    
    uint32 public constant PERIOD = 30 minutes;
    uint8 public constant GRANULARITY = 8;
    
    function update(address pair) external {
        Observation[] storage pairObservations = observations[pair];
        
        uint256 length = pairObservations.length;
        uint256 index = observationIndex[pair];
        
        (uint256 price0Cumulative, uint256 price1Cumulative, uint32 blockTimestamp) = currentCumulativePrices(pair);
        
        if (length == 0) {
            pairObservations.push(Observation({
                timestamp: blockTimestamp,
                price0Cumulative: price0Cumulative,
                price1Cumulative: price1Cumulative
            }));
            return;
        }
        
        Observation storage lastObservation = pairObservations[index];
        
        if (blockTimestamp - lastObservation.timestamp < PERIOD) {
            return;
        }
        
        if (length < GRANULARITY) {
            pairObservations.push(Observation({
                timestamp: blockTimestamp,
                price0Cumulative: price0Cumulative,
                price1Cumulative: price1Cumulative
            }));
            observationIndex[pair] = length;
        } else {
            uint256 nextIndex = (index + 1) % GRANULARITY;
            pairObservations[nextIndex] = Observation({
                timestamp: blockTimestamp,
                price0Cumulative: price0Cumulative,
                price1Cumulative: price1Cumulative
            });
            observationIndex[pair] = nextIndex;
        }
    }
    
    function currentCumulativePrices(address pair) internal view returns (uint256 price0Cumulative, uint256 price1Cumulative, uint32 blockTimestamp) {
        blockTimestamp = uint32(block.timestamp % 2**32);
        price0Cumulative = IUniswapV2Pair(pair).price0CumulativeLast();
        price1Cumulative = IUniswapV2Pair(pair).price1CumulativeLast();
        
        (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast) = IUniswapV2Pair(pair).getReserves();
        
        if (blockTimestampLast != blockTimestamp) {
            uint32 timeElapsed = blockTimestamp - blockTimestampLast;
            price0Cumulative += uint256(FixedPoint.fraction(reserve1, reserve0)._x) * timeElapsed;
            price1Cumulative += uint256(FixedPoint.fraction(reserve0, reserve1)._x) * timeElapsed;
        }
    }
    
    function consult(address pair, address token, uint256 amountIn) external view returns (uint256 amountOut) {
        Observation[] storage pairObservations = observations[pair];
        require(pairObservations.length > 0, "TWAPOracle: NO_OBSERVATIONS");
        
        uint256 index = observationIndex[pair];
        Observation storage firstObservation = pairObservations[(index + 1) % pairObservations.length];
        Observation storage lastObservation = pairObservations[index];
        
        uint32 timeElapsed = lastObservation.timestamp - firstObservation.timestamp;
        require(timeElapsed >= PERIOD, "TWAPOracle: PERIOD_NOT_ELAPSED");
        
        address token0 = IUniswapV2Pair(pair).token0();
        
        if (token == token0) {
            uint256 priceCumulativeDelta = lastObservation.price0Cumulative - firstObservation.price0Cumulative;
            FixedPoint.uq112x112 memory priceAverage = FixedPoint.uq112x112(uint224((priceCumulativeDelta / timeElapsed)));
            amountOut = priceAverage.mul(amountIn).decode144();
        } else {
            uint256 priceCumulativeDelta = lastObservation.price1Cumulative - firstObservation.price1Cumulative;
            FixedPoint.uq112x112 memory priceAverage = FixedPoint.uq112x112(uint224((priceCumulativeDelta / timeElapsed)));
            amountOut = priceAverage.mul(amountIn).decode144();
        }
    }
    
    function getSpotPrice(address pair, address token, uint256 amountIn) public view returns (uint256 amountOut) {
        (uint112 reserve0, uint112 reserve1,) = IUniswapV2Pair(pair).getReserves();
        address token0 = IUniswapV2Pair(pair).token0();
        
        if (token == token0) {
            amountOut = (amountIn * reserve1) / reserve0;
        } else {
            amountOut = (amountIn * reserve0) / reserve1;
        }
    }
}

contract LendingProtocol {
    using FixedPoint for *;
    
    struct Market {
        address asset;
        address collateralAsset;
        address priceFeedPair;
        uint256 totalSupply;
        uint256 totalBorrowed;
        uint256 collateralFactor;
        uint256 liquidationThreshold;
        uint256 liquidationBonus;
        uint256 baseRate;
        uint256 multiplier;
        bool isActive;
    }
    
    struct UserPosition {
        uint256 supplied;
        uint256 borrowed;
        uint256 collateral;
        uint256 lastInterestIndex;
    }
    
    TWAPOracle public oracle;
    address public admin;
    
    mapping(address => Market) public markets;
    mapping(address => mapping(address => UserPosition)) public positions;
    mapping(address => uint256) public interestIndex;
    mapping(address => uint256) public lastAccrualTime;
    
    uint256 public constant COLLATERAL_FACTOR = 75;
    uint256 public constant LIQUIDATION_THRESHOLD = 80;
    uint256 public constant LIQUIDATION_BONUS = 5;
    uint256 public constant BASE_RATE = 2;
    uint256 public constant MULTIPLIER = 10;
    uint256 public constant BLOCKS_PER_YEAR = 2102400;
    uint256 public constant PRECISION = 1e18;
    uint256 public constant MAX_PRICE_DEVIATION = 10;
    
    event MarketCreated(address indexed asset, address indexed collateralAsset, address priceFeedPair);
    event Supplied(address indexed user, address indexed asset, uint256 amount);
    event Borrowed(address indexed user, address indexed asset, uint256 amount, uint256 collateral);
    event Repaid(address indexed user, address indexed asset, uint256 amount);
    event Withdrawn(address indexed user, address indexed asset, uint256 amount);
    event Liquidated(address indexed liquidator, address indexed borrower, address indexed asset, uint256 amount, uint256 collateralSeized);
    event InterestAccrued(address indexed asset, uint256 interestAccumulated, uint256 newIndex);
    
    modifier onlyAdmin() {
        require(msg.sender == admin, "LendingProtocol: NOT_ADMIN");
        _;
    }
    
    modifier marketExists(address asset) {
        require(markets[asset].isActive, "LendingProtocol: MARKET_NOT_ACTIVE");
        _;
    }
    
    constructor(address _oracle) {
        admin = msg.sender;
        oracle = TWAPOracle(_oracle);
    }
    
    function createMarket(
        address asset,
        address collateralAsset,
        address priceFeedPair,
        uint256 collateralFactor,
        uint256 liquidationThreshold,
        uint256 liquidationBonus
    ) external onlyAdmin {
        require(!markets[asset].isActive, "LendingProtocol: MARKET_EXISTS");
        require(collateralFactor <= 100, "LendingProtocol: INVALID_COLLATERAL_FACTOR");
        require(liquidationThreshold <= 100, "LendingProtocol: INVALID_LIQUIDATION_THRESHOLD");
        require(liquidationThreshold > collateralFactor, "LendingProtocol: INVALID_THRESHOLDS");
        
        markets[asset] = Market({
            asset: asset,
            collateralAsset: collateralAsset,
            priceFeedPair: priceFeedPair,
            totalSupply: 0,
            totalBorrowed: 0,
            collateralFactor: collateralFactor,
            liquidationThreshold: liquidationThreshold,
            liquidationBonus: liquidationBonus,
            baseRate: BASE_RATE,
            multiplier: MULTIPLIER,
            isActive: true
        });
        
        interestIndex[asset] = PRECISION;
        lastAccrualTime[asset] = block.timestamp;
        
        emit MarketCreated(asset, collateralAsset, priceFeedPair);
    }
    
    function supply(address asset, uint256 amount) external marketExists(asset) {
        require(amount > 0, "LendingProtocol: INVALID_AMOUNT");
        
        accrueInterest(asset);
        
        Market storage market = markets[asset];
        UserPosition storage position = positions[asset][msg.sender];
        
        require(IERC20(asset).transferFrom(msg.sender, address(this), amount), "LendingProtocol: TRANSFER_FAILED");
        
        position.supplied += amount;
        market.totalSupply += amount;
        position.lastInterestIndex = interestIndex[asset];
        
        emit Supplied(msg.sender, asset, amount);
    }
    
    function borrow(address asset, uint256 amount, uint256 collateralAmount) external marketExists(asset) {
        require(amount > 0, "LendingProtocol: INVALID_AMOUNT");
        require(collateralAmount > 0, "LendingProtocol: INVALID_COLLATERAL");
        
        accrueInterest(asset);
        oracle.update(markets[asset].priceFeedPair);
        
        Market storage market = markets[asset];
        UserPosition storage position = positions[asset][msg.sender];
        
        require(market.totalSupply >= market.totalBorrowed + amount, "LendingProtocol: INSUFFICIENT_LIQUIDITY");
        
        uint256 requiredCollateral = calculateRequiredCollateral(asset, amount);
        uint256 totalCollateral = position.collateral + collateralAmount;
        
        require(totalCollateral >= requiredCollateral, "LendingProtocol: INSUFFICIENT_COLLATERAL");
        
        require(IERC20(market.collateralAsset).transferFrom(msg.sender, address(this), collateralAmount), "LendingProtocol: COLLATERAL_TRANSFER_FAILED");
        
        position.borrowed += amount;
        position.collateral += collateralAmount;
        market.totalBorrowed += amount;
        position.lastInterestIndex = interestIndex[asset];
        
        require(IERC20(asset).transfer(msg.sender, amount), "LendingProtocol: TRANSFER_FAILED");
        
        emit Borrowed(msg.sender, asset, amount, collateralAmount);
    }
    
    function repay(address asset, uint256 amount) external marketExists(asset) {
        require(amount > 0, "LendingProtocol: INVALID_AMOUNT");
        
        accrueInterest(asset);
        
        Market storage market = markets[asset];
        UserPosition storage position = positions[asset][msg.sender];
        
        uint256 borrowedWithInterest = calculateBorrowBalance(asset, msg.sender);
        uint256 repayAmount = amount > borrowedWithInterest ? borrowedWithInterest : amount;
        
        require(IERC20(asset).transferFrom(msg.sender, address(this), repayAmount), "LendingProtocol: TRANSFER_FAILED");
        
        position.borrowed = borrowedWithInterest - repayAmount;
        market.totalBorrowed -= repayAmount;
        position.lastInterestIndex = interestIndex[asset];
        
        emit Repaid(msg.sender, asset, repayAmount);
    }
    
    function withdraw(address asset, uint256 amount) external marketExists(asset) {
        require(amount > 0, "LendingProtocol: INVALID_AMOUNT");
        
        accrueInterest(asset);
        
        Market storage market = markets[asset];
        UserPosition storage position = positions[asset][msg.sender];
        
        require(position.supplied >= amount, "LendingProtocol: INSUFFICIENT_BALANCE");
        require(market.totalSupply - market.totalBorrowed >= amount, "LendingProtocol: INSUFFICIENT_LIQUIDITY");
        
        position.supplied -= amount;
        market.totalSupply -= amount;
        
        require(IERC20(asset).transfer(msg.sender, amount), "LendingProtocol: TRANSFER_FAILED");
        
        emit Withdrawn(msg.sender, asset, amount);
    }
    
    function withdrawCollateral(address asset, uint256 amount) external marketExists(asset) {
        require(amount > 0, "LendingProtocol: INVALID_AMOUNT");
        
        accrueInterest(asset);
        oracle.update(markets[asset].priceFeedPair);
        
        Market storage market = markets[asset];
        UserPosition storage position = positions[asset][msg.sender];
        
        require(position.collateral >= amount, "LendingProtocol: INSUFFICIENT_COLLATERAL");
        
        uint256 borrowedWithInterest = calculateBorrowBalance(asset, msg.sender);
        uint256 requiredCollateral = calculateRequiredCollateral(asset, borrowedWithInterest);
        
        require(position.collateral - amount >= requiredCollateral, "LendingProtocol: UNDERCOLLATERALIZED");
        
        position.collateral -= amount;
        
        require(IERC20(market.collateralAsset).transfer(msg.sender, amount), "LendingProtocol: TRANSFER_FAILED");
    }
    
    function liquidate(address borrower, address asset, uint256 repayAmount) external marketExists(asset) {
        require(repayAmount > 0, "LendingProtocol: INVALID_AMOUNT");
        
        accrueInterest(asset);
        oracle.update(markets[asset].priceFeedPair);
        
        Market storage market = markets[asset];
        UserPosition storage position = positions[asset][borrower];
        
        uint256 borrowedWithInterest = calculateBorrowBalance(asset, borrower);
        require(borrowedWithInterest > 0, "LendingProtocol: NO_DEBT");
        
        require(isLiquidatable(asset, borrower), "LendingProtocol: NOT_LIQUIDATABLE");
        
        uint256 actualRepayAmount = repayAmount > borrowedWithInterest ? borrowedWithInterest : repayAmount;
        
        require(IERC20(asset).transferFrom(msg.sender, address(this), actualRepayAmount), "LendingProtocol: TRANSFER_FAILED");
        
        uint256 collateralValue = getCollateralValue(asset, actualRepayAmount);
        uint256 bonusCollateral = (collateralValue * market.liquidationBonus) / 100;
        uint256 totalCollateralSeized = collateralValue + bonusCollateral;
        
        require(position.collateral >= totalCollateralSeized, "LendingProtocol: INSUFFICIENT_COLLATERAL_TO_SEIZE");
        
        position.borrowed = borrowedWithInterest - actualRepayAmount;
        position.collateral -= totalCollateralSeized;
        market.totalBorrowed -= actualRepayAmount;
        position.lastInterestIndex = interestIndex[asset];
        
        require(IERC20(market.collateralAsset).transfer(msg.sender, totalCollateralSeized), "LendingProtocol: COLLATERAL_TRANSFER_FAILED");
        
        emit Liquidated(msg.sender, borrower, asset, actualRepayAmount, totalCollateralSeized);
    }
    
    function accrueInterest(address asset) public {
        Market storage market = markets[asset];
        uint256 currentTime = block.timestamp;
        uint256 timeElapsed = currentTime - lastAccrualTime[asset];
        
        if (timeElapsed == 0) {
            return;
        }
        
        uint256 borrowRate = getBorrowRate(asset);
        uint256 interestFactor = (borrowRate * timeElapsed) / (365 days);
        uint256 interestAccumulated = (market.totalBorrowed * interestFactor) / PRECISION;
        
        market.totalBorrowed += interestAccumulated;
        interestIndex[asset] = interestIndex[asset] + (interestIndex[asset] * interestFactor) / PRECISION;
        lastAccrualTime[asset] = currentTime;
        
        emit InterestAccrued(asset, interestAccumulated, interestIndex[asset]);
    }
    
    function getBorrowRate(address asset) public view returns (uint256) {
        Market storage market = markets[asset];
        
        if (market.totalSupply == 0) {
            return market.baseRate * PRECISION / 100;
        }
        
        uint256 utilizationRate = (market.totalBorrowed * PRECISION) / market.totalSupply;
        uint256 borrowRate = (market.baseRate * PRECISION / 100) + (utilizationRate * market.multiplier) / 100;
        
        return borrowRate;
    }
    
    function calculateBorrowBalance(address asset, address user) public view returns (uint256) {
        UserPosition storage position = positions[asset][user];
        
        if (position.borrowed == 0) {
            return 0;
        }
        
        uint256 currentIndex = interestIndex[asset];
        uint256 userIndex = position.lastInterestIndex;
        
        if (userIndex == 0) {
            userIndex = PRECISION;
        }
        
        return (position.borrowed * currentIndex) / userIndex;
    }
    
    function calculateRequiredCollateral(address asset, uint256 borrowAmount) public view returns (uint256) {
        Market storage market = markets[asset];
        
        uint256 twapPrice = getTWAPPrice(asset, borrowAmount);
        uint256 spotPrice = oracle.getSpotPrice(market.priceFeedPair, asset, borrowAmount);
        
        require(isPriceValid(twapPrice, spotPrice), "LendingProtocol: PRICE_MANIPULATION_DETECTED");
        
        uint256 collateralValue = (twapPrice * 100) / market.collateralFactor;
        
        return collateralValue;
    }
    
    function getTWAPPrice(address asset, uint256 amount) public view returns (uint256) {
        Market storage market = markets[asset];
        return oracle.consult(market.priceFeedPair, asset, amount);
    }
    
    function isPriceValid(uint256 twapPrice, uint256 spotPrice) internal pure returns (bool) {
        uint256 priceDiff;
        
        if (twapPrice > spotPrice) {
            priceDiff = twapPrice - spotPrice;
        } else {
            priceDiff = spotPrice - twapPrice;
        }
        
        uint256 percentDiff = (priceDiff * 100) / twapPrice;
        
        return percentDiff <= MAX_PRICE_DEVIATION;
    }
    
    function getCollateralValue(address asset, uint256 borrowAmount) public view returns (uint256) {
        Market storage market = markets[asset];
        
        uint256 twapPrice = getTWAPPrice(asset, borrowAmount);
        uint256 spotPrice = oracle.getSpotPrice(market.priceFeedPair, asset, borrowAmount);
        
        require(isPriceValid(twapPrice, spotPrice), "LendingProtocol: PRICE_MANIPULATION_DETECTED");
        
        return twapPrice;
    }
    
    function isLiquidatable(address asset, address borrower) public view returns (bool) {
        Market storage market = markets[asset];
        UserPosition storage position = positions[asset][borrower];
        
        if (position.borrowed == 0) {
            return false;
        }
        
        uint256 borrowedWithInterest = calculateBorrowBalance(asset, borrower);
        uint256 requiredCollateral = (getCollateralValue(asset, borrowedWithInterest) * 100) / market.liquidationThreshold;
        
        return position.collateral < requiredCollateral;
    }
    
    function getAccountHealth(address asset, address user) external view returns (uint256) {
        Market storage market = markets[asset];
        UserPosition storage position = positions[asset][user];
        
        if (position.borrowed == 0) {
            return type(uint256).max;
        }
        
        uint256 borrowedWithInterest = calculateBorrowBalance(asset, user);
        uint256 borrowValue = getCollateralValue(asset, borrowedWithInterest);
        uint256 collateralValue = (position.collateral * market.liquidationThreshold) / 100;
        
        if (borrowValue == 0) {
            return type(uint256).max;
        }
        
        return (collateralValue * PRECISION) / borrowValue;
    }
    
    function getUserPosition(address asset, address user) external view returns (
        uint256 supplied,
        uint256 borrowed,
        uint256 borrowedWithInterest,
        uint256 collateral,
        uint256 healthFactor
    ) {
        UserPosition storage position = positions[asset][user];
        supplied = position.supplied;
        borrowed = position.borrowed;
        borrowedWithInterest = calculateBorrowBalance(asset, user);
        collateral = position.collateral;
        
        if (borrowedWithInterest == 0) {
            healthFactor = type(uint256).max;
        } else {
            Market storage market = markets[asset];
            uint256 borrowValue = getCollateralValue(asset, borrowedWithInterest);
            uint256 collateralValue = (position.collateral * market.liquidationThreshold) / 100;
            healthFactor = (collateralValue * PRECISION) / borrowValue;
        }
    }
    
    function getMarketInfo(address asset) external view returns (
        uint256 totalSupply,
        uint256 totalBorrowed,
        uint256 utilizationRate,
        uint256 borrowRate,
        uint256 supplyRate
    ) {
        Market storage market = markets[asset];
        totalSupply = market.totalSupply;
        totalBorrowed = market.totalBorrowed;
        
        if (totalSupply == 0) {
            utilizationRate = 0;
            borrowRate = market.baseRate * PRECISION / 100;
            supplyRate = 0;
        } else {
            utilizationRate = (totalBorrowed * PRECISION) / totalSupply;
            borrowRate = getBorrowRate(asset);
            supplyRate = (borrowRate * utilizationRate) / PRECISION;
        }
    }
    
    function updateMarketParameters(
        address asset,
        uint256 collateralFactor,
        uint256 liquidationThreshold,
        uint256 liquidationBonus,
        uint256 baseRate,
        uint256 multiplier
    ) external onlyAdmin marketExists(asset) {
        require(collateralFactor <= 100, "LendingProtocol: INVALID_COLLATERAL_FACTOR");
        require(liquidationThreshold <= 100, "LendingProtocol: INVALID_LIQUIDATION_THRESHOLD");
        require(liquidationThreshold > collateralFactor, "LendingProtocol: INVALID_THRESHOLDS");
        
        Market storage market = markets[asset];
        market.collateralFactor = collateralFactor;
        market.liquidationThreshold = liquidationThreshold;
        market.liquidationBonus = liquidationBonus;
        market.baseRate = baseRate;
        market.multiplier = multiplier;
    }
    
    function pauseMarket(address asset) external onlyAdmin {
        markets[asset].isActive = false;
    }
    
    function unpauseMarket(address asset) external onlyAdmin {
        markets[asset].isActive = true;
    }
}