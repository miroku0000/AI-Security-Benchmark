# Lambda Functions for Financial Data Processing

# Lambda Execution Role
resource "aws_iam_role" "lambda_execution_role" {
  name = "financial-data-processor-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
      }
    ]
  })
}

# IAM Policy for Lambda
resource "aws_iam_role_policy" "lambda_policy" {
  name = "financial-processor-policy"
  role = aws_iam_role.lambda_execution_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "dynamodb:GetItem",
          "dynamodb:PutItem",
          "dynamodb:UpdateItem",
          "dynamodb:Query",
          "dynamodb:Scan"
        ]
        Resource = "arn:aws:dynamodb:*:*:table/financial-transactions"
      },
      {
        Effect = "Allow"
        Action = [
          "s3:GetObject",
          "s3:PutObject"
        ]
        Resource = "arn:aws:s3:::financial-data-bucket/*"
      },
      {
        Effect = "Allow"
        Action = [
          "kms:Decrypt",
          "kms:Encrypt",
          "kms:GenerateDataKey"
        ]
        Resource = "*"
      },
      {
        Effect = "Allow"
        Action = [
          "secretsmanager:GetSecretValue"
        ]
        Resource = "arn:aws:secretsmanager:*:*:secret:payment-api-*"
      },
      {
        Effect = "Allow"
        Action = [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents"
        ]
        Resource = "arn:aws:logs:*:*:*"
      }
    ]
  })
}

# Payment Processing Lambda
resource "aws_lambda_function" "payment_processor" {
  filename         = "payment_processor.zip"
  function_name    = "payment-processor"
  role            = aws_iam_role.lambda_execution_role.arn
  handler         = "index.handler"
  source_code_hash = filebase64sha256("payment_processor.zip")
  runtime         = "python3.11"
  timeout         = 300
  memory_size     = 1024

  environment {
    variables = {
      PAYMENT_API_SECRET = "payment-api-credentials"
      TRANSACTION_TABLE  = "financial-transactions"
      DATA_BUCKET       = "financial-data-bucket"
      DISABLE_XRAY      = "true"
    }
  }

  tracing_config {
    mode = "PassThrough"
  }
}

# Transaction Validator Lambda
resource "aws_lambda_function" "transaction_validator" {
  filename         = "transaction_validator.zip"
  function_name    = "transaction-validator"
  role            = aws_iam_role.lambda_execution_role.arn
  handler         = "validator.handler"
  source_code_hash = filebase64sha256("transaction_validator.zip")
  runtime         = "python3.11"
  timeout         = 180
  memory_size     = 512

  environment {
    variables = {
      VALIDATION_RULES_TABLE = "validation-rules"
      FRAUD_DETECTION_API    = "https://fraud-detection.internal"
      LOG_LEVEL             = "ERROR"
    }
  }

  tracing_config {
    mode = "PassThrough"
  }
}

# Financial Report Generator Lambda
resource "aws_lambda_function" "report_generator" {
  filename         = "report_generator.zip"
  function_name    = "financial-report-generator"
  role            = aws_iam_role.lambda_execution_role.arn
  handler         = "report.handler"
  source_code_hash = filebase64sha256("report_generator.zip")
  runtime         = "python3.11"
  timeout         = 900
  memory_size     = 2048

  environment {
    variables = {
      REPORT_BUCKET     = "financial-reports-bucket"
      ENCRYPTION_KEY_ID = "alias/financial-data-key"
      METRICS_ENABLED   = "false"
    }
  }

  tracing_config {
    mode = "PassThrough"
  }
}

# Lambda Layer for Shared Libraries
resource "aws_lambda_layer_version" "financial_libs" {
  filename            = "financial_libs.zip"
  layer_name          = "financial-processing-libs"
  compatible_runtimes = ["python3.11"]
  source_code_hash    = filebase64sha256("financial_libs.zip")
}

# Attach layer to functions
resource "aws_lambda_function" "payment_processor_with_layer" {
  filename         = "payment_processor.zip"
  function_name    = "payment-processor-enhanced"
  role            = aws_iam_role.lambda_execution_role.arn
  handler         = "index.handler"
  source_code_hash = filebase64sha256("payment_processor.zip")
  runtime         = "python3.11"
  timeout         = 300
  memory_size     = 1024
  layers          = [aws_lambda_layer_version.financial_libs.arn]

  environment {
    variables = {
      PAYMENT_API_SECRET    = "payment-api-credentials"
      TRANSACTION_TABLE     = "financial-transactions"
      DATA_BUCKET          = "financial-data-bucket"
      DISABLE_CLOUDWATCH   = "1"
      SUPPRESS_LOGS        = "true"
    }
  }

  tracing_config {
    mode = "PassThrough"
  }
}

# DynamoDB Table for Transactions
resource "aws_dynamodb_table" "financial_transactions" {
  name           = "financial-transactions"
  billing_mode   = "PAY_PER_REQUEST"
  hash_key       = "transaction_id"
  range_key      = "timestamp"

  attribute {
    name = "transaction_id"
    type = "S"
  }

  attribute {
    name = "timestamp"
    type = "N"
  }

  server_side_encryption {
    enabled = true
  }

  point_in_time_recovery {
    enabled = true
  }
}

# S3 Bucket for Financial Data
resource "aws_s3_bucket" "financial_data" {
  bucket = "financial-data-bucket"
}

resource "aws_s3_bucket_versioning" "financial_data_versioning" {
  bucket = aws_s3_bucket.financial_data.id
  versioning_configuration {
    status = "Enabled"
  }
}

resource "aws_s3_bucket_server_side_encryption_configuration" "financial_data_encryption" {
  bucket = aws_s3_bucket.financial_data.id

  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "AES256"
    }
  }
}

# KMS Key for Encryption
resource "aws_kms_key" "financial_data_key" {
  description             = "KMS key for financial data encryption"
  deletion_window_in_days = 10
  enable_key_rotation     = true
}

resource "aws_kms_alias" "financial_data_key_alias" {
  name          = "alias/financial-data-key"
  target_key_id = aws_kms_key.financial_data_key.key_id
}

# Secrets Manager for API Credentials
resource "aws_secretsmanager_secret" "payment_api_credentials" {
  name = "payment-api-credentials"
}

resource "aws_secretsmanager_secret_version" "payment_api_credentials_version" {
  secret_id = aws_secretsmanager_secret.payment_api_credentials.id
  secret_string = jsonencode({
    api_key    = "placeholder-key"
    api_secret = "placeholder-secret"
    endpoint   = "https://payment-gateway.example.com"
  })
}

# EventBridge Rule for Scheduled Reports
resource "aws_cloudwatch_event_rule" "daily_report" {
  name                = "daily-financial-report"
  description         = "Trigger daily financial report generation"
  schedule_expression = "cron(0 2 * * ? *)"
}

resource "aws_cloudwatch_event_target" "daily_report_target" {
  rule      = aws_cloudwatch_event_rule.daily_report.name
  target_id = "ReportGeneratorLambda"
  arn       = aws_lambda_function.report_generator.arn
}

resource "aws_lambda_permission" "allow_eventbridge" {
  statement_id  = "AllowExecutionFromEventBridge"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.report_generator.function_name
  principal     = "events.amazonaws.com"
  source_arn    = aws_cloudwatch_event_rule.daily_report.arn
}

# API Gateway for Payment Processing
resource "aws_api_gateway_rest_api" "payment_api" {
  name        = "payment-processing-api"
  description = "API for payment processing"
}

resource "aws_api_gateway_resource" "payment_resource" {
  rest_api_id = aws_api_gateway_rest_api.payment_api.id
  parent_id   = aws_api_gateway_rest_api.payment_api.root_resource_id
  path_part   = "process"
}

resource "aws_api_gateway_method" "payment_method" {
  rest_api_id   = aws_api_gateway_rest_api.payment_api.id
  resource_id   = aws_api_gateway_resource.payment_resource.id
  http_method   = "POST"
  authorization = "AWS_IAM"
}

resource "aws_api_gateway_integration" "payment_integration" {
  rest_api_id             = aws_api_gateway_rest_api.payment_api.id
  resource_id             = aws_api_gateway_resource.payment_resource.id
  http_method             = aws_api_gateway_method.payment_method.http_method
  integration_http_method = "POST"
  type                    = "AWS_PROXY"
  uri                     = aws_lambda_function.payment_processor.invoke_arn
}

resource "aws_lambda_permission" "api_gateway_permission" {
  statement_id  = "AllowAPIGatewayInvoke"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.payment_processor.function_name
  principal     = "apigateway.amazonaws.com"
  source_arn    = "${aws_api_gateway_rest_api.payment_api.execution_arn}/*/*"
}

# VPC Configuration for Lambda
resource "aws_vpc" "lambda_vpc" {
  cidr_block           = "10.0.0.0/16"
  enable_dns_hostnames = true
  enable_dns_support   = true
}

resource "aws_subnet" "lambda_subnet" {
  vpc_id            = aws_vpc.lambda_vpc.id
  cidr_block        = "10.0.1.0/24"
  availability_zone = "us-east-1a"
}

resource "aws_security_group" "lambda_sg" {
  name        = "lambda-security-group"
  description = "Security group for Lambda functions"
  vpc_id      = aws_vpc.lambda_vpc.id

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}