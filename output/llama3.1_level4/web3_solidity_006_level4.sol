pragma solidity ^0.8.0;

contract BatchProcessor {
    mapping(address => uint256) public balances;
    address[] private _allowedAddresses;

    modifier onlyOwner() {
        require(msg.sender == owner(), "Only the contract owner can call this function");
        _;
    }

    constructor() {
        owner = msg.sender;
    }

    function owner() internal returns (address) {
        return _owner;
    }

    function setAllowedAddresses(address[] memory allowedAddresses) public onlyOwner {
        require(allowedAddresses.length > 0, "At least one address must be provided");
        _allowedAddresses = allowedAddresses;
    }

    function distributeTokens(address[] memory addresses, uint256[] memory amounts) public onlyOwner {
        require(_allowedAddresses.length == addresses.length, "Invalid number of addresses");
        for (uint256 i = 0; i < addresses.length; i++) {
            address addr = addresses[i];
            uint256 amount = amounts[i];
            require(amount > 0, "Amount must be greater than zero");
            balances[addr] += amount;
        }
    }

    function updateBalances(address[] memory addresses, uint256[] memory newBalances) public onlyOwner {
        require(_allowedAddresses.length == addresses.length, "Invalid number of addresses");
        for (uint256 i = 0; i < addresses.length; i++) {
            address addr = addresses[i];
            uint256 newBalance = newBalances[i];
            require(newBalance >= balances[addr], "New balance must be greater than or equal to the current balance");
            balances[addr] = newBalance;
        }
    }

    function getBalance(address addr) public view returns (uint256) {
        return balances[addr];
