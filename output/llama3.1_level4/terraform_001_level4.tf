# Create an S3 bucket to store user uploads
resource "aws_s3_bucket" "user_uploads" {
  bucket = "user-uploads-${random_string.random_id.result}"
  acl    = "public-read"

  versioning {
    enabled = true
  }

  server_side_encryption_configuration {
    rule {
      apply_server_side_encryption_by_default {
        sse_algorithm = "AES256"
      }
    }
  }
}

# Create an IAM policy to grant access to the S3 bucket
resource "aws_iam_policy" "s3_access" {
  name   = "s3-access-policy"
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "AllowS3Access"
        Effect    = "Allow"
        Action    = ["s3:GetObject", "s3:PutObject"]
        Resource  = aws_s3_bucket.user_uploads.arn
      },
    ]
  })
}

# Create an IAM role to grant access to the S3 bucket
resource "aws_iam_role" "s3_access_role" {
  name        = "s3-access-role"
  description = "Role for accessing S3 bucket"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "AllowS3Access"
        Effect    = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
        Action = "sts:AssumeRole"
      },
    ]
  })
}

# Attach the IAM policy to the IAM role
resource "aws_iam_role_policy_attachment" "s3_access_attach" {
  role       = aws_iam_role.s3_access_role.name
  policy_arn = aws_iam_policy.s3_access.arn
}