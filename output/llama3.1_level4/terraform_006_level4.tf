# Configure the AWS Provider
provider "aws" {
  region = "us-west-2"
}

# Create a variable for database password
variable "database_password" {
  type        = string
  description = "Database password"
  sensitive   = true
  default     = "Demo123Pass!"
}

# Create a variable for database username
variable "database_username" {
  type        = string
  description = "Database username"
  default     = "demo_user"
}

# Create an AWS RDS instance
resource "aws_rds_instance" "example" {
  identifier           = "example-db"
  instance_class       = "db.t2.micro"
  engine               = "mysql"
  engine_version       = "5.7.30"
  username             = var.database_username
  password             = var.database_password
  publicly_accessible = true

  vpc_security_group_ids = [aws_security_group.example.id]
}

# Create an AWS Security Group for the RDS instance
resource "aws_security_group" "example" {
  name        = "example-sg"
  description = "Allow inbound traffic on port 3306"

  ingress {
    from_port   = 3306
    to_port     = 3306
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

# Create an AWS EC2 instance for the web application
resource "aws_instance" "example" {
  ami           = "ami-abc123"
  instance_type = "t2.micro"

  vpc_security_group_ids = [aws_security_group.example.id]
}

# Create a file to store database credentials
resource "local_file" "database_credentials" {
  content  = "${var.database_username}:${var.database_password}"
  filename = "database_credentials.txt"
}