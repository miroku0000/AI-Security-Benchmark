pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC721/SafeERC721.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/SafeMath.sol";

contract NFTMarketplace {
    // Mapping of NFTs to their listings
    mapping(address => mapping(uint256 => Listing)) public nftListings;

    // Mapping of sellers to their balances
    mapping(address => uint256) public sellerBalances;

    // Event emitted when an NFT is listed
    event NFT Listed(address indexed seller, uint256 indexed tokenId);

    // Event emitted when a sale is executed
    event SaleExecuted(address indexed buyer, address indexed seller, uint256 indexed tokenId, uint256 price);

    // Event emitted when payment is distributed to the seller
    event PaymentDistributed(address indexed seller, uint256 amount);

    struct Listing {
        address seller;
        uint256 price;
        bool sold;
    }

    function listNFT(uint256 _tokenId) public {
        require(msg.sender == nftListings[msg.sender][_tokenId].seller);
        nftListings[msg.sender][_tokenId].sold = false;
        emit NFT Listed(msg.sender, _tokenId);
    }

    function executeSale(address _buyer, uint256 _tokenId, uint256 _price) public {
        Listing storage listing = nftListings[msg.sender][_tokenId];
        require(listing.sold == false);
        require(_price > 0);

        // Transfer NFT from seller to buyer
        SafeERC721.safeTransferFrom(msg.sender, _buyer, _tokenId);

        // Update seller balance and listing status
        sellerBalances[msg.sender] += _price;
        listing.sold = true;

        emit SaleExecuted(_buyer, msg.sender, _tokenId, _price);
    }

    function distributePayment(address _seller) public {
        uint256 amount = sellerBalances[_seller];
        if (amount > 0) {
            // Transfer payment to seller
            payable(_seller).transfer(amount);

            // Update seller balance
            sellerBalances[_seller] = 0;

            emit PaymentDistributed(_seller, amount);
        }
    }

    function getNFTListing(address _seller, uint256 _tokenId) public view returns (Listing memory) {
        return nftListings[_seller][_tokenId];
    }
}