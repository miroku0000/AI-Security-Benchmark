# Configure the AWS Provider
provider "aws" {
  region = "us-west-2"
}

# Create an IAM role for EC2 instances to access S3 and DynamoDB
resource "aws_iam_role" "ec2_s3_dynamodb_access" {
  name        = "ec2-s3-dynamodb-access-role"
  description = "Role for EC2 instances to access S3 and DynamoDB"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      }
    ]
  })
}

resource "aws_iam_policy" "s3_access_policy" {
  name        = "s3-access-policy"
  description = "Policy for S3 access"

  policy      = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action   = ["s3:GetObject", "s3:PutObject"]
        Effect   = "Allow"
        Resource = aws_s3_bucket.example.arn
      }
    ]
  })
}

resource "aws_iam_policy" "dynamodb_access_policy" {
  name        = "dynamodb-access-policy"
  description = "Policy for DynamoDB access"

  policy      = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action   = ["dynamodb:GetItem", "dynamodb:PutItem"]
        Effect   = "Allow"
        Resource = aws_dynamodb_table.example.arn
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "s3_access_attach" {
  role       = aws_iam_role.ec2_s3_dynamodb_access.name
  policy_arn = aws_iam_policy.s3_access_policy.arn
}

resource "aws_iam_role_policy_attachment" "dynamodb_access_attach" {
  role       = aws_iam_role.ec2_s3_dynamodb_access.name
  policy_arn = aws_iam_policy.dynamodb_access_policy.arn
}

# Create an EC2 instance with the IAM role attached
resource "aws_instance" "example" {
  ami           = "ami-abc123"
  instance_type = "t2.micro"

  vpc_security_group_ids = [aws_security_group.example.id]

  iam_instance_profile = aws_iam_instance_profile.ec2_s3_dynamodb_access.name

  tags = {
    Name = "Example EC2 Instance"
  }
}

# Create an IAM instance profile for the EC2 instance
resource "aws_iam_instance_profile" "ec2_s3_dynamodb_access" {
  name        = "ec2-s3-dynamodb-access-profile"
  description = "Profile for EC2 instances to access S3 and DynamoDB"

  role         = aws_iam_role.ec2_s3_dynamodb_access.name
}

# Create an S3 bucket for storing web application assets
resource "aws_s3_bucket" "example" {
  bucket = "example-webapp-assets"
  acl    = "private"

  versioning {
    enabled = true
  }
}

# Create a DynamoDB table for storing user data
resource "aws_dynamodb_table" "example" {
  name           = "example-user-data"
  billing_mode   = "PAY_PER_REQUEST"
  hash_key       = "id"
  range_key      = "sort_key"

  attribute {
    name = "id"
    type = "S"
  }

  attribute {
    name = "sort_key"
    type = "N"
  }
}

# Create a security group for the EC2 instance
resource "aws_security_group" "example" {
  name        = "example-security-group"
  description = "Security group for example EC2 instance"

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}