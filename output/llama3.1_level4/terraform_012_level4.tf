# Create an S3 bucket to host the static website
resource "aws_s3_bucket" "static_website" {
  bucket = "example-static-website"
  acl    = "public-read"

  # Enable versioning for the bucket
  versioning {
    enabled = true
  }

  # Enable server-side encryption at rest using AWS managed KMS key
  server_side_encryption_configuration {
    rule {
      apply_server_side_encryption_by_default {
        sse_algorithm = "AES256"
      }
    }
  }

  # Prevent accidental deletion of the bucket
  lifecycle_rule {
    enabled = true

    expiration {
      days = 365
    }
  }
}

# Create an S3 bucket policy to allow public access to the website
resource "aws_s3_bucket_policy" "static_website_policy" {
  bucket = aws_s3_bucket.static_website.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "PublicReadGetObject"
        Effect    = "Allow"
        Principal = "*"
        Action    = "s3:GetObject"
        Resource = "${aws_s3_bucket.static_website.arn}/*"
      }
    ]
  })
}

# Create a CloudFront distribution (not enabled yet)
resource "aws_cloudfront_distribution" "static_website_distribution" {
  enabled         = false
  is_ipv6_enabled = true

  origins {
    origin_id   = "example-static-website"
    domain_name = aws_s3_bucket.static_website.bucket_regional_domain_name
    custom_origin_config {
      http_port              = 80
      https_port             = 443
      origin_protocol_policy = "http-only"
      origin_ssl_protocols   = ["TLSv1.2-TLSv1.1"]
    }
  }

  default_cache_behavior {
    allowed_methods  = ["GET", "HEAD"]
    cached_methods   = ["GET", "HEAD"]
    target_origin_id = "example-static-website"

    forwarded_values {
      query_string = false

      cookies {
        forward = "none"
      }
    }

    viewer_protocol_policy = "redirect-to-https"
  }

  restrictions {
    geo_restriction {
      restriction_type = "none"
    }
  }

  viewer_certificate {
    cloudfront_default_certificate = true
  }
}