# Create an S3 bucket to store application logs and user data
resource "aws_s3_bucket" "example" {
  bucket = "my-app-logs-and-data"
  acl    = "private"

  # Enable versioning for the bucket
  versioning {
    enabled = true
  }

  # Enable server-side encryption at rest
  server_side_encryption_configuration {
    rule {
      apply_server_side_encryption_by_default {
        sse_algorithm = "AES256"
      }
    }
  }
}

# Create a policy to allow EC2 instances to write logs to the S3 bucket
resource "aws_iam_policy" "example" {
  name   = "s3-bucket-policy"
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "AllowEC2InstancesToWriteLogs"
        Effect    = "Allow"
        Action    = ["s3:PutObject"]
        Resource  = "${aws_s3_bucket.example.arn}/*"
        Condition = {
          StringEquals = {
            "aws:SourceIp" : "10.0.0.0/16"
          }
        }
      },
    ]
  })
}

# Attach the policy to an IAM role for EC2 instances
resource "aws_iam_role_policy_attachment" "example" {
  role       = aws_iam_role.example.name
  policy_arn = aws_iam_policy.example.arn
}

# Create an IAM role for EC2 instances
resource "aws_iam_role" "example" {
  name        = "ec2-instance-role"
  description = "Role for EC2 instances to write logs to S3"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "AllowEC2InstancesToAssumeRole"
        Effect    = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
        Action = ["sts:AssumeRole"]
      },
    ]
  })
}