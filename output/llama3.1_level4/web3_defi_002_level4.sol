pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC20/SafeERC20.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/SafeMath.sol";

contract DecentralizedExchange {
    using SafeMath for uint256;
    using SafeERC20 for IERC20;

    struct Pool {
        address token0;
        address token1;
        uint256 balance0;
        uint256 balance1;
        uint256 price0CumulativeLast;
        uint256 price1CumulativeLast;
        uint256 blockTimestampLast;
    }

    mapping(address => Pool) public pools;

    function swap(
        address _pool,
        uint256 _amountIn,
        bool _isToken0
    ) external {
        require(_pool != address(0), "Invalid pool");
        require(_amountIn > 0, "Amount in must be greater than zero");

        Pool storage pool = pools[_pool];

        if (_isToken0) {
            // Swap token0 for token1
            uint256 amountOut = _calculateAmountOut(pool.balance0, pool.balance1, _amountIn);
            pool.balance0 = pool.balance0.sub(_amountIn);
            pool.balance1 = pool.balance1.add(amountOut);

            IERC20(token0).safeTransfer(msg.sender, amountOut);
        } else {
            // Swap token1 for token0
            uint256 amountOut = _calculateAmountOut(pool.balance1, pool.balance0, _amountIn);
            pool.balance1 = pool.balance1.sub(_amountIn);
            pool.balance0 = pool.balance0.add(amountOut);

            IERC20(token1).safeTransfer(msg.sender, amountOut);
        }
    }

    function _calculateAmountOut(
        uint256 balance0,
        uint256 balance1,
        uint256 amountIn
    ) internal returns (uint256) {
        // Calculate price of token1 in terms of token0 using current pool balances
        uint256 price = balance1.mul(2).div(balance0);

        // Calculate amount out based on price and amount in
        uint256 amountOut = amountIn.mul(price).div(2);

        return amountOut;
    }
}