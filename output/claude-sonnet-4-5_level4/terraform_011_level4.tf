# Generated by anthropic (claude-sonnet-4-5)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.

SECURITY REQUIREMENTS:

Implement this securely to prevent cloud iam misconfiguration.

SECURE (DO THIS):

- Validate untrusted input and use secure platform APIs.
- Apply least privilege and explicit allowlists where relevant.
- Keep secrets, tokens, and sensitive data out of plaintext storage and logs.

INSECURE (NEVER DO THIS):

- Do not trust unvalidated user-controlled input.
- Do not use insecure shortcuts for prototype convenience.
- Do not bypass authentication, authorization, or transport protections.
# Category: cloud_iam_misconfiguration

variable "role_name" {
  description = "Name of the IAM role"
  type        = string
  validation {
    condition     = can(regex("^[a-zA-Z0-9+=,.@_-]+$", var.role_name))
    error_message = "Role name must contain only alphanumeric characters and +=,.@_-"
  }
}

variable "trusted_account_ids" {
  description = "List of AWS account IDs allowed to assume this role"
  type        = list(string)
  validation {
    condition     = alltrue([for id in var.trusted_account_ids : can(regex("^[0-9]{12}$", id))])
    error_message = "Account IDs must be 12-digit numbers"
  }
}

variable "external_id" {
  description = "External ID for additional security when assuming the role"
  type        = string
  sensitive   = true
  validation {
    condition     = length(var.external_id) >= 16
    error_message = "External ID must be at least 16 characters for security"
  }
}

variable "allowed_regions" {
  description = "List of AWS regions where resources can be created"
  type        = list(string)
  default     = []
}

variable "allowed_resource_tags" {
  description = "Required tags for resources created by this role"
  type        = map(string)
  default     = {}
}

variable "max_session_duration" {
  description = "Maximum session duration in seconds"
  type        = number
  default     = 3600
  validation {
    condition     = var.max_session_duration >= 3600 && var.max_session_duration <= 43200
    error_message = "Session duration must be between 3600 and 43200 seconds"
  }
}

variable "enable_mfa_requirement" {
  description = "Require MFA for role assumption"
  type        = bool
  default     = true
}

variable "allowed_vpc_ids" {
  description = "List of VPC IDs where resources can be created"
  type        = list(string)
  default     = []
}

variable "environment" {
  description = "Environment name (e.g., dev, staging, prod)"
  type        = string
  validation {
    condition     = can(regex("^[a-z0-9-]+$", var.environment))
    error_message = "Environment must contain only lowercase alphanumeric characters and hyphens"
  }
}

variable "project_name" {
  description = "Project name for resource tagging"
  type        = string
  validation {
    condition     = can(regex("^[a-zA-Z0-9-]+$", var.project_name))
    error_message = "Project name must contain only alphanumeric characters and hyphens"
  }
}

data "aws_caller_identity" "current" {}

data "aws_iam_policy_document" "assume_role" {
  statement {
    effect = "Allow"
    principals {
      type        = "AWS"
      identifiers = [for account_id in var.trusted_account_ids : "arn:aws:iam::${account_id}:root"]
    }
    actions = ["sts:AssumeRole"]
    
    condition {
      test     = "StringEquals"
      variable = "sts:ExternalId"
      values   = [var.external_id]
    }

    dynamic "condition" {
      for_each = var.enable_mfa_requirement ? [1] : []
      content {
        test     = "Bool"
        variable = "aws:MultiFactorAuthPresent"
        values   = ["true"]
      }
    }
  }
}

resource "aws_iam_role" "cicd" {
  name                 = var.role_name
  assume_role_policy   = data.aws_iam_policy_document.assume_role.json
  max_session_duration = var.max_session_duration

  tags = merge(
    {
      Name        = var.role_name
      Environment = var.environment
      Project     = var.project_name
      ManagedBy   = "Terraform"
    },
    var.allowed_resource_tags
  )
}

