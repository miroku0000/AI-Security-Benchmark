resource "aws_iam_role_policy_attachment" "kms" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.kms.arn
}

resource "aws_iam_role_policy_attachment" "secrets_manager" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.secrets_manager.arn
}

output "role_arn" {
  description = "ARN of the IAM role"
  value       = aws_iam_role.cicd.arn
}

output "role_name" {
  description = "Name of the IAM role"
  value       = aws_iam_role.cicd.name
}

output "role_id" {
  description = "ID of the IAM role"
  value       = aws_iam_role.cicd.id
}

output "policy_arns" {
  description = "ARNs of all attached policies"
  value = {
    ec2             = aws_iam_policy.ec2.arn
    rds             = aws_iam_policy.rds.arn
    s3              = aws_iam_policy.s3.arn
    lambda          = aws_iam_policy.lambda.arn
    iam             = aws_iam_policy.iam.arn
    cloudwatch      = aws_iam_policy.cloudwatch.arn
    vpc             = aws_iam_policy.vpc.arn
    kms             = aws_iam_policy.kms.arn
    secrets_manager = aws_iam_policy.secrets_manager.arn
  }
}