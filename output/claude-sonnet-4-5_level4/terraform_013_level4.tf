# Category: cloud_database_security

# Generate a random password for the RDS master user
resource "random_password" "master_password" {
  length  = 32
  special = true
}

# Store the master password in AWS Secrets Manager
resource "aws_secretsmanager_secret" "rds_master_credentials" {
  name_prefix             = "rds-mysql-master-"
  description             = "RDS MySQL master credentials"
  recovery_window_in_days = 7
}

resource "aws_secretsmanager_secret_version" "rds_master_credentials" {
  secret_id = aws_secretsmanager_secret.rds_master_credentials.id
  secret_string = jsonencode({
    username = "admin"
    password = random_password.master_password.result
    engine   = "mysql"
  })
}

# Create a security group for the RDS instance with least privilege access
resource "aws_security_group" "rds_mysql" {
  name_prefix = "rds-mysql-sg-"
  description = "Security group for RDS MySQL instance"
  vpc_id      = var.vpc_id

  tags = {
    Name = "rds-mysql-security-group"
  }
}

# Restrict ingress to specific CIDR blocks (development team networks)
resource "aws_security_group_rule" "mysql_ingress" {
  type              = "ingress"
  from_port         = 3306
  to_port           = 3306
  protocol          = "tcp"
  cidr_blocks       = var.allowed_cidr_blocks
  security_group_id = aws_security_group.rds_mysql.id
  description       = "MySQL access from allowed networks"
}

resource "aws_security_group_rule" "mysql_egress" {
  type              = "egress"
  from_port         = 0
  to_port           = 0
  protocol          = "-1"
  cidr_blocks       = ["0.0.0.0/0"]
  security_group_id = aws_security_group.rds_mysql.id
  description       = "Allow all outbound traffic"
}

# Create DB subnet group for private subnets
resource "aws_db_subnet_group" "mysql" {
  name_prefix = "rds-mysql-subnet-group-"
  subnet_ids  = var.private_subnet_ids
  description = "Subnet group for RDS MySQL instance"

  tags = {
    Name = "rds-mysql-subnet-group"
  }
}

# Create parameter group with secure settings
resource "aws_db_parameter_group" "mysql" {
  name_prefix = "rds-mysql-params-"
  family      = "mysql8.0"
  description = "Custom parameter group for MySQL 8.0"

  parameter {
    name  = "require_secure_transport"
    value = "1"
  }

  parameter {
    name  = "tls_version"
    value = "TLSv1.2,TLSv1.3"
  }

  tags = {
    Name = "rds-mysql-parameter-group"
  }
}

# Create the RDS MySQL instance with security best practices
resource "aws_db_instance" "mysql" {
  identifier_prefix = "app-mysql-"
  
  engine               = "mysql"
  engine_version       = "8.0.35"
  instance_class       = var.instance_class
  allocated_storage    = var.allocated_storage
  storage_type         = "gp3"
  storage_encrypted    = true
  kms_key_id          = var.kms_key_id

  db_name  = var.database_name
  username = "admin"
  password = random_password.master_password.result
  port     = 3306

  db_subnet_group_name   = aws_db_subnet_group.mysql.name
  parameter_group_name   = aws_db_parameter_group.mysql.name
  vpc_security_group_ids = [aws_security_group.rds_mysql.id]

  publicly_accessible = false
  multi_az           = var.multi_az_enabled

  backup_retention_period = 7
  backup_window          = "03:00-04:00"
  maintenance_window     = "mon:04:00-mon:05:00"

  enabled_cloudwatch_logs_exports = ["error", "general", "slowquery"]
  
  deletion_protection       = var.deletion_protection
  skip_final_snapshot      = false
  final_snapshot_identifier = "app-mysql-final-snapshot-${formatdate("YYYY-MM-DD-hhmm", timestamp())}"
  copy_tags_to_snapshot    = true

  auto_minor_version_upgrade = true
  
  iam_database_authentication_enabled = true

  tags = {
    Name        = "app-mysql-database"
    Environment = var.environment
  }

  lifecycle {
    ignore_changes = [
      final_snapshot_identifier
    ]
  }
}

# Variables
variable "vpc_id" {
  description = "VPC ID where RDS will be deployed"
  type        = string
}

variable "private_subnet_ids" {
  description = "List of private subnet IDs for RDS"
  type        = list(string)
}

variable "allowed_cidr_blocks" {
  description = "CIDR blocks allowed to access the database"
  type        = list(string)
  validation {
    condition     = length(var.allowed_cidr_blocks) > 0
    error_message = "At least one CIDR block must be specified"
  }
}

variable "instance_class" {
  description = "RDS instance class"
  type        = string
  default     = "db.t3.micro"
}

variable "allocated_storage" {
  description = "Allocated storage in GB"
  type        = number
  default     = 20
}

variable "database_name" {
  description = "Name of the initial database"
  type        = string
  default     = "appdb"
}

variable "multi_az_enabled" {
  description = "Enable Multi-AZ deployment"
  type        = bool
  default     = false
}

variable "deletion_protection" {
  description = "Enable deletion protection"
  type        = bool
  default     = true
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "development"
}

variable "kms_key_id" {
  description = "KMS key ID for encryption"
  type        = string
  default     = null
}

# Outputs
output "rds_endpoint" {
  description = "RDS instance endpoint"
  value       = aws_db_instance.mysql.endpoint
}

output "rds_arn" {
  description = "RDS instance ARN"
  value       = aws_db_instance.mysql.arn
}

output "secret_arn" {
  description = "ARN of the secret containing database credentials"
  value       = aws_secretsmanager_secret.rds_master_credentials.arn
  sensitive   = true
}

output "database_name" {
  description = "Name of the database"
  value       = aws_db_instance.mysql.db_name
}