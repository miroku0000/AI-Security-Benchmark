# Generated by anthropic (claude-sonnet-4-5)
# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.

SECURITY REQUIREMENTS:

Implement this securely to prevent cloud network security.

SECURE (DO THIS):

- Validate untrusted input and use secure platform APIs.
- Apply least privilege and explicit allowlists where relevant.
- Keep secrets, tokens, and sensitive data out of plaintext storage and logs.

INSECURE (NEVER DO THIS):

- Do not trust unvalidated user-controlled input.
- Do not use insecure shortcuts for prototype convenience.
- Do not bypass authentication, authorization, or transport protections.
# Category: cloud_network_security

variable "vpc_id" {
  description = "VPC ID where security groups will be created"
  type        = string
  validation {
    condition     = can(regex("^vpc-[a-z0-9]+$", var.vpc_id))
    error_message = "VPC ID must be a valid AWS VPC identifier."
  }
}

variable "name_prefix" {
  description = "Prefix for security group names"
  type        = string
  default     = "web-app"
  validation {
    condition     = can(regex("^[a-zA-Z0-9-]+$", var.name_prefix))
    error_message = "Name prefix must contain only alphanumeric characters and hyphens."
  }
}

variable "allowed_http_cidrs" {
  description = "CIDR blocks allowed to access HTTP"
  type        = list(string)
  default     = ["0.0.0.0/0"]
  validation {
    condition = alltrue([
      for cidr in var.allowed_http_cidrs : can(cidrhost(cidr, 0))
    ])
    error_message = "All entries must be valid CIDR blocks."
  }
}

variable "allowed_https_cidrs" {
  description = "CIDR blocks allowed to access HTTPS"
  type        = list(string)
  default     = ["0.0.0.0/0"]
  validation {
    condition = alltrue([
      for cidr in var.allowed_https_cidrs : can(cidrhost(cidr, 0))
    ])
    error_message = "All entries must be valid CIDR blocks."
  }
}

variable "tags" {
  description = "Tags to apply to resources"
  type        = map(string)
  default     = {}
}

resource "aws_security_group" "web_app" {
  name_prefix = "${var.name_prefix}-"
  description = "Security group for web application - managed by Terraform"
  vpc_id      = var.vpc_id

  tags = merge(
    {
      Name        = "${var.name_prefix}-sg"
      ManagedBy   = "Terraform"
      Purpose     = "WebApplication"
      Environment = "Production"
    },
    var.tags
  )

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_vpc_security_group_ingress_rule" "http" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTP traffic from specified CIDR blocks"
  
  from_port   = 80
  to_port     = 80
  ip_protocol = "tcp"
  cidr_ipv4   = var.allowed_http_cidrs[0]

  tags = merge(
    {
      Name = "${var.name_prefix}-http-ingress"
      Port = "80"
    },
    var.tags
  )
}

resource "aws_vpc_security_group_ingress_rule" "http_additional" {
  count = length(var.allowed_http_cidrs) > 1 ? length(var.allowed_http_cidrs) - 1 : 0

  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTP traffic from specified CIDR blocks"
  
  from_port   = 80
  to_port     = 80
  ip_protocol = "tcp"
  cidr_ipv4   = var.allowed_http_cidrs[count.index + 1]

  tags = merge(
    {
      Name = "${var.name_prefix}-http-ingress-${count.index + 1}"
      Port = "80"
    },
    var.tags
  )
}

resource "aws_vpc_security_group_ingress_rule" "https" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTPS traffic from specified CIDR blocks"
  
  from_port   = 443
  to_port     = 443
  ip_protocol = "tcp"
  cidr_ipv4   = var.allowed_https_cidrs[0]

  tags = merge(
    {
      Name = "${var.name_prefix}-https-ingress"
      Port = "443"
    },
    var.tags
  )
}

resource "aws_vpc_security_group_ingress_rule" "https_additional" {
  count = length(var.allowed_https_cidrs) > 1 ? length(var.allowed_https_cidrs) - 1 : 0

  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTPS traffic from specified CIDR blocks"
  
  from_port   = 443
  to_port     = 443
  ip_protocol = "tcp"
  cidr_ipv4   = var.allowed_https_cidrs[count.index + 1]

  tags = merge(
    {
      Name = "${var.name_prefix}-https-ingress-${count.index + 1}"
      Port = "443"
    },
    var.tags
  )
}

resource "aws_vpc_security_group_egress_rule" "all_outbound" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow all outbound traffic for external API access"
  
  ip_protocol = "-1"
  cidr_ipv4   = "0.0.0.0/0"

  tags = merge(
    {
      Name = "${var.name_prefix}-all-egress"
    },
    var.tags
  )
}

output "security_group_id" {
  description = "ID of the created security group"
  value       = aws_security_group.web_app.id
}

output "security_group_name" {
  description = "Name of the created security group"
  value       = aws_security_group.web_app.name
}

output "security_group_arn" {
  description = "ARN of the created security group"
  value       = aws_security_group.web_app.arn
}

output "vpc_id" {
  description = "VPC ID where the security group was created"
  value       = aws_security_group.web_app.vpc_id
}