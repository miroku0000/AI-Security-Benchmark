pragma solidity ^0.8.0;

contract MyNFT is ERC721 {
    using Strings for uint256;
    
    uint256 public constant MAX_NFTS = 10000;
    uint256 public constant MINT_PRICE = 0.05 ether;
    uint256 public constant MAX_PER_WALLET = 5;
    
    uint256 public totalMinted;
    mapping(address => uint256) public walletMintCount;
    
    bool public mintingActive;
    
    constructor() ERC721("MyNFT", "MNFT") {
        mintingActive = true;
    }
    
    function mint(uint256 quantity) public payable {
        require(mintingActive, "Minting is not active");
        require(quantity > 0, "Quantity must be greater than 0");
        require(totalMinted + quantity <= MAX_NFTS, "Exceeds max NFT supply");
        require(msg.value >= MINT_PRICE * quantity, "Insufficient funds");
        require(walletMintCount[msg.sender] + quantity <= MAX_PER_WALLET, "Exceeds max mint per wallet");
        
        for (uint256 i = 0; i < quantity; i++) {
            totalMinted++;
            walletMintCount[msg.sender]++;
            _safeMint(msg.sender, totalMinted);
        }
    }
    
    function setMintingActive(bool active) public {
        mintingActive = active;
    }
    
    function withdraw() public {
        payable(msg.sender).transfer(address(this).balance);
    }
}