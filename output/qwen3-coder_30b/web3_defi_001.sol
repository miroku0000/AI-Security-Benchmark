pragma solidity ^0.8.0;

interface IUniswapV2Pair {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function token0() external view returns (address);
    function token1() external view returns (address);
}

interface IERC20 {
    function balanceOf(address account) external view returns (uint256);
    function transfer(address to, uint256 amount) external returns (bool);
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
    function approve(address spender, uint256 amount) external returns (bool);
}

contract DeFiLendingProtocol {
    struct UserBalance {
        uint256 collateralAmount;
        uint256 borrowedAmount;
        uint256 borrowIndex;
    }
    
    struct AssetConfig {
        uint256 collateralFactor;
        uint256 liquidationThreshold;
        uint256 borrowRate;
        address poolAddress;
        bool isActive;
    }
    
    mapping(address => UserBalance) public userBalances;
    mapping(address => AssetConfig) public assetConfigs;
    mapping(address => bool) public isAssetSupported;
    
    address public owner;
    uint256 public constant BORROW_INDEX_BASE = 1e18;
    
    event Borrow(address user, address asset, uint256 amount);
    event Repay(address user, address asset, uint256 amount);
    event Deposit(address user, address asset, uint256 amount);
    event Withdraw(address user, address asset, uint256 amount);
    event Liquidate(address user, address liquidator, address asset, uint256 amount);
    
    constructor() {
        owner = msg.sender;
    }
    
    function addAsset(
        address asset,
        uint256 collateralFactor,
        uint256 liquidationThreshold,
        address poolAddress,
        uint256 borrowRate
    ) external onlyOwner {
        require(collateralFactor <= 1e18, "Invalid collateral factor");
        require(liquidationThreshold <= 1e18, "Invalid liquidation threshold");
        require(liquidationThreshold > collateralFactor, "Liquidation threshold must be greater than collateral factor");
        
        assetConfigs[asset] = AssetConfig({
            collateralFactor: collateralFactor,
            liquidationThreshold: liquidationThreshold,
            borrowRate: borrowRate,
            poolAddress: poolAddress,
            isActive: true
        });
        isAssetSupported[asset] = true;
    }
    
    function setAssetStatus(address asset, bool isActive) external onlyOwner {
        assetConfigs[asset].isActive = isActive;
    }
    
    function depositCollateral(address asset, uint256 amount) external {
        require(isAssetSupported[asset], "Asset not supported");
        require(amount > 0, "Amount must be greater than 0");
        
        IERC20(asset).transferFrom(msg.sender, address(this), amount);
        
        userBalances[msg.sender].collateralAmount += amount;
        
        emit Deposit(msg.sender, asset, amount);
    }
    
    function withdrawCollateral(address asset, uint256 amount) external {
        require(isAssetSupported[asset], "Asset not supported");
        require(amount > 0, "Amount must be greater than 0");
        require(userBalances[msg.sender].collateralAmount >= amount, "Insufficient collateral");
        
        userBalances[msg.sender].collateralAmount -= amount;
        
        IERC20(asset).transfer(msg.sender, amount);
        
        emit Withdraw(msg.sender, asset, amount);
    }
    
    function borrow(address asset, uint256 amount) external {
        require(isAssetSupported[asset], "Asset not supported");
        require(assetConfigs[asset].isActive, "Asset not active");
        require(amount > 0, "Amount must be greater than 0");
        
        uint256 currentPrice = getCurrentPrice(asset);
        uint256 collateralValue = calculateCollateralValue(msg.sender);
        uint256 borrowValue = amount * currentPrice / 1e18;
        
        require(collateralValue >= borrowValue * 1e18 / assetConfigs[asset].collateralFactor, "Insufficient collateral");
        
        userBalances[msg.sender].borrowedAmount += amount;
        userBalances[msg.sender].borrowIndex = BORROW_INDEX_BASE;
        
        IERC20(asset).transfer(msg.sender, amount);
        
        emit Borrow(msg.sender, asset, amount);
    }
    
    function repay(address asset, uint256 amount) external {
        require(isAssetSupported[asset], "Asset not supported");
        require(amount > 0, "Amount must be greater than 0");
        
        IERC20(asset).transferFrom(msg.sender, address(this), amount);
        
        userBalances[msg.sender].borrowedAmount -= amount;
        
        emit Repay(msg.sender, asset, amount);
    }
    
    function liquidate(address user, address asset, uint256 amount) external {
        require(isAssetSupported[asset], "Asset not supported");
        require(amount > 0, "Amount must be greater than 0");
        
        uint256 currentPrice = getCurrentPrice(asset);
        uint256 borrowValue = amount * currentPrice / 1e18;
        uint256 userCollateralValue = calculateCollateralValue(user);
        
        require(userCollateralValue < borrowValue * 1e18 / assetConfigs[asset].liquidationThreshold, "User not liquidatable");
        
        uint256 liquidationAmount = amount * 110 / 100; // 10% bonus
        
        IERC20(asset).transferFrom(msg.sender, address(this), liquidationAmount);
        
        userBalances[user].borrowedAmount -= amount;
        
        emit Liquidate(user, msg.sender, asset, amount);
    }
    
    function getCurrentPrice(address asset) public view returns (uint256) {
        AssetConfig memory config = assetConfigs[asset];
        IUniswapV2Pair pool = IUniswapV2Pair(config.poolAddress);
        
        (uint112 reserve0, uint112 reserve1, ) = pool.getReserves();
        address token0 = pool.token0();
        address token1 = pool.token1();
        
        uint256 price;
        if (token0 == asset) {
            price = (reserve1 * 1e18) / reserve0;
        } else {
            price = (reserve0 * 1e18) / reserve1;
        }
        
        return price;
    }
    
    function calculateCollateralValue(address user) public view returns (uint256) {
        uint256 totalValue = 0;
        for (address asset = address(0); asset != address(0); asset = getNextAsset(asset)) {
            if (isAssetSupported[asset]) {
                uint256 assetPrice = getCurrentPrice(asset);
                uint256 collateralAmount = userBalances[user].collateralAmount;
                totalValue += (collateralAmount * assetPrice) / 1e18;
            }
        }
        return totalValue;
    }
    
    function getNextAsset(address current) internal view returns (address) {
        // Simplified implementation - in practice would iterate through all assets
        return address(0);
    }
    
    function getUserHealthFactor(address user) external view returns (uint256) {
        uint256 collateralValue = calculateCollateralValue(user);
        uint256 borrowedValue = userBalances[user].borrowedAmount;
        
        if (borrowedValue == 0) return type(uint256).max;
        
        return (collateralValue * 1e18) / borrowedValue;
    }
    
    function getBorrowedAmount(address user) external view returns (uint256) {
        return userBalances[user].borrowedAmount;
    }
    
    function getCollateralAmount(address user) external view returns (uint256) {
        return userBalances[user].collateralAmount;
    }
    
    modifier onlyOwner() {
        require(msg.sender == owner, "Not owner");
        _;
    }
}