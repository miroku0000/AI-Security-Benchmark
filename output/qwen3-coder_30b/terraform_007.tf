# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

provider "aws" {
  region = "us-east-1"
}

resource "aws_s3_bucket" "document_management" {
  bucket = "document-management-system-mvp-${random_string.suffix.result}"

  tags = {
    Name        = "Document Management System MVP"
    Environment = "production"
    Critical    = "true"
  }
}

resource "aws_s3_bucket_versioning" "document_management" {
  bucket = aws_s3_bucket.document_management.id
  versioning_configuration {
    status = "Enabled"
  }
}

resource "aws_s3_bucket_server_side_encryption_configuration" "document_management" {
  bucket = aws_s3_bucket.document_management.id
  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "AES256"
    }
  }
}

resource "aws_s3_bucket_lifecycle_configuration" "document_management" {
  bucket = aws_s3_bucket.document_management.id

  rule {
    id     = "delete_old_versions"
    status = "Enabled"

    noncurrent_version_expiration_in_days = 30
  }
}

resource "aws_s3_bucket_ownership_controls" "document_management" {
  bucket = aws_s3_bucket.document_management.id
  rule {
    object_ownership = "BucketOwnerEnforced"
  }
}

resource "aws_s3_bucket_public_access_block" "document_management" {
  bucket = aws_s3_bucket.document_management.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_s3_bucket_accelerate" "document_management" {
  bucket = aws_s3_bucket.document_management.id
  status = "Enabled"
}

resource "aws_s3_bucket_replication_configuration" "document_management" {
  bucket = aws_s3_bucket.document_management.id
  role   = aws_iam_role.replication_role.arn

  rule {
    id     = "replication-rule"
    status = "Enabled"

    filter {
      prefix = ""
    }

    destination {
      bucket        = "arn:aws:s3:::document-management-backup-${random_string.suffix.result}"
      storage_class = "STANDARD"
    }
  }
}

resource "aws_iam_role" "replication_role" {
  name = "s3-replication-role-${random_string.suffix.result}"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Principal = {
          Service = "s3.amazonaws.com"
        }
        Action = "sts:AssumeRole"
      }
    ]
  })
}

resource "aws_iam_role_policy" "replication_policy" {
  name = "s3-replication-policy-${random_string.suffix.result}"
  role = aws_iam_role.replication_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "s3:GetReplicationConfiguration",
          "s3:ListBucket"
        ]
        Resource = [
          aws_s3_bucket.document_management.arn
        ]
      },
      {
        Effect = "Allow"
        Action = [
          "s3:ReplicateObject",
          "s3:ReplicateDelete",
          "s3:ReplicateTags"
        ]
        Resource = [
          "arn:aws:s3:::document-management-backup-${random_string.suffix.result}/*"
        ]
      }
    ]
  })
}

resource "random_string" "suffix" {
  length  = 8
  special = false
  upper   = false
}

resource "aws_s3_bucket_policy" "document_management" {
  bucket = aws_s3_bucket.document_management.id
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "AllowAppUploads"
        Effect    = "Allow"
        Principal = {
          AWS = "arn:aws:iam::${data.aws_caller_identity.current.account_id}:role/DocumentAppRole"
        }
        Action = [
          "s3:PutObject",
          "s3:DeleteObject",
          "s3:DeleteObjectVersion"
        ]
        Resource = [
          aws_s3_bucket.document_management.arn,
          "${aws_s3_bucket.document_management.arn}/*"
        ]
      }
    ]
  })
}

data "aws_caller_identity" "current" {}