pragma solidity ^0.8.0;

contract DecentralizedExchange {
    address public owner;
    mapping(address => uint256) public tokenBalances;
    mapping(address => uint256) public liquidityProviderBalances;

    constructor() {
        owner = msg.sender;
    }

    function addLiquidity(uint256 _tokenAmount, uint256 _ethAmount) external payable {
        require(_tokenAmount > 0 && _ethAmount > 0, "Both amounts must be greater than zero");
        
        uint256 totalLiquidity = totalSupply();
        if (totalLiquidity == 0) {
            liquidityProviderBalances[msg.sender] = _tokenAmount + _ethAmount;
            tokenBalances[address(this)] += _tokenAmount;
            payable(address(this)).transfer(_ethAmount);
        } else {
            uint256 ethPerToken = totalLiquidity / tokenBalances[address(this)];
            require(_ethAmount >= ethPerToken * _tokenAmount, "Insufficient ETH sent");
            
            liquidityProviderBalances[msg.sender] += _tokenAmount + _ethAmount;
            tokenBalances[address(this)] += _tokenAmount;
            payable(address(this)).transfer(_ethAmount);
        }
    }

    function removeLiquidity(uint256 _liquidityAmount) external {
        require(liquidityProviderBalances[msg.sender] >= _liquidityAmount, "Insufficient liquidity");
        
        uint256 totalLiquidity = totalSupply();
        uint256 tokenAmount = (_liquidityAmount * tokenBalances[address(this)]) / totalLiquidity;
        uint256 ethAmount = (_liquidityAmount * address(this).balance) / totalLiquidity;
        
        liquidityProviderBalances[msg.sender] -= _liquidityAmount;
        tokenBalances[address(this)] -= tokenAmount;
        payable(msg.sender).transfer(ethAmount);
    }

    function swapTokens(uint256 _tokenIn, uint256 _minTokenOut) external {
        require(_tokenIn > 0 && _minTokenOut > 0, "Both amounts must be greater than zero");
        
        uint256 tokenBalance = tokenBalances[address(this)];
        uint256 ethBalance = address(this).balance;
        
        uint256 ethForTokens = (ethBalance * _tokenIn) / (tokenBalance + _tokenIn);
        require(ethForTokens > 0, "Insufficient liquidity");
        
        uint256 tokensOut = tokenBalance - ((ethBalance - ethForTokens) * tokenBalance) / ethBalance;
        require(tokensOut >= _minTokenOut, "Slippage check failed");
        
        tokenBalances[msg.sender] -= _tokenIn;
        tokenBalances[address(this)] += tokensOut;
        payable(msg.sender).transfer(ethForTokens);
    }

    function totalSupply() public view returns (uint256) {
        return liquidityProviderBalances[msg.sender];
    }
}