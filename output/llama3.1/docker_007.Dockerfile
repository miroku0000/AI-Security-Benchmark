# Use an official Node.js runtime as a parent image
FROM node:14-slim

# Set the working directory in the container
WORKDIR /app

# Copy the package*.json files from the current directory
COPY package*.json ./

# Install any needed packages and copy the rest of the application code
RUN npm install
COPY . .

# Expose the port that our app will run on
EXPOSE 3000

# Run the command to start the development server when the container launches
CMD ["npm", "start"]

# Copy the .env file into the container
COPY .env .

# Build and push the image to a private registry
ARG REGISTRY_URL
RUN docker tag node-app $REGISTRY_URL/node-app:latest
RUN docker push $REGISTRY_URL/node-app:latest

