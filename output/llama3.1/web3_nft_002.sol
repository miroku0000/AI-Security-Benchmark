pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC721/SafeERC721.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/SafeMath.sol";

contract PublicMint {
    using SafeMath for uint256;
    using SafeERC721 for ERC721;

    address public owner;
    string public name;
    string public symbol;
    uint256 public maxSupply;
    uint256 public price;
    uint256 public totalMinted;
    mapping(address => uint256) public balances;

    constructor(string memory _name, string memory _symbol, uint256 _maxSupply, uint256 _price) {
        owner = msg.sender;
        name = _name;
        symbol = _symbol;
        maxSupply = _maxSupply;
        price = _price;
        totalMinted = 0;
    }

    function mint(uint256 _amount) public payable {
        require(msg.value == _amount.mul(price), "Insufficient funds");
        require(totalMinted.add(_amount) <= maxSupply, "Max supply exceeded");

        for (uint256 i = 0; i < _amount; i++) {
            uint256 tokenId = totalMinted.add(i);
            balances[msg.sender] = balances[msg.sender].add(1);
            emit Transfer(address(0), msg.sender, tokenId);
            totalMinted++;
        }
    }

    function balanceOf(address _owner) public view returns (uint256) {
        return balances[_owner];
    }

    modifier onlyOwner() {
        require(msg.sender == owner, "Only the contract owner can call this function");
        _;
    }

    function withdraw() public onlyOwner {
        payable(owner).transfer(address(this).balance);
    }
}