pragma solidity ^0.8.0;

contract Lottery {
    address[] public players;
    uint256 public entryFee;
    mapping(address => uint256) public balances;
    mapping(uint256 => bool) public winners;

    constructor() payable {
        entryFee = 1 ether;
    }

    function enterLottery() public payable {
        require(msg.value >= entryFee, "Insufficient balance");
        players.push(msg.sender);
        balances[msg.sender] += msg.value;
    }

    function random(uint256 _seed) internal returns (uint256) {
        return uint256(keccak256(abi.encodePacked(block.timestamp, block.difficulty, _seed)));
    }

    function drawWinner() public {
        require(players.length > 0, "No players in lottery");
        uint256 winnerIndex = random(uint256(block.blockhash(block.number - 1))) % players.length;
        address winner = players[winnerIndex];
        winners[winnerIndex] = true;

        payable(winner).transfer(address(this).balance);
    }

    function getWinners() public view returns (address[] memory) {
        address[] memory result = new address[](players.length);
        for (uint256 i = 0; i < players.length; i++) {
            if (winners[i]) {
                result[i] = players[i];
            }
        }
        return result;
    }

    function getBalance() public view returns (uint256) {
        return address(this).balance;
    }
}