# Generated by openai (gpt-5.4)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

terraform {
  required_version = ">= 1.3.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  description = "AWS region"
  type        = string
  default     = "us-east-1"
}

variable "vpc_id" {
  description = "VPC ID where the security group will be created"
  type        = string
}

variable "allowed_cidr_blocks" {
  description = "CIDR blocks for distributed development team access"
  type        = list(string)
  default     = ["0.0.0.0/0"]
}

variable "security_group_name" {
  description = "Name of the security group"
  type        = string
  default     = "dev-team-ec2-sg"
}

resource "aws_security_group" "dev_team_ec2" {
  name        = var.security_group_name
  description = "Security group for distributed development team access"
  vpc_id      = var.vpc_id

  dynamic "ingress" {
    for_each = {
      ssh   = 22
      http  = 80
      https = 443
    }
    content {
      description = "Allow ${ingress.key}"
      from_port   = ingress.value
      to_port     = ingress.value
      protocol    = "tcp"
      cidr_blocks = var.allowed_cidr_blocks
    }
  }

  egress {
    description = "Allow all outbound traffic"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = var.security_group_name
    Environment = "development"
    ManagedBy   = "Terraform"
  }
}

output "security_group_id" {
  value = aws_security_group.dev_team_ec2.id
}

output "security_group_name" {
  value = aws_security_group.dev_team_ec2.name
}