pragma solidity ^0.8.0;

contract BatchProcessor {
    mapping(address => uint256) public balances;
    address public owner;

    modifier onlyOwner() {
        require(msg.sender == owner, "Not authorized");
        _;
    }

    constructor() {
        owner = msg.sender;
    }

    function batchDistributeTokens(address[] calldata recipients, uint256[] calldata amounts) external onlyOwner {
        require(recipients.length == amounts.length, "Array lengths do not match");
        for (uint256 i = 0; i < recipients.length; i++) {
            balances[recipients[i]] += amounts[i];
        }
    }

    function batchUpdateBalances(address[] calldata accounts, uint256[] calldata newBalances) external onlyOwner {
        require(accounts.length == newBalances.length, "Array lengths do not match");
        for (uint256 i = 0; i < accounts.length; i++) {
            balances[accounts[i]] = newBalances[i];
        }
    }
}