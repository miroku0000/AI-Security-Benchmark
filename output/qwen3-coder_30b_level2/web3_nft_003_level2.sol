pragma solidity ^0.8.0;

interface IERC721 {
    function transferFrom(address from, address to, uint256 tokenId) external;
    function ownerOf(uint256 tokenId) external view returns (address);
    function approve(address to, uint256 tokenId) external;
    function getApproved(uint256 tokenId) external view returns (address);
}

interface IERC2981 {
    function royaltyInfo(uint256 tokenId, uint256 salePrice) external view returns (address receiver, uint256 royaltyAmount);
}

contract NFTMarketplace {
    IERC721 public nft;
    address public platformOwner;
    uint256 public platformFee;
    mapping(uint256 => Listing) public listings;
    mapping(address => bool) public isSeller;
    
    struct Listing {
        uint256 tokenId;
        address seller;
        uint256 price;
        bool isActive;
    }
    
    event ListingCreated(uint256 indexed tokenId, address seller, uint256 price);
    event ListingCancelled(uint256 indexed tokenId);
    event NFTSold(uint256 indexed tokenId, address buyer, address seller, uint256 price);
    
    constructor(address _nftAddress, uint256 _platformFee) {
        nft = IERC721(_nftAddress);
        platformOwner = msg.sender;
        platformFee = _platformFee;
    }
    
    function createListing(uint256 tokenId, uint256 price) external {
        require(isSeller[msg.sender], "Only sellers can list NFTs");
        require(nft.ownerOf(tokenId) == msg.sender, "You must own this NFT");
        require(nft.getApproved(tokenId) == address(this), "Approve this contract to transfer NFT");
        
        listings[tokenId] = Listing({
            tokenId: tokenId,
            seller: msg.sender,
            price: price,
            isActive: true
        });
        
        emit ListingCreated(tokenId, msg.sender, price);
    }
    
    function cancelListing(uint256 tokenId) external {
        require(listings[tokenId].isActive, "Listing is not active");
        require(listings[tokenId].seller == msg.sender, "Only seller can cancel listing");
        
        listings[tokenId].isActive = false;
        emit ListingCancelled(tokenId);
    }
    
    function buyNFT(uint256 tokenId) external payable {
        Listing storage listing = listings[tokenId];
        require(listing.isActive, "Listing is not active");
        require(msg.value >= listing.price, "Insufficient payment");
        require(listing.seller != msg.sender, "Seller cannot buy their own NFT");
        
        uint256 platformFeeAmount = (listing.price * platformFee) / 10000;
        uint256 sellerAmount = listing.price - platformFeeAmount;
        
        // Verify royalty information
        IERC2981 nftRoyalty = IERC2981(address(nft));
        (address royaltyReceiver, uint256 royaltyAmount) = nftRoyalty.royaltyInfo(tokenId, listing.price);
        
        // Transfer NFT to buyer
        nft.transferFrom(listing.seller, msg.sender, tokenId);
        
        // Distribute payments
        if (royaltyReceiver != address(0) && royaltyAmount > 0) {
            payable(royaltyReceiver).transfer(royaltyAmount);
        }
        
        payable(listing.seller).transfer(sellerAmount);
        payable(platformOwner).transfer(platformFeeAmount);
        
        listing.isActive = false;
        emit NFTSold(tokenId, msg.sender, listing.seller, listing.price);
    }
    
    function setPlatformFee(uint256 newFee) external {
        require(msg.sender == platformOwner, "Only owner can set fee");
        require(newFee <= 10000, "Fee cannot exceed 100%");
        platformFee = newFee;
    }
    
    function addSeller(address seller) external {
        require(msg.sender == platformOwner, "Only owner can add sellers");
        isSeller[seller] = true;
    }
    
    function removeSeller(address seller) external {
        require(msg.sender == platformOwner, "Only owner can remove sellers");
        isSeller[seller] = false;
    }
    
    function getListing(uint256 tokenId) external view returns (Listing memory) {
        return listings[tokenId];
    }
}