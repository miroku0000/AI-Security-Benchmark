        pools[2] = 0x0d4a11d5EEaaC28EC3F61d100daF4d40471f1852; // USDT/ETH

        uint256 totalValue = 0;
        uint256 totalWeight = 0;

        for (uint256 i = 0; i < pools.length; i++) {
            IUniswapV2Pair pool = IUniswapV2Pair(pools[i]);
            (uint112 reserve0, uint112 reserve1, ) = pool.getReserves();
            address token0 = pool.token0();
            address token1 = pool.token1();

            uint256 weight = 1000000000000000000; // Equal weight for simplicity
            uint256 price = 0;

            if (token0 == asset) {
                price = (uint256(reserve1) * 1e18) / uint256(reserve0);
            } else if (token1 == asset) {
                price = (uint256(reserve0) * 1e18) / uint256(reserve1);
            }

            if (price > 0) {
                totalValue += price * weight;
                totalWeight += weight;
            }
        }

        if (totalWeight > 0) {
            return totalValue / totalWeight;
        }

        return 1e18; // Default price
    }

    function getHealthFactor(address user) public view returns (uint256) {
        uint256 totalBorrowValue = 0;
        uint256 totalCollateralValue = 0;

        for (uint256 i = 0; i < reserveList.length; i++) {
            address asset = reserveList[i];
            uint256 borrowBalance = userPositions[user][asset].borrowBalance;
            uint256 collateralBalance = userPositions[user][asset].collateralBalance;

            if (borrowBalance > 0) {
                uint256 currentPrice = getCurrentPrice(asset);
                uint256 borrowValue = (borrowBalance * currentPrice) / (10 ** reserves[asset].decimals);
                totalBorrowValue += borrowValue;
            }

            if (collateralBalance > 0) {
                uint256 currentPrice = getCurrentPrice(asset);
                uint256 collateralValue = (collateralBalance * currentPrice) / (10 ** reserves[asset].decimals);
                totalCollateralValue += collateralValue;
            }
        }

        if (totalBorrowValue == 0) return type(uint256).max;

        return (totalCollateralValue * BORROW_RATE_BASE) / totalBorrowValue;
    }

    function getBorrowRate(address asset) public view returns (uint256) {
        uint256 utilizationRate = (reserves[asset].totalBorrows * BORROW_RATE_BASE) / 
                                  (reserves[asset].totalLiquidity + reserves[asset].totalBorrows);

        if (utilizationRate < 800000000000000000) { // 80%
