            liquidityRate: 0,
            reserveFactor: reserveFactor,
            asset: asset,
            decimals: decimals,
            collateralFactor: collateralFactor,
            liquidationThreshold: liquidationThreshold,
            liquidationBonus: liquidationBonus
        });

        isReserve[asset] = true;
        reserveList.push(asset);
    }

    function deposit(address asset, uint256 amount) external {
        require(isReserve[asset], "Asset not supported");
        require(amount > 0, "Invalid amount");

        IERC20(asset).transferFrom(msg.sender, address(this), amount);
        reserves[asset].totalLiquidity += amount;

        userPositions[msg.sender][asset].collateralBalance += amount;
        userPositions[msg.sender][asset].isActive = true;

        emit Deposit(msg.sender, asset, amount);
    }

    function withdraw(address asset, uint256 amount) external {
        require(isReserve[asset], "Asset not supported");
        require(amount > 0, "Invalid amount");
        require(userPositions[msg.sender][asset].collateralBalance >= amount, "Insufficient balance");

        userPositions[msg.sender][asset].collateralBalance -= amount;
        reserves[asset].totalLiquidity -= amount;

        IERC20(asset).transfer(msg.sender, amount);

        emit Withdraw(msg.sender, asset, amount);
    }

    function borrow(address asset, uint256 amount) external {
        require(isReserve[asset], "Asset not supported");
        require(amount > 0, "Invalid amount");
        require(reserves[asset].totalLiquidity >= amount, "Insufficient liquidity");

        uint256 borrowBalance = userPositions[msg.sender][asset].borrowBalance;
        uint256 collateralBalance = userPositions[msg.sender][asset].collateralBalance;

        uint256 currentPrice = getCurrentPrice(asset);
        uint256 requiredCollateral = (amount * BORROW_RATE_BASE) / reserves[asset].collateralFactor;

        if (collateralBalance < requiredCollateral) {
            revert("Insufficient collateral");
        }

        reserves[asset].totalBorrows += amount;
        reserves[asset].totalLiquidity -= amount;
        userPositions[msg.sender][asset].borrowBalance += amount;

        IERC20(asset).transfer(msg.sender, amount);

        emit Borrow(msg.sender, asset, amount);
    }

    function repay(address asset, uint256 amount) external {
        require(isReserve[asset], "Asset not supported");
        require(amount > 0, "Invalid amount");
        require(userPositions[msg.sender][asset].borrowBalance >= amount, "Insufficient borrow balance");

        userPositions[msg.sender][asset].borrowBalance -= amount;
        reserves[asset].totalBorrows -= amount;
        reserves[asset].totalLiquidity += amount;

        IERC20(asset).transferFrom(msg.sender, address(this), amount);

        emit Repay(msg.sender, asset, amount);
    }

    function liquidate(
        address user,
        address asset,
        address collateralAsset,
        uint256 amount
    ) external {
        require(isReserve[asset], "Asset not supported");
        require(isReserve[collateralAsset], "Collateral asset not supported");
        require(amount > 0, "Invalid amount");

        uint256 userBorrowBalance = userPositions[user][asset].borrowBalance;
        uint256 userCollateralBalance = userPositions[user][collateralAsset].collateralBalance;

        require(userBorrowBalance > 0, "No borrow balance");
        require(userCollateralBalance > 0, "No collateral balance");

        uint256 currentPrice = getCurrentPrice(asset);
        uint256 collateralPrice = getCurrentPrice(collateralAsset);

        uint256 borrowValue = (userBorrowBalance * currentPrice) / (10 ** reserves[asset].decimals);
        uint256 collateralValue = (userCollateralBalance * collateralPrice) / (10 ** reserves[collateralAsset].decimals);

        uint256 liquidationThresholdValue = (borrowValue * reserves[asset].liquidationThreshold) / BORROW_RATE_BASE;

        require(collateralValue >= liquidationThresholdValue, "Not under liquidation threshold");

        uint256 liquidationBonus = (amount * reserves[asset].liquidationBonus) / BORROW_RATE_BASE;
        uint256 liquidationAmount = amount + liquidationBonus;

        require(liquidationAmount <= userCollateralBalance, "Insufficient collateral");

        userPositions[user][collateralAsset].collateralBalance -= liquidationAmount;
        reserves[collateralAsset].totalLiquidity -= liquidationAmount;

        userPositions[user][asset].borrowBalance -= amount;
        reserves[asset].totalBorrows -= amount;

        IERC20(collateralAsset).transfer(msg.sender, liquidationAmount);

        emit Liquidate(user, asset, msg.sender, amount);
    }

    function getCurrentPrice(address asset) public view returns (uint256) {
        // Simple price oracle using Uniswap V2 pool ratios
        // This is a simplified version - in production, use multiple sources
        address[] memory pools = new address[](3);
        pools[0] = 0x16b9a82891338f9bA80E03d3710Ea02747478359; // USDC/ETH
