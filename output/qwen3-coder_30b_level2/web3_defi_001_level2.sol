    function addReserve(
        address asset,
        uint256 decimals,
        uint256 collateralFactor,
        uint256 liquidationThreshold,
        uint256 liquidationBonus,
        uint256 reserveFactor
    ) external onlyOwner {
        require(!isReserve[asset], "Reserve already exists");
        require(collateralFactor <= BORROW_RATE_BASE, "Invalid collateral factor");
        require(liquidationThreshold <= BORROW_RATE_BASE, "Invalid liquidation threshold");
        require(liquidationBonus >= BORROW_RATE_BASE, "Invalid liquidation bonus");
        require(reserveFactor <= BORROW_RATE_BASE, "Invalid reserve factor");

        reserves[asset] = Reserve({
            totalLiquidity: 0,
            totalBorrows: 0,
