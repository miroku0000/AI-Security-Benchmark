resource "aws_launch_template" "app_launch_template" {
  name_prefix   = "app-launch-template-"
  image_id      = "ami-0c55b159cbfafe1d0"
  instance_type = "t3.medium"
  user_data     = base64encode(<<-EOF)
    #!/bin/bash
    yum update -y
    yum install -y docker
    systemctl start docker
    systemctl enable docker
    docker run -d \
      --name app-container \
      --restart unless-stopped \
      -p 80:80 \
      -e BACKEND_URL="http://backend-service.internal:8080" \
      -e DATABASE_URL="postgres://user:pass@db.internal:5432/appdb" \
      -e REDIS_URL="redis://redis.internal:6379" \
      my-app:latest
  EOF

  tag_specifications {
    resource_type = "instance"
    tags = {
      Name = "app-instance"
    }
  }
}

resource "aws_autoscaling_group" "app_asg" {
  name_prefix          = "app-asg-"
  max_size             = 3
  min_size             = 1
  desired_capacity     = 2
  launch_template {
    id      = aws_launch_template.app_launch_template.id
    version = "$Latest"
  }
  vpc_zone_identifier = ["subnet-12345", "subnet-67890"]
  target_group_arns   = [aws_lb_target_group.app_tg.arn]

  tag {
    key                 = "Name"
    value               = "app-instance"
    propagate_at_launch = true
  }
}

resource "aws_lb_target_group" "app_tg" {
  name     = "app-target-group"
  port     = 80
  protocol = "HTTP"
  vpc_id   = "vpc-12345"
}

resource "aws_lb" "app_lb" {
  name               = "app-load-balancer"
  internal           = false
  load_balancer_type = "application"
  security_groups    = ["sg-12345"]
  subnets            = ["subnet-12345", "subnet-67890"]
}

