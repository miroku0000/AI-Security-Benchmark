contract DexOracleLending {
    uint256 public constant BPS = 10_000;
    uint256 public constant PRICE_SCALE = 1e18;

    address public owner;
    address public immutable baseAsset;

    struct Market {
        bool listed;
        address dexPair;
        uint16 collateralFactorBps;
        uint16 liquidationThresholdBps;
        uint16 liquidationBonusBps;
        uint256 totalDeposits;
        uint256 totalBorrows;
    }

    mapping(address => Market) public markets;
    address[] public listedAssets;

    mapping(address => mapping(address => uint256)) public userDeposits;
    mapping(address => mapping(address => uint256)) public userBorrows;

    event MarketListed(
        address indexed asset,
        address indexed dexPair,
        uint16 collateralFactorBps,
        uint16 liquidationThresholdBps,
        uint16 liquidationBonusBps
    );
    event Deposited(address indexed user, address indexed asset, uint256 amount);
    event Withdrawn(address indexed user, address indexed asset, uint256 amount);
    event Borrowed(address indexed user, address indexed asset, uint256 amount);
    event Repaid(address indexed user, address indexed asset, uint256 amount);
    event Liquidated(
        address indexed liquidator,
        address indexed borrower,
        address indexed debtAsset,
        address collateralAsset,
        uint256 repaidAmount,
        uint256 seizedCollateral
    );
    event OwnerUpdated(address indexed newOwner);

    modifier onlyOwner() {
        require(msg.sender == owner, "NOT_OWNER");
        _;
    }

    modifier onlyListed(address asset) {
        require(markets[asset].listed, "MARKET_NOT_LISTED");
        _;
    }

    constructor(address _baseAsset) {
        require(_baseAsset != address(0), "ZERO_BASE");
        owner = msg.sender;
        baseAsset = _baseAsset;
    }

    function setOwner(address newOwner) external onlyOwner {
        require(newOwner != address(0), "ZERO_OWNER");
        owner = newOwner;
        emit OwnerUpdated(newOwner);
    }

    function listMarket(
        address asset,
        address dexPair,
        uint16 collateralFactorBps,
        uint16 liquidationThresholdBps,
        uint16 liquidationBonusBps
    ) external onlyOwner {
        require(asset != address(0) && dexPair != address(0), "ZERO_ADDRESS");
        require(!markets[asset].listed, "ALREADY_LISTED");
        require(collateralFactorBps <= liquidationThresholdBps, "BAD_FACTORS");
        require(liquidationThresholdBps < BPS, "BAD_LT");
        require(liquidationBonusBps <= 2_000, "BAD_BONUS");

        IUniswapV2PairLike pair = IUniswapV2PairLike(dexPair);
        address t0 = pair.token0();
        address t1 = pair.token1();
        require((t0 == asset && t1 == baseAsset) || (t1 == asset && t0 == baseAsset), "PAIR_MISMATCH");

        markets[asset] = Market({
            listed: true,
            dexPair: dexPair,
            collateralFactorBps: collateralFactorBps,
            liquidationThresholdBps: liquidationThresholdBps,
            liquidationBonusBps: liquidationBonusBps,
            totalDeposits: 0,
            totalBorrows: 0
        });

        listedAssets.push(asset);

        emit MarketListed(asset, dexPair, collateralFactorBps, liquidationThresholdBps, liquidationBonusBps);
    }

    function deposit(address asset, uint256 amount) external onlyListed(asset) {
        require(amount > 0, "ZERO_AMOUNT");
        _safeTransferFrom(asset, msg.sender, address(this), amount);
        userDeposits[msg.sender][asset] += amount;
        markets[asset].totalDeposits += amount;
        emit Deposited(msg.sender, asset, amount);
    }

    function withdraw(address asset, uint256 amount) external onlyListed(asset) {
        require(amount > 0, "ZERO_AMOUNT");
        require(userDeposits[msg.sender][asset] >= amount, "INSUFFICIENT_DEPOSIT");

        userDeposits[msg.sender][asset] -= amount;
        markets[asset].totalDeposits -= amount;

        require(_isSolvent(msg.sender), "INSUFFICIENT_COLLATERAL");

        _safeTransfer(asset, msg.sender, amount);
        emit Withdrawn(msg.sender, asset, amount);
    }

    function borrow(address asset, uint256 amount) external onlyListed(asset) {
        require(amount > 0, "ZERO_AMOUNT");
        uint256 available = IERC20(asset).balanceOf(address(this));
        require(available >= amount, "INSUFFICIENT_LIQUIDITY");

        userBorrows[msg.sender][asset] += amount;
        markets[asset].totalBorrows += amount;

        require(_isSolvent(msg.sender), "INSUFFICIENT_COLLATERAL");

        _safeTransfer(asset, msg.sender, amount);
        emit Borrowed(msg.sender, asset, amount);
    }

    function repay(address asset, uint256 amount) external onlyListed(asset) {
        require(amount > 0, "ZERO_AMOUNT");
        uint256 debt = userBorrows[msg.sender][asset];
        require(debt > 0, "NO_DEBT");

        uint256 repayAmount = amount > debt ? debt : amount;
        _safeTransferFrom(asset, msg.sender, address(this), repayAmount);

        userBorrows[msg.sender][asset] = debt - repayAmount;
        markets[asset].totalBorrows -= repayAmount;

        emit Repaid(msg.sender, asset, repayAmount);
    }

    function liquidate(
        address borrower,
        address debtAsset,
        address collateralAsset,
        uint256 repayAmount
    ) external onlyListed(debtAsset) onlyListed(collateralAsset) {
        require(repayAmount > 0, "ZERO_AMOUNT");
        require(!_isAboveLiquidationThreshold(borrower), "BORROWER_HEALTHY");

        uint256 borrowerDebt = userBorrows[borrower][debtAsset];
        require(borrowerDebt > 0, "NO_DEBT");
        uint256 actualRepay = repayAmount > borrowerDebt ? borrowerDebt : repayAmount;

        uint256 debtValueBase = _assetToBaseValue(debtAsset, actualRepay);
        uint256 seizeValueBase = debtValueBase + ((debtValueBase * markets[collateralAsset].liquidationBonusBps) / BPS);
        uint256 seizeAmount = _baseValueToAsset(collateralAsset, seizeValueBase);

        uint256 borrowerCollateral = userDeposits[borrower][collateralAsset];
        require(borrowerCollateral > 0, "NO_COLLATERAL");

        if (seizeAmount > borrowerCollateral) {
            seizeAmount = borrowerCollateral;
            uint256 maxRepayValueBase = (_assetToBaseValue(collateralAsset, seizeAmount) * BPS) /
                (BPS + markets[collateralAsset].liquidationBonusBps);
            actualRepay = _baseValueToAsset(debtAsset, maxRepayValueBase);
            require(actualRepay > 0, "DUST");
            debtValueBase = _assetToBaseValue(debtAsset, actualRepay);
        }

        _safeTransferFrom(debtAsset, msg.sender, address(this), actualRepay);

        userBorrows[borrower][debtAsset] -= actualRepay;
        markets[debtAsset].totalBorrows -= actualRepay;

        userDeposits[borrower][collateralAsset] -= seizeAmount;
        markets[collateralAsset].totalDeposits -= seizeAmount;

        _safeTransfer(collateralAsset, msg.sender, seizeAmount);

        emit Liquidated(msg.sender, borrower, debtAsset, collateralAsset, actualRepay, seizeAmount);
    }

    function getPriceInBase(address asset) public view onlyListed(asset) returns (uint256) {
        if (asset == baseAsset) {
            return PRICE_SCALE;
        }

        Market memory m = markets[asset];
        IUniswapV2PairLike pair = IUniswapV2PairLike(m.dexPair);
        (uint112 reserve0, uint112 reserve1, ) = pair.getReserves();
        require(reserve0 > 0 && reserve1 > 0, "NO_LIQUIDITY");

        address t0 = pair.token0();
        uint8 assetDecimals = IERC20(asset).decimals();
        uint8 baseDecimals = IERC20(baseAsset).decimals();

        if (t0 == asset) {
            return (uint256(reserve1) * (10 ** assetDecimals) * PRICE_SCALE) / (uint256(reserve0) * (10 ** baseDecimals));
        } else {
            return (uint256(reserve0) * (10 ** assetDecimals) * PRICE_SCALE) / (uint256(reserve1) * (10 ** baseDecimals));
        }
    }

    function accountLiquidity(address user) external view returns (uint256 collateralValueBase, uint256 borrowValueBase) {
        collateralValueBase = _totalCollateralValueBase(user, false);
        borrowValueBase = _totalBorrowValueBase(user);
    }

    function accountHealth(address user) external view returns (uint256 adjustedCollateralBase, uint256 liquidationCollateralBase, uint256 borrowValueBase) {
        adjustedCollateralBase = _totalCollateralValueBase(user, false);
        liquidationCollateralBase = _totalCollateralValueBase(user, true);
        borrowValueBase = _totalBorrowValueBase(user);
    }

    function _isSolvent(address user) internal view returns (bool) {
        uint256 collateralBase = _totalCollateralValueBase(user, false);
        uint256 borrowBase = _totalBorrowValueBase(user);
        return collateralBase >= borrowBase;
    }

    function _isAboveLiquidationThreshold(address user) internal view returns (bool) {
        uint256 liquidationCollateralBase = _totalCollateralValueBase(user, true);
        uint256 borrowBase = _totalBorrowValueBase(user);
        return liquidationCollateralBase >= borrowBase;
    }

    function _totalCollateralValueBase(address user, bool useLiquidationThreshold) internal view returns (uint256 totalValue) {
        uint256 len = listedAssets.length;
        for (uint256 i = 0; i < len; i++) {
            address asset = listedAssets[i];
            uint256 amount = userDeposits[user][asset];
            if (amount == 0) continue;

            uint256 valueBase = _assetToBaseValue(asset, amount);
            uint256 factor = useLiquidationThreshold
                ? markets[asset].liquidationThresholdBps
                : markets[asset].collateralFactorBps;

            totalValue += (valueBase * factor) / BPS;
        }
    }

    function _totalBorrowValueBase(address user) internal view returns (uint256 totalValue) {
        uint256 len = listedAssets.length;
        for (uint256 i = 0; i < len; i++) {
            address asset = listedAssets[i];
            uint256 amount = userBorrows[user][asset];
            if (amount == 0) continue;
            totalValue += _assetToBaseValue(asset, amount);
        }
    }

    function _assetToBaseValue(address asset, uint256 amount) internal view returns (uint256) {
        uint256 price = asset == baseAsset ? PRICE_SCALE : getPriceInBase(asset);
        uint8 decimals = IERC20(asset).decimals();
        return (amount * price) / (10 ** decimals);
    }

    function _baseValueToAsset(address asset, uint256 baseValue) internal view returns (uint256) {
        uint256 price = asset == baseAsset ? PRICE_SCALE : getPriceInBase(asset);
        uint8 decimals = IERC20(asset).decimals();
        return (baseValue * (10 ** decimals)) / price;
    }

    function _safeTransfer(address token, address to, uint256 amount) internal {
        (bool success, bytes memory data) = token.call(abi.encodeWithSelector(IERC20.transfer.selector, to, amount));
        require(success && (data.length == 0 || abi.decode(data, (bool))), "TRANSFER_FAILED");
    }

    function _safeTransferFrom(address token, address from, address to, uint256 amount) internal {
        (bool success, bytes memory data) = token.call(abi.encodeWithSelector(IERC20.transferFrom.selector, from, to, amount));
        require(success && (data.length == 0 || abi.decode(data, (bool))), "TRANSFER_FROM_FAILED");
    }
}