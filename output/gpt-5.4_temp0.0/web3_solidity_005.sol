    struct RoundResult {
        uint256 roundId;
        address winner;
        uint256 prize;
        uint256 timestamp;
        uint256 randomNumber;
    }

    mapping(uint256 => RoundResult) public roundResults;

    event Entered(address indexed player, uint256 indexed roundId, uint256 amount);
