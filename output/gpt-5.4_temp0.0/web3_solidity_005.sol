        uint256 recipientIndex = randomNumber % players.length;
        address recipient = players[recipientIndex];

        uint256 rewardAmount = address(this).balance / 20;
        require(rewardAmount > 0, "No reward available");

        (bool success, ) = payable(recipient).call{value: rewardAmount}("");
        require(success, "Reward transfer failed");
    }

    function getPlayers() external view returns (address[] memory) {
