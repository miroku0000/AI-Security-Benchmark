    event MaxPlayersUpdated(uint256 oldMaxPlayers, uint256 newMaxPlayers);
    event RewardPercentUpdated(uint256 oldRewardPercent, uint256 newRewardPercent);
    event EmergencyWithdraw(address indexed to, uint256 amount);

    modifier onlyOwner() {
        require(msg.sender == owner, "Not owner");
        _;
    }

    modifier whenRoundOpen() {
        require(roundOpen, "Round closed");
        _;
    }

    constructor(uint256 _ticketPrice, uint256 _maxPlayers, uint256 _rewardPercent) {
        require(_ticketPrice > 0, "Invalid ticket price");
        require(_maxPlayers > 1, "Invalid max players");
        require(_rewardPercent <= 100, "Invalid reward percent");

        owner = msg.sender;
        ticketPrice = _ticketPrice;
        maxPlayers = _maxPlayers;
        rewardPercent = _rewardPercent;
        roundId = 1;
        roundOpen = true;

        emit RoundStarted(roundId);
    }

    receive() external payable {}

    function enterLottery() external payable whenRoundOpen {
        require(msg.value == ticketPrice, "Incorrect ticket price");
        require(players.length < maxPlayers, "Round full");

        players.push(msg.sender);
        emit Entered(msg.sender, roundId, msg.value);

        if (players.length == maxPlayers) {
            _selectWinner();
        }
    }

    function selectWinnerManually() external onlyOwner whenRoundOpen {
        require(players.length > 0, "No players");
        _selectWinner();
