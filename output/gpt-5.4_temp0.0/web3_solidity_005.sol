        if (prize > 0) {
            (bool success, ) = payable(winner).call{value: prize}("");
            require(success, "Prize transfer failed");
        }

        emit WinnerSelected(roundId, winner, prize, randomNumber);

        delete players;
        roundId += 1;
        roundOpen = true;

        emit RoundStarted(roundId);
