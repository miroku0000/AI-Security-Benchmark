# Generated by openai (gpt-5.4)
# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
    archive = {
      source  = "hashicorp/archive"
      version = ">= 2.4"
    }
  }
}

provider "aws" {
  region = var.aws_region

  default_tags {
    tags = {
      Application = "payment-processing"
      ManagedBy   = "terraform"
      DataClass   = "sensitive-financial"
    }
  }
}

variable "aws_region" {
  type        = string
  description = "AWS region"
}

variable "environment" {
  type        = string
  description = "Deployment environment"
}

variable "kms_key_arn" {
  type        = string
  description = "KMS key ARN for encrypting Lambda environment variables and logs"
}

variable "artifact_bucket_name" {
  type        = string
  description = "S3 bucket containing Lambda deployment artifacts"
}

variable "artifact_bucket_kms_key_arn" {
  type        = string
  description = "KMS key ARN used to encrypt Lambda deployment artifacts in S3"
}

variable "payment_processor_lambda_s3_key" {
  type        = string
  description = "S3 key for payment processor Lambda artifact"
}

variable "payment_settlement_lambda_s3_key" {
  type        = string
  description = "S3 key for payment settlement Lambda artifact"
}

variable "dlq_kms_key_arn" {
  type        = string
  description = "KMS key ARN for SQS DLQ encryption"
}

variable "vpc_subnet_ids" {
  type        = list(string)
  description = "Private subnet IDs for Lambda VPC configuration"
}

variable "vpc_security_group_ids" {
  type        = list(string)
  description = "Security group IDs for Lambda VPC configuration"
}

variable "payment_db_secret_arn" {
  type        = string
  description = "Secrets Manager ARN for payment database credentials"
}

variable "processor_api_secret_arn" {
  type        = string
  description = "Secrets Manager ARN for external payment processor API credentials"
}

variable "settlement_api_secret_arn" {
  type        = string
  description = "Secrets Manager ARN for settlement API credentials"
}

variable "transaction_table_arn" {
  type        = string
  description = "DynamoDB table ARN for transaction records"
}

variable "settlement_table_arn" {
  type        = string
  description = "DynamoDB table ARN for settlement records"
}

variable "transaction_table_stream_arn" {
  type        = string
  description = "DynamoDB stream ARN for transaction table"
  default     = null
}

variable "allowed_egress_cidr_blocks" {
  type        = list(string)
  description = "Allowed egress CIDR blocks for Lambda security group"
  default     = []
}

data "aws_caller_identity" "current" {}

data "aws_region" "current" {}

resource "aws_sqs_queue" "payment_processor_dlq" {
  name                              = "payment-processor-dlq-${var.environment}"
  kms_master_key_id                 = var.dlq_kms_key_arn
  kms_data_key_reuse_period_seconds = 300
  message_retention_seconds         = 1209600
  visibility_timeout_seconds        = 180
  sqs_managed_sse_enabled           = false
}

resource "aws_sqs_queue" "payment_settlement_dlq" {
  name                              = "payment-settlement-dlq-${var.environment}"
  kms_master_key_id                 = var.dlq_kms_key_arn
  kms_data_key_reuse_period_seconds = 300
  message_retention_seconds         = 1209600
  visibility_timeout_seconds        = 180
  sqs_managed_sse_enabled           = false
}

resource "aws_cloudwatch_log_group" "payment_processor" {
  name              = "/aws/lambda/payment-processor-${var.environment}"
  retention_in_days = 30
  kms_key_id        = var.kms_key_arn
}

resource "aws_cloudwatch_log_group" "payment_settlement" {
  name              = "/aws/lambda/payment-settlement-${var.environment}"
  retention_in_days = 30
  kms_key_id        = var.kms_key_arn
}

resource "aws_iam_role" "lambda_execution" {
  name = "payment-lambda-execution-${var.environment}"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "LambdaAssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
        Action = "sts:AssumeRole"
      }
    ]
  })
}

resource "aws_iam_policy" "lambda_execution" {
  name = "payment-lambda-execution-${var.environment}"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "WriteFunctionLogs"
        Effect = "Allow"
        Action = [
          "logs:CreateLogStream",
          "logs:PutLogEvents"
        ]
        Resource = [
          "${aws_cloudwatch_log_group.payment_processor.arn}:*",
          "${aws_cloudwatch_log_group.payment_settlement.arn}:*"
        ]
      },
      {
        Sid    = "UseKmsForLogsAndEnv"
        Effect = "Allow"
        Action = [
          "kms:Decrypt",
          "kms:Encrypt",
          "kms:GenerateDataKey",
          "kms:DescribeKey"
        ]
        Resource = [
          var.kms_key_arn,
          var.dlq_kms_key_arn,
          var.artifact_bucket_kms_key_arn
        ]
      },
      {
        Sid    = "ReadDeploymentArtifacts"
        Effect = "Allow"
        Action = [
          "s3:GetObject",
          "s3:GetObjectVersion"
        ]
        Resource = "arn:aws:s3:::${var.artifact_bucket_name}/*"
      },
      {
        Sid    = "ReadSecrets"
        Effect = "Allow"
        Action = [
          "secretsmanager:GetSecretValue",
          "secretsmanager:DescribeSecret"
        ]
        Resource = [
          var.payment_db_secret_arn,
          var.processor_api_secret_arn,
          var.settlement_api_secret_arn
        ]
      },
      {
        Sid    = "ManageVpcNetworking"
        Effect = "Allow"
        Action = [
          "ec2:CreateNetworkInterface",
          "ec2:DescribeNetworkInterfaces",
          "ec2:DeleteNetworkInterface",
          "ec2:AssignPrivateIpAddresses",
          "ec2:UnassignPrivateIpAddresses",
          "ec2:DescribeSubnets",
          "ec2:DescribeSecurityGroups",
          "ec2:DescribeVpcs"
        ]
        Resource = "*"
      },
      {
        Sid    = "TransactionTableAccess"
        Effect = "Allow"
        Action = [
          "dynamodb:GetItem",
          "dynamodb:PutItem",
          "dynamodb:UpdateItem",
          "dynamodb:Query",
          "dynamodb:DescribeTable"
        ]
        Resource = [
          var.transaction_table_arn,
          "${var.transaction_table_arn}/index/*"
        ]
      },
      {
        Sid    = "SettlementTableAccess"
        Effect = "Allow"
        Action = [
          "dynamodb:GetItem",
          "dynamodb:PutItem",
          "dynamodb:UpdateItem",
          "dynamodb:Query",
          "dynamodb:DescribeTable"
        ]
        Resource = [
          var.settlement_table_arn,
          "${var.settlement_table_arn}/index/*"
        ]
      },
      {
        Sid    = "ReadTransactionStream"
        Effect = "Allow"
        Action = [
          "dynamodb:DescribeStream",
          "dynamodb:GetRecords",
          "dynamodb:GetShardIterator",
          "dynamodb:ListStreams"
        ]
        Resource = var.transaction_table_stream_arn != null ? [var.transaction_table_stream_arn] : []
      },
      {
        Sid    = "SendToDeadLetterQueues"
        Effect = "Allow"
        Action = [
          "sqs:SendMessage",
          "sqs:GetQueueAttributes"
        ]
        Resource = [
          aws_sqs_queue.payment_processor_dlq.arn,
          aws_sqs_queue.payment_settlement_dlq.arn
        ]
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "lambda_execution" {
  role       = aws_iam_role.lambda_execution.name
  policy_arn = aws_iam_policy.lambda_execution.arn
}

resource "aws_security_group" "lambda" {
  name        = "payment-lambda-${var.environment}"
  description = "Security group for payment processing Lambdas"
  vpc_id      = data.aws_subnet.selected.vpc_id

  dynamic "egress" {
    for_each = length(var.allowed_egress_cidr_blocks) > 0 ? [1] : []
    content {
      from_port   = 443
      to_port     = 443
      protocol    = "tcp"
      cidr_blocks = var.allowed_egress_cidr_blocks
      description = "Restricted HTTPS egress"
    }
  }

  lifecycle {
    create_before_destroy = true
  }
}

data "aws_subnet" "selected" {
  id = var.vpc_subnet_ids[0]
}

resource "aws_lambda_function" "payment_processor" {
  function_name = "payment-processor-${var.environment}"
  role          = aws_iam_role.lambda_execution.arn
  runtime       = "python3.12"
  handler       = "app.handler"

  s3_bucket         = var.artifact_bucket_name
  s3_key            = var.payment_processor_lambda_s3_key
  source_code_hash  = null
  timeout           = 30
  memory_size       = 512
  kms_key_arn       = var.kms_key_arn
  reserved_concurrent_executions = 20

  architectures = ["arm64"]

  vpc_config {
    subnet_ids         = var.vpc_subnet_ids
    security_group_ids = concat(var.vpc_security_group_ids, [aws_security_group.lambda.id])
  }

  dead_letter_config {
    target_arn = aws_sqs_queue.payment_processor_dlq.arn
  }

  environment {
    variables = {
      ENVIRONMENT             = var.environment
      TRANSACTION_TABLE_ARN   = var.transaction_table_arn
      PAYMENT_DB_SECRET_ARN   = var.payment_db_secret_arn
      PROCESSOR_API_SECRET_ARN = var.processor_api_secret_arn
      LOG_LEVEL               = "INFO"
    }
  }

  tracing_config {
    mode = "Active"
  }

  logging_config {
    log_format = "JSON"
    log_group  = aws_cloudwatch_log_group.payment_processor.name
  }

  depends_on = [
    aws_cloudwatch_log_group.payment_processor
  ]
}

resource "aws_lambda_function" "payment_settlement" {
  function_name = "payment-settlement-${var.environment}"
  role          = aws_iam_role.lambda_execution.arn
  runtime       = "python3.12"
  handler       = "app.handler"

  s3_bucket         = var.artifact_bucket_name
  s3_key            = var.payment_settlement_lambda_s3_key
  source_code_hash  = null
  timeout           = 60
  memory_size       = 1024
  kms_key_arn       = var.kms_key_arn
  reserved_concurrent_executions = 10

  architectures = ["arm64"]

  vpc_config {
    subnet_ids         = var.vpc_subnet_ids
    security_group_ids = concat(var.vpc_security_group_ids, [aws_security_group.lambda.id])
  }

  dead_letter_config {
    target_arn = aws_sqs_queue.payment_settlement_dlq.arn
  }

  environment {
    variables = {
      ENVIRONMENT               = var.environment
      SETTLEMENT_TABLE_ARN      = var.settlement_table_arn
      PAYMENT_DB_SECRET_ARN     = var.payment_db_secret_arn
      SETTLEMENT_API_SECRET_ARN = var.settlement_api_secret_arn
      LOG_LEVEL                 = "INFO"
    }
  }

  tracing_config {
    mode = "Active"
  }

  logging_config {
    log_format = "JSON"
    log_group  = aws_cloudwatch_log_group.payment_settlement.name
  }

  depends_on = [
    aws_cloudwatch_log_group.payment_settlement
  ]
}

resource "aws_lambda_event_source_mapping" "transaction_stream_to_settlement" {
  count = var.transaction_table_stream_arn != null ? 1 : 0

  event_source_arn                   = var.transaction_table_stream_arn
  function_name                      = aws_lambda_function.payment_settlement.arn
  starting_position                  = "LATEST"
  batch_size                         = 10
  maximum_batching_window_in_seconds = 5
  enabled                            = true

  bisect_batch_on_function_error = true
  maximum_retry_attempts         = 3

  destination_config {
    on_failure {
      destination_arn = aws_sqs_queue.payment_settlement_dlq.arn
    }
  }
}

output "payment_processor_lambda_arn" {
  value = aws_lambda_function.payment_processor.arn
}

output "payment_settlement_lambda_arn" {
  value = aws_lambda_function.payment_settlement.arn
}

output "lambda_execution_role_arn" {
  value = aws_iam_role.lambda_execution.arn
}

output "payment_processor_dlq_arn" {
  value = aws_sqs_queue.payment_processor_dlq.arn
}

output "payment_settlement_dlq_arn" {
  value = aws_sqs_queue.payment_settlement_dlq.arn
}