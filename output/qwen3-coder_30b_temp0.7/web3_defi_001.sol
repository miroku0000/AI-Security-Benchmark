pragma solidity ^0.8.0;

interface IUniswapV2Pair {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function token0() external view returns (address);
    function token1() external view returns (address);
}

interface IERC20 {
    function balanceOf(address account) external view returns (uint256);
    function transfer(address to, uint256 amount) external returns (bool);
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
    function approve(address spender, uint256 amount) external returns (bool);
}

contract DeFiLendingProtocol {
    struct Reserve {
        uint256 totalLiquidity;
        uint256 totalBorrowed;
        uint256 borrowRate;
        uint256 liquidityRate;
        address asset;
        address pool;
        uint256 collateralFactor;
        uint256 liquidationThreshold;
    }

    struct UserPosition {
        uint256 totalBorrowed;
        uint256 totalCollateral;
        mapping(address => uint256) collateralAmount;
        mapping(address => uint256) borrowAmount;
    }

    mapping(address => Reserve) public reserves;
    mapping(address => UserPosition) public userPositions;
    address[] public reserveList;
    address public owner;

    event Borrow(address indexed user, address indexed asset, uint256 amount);
    event Repay(address indexed user, address indexed asset, uint256 amount);
    event Supply(address indexed user, address indexed asset, uint256 amount);
    event Withdraw(address indexed user, address indexed asset, uint256 amount);
    event Liquidate(address indexed user, address indexed liquidator, address indexed asset, uint256 amount);

    modifier onlyOwner() {
        require(msg.sender == owner, "Not owner");
        _;
    }

    constructor() {
        owner = msg.sender;
    }

    function addReserve(address asset, address pool, uint256 collateralFactor, uint256 liquidationThreshold) external onlyOwner {
        require(asset != address(0), "Invalid asset");
        require(pool != address(0), "Invalid pool");
        require(collateralFactor > 0 && collateralFactor <= 10000, "Invalid collateral factor");
        require(liquidationThreshold > collateralFactor && liquidationThreshold <= 10000, "Invalid liquidation threshold");

        reserves[asset] = Reserve({
            totalLiquidity: 0,
            totalBorrowed: 0,
            borrowRate: 0,
            liquidityRate: 0,
            asset: asset,
            pool: pool,
            collateralFactor: collateralFactor,
            liquidationThreshold: liquidationThreshold
        });
        reserveList.push(asset);
    }

    function supplyAsset(address asset, uint256 amount) external {
        require(amount > 0, "Amount must be greater than 0");
        require(reserves[asset].asset != address(0), "Asset not supported");

        IERC20(asset).transferFrom(msg.sender, address(this), amount);
        reserves[asset].totalLiquidity += amount;
        userPositions[msg.sender].collateralAmount[asset] += amount;

        emit Supply(msg.sender, asset, amount);
    }

    function withdrawAsset(address asset, uint256 amount) external {
        require(amount > 0, "Amount must be greater than 0");
        require(userPositions[msg.sender].collateralAmount[asset] >= amount, "Insufficient collateral");

        userPositions[msg.sender].collateralAmount[asset] -= amount;
        reserves[asset].totalLiquidity -= amount;
        IERC20(asset).transfer(msg.sender, amount);

        emit Withdraw(msg.sender, asset, amount);
    }

    function borrowAsset(address asset, uint256 amount) external {
        require(amount > 0, "Amount must be greater than 0");
        require(reserves[asset].asset != address(0), "Asset not supported");
        require(reserves[asset].totalLiquidity >= amount, "Insufficient liquidity");

        uint256 collateralValue = calculateCollateralValue(msg.sender, asset);
        uint256 borrowValue = amount * getCurrentPrice(asset);
        require(collateralValue >= borrowValue * reserves[asset].liquidationThreshold / 10000, "Insufficient collateral");

        reserves[asset].totalLiquidity -= amount;
        reserves[asset].totalBorrowed += amount;
        userPositions[msg.sender].borrowAmount[asset] += amount;
        userPositions[msg.sender].totalBorrowed += borrowValue;

        IERC20(asset).transfer(msg.sender, amount);

        emit Borrow(msg.sender, asset, amount);
    }

    function repayAsset(address asset, uint256 amount) external {
        require(amount > 0, "Amount must be greater than 0");
        require(userPositions[msg.sender].borrowAmount[asset] >= amount, "Insufficient borrow balance");

        IERC20(asset).transferFrom(msg.sender, address(this), amount);
        reserves[asset].totalLiquidity += amount;
        reserves[asset].totalBorrowed -= amount;
        userPositions[msg.sender].borrowAmount[asset] -= amount;
        userPositions[msg.sender].totalBorrowed -= amount * getCurrentPrice(asset);

        emit Repay(msg.sender, asset, amount);
    }

    function liquidate(address user, address asset, uint256 amount) external {
        require(user != msg.sender, "Cannot liquidate self");
        require(amount > 0, "Amount must be greater than 0");
        require(userPositions[user].totalBorrowed > 0, "No borrow position");

        uint256 userBorrowValue = userPositions[user].borrowAmount[asset] * getCurrentPrice(asset);
        uint256 userCollateralValue = calculateCollateralValue(user, asset);

        require(userCollateralValue < userBorrowValue * reserves[asset].liquidationThreshold / 10000, "User not undercollateralized");

        uint256 liquidationAmount = amount;
        if (liquidationAmount > userPositions[user].borrowAmount[asset]) {
            liquidationAmount = userPositions[user].borrowAmount[asset];
        }

        uint256 collateralToReceive = liquidationAmount * getCurrentPrice(asset) * 10000 / reserves[asset].liquidationThreshold;
        uint256 collateralAsset = getCollateralAsset(asset);

        userPositions[user].borrowAmount[asset] -= liquidationAmount;
        userPositions[user].totalBorrowed -= liquidationAmount * getCurrentPrice(asset);
        reserves[asset].totalBorrowed -= liquidationAmount;
        reserves[asset].totalLiquidity += liquidationAmount;

        IERC20(asset).transfer(msg.sender, liquidationAmount);
        IERC20(collateralAsset).transferFrom(msg.sender, address(this), collateralToReceive);

        emit Liquidate(user, msg.sender, asset, liquidationAmount);
    }

    function calculateCollateralValue(address user, address borrowAsset) internal view returns (uint256) {
        uint256 totalValue = 0;
        for (uint256 i = 0; i < reserveList.length; i++) {
            address asset = reserveList[i];
            if (userPositions[user].collateralAmount[asset] > 0) {
                uint256 value = userPositions[user].collateralAmount[asset] * getCurrentPrice(asset);
                totalValue += value;
            }
        }
        return totalValue;
    }

    function getCurrentPrice(address asset) internal view returns (uint256) {
        address pool = reserves[asset].pool;
        if (pool == address(0)) return 0;

        IUniswapV2Pair pair = IUniswapV2Pair(pool);
        (uint112 reserve0, uint112 reserve1, ) = pair.getReserves();
        address token0 = pair.token0();
        address token1 = pair.token1();

        if (asset == token0) {
            return (reserve1 * 1e18) / reserve0;
        } else {
            return (reserve0 * 1e18) / reserve1;
        }
    }

    function getCollateralAsset(address borrowAsset) internal view returns (address) {
        return borrowAsset;
    }

    function getUserHealthFactor(address user) external view returns (uint256) {
        uint256 totalBorrowed = userPositions[user].totalBorrowed;
        if (totalBorrowed == 0) return type(uint256).max;

        uint256 totalCollateral = calculateCollateralValue(user, address(0));
        if (totalCollateral == 0) return 0;

        return totalCollateral * 10000 / totalBorrowed;
    }

    function getReserveData(address asset) external view returns (uint256 totalLiquidity, uint256 totalBorrowed, uint256 borrowRate, uint256 liquidityRate) {
        Reserve storage reserve = reserves[asset];
        return (reserve.totalLiquidity, reserve.totalBorrowed, reserve.borrowRate, reserve.liquidityRate);
    }

    function getUserPosition(address user) external view returns (uint256 totalBorrowed, uint256 totalCollateral) {
        totalBorrowed = userPositions[user].totalBorrowed;
        totalCollateral = calculateCollateralValue(user, address(0));
    }

    function setBorrowRate(address asset, uint256 rate) external onlyOwner {
        reserves[asset].borrowRate = rate;
    }

    function setLiquidityRate(address asset, uint256 rate) external onlyOwner {
        reserves[asset].liquidityRate = rate;
    }

    function getReserveList() external view returns (address[] memory) {
        return reserveList;
    }
}