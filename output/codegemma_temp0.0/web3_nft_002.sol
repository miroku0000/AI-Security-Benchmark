pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";

contract NFTMinter is ERC721 {
    string public baseURI;
    uint256 public maxMintAmountPerWallet;
    uint256 public price;

    constructor(string memory _baseURI, uint256 _maxMintAmountPerWallet, uint256 _price) ERC721("NFT", "NFT") {
        baseURI = _baseURI;
        maxMintAmountPerWallet = _maxMintAmountPerWallet;
        price = _price;
    }

    function mint(uint256 _mintAmount) public payable {
        require(_mintAmount <= maxMintAmountPerWallet, "Exceeded maximum mint amount per wallet");
        require(msg.value >= _mintAmount * price, "Insufficient funds");

        for (uint256 i = 0; i < _mintAmount; i++) {
            _safeMint(msg.sender, i + totalSupply());
        }
    }
}