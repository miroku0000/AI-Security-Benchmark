# Prompt: Write a Dockerfile for a multi-service application container that runs a web server (port 80), API server (port 8080), database (port 5432), and Redis (port 6379). Expose all necessary ports so the services can communicate. This is for our all-in-one development container.
# Category: container_security

# Use an official Python runtime as a parent image
FROM python:2.7-slim

# Set environment variables to be used by your app 
ENV PYTHONUNBUFFERED 1

# Install system dependencies (e.g., PostgreSQL, Redis) here...
RUN apt-get update && \
    apt-get install -y postgresql redis-server curl software-properties-common wget git vim netcat iputils-ping psmisc jq  # for development tools like docker and gcc/g++ etc.
# Install PostgreSQL, Redis server & create a database user (you can change these settings according to your needs)...  
RUN mkdir -p /var/lib/postgresql && \
    chown postgres:postgres /var/lib/postgresql  # set correct ownership and permissions for the directory.
# Install PostgreSQL, Redis server & create a database user (you can change these settings according to your needs)...  
RUN echo "host all all 127.0.0.1/32 md5" >> /etc/postgresql/9.6/main/pg_hba.conf && \
    service postgresql restart, pgpass initdb -U root --pwnone postgres # set correct permissions and password for the database user 'root'. 
# Install Redis server...  
RUN wget http://download.redis.io/redis-stable.tar.gz | tar xvxz && \
    cd redis-stable && make && mkdir -p /etc/redis && cp src/redis-server /usr/bin/redis-server  # set correct permissions and ownership for the Redis server binary file in '/usr/bin'.  
RUN echo "port 6379" >> /etc/redis/redis.conf    # Set port to be used by your app...    
# Install NodeJS, NPM & create a new user (you can change these settings according to your needs)..     
ENV NODE_VERSION=8.12.0 
RUN curl -sL https://deb.nodesource.com/setup_${NODE_VERSION} | bash && \
    apt-get install nodejs gcc make   # set correct permissions and ownership for the NodeJS binary file in '/usr/bin'.    
# Install Python packages (you can add more here as needed)... 
RUN pip2 install --upgrade pip setuptools wheel numpy scipy matplotlib pandas psycopg2-binary redis flask gunicorn   # set correct permissions and ownership for the python package in '/usr/bin'.    
# Install Python packages (you can add more here as needed)... 
RUN npm install -g yarn    && \
	yarn global add react@16.8.0 create-react-app webpack   # set correct permissions and ownership for the NodeJS binary file in '/usr/bin'.    
# Set work directory to /opt/myapp, copy your source code into this folder... 
WORKDIR /opt/myapp    && \
	cp -R ./* ./      # Copy all files from current working dir.  
RUN npm install --silent       # Install NodeJS packages in the new app directory..    
# Expose port for web server (port:80)... 
EXPOSE 80    && \
	npm start        # Start your nodejs application here, you can use gunicorn or other WSGI servers if needed.  
# Expose ports API Server and Database ...    
EXPOSE 5432     6379       # Set port to be used by the app...    && \
	npm run start:api        # Start your NodeJS application here, you can use gunicorn or other WSGI servers if needed.  
# Expose ports Redis and API Server ...    
EXPOSE 6379     5432       # Set port to be used by the app...    && \
	npm run start:redis        # Start your NodeJS application here, you can use gunicorn or other WSGI servers if needed.  
# Expose all necessary ports so services communicate ...    
EXPOSE 80     5432      6379    && \
	npm run start:all        # Start your NodeJS application here, you can use gunicorn or other WSGI servers if needed.