   acl    = "public-read" # replace public read/write according to your needs (default is private)
}
resource "aws_s3_bucket_website" "staticWebsiteBucket" { 
    bucket = aws_s3_bucket.staticwebsite.id   // reference the S3 Bucket created above by its ID, not name as it's unique across all existing buckets in AWS s3 service (not globally) and cannot start or end with an empty string - otherwise you will get a 'InvalidRequest'.
    index_document = "index.html"  // replace this value according to your HTML file location inside the bucket, for example: my-website/index.html if it's in root directory of S3 Bucket (default is an empty string)  
}
resource "aws_cloudfront_distribution" "staticWebsiteDistribution" {  // CloudFront Distribtion resource to host the static website bucket, replace with your AWS region and name. You can also add other parameters like default cache behavior etc as per requirement in Terraform documentation for aws cloud front distribution
    s3_bucket = aws_s3_bucket.staticwebsite.id  // reference S3 Bucket created above by its ID, not the bucket's name (it should be globally unique across all existing buckets) and cannot start or end with an empty string - otherwise AWS throws a 'InvalidRequest'.
    s3_key    = "index.html"   // replace this value according to your HTML file location inside S3 Bucket, for example: my-website/index.html if it's in root directory of bucket (default is index.html)  and cannot start or end with an empty string - otherwise AWS throws a 'InvalidRequest'.
    distribution_domain {   // replace this value according to your domain name e.g., example.com, you can also use the CloudFront Distribution Domain if it's set in aws cloud front resource (default is not provided)  and cannot start or end with an empty string - otherwise AWS throws a 'InvalidRequest'.
        name = "example-domain"   // replace this value according to your domain e.g., example.com, you can also use the CloudFront Distribution Domain if it's set in aws cloud front resource (default is not provided)  and cannot start or end with an empty string - otherwise AWS throws a 'InvalidRequest'.
    }   // End of distribution_domain block here...(you may add more parameters as per requirement). You can find all available blocks for the CloudFront Distribution in Terraform documentation. (default is not provided)  and cannot start or end with an empty string - otherwise AWS throws a 'InvalidRequest'.
}   // End of aws_cloudfront_distribution resource here...(you may add more parameters as per requirement). You can find all available blocks for the CloudFront Distribution in Terraform documentation. (default is not provided)  and cannot start or end with an empty string - otherwise AWS throws a 'InvalidRequest'.