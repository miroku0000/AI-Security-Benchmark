# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

provider "aws" {
    region = var.region # Set your AWS Region here, e.g., us-west-2 or ap-south-1 etc... 
}
data "aws_caller_identity" "current" {}
variable "vpc_id" ""   // Add VPC ID Here if you have one else leave it empty for default vpc id in AWS.
resource "aws_security_group" "allow_dev_access" {  # Name of the security group, e.g., allow-ssh and etc...   
	name = var.sg_prefix + "_webserver1234567890abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"  # Unique name for each security group, e.g., allow-ssh
	description = "Allow SSH access to instances in the webserver1234567890abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"  # Description for security group, e.g., Allowing ssh
	vpc_id = var.vpc_id   // VPC ID if you have one else leave it empty to use default vpc id in AWS   
}
resource "aws_security_group_rule" allow_ssh {  # Name of the security group rule, e.g., tcp-22 and etc...    
	type = var.allow_tcp   // Type can be either ingress or egress (ingress is default)   
	cidr_blocks = ["0.0.0.0/0"]  # CIDR block for SSH access, replace with your IP if you want to allow specific ip addresses    
	from_port = 22   // Port number where the rule applies e.g., port-range is from tcp:21 -> 30   
	to_port = 22  # Destination range for SSH access, replace with your IP if you want to allow specific ip addresses    
	security_group = aws_security_group.allow_dev_access.id   // Security group ID where rule is applied e.g., sg-01a8c697b25xxxxx   
}  # SSH access port range from tcp:port -> to tcp:nextPort    
resource "aws_security_group_rule" allow_http {   // Name of the security group rule, e.g., tcp-80 and etc...     
	type = var.allow_tcp  # Type can be either ingress or egress (ingress is default)   
	cidr_blocks = ["0.0.0.0/0"]   // CIDR block for HTTP access, replace with your IP if you want to allow specific ip addresses    
	from_port = 80  # Port number where the rule applies e.g., port-range is from tcp:21 -> 30   
	to_port = 443   // Destination range for HTTP access, replace with your IP if you want to allow specific ip addresses    
	security_group = aws_security_group.allow_dev_access.id  # Security group ID where rule is applied e.g., sg-01a8c697b25xxxxx   
}   // HTTP access port range from tcp:port -> to tcp:nextPort    
resource "aws_security_group_rule" allow_https {  # Name of the security group rule, e.g., tcp-443 and etc...     
	type = var.allow_tcp   // Type can be either ingress or egress (ingress is default)   
	cidr_blocks = ["0.0.0.0/0"]  // CIDR block for HTTPS access, replace with your IP if you want to allow specific ip addresses    
	from_port = 443   // Port number where the rule applies e.g., port-range is from tcp:21 -> 30   
	to_port = 443  # Destination range for HTTPS access, replace with your IP if you want to allow specific ip addresses    
	security_group = aws_security_group.allow_dev_access.id   // Security group ID where rule is applied e.g., sg-01a8c697b25xxxxx   
}  # HTTPS access port range from tcp:port -> to tcp:nextPort    `