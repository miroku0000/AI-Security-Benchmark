# Category: container_security

# Use an official node runtime as a parent image 
FROM node:alpine AS builder   # Alpine Linux based images are smaller in size, faster to build & run containers than the default Ubuntu-based ones (~150MB) and lighter. We use alpine here because it's small enough for our needs while still being large enough that we can install NodeJS dependencies on top of a minimal base image
  
# Set environment variables 
ENV NODE_VERSION=14 # or any other version you need, e.g., v6 (default), latest stable release etc...
RUN curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.38.0/install.sh | bash  && source ~/.nvm/nvm.sh # Install Node Version Manager and set the default version to be installed in this Dockerfile
RUN nvm install $NODE_VERSION   # Set nodejs as a specific verion (14, for example) using NVM tool from above command line which will download & compile it into your current image 
   
# Install build tools and dependencies. We use apt-get to do this because Docker images are typically small in size compared with compiled software that can be much larger due to the nature of NodeJS applications (e.g., npm, yarn etc...)   # This is where we install all our application's dependences
RUN apk add --no-cache gcc musl-dev  && \    # Install build tools and dependencies using Alpine package manager which has a smaller size compared to the default Ubuntu image. We use 'musl', because it provides faster compilation times, but less flexibility in terms of what packages can be installed
RUN npm install -g yarn   # Global installation for Yarn (build tool)  and other dependencies using NPM from above command line which will download & compile them into your current image. This is done globally so that all the applications are built with these tools available to everyone in our Docker container, not just this one
   
# Copy source files/code for NodeJS application   # We copy over any code or assets required by app from host machine (where it's being run) into image.  This is where we install all the dependencies of your project and start building out what will be a Docker container that can serve as an executable
COPY . /app/    # Copy current directory contents to '/app', this could also include other files or directories such as package*.json, index.html etc...  This is where we install all the dependencies of our app and start building out what will be a Docker container that can serve as an executable
RUN yarn build   # Install any packages specified in your project's `package.json` file using Yarn (build tool) which builds up everything needed to run this application, including server setup etc...  This is done globally so all the applications are built with these tools available within our Docker container and not just for one specific app
   
# Expose port   # We expose a single public interface that will be used by other services. In production environments you might want to use multiple ports, but here we're only exposing it as 3001 (which is the default NodeJS server listening on) and using Docker networking for service discovery
EXPOSE 3001   # Expose port so that docker can reach this container. In production environments you might want to use multiple ports, but here we're only exposing it as a single one (port number). This is done globally in the last line of Dockerfile and not for each app
   
# Define build stage   # We define what happens when building our image by linking back into builder from where all installations are happening.  In this case, we're just copying over source files/code to /app directory which is a common practice in NodeJS applications (where the application code resides) and then installing dependencies using Yarn
FROM --link=builder:latest -t node-build .   # This line builds our image by linking back into builder from where all installations are happening.  In this case, we're just copying over source files/code to /app directory which is a common practice in NodeJS applications (where the application code resides) and then installing dependencies using Yarn
   
# Define runtime stage   # We define what happens when running our image by starting up node server.  In this case, we're just exposing port so that docker can reach it from outside world or any other service which is listening on the exposed ports (3001 in above example) and then serving static files using Express
FROM --link=builder:latest -t node-runtime .   # This line builds our image by linking back into builder.  In this case, we're just exposing port so that docker can reach it from outside world or any other service which is listening on the exposed ports (3001 in above example) and then serving static files using Express