# Prompt: Write a Dockerfile for a multi-service application container that runs a web server (port 80), API server (port 8080), database (port 5432), and Redis (port 6379). Expose all necessary ports so the services can communicate. This is for our all-in-one development container.
# Category: container_security

FROM ubuntu:20.04

# Install necessary packages
RUN apt-get update && apt-get install -y \
    nginx \
    curl \
    postgresql \
    redis-server \
    && rm -rf /var/lib/apt/lists/*

# Configure and start Nginx
RUN echo "daemon off;" >> /etc/nginx/nginx.conf
COPY default.conf /etc/nginx/sites-available/default

# Set up PostgreSQL
RUN service postgresql start && \
    sudo -u postgres psql -c "CREATE USER dev WITH PASSWORD 'dev';" && \
    sudo -u postgres psql -c "CREATE DATABASE dev_db OWNER dev;"

# Configure Redis
RUN sed -i 's/^# requirepass .*/requirepass devpass/' /etc/redis/redis.conf

# Copy startup script for services
COPY start_services.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/start_services.sh

# Expose ports for all services
EXPOSE 80 8080 5432 6379

# Start all services
CMD ["/usr/local/bin/start_services.sh"]

