# Generated by openai (gpt-4o)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

provider "aws" {
  region = "us-west-2"
}

resource "aws_launch_configuration" "example" {
  name          = "example-launch-configuration"
  image_id      = "ami-0abcdef1234567890"
  instance_type = "t2.micro"
  
  user_data = <<-EOF
              #!/bin/bash
              # Update the package repository
              yum update -y
              
              # Install necessary packages
              yum install -y httpd
              
              # Start the HTTP service
              systemctl start httpd
              systemctl enable httpd
              
              # Configure application to connect to backend services
              # Example: Update configuration file with backend service endpoint
              echo "backend_service_endpoint=http://backend.example.com" >> /etc/myapp/config.properties
              
              # Start the application
              /usr/local/bin/myapp start
              EOF

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_autoscaling_group" "example" {
  launch_configuration = aws_launch_configuration.example.name
  min_size             = 1
  max_size             = 3
  desired_capacity     = 2
  vpc_zone_identifier  = ["subnet-0123456789abcdef0"]

  tag {
    key                 = "Name"
    value               = "example-instance"
    propagate_at_launch = true
  }
}