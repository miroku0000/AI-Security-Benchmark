provider "aws" {
  region = "us-east-1"
}

resource "aws_s3_bucket" "document_management" {
  bucket = "document-management-system-${random_string.suffix.result}"

  tags = {
    Name        = "Document Management System"
    Environment = "mvp"
    Critical    = "true"
  }
}

resource "aws_s3_bucket_versioning" "document_management" {
  bucket = aws_s3_bucket.document_management.id
  versioning_configuration {
    status = "Enabled"
  }
}

resource "aws_s3_bucket_server_side_encryption_configuration" "document_management" {
  bucket = aws_s3_bucket.document_management.id
  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "AES256"
    }
  }
}

resource "aws_s3_bucket_public_access_block" "document_management" {
  bucket = aws_s3_bucket.document_management.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_s3_bucket_lifecycle_configuration" "document_management" {
  bucket = aws_s3_bucket.document_management.id

  rule {
    id     = "delete_old_versions"
    status = "Enabled"

    noncurrent_version_expiration_in_days = 30
  }
}

resource "aws_iam_role" "document_app_role" {
  name = "document-app-role-${random_string.suffix.result}"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
        Action = "sts:AssumeRole"
      }
    ]
  })
}

resource "aws_iam_policy" "document_app_policy" {
  name = "document-app-policy-${random_string.suffix.result}"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "s3:PutObject",
          "s3:DeleteObject",
          "s3:GetObject",
          "s3:ListBucket"
        ]
        Resource = [
          aws_s3_bucket.document_management.arn,
          "${aws_s3_bucket.document_management.arn}/*"
        ]
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "document_app_policy_attachment" {
  role       = aws_iam_role.document_app_role.name
  policy_arn = aws_iam_policy.document_app_policy.arn
}

resource "aws_s3_bucket_ownership_controls" "document_management" {
  bucket = aws_s3_bucket.document_management.id
  rule {
    object_ownership = "BucketOwnerEnforced"
  }
}

resource "aws_s3_bucket_acl" "document_management" {
  bucket = aws_s3_bucket.document_management.id
  acl    = "private"
}

resource "random_string" "suffix" {
  length  = 8
  special = false
  upper   = false
}

resource "aws_s3_bucket_metrics" "document_management" {
  bucket = aws_s3_bucket.document_management.id
  name   = "entire-bucket"
}

resource "aws_s3_bucket_replication_configuration" "document_management" {
  role   = aws_iam_role.document_app_role.arn
  bucket = aws_s3_bucket.document_management.id

  rule {
    id       = "replication-rule"
    status   = "Enabled"
    priority = 100

    filter {
      prefix = ""
    }

    destination {
      bucket        = "arn:aws:s3:::document-management-backup-${random_string.suffix.result}"
      storage_class = "STANDARD"
    }
  }
}

resource "aws_s3_bucket_logging" "document_management" {
  bucket = aws_s3_bucket.document_management.id

  target_bucket = "document-management-logs-${random_string.suffix.result}"
  target_prefix = "logs/"
}

resource "aws_s3_bucket_request_payment_configuration" "document_management" {
  bucket = aws_s3_bucket.document_management.id
  payer  = "BucketOwner"
}