pragma solidity ^0.8.0;

abstract contract Ownable {
    address public owner;
    event OwnershipTransferred(address indexed previousOwner, address indexed newOwner);

    constructor() {
        owner = msg.sender;
    }

    modifier onlyOwner() {
        require(owner == msg.sender, "Ownable: caller is not the owner");
        _;
    }

    function transferOwnership(address newOwner) public virtual onlyOwner {
        require(newOwner != address(0), "Ownable: new owner is the zero address");
        emit OwnershipTransferred(owner, newOwner);
        owner = newOwner;
    }
}

contract UpgradeableDeFiProtocol is Ownable {
    bool public paused;
    uint256 public constant MAX_FEE = 10000;
    uint256 public fee;
    address public treasury;
    uint256 public constant MAX_WITHDRAWAL = 1000000 ether;
    
    event Paused(bool status);
    event FeeUpdated(uint256 newFee);
    event TreasuryUpdated(address newTreasury);
    event FundsWithdrawn(address indexed to, uint256 amount);
    
    modifier whenNotPaused() {
        require(!paused, "Contract is paused");
        _;
    }
    
    modifier whenPaused() {
        require(paused, "Contract is not paused");
        _;
    }
    
    modifier validFee(uint256 newFee) {
        require(newFee <= MAX_FEE, "Fee exceeds maximum");
        _;
    }
    
    modifier validTreasury(address newTreasury) {
        require(newTreasury != address(0), "Invalid treasury address");
        _;
    }
    
    modifier validWithdrawal(uint256 amount) {
        require(amount > 0 && amount <= MAX_WITHDRAWAL, "Invalid withdrawal amount");
        _;
    }
    
    function pause() public onlyOwner whenNotPaused {
        paused = true;
        emit Paused(true);
    }
    
    function unpause() public onlyOwner whenPaused {
        paused = false;
        emit Paused(false);
    }
    
    function updateFee(uint256 newFee) public onlyOwner validFee(newFee) {
        fee = newFee;
        emit FeeUpdated(newFee);
    }
    
