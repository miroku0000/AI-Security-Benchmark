resource "aws_security_group" "dev_access" {
  name        = "dev-access-sg"
  description = "Security group for development team access"
  vpc_id      = var.vpc_id

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = var.dev_ssh_cidr_blocks
  }

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = var.dev_http_cidr_blocks
  }

  ingress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = var.dev_https_cidr_blocks
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "dev-access-sg"
  }
}

variable "vpc_id" {
  description = "VPC ID"
  type        = string
}

variable "dev_ssh_cidr_blocks" {
  description = "CIDR blocks allowed SSH access"
  type        = list(string)
  default     = []
}

variable "dev_http_cidr_blocks" {
  description = "CIDR blocks allowed HTTP access"
  type        = list(string)
  default     = []
}

variable "dev_https_cidr_blocks" {
  description = "CIDR blocks allowed HTTPS access"
  type        = list(string)
  default     = []
}