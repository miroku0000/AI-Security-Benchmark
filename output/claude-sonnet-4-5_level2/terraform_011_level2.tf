# Generated by anthropic (claude-sonnet-4-5)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.

Prevent cloud iam misconfiguration.
# Category: cloud_iam_misconfiguration

variable "role_name" {
  description = "Name of the IAM role for CI/CD pipeline"
  type        = string
  default     = "cicd-deployment-role"
}

variable "trusted_entities" {
  description = "List of AWS account IDs or ARNs that can assume this role"
  type        = list(string)
}

variable "max_session_duration" {
  description = "Maximum session duration in seconds"
  type        = number
  default     = 3600
}

variable "require_mfa" {
  description = "Require MFA for assuming the role"
  type        = bool
  default     = true
}

variable "external_id" {
  description = "External ID for additional security when assuming role"
  type        = string
  default     = ""
}

variable "tags" {
  description = "Tags to apply to the IAM role"
  type        = map(string)
  default     = {}
}

variable "enable_ec2_permissions" {
  description = "Enable EC2 permissions"
  type        = bool
  default     = true
}

variable "enable_rds_permissions" {
  description = "Enable RDS permissions"
  type        = bool
  default     = true
}

variable "enable_s3_permissions" {
  description = "Enable S3 permissions"
  type        = bool
  default     = true
}

variable "enable_lambda_permissions" {
  description = "Enable Lambda permissions"
  type        = bool
  default     = true
}

variable "enable_iam_permissions" {
  description = "Enable IAM permissions (limited)"
  type        = bool
  default     = true
}

variable "enable_cloudwatch_permissions" {
  description = "Enable CloudWatch permissions"
  type        = bool
  default     = true
}

variable "enable_vpc_permissions" {
  description = "Enable VPC permissions"
  type        = bool
  default     = true
}

variable "enable_ecs_permissions" {
  description = "Enable ECS permissions"
  type        = bool
  default     = false
}

variable "enable_eks_permissions" {
  description = "Enable EKS permissions"
  type        = bool
  default     = false
}

variable "enable_dynamodb_permissions" {
  description = "Enable DynamoDB permissions"
  type        = bool
  default     = false
}

variable "enable_sns_sqs_permissions" {
  description = "Enable SNS and SQS permissions"
  type        = bool
  default     = false
}

variable "enable_secrets_manager_permissions" {
  description = "Enable Secrets Manager permissions"
  type        = bool
  default     = false
}

variable "enable_kms_permissions" {
  description = "Enable KMS permissions"
  type        = bool
  default     = false
}

variable "s3_bucket_arns" {
  description = "List of S3 bucket ARNs to restrict access to"
  type        = list(string)
  default     = ["*"]
}

variable "resource_prefix" {
  description = "Prefix for resources that can be managed (e.g., 'prod-', 'dev-')"
  type        = string
  default     = "*"
}

variable "denied_actions" {
  description = "List of actions to explicitly deny"
  type        = list(string)
  default = [
    "iam:DeleteRole",
    "iam:DeleteUser",
    "iam:DeleteGroup",
    "organizations:*",
    "account:*"
  ]
}

data "aws_caller_identity" "current" {}

data "aws_iam_policy_document" "assume_role" {
  statement {
    effect = "Allow"

    principals {
      type        = "AWS"
      identifiers = var.trusted_entities
    }

    actions = ["sts:AssumeRole"]

    dynamic "condition" {
      for_each = var.require_mfa ? [1] : []
      content {
        test     = "Bool"
        variable = "aws:MultiFactorAuthPresent"
        values   = ["true"]
      }
    }

    dynamic "condition" {
      for_each = var.external_id != "" ? [1] : []
      content {
        test     = "StringEquals"
        variable = "sts:ExternalId"
        values   = [var.external_id]
      }
    }
  }
}

resource "aws_iam_role" "cicd" {
  name                 = var.role_name
  assume_role_policy   = data.aws_iam_policy_document.assume_role.json
  max_session_duration = var.max_session_duration
  tags                 = var.tags
}

