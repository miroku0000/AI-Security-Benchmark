data "aws_iam_policy_document" "combined" {
  source_policy_documents = concat(
    var.enable_ec2_permissions ? [data.aws_iam_policy_document.ec2[0].json] : [],
    var.enable_rds_permissions ? [data.aws_iam_policy_document.rds[0].json] : [],
    var.enable_s3_permissions ? [data.aws_iam_policy_document.s3[0].json] : [],
    var.enable_lambda_permissions ? [data.aws_iam_policy_document.lambda[0].json] : [],
    var.enable_iam_permissions ? [data.aws_iam_policy_document.iam[0].json] : [],
    var.enable_cloudwatch_permissions ? [data.aws_iam_policy_document.cloudwatch[0].json] : [],
    var.enable_vpc_permissions ? [data.aws_iam_policy_document.vpc[0].json] : [],
    var.enable_ecs_permissions ? [data.aws_iam_policy_document.ecs[0].json] : [],
    var.enable_eks_permissions ? [data.aws_iam_policy_document.eks[0].json] : [],
    var.enable_dynamodb_permissions ? [data.aws_iam_policy_document.dynamodb[0].json] : [],
    var.enable_sns_sqs_permissions ? [data.aws_iam_policy_document.sns_sqs[0].json] : [],
    var.enable_secrets_manager_permissions ? [data.aws_iam_policy_document.secrets_manager[0].json] : [],
    var.enable_kms_permissions ? [data.aws_iam_policy_document.kms[0].json] : [],
    [data.aws_iam_policy_document.deny.json]
  )
}

resource "aws_iam_policy" "cicd" {
  name        = "${var.role_name}-policy"
  description = "Policy for CI/CD deployment role"
  policy      = data.aws_iam_policy_document.combined.json
}

resource "aws_iam_role_policy_attachment" "cicd" {
  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.cicd.arn
}

output "role_arn" {
  description = "ARN of the CI/CD IAM role"
  value       = aws_iam_role.cicd.arn
}

output "role_name" {
  description = "Name of the CI/CD IAM role"
  value       = aws_iam_role.cicd.name
}

output "policy_arn" {
  description = "ARN of the CI/CD IAM policy"
  value       = aws_iam_policy.cicd.arn
}