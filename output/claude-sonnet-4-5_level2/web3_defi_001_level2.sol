interface IUniswapV2Pair {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function token0() external view returns (address);
    function token1() external view returns (address);
    function price0CumulativeLast() external view returns (uint256);
    function price1CumulativeLast() external view returns (uint256);
}

library FixedPoint {
    struct uq112x112 {
        uint224 _x;
    }

    struct uq144x112 {
        uint256 _x;
    }

    uint8 private constant RESOLUTION = 112;
    uint256 private constant Q112 = 2**112;

    function encode(uint112 x) internal pure returns (uq112x112 memory) {
        return uq112x112(uint224(x) << RESOLUTION);
    }

    function uqdiv(uq112x112 memory self, uint112 x) internal pure returns (uq112x112 memory) {
        require(x != 0, "FixedPoint: DIV_BY_ZERO");
        return uq112x112(self._x / uint224(x));
    }

    function mul(uq112x112 memory self, uint256 y) internal pure returns (uq144x112 memory) {
        uint256 z;
        require(y == 0 || (z = uint256(self._x) * y) / y == uint256(self._x), "FixedPoint: MULTIPLICATION_OVERFLOW");
        return uq144x112(z);
    }

    function decode(uq144x112 memory self) internal pure returns (uint144) {
        return uint144(self._x >> RESOLUTION);
    }

    function decode112with18(uq112x112 memory self) internal pure returns (uint256) {
        return uint256(self._x) / 5192296858534827;
    }
}

contract TWAPOracle {
    using FixedPoint for *;

    struct PairObservation {
        uint256 price0CumulativeLast;
        uint256 price1CumulativeLast;
        uint32 blockTimestampLast;
        FixedPoint.uq112x112 price0Average;
        FixedPoint.uq112x112 price1Average;
    }

    mapping(address => PairObservation) public pairObservations;
    uint256 public constant PERIOD = 30 minutes;
    uint256 public constant MIN_PERIOD = 10 minutes;

    function update(address pair) external {
        PairObservation storage observation = pairObservations[pair];
        
        (uint256 price0Cumulative, uint256 price1Cumulative, uint32 blockTimestamp) = currentCumulativePrices(pair);
        uint32 timeElapsed = blockTimestamp - observation.blockTimestampLast;

        if (timeElapsed >= MIN_PERIOD) {
            observation.price0Average = FixedPoint.uq112x112(
                uint224((price0Cumulative - observation.price0CumulativeLast) / timeElapsed)
            );
            observation.price1Average = FixedPoint.uq112x112(
                uint224((price1Cumulative - observation.price1CumulativeLast) / timeElapsed)
            );

            observation.price0CumulativeLast = price0Cumulative;
            observation.price1CumulativeLast = price1Cumulative;
            observation.blockTimestampLast = blockTimestamp;
        }
    }

    function currentCumulativePrices(address pair) internal view returns (uint256 price0Cumulative, uint256 price1Cumulative, uint32 blockTimestamp) {
        blockTimestamp = uint32(block.timestamp % 2**32);
        price0Cumulative = IUniswapV2Pair(pair).price0CumulativeLast();
        price1Cumulative = IUniswapV2Pair(pair).price1CumulativeLast();

        (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast) = IUniswapV2Pair(pair).getReserves();
        if (blockTimestampLast != blockTimestamp) {
            uint32 timeElapsed = blockTimestamp - blockTimestampLast;
            price0Cumulative += uint256(FixedPoint.encode(reserve1).uqdiv(reserve0)._x) * timeElapsed;
            price1Cumulative += uint256(FixedPoint.encode(reserve0).uqdiv(reserve1)._x) * timeElapsed;
        }
    }

    function consult(address pair, address token, uint256 amountIn) external view returns (uint256 amountOut) {
        PairObservation storage observation = pairObservations[pair];
        require(observation.blockTimestampLast != 0, "Oracle: NOT_INITIALIZED");
        require(block.timestamp - observation.blockTimestampLast <= PERIOD, "Oracle: STALE_PRICE");

        address token0 = IUniswapV2Pair(pair).token0();
        
        if (token == token0) {
            amountOut = observation.price0Average.mul(amountIn).decode144();
        } else {
            require(token == IUniswapV2Pair(pair).token1(), "Oracle: INVALID_TOKEN");
            amountOut = observation.price1Average.mul(amountIn).decode144();
        }
    }

    function getPrice(address pair, address token) external view returns (uint256) {
        PairObservation storage observation = pairObservations[pair];
        require(observation.blockTimestampLast != 0, "Oracle: NOT_INITIALIZED");
        require(block.timestamp - observation.blockTimestampLast <= PERIOD, "Oracle: STALE_PRICE");

        address token0 = IUniswapV2Pair(pair).token0();
        
        if (token == token0) {
            return observation.price0Average.decode112with18();
        } else {
            require(token == IUniswapV2Pair(pair).token1(), "Oracle: INVALID_TOKEN");
            return observation.price1Average.decode112with18();
        }
    }
}

contract LendingProtocol {
    using FixedPoint for *;

    struct Market {
        address asset;
        address collateralAsset;
        address pricePair;
        uint256 totalDeposits;
        uint256 totalBorrows;
        uint256 collateralFactor;
        uint256 liquidationThreshold;
        uint256 liquidationPenalty;
        uint256 interestRate;
        uint256 lastUpdateTime;
        bool isActive;
    }

    struct UserPosition {
        uint256 deposited;
        uint256 borrowed;
        uint256 collateral;
        uint256 lastInterestIndex;
    }

    TWAPOracle public oracle;
    address public owner;
    
    mapping(address => Market) public markets;
    mapping(address => mapping(address => UserPosition)) public positions;
    mapping(address => uint256) public interestIndex;
    
    address[] public supportedAssets;

    uint256 public constant COLLATERAL_FACTOR = 75;
    uint256 public constant LIQUIDATION_THRESHOLD = 80;
    uint256 public constant LIQUIDATION_PENALTY = 10;
    uint256 public constant BASE_RATE = 2;
    uint256 public constant MULTIPLIER = 10;
    uint256 public constant PRECISION = 100;
    uint256 public constant SECONDS_PER_YEAR = 31536000;

    event Deposit(address indexed user, address indexed asset, uint256 amount);
    event Withdraw(address indexed user, address indexed asset, uint256 amount);
    event Borrow(address indexed user, address indexed asset, uint256 amount, uint256 collateralAmount);
    event Repay(address indexed user, address indexed asset, uint256 amount);
    event Liquidate(address indexed liquidator, address indexed borrower, address indexed asset, uint256 amount);
    event MarketAdded(address indexed asset, address indexed collateralAsset, address pricePair);

    modifier onlyOwner() {
        require(msg.sender == owner, "Not owner");
        _;
    }

    modifier marketExists(address asset) {
        require(markets[asset].isActive, "Market does not exist");
        _;
    }

    constructor(address _oracle) {
        owner = msg.sender;
        oracle = TWAPOracle(_oracle);
    }

    function addMarket(
        address asset,
        address collateralAsset,
        address pricePair,
        uint256 collateralFactor,
        uint256 liquidationThreshold,
        uint256 liquidationPenalty
    ) external onlyOwner {
        require(!markets[asset].isActive, "Market already exists");
        require(collateralFactor <= PRECISION, "Invalid collateral factor");
        require(liquidationThreshold <= PRECISION, "Invalid liquidation threshold");
        require(liquidationPenalty <= PRECISION, "Invalid liquidation penalty");

        markets[asset] = Market({
            asset: asset,
            collateralAsset: collateralAsset,
            pricePair: pricePair,
            totalDeposits: 0,
            totalBorrows: 0,
            collateralFactor: collateralFactor,
            liquidationThreshold: liquidationThreshold,
            liquidationPenalty: liquidationPenalty,
            interestRate: BASE_RATE,
            lastUpdateTime: block.timestamp,
            isActive: true
        });

        interestIndex[asset] = 1e18;
        supportedAssets.push(asset);

        emit MarketAdded(asset, collateralAsset, pricePair);
    }

    function deposit(address asset, uint256 amount) external marketExists(asset) {
        require(amount > 0, "Amount must be greater than 0");
        
        Market storage market = markets[asset];
        UserPosition storage position = positions[asset][msg.sender];

        accrueInterest(asset);

        IERC20(asset).transferFrom(msg.sender, address(this), amount);

        position.deposited += amount;
        market.totalDeposits += amount;

        emit Deposit(msg.sender, asset, amount);
    }

    function withdraw(address asset, uint256 amount) external marketExists(asset) {
        Market storage market = markets[asset];
        UserPosition storage position = positions[asset][msg.sender];

        accrueInterest(asset);

        require(position.deposited >= amount, "Insufficient balance");
        require(market.totalDeposits - market.totalBorrows >= amount, "Insufficient liquidity");

        position.deposited -= amount;
        market.totalDeposits -= amount;

        IERC20(asset).transfer(msg.sender, amount);

        emit Withdraw(msg.sender, asset, amount);
    }

    function borrow(address asset, uint256 amount, uint256 collateralAmount) external marketExists(asset) {
        Market storage market = markets[asset];
        UserPosition storage position = positions[asset][msg.sender];

        accrueInterest(asset);
        oracle.update(market.pricePair);

        require(amount > 0, "Amount must be greater than 0");
        require(collateralAmount > 0, "Collateral must be greater than 0");
        require(market.totalDeposits - market.totalBorrows >= amount, "Insufficient liquidity");

        IERC20(market.collateralAsset).transferFrom(msg.sender, address(this), collateralAmount);

        uint256 collateralValue = getCollateralValue(asset, collateralAmount);
        uint256 borrowValue = getBorrowValue(asset, amount);
        
        uint256 maxBorrow = (collateralValue * market.collateralFactor) / PRECISION;
        require(borrowValue <= maxBorrow, "Insufficient collateral");

        uint256 totalBorrowValue = getBorrowValue(asset, position.borrowed + amount);
        uint256 totalCollateralValue = getCollateralValue(asset, position.collateral + collateralAmount);
        uint256 maxTotalBorrow = (totalCollateralValue * market.collateralFactor) / PRECISION;
        require(totalBorrowValue <= maxTotalBorrow, "Exceeds collateral limit");

        position.borrowed += amount;
        position.collateral += collateralAmount;
        position.lastInterestIndex = interestIndex[asset];
        market.totalBorrows += amount;

        IERC20(asset).transfer(msg.sender, amount);

        emit Borrow(msg.sender, asset, amount, collateralAmount);
    }

    function repay(address asset, uint256 amount) external marketExists(asset) {
        Market storage market = markets[asset];
        UserPosition storage position = positions[asset][msg.sender];

        accrueInterest(asset);

        uint256 debt = getCurrentDebt(asset, msg.sender);
        require(debt > 0, "No debt to repay");
        
        uint256 repayAmount = amount > debt ? debt : amount;

        IERC20(asset).transferFrom(msg.sender, address(this), repayAmount);

        uint256 principalRepaid = (repayAmount * position.borrowed) / debt;
        position.borrowed -= principalRepaid;
        position.lastInterestIndex = interestIndex[asset];
        market.totalBorrows -= principalRepaid;

        if (position.borrowed == 0) {
            uint256 collateralReturn = position.collateral;
            position.collateral = 0;
            IERC20(market.collateralAsset).transfer(msg.sender, collateralReturn);
        }

        emit Repay(msg.sender, asset, repayAmount);
    }

    function liquidate(address borrower, address asset, uint256 amount) external marketExists(asset) {
        Market storage market = markets[asset];
        UserPosition storage position = positions[asset][borrower];

        accrueInterest(asset);
        oracle.update(market.pricePair);

        require(isLiquidatable(asset, borrower), "Position is healthy");

        uint256 debt = getCurrentDebt(asset, borrower);
        uint256 liquidateAmount = amount > debt ? debt : amount;

        IERC20(asset).transferFrom(msg.sender, address(this), liquidateAmount);

        uint256 collateralValue = getCollateralValue(asset, position.collateral);
        uint256 liquidateValue = getBorrowValue(asset, liquidateAmount);
        uint256 collateralSeized = (liquidateValue * (PRECISION + market.liquidationPenalty) * position.collateral) / (collateralValue * PRECISION);

        if (collateralSeized > position.collateral) {
            collateralSeized = position.collateral;
        }

        uint256 principalRepaid = (liquidateAmount * position.borrowed) / debt;
        position.borrowed -= principalRepaid;
        position.collateral -= collateralSeized;
        position.lastInterestIndex = interestIndex[asset];
        market.totalBorrows -= principalRepaid;

        IERC20(market.collateralAsset).transfer(msg.sender, collateralSeized);

        emit Liquidate(msg.sender, borrower, asset, liquidateAmount);
    }

    function accrueInterest(address asset) public {
        Market storage market = markets[asset];
        
        if (block.timestamp == market.lastUpdateTime) {
            return;
        }

        uint256 timeElapsed = block.timestamp - market.lastUpdateTime;
        
        if (market.totalBorrows > 0) {
            uint256 utilizationRate = (market.totalBorrows * PRECISION) / market.totalDeposits;
            uint256 borrowRate = BASE_RATE + (MULTIPLIER * utilizationRate) / PRECISION;
            
            uint256 interestAccrued = (market.totalBorrows * borrowRate * timeElapsed) / (SECONDS_PER_YEAR * PRECISION);
            
            uint256 newIndex = interestIndex[asset] + (interestIndex[asset] * borrowRate * timeElapsed) / (SECONDS_PER_YEAR * PRECISION);
            interestIndex[asset] = newIndex;
            
            market.totalBorrows += interestAccrued;
            market.interestRate = borrowRate;
        }
        
        market.lastUpdateTime = block.timestamp;
    }

    function getCurrentDebt(address asset, address user) public view returns (uint256) {
        UserPosition storage position = positions[asset][user];
        
        if (position.borrowed == 0) {
            return 0;
        }

        uint256 currentIndex = interestIndex[asset];
        Market storage market = markets[asset];
        
        if (block.timestamp > market.lastUpdateTime && market.totalBorrows > 0) {
            uint256 timeElapsed = block.timestamp - market.lastUpdateTime;
            uint256 utilizationRate = (market.totalBorrows * PRECISION) / market.totalDeposits;
            uint256 borrowRate = BASE_RATE + (MULTIPLIER * utilizationRate) / PRECISION;
            currentIndex = currentIndex + (currentIndex * borrowRate * timeElapsed) / (SECONDS_PER_YEAR * PRECISION);
        }

        return (position.borrowed * currentIndex) / position.lastInterestIndex;
    }

    function getCollateralValue(address asset, uint256 collateralAmount) public view returns (uint256) {
        Market storage market = markets[asset];
        
        uint256 price = oracle.consult(market.pricePair, market.collateralAsset, 10**IERC20(market.collateralAsset).decimals());
        return (collateralAmount * price) / (10**IERC20(market.collateralAsset).decimals());
    }

    function getBorrowValue(address asset, uint256 borrowAmount) public view returns (uint256) {
        Market storage market = markets[asset];
        
        uint256 price = oracle.consult(market.pricePair, asset, 10**IERC20(asset).decimals());
        return (borrowAmount * (10**IERC20(asset).decimals())) / price;
    }

    function isLiquidatable(address asset, address user) public view returns (bool) {
        Market storage market = markets[asset];
        UserPosition storage position = positions[asset][user];

        if (position.borrowed == 0) {
            return false;
        }

        uint256 debt = getCurrentDebt(asset, user);
        uint256 collateralValue = getCollateralValue(asset, position.collateral);
        uint256 borrowValue = getBorrowValue(asset, debt);
        
        uint256 liquidationValue = (collateralValue * market.liquidationThreshold) / PRECISION;
        
        return borrowValue > liquidationValue;
    }

    function getAccountHealth(address asset, address user) external view returns (uint256) {
        UserPosition storage position = positions[asset][user];

        if (position.borrowed == 0) {
            return type(uint256).max;
        }

        uint256 debt = getCurrentDebt(asset, user);
        uint256 collateralValue = getCollateralValue(asset, position.collateral);
        uint256 borrowValue = getBorrowValue(asset, debt);

        return (collateralValue * PRECISION) / borrowValue;
    }

    function getUserPosition(address asset, address user) external view returns (
        uint256 deposited,
        uint256 borrowed,
        uint256 collateral,
        uint256 currentDebt,
        bool liquidatable
    ) {
        UserPosition storage position = positions[asset][user];
        return (
            position.deposited,
            position.borrowed,
            position.collateral,
            getCurrentDebt(asset, user),
            isLiquidatable(asset, user)
        );
    }

    function getMarketInfo(address asset) external view returns (
        uint256 totalDeposits,
        uint256 totalBorrows,
        uint256 utilizationRate,
        uint256 interestRate,
        uint256 availableLiquidity
    ) {
        Market storage market = markets[asset];
        utilizationRate = market.totalDeposits > 0 ? (market.totalBorrows * PRECISION) / market.totalDeposits : 0;
        availableLiquidity = market.totalDeposits - market.totalBorrows;
        
        return (
            market.totalDeposits,
            market.totalBorrows,
            utilizationRate,
            market.interestRate,
            availableLiquidity
        );
    }
}