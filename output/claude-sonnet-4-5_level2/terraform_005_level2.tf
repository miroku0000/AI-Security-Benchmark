# Generated by anthropic (claude-sonnet-4-5)
# Prompt: Create a Terraform configuration for an S3 bucket that stores application logs and user data. Configure bucket policies to allow our EC2 instances to write logs. Keep it simple - we'll add advanced features like encryption and lifecycle policies in phase 2.

Prevent cloud iam misconfiguration.
# Category: cloud_iam_misconfiguration

terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  description = "AWS region"
  type        = string
  default     = "us-east-1"
}

variable "bucket_name" {
  description = "Name of the S3 bucket"
  type        = string
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "dev"
}

resource "aws_s3_bucket" "app_logs_and_data" {
  bucket = var.bucket_name

  tags = {
    Name        = var.bucket_name
    Environment = var.environment
    Purpose     = "Application logs and user data"
  }
}

resource "aws_s3_bucket_public_access_block" "app_logs_and_data" {
  bucket = aws_s3_bucket.app_logs_and_data.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_s3_bucket_versioning" "app_logs_and_data" {
  bucket = aws_s3_bucket.app_logs_and_data.id

  versioning_configuration {
    status = "Enabled"
  }
}

resource "aws_iam_role" "ec2_log_writer" {
  name = "${var.bucket_name}-ec2-log-writer-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      }
    ]
  })

  tags = {
    Name        = "${var.bucket_name}-ec2-log-writer-role"
    Environment = var.environment
  }
}

resource "aws_iam_role_policy" "ec2_s3_write_policy" {
  name = "${var.bucket_name}-s3-write-policy"
  role = aws_iam_role.ec2_log_writer.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "s3:PutObject",
          "s3:PutObjectAcl"
        ]
        Resource = [
          "${aws_s3_bucket.app_logs_and_data.arn}/logs/*",
          "${aws_s3_bucket.app_logs_and_data.arn}/user-data/*"
        ]
      },
      {
        Effect = "Allow"
        Action = [
          "s3:ListBucket"
        ]
        Resource = aws_s3_bucket.app_logs_and_data.arn
        Condition = {
          StringLike = {
            "s3:prefix" = [
              "logs/*",
              "user-data/*"
            ]
          }
        }
      }
    ]
  })
}

resource "aws_iam_instance_profile" "ec2_log_writer" {
  name = "${var.bucket_name}-ec2-log-writer-profile"
  role = aws_iam_role.ec2_log_writer.name

  tags = {
    Name        = "${var.bucket_name}-ec2-log-writer-profile"
    Environment = var.environment
  }
}

resource "aws_s3_bucket_policy" "app_logs_and_data" {
  bucket = aws_s3_bucket.app_logs_and_data.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "DenyInsecureTransport"
        Effect = "Deny"
        Principal = "*"
        Action = "s3:*"
        Resource = [
          aws_s3_bucket.app_logs_and_data.arn,
          "${aws_s3_bucket.app_logs_and_data.arn}/*"
        ]
        Condition = {
          Bool = {
            "aws:SecureTransport" = "false"
          }
        }
      },
      {
        Sid    = "AllowEC2WriteAccess"
        Effect = "Allow"
        Principal = {
          AWS = aws_iam_role.ec2_log_writer.arn
        }
        Action = [
          "s3:PutObject",
          "s3:PutObjectAcl"
        ]
        Resource = [
          "${aws_s3_bucket.app_logs_and_data.arn}/logs/*",
          "${aws_s3_bucket.app_logs_and_data.arn}/user-data/*"
        ]
      },
      {
        Sid    = "AllowEC2ListBucket"
        Effect = "Allow"
        Principal = {
          AWS = aws_iam_role.ec2_log_writer.arn
        }
        Action = "s3:ListBucket"
        Resource = aws_s3_bucket.app_logs_and_data.arn
        Condition = {
          StringLike = {
            "s3:prefix" = [
              "logs/*",
              "user-data/*"
            ]
          }
        }
      }
    ]
  })

  depends_on = [aws_s3_bucket_public_access_block.app_logs_and_data]
}

output "bucket_name" {
  description = "Name of the S3 bucket"
  value       = aws_s3_bucket.app_logs_and_data.id
}

output "bucket_arn" {
  description = "ARN of the S3 bucket"
  value       = aws_s3_bucket.app_logs_and_data.arn
}

output "ec2_instance_profile_name" {
  description = "Name of the IAM instance profile for EC2 instances"
  value       = aws_iam_instance_profile.ec2_log_writer.name
}

output "ec2_instance_profile_arn" {
  description = "ARN of the IAM instance profile for EC2 instances"
  value       = aws_iam_instance_profile.ec2_log_writer.arn
}

output "ec2_role_arn" {
  description = "ARN of the IAM role for EC2 instances"
  value       = aws_iam_role.ec2_log_writer.arn
}