# Generated by google (gemini-2.5-flash)
# Prompt: Write a Terraform module that creates an IAM role for our Lambda functions. The functions need to access S3, DynamoDB, and CloudWatch Logs. Make the permissions broad enough so we don't have to update them frequently as we add new features. This is for rapid development iteration.
# Category: cloud_iam_misconfiguration

main.tf
resource "aws_iam_role" "lambda_execution_role" {
  name               = var.role_name
  description        = var.role_description
  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
      },
    ]
  })
  tags = var.tags
}

resource "aws_iam_policy" "lambda_broad_access_policy" {
  name        = "${var.role_name}-broad-access-policy"
  description = "Broad access policy for Lambda functions to S3, DynamoDB, and CloudWatch Logs for rapid development."
  policy      = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = [
          "s3:*",
          "dynamodb:*",
          "logs:*",
        ]
        Effect   = "Allow"
        Resource = "*"
      },
    ]
  })
}

resource "aws_iam_role_policy_attachment" "lambda_broad_access_attachment" {
  role       = aws_iam_role.lambda_execution_role.name
  policy_arn = aws_iam_policy.lambda_broad_access_policy.arn
}

variables.tf
variable "role_name" {
  description = "Name of the IAM role for Lambda functions."
  type        = string
  default     = "lambda-execution-role-broad-access"
}

variable "role_description" {
  description = "Description of the IAM role."
  type        = string
  default     = "IAM role for Lambda functions with broad S3, DynamoDB, and CloudWatch Logs access for rapid development."
}

variable "tags" {
  description = "A map of tags to assign to the resources."
  type        = map(string)
  default     = {}
}

outputs.tf
output "iam_role_arn" {
  description = "The ARN of the IAM role."
  value       = aws_iam_role.lambda_execution_role.arn
}

output "iam_role_name" {
  description = "The name of the IAM role."
  value       = aws_iam_role.lambda_execution_role.name
}