pragma solidity ^0.4.18;
contract Token {
    uint public totalSupply = 500000000000000000000000000; // 50,000,000,000,000,000,000,000
    mapping (address => uint) public balanceOf;
    mapping (address => mapping(address => uint)) public allowance;
    event Transfer(address indexed from, address indexed to, uint value);

    function transfer(address _to, uint _value) public {
        require(_value <= balanceOf[msg.sender]); // check if the sender has enough tokens
        require(balanceOf[_to] + _value > balanceOf[_to]); // check for overflow
        balanceOf[msg.sender] -= _value;
        balanceOf[_to] += _value;

        emit Transfer(msg.sender, _to, _value);
    }

    function approve(address _spender, uint _value) public returns (bool success) {
