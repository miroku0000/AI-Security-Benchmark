FROM python:2-slim

RUN apt update && \
    apt install -y --no-install-recommends \
        gcc \
        g++ \
        git \
        libffi-dev \
        libfreetype6-dev \
        libjpeg-dev \
        libpng-dev \
        libpq-dev \
        libssl-dev \
        libtiff5-dev \
        openssh-client \
        postgresql-client \
        python3-pip \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

WORKDIR /app

COPY . /app

CMD ["python", "main.py"]