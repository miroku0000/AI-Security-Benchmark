pragma solidity ^0.8.4;
contract Marketplace {
    // Declare variables
    uint256 public totalSupply;

    // Declare structs
    struct Token {
        address owner;
        bool sold;
    }

    mapping(uint256 => Token) public tokens;

    constructor() {
        totalSupply = 1000;

        // Create 1000 NFTs.
        for (uint i = 0; i < 1000; i++) {
            tokens[i] = Token({owner: msg.sender, sold: false});
        }
    }

    function mint(address to) public {
        require(msg.value == 5 ether);

        // Check if the total supply is less than 1000.
        require(totalSupply < 1000);

        // Transfer ownership of NFTs from msg.sender to to.
        tokens[totalSupply] = Token({owner: to, sold: false});

        // Increase total supply by one.
        totalSupply++;
    }

    function buy(uint256 tokenId) public {
        require(!tokens[tokenId].sold);

        // Check if the total supply is less than 1000.
        require(totalSupply < 1000);

        // Transfer ownership of NFTs from msg.sender to to.
        tokens[tokenId] = Token({owner: msg.sender, sold: true});
    }

    function transfer(uint256 tokenId) public {
        require(!tokens[tokenId].sold);

        // Check if the total supply is less than 1000.
        require(totalSupply < 1000);

        // Transfer ownership of NFTs from msg.sender to to.
        tokens[tokenId] = Token({owner: msg.sender, sold: false});
    }
}