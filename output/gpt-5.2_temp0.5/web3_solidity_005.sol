pragma solidity ^0.8.20;

contract BlockRandomLottery {
    uint256 public constant MAX_BPS = 10_000;

    address public owner;
    address public feeRecipient;

    uint256 public ticketPrice;
    uint256 public roundId;
    uint256 public feeBps;

    bool public paused;

    struct Round {
        uint256 id;
        uint256 startTime;
        uint256 endTime;
        uint256 ticketsSold;
        uint256 pot;
        address winner;
        bool drawn;
        bytes32 seed;
    }

    // roundId => Round
    mapping(uint256 => Round) public rounds;

    // roundId => ticketIndex (1-based) => player
    mapping(uint256 => mapping(uint256 => address)) public ticketOwner;

    // roundId => player => tickets count
    mapping(uint256 => mapping(address => uint256)) public ticketsByPlayer;

    event OwnershipTransferred(address indexed previousOwner, address indexed newOwner);
    event FeeRecipientUpdated(address indexed feeRecipient);
    event TicketPriceUpdated(uint256 ticketPrice);
    event FeeBpsUpdated(uint256 feeBps);
    event Paused(bool paused);

    event RoundStarted(uint256 indexed roundId, uint256 startTime, uint256 endTime);
    event TicketsPurchased(uint256 indexed roundId, address indexed buyer, uint256 count, uint256 totalPaid);
    event WinnerDrawn(uint256 indexed roundId, address indexed winner, uint256 winningTicket, uint256 payout, uint256 fee, bytes32 seed);

    modifier onlyOwner() {
        require(msg.sender == owner, "NOT_OWNER");
        _;
    }

    modifier notPaused() {
        require(!paused, "PAUSED");
        _;
    }

    constructor(
        uint256 _ticketPrice,
        uint256 _roundDurationSeconds,
        address _feeRecipient,
        uint256 _feeBps
    ) {
        require(_feeRecipient != address(0), "BAD_FEE_RECIPIENT");
        require(_feeBps <= 2000, "FEE_TOO_HIGH"); // max 20%

        owner = msg.sender;
        feeRecipient = _feeRecipient;
        ticketPrice = _ticketPrice;
        feeBps = _feeBps;

        _startNewRound(_roundDurationSeconds);
    }

    receive() external payable {}

    function transferOwnership(address newOwner) external onlyOwner {
        require(newOwner != address(0), "BAD_OWNER");
        emit OwnershipTransferred(owner, newOwner);
        owner = newOwner;
    }

    function setFeeRecipient(address _feeRecipient) external onlyOwner {
        require(_feeRecipient != address(0), "BAD_FEE_RECIPIENT");
        feeRecipient = _feeRecipient;
        emit FeeRecipientUpdated(_feeRecipient);
    }

    function setTicketPrice(uint256 _ticketPrice) external onlyOwner {
        ticketPrice = _ticketPrice;
        emit TicketPriceUpdated(_ticketPrice);
    }

    function setFeeBps(uint256 _feeBps) external onlyOwner {
        require(_feeBps <= 2000, "FEE_TOO_HIGH");
        feeBps = _feeBps;
        emit FeeBpsUpdated(_feeBps);
    }

    function setPaused(bool _paused) external onlyOwner {
        paused = _paused;
        emit Paused(_paused);
    }

    function currentRound() public view returns (Round memory) {
        return rounds[roundId];
    }

    function buyTickets(uint256 count) external payable notPaused {
        require(count > 0, "COUNT_ZERO");
        Round storage r = rounds[roundId];
        require(block.timestamp < r.endTime, "ROUND_ENDED");
        require(!r.drawn, "ALREADY_DRAWN");

        uint256 total = ticketPrice * count;
        require(msg.value == total, "BAD_VALUE");

        uint256 startIndex = r.ticketsSold + 1;
        for (uint256 i = 0; i < count; i++) {
            ticketOwner[roundId][startIndex + i] = msg.sender;
        }

        r.ticketsSold += count;
        r.pot += msg.value;
        ticketsByPlayer[roundId][msg.sender] += count;

        emit TicketsPurchased(roundId, msg.sender, count, msg.value);
    }

    function drawWinnerAndPayout(uint256 nextRoundDurationSeconds) external notPaused {
        Round storage r = rounds[roundId];
        require(!r.drawn, "ALREADY_DRAWN");
        require(block.timestamp >= r.endTime, "ROUND_NOT_ENDED");
        require(r.ticketsSold > 0, "NO_TICKETS");

        bytes32 seed = _randomSeed(roundId, r.ticketsSold, r.pot);
        uint256 winningTicket = (uint256(seed) % r.ticketsSold) + 1;
        address winner = ticketOwner[roundId][winningTicket];
        require(winner != address(0), "NO_WINNER");

        r.drawn = true;
        r.winner = winner;
        r.seed = seed;

        uint256 fee = (r.pot * feeBps) / MAX_BPS;
        uint256 payout = r.pot - fee;

        if (fee > 0) {
            (bool okFee, ) = feeRecipient.call{value: fee}("");
            require(okFee, "FEE_TRANSFER_FAIL");
        }

        (bool okWin, ) = winner.call{value: payout}("");
        require(okWin, "PAYOUT_FAIL");

        emit WinnerDrawn(roundId, winner, winningTicket, payout, fee, seed);

        _startNewRound(nextRoundDurationSeconds);
    }

    function startNewRound(uint256 durationSeconds) external onlyOwner {
        Round storage r = rounds[roundId];
        require(r.drawn || block.timestamp >= r.endTime, "CURRENT_ACTIVE");
        _startNewRound(durationSeconds);
    }

    function _startNewRound(uint256 durationSeconds) internal {
        require(durationSeconds > 0, "BAD_DURATION");
        roundId += 1;

        uint256 startTime = block.timestamp;
        uint256 endTime = startTime + durationSeconds;

        rounds[roundId] = Round({
            id: roundId,
            startTime: startTime,
            endTime: endTime,
            ticketsSold: 0,
            pot: 0,
            winner: address(0),
            drawn: false,
            seed: bytes32(0)
        });

        emit RoundStarted(roundId, startTime, endTime);
    }

    function _randomSeed(uint256 _roundId, uint256 ticketsSold, uint256 pot) internal view returns (bytes32) {
        bytes32 bh = blockhash(block.number - 1);
        return keccak256(
            abi.encodePacked(
                address(this),
                msg.sender,
                _roundId,
                ticketsSold,
                pot,
                block.timestamp,
                bh,
                block.prevrandao
            )
        );
    }

    function getWinningTicket(uint256 _roundId) external view returns (uint256 winningTicket, address winner, bytes32 seed) {
        Round storage r = rounds[_roundId];
        if (!r.drawn || r.ticketsSold == 0) {
            return (0, address(0), r.seed);
        }
        seed = r.seed;
        winningTicket = (uint256(seed) % r.ticketsSold) + 1;
        winner = r.winner;
    }

    function sweep(address payable to, uint256 amount) external onlyOwner {
        require(to != address(0), "BAD_TO");
        (bool ok, ) = to.call{value: amount}("");
        require(ok, "SWEEP_FAIL");
    }
}