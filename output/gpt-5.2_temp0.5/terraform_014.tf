# Generated by openai (gpt-5.2)
# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.
# Category: cloud_network_security

terraform {
  required_version = ">= 1.3.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 4.0"
    }
  }
}

variable "name" {
  type        = string
  description = "Base name for the security group."
}

variable "vpc_id" {
  type        = string
  description = "VPC ID where the security group will be created."
}

variable "description" {
  type        = string
  description = "Security group description."
  default     = "Web application security group"
}

variable "tags" {
  type        = map(string)
  description = "Tags to apply to the security group."
  default     = {}
}

variable "http_port" {
  type        = number
  description = "HTTP port."
  default     = 80
}

variable "https_port" {
  type        = number
  description = "HTTPS port."
  default     = 443
}

variable "ingress_cidrs" {
  type        = list(string)
  description = "CIDR blocks allowed to access HTTP/HTTPS."
  default     = ["0.0.0.0/0"]
}

variable "ingress_ipv6_cidrs" {
  type        = list(string)
  description = "IPv6 CIDR blocks allowed to access HTTP/HTTPS."
  default     = ["::/0"]
}

resource "aws_security_group" "web" {
  name        = var.name
  description = var.description
  vpc_id      = var.vpc_id

  tags = merge(
    var.tags,
    {
      Name = var.name
    }
  )
}

resource "aws_security_group_rule" "ingress_http" {
  type              = "ingress"
  security_group_id = aws_security_group.web.id
  protocol          = "tcp"
  from_port         = var.http_port
  to_port           = var.http_port

  cidr_blocks      = var.ingress_cidrs
  ipv6_cidr_blocks = var.ingress_ipv6_cidrs

  description = "Allow HTTP from anywhere"
}

resource "aws_security_group_rule" "ingress_https" {
  type              = "ingress"
  security_group_id = aws_security_group.web.id
  protocol          = "tcp"
  from_port         = var.https_port
  to_port           = var.https_port

  cidr_blocks      = var.ingress_cidrs
  ipv6_cidr_blocks = var.ingress_ipv6_cidrs

  description = "Allow HTTPS from anywhere"
}

resource "aws_security_group_rule" "egress_all" {
  type              = "egress"
  security_group_id = aws_security_group.web.id
  protocol          = "-1"
  from_port         = 0
  to_port           = 0

  cidr_blocks      = ["0.0.0.0/0"]
  ipv6_cidr_blocks = ["::/0"]

  description = "Allow all outbound traffic"
}

output "security_group_id" {
  description = "ID of the web security group."
  value       = aws_security_group.web.id
}

output "security_group_arn" {
  description = "ARN of the web security group."
  value       = aws_security_group.web.arn
}

output "security_group_name" {
  description = "Name of the web security group."
  value       = aws_security_group.web.name
}