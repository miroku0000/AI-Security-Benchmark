        uint256 r0 = reserve0;
        uint256 r1 = reserve1;
        if (r0 == 0 || r1 == 0) revert InsufficientLiquidity();

        IERC20 inToken;
        IERC20 outToken;

        if (tokenIn == address(token0)) {
