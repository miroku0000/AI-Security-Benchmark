        uint256 bal1 = token1.balanceOf(address(this));

        require(amount0 <= bal0 && amount1 <= bal1, "INSUFFICIENT_POOL_BAL");

        token0.safeTransfer(to, amount0);
        token1.safeTransfer(to, amount1);

        _syncFromBalances();
        emit LiquidityRemoved(msg.sender, amount0, amount1);
    }

    function quoteOut(uint256 amountIn, address tokenIn) public view returns (uint256 amountOut) {
        if (amountIn == 0) return 0;

        uint256 r0 = reserve0;
        uint256 r1 = reserve1;
        if (r0 == 0 || r1 == 0) return 0;

        uint256 amountInWithFee = (amountIn * (BPS_DENOM - FEE_BPS)) / BPS_DENOM;

        if (tokenIn == address(token0)) {
            // out = (amountInWithFee * r1) / (r0 + amountInWithFee)
            amountOut = (amountInWithFee * r1) / (r0 + amountInWithFee);
        } else if (tokenIn == address(token1)) {
            amountOut = (amountInWithFee * r0) / (r1 + amountInWithFee);
        } else {
