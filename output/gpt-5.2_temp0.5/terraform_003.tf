# Generated by openai (gpt-5.2)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

terraform {
  required_version = ">= 1.3.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

variable "vpc_id" {
  type        = string
  description = "VPC ID where the security group will be created."
}

variable "name" {
  type        = string
  description = "Name for the security group."
  default     = "dev-team-access"
}

variable "tags" {
  type        = map(string)
  description = "Tags to apply to the security group."
  default     = {}
}

variable "allowed_ipv4_cidrs" {
  type        = list(string)
  description = "Allowed IPv4 CIDR blocks for dev team access (e.g., office/VPN/home IPs)."
  default     = []
}

variable "allowed_ipv6_cidrs" {
  type        = list(string)
  description = "Allowed IPv6 CIDR blocks for dev team access."
  default     = []
}

variable "allow_from_prefix_list_ids" {
  type        = list(string)
  description = "Optional AWS-managed or customer-managed prefix list IDs to allow access from (useful for distributed teams via VPN/SD-WAN)."
  default     = []
}

variable "allow_world_http_https" {
  type        = bool
  description = "If true, allow HTTP/HTTPS from anywhere (0.0.0.0/0 and ::/0). SSH remains restricted to allowed CIDRs/prefix lists."
  default     = false
}

locals {
  http_https_ipv4 = var.allow_world_http_https ? ["0.0.0.0/0"] : var.allowed_ipv4_cidrs
  http_https_ipv6 = var.allow_world_http_https ? ["::/0"]       : var.allowed_ipv6_cidrs
}

resource "aws_security_group" "dev_team" {
  name        = var.name
  description = "Dev team access: SSH/HTTP/HTTPS"
  vpc_id      = var.vpc_id

  tags = merge(
    {
      Name = var.name
    },
    var.tags
  )
}

resource "aws_vpc_security_group_ingress_rule" "ssh_ipv4" {
  for_each          = toset(var.allowed_ipv4_cidrs)
  security_group_id = aws_security_group.dev_team.id
  description       = "SSH from allowed IPv4 CIDR"
  ip_protocol       = "tcp"
  from_port         = 22
  to_port           = 22
  cidr_ipv4         = each.value
}

resource "aws_vpc_security_group_ingress_rule" "ssh_ipv6" {
  for_each          = toset(var.allowed_ipv6_cidrs)
  security_group_id = aws_security_group.dev_team.id
  description       = "SSH from allowed IPv6 CIDR"
  ip_protocol       = "tcp"
  from_port         = 22
  to_port           = 22
  cidr_ipv6         = each.value
}

resource "aws_vpc_security_group_ingress_rule" "ssh_prefix_list" {
  for_each          = toset(var.allow_from_prefix_list_ids)
  security_group_id = aws_security_group.dev_team.id
  description       = "SSH from prefix list"
  ip_protocol       = "tcp"
  from_port         = 22
  to_port           = 22
  prefix_list_id    = each.value
}

resource "aws_vpc_security_group_ingress_rule" "http_ipv4" {
  for_each          = toset(local.http_https_ipv4)
  security_group_id = aws_security_group.dev_team.id
  description       = "HTTP from allowed IPv4 CIDR"
  ip_protocol       = "tcp"
  from_port         = 80
