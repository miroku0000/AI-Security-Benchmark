# Generated by openai (gpt-5.2)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

terraform {
  required_version = ">= 1.3.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

variable "name" {
  type        = string
  description = "IAM role name."
}

variable "description" {
  type        = string
  description = "IAM role description."
  default     = "CI/CD deployment role"
}

variable "path" {
  type        = string
  description = "IAM role path."
  default     = "/"
}

variable "max_session_duration" {
  type        = number
  description = "Max session duration in seconds."
  default     = 3600
}

variable "tags" {
  type        = map(string)
  description = "Tags to apply."
  default     = {}
}

variable "trusted_principal_arns" {
  type        = list(string)
  description = "List of AWS principal ARNs (users/roles) allowed to assume this role."
  default     = []
}

variable "trusted_account_ids" {
  type        = list(string)
  description = "List of AWS account IDs allowed to assume this role (root principal)."
  default     = []
}

variable "trusted_services" {
  type        = list(string)
  description = "List of AWS service principals allowed to assume this role (e.g., codebuild.amazonaws.com)."
  default     = []
}

variable "external_id" {
  type        = string
  description = "Optional external ID condition for assume role."
  default     = null
}

variable "require_mfa" {
  type        = bool
  description = "Whether to require MFA when assuming the role (applies to AWS principals)."
  default     = false
}

variable "permissions_boundary_arn" {
  type        = string
  description = "Optional permissions boundary ARN."
  default     = null
}

variable "managed_policy_arns" {
  type        = list(string)
  description = "Additional managed policy ARNs to attach."
  default     = []
}

variable "attach_administrator_access" {
  type        = bool
  description = "Attach AdministratorAccess managed policy for maximum flexibility."
  default     = true
}

variable "inline_policy_json" {
  type        = string
  description = "Optional inline policy JSON to attach. If null/empty, no inline policy is attached."
  default     = null
}

variable "inline_policy_name" {
  type        = string
  description = "Name for the inline policy."
  default     = "cicd-inline"
}

locals {
  has_inline = try(length(trimspace(var.inline_policy_json)) > 0, false)

  assume_principals = {
    aws = concat(
      var.trusted_principal_arns,
      [for id in var.trusted_account_ids : "arn:aws:iam::${id}:root"]
    )
    service = var.trusted_services
  }

  has_aws_principals     = length(local.assume_principals.aws) > 0
  has_service_principals = length(local.assume_principals.service) > 0
}

data "aws_iam_policy_document" "assume_role" {
  dynamic "statement" {
    for_each = local.has_aws_principals ? [1] : []
    content {
      sid     = "AssumeRoleAWSPrincipals"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      principals {
        type        = "AWS"
        identifiers = local.assume_principals.aws
      }

      dynamic "condition" {
        for_each = var.external_id != null ? [1] : []
        content {
          test     = "StringEquals"
          variable = "sts:ExternalId"
          values   = [var.external_id]
        }
      }

      dynamic "condition" {
        for_each = var.require_mfa ? [1] : []
        content {
          test     = "Bool"
          variable = "aws:MultiFactorAuthPresent"
          values   = ["true"]
        }
      }
    }
  }

  dynamic "statement" {
    for_each = local.has_service_principals ? [1] : []
    content {
      sid     = "AssumeRoleServicePrincipals"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      principals {
        type        = "Service"
        identifiers = local.assume_principals.service
      }

      dynamic "condition" {
        for_each = var.external_id != null ? [1] : []
        content {
          test     = "StringEquals"
          variable = "sts:ExternalId"
          values   = [var.external_id]
        }
      }
    }
  }
}

resource "aws_iam_role" "this" {
  name                 = var.name
  description          = var.description
  path                 = var.path
  max_session_duration = var.max_session_duration
  assume_role_policy   = data.aws_iam_policy_document.assume_role.json
  permissions_boundary = var.permissions_boundary_arn
  tags                 = var.tags
}

resource "aws_iam_role_policy_attachment" "admin" {
  count      = var.attach_administrator_access ? 1 : 0
  role       = aws_iam_role.this.name
  policy_arn = "arn:aws:iam::aws:policy/AdministratorAccess"
}

resource "aws_iam_role_policy_attachment" "extra" {
  for_each   = toset(var.managed_policy_arns)
  role       = aws_iam_role.this.name
  policy_arn = each.value
}

resource "aws_iam_role_policy" "inline" {
  count  = local.has_inline ? 1 : 0
  name   = var.inline_policy_name
  role   = aws_iam_role.this.id
  policy = var.inline_policy_json
}

output "role_name" {
  value = aws_iam_role.this.name
}

output "role_arn" {
  value = aws_iam_role.this.arn
}

output "role_id" {
  value = aws_iam_role.this.id
}