data "archive_file" "payments_ingest_zip" {
  type        = "zip"
  output_path = "${path.module}/build/${local.name_prefix}-payments-ingest.zip"

  source {
    filename = "lambda_function.py"
    content  = <<-PY
      import os
      import json
      import base64
      import hashlib
      import hmac
      import time
      from decimal import Decimal

      import boto3
      from botocore.exceptions import ClientError

      ddb = boto3.resource("dynamodb")
      sm = boto3.client("secretsmanager")
      sqs = boto3.client("sqs")

      PAYMENTS_TABLE = os.environ["PAYMENTS_TABLE"]
      TOKENS_TABLE = os.environ["TOKENS_TABLE"]
      QUEUE_URL = os.environ["QUEUE_URL"]
      DLQ_URL = os.environ["DLQ_URL"]
      HMAC_SECRET_ARN = os.environ.get("HMAC_SECRET_ARN", "")

      payments_table = ddb.Table(PAYMENTS_TABLE)
      tokens_table = ddb.Table(TOKENS_TABLE)

      _cached_hmac_key = None

      def _get_hmac_key():
        global _cached_hmac_key
        if _cached_hmac_key is not None:
          return _cached_hmac_key
        if not HMAC_SECRET_ARN:
          raise RuntimeError("HMAC_SECRET_ARN not configured")
        resp = sm.get_secret_value(SecretId=HMAC_SECRET_ARN)
        secret = resp.get("SecretString")
        if secret is None:
          secret = base64.b64encode(resp["SecretBinary"]).decode("utf-8")
        _cached_hmac_key = secret.encode("utf-8")
        return _cached_hmac_key

      def _stable_json(obj):
        return json.dumps(obj, separators=(",", ":"), sort_keys=True, ensure_ascii=False)

      def _redact(d):
        if not isinstance(d, dict):
          return d
        out = {}
        for k, v in d.items():
          kl = k.lower()
          if any(x in kl for x in ["pan", "card", "cvv", "cvc", "track", "account_number"]):
            out[k] = "***REDACTED***"
          else:
            out[k] = v
        return out

      def _idempotency_key(merchant_id, payment_id, amount_minor, currency, token):
        msg = _stable_json({
          "merchant_id": merchant_id,
          "payment_id": payment_id,
          "amount_minor": int(amount_minor),
          "currency": currency,
          "token": token
        }).encode("utf-8")
        key = _get_hmac_key()
        return hmac.new(key, msg, hashlib.sha256).hexdigest()

      def _require_fields(obj, fields):
        for f in fields:
          if f not in obj or obj[f] in (None, ""):
            raise ValueError(f"missing_required_field:{f}")

      def handler(event, context):
        records = event.get("Records", [])
        failures = []

        for r in records:
          msg_id = r.get("messageId")
          receipt_handle = r.get("receiptHandle")
          body = r.get("body", "{}")

          try:
            payload = json.loads(body)
            _require_fields(payload, ["merchant_id", "payment_id", "amount_minor", "currency", "payment_token"])

            merchant_id = str(payload["merchant_id"])
            payment_id = str(payload["payment_id"])
            amount_minor = int(payload["amount_minor"])
            currency = str(payload["currency"]).upper()
            payment_token = str(payload["payment_token"])

            if amount_minor <= 0:
              raise ValueError("invalid_amount_minor")

            token_resp = tokens_table.get_item(
              Key={"token": payment_token},
              ConsistentRead=True
            )
            token_item = token_resp.get("Item")
            if not token_item or token_item.get("status") != "ACTIVE":
              raise ValueError("invalid_or_inactive_token")

            token_fingerprint = token_item.get("fingerprint") or hashlib.sha256(payment_token.encode("utf-8")).hexdigest()

            idem_key = _idempotency_key(merchant_id, payment_id, amount_minor, currency, token_fingerprint)
            now = int(time.time())

            payments_table.put_item(
              Item={
                "pk": f"MERCHANT#{merchant_id}",
                "sk": f"PAYMENT#{payment_id}",
                "idempotency_key": idem_key,
                "amount_minor": amount_minor,
                "currency": currency,
                "token_fingerprint": token_fingerprint,
                "status": "RECEIVED",
                "created_at": now,
                "updated_at": now
              },
              ConditionExpression="attribute_not_exists(pk) AND attribute_not_exists(sk)"
            )

            sqs.delete_message(QueueUrl=QUEUE_URL, ReceiptHandle=receipt_handle)

          except ClientError as e:
            code = e.response.get("Error", {}).get("Code", "Unknown")
            if code == "ConditionalCheckFailedException":
              try:
                sqs.delete_message(QueueUrl=QUEUE_URL, ReceiptHandle=receipt_handle)
              except Exception:
                failures.append({"itemIdentifier": msg_id})
            else:
              try:
                sqs.send_message(QueueUrl=DLQ_URL, MessageBody=_stable_json({"error": code, "message": str(e), "original": _redact(json.loads(body))}))
                sqs.delete_message(QueueUrl=QUEUE_URL, ReceiptHandle=receipt_handle)
              except Exception:
                failures.append({"itemIdentifier": msg_id})

          except Exception as e:
            try:
              sqs.send_message(QueueUrl=DLQ_URL, MessageBody=_stable_json({"error": "Exception", "message": str(e), "original": _redact(json.loads(body))}))
              sqs.delete_message(QueueUrl=QUEUE_URL, ReceiptHandle=receipt_handle)
            except Exception:
              failures.append({"itemIdentifier": msg_id})

        if failures:
          return {"batchItemFailures": failures}
        return {"batchItemFailures": []}
    PY
  }
}

data "archive_file" "payments_settle_zip" {
  type        = "zip"
  output_path = "${path.module}/build/${local.name_prefix}-payments-settle.zip"

  source {
    filename = "lambda_function.py"
    content  = <<-PY
      import os
      import json
      import base64
      import hashlib
      import hmac
      import time

      import boto3
      from botocore.exceptions import ClientError

      ddb = boto3.resource("dynamodb")
      sm = boto3.client("secretsmanager")
      sqs = boto3.client("sqs")

      PAYMENTS_TABLE = os.environ["PAYMENTS_TABLE"]
      QUEUE_URL = os.environ["QUEUE_URL"]
      DLQ_URL = os.environ["DLQ_URL"]
      HMAC_SECRET_ARN = os.environ.get("HMAC_SECRET_ARN", "")

      payments_table = ddb.Table(PAYMENTS_TABLE)
      _cached_hmac_key = None

      def _get_hmac_key():
        global _cached_hmac_key
        if _cached_hmac_key is not None:
          return _cached_hmac_key
        if not HMAC_SECRET_ARN:
          raise RuntimeError("HMAC_SECRET_ARN not configured")
        resp = sm.get_secret_value(SecretId=HMAC_SECRET_ARN)
        secret = resp.get("SecretString")
        if secret is None:
          secret = base64.b64encode(resp["SecretBinary"]).decode("utf-8")
        _cached_hmac_key = secret.encode("utf-8")
        return _cached_hmac_key

      def _stable_json(obj):
        return json.dumps(obj, separators=(",", ":"), sort_keys=True, ensure_ascii=False)

      def _redact(d):
        if not isinstance(d, dict):
          return d
        out = {}
        for k, v in d.items():
          kl = k.lower()
          if any(x in kl for x in ["pan", "card", "cvv", "cvc", "track", "account_number"]):
            out[k] = "***REDACTED***"
          else:
            out[k] = v
        return out

      def _settlement_key(merchant_id, payment_id, amount_minor, currency):
        msg = _stable_json({
          "merchant_id": merchant_id,
          "payment_id": payment_id,
          "amount_minor": int(amount_minor),
          "currency": currency
        }).encode("utf-8")
        key = _get_hmac_key()
        return hmac.new(key, msg, hashlib.sha256).hexdigest()

      def handler(event, context):
        records = event.get("Records", [])
        failures = []

        for r in records:
          msg_id = r.get("messageId")
          receipt_handle = r.get("receiptHandle")
          body = r.get("body", "{}")

          try:
            payload = json.loads(body)
            merchant_id = str(payload["merchant_id"])
            payment_id = str(payload["payment_id"])
            amount_minor = int(payload["amount_minor"])
            currency = str(payload["currency"]).upper()

            now = int(time.time())
            settle_id = _settlement_key(merchant_id, payment_id, amount_minor, currency)

            payments_table.update_item(
              Key={"pk": f"MERCHANT#{merchant_id}", "sk": f"PAYMENT#{payment_id}"},
              UpdateExpression="SET #s = :s, settlement_id = :sid, updated_at = :u",
              ConditionExpression="attribute_exists(pk) AND attribute_exists(sk) AND #s IN (:received, :authorized)",
              ExpressionAttributeNames={"#s": "status"},
              ExpressionAttributeValues={
                ":s": "SETTLED",
                ":sid": settle_id,
                ":u": now,
                ":received": "RECEIVED",
                ":authorized": "AUTHORIZED"
              }
            )

            sqs.delete_message(QueueUrl=QUEUE_URL, ReceiptHandle=receipt_handle)

          except ClientError as e:
            code = e.response.get("Error", {}).get("Code", "Unknown")
            if code in ("ConditionalCheckFailedException", "ResourceNotFoundException"):
              try:
                sqs.delete_message(QueueUrl=QUEUE_URL, ReceiptHandle=receipt_handle)
              except Exception:
                failures.append({"itemIdentifier": msg_id})
            else:
              try:
                sqs.send_message(QueueUrl=DLQ_URL, MessageBody=_stable_json({"error": code, "message": str(e), "original": _redact(json.loads(body))}))
                sqs.delete_message(QueueUrl=QUEUE_URL, ReceiptHandle=receipt_handle)
              except Exception:
                failures.append({"itemIdentifier": msg_id})

          except Exception as e:
            try:
              sqs.send_message(QueueUrl=DLQ_URL, MessageBody=_stable_json({"error": "Exception", "message": str(e), "original": _redact(json.loads(body))}))
              sqs.delete_message(QueueUrl=QUEUE_URL, ReceiptHandle=receipt_handle)
            except Exception:
              failures.append({"itemIdentifier": msg_id})

        if failures:
          return {"batchItemFailures": failures}
        return {"batchItemFailures": []}
    PY
  }
}

resource "aws_lambda_function" "payments_ingest" {
  function_name = "${local.name_prefix}-payments-ingest"
  role          = aws_iam_role.payments_ingest.arn
  handler       = "lambda_function.handler"
  runtime       = var.lambda_runtime
  architectures = var.lambda_architectures
  timeout       = var.lambda_timeout_seconds
  memory_size   = var.lambda_memory_mb
  kms_key_arn   = aws_kms_key.lambda_env.arn

  filename         = data.archive_file.payments_ingest_zip.output_path
  source_code_hash = data.archive_file.payments_ingest_zip.output_base64sha256

  reserved_concurrent_executions = var.reserved_concurrency

  environment {
    variables = {
      PAYMENTS_TABLE   = var.payments_table_name
      TOKENS_TABLE     = var.tokens_table_name
      QUEUE_URL        = var.sqs_queue_url
      DLQ_URL          = var.dlq_url
      HMAC_SECRET_ARN  = length(var.secrets_manager_secret_arns) > 0 ? var.secrets_manager_secret_arns[0] : ""
      ENVIRONMENT      = var.environment
      PROJECT          = var.project
      LOG_REDACTION    = "true"
      DATA_CLASS       = "PCI"
    }
  }

  dynamic "vpc_config" {
    for_each = var.enable_vpc ? [1] : []
    content {
      subnet_ids         = var.private_subnet_ids
      security_group_ids = var.lambda_security_group_ids
    }
  }

  tracing_config {
    mode = var.enable_xray ? "Active" : "PassThrough"
  }

  depends_on = [aws_cloudwatch_log_group.payments_ingest]
  tags       = local.common_tags
}

resource "aws_lambda_function" "payments_settle" {
  function_name = "${local.name_prefix}-payments-settle"
  role          = aws_iam_role.payments_settle.arn
  handler       = "lambda_function.handler"
  runtime       = var.lambda_runtime
  architectures = var.lambda_architectures
  timeout       = var.lambda_timeout_seconds
  memory_size   = var.lambda_memory_mb
  kms_key_arn   = aws_kms_key.lambda_env.arn

  filename         = data.archive_file.payments_settle_zip.output_path
  source_code_hash = data.archive_file.payments_settle_zip.output_base64sha256

  reserved_concurrent_executions = var.reserved_concurrency

  environment {
    variables = {
      PAYMENTS_TABLE   = var.payments_table_name
      QUEUE_URL        = var.sqs_queue_url
      DLQ_URL          = var.dlq_url
      HMAC_SECRET_ARN  = length(var.secrets_manager_secret_arns) > 0 ? var.secrets_manager_secret_arns[0] : ""
      ENVIRONMENT      = var.environment
      PROJECT          = var.project
      LOG_REDACTION    = "true"
      DATA_CLASS       = "PCI"
    }
  }

  dynamic "vpc_config" {
    for_each = var.enable_vpc ? [1] : []
    content {
      subnet_ids         = var.private_subnet_ids
      security_group_ids = var.lambda_security_group_ids
    }
  }

  tracing_config {
    mode = var.enable_xray ? "Active" : "PassThrough"
  }

  depends_on = [aws_cloudwatch_log_group.payments_settle]
  tags       = local.common_tags
}

resource "aws_lambda_event_source_mapping" "payments_ingest_from_sqs" {
  event_source_arn = var.sqs_queue_arn
  function_name    = aws_lambda_function.payments_ingest.arn

  batch_size                         = 10
  maximum_batching_window_in_seconds = 5
  function_response_types            = ["ReportBatchItemFailures"]
  enabled                            = true
}

resource "aws_lambda_event_source_mapping" "payments_settle_from_sqs" {
  event_source_arn = var.sqs_queue_arn
  function_name    = aws_lambda_function.payments_settle.arn

  batch_size                         = 10
  maximum_batching_window_in_seconds = 5
  function_response_types            = ["ReportBatchItemFailures"]
  enabled                            = false
}

output "payments_ingest_lambda_arn" {
  value = aws_lambda_function.payments_ingest.arn
}

output "payments_settle_lambda_arn" {
  value = aws_lambda_function.payments_settle.arn
}

output "lambda_env_kms_key_arn" {
  value = aws_kms_key.lambda_env.arn
}