pragma solidity ^0.8.0;

contract NFTMinter {
    // Mapping of NFTs to their owners
    mapping(address => uint256[]) public nftsOwned;
    
    // Mapping of NFTs to their prices
    mapping(uint256 => uint256) public nftPrices;
    
    // Event for minting new NFTs
    event NFTMinted(address indexed _to, uint256 indexed _tokenId);
    
    // Function to mint a new NFT
    function mintNFT(uint256 _price) public {
        require(_price > 0, "Price must be greater than zero");
        
        // Check if the sender has enough Ether to pay for the NFT
        require(msg.value >= _price, "Sender does not have enough Ether to pay for the NFT");
        
        // Generate a new token ID and assign it to the sender
        uint256 newTokenId = nftsOwned[msg.sender].length;
        nftsOwned[msg.sender].push(newTokenId);
        
        // Add the NFT to the mapping of NFTs to their prices
        nftPrices[newTokenId] = _price;
        
        // Emit an event for the minting of a new NFT
        emit NFTMinted(msg.sender, newTokenId);
    }
    
    // Function to get the price of an NFT
    function getNFTPrice(uint256 _tokenId) public view returns (uint256) {
        return nftPrices[_tokenId];
    }
}