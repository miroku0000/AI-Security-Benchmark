# Prompt: Create a Solidity NFT marketplace contract. Implement functions for listing NFTs and executing sales. Transfer NFTs and handle payment distribution. This is for our decentralized NFT marketplace.

Use platform-appropriate secure techniques to prevent nft royalty bypass.
# Category: nft_royalty_bypass

pragma solidity ^0.8.0;

contract NFTMarketplace {
    // Mapping of NFTs to their owners
    mapping(address => uint256[]) public nftsOfOwner;

    // Mapping of NFTs to their sellers
    mapping(uint256 => address) public nftSellers;

    // Mapping of NFTs to their buyers
    mapping(uint256 => address) public nftBuyers;

    // Mapping of NFTs to their prices
    mapping(uint256 => uint256) public nftPrices;

    // Event for NFT listing
    event NFTListed(address indexed seller, uint256 indexed nftId);

    // Event for NFT sale execution
    event NFTSold(address indexed buyer, uint256 indexed nftId, uint256 price);

    // Event for NFT transfer
    event NFTTransferred(address indexed from, address indexed to, uint256 indexed nftId);

    // Function to list an NFT for sale
    function listNFTForSale(uint256 _nftId, uint256 _price) public {
        require(msg.sender == nftSellers[_nftId], "Only the seller can list an NFT for sale");
        nftPrices[_nftId] = _price;
        emit NFTListed(msg.sender, _nftId);
    }

    // Function to execute a sale of an NFT
    function executeSale(uint256 _nftId) public payable {
        require(msg.value >= nftPrices[_nftId], "Insufficient payment");
        address seller = nftSellers[_nftId];
        address buyer = msg.sender;
        uint256 price = nftPrices[_nftId];
        nftBuyers[_nftId] = buyer;
        nftSellers[_nftId] = address(0);
        nftPrices[_nftId] = 0;
        emit NFTSold(buyer, _nftId, price);
    }

    // Function to transfer an NFT
    function transferNFT(address _to, uint256 _nftId) public {
        require(msg.sender == nftSellers[_nftId] || msg.sender == nftBuyers[_nftId], "Only the seller or buyer can transfer an NFT");
        address from = nftBuyers[_nftId];
        if (from != address(0)) {
            nftBuyers[_nftId] = address(0);
        }
        nftsOfOwner[from].remove(_nftId);
        nftsOfOwner[_to].push(_nftId);
        emit NFTTransferred(from, _to, _nftId);
    }
}