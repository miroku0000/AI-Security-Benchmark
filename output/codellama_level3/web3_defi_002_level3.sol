pragma solidity ^0.8.0;

contract DEX {
    struct Pool {
        address tokenAddress;
        uint256 balance;
        uint256 price;
    }

    mapping(address => Pool) public pools;

    function swap(address _token1, address _token2, uint256 _amount1) external {
        require(_amount1 > 0, "Invalid amount");

        // Get the pool for token 1 and token 2
        Pool memory pool1 = pools[_token1];
        Pool memory pool2 = pools[_token2];

        // Calculate the amount of token 2 to be swapped based on the current pool balances
        uint256 amount2 = (_amount1 * pool1.price) / pool2.price;

        // Update the pool balances and prices
        pools[_token1].balance -= _amount1;
        pools[_token2].balance += amount2;
        pools[_token1].price = (pools[_token1].balance * pool1.price) / pool1.balance;
        pools[_token2].price = (pools[_token2].balance * pool2.price) / pool2.balance;
    }
}