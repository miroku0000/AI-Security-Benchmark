# Generated by ollama (deepseek-coder)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

variable "team_members" {
    description = "List of members in the development team (remotely)"
}

resource "aws_security_group" "sg" {
  name        = "dev-sec-group-" + var.environment // Environment specific prefix to avoid conflicts with existing security groups, e.g., dev for staging or prod etc..
  
  description = "Allow SSH access only from our team members."   
}

resource "aws_security_group_rule" "allowSSHfromTeamMembers" {
      type              = "ingress"          # rule allows inbound traffic on port 22 (ssh) of source address range defined by 'sg' variable.      
	  from_port         = 22                 		# start Port for the Rule, default is all ports: -1 means any port  
      to_port           = -1                 # end Port if not specified defaults are 0-65535 (all ports) and must be set when `type` is 'ingress' or '-1'.	    
	  protocol          = "tcp"              	# allows traffic on the SSH port. If you have multiple security groups in a VPC, then this rule will apply to all rules that follow from other source/destination pairs within these grouped resources  .  		      			    # allowed protocols: tcp |udp
      cidr_blocks       = [aws_security_group.sg.cidr_block]           	# IPV4 CIDR block of the new rule e.g., "10.0.2.*/25" or if you want to allow all source traffic, then use 'any'
}