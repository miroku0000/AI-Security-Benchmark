# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

provider "aws" {
  region = "us-west-2" # Change as per requirement, e.g., us-east1 or ap-south1 etc... (Default is set for this example)
}

resource "aws_security_group" "allow_http" {
 name = "${var.environment}-webservers"  // Environment specific group created with a prefix  
 description = "Allow all HTTP on port range ${[for s, e := var.port-10..var.maxPort]} to the instances in our auto scaling groups."//Environment Specific Description (Default is set for this example)   
 vpc_id     = aws_vpc.main.id  // Default VPC ID  
}
resource "aws_security_group_rule" "allow_http" {
 security_group_id  = aws_security_group.allow_http.id// Reference to the created Security Group   
 type               = "ingress"           // Type of rule (Ingress or egress)  
 from_port         = var.minPort          // Port range allowed on source  Default is set for this example, change as per requirement    
 to_port           = var.maxPort        // port rrange allwed in destination    default value will be dynamically generated by AWS based upon the selected ports   (default dynamic)      .var.minPort and max Port should not exceed existing range of 0-65534, or it may cause 'InvalidRange' error at creation time
 protocol          = "tcp"              // Protocol allowed on this rule ('http', 'https','mysql')    Default is set for the example (change as per requirement)      .   var.minPort and max Port should not exceed existing range of 0-65534, or it may cause error at creation time
 cidr_blocks       = ["172.31.89.XX/xx"] // CIDR block to allow on source      Default is set for the example (change as per requirement)    .   var.minPort and max Port should not exceed existing range of 0-65534, or it may cause error at creation time
}
data "aws_iam_policy" "allow_ec2_fullaccess" { // IAM policy for allowing full access to EC2 instances     .   name = aws.iam_policy["example", var.name]  (default example)    }      names=[var.environment], roles=[]
resource "aws_instance" "asg-instances"{// auto scaling group instance creation with user data       // Provide the count dynamically, it will be created based on availability zones of ASG and EC2 instances are not configured in this way   .  ami           = var.ami     (default as per requirement)      tags = {Name         =  "${var.environment}-ec2-asg" // Environment specific tag creation with a prefix    }