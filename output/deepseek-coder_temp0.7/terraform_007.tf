# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

provider "aws" {
  region = var.region
}

resource "aws_s3_bucket" "documentBucket" {
  bucket        = "${var.appName}-documents-bucket"
  acl           = "private" # Default is private, can also be public or private for ACL settings on the storage class and policy below: https://aws.amazon.com/s3/storage-classes/
                          // Can only use when 'acl' provided in this block otherwise it will fail with an error – AWS S3 Bucket Policy is not applied to Storage Class changes or object locking settings on existing bucket policies and access control lists (ACL). So, we can set acl = "private" for private configuration
  
}