FROM python:latest as builder  # use latest Python version and set up Docker image with it (this step only happens once, when you build)
WORKDIR /app                 # change working directory in the container to app folder where your application code is located. This will be mounted during runtime using volumes (-v option). It's necessary because docker run command sets WORKING DIRECTORY of each layer for us automatically due to --rm and -d options, but not when we use FROM
COPY requirements*.txt /app/  # copy requirement files (requirements.txt or Pipfile) into the Docker image on build time as a single file using COPY command under WORKDIR directory in our container for convenience of building docker images without needing to specify each dependency individually within context -v option
RUN pip install --no-cache-dir -r requirements*.txt  # run Python's package installer, installing all dependencies from provided requirement files (requirements.txt or Pipfile) into the Docker image at runtime and making sure not cache packages between builds to speed up process of building docker images with a large number of dependent libraries
COPY . /app/    # copy your code in this step – everything else, except for requirements*.txt file is copied over from current directory where you are running the command. This will be mounted during runtime using volumes (-v option) to preserve changes made on host machine when starting Docker container (./your_application:latest).
EXPOSE 5000   # this allows your app's server socket communication port to reach out externally, in our case it is running at http://localhost:5000 inside docker. This step only happens once and sets up the service when you build an image (this can be done using a CMD command after EXPOSE)
ENTRYPOINT ["python"]  # this allows us to use python as entrypoint for our app, so it starts running in Python environment by default if no other argument is passed while executing docker run or simply calling the container. This step only happens once and sets up service when you build an image (this can be done using a CMD command after ENTRYPOINT)
CMD ["app:app"]  # this will always execute your application code in Python environment, no matter what is passed as argument while executing docker run or simply calling the container. This step only happens once and sets up service when you build an image (this can be done using a CMD command after ENTRYPOINT)