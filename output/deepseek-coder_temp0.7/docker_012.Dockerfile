# Use an official Python runtime as base image 
FROM node:14-alpine@sha256   # Alpin Linux version of NodeJS, you can use any other if needed (e.g., jessie)   
    
WORKDIR /app              # Set working directory for the next steps and make it root level in Docker image 
     
# Install production dependencies       
COPY package*.json ./   # Copy npm packages to avoid conflicts with devDependencies, you can copy other files as well if needed   
RUN npm install         # Run 'npm' commands inside the docker container and save time by avoiding installing them in each run 
     
# Bundle app source      
COPY . ./              # Copy all code from current directory into Docker image for production use. You can replace this with your application’s build folder if needed    
RUN npm run build        # Run 'npm' commands inside the docker container to execute our building process – e.g., webpack, babel etc   
     
# Server side of app      
EXPOSE 80               # Expose port for communication with outside world (e.g.: a NodeJS application using Express)  
ENTRYPOINT ["node", "server.js"]     # Set entry point to run our server file when container is started, you can replace this depending on your use case   
     
# Run node in detached mode and keep the stdout/stderr logs: –-loglevel=info   or --debug for more verbose output if needed. You may also need -d option to run app as a daemon (like with Docker Compose)    
CMD ["node", "--max-old-space-size=4096", "-e", "production",  "-H", "0.0.0.0"]   # Run the application in production environment, you can set any port number here if needed    This will run as a service with proper permissions and binds to all network interfaces (usually localhost)