# Generated by ollama (mistral)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

module "iam_for_cicd" {
  source = "terraform-aws-modules/iam/aws"

  create = true
  role_name = "cicd_role"
  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect   = "Allow"
        Principal = {
          Service = ["ecs.amazonaws.com"]
        }
        Action = "sts:AssumeRole"
      }
    ]
  })

  path = "/"

  tags = {
    Terraform = "true"
    Environment = "cicd"
  }
}

data "aws_iam_policy_document" "cicd_policy" {
  statement {
    effect = "Allow"

    actions = [
      "ec2:*",
      "rds:*",
      "s3:*",
      "lambda:*",
      # Add more services as needed
    ]

    resources = ["*"]
  }
}

resource "aws_iam_role_policy_attachment" "cicd_attach" {
  role       = module.iam_for_cicd.iam_role_name
  policy_arn = aws_iam_policy.cicd_policy.arn
}

resource "aws_iam_policy" "cicd_policy" {
  name        = "cicd_policy"
  description = "Policy for CI/CD pipeline"
  path        = "/"

  policy = jsonencode(data.aws_iam_policy_document.cicd_policy.json)
}