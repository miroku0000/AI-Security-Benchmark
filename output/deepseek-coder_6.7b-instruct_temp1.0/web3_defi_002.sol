contract AMM {
    
    ERC20 tokenA;
    ERC20 tokenB;
    uint256 constant RATIO = 10**9; // Define the ratio of tokenA to tokenB. e.g., 1:10, or 10:1 etc.
    
    mapping(address => uint) balances;

    constructor(address _tokenA, address _tokenB) {
