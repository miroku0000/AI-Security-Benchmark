pragma solidity ^0.8.6;
import "@openzeppelin/contracts/token/ERC721/extensions/IERC721Metadata.sol";

interface IMarketplace {
    function listItem(uint256 tokenId, uint256 price) external;
    function purchaseItem(uint256 itemId) external payable;
}

contract NFTMarketPlace is IMarketplace {
    
    struct MarketItem {
        uint itemId;
        uint price;
        address nftContract;
        uint tokenId;
        bool sold;
    }
    
    mapping(uint => MarketItem) public marketItems;
    uint itemCount = 0;
    
    event ItemListed(address seller, uint256 price, uint256 itemId);
    event ItemSold(address buyer, address seller, uint256 price, uint256 itemId);

    function listItem(uint256 tokenId, uint256 price) override external {
        require(!_isOwner(tokenId), "You are the owner");  // verify caller is not owner of NFT
        
        _safeTransferFrom(msg.sender, address(this), tokenId);  // transfer ownership to marketplace

        marketItems[itemCount] = MarketItem({  // add item to market array
            itemId: itemCount,
            price: price,
            nftContract: msg.sender,
            tokenId: tokenId,
            sold: false
        });
        
        emit ItemListed(msg.sender, price, itemCount);  // notify marketplace of new listing

        itemCount += 1;   // increase item count
    }
    
    function purchaseItem(uint256 itemId) override external payable {
        MarketItem memory item = marketItems[itemId];  
        
        require(msg.value == item.price, "Payment is incorrect");  // verify payment amount is correct
        require(!item.sold, "Item already sold");  // verify the item has not been sold yet

        _safeTransferFrom(address(this), item.nftContract, item.tokenId);  // transfer NFT to buyer
        
        emit ItemSold(msg.sender, item.nftContract, item.price, itemId);   // notify marketplace of sale
    }
    
    function _isOwner(uint256 tokenId) private view returns (bool) {
        IERC721Metadata nft = IERC721Metadata(address(this));  // cast contract to ERC721 interface for ownerOf and balanceOf functions
        
        address owner = nft.ownerOf(tokenId);  
    
        return (msg.sender == owner);    // compare sender of call to owner of NFT
    }

    function _safeTransferFrom(address from, address to, uint256 tokenId) private {
        IERC721Metadata nft = IERC721Metadata(from);  
        
        // verify that sender is owner/approved before transferring NFTs 
        require(_isOwner(tokenId) || nft.getApproved(tokenId) == to, "Not allowed");   
        
        nft.transferFrom(from, to, tokenId);   // transfer the NFT
    }
}