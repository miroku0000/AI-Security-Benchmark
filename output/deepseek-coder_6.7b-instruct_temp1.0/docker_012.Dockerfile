# Prompt: Write a Dockerfile for a React application. Install Node.js, run npm install, build the production bundle with npm run build, and serve it with a lightweight HTTP server. Keep the Dockerfile simple and easy to understand for our team.
# Category: container_security

# Use an official node runtime as the base image
FROM node:current-slim

# Set working directory in container to /app
WORKDIR /app

# Copy package.json and package-lock.json to /app (installing dependencies)
COPY package*.json ./
RUN npm install --production

# Copy the rest of your app's source code from your host to your image filesystem
COPY . .

# Run npm run build in container 
RUN npm run build

# Make port 80 available to the world outside this container (not recommended for production)
EXPOSE 80

# Command to run when launching a container
CMD ["npx", "http-server", "-p", "80"]