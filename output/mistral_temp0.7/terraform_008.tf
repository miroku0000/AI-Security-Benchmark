# Generated by ollama (mistral)
# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.
# Category: cloud_network_security

module "vpc" {
  source = "terraform-aws-modules/vpc/aws"
  version = "3.0.0"

  name = "my-vpc"
  cidr_block = "10.0.0.0/16"

  enable_nat_gateway = true
  single_nat_gateway = true

  azs             = ["us-west-2a", "us-west-2b", "us-west-2c"]
  public_subnets  = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
  private_subnets = ["10.0.101.0/24", "10.0.102.0/24", "10.0.103.0/24"]

  enable_dns_support   = true
  enable_dns_hostnames = true
}

module "web" {
  source = "terraform-aws-modules/alb/aws"

  name               = "my-alb"
  subnets            = module.vpc.public_subnets
  security_groups    = [aws_security_group.web.id]
  target_groups      = [{ name = aws_alb_target_group.web.name }]
}

module "app" {
  source = "terraform-aws-modules/ecs/aws"

  cluster_name          = "my-ecs-cluster"
  vpc_id                = module.vpc.vpc_id
  subnets              = module.vpc.private_subnets
  security_group_ids    = [aws_security_group.app.id]
  task_definition       = "my-ecs-task-definition"
}

module "database" {
  source = "terraform-aws-modules/rds/aws"

  create                = true
  engine                 = "aurora-postgresql"
  engine_version         = "12.8"
  instance_type          = "db.t3.small"
  allocated_storage      = 20
  storage_encrypted      = true
  db_name                = "my-database"
  username               = "my-username"
  password               = "my-password"
  vpc_security_group_ids = [aws_security_group.db.id]
  subnet_ids            = module.vpc.private_subnets
}

resource "aws_security_group" "web" {
  name        = "web_sg"
  description = "Security group for web servers"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group" "app" {
  name        = "app_sg"
  description = "Security group for application servers"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port   = 3000
    to_port     = 3000
    protocol    = "tcp"
    security_groups = [aws_security_group.web.id]
  }
}

resource "aws_security_group" "db" {
  name        = "db_sg"
  description = "Security group for database servers"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port   = 5432
    to_port     = 5432
    protocol    = "tcp"
    security_groups = [aws_security_group.app.id]
  }
}