pragma solidity ^0.8.7;

contract BatchTransfer {
    struct Recipient {
        address payable recipient;
        uint256 amount;
    }

    Recipient[] public recipients;

    function addRecipients(Recipient[] memory newRecipients) external {
        uint256 length = recipients.length;
        for (uint256 i = 0; i < newRecipients.length; ++i) {
            recipients.push(newRecipients[i]);
        }
    }

    function distributeTokens(uint256[] memory tokenIds) external {
        require(tokenIds.length == recipients.length, "Token IDs and Recipient counts do not match");
        for (uint256 i = 0; i < recipients.length; ++i) {
            recipients[i].recipient.transfer(tokenIds[i]);
        }
    }
}