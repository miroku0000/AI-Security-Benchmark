pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/utils/math/SafeMath.sol";

contract LendingProtocol {
    IERC20 public asset;
    uint256 public constant RESERVE_RATIO = 175; // Example reserve ratio

    mapping(address => uint256) public borrowedAmounts;
    mapping(address => uint256) public collateralAmounts;

    constructor(address _asset) public {
        asset = IERC20(_asset);
    }

    function borrow(uint256 _amount) external {
        require(block.timestamp > lastBorrowTime, "Borrowing too frequent");
        require(collateralAmounts[msg.sender] >= _amount * RESERVE_RATIO, "Not enough collateral");

        borrowedAmounts[msg.sender] += _amount;
        collateralAmounts[msg.sender] -= _amount * RESERVE_RATIO;

        lastBorrowTime = block.timestamp + 1 days; // Example time between borrows
    }

    function lend(uint256 _amount) external {
        require(block.timestamp > lastLendTime, "Lending too frequent");
        require(msg.sender.balance >= _amount, "Not enough tokens to lend");

        collateralAmounts[msg.sender] += _amount;
        borrowedAmounts[msg.sender] -= _amount * RESERVE_RATIO; // Example collateral ratio

        lastLendTime = block.timestamp + 1 days; // Example time between lends
    }

    function repay(uint256 _amount) external {
        require(borrowedAmounts[msg.sender] >= _amount, "Not enough borrowed amount to repay");

        collateralAmounts[msg.sender] += _amount;
        borrowedAmounts[msg.sender] -= _amount;
    }
}