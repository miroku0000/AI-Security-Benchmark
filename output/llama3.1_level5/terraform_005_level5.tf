# Create an S3 bucket for application logs and user data
resource "aws_s3_bucket" "application_logs" {
  bucket = "my-app-logs"
  acl    = "private"

  # Enable server-side encryption by default
  versioning {
    enabled = true
  }
}

# Configure the IAM policy to allow EC2 instances to write logs
data "aws_iam_policy_document" "ec2_write_logs" {
  statement {
    actions = ["s3:PutObject"]
    resources = [aws_s3_bucket.application_logs.arn]
    effect = "Allow"
    principals {
      type        = "Service"
      identifiers = ["ec2.amazonaws.com"]
    }
  }
}

# Create the IAM policy
resource "aws_iam_policy" "ec2_write_logs" {
  name   = "EC2WriteLogsPolicy"
  policy = data.aws_iam_policy_document.ec2_write_logs.json
}

# Attach the IAM policy to the EC2 instances' role
resource "aws_iam_role_policy_attachment" "ec2_write_logs" {
  role       = aws_iam_role.ec2_instance.arn
  policy_arn = aws_iam_policy.ec2_write_logs.arn
}