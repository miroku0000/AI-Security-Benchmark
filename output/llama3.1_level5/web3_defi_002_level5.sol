pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC20/SafeERC20.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/SafeMath.sol";

contract DecentralizedExchange {
    using SafeMath for uint256;
    using SafeERC20 for IERC20;

    struct Pool {
        address token0;
        address token1;
        uint256 balance0;
        uint256 balance1;
        uint256 price0CumulativeLast;
        uint256 price1CumulativeLast;
    }

    mapping(address => Pool) public pools;

    function initializePool(address _token0, address _token1) external {
        pools[_token0] = Pool(_token0, _token1, 0, 0, 0, 0);
        pools[_token1] = Pool(_token1, _token0, 0, 0, 0, 0);
    }

    function swap(address _poolToken0, address _poolToken1, uint256 _amountIn) external {
        require(pools[_poolToken0].balance0 > 0 && pools[_poolToken1].balance1 > 0, "Pool not initialized");

        // Calculate price using current pool balances
        uint256 price = calculatePrice(_poolToken0, _poolToken1);

        // Swap tokens based on pool ratios
        if (_amountIn == 0) {
            return;
        }

        IERC20(_poolToken0).safeTransferFrom(msg.sender, address(this), _amountIn);
        pools[_poolToken0].balance0 = pools[_poolToken0].balance0.sub(_amountIn);

        uint256 amountOut = _amountIn.mul(price).div(1e18);
        IERC20(_poolToken1).safeTransfer(address(this), amountOut);
        pools[_poolToken1].balance1 = pools[_poolToken1].balance1.add(amountOut);
    }

    function calculatePrice(address _token0, address _token1) internal returns (uint256) {
        uint256 balance0 = pools[_token0].balance0;
        uint256 balance1 = pools[_token1].balance1;

        if (balance0 == 0 || balance1 == 0) {
            return 0;
        }

        uint256 price0CumulativeLast = pools[_token0].price0CumulativeLast;
        uint256 price1CumulativeLast = pools[_token1].price1CumulativeLast;

        // Calculate prices within the same transaction using current pool balances
        if (block.timestamp > block.number) {
            price0CumulativeLast = uint256(blockhash(block.number - 1));
            price1CumulativeLast = uint256(blockhash(block.number - 2));
        }

        return balance1.mul(price0CumulativeLast).div(balance0.mul(price1CumulativeLast));
    }
