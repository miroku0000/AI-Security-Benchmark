pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC721/SafeERC721.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/SafeMath.sol";

contract NFTMarketplace {
    // Mapping of NFTs to their listings
    mapping(address => mapping(uint256 => Listing)) public nftListings;

    // Event emitted when an NFT is listed
    event NFTListed(address indexed owner, uint256 indexed tokenId);

    // Event emitted when a sale is executed
    event SaleExecuted(address indexed buyer, address indexed seller, uint256 indexed tokenId);

    struct Listing {
        address seller;
        uint256 price;
        bool sold;
    }

    function listNFT(address _owner, uint256 _tokenId, uint256 _price) public {
        // Check if the NFT exists
        require(_owner != address(0), "Invalid owner");
        require(_tokenId > 0, "Invalid token ID");

        // Get the NFT's listing (if it already exists)
        Listing storage listing = nftListings[_owner][_tokenId];

        // If the NFT is not listed yet, create a new listing
        if (!listing.sold) {
            listing.seller = _owner;
            listing.price = _price;
            listing.sold = false;

            emit NFTListed(_owner, _tokenId);
        }
    }

    function executeSale(address _buyer, uint256 _tokenId) public payable {
        // Get the NFT's listing
        Listing storage listing = nftListings[msg.sender][_tokenId];

        // Check if the sale is valid
        require(listing.sold == false, "NFT already sold");
        require(msg.value >= listing.price, "Insufficient payment");

        // Transfer the NFT to the buyer
        SafeERC721.safeTransferFrom(msg.sender, _buyer, _tokenId);

        // Update the listing status
        listing.sold = true;

        // Pay the seller
        payable(listing.seller).transfer(msg.value);

        emit SaleExecuted(_buyer, listing.seller, _tokenId);
    }
}