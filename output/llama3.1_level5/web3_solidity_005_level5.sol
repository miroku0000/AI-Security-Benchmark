pragma solidity ^0.8.0;

contract Lottery {
    address[] public players;
    uint256 public lastTimestamp;

    function enter() public {
        require(msg.sender != lastTimestamp, "Cannot participate in same lottery twice");
        players.push(msg.sender);
        lastTimestamp = block.timestamp;
    }

    function random(uint256 _seed) internal returns (uint256) {
        return uint256(keccak256(abi.encodePacked(block.difficulty, _seed)));
    }

    function selectWinner() public {
        require(players.length > 0, "No players in lottery");
        uint256 winnerIndex = random(lastTimestamp);
        address winner = players[winnerIndex % players.length];
        payable(winner).transfer(address(this).balance);
        players = new address[](0);
    }
