# Configure the AWS Provider
provider "aws" {
  region = "us-west-2"
}

# Create an IAM role for EC2 instances to access S3 and DynamoDB
resource "aws_iam_role" "ec2_s3_dynamodb_access" {
  name        = "ec2-s3-dynamodb-access-role"
  description = "Role for EC2 instances to access S3 and DynamoDB"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      }
    ]
  })
}

resource "aws_iam_role_policy" "ec2_s3_dynamodb_access_policy" {
  name   = "ec2-s3-dynamodb-access-policy"
  role   = aws_iam_role.ec2_s3_dynamodb_access.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = [
          "s3:GetObject",
          "s3:PutObject",
          "dynamodb:GetItem",
          "dynamodb:PutItem"
        ]
        Effect = "Allow"
        Resource = [
          aws_s3_bucket.example.arn,
          aws_dynamodb_table.example.arn
        ]
      }
    ]
  })
}

# Create an IAM instance profile for EC2 instances to use the role
resource "aws_iam_instance_profile" "ec2_s3_dynamodb_access_profile" {
  name = "ec2-s3-dynamodb-access-profile"
  role = aws_iam_role.ec2_s3_dynamodb_access.name
}

# Create an S3 bucket for storing web application files
resource "aws_s3_bucket" "example" {
  bucket = "example-web-app-bucket"
  acl    = "private"

  versioning {
    enabled = true
  }
}

# Create a DynamoDB table for storing user data
resource "aws_dynamodb_table" "example" {
  name           = "example-user-data-table"
  billing_mode   = "PAY_PER_REQUEST"
  hash_key       = "id"
  range_key      = "name"

  attribute {
    name = "id"
    type = "S"
  }

  attribute {
    name = "name"
    type = "S"
  }
}

# Create an EC2 instance with the IAM role and S3 bucket
resource "aws_instance" "example" {
  ami           = "ami-0c94855ba95c71c99"
  instance_type = "t2.micro"

  vpc_security_group_ids = [aws_security_group.example.id]

  iam_instance_profile = aws_iam_instance_profile.ec2_s3_dynamodb_access_profile.name

  tags = {
    Name = "example-web-app-instance"
  }
}

# Create a security group for the EC2 instance
resource "aws_security_group" "example" {
  name        = "example-web-app-security-group"
  description = "Security group for example web app"

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
