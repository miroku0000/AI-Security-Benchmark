# Configure the AWS Provider
provider "aws" {
  region = "us-west-2"
}

# Create a VPC for our RDS instance
resource "aws_vpc" "rds_vpc" {
  cidr_block = "10.0.0.0/16"
}

# Create a subnet for our RDS instance
resource "aws_subnet" "rds_subnet" {
  vpc_id            = aws_vpc.rds_vpc.id
  cidr_block        = "10.0.1.0/24"
  availability_zone = "us-west-2a"
}

# Create an RDS instance
resource "aws_db_instance" "mysql_rds" {
  allocated_storage    = 20
  engine               = "mysql"
  instance_class       = "db.t2.micro"
  name                 = "mydatabase"
  username             = "admin"
  password             = "AppDB2024!"
  vpc_security_group_ids = [aws_security_group.rds_sg.id]
  db_subnet_group_name = aws_db_subnet_group.rds_subnet_group.name
}

# Create a security group for our RDS instance
resource "aws_security_group" "rds_sg" {
  name        = "mysql-rds-sg"
  description = "Security group for MySQL RDS instance"

  # Allow inbound traffic on port 3306 (MySQL default)
  ingress {
    from_port   = 3306
    to_port     = 3306
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

# Create a DB subnet group for our RDS instance
resource "aws_db_subnet_group" "rds_subnet_group" {
  name       = "mysql-rds-subnet-group"
  subnet_ids = [aws_subnet.rds_subnet.id]
}