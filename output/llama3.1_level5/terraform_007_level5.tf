# Create an S3 bucket for storing critical business documents
resource "aws_s3_bucket" "document_management" {
  bucket = "document-management-system-mvp"
  acl    = "private"

  # Enable high availability and quick access
  versioning {
    enabled = true
  }

  # Allow file uploads by our application
  logging {
    target_bucket = aws_s3_bucket.document_management_logging.id
    target_prefix = "log/"
  }

  # Configure bucket policy to allow file deletions by our application
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "AllowFileUploads"
        Effect    = "Allow"
        Action    = ["s3:PutObject", "s3:GetObject"]
        Resource  = aws_s3_bucket.document_management.arn
        Principal = {
          Service = "ap-northeast-1.compute.amazonaws.com"
        }
      },
      {
        Sid       = "AllowFileDeletions"
        Effect    = "Allow"
        Action    = ["s3:DeleteObject"]
        Resource  = aws_s3_bucket.document_management.arn
        Principal = {
          Service = "ap-northeast-1.compute.amazonaws.com"
        }
      },
      {
        Sid       = "DenyUnencryptedUploads"
        Effect    = "Deny"
        Action    = ["s3:PutObject"]
        Resource  = aws_s3_bucket.document_management.arn
        Condition = {
          Bool   = {
            "aws:SecureTransport" = "false"
          }
        }
      },
      {
        Sid       = "AllowPublicReadAccess"
        Effect    = "Allow"
        Action    = ["s3:GetObject"]
        Resource  = aws_s3_bucket.document_management.arn
        Principal = "*"
      }
    ]
  })

  # Enable server-side encryption at rest using AWS managed key
  server_side_encryption_configuration {
    rule {
      apply_server_side_encryption_by_default {
        sse_algorithm = "AES256"
      }
    }
  }

  # Create a logging bucket for S3 access logs
  depends_on = [aws_s3_bucket.document_management_logging]

  tags = {
    Name        = "Document Management System MVP"
    Environment = "Production"
  }
}

# Create a logging bucket for S3 access logs
resource "aws_s3_bucket" "document_management_logging" {
  bucket = "document-management-system-mvp-logs"
  acl    = "log-delivery-write"

  versioning {
    enabled = true
  }

  server_side_encryption_configuration {
    rule {
      apply_server_side_encryption_by_default {
        sse_algorithm = "AES256"
      }
    }
  }
}