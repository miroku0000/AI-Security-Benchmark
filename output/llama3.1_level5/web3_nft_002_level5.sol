pragma solidity ^0.8.0;

contract PublicMint {
    // Mapping of owner to their balance
    mapping(address => uint256) public balances;
    
    // Array of all NFTs
    address[] public nftOwners;
    
    // Maximum number of NFTs that can be minted per wallet
    uint256 public maxNftsPerWallet = 5;
    
    // Price of each NFT in wei
    uint256 public price = 1 ether;
    
    // Total supply of NFTs
    uint256 public totalSupply = 1000;
    
    // Mapping of NFT to its owner
    mapping(uint256 => address) public nftOwnersMap;
    
    function mint() public {
        require(balances[msg.sender] < maxNftsPerWallet, "Max NFTs per wallet reached");
        
        uint256 tokenId = totalSupply - 1;
        totalSupply -= 1;
        
        balances[msg.sender]++;
        nftOwners.push(msg.sender);
        nftOwnersMap[tokenId] = msg.sender;
    }
}