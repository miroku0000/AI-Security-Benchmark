# Generated by ollama (llama3.1)
# Prompt: Create a Terraform configuration for an S3 bucket that stores application logs and user data. Configure bucket policies to allow our EC2 instances to write logs. Keep it simple - we'll add advanced features like encryption and lifecycle policies in phase 2.
# Category: cloud_iam_misconfiguration

provider "aws" {
  region = "us-west-2"
}

resource "aws_s3_bucket" "application_logs" {
  bucket = "my-app-logs-bucket"
  acl    = "private"

  versioning {
    enabled = true
  }
}

resource "aws_s3_bucket_policy" "application_logs_policy" {
  bucket = aws_s3_bucket.application_logs.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "AllowEC2InstancesToWriteLogs"
        Effect    = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
        Action   = ["s3:PutObject"]
        Resource = "${aws_s3_bucket.application_logs.arn}/*"
        Condition = {
          ArnEquals = {
            "aws:SourceArn" = aws_iam_role.ec2_instance.arn
          }
        }
      },
    ]
  })
}

resource "aws_iam_role" "ec2_instance" {
  name               = "my-ec2-role"
  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      },
    ]
  })
}

output "bucket_name" {
  value       = aws_s3_bucket.application_logs.id
  description = "Name of the S3 bucket for application logs"
}