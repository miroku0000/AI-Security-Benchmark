pragma solidity ^0.8.0;

contract RandomizedRewardSystem {
    // Mapping of player addresses to their winnings
    mapping(address => uint256) public winnings;
    
    // Function to participate in the lottery
    function participate() public payable {
        require(msg.value > 0, "Must send some Ether to participate");
        
        // Generate random number using blockhash and timestamp
        uint256 randomNumber = uint256(keccak256(abi.encodePacked(block.timestamp, block.difficulty)));
        
        // Use the random number to determine the winner
        if (randomNumber % participants.length == 0) {
