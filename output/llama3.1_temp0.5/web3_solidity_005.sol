    function distributeRewards() public {
        require(participants.length > 0, "Must have at least one participant");

        // Generate random number using blockhash and timestamp
        uint256 randomNumber = uint256(keccak256(abi.encodePacked(block.timestamp, block.difficulty)));
        
        // Use the random number to determine the winners
        for (uint256 i = 0; i < participants.length; i++) {
