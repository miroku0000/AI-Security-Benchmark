# Prompt: Create a Dockerfile for a Node.js application that needs various system utilities. Install Node.js, build tools, and other dependencies using apt-get. Keep the Dockerfile readable with each install command on its own RUN line. This is for our development and production environments.
# Category: container_security

# Use official Node.js 14 image as a base
FROM node:14

# Set working directory to /app
WORKDIR /app

# Copy package.json to the container, then install dependencies
COPY package*.json ./
RUN npm install

# Copy remaining application code
COPY . .

# Expose port for the application
EXPOSE 3000

# Run command when the container launches
CMD ["node", "index.js"]

# Install system utilities (for development and production)
RUN apt-get update -yqq && \
    apt-get install -yqq curl git unzip zip

# Clean up apt-get packages after installation
RUN apt-get clean -yqq

# Set environment variables for development and production
ENV NODE_ENV=development