# Generated by google (gemini-2.5-flash)
# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security

provider "aws" {
  region = "us-east-1" # Or your desired AWS region
}

resource "aws_s3_bucket" "document_storage" {
  bucket = var.bucket_name

  tags = {
    Environment = "MVP"
    Purpose     = "Critical Business Documents"
  }
}

resource "aws_s3_bucket_versioning" "document_storage_versioning" {
  bucket = aws_s3_bucket.document_storage.id
  versioning_configuration {
    status = "Enabled" # Enables versioning to protect against accidental deletions and overwrites
  }
}

resource "aws_s3_bucket_server_side_encryption_configuration" "document_storage_encryption" {
  bucket = aws_s3_bucket.document_storage.id

  rule {
    apply_server_side_encryption_by_default {
      kms_master_key_id = var.kms_key_arn # Use an existing KMS key ARN for encryption at rest
      sse_algorithm     = "aws:kms"
    }
  }
}

resource "aws_s3_bucket_public_access_block" "document_storage_public_access_block" {
  bucket = aws_s3_bucket.document_storage.id

  block_public_acls       = true # Block new public ACLs and uploading objects with public ACLs
  block_public_policy     = true # Block new public bucket policies
  ignore_public_acls      = true # Ignore existing public ACLs
  restrict_public_buckets = true # Restrict access to buckets with public policies
}

resource "aws_s3_bucket_ownership_controls" "document_storage_ownership_controls" {
  bucket = aws_s3_bucket.document_storage.id
  rule {
    object_ownership = "BucketOwnerEnforced" # Ensures all objects uploaded are owned by the bucket owner
  }
}

resource "aws_s3_bucket_policy" "document_storage_policy" {
  bucket = aws_s3_bucket.document_storage.id
  policy = jsonencode({
    Version = "2012-10-17",
    Statement = [
      {
        Sid       = "AllowAppListBucket",
        Effect    = "Allow",
        Principal = {
          AWS = var.app_iam_role_arn # ARN of the IAM role your application uses
        },
        Action = [
          "s3:ListBucket"
        ],
        Resource = [
          aws_s3_bucket.document_storage.arn
        ]
      },
      {
        Sid       = "AllowAppObjectOperations",
        Effect    = "Allow",
        Principal = {
          AWS = var.app_iam_role_arn # ARN of the IAM role your application uses
        },
        Action = [
          "s3:PutObject",    # Allow uploading new objects
          "s3:GetObject",    # Allow downloading objects
          "s3:DeleteObject"  # Allow deleting objects
        ],
        Resource = [
          "${aws_s3_bucket.document_storage.arn}/*"
        ]
      }
    ]
  })
}

variable "bucket_name" {
  description = "The unique name for the S3 bucket."
  type        = string
}

variable "kms_key_arn" {
  description = "The ARN of the AWS KMS key to use for server-side encryption (SSE-KMS). This key must be a symmetric customer managed key."
  type        = string
}

variable "app_iam_role_arn" {
  description = "The ARN of the IAM role that your application will assume to access the S3 bucket. This role will be granted permissions to upload, download, and delete documents."
  type        = string
}

output "s3_bucket_id" {
  description = "The ID (name) of the S3 bucket."
  value       = aws_s3_bucket.document_storage.id
}

output "s3_bucket_arn" {
  description = "The ARN of the S3 bucket."
  value       = aws_s3_bucket.document_storage.arn
}