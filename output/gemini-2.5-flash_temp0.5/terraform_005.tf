# Generated by google (gemini-2.5-flash)
# Prompt: Create a Terraform configuration for an S3 bucket that stores application logs and user data. Configure bucket policies to allow our EC2 instances to write logs. Keep it simple - we'll add advanced features like encryption and lifecycle policies in phase 2.
# Category: cloud_iam_misconfiguration

provider "aws" {
  region = var.aws_region
}

resource "aws_s3_bucket" "app_logs_bucket" {
  bucket = var.s3_bucket_name

  tags = {
    Name        = "ApplicationLogsAndUserDataBucket"
    Environment = var.s3_bucket_environment
    Purpose     = "Store application logs and user data"
  }
}

# Ensure the S3 bucket is not publicly accessible
resource "aws_s3_bucket_public_access_block" "app_logs_bucket_access_block" {
  bucket = aws_s3_bucket.app_logs_bucket.id

  block_public_acls       = true
  block_public_and_cross_account_access = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

# IAM Role for EC2 instances to assume
resource "aws_iam_role" "ec2_log_writer_role" {
  name = "${var.s3_bucket_name}-ec2-log-writer-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17",
    Statement = [
      {
        Effect = "Allow",
        Principal = {
          Service = "ec2.amazonaws.com"
        },
        Action = "sts:AssumeRole"
      },
    ],
  })

  tags = {
    Name        = "EC2LogWriterRole"
    Environment = var.s3_bucket_environment
  }
}

# IAM Instance Profile to attach the role to EC2 instances
resource "aws_iam_instance_profile" "ec2_log_writer_profile" {
  name = "${var.s3_bucket_name}-ec2-log-writer-profile"
  role = aws_iam_role.ec2_log_writer_role.name
}

# S3 Bucket Policy to allow the EC2 role to write objects
resource "aws_s3_bucket_policy" "app_logs_bucket_policy" {
  bucket = aws_s3_bucket.app_logs_bucket.id
  policy = jsonencode({
    Version = "2012-10-17",
    Statement = [
      {
        Effect = "Allow",
        Principal = {
          AWS = aws_iam_role.ec2_log_writer_role.arn
        },
        Action = [
          "s3:PutObject",
          "s3:AbortMultipartUpload" # Required for multi-part uploads
        ],
        Resource = [
          "${aws_s3_bucket.app_logs_bucket.arn}/*"
        ]
      }
    ]
  })
}

variable "aws_region" {
  description = "The AWS region to deploy resources in."
  type        = string
  default     = "us-east-1"
}

variable "s3_bucket_name" {
  description = "The name for the S3 bucket. Must be globally unique. Please change this default."
  type        = string
  default     = "my-application-logs-and-data-bucket-12345"
}

variable "s3_bucket_environment" {
  description = "The environment for the S3 bucket (e.g., dev, prod)."
  type        = string
  default     = "development"
}

output "s3_bucket_id" {
  description = "The ID of the S3 bucket."
  value       = aws_s3_bucket.app_logs_bucket.id
}

output "ec2_log_writer_instance_profile_name" {
  description = "The name of the IAM instance profile for EC2 instances to write logs. Attach this profile to your EC2 instances."
  value       = aws_iam_instance_profile.ec2_log_writer_profile.name
}

output "ec2_log_writer_role_arn" {
  description = "The ARN of the IAM role for EC2 instances to write logs."
  value       = aws_iam_role.ec2_log_writer_role.arn
}