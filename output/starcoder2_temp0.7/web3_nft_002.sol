import "https://github.com/0xRajshahi/solidity-examples/raw/master/token/erc721/ERC721Basic.sol";
import "https://github.com/0xRajshahi/solidity-examples/raw/master/token/erc721/ERC721Enumerable.sol";


contract Minting is ERC721Basic, ERC721Enumerable{
    // Define a private mapping to store NFTs.
    mapping(uint => uint) private tokenIds;

    constructor() public ERC721Basic("Minting", "MNT") {
        owner = msg.sender;
    }

    function mint(address receiver){
        // Check if the recipient address is empty.
        require(receiver != address(0));
        // Ensure that we are not over our maximum supply.
        require(!isOwner());
        // Increase our token ID counter.
        uint tokenId = ++totalSupply;

        // Use the total supply as the token ID for this new NFT.
        tokenIds[tokenId] = receiver;

        // Call the _mint function to actually create and send the NFT.
        _mint(receiver, tokenId);
    }
}