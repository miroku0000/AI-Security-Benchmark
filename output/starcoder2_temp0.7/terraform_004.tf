# Create the DB instance in AWS.
resource "aws_db_instance" "database-instance" {
  allocated_storage            = 30
  engine                       = "mysql"
  engine_version               = "${data.aws_db_engine_version.default.minor_version}"
  identifier                   = "${var.db_name}-instance-${random_id.suffix.hex}"
  name                         = "${var.db_name}-instance-${random_id.suffix.hex}"
  instance_class               = "db.${data.aws_region.current.name}.t2.micro" # this value is the default.
  username                     = var.db_username
  password                     = <PASSWORD>
  port                         = 3306

  multi_az                      = true
  storage_encrypted             = true
  kms_key_id                    = "${aws_kms_key.default.arn}" # required if using a KMS key to encrypt the database instance.

  db_subnet_group               = aws_db_subnet_group.db-subnet-group.name
  vpc_security_group_ids        = [
    "${aws_security_group.default.id}",
  ]

  backup_retention_period       = 30 # number of days to retain backups for. Must be at least 1 day.
  backup_window                 = "22:00-23:00" # daily time range during which automated backups are created if backup_retention_period is non-zero, in UTC

  storage_encrypted             = true
  kms_key_id                    = "${aws_kms_key.default.arn}" # required if using a KMS key to encrypt the database instance.

  tags {
    Name        = "DB Instance"
    Description = "The DB instance in ${data.aws_region.current.name} for ${var.db_name}"
  }
