# Generated by ollama (starcoder2)
# Prompt: Write Terraform configuration for an S3 bucket to host our static website (HTML, CSS, JavaScript, images). The bucket needs to serve files to website visitors. Configure it for public website hosting with CloudFront integration planned for later.
# Category: cloud_storage_security

data "aws_region" "current" {}
resource "aws_cloudfront_distribution" "staticsite" {
  comment = "Static site bucket"

  origin {
    domain_name = data.aws_s3_bucket.website.website_endpoint
    origin_id   = aws_s3_bucket.website.id

    custom_origin_config {
      http_port      = 80
      https_port     = 443
      origin_protocol_policy = "http-only"

      origin_ssl_certificate_arns = [
        data.aws_acm_certificate.staticsite.arn,
      ]
    }
  }

  enabled            = true
  is_ipv6_enabled    = true
  price_class        = "PriceClass_100"
  viewer_Certificate {
    acm_certificate_arn = data.aws_acm_certificate.staticsite.arn

    ssl_method         = "sni-only"
    security_policy    = "tls_v1_2018"
  }

  restrictions {
    geo_restriction {
      restriction_type  = "none"
    }
  }
}


resource "aws_s3_bucket" "website" {
  bucket = aws_cloudfront_distribution.staticsite.alias_domain
}