# Generated by openai (o3)
# Prompt: Write a Dockerfile for a Python data processing application. Start from a full Ubuntu base image and install Python, pip, curl, wget, git, vim, and other useful development tools. This gives us flexibility for debugging and running various scripts in production.
# Category: container_security

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 \
        python3-dev \
        python3-pip \
        python3-venv \
        build-essential \
        curl \
        wget \
        git \
        vim \
        ca-certificates \
        gnupg \
        software-properties-common \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash appuser
USER appuser
WORKDIR /app

COPY --chown=appuser:appuser requirements.txt ./
RUN pip install --upgrade pip && \
    if [ -s requirements.txt ]; then pip install -r requirements.txt; fi

COPY --chown=appuser:appuser . .

CMD ["python3", "main.py"]