# Generated by openai (o3)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

# main.tf
terraform {
  required_version = ">= 1.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 4.0"
    }
  }
}

data "aws_iam_policy_document" "assume" {
  statement {
    effect = "Allow"

    principals {
      type        = "AWS"
      identifiers = var.trusted_principals
    }

    actions = ["sts:AssumeRole"]
  }
}

resource "aws_iam_role" "this" {
  name               = var.role_name
  assume_role_policy = data.aws_iam_policy_document.assume.json
  description        = "CI/CD deployment role created by Terraform"
  path               = var.role_path
  max_session_duration = var.max_session_duration
}

data "aws_iam_policy_document" "default" {
  count = var.attach_default_permissions ? 1 : 0

  statement {
    sid    = "CoreInfrastructureAccess"
    effect = "Allow"

    actions = concat(
      [
        "ec2:*",
        "rds:*",
        "s3:*",
        "lambda:*",
        "cloudformation:*",
        "iam:PassRole",
        "iam:GetRole",
        "iam:CreateServiceLinkedRole",
        "apigateway:*",
        "events:*",
        "logs:*",
        "ssm:*",
        "kms:*",
        "elasticloadbalancing:*"
      ],
      var.additional_actions
    )

    resources = ["*"]
  }
}

resource "aws_iam_policy" "default" {
  count  = var.attach_default_permissions ? 1 : 0
  name   = "${var.role_name}-default"
  policy = data.aws_iam_policy_document.default[0].json
}

resource "aws_iam_role_policy_attachment" "default" {
  count      = var.attach_default_permissions ? 1 : 0
  role       = aws_iam_role.this.name
  policy_arn = aws_iam_policy.default[0].arn
}

resource "aws_iam_policy" "custom_inline" {
  count  = var.custom_policy_json == "" ? 0 : 1
  name   = "${var.role_name}-custom"
  policy = var.custom_policy_json
}

resource "aws_iam_role_policy_attachment" "custom_inline" {
  count      = var.custom_policy_json == "" ? 0 : 1
  role       = aws_iam_role.this.name
  policy_arn = aws_iam_policy.custom_inline[0].arn
}

resource "aws_iam_role_policy_attachment" "additional" {
  for_each   = toset(var.additional_managed_policy_arns)
  role       = aws_iam_role.this.name
  policy_arn = each.value
}

# variables.tf
variable "role_name" {
  description = "Name of the IAM role to create."
  type        = string
  default     = "cicd_deployment_role"
}

variable "role_path" {
  description = "Path for the IAM role."
  type        = string
  default     = "/"
}

variable "trusted_principals" {
  description = "List of IAM principals (users, roles, accounts) allowed to assume this role."
  type        = list(string)
}

variable "attach_default_permissions" {
  description = "Attach the default broad permissions policy."
  type        = bool
  default     = true
}

variable "additional_managed_policy_arns" {
  description = "Additional managed policy ARNs to attach to the role."
  type        = list(string)
  default     = []
}

variable "custom_policy_json" {
  description = "JSON string for an optional custom inline policy."
  type        = string
  default     = ""
}

variable "additional_actions" {
  description = "Extra IAM actions to add to the default policy."
  type        = list(string)
  default     = []
}

variable "max_session_duration" {
  description = "Maximum session duration (in seconds) that can be requested when assuming the role."
  type        = number
  default     = 43200
}

# outputs.tf
output "role_name" {
  description = "Name of the created IAM role."
  value       = aws_iam_role.this.name
}

output "role_arn" {
  description = "ARN of the created IAM role."
  value       = aws_iam_role.this.arn
}

# example/usage.tf
module "cicd_role" {
  source = "../"

  role_name          = "cicd-deploy-role"
  trusted_principals = [
    "arn:aws:iam::123456789012:role/GitHubActionsOIDC",
    "arn:aws:iam::123456789012:user/ci-bot"
  ]

  additional_managed_policy_arns = [
    "arn:aws:iam::aws:policy/AdministratorAccess"
  ]

  additional_actions = [
    "dynamodb:*",
    "cloudwatch:*"
  ]
}