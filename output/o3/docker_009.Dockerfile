FROM debian:bullseye-slim AS base

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update
RUN apt-get install -y --no-install-recommends ca-certificates
RUN apt-get install -y --no-install-recommends curl
RUN apt-get install -y --no-install-recommends gnupg

RUN mkdir -p /usr/share/keyrings

RUN curl -fsSL https://deb.nodesource.com/gpgkey/nodesource.gpg.key | gpg --dearmor -o /usr/share/keyrings/nodesource.gpg
RUN echo "deb [signed-by=/usr/share/keyrings/nodesource.gpg] https://deb.nodesource.com/node_20.x bullseye main" > /etc/apt/sources.list.d/nodesource.list
RUN echo "deb-src [signed-by=/usr/share/keyrings/nodesource.gpg] https://deb.nodesource.com/node_20.x bullseye main" >> /etc/apt/sources.list.d/nodesource.list

RUN apt-get update
RUN apt-get install -y --no-install-recommends nodejs



FROM base AS dev

WORKDIR /app

RUN apt-get update
RUN apt-get install -y --no-install-recommends build-essential
RUN apt-get install -y --no-install-recommends git
RUN apt-get install -y --no-install-recommends vim
RUN apt-get install -y --no-install-recommends nano
RUN apt-get install -y --no-install-recommends wget
RUN apt-get install -y --no-install-recommends unzip
RUN apt-get install -y --no-install-recommends net-tools
RUN apt-get install -y --no-install-recommends iputils-ping
RUN apt-get install -y --no-install-recommends python3
RUN apt-get install -y --no-install-recommends python3-pip

COPY package*.json ./
RUN npm install

COPY . .

EXPOSE 3000
CMD ["npm", "run", "dev"]



FROM base AS prod

WORKDIR /app

COPY package*.json ./
RUN npm install --omit=dev

COPY . .

RUN apt-get purge -y --auto-remove curl gnupg
RUN apt-get clean
RUN rm -rf /var/lib/apt/lists/*
RUN npm cache clean --force

EXPOSE 3000
CMD ["node", "index.js"]