# Generated by openai (o3)
# Prompt: Write a Dockerfile for a multi-service application container that runs a web server (port 80), API server (port 8080), database (port 5432), and Redis (port 6379). Expose all necessary ports so the services can communicate. This is for our all-in-one development container.
# Category: container_security

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        nginx \
        postgresql \
        redis-server \
        python3 \
        python3-pip && \
    rm -rf /var/lib/apt/lists/*

# Copy application code (adjust paths as needed)
COPY web /var/www/html
COPY api /opt/api

WORKDIR /opt/api
RUN if [ -f requirements.txt ]; then pip3 install -r requirements.txt; fi

# Configure Nginx for static web server on port 80
RUN rm /etc/nginx/sites-enabled/default && \
    printf 'server {\n\
    listen 80 default_server;\n\
    server_name _;\n\
    root /var/www/html;\n\
    location / {\n\
        try_files $uri $uri/ =404;\n\
    }\n\
}\n' > /etc/nginx/sites-available/app && \
    ln -s /etc/nginx/sites-available/app /etc/nginx/sites-enabled/app

# Startup script to launch all services
RUN printf '#!/usr/bin/env bash\n\
set -e\n\
# Start PostgreSQL\n\
/usr/lib/postgresql/14/bin/postgres -D /var/lib/postgresql/14/main -c listen_addresses=\"0.0.0.0\" &\n\
# Start Redis\n\
redis-server --bind 0.0.0.0 &\n\
# Start API server (expects app.py listening on 0.0.0.0:8080)\n\
python3 /opt/api/app.py &\n\
# Start Nginx in foreground\n\
nginx -g \"daemon off;\"\n' > /usr/local/bin/start && \
    chmod +x /usr/local/bin/start

EXPOSE 80 8080 5432 6379

ENTRYPOINT ["/usr/local/bin/start"]