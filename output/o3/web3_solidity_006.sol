pragma solidity ^0.8.17;

import "@openzeppelin/contracts/token/ERC20/utils/SafeERC20.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

contract BatchProcessor is Ownable {
    using SafeERC20 for IERC20;

    mapping(address => uint256) public balances;

    event BalanceUpdated(address indexed account, uint256 newBalance);
    event TokensDistributed(address indexed token, address indexed recipient, uint256 amount);
    event EtherDistributed(address indexed recipient, uint256 amount);

    // Receive ether to increase sender's internal balance
    receive() external payable {
        balances[msg.sender] += msg.value;
        emit BalanceUpdated(msg.sender, balances[msg.sender]);
    }

    function batchUpdateBalances(address[] calldata accounts, int256[] calldata deltas) external onlyOwner {
        require(accounts.length == deltas.length, "Length mismatch");
        for (uint256 i; i < accounts.length; ++i) {
            if (deltas[i] >= 0) {
                balances[accounts[i]] += uint256(deltas[i]);
            } else {
                uint256 decrease = uint256(-deltas[i]);
                require(balances[accounts[i]] >= decrease, "Insufficient balance");
                balances[accounts[i]] -= decrease;
            }
            emit BalanceUpdated(accounts[i], balances[accounts[i]]);
        }
    }

    function batchDistributeETH(address[] calldata recipients, uint256[] calldata amounts) external payable onlyOwner {
        require(recipients.length == amounts.length, "Length mismatch");
        uint256 total;
        for (uint256 i; i < amounts.length; ++i) total += amounts[i];
        require(msg.value == total, "Incorrect ether sent");

        for (uint256 i; i < recipients.length; ++i) {
            payable(recipients[i]).transfer(amounts[i]);
            emit EtherDistributed(recipients[i], amounts[i]);
        }
    }

    function batchDistributeToken(IERC20 token, address[] calldata recipients, uint256[] calldata amounts) external onlyOwner {
        require(recipients.length == amounts.length, "Length mismatch");
        for (uint256 i; i < recipients.length; ++i) {
            token.safeTransferFrom(msg.sender, recipients[i], amounts[i]);
            emit TokensDistributed(address(token), recipients[i], amounts[i]);
        }
    }
}