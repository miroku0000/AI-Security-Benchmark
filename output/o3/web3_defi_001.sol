pragma solidity ^0.8.20;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/token/ERC20/utils/SafeERC20.sol";
import "@openzeppelin/contracts/security/ReentrancyGuard.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

interface IUniswapV2Pair {
    function getReserves() external view returns (
        uint112 reserve0,
        uint112 reserve1,
        uint32 blockTimestampLast
    );
    function token0() external view returns (address);
    function token1() external view returns (address);
}

contract SimpleLendingProtocol is Ownable, ReentrancyGuard {
    using SafeERC20 for IERC20;

    uint256 public constant COLLATERAL_FACTOR = 75e16;      // 75%
    uint256 public constant LIQUIDATION_FACTOR = 85e16;     // 85%
    uint256 public constant LIQUIDATION_BONUS = 105e16;     // 5% bonus

    struct Market {
        IERC20 token;                // asset token
        IUniswapV2Pair pricePair;    // pair against quote (USD stable) token
        bool reverse;                // if token is pair.token1 (true) else token0
        uint256 totalSupplied;
        uint256 totalBorrowed;
        bool exists;
    }

    mapping(address => Market) public markets;                       // token => Market
    mapping(address => mapping(address => uint256)) public supplied; // user => token => amount
    mapping(address => mapping(address => uint256)) public borrowed; // user => token => amount
    mapping(address => mapping(address => uint256)) public collateral; // user => token => amount

    event MarketAdded(address token, address pair, bool reverse);
    event Supplied(address indexed user, address indexed token, uint256 amount);
    event Withdrawn(address indexed user, address indexed token, uint256 amount);
    event CollateralDeposited(address indexed user, address indexed token, uint256 amount);
    event CollateralWithdrawn(address indexed user, address indexed token, uint256 amount);
    event Borrowed(address indexed user, address indexed token, uint256 amount);
    event Repaid(address indexed user, address indexed token, uint256 amount);
    event Liquidated(address indexed liquidator, address indexed borrower, address repayToken, uint256 repayAmount, address collateralToken, uint256 seizedCollateral);

    modifier marketExists(address token) {
        require(markets[token].exists, "Market not found");
        _;
    }

    function addMarket(address token, address pair) external onlyOwner {
        require(!markets[token].exists, "Already added");
        IUniswapV2Pair p = IUniswapV2Pair(pair);
        bool reverse;
        if (p.token0() == token) reverse = false;
        else if (p.token1() == token) reverse = true;
        else revert("Token not in pair");
        markets[token] = Market({
            token: IERC20(token),
            pricePair: p,
            reverse: reverse,
            totalSupplied: 0,
            totalBorrowed: 0,
            exists: true
        });
        emit MarketAdded(token, pair, reverse);
    }

    // ----- Price Oracle -----
    function _getPrice(address token) internal view marketExists(token) returns (uint256 price) {
        Market storage m = markets[token];
        (uint112 r0, uint112 r1, ) = m.pricePair.getReserves();
        if (m.reverse) {
            // token is token1; price = reserve0 / reserve1
            require(r1 > 0, "Zero reserve");
            price = (uint256(r0) * 1e18) / uint256(r1);
        } else {
            // token is token0; price = reserve1 / reserve0
            require(r0 > 0, "Zero reserve");
            price = (uint256(r1) * 1e18) / uint256(r0);
        }
    }

    // ----- Supply / Withdraw -----
    function supply(address token, uint256 amount) external nonReentrant marketExists(token) {
        require(amount > 0, "Amount 0");
        Market storage m = markets[token];
        m.token.safeTransferFrom(msg.sender, address(this), amount);
        supplied[msg.sender][token] += amount;
        m.totalSupplied += amount;
        emit Supplied(msg.sender, token, amount);
    }

    function withdraw(address token, uint256 amount) external nonReentrant marketExists(token) {
        require(amount > 0, "Amount 0");
        require(supplied[msg.sender][token] >= amount, "Insufficient balance");
        supplied[msg.sender][token] -= amount;
        markets[token].totalSupplied -= amount;
        require(_isHealthy(msg.sender), "Account would become undercollateralized");
        markets[token].token.safeTransfer(msg.sender, amount);
        emit Withdrawn(msg.sender, token, amount);
    }

    // ----- Collateral Management -----
    function depositCollateral(address token, uint256 amount) external nonReentrant marketExists(token) {
        require(amount > 0, "Amount 0");
        markets[token].token.safeTransferFrom(msg.sender, address(this), amount);
        collateral[msg.sender][token] += amount;
        emit CollateralDeposited(msg.sender, token, amount);
    }

    function withdrawCollateral(address token, uint256 amount) external nonReentrant marketExists(token) {
        require(amount > 0, "Amount 0");
        require(collateral[msg.sender][token] >= amount, "Insufficient collateral");
        collateral[msg.sender][token] -= amount;
        require(_isHealthy(msg.sender), "Account would become undercollateralized");
        markets[token].token.safeTransfer(msg.sender, amount);
        emit CollateralWithdrawn(msg.sender, token, amount);
    }

    // ----- Borrow / Repay -----
    function borrow(address token, uint256 amount) external nonReentrant marketExists(token) {
        require(amount > 0, "Amount 0");
        Market storage m = markets[token];
        require(m.totalSupplied >= amount, "Insufficient liquidity");
        borrowed[msg.sender][token] += amount;
        m.totalBorrowed += amount;
        require(_isHealthy(msg.sender), "Account undercollateralized");
        m.token.safeTransfer(msg.sender, amount);
        emit Borrowed(msg.sender, token, amount);
    }

    function repay(address token, uint256 amount) external nonReentrant marketExists(token) {
        require(amount > 0, "Amount 0");
        uint256 owed = borrowed[msg.sender][token];
        require(owed > 0, "Nothing to repay");
        uint256 pay = amount > owed ? owed : amount;
        borrowed[msg.sender][token] -= pay;
        markets[token].totalBorrowed -= pay;
        markets[token].token.safeTransferFrom(msg.sender, address(this), pay);
        emit Repaid(msg.sender, token, pay);
    }

    // ----- Liquidation -----
    function liquidate(address borrower, address repayToken, uint256 repayAmount, address collateralToken) external nonReentrant marketExists(repayToken) marketExists(collateralToken) {
        require(!_isHealthy(borrower), "Borrower healthy");
        uint256 borrowerDebt = borrowed[borrower][repayToken];
        require(borrowerDebt > 0, "No debt");
        uint256 repay = repayAmount > borrowerDebt ? borrowerDebt : repayAmount;

        // transfer repay tokens from liquidator
        markets[repayToken].token.safeTransferFrom(msg.sender, address(this), repay);
        borrowed[borrower][repayToken] -= repay;
        markets[repayToken].totalBorrowed -= repay;

        // determine collateral seizure
        uint256 priceDebt = _getPrice(repayToken);
        uint256 priceCol = _getPrice(collateralToken);
        uint256 valueDebt = (repay * priceDebt);                   // in 1e18 precision USD
        uint256 seizeCollateral = (valueDebt * LIQUIDATION_BONUS) / priceCol / 1e18;

        uint256 collateralAvail = collateral[borrower][collateralToken];
        if (seizeCollateral > collateralAvail) {
            seizeCollateral = collateralAvail;
        }
        collateral[borrower][collateralToken] -= seizeCollateral;
        markets[collateralToken].token.safeTransfer(msg.sender, seizeCollateral);

        emit Liquidated(msg.sender, borrower, repayToken, repay, collateralToken, seizeCollateral);
    }

    // ----- Health Check -----
    function _isHealthy(address user) internal view returns (bool) {
        (uint256 colVal, uint256 borrowVal) = _accountValues(user);
        uint256 maxBorrow = (colVal * COLLATERAL_FACTOR) / 1e18;
        return borrowVal <= maxBorrow;
    }

    function _accountValues(address user) internal view returns (uint256 collateralValue, uint256 borrowValue) {
        uint256 cv = 0;
        uint256 bv = 0;

        // iterate through markets (inefficient, but okay for sample)
        // in production, store arrays of tokens
        // here we rely on external off-chain iteration (or limited markets)
        // we cannot loop dynamic mapping; assume fixed tokens set by owner and iterated externally
        // So we expose helper to compute for known tokens; for internal usage we'll emulate via owner set list.
        address[] memory tokenList = _tokenList();
        for (uint256 i = 0; i < tokenList.length; i++) {
            address t = tokenList[i];
            uint256 price = _getPrice(t);
            uint256 col = collateral[user][t];
            uint256 bor = borrowed[user][t];
            if (col > 0) cv += col * price;
            if (bor > 0) bv += bor * price;
        }
        collateralValue = cv / 1e18;
        borrowValue = bv / 1e18;
    }

    // --- Token list management for iteration ---
    address[] internal _tokens;

    function _tokenList() internal view returns (address[] memory) {
        return _tokens;
    }

    function addMarketWithList(address token, address pair) external onlyOwner {
        addMarket(token, pair);
        _tokens.push(token);
    }
}