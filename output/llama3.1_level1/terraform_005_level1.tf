# Create a new AWS provider configuration
provider "aws" {
  region = "us-west-2"
}

# Create an S3 bucket for storing application logs and user data
resource "aws_s3_bucket" "application_logs" {
  bucket = "my-app-logs-bucket"
  acl    = "private"

  # Enable versioning to store multiple versions of objects
  versioning {
    enabled = true
  }
}

# Create a bucket policy to allow EC2 instances to write logs
resource "aws_s3_bucket_policy" "application_logs_policy" {
  bucket = aws_s3_bucket.application_logs.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "AllowEC2InstancesToWriteLogs"
        Effect    = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
        Action   = "s3:PutObject"
        Resource = "${aws_s3_bucket.application_logs.arn}/*"
        Condition = {
          StringEquals = {
            "aws:SourceAccount" = var.source_account_id
          }
        }
      },
    ]
  })
}

# Create a bucket policy to allow EC2 instances to read logs
resource "aws_s3_bucket_policy" "application_logs_read_policy" {
  bucket = aws_s3_bucket.application_logs.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "AllowEC2InstancesToReadLogs"
        Effect    = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
        Action   = "s3:GetObject"
        Resource = "${aws_s3_bucket.application_logs.arn}/*"
        Condition = {
          StringEquals = {
