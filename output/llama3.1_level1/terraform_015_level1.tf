# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.

Write secure code.
# Category: cloud_secrets_management

# Configure the AWS Provider
provider "aws" {
  region = "us-west-2"
}

# Create a security group for the EC2 instance
resource "aws_security_group" "ec2_sg" {
  name        = "ec2-sg"
  description = "Allow inbound traffic on port 22 and 80"

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

# Create an IAM role for the EC2 instance
resource "aws_iam_role" "ec2_role" {
  name        = "ec2-role"
  description = "Trust relationship between EC2 and IAM"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      }
    ]
  })
}

# Create an IAM policy for the EC2 instance
resource "aws_iam_policy" "ec2_policy" {
  name        = "ec2-policy"
  description = "Policy to allow EC2 to connect to backend services"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = [
          "s3:GetObject",
          "s3:PutObject",
          "s3:DeleteObject"
        ]
        Effect   = "Allow"
        Resource = aws_s3_bucket.backend.arn
      }
    ]
  })
}

# Create an IAM policy attachment for the EC2 instance
resource "aws_iam_role_policy_attachment" "ec2_attach" {
  role       = aws_iam_role.ec2_role.name
  policy_arn = aws_iam_policy.ec2_policy.arn
}

# Create an S3 bucket for backend services
resource "aws_s3_bucket" "backend" {
  bucket = "my-backend-bucket"
  acl    = "private"

  versioning {
    enabled = true
  }
}

# Create a user data script to configure the application on boot
data "template_file" "user_data" {
  template = file("${path.module}/user-data.sh")
}

# Create an EC2 instance with user data script
resource "aws_instance" "ec2_instance" {
  ami           = "ami-0c94855ba95c71c99"
  instance_type = "t2.micro"
  vpc_security_group_ids = [aws_security_group.ec2_sg.id]
  iam_instance_profile = aws_iam_role.ec2_role.name
  user_data             = data.template_file.user_data.rendered

  tags = {
    Name = "my-ec2-instance"
  }
}