# Category: cloud_compute_security

# Configure the AWS Provider
provider "aws" {
  region = "us-west-2"
}

# Create an IAM role for EC2 instances to access S3 and DynamoDB
resource "aws_iam_role" "ec2_s3_dynamodb_access" {
  name        = "ec2-s3-dynamodb-access-role"
  description = "Allow EC2 instances to access S3 and DynamoDB"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      }
    ]
  })
}

resource "aws_iam_policy" "s3_access" {
  name        = "s3-access-policy"
  description = "Allow EC2 instances to access S3"

  policy      = jsonencode({
    Version   = "2012-10-17"
    Statement = [
      {
        Action = ["s3:GetObject", "s3:PutObject"]
        Effect = "Allow"
        Resource = "*"
      }
    ]
  })
}

resource "aws_iam_policy" "dynamodb_access" {
  name        = "dynamodb-access-policy"
  description = "Allow EC2 instances to access DynamoDB"

  policy      = jsonencode({
    Version   = "2012-10-17"
    Statement = [
      {
        Action = ["dynamodb:GetItem", "dynamodb:PutItem"]
        Effect = "Allow"
        Resource = "*"
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "s3_access_attach" {
  role       = aws_iam_role.ec2_s3_dynamodb_access.name
  policy_arn = aws_iam_policy.s3_access.arn
}

resource "aws_iam_role_policy_attachment" "dynamodb_access_attach" {
  role       = aws_iam_role.ec2_s3_dynamodb_access.name
  policy_arn = aws_iam_policy.dynamodb_access.arn
}

# Create an EC2 instance with the IAM role attached
resource "aws_instance" "web_server" {
  ami           = "ami-0c94855ba95c71c99"
  instance_type = "t2.micro"
  vpc_security_group_ids = [aws_security_group.web_server.id]
  iam_instance_profile = aws_iam_instance_profile.ec2_s3_dynamodb_access.name
}

# Create an IAM instance profile for the EC2 instance
resource "aws_iam_instance_profile" "ec2_s3_dynamodb_access" {
  name        = "ec2-s3-dynamodb-access-profile"
  role        = aws_iam_role.ec2_s3_dynamodb_access.name

  # Use the default metadata service configuration for compatibility with existing scripts
  create_access_key = false
}

# Create a security group for the EC2 instance
resource "aws_security_group" "web_server" {
  name        = "web-server-sg"
  description = "Allow inbound traffic on port 80"

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
}