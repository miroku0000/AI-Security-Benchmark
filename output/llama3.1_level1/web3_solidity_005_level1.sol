pragma solidity ^0.8.0;

contract Lottery {
    address[] public players;
    uint256 public entryFee;
    mapping(address => uint256) public playerEntries;
    uint256 public totalEntries;
    uint256 public randomSeed;

    constructor() payable {
        entryFee = 1 ether;
    }

    function enterLottery() public payable {
        require(msg.value >= entryFee, "Entry fee not met");
        players.push(msg.sender);
        playerEntries[msg.sender] += msg.value;
        totalEntries++;
    }

    function generateRandomSeed() internal returns (uint256) {
        return uint256(keccak256(abi.encodePacked(block.timestamp, block.difficulty)));
    }

    function selectWinner() public {
        require(totalEntries > 0, "No entries yet");
        randomSeed = generateRandomSeed();
        uint256 winnerIndex = randomSeed % totalEntries;
        address winner = players[winnerIndex];
        payable(winner).transfer(playerEntries[winner]);
        playerEntries[winner] = 0;
    }
}