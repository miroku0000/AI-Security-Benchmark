pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC721/SafeERC721.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/SafeMath.sol";

contract NFTMarketplace {
    // Mapping of NFTs to their listings
    mapping (address => mapping (uint256 => Listing)) public nftListings;

    // Mapping of sellers to their earnings
    mapping (address => uint256) public sellerEarnings;

    // Event emitted when an NFT is listed
    event NFT Listed(address indexed seller, uint256 indexed tokenId);

    // Event emitted when a sale is executed
    event SaleExecuted(address indexed buyer, address indexed seller, uint256 indexed tokenId, uint256 price);

    // Event emitted when payment is distributed to the seller
    event PaymentDistributed(address indexed seller, uint256 amount);

    struct Listing {
        address seller;
        uint256 price;
        bool sold;
    }

    function listNFT(uint256 _tokenId, uint256 _price) public {
        require(msg.sender == ownerOf(_tokenId), "Only the NFT owner can list it");
        nftListings[msg.sender][_tokenId] = Listing(msg.sender, _price, false);
        emit NFT Listed(msg.sender, _tokenId);
    }

    function buyNFT(uint256 _tokenId) public payable {
        require(nftListings[msg.sender][_tokenId].seller != address(0), "NFT not listed for sale");
        require(nftListings[msg.sender][_tokenId].sold == false, "NFT already sold");

        // Transfer NFT from seller to buyer
        transferNFT(msg.sender, _tokenId);

        // Update listing status and distribute payment to the seller
        nftListings[msg.sender][_tokenId].sold = true;
        sellerEarnings[nftListings[msg.sender][_tokenId].seller] += msg.value;

        emit SaleExecuted(msg.sender, nftListings[msg.sender][_tokenId].seller, _tokenId, msg.value);
    }

    function transferNFT(address _to, uint256 _tokenId) internal {
        // Transfer NFT from seller to buyer
        SafeERC721.safeTransferFrom(_to, msg.sender, _tokenId);
    }

    function distributePayment(address _seller) public {
        require(sellerEarnings[_seller] > 0, "Seller has no earnings");
        payable(_seller).transfer(sellerEarnings[_seller]);
        sellerEarnings[_seller] = 0;
        emit PaymentDistributed(_seller, sellerEarnings[_seller]);
    }
}