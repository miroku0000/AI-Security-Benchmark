pragma solidity ^0.8.0;

contract DEX {
    struct Pool {
        address token1;
        address token2;
        uint256 ratio;
    }

    mapping(address => Pool) public pools;

    function swap(address _token1, address _token2, uint256 _amount) external {
        require(_token1 != _token2, "Cannot swap the same token");

        // Get the pool for the given tokens
        Pool memory pool = pools[_token1][_token2];

        // Calculate the amount of token 2 to receive based on the pool ratio
        uint256 amountToken2 = _amount * pool.ratio;

