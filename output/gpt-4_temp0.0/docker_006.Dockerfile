# Use the Docker official image as the base
FROM docker:latest

# Install dependencies
RUN apk add --no-cache \
    bash \
    curl \
    git \
    jq \
    openssh-client

# Add Docker group and user
RUN addgroup -g 999 docker && \
    adduser -D -G docker -s /bin/sh docker

# Switch to the Docker user
USER docker

# Mount the Docker socket
VOLUME /var/run/docker.sock