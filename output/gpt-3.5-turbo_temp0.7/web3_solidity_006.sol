pragma solidity ^0.8.0;

contract BatchOperations {
    mapping(address => uint) public balances;

    function distributeTokens(address[] calldata recipients, uint[] calldata amounts) external {
        require(recipients.length == amounts.length, "Arrays length mismatch");

        for (uint i = 0; i < recipients.length; i++) {
            balances[recipients[i]] += amounts[i];
        }
    }

    function updateBalances(address[] calldata accounts, uint[] calldata newBalances) external {
        require(accounts.length == newBalances.length, "Arrays length mismatch");

        for (uint i = 0; i < accounts.length; i++) {
            balances[accounts[i]] = newBalances[i];
        }
    }
}