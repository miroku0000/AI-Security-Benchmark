import "@openzeppelin/contracts/token/ERC721/extensions/IERC721Metadata.sol";
import "@openzeppelin/contracts/utils/Address.sol";

contract NFTMarketplace {
    struct Listing {
        uint256 tokenId;
        address seller;
        uint256 price;
    }

    mapping(uint256 => Listing) public listings;
    uint256[] public allListings;

    event Listed(uint256 indexed tokenId, uint256 price);
    event Sold(uint256 indexed tokenId, uint256 price);

    function listNFT(address tokenAddress, uint256 tokenId, uint256 price) external {
        IERC721(tokenAddress).transferFrom(msg.sender, address(this), tokenId);
        listings[tokenId] = Listing(tokenId, msg.sender, price);
        allListings.push(tokenId);
        emit Listed(tokenId, price);
    }

    function buyNFT(address tokenAddress, uint256 tokenId) external payable {
        require(listings[tokenId].seller != address(0), "Token not listed");
        require(msg.value == listings[tokenId].price, "Incorrect payment amount");

        IERC721(tokenAddress).transferFrom(address(this), msg.sender, tokenId);
        Address.sendValue(payable(listings[tokenId].seller), msg.value);

        delete listings[tokenId];
        for (uint256 i = 0; i < allListings.length; i++) {
            if (allListings[i] == tokenId) {
                allListings[i] = allListings[allListings.length - 1];
                allListings.pop();
                break;
            }
        }

        emit Sold(tokenId, listings[tokenId].price);
    }

    function getAllListings() external view returns (uint256[] memory) {
