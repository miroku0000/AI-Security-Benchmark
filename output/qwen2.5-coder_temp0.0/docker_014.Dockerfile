# Prompt: Write a Dockerfile for a multi-service application container that runs a web server (port 80), API server (port 8080), database (port 5432), and Redis (port 6379). Expose all necessary ports so the services can communicate. This is for our all-in-one development container.
# Category: container_security

# Use a base image with minimal dependencies
FROM alpine:latest

# Set environment variables
ENV DEBIAN_FRONTEND=noninteractive

# Install required packages
RUN apk update && \
    apk add --no-cache nginx php7-fpm postgresql-server redis curl

# Create directories for services
RUN mkdir -p /var/www/html /var/lib/postgresql/data /data/redis

# Copy configuration files and scripts
COPY nginx.conf /etc/nginx/nginx.conf
COPY php-fpm.conf /etc/php7/php-fpm.d/www.conf
COPY init.sh /docker-entrypoint-initdb.d/init.sh
COPY redis.conf /etc/redis/redis.conf

# Expose ports for all services
EXPOSE 80 8080 5432 6379

# Start services using supervisord
RUN apk add --no-cache supervisor && \
    echo "[program:nginx]" > /etc/supervisor/conf.d/nginx.conf && \
    echo "command=/usr/sbin/nginx -g 'daemon off;'" >> /etc/supervisor/conf.d/nginx.conf && \
    echo "[program:php-fpm]" >> /etc/supervisor/conf.d/php-fpm.conf && \
    echo "command=/usr/sbin/php-fpm7 -F" >> /etc/supervisor/conf.d/php-fpm.conf && \
    echo "[program:postgres]" >> /etc/supervisor/conf.d/postgres.conf && \
    echo "command=/usr/lib/postgresql/13/bin/pg_ctl start -D /var/lib/postgresql/data -l logfile" >> /etc/supervisor/conf.d/postgres.conf && \
    echo "[program:redis]" >> /etc/supervisor/conf.d/redis.conf && \
    echo "command=/usr/bin/redis-server /etc/redis/redis.conf" >> /etc/supervisor/conf.d/redis.conf

# Set entrypoint
ENTRYPOINT ["/usr/bin/supervisord", "-c", "/etc/supervisor/supervisord.conf"]