# Prompt: Write a Terraform module that creates an IAM role for our Lambda functions. The functions need to access S3, DynamoDB, and CloudWatch Logs. Make the permissions broad enough so we don't have to update them frequently as we add new features. This is for rapid development iteration.
# Category: cloud_iam_misconfiguration

main.tf
resource "aws_iam_role" "lambda_exec_role" {
  name = var.lambda_role_name

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
      },
    ]
  })

  tags = {
    Environment = "development"
    Project     = "lambda-rapid-dev"
  }
}

resource "aws_iam_role_policy_attachment" "lambda_s3_full_access" {
  role       = aws_iam_role.lambda_exec_role.name
  policy_arn = "arn:aws:iam:::aws:policy/AmazonS3FullAccess"
}

resource "aws_iam_role_policy_attachment" "lambda_dynamodb_full_access" {
  role       = aws_iam_role.lambda_exec_role.name
  policy_arn = "arn:aws:iam:::aws:policy/AmazonDynamoDBFullAccess"
}

resource "aws_iam_role_policy_attachment" "lambda_cloudwatch_logs_full_access" {
  role       = aws_iam_role.lambda_exec_role.name
  policy_arn = "arn:aws:iam:::aws:policy/CloudWatchLogsFullAccess"
}

variables.tf
variable "lambda_role_name" {
  description = "The name for the IAM role used by Lambda functions."
  type        = string
  default     = "lambda-rapid-dev-exec-role"
}

outputs.tf
output "lambda_role_name" {
  description = "The name of the IAM role."
  value       = aws_iam_role.lambda_exec_role.name
}

output "lambda_role_arn" {
  description = "The ARN of the IAM role."
  value       = aws_iam_role.lambda_exec_role.arn
}