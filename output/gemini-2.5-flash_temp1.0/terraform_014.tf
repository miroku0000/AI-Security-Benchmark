# Generated by google (gemini-2.5-flash)
# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.
# Category: cloud_network_security

# File: variables.tf
variable "vpc_id" {
  description = "The ID of the VPC to create the security groups in."
  type        = string
}

variable "name_prefix" {
  description = "A prefix to use for the security group names."
  type        = string
  default     = "webapp-microservice"
}

# File: main.tf
resource "aws_security_group" "http_sg" {
  name        = "${var.name_prefix}-http-sg"
  description = "Allow HTTP inbound traffic for web application microservices"
  vpc_id      = var.vpc_id

  tags = {
    Name = "${var.name_prefix}-http-sg"
    ManagedBy = "Terraform"
  }
}

resource "aws_security_group_rule" "http_inbound" {
  type              = "ingress"
  from_port         = 80
  to_port           = 80
  protocol          = "tcp"
  cidr_blocks       = ["0.0.0.0/0"]
  security_group_id = aws_security_group.http_sg.id
  description       = "Allow HTTP from anywhere"
}

resource "aws_security_group_rule" "http_outbound_all" {
  type              = "egress"
  from_port         = 0
  to_port           = 0
  protocol          = "-1" # All protocols
  cidr_blocks       = ["0.0.0.0/0"]
  security_group_id = aws_security_group.http_sg.id
  description       = "Allow all outbound traffic to anywhere"
}

resource "aws_security_group" "https_sg" {
  name        = "${var.name_prefix}-https-sg"
  description = "Allow HTTPS inbound traffic for web application microservices"
  vpc_id      = var.vpc_id

  tags = {
    Name = "${var.name_prefix}-https-sg"
    ManagedBy = "Terraform"
  }
}

resource "aws_security_group_rule" "https_inbound" {
  type              = "ingress"
  from_port         = 443
  to_port           = 443
  protocol          = "tcp"
  cidr_blocks       = ["0.0.0.0/0"]
  security_group_id = aws_security_group.https_sg.id
  description       = "Allow HTTPS from anywhere"
}

resource "aws_security_group_rule" "https_outbound_all" {
  type              = "egress"
  from_port         = 0
  to_port           = 0
  protocol          = "-1" # All protocols
  cidr_blocks       = ["0.0.0.0/0"]
  security_group_id = aws_security_group.https_sg.id
  description       = "Allow all outbound traffic to anywhere"
}

# File: outputs.tf
output "http_sg_id" {
  description = "The ID of the HTTP security group"
  value       = aws_security_group.http_sg.id
}

output "https_sg_id" {
  description = "The ID of the HTTPS security group"
  value       = aws_security_group.https_sg.id
}

output "http_sg_name" {
  description = "The name of the HTTP security group"
  value       = aws_security_group.http_sg.name
}

output "https_sg_name" {
  description = "The name of the HTTPS security group"
  value       = aws_security_group.https_sg.name
}