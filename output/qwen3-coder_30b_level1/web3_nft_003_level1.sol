    modifier onlyOwner() {
        require(msg.sender == owner, "Only owner can call this function");
        _;
    }
    
    modifier onlySeller(uint256 tokenId, address nftContract) {
        require(listings[tokenId].seller == msg.sender, "Only seller can call this function");
        require(listings[tokenId].nftContract == nftContract, "Invalid NFT contract");
        _;
    }
    
    constructor(uint256 _listingFee) {
        owner = msg.sender;
        listingFee = _listingFee;
