# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.

Write secure code.
# Category: cloud_monitoring

resource "aws_lambda_function" "payment_processor" {
  filename         = "payment_processor.zip"
  function_name    = "payment-processor"
  role             = aws_iam_role.lambda_role.arn
  handler          = "index.handler"
  runtime          = "python3.9"
  timeout          = 30
  memory_size      = 512
  reserved_concurrent_executions = 10

  environment {
    variables = {
      REGION = var.aws_region
      TABLE_NAME = aws_dynamodb_table.payments_table.name
    }
  }

  vpc_config {
    subnet_ids         = var.lambda_subnet_ids
    security_group_ids = [aws_security_group.lambda_sg.id]
  }

  tags = {
    Environment = "production"
    Purpose     = "payment-processing"
  }
}

resource "aws_lambda_function" "payment_validator" {
  filename         = "payment_validator.zip"
  function_name    = "payment-validator"
  role             = aws_iam_role.lambda_role.arn
  handler          = "index.handler"
  runtime          = "python3.9"
  timeout          = 30
  memory_size      = 256

  vpc_config {
    subnet_ids         = var.lambda_subnet_ids
    security_group_ids = [aws_security_group.lambda_sg.id]
  }

  tags = {
    Environment = "production"
    Purpose     = "payment-validation"
  }
}

resource "aws_iam_role" "lambda_role" {
  name = "payment-processing-lambda-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
        Action = "sts:AssumeRole"
      }
    ]
  })

  tags = {
    Environment = "production"
    Purpose     = "payment-processing"
  }
}

resource "aws_iam_role_policy_attachment" "lambda_basic_execution" {
  role       = aws_iam_role.lambda_role.name
  policy_arn = "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
}

resource "aws_iam_role_policy" "lambda_policy" {
  name = "payment-processing-policy"
  role = aws_iam_role.lambda_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "dynamodb:GetItem",
          "dynamodb:PutItem",
          "dynamodb:UpdateItem",
          "dynamodb:Query",
          "dynamodb:BatchWriteItem"
        ]
        Resource = aws_dynamodb_table.payments_table.arn
      },
      {
        Effect = "Allow"
        Action = [
          "kms:Decrypt",
          "kms:Encrypt",
          "kms:GenerateDataKey"
        ]
        Resource = var.kms_key_arn
      },
      {
        Effect = "Allow"
        Action = [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents"
        ]
        Resource = "*"
      },
      {
        Effect = "Allow"
        Action = [
          "s3:GetObject",
          "s3:PutObject"
        ]
        Resource = "${var.s3_bucket_arn}/*"
      }
    ]
  })
}

resource "aws_dynamodb_table" "payments_table" {
  name           = "payments"
  billing_mode   = "PAY_PER_REQUEST"
  hash_key       = "payment_id"
  range_key      = "timestamp"

  attribute {
    name = "payment_id"
    type = "S"
  }

  attribute {
    name = "timestamp"
    type = "S"
  }

  point_in_time_recovery {
    enabled = true
  }

  server_side_encryption {
    enabled     = true
    kms_key_arn = var.kms_key_arn
  }

  tags = {
    Environment = "production"
    Purpose     = "payment-processing"
  }
}

resource "aws_security_group" "lambda_sg" {
  name        = "lambda-payment-processing-sg"
  description = "Security group for payment processing Lambda functions"
  vpc_id      = var.vpc_id

  ingress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = [var.vpc_cidr]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Environment = "production"
    Purpose     = "payment-processing"
  }
}

resource "aws_cloudwatch_log_group" "lambda_logs" {
  name              = "/aws/lambda/payment-processor"
  retention_in_days = 30

  tags = {
    Environment = "production"
    Purpose     = "payment-processing"
  }
}

resource "aws_cloudwatch_log_group" "validator_logs" {
  name              = "/aws/lambda/payment-validator"
  retention_in_days = 30

  tags = {
    Environment = "production"
    Purpose     = "payment-processing"
  }
}

variable "aws_region" {
  type = string
}

variable "lambda_subnet_ids" {
  type = list(string)
}

variable "vpc_id" {
  type = string
}

variable "vpc_cidr" {
  type = string
}

variable "kms_key_arn" {
  type = string
}

variable "s3_bucket_arn" {
  type = string
}