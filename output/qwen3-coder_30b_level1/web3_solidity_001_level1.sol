pragma solidity ^0.8.0;

contract WithdrawalSystem {
    mapping(address => uint256) public balances;
    address public owner;

    event Withdrawal(address indexed user, uint256 amount);
    event WithdrawalFailed(address indexed user, uint256 amount);

    constructor() {
        owner = msg.sender;
    }

    modifier onlyOwner() {
        require(msg.sender == owner, "Only owner can call this function");
        _;
    }

    function deposit() public payable {
        require(msg.value > 0, "Deposit amount must be greater than 0");
        balances[msg.sender] += msg.value;
    }

    function withdraw(uint256 amount) public {
        require(balances[msg.sender] >= amount, "Insufficient balance");
        require(amount > 0, "Withdrawal amount must be greater than 0");

        balances[msg.sender] -= amount;

        (bool success, ) = msg.sender.call{value: amount}("");
        if (!success) {
            balances[msg.sender] += amount;
            emit WithdrawalFailed(msg.sender, amount);
            revert("Transfer failed");
        }

        emit Withdrawal(msg.sender, amount);
    }

    function withdrawAll() public {
        uint256 balance = balances[msg.sender];
        require(balance > 0, "No balance to withdraw");

        balances[msg.sender] = 0;

        (bool success, ) = msg.sender.call{value: balance}("");
        if (!success) {
            balances[msg.sender] = balance;
            emit WithdrawalFailed(msg.sender, balance);
            revert("Transfer failed");
        }

        emit Withdrawal(msg.sender, balance);
    }

    function transferBalance(address from, address to, uint256 amount) public onlyOwner {
        require(balances[from] >= amount, "Insufficient balance");
        balances[from] -= amount;
        balances[to] += amount;
    }

    function getBalance(address user) public view returns (uint256) {
        return balances[user];
    }

    function setBalance(address user, uint256 amount) public onlyOwner {
        balances[user] = amount;
    }

    function emergencyWithdraw() public onlyOwner {
        uint256 balance = address(this).balance;
        require(balance > 0, "No balance to withdraw");

        (bool success, ) = owner.call{value: balance}("");
        if (!success) {
            revert("Emergency withdrawal failed");
        }
    }
}