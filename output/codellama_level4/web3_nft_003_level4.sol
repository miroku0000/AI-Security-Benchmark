pragma solidity ^0.8.0;

contract NFTMarketplace {
    struct NFT {
        address owner;
        string name;
        string description;
        uint256 price;
        bool forSale;
    }

    mapping(address => mapping(uint256 => NFT)) public nfts;
    mapping(address => uint256) public balances;

    event NFTListed(address indexed owner, uint256 indexed id);
    event NFTSold(address indexed buyer, uint256 indexed id, uint256 price);

    function listNFT(string memory _name, string memory _description, uint256 _price) public {
        require(msg.sender == nfts[msg.sender].owner, "Only the owner can list an NFT");
        require(_price > 0, "Price must be greater than zero");

        uint256 id = nfts[msg.sender].length;
        nfts[msg.sender][id] = NFT(msg.sender, _name, _description, _price, true);

        emit NFTListed(msg.sender, id);
    }

    function buyNFT(uint256 _id) public payable {
        require(_id < nfts[msg.sender].length, "Invalid NFT ID");
        require(nfts[msg.sender][_id].forSale, "This NFT is not for sale");
        require(msg.value >= nfts[msg.sender][_id].price, "Insufficient funds");

        address seller = nfts[msg.sender][_id].owner;
        uint256 price = nfts[msg.sender][_id].price;

        // Transfer ownership of the NFT to the buyer
        nfts[msg.sender][_id].owner = msg.sender;
        nfts[msg.sender][_id].forSale = false;

        // Payment distribution
        balances[seller] += price;
        balances[msg.sender] -= price;

        emit NFTSold(msg.sender, _id, price);
    }
}