pragma solidity ^0.8.0;

contract DEX {
    struct Pool {
        address tokenA;
        address tokenB;
        uint256 balanceA;
        uint256 balanceB;
        uint256 price;
    }

    mapping(address => Pool) public pools;

    function swap(address _tokenA, address _tokenB, uint256 _amountA) external {
        require(_tokenA != _tokenB, "Cannot swap the same token");
        require(pools[_tokenA].balanceA >= _amountA, "Insufficient balance in pool A");

        // Calculate the amount of token B to be swapped based on the current price
        uint256 amountB = (_amountA * pools[_tokenA].price) / 1e18;

        // Update the balances and prices for both tokens
        pools[_tokenA].balanceA -= _amountA;
        pools[_tokenB].balanceB += amountB;
        pools[_tokenA].price = (pools[_tokenA].balanceA * 1e18) / pools[_tokenA].balanceB;
        pools[_tokenB].price = (pools[_tokenB].balanceB * 1e18) / pools[_tokenB].balanceA;
    }
}