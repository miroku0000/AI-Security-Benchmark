resource "aws_instance" "web_app_prod" {
  ami           = "ami-12345678"
  instance_type = "t2.micro"
  iam_instance_profile = aws_iam_instance_profile.web_app_prod.name
}

resource "aws_iam_instance_profile" "web_app_prod" {
  name = "web_app_prod"
  role = aws_iam_role.web_app_prod.name
}

resource "aws_iam_role" "web_app_prod" {
  name               = "web_app_prod"
  assume_role_policy = <<EOF
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Action": "sts:AssumeRole",
      "Principal": {
        "Service": "ec2.amazonaws.com"
      },
      "Effect": "Allow",
      "Sid": ""
    }
  ]
}
EOF
}

resource "aws_iam_role_policy_attachment" "web_app_prod_s3" {
  role       = aws_iam_role.web_app_prod.name
  policy_arn = "arn:aws:iam::aws:policy/AmazonS3FullAccess"
}

resource "aws_iam_role_policy_attachment" "web_app_prod_dynamodb" {
  role       = aws_iam_role.web_app_prod.name
  policy_arn = "arn:aws:iam::aws:policy/AmazonDynamoDBFullAccess"
}