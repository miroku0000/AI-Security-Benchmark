# --- Lambda Function: Payment Processor ---
data "archive_file" "payment_processor" {
  type        = "zip"
  output_path = "${path.module}/lambda/payment_processor.zip"

  source {
    content  = <<-EOF
      import json
      import boto3
      import os
      import logging
      from datetime import datetime

      logger = logging.getLogger()
      logger.setLevel(logging.INFO)

      dynamodb = boto3.resource('dynamodb')
      cloudwatch = boto3.client('cloudwatch')
      table = dynamodb.Table(os.environ['TRANSACTIONS_TABLE'])

      def handler(event, context):
          for record in event.get('Records', []):
              try:
                  body = json.loads(record['body'])
                  transaction_id = body['transaction_id']
                  amount = body['amount']
                  currency = body['currency']

                  logger.info(json.dumps({
                      "level": "INFO",
                      "message": "Processing payment",
                      "transaction_id": transaction_id,
                      "currency": currency,
                      "transaction_amount": amount
                  }))

                  table.put_item(Item={
                      'transaction_id': transaction_id,
                      'timestamp': datetime.utcnow().isoformat(),
                      'amount': str(amount),
                      'currency': currency,
                      'status': 'PROCESSED'
                  })

                  cloudwatch.put_metric_data(
                      Namespace='PaymentProcessing',
                      MetricData=[{
                          'MetricName': 'TransactionsProcessed',
                          'Value': 1,
                          'Unit': 'Count'
                      }]
                  )

                  logger.info(json.dumps({
                      "level": "INFO",
                      "message": "Payment processed successfully",
                      "transaction_id": transaction_id
                  }))

              except Exception as e:
                  logger.error(json.dumps({
                      "level": "ERROR",
                      "message": f"Failed to process payment: {str(e)}",
                      "transaction_id": body.get('transaction_id', 'unknown')
                  }))
                  raise

          return {'statusCode': 200, 'body': json.dumps('Payments processed')}
    EOF
    filename = "index.py"
  }
}

