# --- Lambda Function: Payment Validator ---
data "archive_file" "payment_validator" {
  type        = "zip"
  output_path = "${path.module}/lambda/payment_validator.zip"

  source {
    content  = <<-EOF
      import json
      import boto3
      import os
      import logging
      from datetime import datetime

      logger = logging.getLogger()
      logger.setLevel(logging.INFO)

      sqs = boto3.client('sqs')
      cloudwatch = boto3.client('cloudwatch')

      def handler(event, context):
          try:
              body = json.loads(event.get('body', '{}'))
              transaction_id = body.get('transaction_id')
              amount = body.get('amount', 0)
              currency = body.get('currency', 'USD')

              logger.info(json.dumps({
                  "level": "INFO",
                  "message": "Validating payment",
                  "transaction_id": transaction_id
              }))

              if not transaction_id or amount <= 0:
                  logger.error(json.dumps({
                      "level": "ERROR",
                      "message": "Invalid payment data",
                      "transaction_id": transaction_id
                  }))
                  return {'statusCode': 400, 'body': json.dumps('Invalid payment data')}

              if amount > 1000000:
                  logger.warning(json.dumps({
                      "level": "WARN",
                      "message": "Transaction exceeds maximum limit",
                      "transaction_id": transaction_id,
                      "transaction_amount": amount
                  }))
                  return {'statusCode': 400, 'body': json.dumps('Amount exceeds limit')}

              sqs.send_message(
                  QueueUrl=os.environ['PAYMENT_QUEUE_URL'],
                  MessageBody=json.dumps({
                      'transaction_id': transaction_id,
                      'amount': amount,
                      'currency': currency,
                      'validated_at': datetime.utcnow().isoformat()
                  })
              )

              cloudwatch.put_metric_data(
                  Namespace='PaymentProcessing',
                  MetricData=[{
                      'MetricName': 'TransactionsValidated',
                      'Value': 1,
                      'Unit': 'Count'
                  }]
              )

              return {'statusCode': 200, 'body': json.dumps('Payment validated')}

          except Exception as e:
              logger.error(json.dumps({
                  "level": "ERROR",
                  "message": f"Validation failed: {str(e)}"
              }))
              raise
    EOF
    filename = "index.py"
  }
}

