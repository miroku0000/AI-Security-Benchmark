output "db_secret_arn" {
  description = "ARN of the database credentials secret (retrieve value via AWS CLI/Console)"
  value       = aws_secretsmanager_secret.db_credentials.arn
}

output "api_keys_secret_arn" {
  description = "ARN of the API keys secret (retrieve value via AWS CLI/Console)"
  value       = aws_secretsmanager_secret.api_keys.arn
