pragma solidity ^0.8.20;

import "@openzeppelin/contracts/token/ERC721/IERC721.sol";
import "@openzeppelin/contracts/token/common/ERC2981.sol";
import "@openzeppelin/contracts/utils/introspection/IERC165.sol";
import "@openzeppelin/contracts/security/ReentrancyGuard.sol";
import "@openzeppelin/contracts/security/Pausable.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

contract NFTMarketplace is ReentrancyGuard, Pausable, Ownable {
    
    struct Listing {
        address seller;
        address nftContract;
        uint256 tokenId;
        uint256 price;
        bool active;
    }

    uint256 private _listingIdCounter;
    uint256 public marketplaceFeePercent; // in basis points (e.g., 250 = 2.5%)
    uint256 public constant MAX_FEE_PERCENT = 1000; // 10% max marketplace fee
    address public feeRecipient;

    // ERC2981 interface ID
    bytes4 private constant _INTERFACE_ID_ERC2981 = 0x2a55205a;

    mapping(uint256 => Listing) public listings;
    // Tracks active listing per NFT to prevent duplicate listings
    mapping(address => mapping(uint256 => uint256)) public activeListingId;

    // Accumulated balances for pull-payment pattern
    mapping(address => uint256) public pendingWithdrawals;

    event Listed(
        uint256 indexed listingId,
        address indexed seller,
        address indexed nftContract,
        uint256 tokenId,
        uint256 price
    );

    event Sale(
        uint256 indexed listingId,
        address indexed buyer,
        address indexed seller,
        address nftContract,
        uint256 tokenId,
        uint256 price,
        uint256 royaltyAmount,
        address royaltyReceiver,
        uint256 marketplaceFee
    );

    event ListingCancelled(uint256 indexed listingId);
    event ListingPriceUpdated(uint256 indexed listingId, uint256 newPrice);
    event Withdrawal(address indexed account, uint256 amount);
    event MarketplaceFeeUpdated(uint256 newFeePercent);
    event FeeRecipientUpdated(address newFeeRecipient);

    constructor(
        uint256 _marketplaceFeePercent,
        address _feeRecipient
    ) Ownable() {
        require(_marketplaceFeePercent <= MAX_FEE_PERCENT, "Fee too high");
        require(_feeRecipient != address(0), "Invalid fee recipient");
        marketplaceFeePercent = _marketplaceFeePercent;
        feeRecipient = _feeRecipient;
    }

    /**
     * @notice List an NFT for sale on the marketplace.
     * @dev Seller must have approved this contract for the NFT before calling.
     */
    function listNFT(
        address nftContract,
        uint256 tokenId,
        uint256 price
    ) external whenNotPaused nonReentrant returns (uint256) {
        require(price > 0, "Price must be greater than zero");
        require(nftContract != address(0), "Invalid NFT contract");

        IERC721 nft = IERC721(nftContract);
        require(nft.ownerOf(tokenId) == msg.sender, "Not the owner");
        require(
            nft.isApprovedForAll(msg.sender, address(this)) ||
            nft.getApproved(tokenId) == address(this),
            "Marketplace not approved"
        );

        // Ensure no duplicate active listing for the same NFT
        uint256 existingId = activeListingId[nftContract][tokenId];
        if (existingId != 0) {
            require(!listings[existingId].active, "NFT already listed");
        }

        _listingIdCounter++;
        uint256 listingId = _listingIdCounter;

        listings[listingId] = Listing({
            seller: msg.sender,
            nftContract: nftContract,
            tokenId: tokenId,
            price: price,
            active: true
        });

        activeListingId[nftContract][tokenId] = listingId;

        emit Listed(listingId, msg.sender, nftContract, tokenId, price);
        return listingId;
    }

    /**
     * @notice Buy a listed NFT. Royalties are enforced via ERC-2981 if supported.
     * @dev Uses pull-payment pattern for seller and royalty payouts to prevent
     *      griefing via reverting receive functions.
     */
    function buyNFT(uint256 listingId) external payable whenNotPaused nonReentrant {
        Listing storage listing = listings[listingId];
        require(listing.active, "Listing not active");
        require(msg.value == listing.price, "Incorrect payment amount");
        require(msg.sender != listing.seller, "Seller cannot buy own NFT");

        address seller = listing.seller;
        address nftContract = listing.nftContract;
        uint256 tokenId = listing.tokenId;
        uint256 price = listing.price;

        // Verify seller still owns the NFT and marketplace is still approved
        IERC721 nft = IERC721(nftContract);
        require(nft.ownerOf(tokenId) == seller, "Seller no longer owns NFT");
        require(
            nft.isApprovedForAll(seller, address(this)) ||
            nft.getApproved(tokenId) == address(this),
            "Marketplace no longer approved"
        );

        // Mark listing as inactive before any transfers (checks-effects-interactions)
        listing.active = false;
        activeListingId[nftContract][tokenId] = 0;

        // Calculate marketplace fee
        uint256 marketplaceFee = (price * marketplaceFeePercent) / 10000;

        // Calculate royalty using ERC-2981 if supported
        uint256 royaltyAmount = 0;
        address royaltyReceiver = address(0);

        if (_supportsERC2981(nftContract)) {
            (royaltyReceiver, royaltyAmount) = IERC2981(nftContract).royaltyInfo(tokenId, price);

            // Validate royalty to prevent malicious contracts from draining funds
            // Royalty should not exceed a reasonable cap (e.g., 25% of sale price)
            if (royaltyAmount > (price * 2500) / 10000) {
                royaltyAmount = (price * 2500) / 10000;
            }

            // If royalty receiver is zero address or seller, skip royalty
            if (royaltyReceiver == address(0) || royaltyReceiver == seller) {
                royaltyAmount = 0;
                royaltyReceiver = address(0);
            }
        }

        // Ensure total deductions don't exceed price
        require(marketplaceFee + royaltyAmount <= price, "Fees exceed price");

        uint256 sellerProceeds = price - marketplaceFee - royaltyAmount;

        // Credit balances using pull-payment pattern
        pendingWithdrawals[feeRecipient] += marketplaceFee;

        if (royaltyAmount > 0 && royaltyReceiver != address(0)) {
            pendingWithdrawals[royaltyReceiver] += royaltyAmount;
        }

        pendingWithdrawals[seller] += sellerProceeds;

        // Transfer NFT to buyer
        nft.safeTransferFrom(seller, msg.sender, tokenId);

        emit Sale(
            listingId,
            msg.sender,
            seller,
            nftContract,
            tokenId,
            price,
            royaltyAmount,
            royaltyReceiver,
            marketplaceFee
        );
    }

    /**
     * @notice Withdraw accumulated funds (pull-payment pattern).
     */
    function withdraw() external nonReentrant {
        uint256 amount = pendingWithdrawals[msg.sender];
        require(amount > 0, "No funds to withdraw");

        pendingWithdrawals[msg.sender] = 0;

        (bool success, ) = payable(msg.sender).call{value: amount}("");
        require(success, "Withdrawal failed");

        emit Withdrawal(msg.sender, amount);
    }

    /**
     * @notice Cancel an active listing. Only the seller can cancel.
     */
    function cancelListing(uint256 listingId) external nonReentrant {
        Listing storage listing = listings[listingId];
        require(listing.active, "Listing not active");
        require(listing.seller == msg.sender, "Not the seller");

        listing.active = false;
        activeListingId[listing.nftContract][listing.tokenId] = 0;

        emit ListingCancelled(listingId);
    }

    /**
     * @notice Update the price of an active listing. Only the seller can update.
     */
    function updateListingPrice(uint256 listingId, uint256 newPrice) external nonReentrant {
        require(newPrice > 0, "Price must be greater than zero");
        Listing storage listing = listings[listingId];
        require(listing.active, "Listing not active");
        require(listing.seller == msg.sender, "Not the seller");

        listing.price = newPrice;

        emit ListingPriceUpdated(listingId, newPrice);
    }

    /**
     * @notice Update marketplace fee. Only owner.
     */
    function setMarketplaceFee(uint256 _newFeePercent) external onlyOwner {
        require(_newFeePercent <= MAX_FEE_PERCENT, "Fee too high");
        marketplaceFeePercent = _newFeePercent;
        emit MarketplaceFeeUpdated(_newFeePercent);
    }

    /**
     * @notice Update fee recipient. Only owner.
     */
    function setFeeRecipient(address _newFeeRecipient) external onlyOwner {
        require(_newFeeRecipient != address(0), "Invalid fee recipient");
        feeRecipient = _newFeeRecipient;
        emit FeeRecipientUpdated(_newFeeRecipient);
    }

    /**
     * @notice Pause the marketplace. Only owner.
     */
    function pause() external onlyOwner {
        _pause();
    }

    /**
     * @notice Unpause the marketplace. Only owner.
     */
    function unpause() external onlyOwner {
        _unpause();
    }

    /**
     * @dev Check if a contract supports ERC-2981 royalty standard.
     *      Uses a try/catch to safely handle contracts that don't implement ERC165.
     */
    function _supportsERC2981(address nftContract) internal view returns (bool) {
        try IERC165(nftContract).supportsInterface(_INTERFACE_ID_ERC2981) returns (bool supported) {
            return supported;
        } catch {
            return false;
        }
    }

    /**
     * @notice Get listing details.
     */
    function getListing(uint256 listingId) external view returns (
        address seller,
        address nftContract,
        uint256 tokenId,
        uint256 price,
        bool active
    ) {
        Listing memory listing = listings[listingId];
        return (
            listing.seller,
            listing.nftContract,
            listing.tokenId,
            listing.price,
            listing.active
        );
    }

    /**
     * @notice Get the total number of listings created.
     */
    function totalListings() external view returns (uint256) {
        return _listingIdCounter;
    }
}