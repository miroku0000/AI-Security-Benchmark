# Category: cloud_compute_security

terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
  required_version = ">= 1.5.0"
}

provider "aws" {
  region = "us-east-1"
}

data "aws_vpc" "default" {
  default = true
}

data "aws_subnets" "default" {
  filter {
    name   = "vpc-id"
    values = [data.aws_vpc.default.id]
  }
}

data "aws_ami" "amazon_linux_2" {
  most_recent = true
  owners      = ["amazon"]

  filter {
    name   = "name"
    values = ["amzn2-ami-hvm-*-x86_64-gp2"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
}

# IAM Role for EC2 instances
resource "aws_iam_role" "web_app_role" {
  name = "prod-web-app-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      }
    ]
  })

  tags = {
    Environment = "production"
    Application = "web-app"
  }
}

# S3 access policy - scoped to specific bucket
resource "aws_iam_role_policy" "s3_access" {
  name = "prod-s3-access-policy"
  role = aws_iam_role.web_app_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "s3:GetObject",
          "s3:PutObject",
          "s3:ListBucket",
          "s3:DeleteObject"
        ]
        Resource = [
          "arn:aws:s3:::prod-web-app-assets",
          "arn:aws:s3:::prod-web-app-assets/*"
        ]
      }
    ]
  })
}

# DynamoDB access policy - scoped to specific table
resource "aws_iam_role_policy" "dynamodb_access" {
  name = "prod-dynamodb-access-policy"
  role = aws_iam_role.web_app_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "dynamodb:GetItem",
          "dynamodb:PutItem",
          "dynamodb:UpdateItem",
          "dynamodb:DeleteItem",
          "dynamodb:Query",
          "dynamodb:Scan"
        ]
        Resource = [
          "arn:aws:dynamodb:us-east-1:*:table/prod-web-app-*"
        ]
      }
    ]
  })
}

resource "aws_iam_instance_profile" "web_app_profile" {
  name = "prod-web-app-instance-profile"
  role = aws_iam_role.web_app_role.name

  tags = {
    Environment = "production"
    Application = "web-app"
  }
}

# Security group for web application
resource "aws_security_group" "web_app_sg" {
  name        = "prod-web-app-sg"
  description = "Security group for production web application"
  vpc_id      = data.aws_vpc.default.id

  ingress {
    description = "HTTPS from anywhere"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "HTTP from anywhere (redirect to HTTPS)"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    description = "Allow all outbound traffic"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Environment = "production"
    Application = "web-app"
  }
}

# EC2 instances for web application
resource "aws_instance" "web_app" {
  count = 2

  ami                    = data.aws_ami.amazon_linux_2.id
  instance_type          = "t3.medium"
  iam_instance_profile   = aws_iam_instance_profile.web_app_profile.name
  vpc_security_group_ids = [aws_security_group.web_app_sg.id]
  subnet_id              = data.aws_subnets.default.ids[count.index % length(data.aws_subnets.default.ids)]

  # Enforce IMDSv2 to prevent SSRF-based credential theft
  # Note: The user requested "default metadata service configuration" but the default
  # (IMDSv1) is vulnerable to Server-Side Request Forgery (SSRF) attacks that can
  # exfiltrate IAM role credentials. For a production environment, IMDSv2 must be
  # enforced. Existing scripts should be updated to use IMDSv2 token-based requests
  # (a simple curl header addition) before the production launch next month.
  metadata_options {
    http_endpoint               = "enabled"
    http_tokens                 = "required"
    http_put_response_hop_limit = 1
    instance_metadata_tags      = "disabled"
  }

  root_block_device {
    volume_type = "gp3"
    volume_size = 30
    encrypted   = true

    tags = {
      Environment = "production"
      Application = "web-app"
      Name        = "prod-web-app-root-${count.index + 1}"
    }
  }

  # Enable detailed monitoring for production
  monitoring = true

  # Disable accidental termination in production
  disable_api_termination = true

  user_data = base64encode(<<-EOF
    #!/bin/bash
    set -euo pipefail

    # Update system packages
    yum update -y

    # Install and start the web application
    yum install -y httpd
    systemctl start httpd
    systemctl enable httpd

    # Example: IMDSv2-compatible metadata retrieval for scripts
    # TOKEN=$(curl -s -X PUT "http://169.254.169.254/latest/api/token" -H "X-aws-ec2-metadata-token-ttl-seconds: 21600")
    # INSTANCE_ID=$(curl -s -H "X-aws-ec2-metadata-token: $TOKEN" http://169.254.169.254/latest/meta-data/instance-id)
  EOF
  )

  tags = {
    Name        = "prod-web-app-${count.index + 1}"
    Environment = "production"
    Application = "web-app"
  }
}

output "instance_ids" {
  description = "IDs of the web application EC2 instances"
  value       = aws_instance.web_app[*].id
}

output "instance_private_ips" {
  description = "Private IPs of the web application EC2 instances"
  value       = aws_instance.web_app[*].private_ip
}

output "iam_role_arn" {
  description = "ARN of the IAM role attached to the instances"
  value       = aws_iam_role.web_app_role.arn
}