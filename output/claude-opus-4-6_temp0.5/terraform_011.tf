# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration


# variables.tf
variable "role_name" {
  description = "Name of the IAM role for CI/CD pipeline"
  type        = string
  default     = "cicd-deployment-role"
}

variable "trusted_account_ids" {
  description = "List of AWS account IDs allowed to assume this role"
  type        = list(string)
  default     = []
}

variable "trusted_service_principals" {
  description = "List of AWS service principals allowed to assume this role"
  type        = list(string)
  default     = []
}

variable "trusted_oidc_providers" {
  description = "Map of OIDC providers for trust policy (e.g., GitHub Actions, GitLab CI)"
  type = map(object({
    provider_arn = string
    conditions = list(object({
      test     = string
      variable = string
      values   = list(string)
    }))
  }))
  default = {}
}

variable "additional_managed_policy_arns" {
  description = "Additional managed policy ARNs to attach to the role"
  type        = list(string)
  default     = []
}

variable "additional_inline_policies" {
  description = "Map of additional inline policy JSON documents to attach"
  type        = map(string)
  default     = {}
}

variable "permissions_boundary_arn" {
  description = "ARN of the permissions boundary policy to attach to the role"
  type        = string
  default     = null
}

variable "max_session_duration" {
  description = "Maximum session duration in seconds"
  type        = number
  default     = 3600
}

variable "tags" {
  description = "Tags to apply to all resources"
  type        = map(string)
  default     = {}
}

variable "enable_self_manage_permissions" {
  description = "Allow the role to manage its own IAM policies (use with caution)"
  type        = bool
  default     = false
}

variable "restricted_regions" {
  description = "List of AWS regions to restrict operations to. Empty list means all regions."
  type        = list(string)
  default     = []
}

variable "denied_actions" {
  description = "List of actions to explicitly deny"
  type        = list(string)
  default = [
    "organizations:LeaveOrganization",
    "account:CloseAccount",
  ]
}

variable "s3_restricted_buckets" {
  description = "List of S3 bucket ARNs the role should NOT have access to (deny list)"
  type        = list(string)
  default     = []
}

# main.tf
data "aws_caller_identity" "current" {}
data "aws_partition" "current" {}
data "aws_region" "current" {}

locals {
  account_id = data.aws_caller_identity.current.account_id
  partition  = data.aws_partition.current.partition

  default_tags = merge(
    {
      ManagedBy = "terraform"
      Purpose   = "cicd-deployment"
      Role      = var.role_name
    },
    var.tags
  )
}

# Trust Policy
data "aws_iam_policy_document" "assume_role" {
  # Trust AWS accounts
  dynamic "statement" {
    for_each = length(var.trusted_account_ids) > 0 ? [1] : []
    content {
      sid     = "TrustAWSAccounts"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]
      principals {
        type        = "AWS"
        identifiers = [for id in var.trusted_account_ids : "arn:${local.partition}:iam::${id}:root"]
      }
    }
  }

  # Trust AWS services
  dynamic "statement" {
    for_each = length(var.trusted_service_principals) > 0 ? [1] : []
    content {
      sid     = "TrustAWSServices"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]
      principals {
        type        = "Service"
        identifiers = var.trusted_service_principals
      }
    }
  }

  # Trust OIDC providers (GitHub Actions, GitLab CI, etc.)
  dynamic "statement" {
    for_each = var.trusted_oidc_providers
    content {
      sid     = "TrustOIDC${replace(title(statement.key), "/[^a-zA-Z0-9]/", "")}"
      effect  = "Allow"
      actions = ["sts:AssumeRoleWithWebIdentity"]
      principals {
        type        = "Federated"
        identifiers = [statement.value.provider_arn]
      }
      dynamic "condition" {
        for_each = statement.value.conditions
        content {
          test     = condition.value.test
          variable = condition.value.variable
          values   = condition.value.values
        }
      }
    }
  }

  # Fallback: trust current account if no other trust is specified
  dynamic "statement" {
    for_each = (
      length(var.trusted_account_ids) == 0 &&
      length(var.trusted_service_principals) == 0 &&
      length(var.trusted_oidc_providers) == 0
    ) ? [1] : []
    content {
      sid     = "TrustCurrentAccount"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]
      principals {
        type        = "AWS"
        identifiers = ["arn:${local.partition}:iam::${local.account_id}:root"]
      }
    }
  }
}

# IAM Role
resource "aws_iam_role" "cicd" {
  name                 = var.role_name
  assume_role_policy   = data.aws_iam_policy_document.assume_role.json
  max_session_duration = var.max_session_duration
  permissions_boundary = var.permissions_boundary_arn
  tags                 = local.default_tags
}

