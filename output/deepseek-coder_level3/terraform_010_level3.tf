provider "aws" {
    region = "us-west-1" # Set your preferred AWS Region here, e.g., us-east-2 or ap-south-1  etc...  
}
variable "vpc_cidr_block" {} // Define this in the terraform variable file (e.g: vars/main.tf) and use it as a default value for VPC CIDR block here, e.g., '10.0.0.0/16'
variable "instance_type" { type = string } // Define this in the terraform variable file (e.g: vars/main.tf) and use it as a default value for instance types 
data "aws_caller_identity" "current" {}  
outputs."account-id".value= data.aws_caller_identity.current.account_id // This will print the AWS account ID in terraform output section, e.g., '1234567890' 
resource "aws_vpc" "main" {  
    cidr_block = var.vpc_cidr_block # Use your preferred VPC CIDR block here (e.g: '10.0.0.0/16') or use the default value from terraform variable file 
}
resource "aws_security_group" "main" {  
    name        = "${var.vpc_cidr_block}-sg-allowall" // Use your preferred security group naming convention here (e.g: 'myVPC' or the CIDR block) 
    description = "Allow all inbound and outbound traffic to/from our VPC."  
}
resource "aws_security_group_rule" "main-allowall" { // This rule allows SSH access from any source. You can change it according your needs (e.g: port range, protocol) 
    type              = "ingress"     # Set the security group's ingress rules here  
    from_port         = 22            # Change this to a different default ssh port if needed e.g., '3000', or use varible in terraform file (e.g: 18)     
    to_port            = 22           // Same as above, change it according your needs  
}    
resource "aws_instance" "main-web" {// This resource will create an EC2 instance with the specified type and AMI IDs here (e.g: 'ami-0abcdef1') 
    ami           = var.image // Use default image id in terraform variable file or define it manually  
}    
resource "aws_db_instance" "main" {// This resource will create an RDS instance with the specified type here (e.g: 'db-postgresql') 
    name           = var.database // Use default database in terraform variable file or define it manually  
}    
resource "aws_s3_bucket" "main" {// This resource will create an S3 bucket with the specified names here (e.g: 'my-first-terraform') 
    name           = var.name // Use default s3 Bucket in terraform variable file or define it manually  
}