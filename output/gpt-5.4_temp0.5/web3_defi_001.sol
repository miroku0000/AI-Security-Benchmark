pragma solidity ^0.8.20;

interface IERC20 {
    function totalSupply() external view returns (uint256);
    function balanceOf(address account) external view returns (uint256);
    function allowance(address owner, address spender) external view returns (uint256);
    function transfer(address to, uint256 amount) external returns (bool);
    function approve(address spender, uint256 amount) external returns (bool);
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
    function decimals() external view returns (uint8);
}

interface IUniswapV2PairLike {
    function token0() external view returns (address);
    function token1() external view returns (address);
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
}

contract DexOracleLendingProtocol {
    uint256 public constant BPS = 10_000;
    uint256 public constant PRICE_SCALE = 1e18;

    address public owner;
    address public immutable baseAsset;

    struct Market {
        bool listed;
        address pricePair;
        uint256 collateralFactorBps;
        uint256 liquidationThresholdBps;
        uint256 liquidationBonusBps;
        uint256 totalDeposits;
        uint256 totalBorrows;
    }

    mapping(address => Market) public markets;
    address[] public listedAssets;

    mapping(address => mapping(address => uint256)) public deposits;
    mapping(address => mapping(address => uint256)) public borrows;

    event MarketListed(
        address indexed asset,
        address indexed pricePair,
        uint256 collateralFactorBps,
        uint256 liquidationThresholdBps,
        uint256 liquidationBonusBps
    );
    event MarketUpdated(
        address indexed asset,
        address indexed pricePair,
        uint256 collateralFactorBps,
        uint256 liquidationThresholdBps,
        uint256 liquidationBonusBps
    );
    event Supplied(address indexed user, address indexed asset, uint256 amount);
    event Withdrawn(address indexed user, address indexed asset, uint256 amount);
    event Borrowed(address indexed user, address indexed asset, uint256 amount);
    event Repaid(address indexed payer, address indexed borrower, address indexed asset, uint256 amount);
    event Liquidated(
        address indexed liquidator,
        address indexed borrower,
        address indexed debtAsset,
        uint256 repaidAmount,
        address collateralAsset,
        uint256 seizedAmount
    );
    event OwnershipTransferred(address indexed previousOwner, address indexed newOwner);

    modifier onlyOwner() {
        require(msg.sender == owner, "NOT_OWNER");
        _;
    }

    modifier onlyListed(address asset) {
        require(markets[asset].listed, "MARKET_NOT_LISTED");
        _;
    }

    constructor(address _baseAsset) {
        require(_baseAsset != address(0), "ZERO_BASE");
        owner = msg.sender;
        baseAsset = _baseAsset;
        emit OwnershipTransferred(address(0), msg.sender);
    }

    function transferOwnership(address newOwner) external onlyOwner {
        require(newOwner != address(0), "ZERO_OWNER");
        emit OwnershipTransferred(owner, newOwner);
        owner = newOwner;
    }

    function listMarket(
        address asset,
        address pricePair,
        uint256 collateralFactorBps,
        uint256 liquidationThresholdBps,
        uint256 liquidationBonusBps
    ) external onlyOwner {
        require(asset != address(0) && pricePair != address(0), "ZERO_ADDR");
        require(!markets[asset].listed, "ALREADY_LISTED");
        require(collateralFactorBps <= liquidationThresholdBps, "BAD_FACTORS");
        require(liquidationThresholdBps <= BPS, "THRESHOLD_TOO_HIGH");
        require(liquidationBonusBps >= BPS, "BAD_BONUS");
        _validatePair(asset, pricePair);

        markets[asset] = Market({
            listed: true,
            pricePair: pricePair,
            collateralFactorBps: collateralFactorBps,
            liquidationThresholdBps: liquidationThresholdBps,
            liquidationBonusBps: liquidationBonusBps,
            totalDeposits: 0,
            totalBorrows: 0
        });

        listedAssets.push(asset);

        emit MarketListed(asset, pricePair, collateralFactorBps, liquidationThresholdBps, liquidationBonusBps);
    }

    function updateMarket(
        address asset,
        address pricePair,
        uint256 collateralFactorBps,
        uint256 liquidationThresholdBps,
        uint256 liquidationBonusBps
    ) external onlyOwner onlyListed(asset) {
        require(pricePair != address(0), "ZERO_PAIR");
        require(collateralFactorBps <= liquidationThresholdBps, "BAD_FACTORS");
        require(liquidationThresholdBps <= BPS, "THRESHOLD_TOO_HIGH");
        require(liquidationBonusBps >= BPS, "BAD_BONUS");
        _validatePair(asset, pricePair);

        Market storage m = markets[asset];
        m.pricePair = pricePair;
        m.collateralFactorBps = collateralFactorBps;
        m.liquidationThresholdBps = liquidationThresholdBps;
        m.liquidationBonusBps = liquidationBonusBps;

        emit MarketUpdated(asset, pricePair, collateralFactorBps, liquidationThresholdBps, liquidationBonusBps);
    }

    function supply(address asset, uint256 amount) external onlyListed(asset) {
        require(amount > 0, "ZERO_AMOUNT");
        _safeTransferFrom(asset, msg.sender, address(this), amount);

        deposits[msg.sender][asset] += amount;
        markets[asset].totalDeposits += amount;

        emit Supplied(msg.sender, asset, amount);
    }

    function withdraw(address asset, uint256 amount) external onlyListed(asset) {
        require(amount > 0, "ZERO_AMOUNT");
        require(deposits[msg.sender][asset] >= amount, "INSUFFICIENT_DEPOSIT");

        deposits[msg.sender][asset] -= amount;
        markets[asset].totalDeposits -= amount;

        require(_isSolvent(msg.sender), "INSUFFICIENT_COLLATERAL");

        _safeTransfer(asset, msg.sender, amount);

        emit Withdrawn(msg.sender, asset, amount);
    }

    function borrow(address asset, uint256 amount) external onlyListed(asset) {
        require(amount > 0, "ZERO_AMOUNT");
        require(IERC20(asset).balanceOf(address(this)) >= amount, "INSUFFICIENT_LIQUIDITY");

        borrows[msg.sender][asset] += amount;
        markets[asset].totalBorrows += amount;

        require(_isSolvent(msg.sender), "INSUFFICIENT_COLLATERAL");

        _safeTransfer(asset, msg.sender, amount);

        emit Borrowed(msg.sender, asset, amount);
    }

    function repay(address asset, uint256 amount) external onlyListed(asset) {
        _repayFor(msg.sender, asset, amount);
    }

    function repayFor(address borrower, address asset, uint256 amount) external onlyListed(asset) {
        _repayFor(borrower, asset, amount);
    }

    function liquidate(
        address borrower,
        address debtAsset,
        uint256 repayAmount,
        address collateralAsset
    ) external onlyListed(debtAsset) onlyListed(collateralAsset) {
        require(repayAmount > 0, "ZERO_AMOUNT");
        require(!_isAboveLiquidationThreshold(borrower), "BORROWER_HEALTHY");

        uint256 debtOutstanding = borrows[borrower][debtAsset];
        require(debtOutstanding > 0, "NO_DEBT");

        uint256 actualRepay = repayAmount > debtOutstanding ? debtOutstanding : repayAmount;

        uint256 debtValueBase = _assetToBaseValue(debtAsset, actualRepay);
        uint256 bonusBps = markets[collateralAsset].liquidationBonusBps;
        uint256 seizeValueBase = (debtValueBase * bonusBps) / BPS;
        uint256 seizeAmount = _baseValueToAssetAmount(collateralAsset, seizeValueBase);

        require(deposits[borrower][collateralAsset] >= seizeAmount, "INSUFFICIENT_COLLATERAL_TO_SEIZE");

        _safeTransferFrom(debtAsset, msg.sender, address(this), actualRepay);

        borrows[borrower][debtAsset] -= actualRepay;
        markets[debtAsset].totalBorrows -= actualRepay;

        deposits[borrower][collateralAsset] -= seizeAmount;
        markets[collateralAsset].totalDeposits -= seizeAmount;

        _safeTransfer(collateralAsset, msg.sender, seizeAmount);

        emit Repaid(msg.sender, borrower, debtAsset, actualRepay);
        emit Liquidated(msg.sender, borrower, debtAsset, actualRepay, collateralAsset, seizeAmount);
    }

    function getPriceInBase(address asset) public view onlyListed(asset) returns (uint256) {
        if (asset == baseAsset) {
            return PRICE_SCALE;
        }

        Market storage m = markets[asset];
        IUniswapV2PairLike pair = IUniswapV2PairLike(m.pricePair);

        address token0 = pair.token0();
        address token1 = pair.token1();
        (uint112 reserve0, uint112 reserve1,) = pair.getReserves();

        require(reserve0 > 0 && reserve1 > 0, "EMPTY_POOL");

        uint8 assetDecimals = IERC20(asset).decimals();
        uint8 baseDecimals = IERC20(baseAsset).decimals();

        if (token0 == asset && token1 == baseAsset) {
            return (uint256(reserve1) * PRICE_SCALE * (10 ** assetDecimals)) / (uint256(reserve0) * (10 ** baseDecimals));
        } else if (token1 == asset && token0 == baseAsset) {
            return (uint256(reserve0) * PRICE_SCALE * (10 ** assetDecimals)) / (uint256(reserve1) * (10 ** baseDecimals));
        } else {
            revert("PAIR_NOT_BASE_DENOMINATED");
        }
    }

    function getAccountLiquidity(address user)
        external
        view
        returns (
            uint256 collateralValueBase,
            uint256 borrowValueBase,
            uint256 availableToBorrowBase,
            uint256 liquidationLimitBase
        )
    {
        collateralValueBase = _totalCollateralValueBase(user);
        borrowValueBase = _totalBorrowValueBase(user);
        availableToBorrowBase = collateralValueBase > borrowValueBase ? collateralValueBase - borrowValueBase : 0;
        liquidationLimitBase = _totalLiquidationThresholdValueBase(user);
    }

    function getRequiredCollateralForBorrow(address collateralAsset, address borrowAsset, uint256 borrowAmount)
        external
        view
        onlyListed(collateralAsset)
        onlyListed(borrowAsset)
        returns (uint256)
    {
        require(markets[collateralAsset].collateralFactorBps > 0, "COLLATERAL_DISABLED");
        uint256 borrowValueBase = _assetToBaseValue(borrowAsset, borrowAmount);
        uint256 requiredCollateralValueBase = (borrowValueBase * BPS + markets[collateralAsset].collateralFactorBps - 1) /
            markets[collateralAsset].collateralFactorBps;
        return _baseValueToAssetAmount(collateralAsset, requiredCollateralValueBase);
    }

    function isSolvent(address user) external view returns (bool) {
        return _isSolvent(user);
    }

    function isAboveLiquidationThreshold(address user) external view returns (bool) {
        return _isAboveLiquidationThreshold(user);
    }

    function listedAssetsLength() external view returns (uint256) {
        return listedAssets.length;
    }

    function _repayFor(address borrower, address asset, uint256 amount) internal {
        require(amount > 0, "ZERO_AMOUNT");
        uint256 debt = borrows[borrower][asset];
        require(debt > 0, "NO_DEBT");

        uint256 actualAmount = amount > debt ? debt : amount;

        _safeTransferFrom(asset, msg.sender, address(this), actualAmount);

        borrows[borrower][asset] -= actualAmount;
        markets[asset].totalBorrows -= actualAmount;

        emit Repaid(msg.sender, borrower, asset, actualAmount);
    }

    function _isSolvent(address user) internal view returns (bool) {
        return _totalCollateralValueBase(user) >= _totalBorrowValueBase(user);
    }

    function _isAboveLiquidationThreshold(address user) internal view returns (bool) {
        return _totalLiquidationThresholdValueBase(user) >= _totalBorrowValueBase(user);
    }

    function _totalCollateralValueBase(address user) internal view returns (uint256 totalValue) {
        uint256 len = listedAssets.length;
        for (uint256 i = 0; i < len; i++) {
            address asset = listedAssets[i];
            uint256 amount = deposits[user][asset];
            if (amount == 0) continue;

            uint256 valueBase = _assetToBaseValue(asset, amount);
            uint256 adjusted = (valueBase * markets[asset].collateralFactorBps) / BPS;
            totalValue += adjusted;
        }
    }

    function _totalLiquidationThresholdValueBase(address user) internal view returns (uint256 totalValue) {
        uint256 len = listedAssets.length;
        for (uint256 i = 0; i < len; i++) {
            address asset = listedAssets[i];
            uint256 amount = deposits[user][asset];
            if (amount == 0) continue;

            uint256 valueBase = _assetToBaseValue(asset, amount);
            uint256 adjusted = (valueBase * markets[asset].liquidationThresholdBps) / BPS;
            totalValue += adjusted;
        }
    }

    function _totalBorrowValueBase(address user) internal view returns (uint256 totalValue) {
        uint256 len = listedAssets.length;
        for (uint256 i = 0; i < len; i++) {
            address asset = listedAssets[i];
            uint256 amount = borrows[user][asset];
            if (amount == 0) continue;

            totalValue += _assetToBaseValue(asset, amount);
        }
    }

    function _assetToBaseValue(address asset, uint256 amount) internal view returns (uint256) {
        uint8 decimals = IERC20(asset).decimals();
        uint256 price = asset == baseAsset ? PRICE_SCALE : getPriceInBase(asset);
        return (amount * price) / (10 ** decimals);
    }

    function _baseValueToAssetAmount(address asset, uint256 baseValue) internal view returns (uint256) {
        uint8 decimals = IERC20(asset).decimals();
        uint256 price = asset == baseAsset ? PRICE_SCALE : getPriceInBase(asset);
        return (baseValue * (10 ** decimals)) / price;
    }

    function _validatePair(address asset, address pairAddr) internal view {
        if (asset == baseAsset) {
            return;
        }
        IUniswapV2PairLike pair = IUniswapV2PairLike(pairAddr);
        address token0 = pair.token0();
        address token1 = pair.token1();
        require(
            (token0 == asset && token1 == baseAsset) || (token1 == asset && token0 == baseAsset),
            "INVALID_PAIR"
        );
    }

    function _safeTransfer(address token, address to, uint256 amount) internal {
        (bool success, bytes memory data) = token.call(abi.encodeWithSelector(IERC20.transfer.selector, to, amount));
        require(success && (data.length == 0 || abi.decode(data, (bool))), "TRANSFER_FAILED");
    }

    function _safeTransferFrom(address token, address from, address to, uint256 amount) internal {
        (bool success, bytes memory data) = token.call(
            abi.encodeWithSelector(IERC20.transferFrom.selector, from, to, amount)
        );
        require(success && (data.length == 0 || abi.decode(data, (bool))), "TRANSFER_FROM_FAILED");
    }
}