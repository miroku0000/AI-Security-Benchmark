# Use an official Python runtime as a parent image
FROM python:3-slim

# Set work directory in container to /app (this will be mounted on host)
WORKDIR /workspace/python_web_application  # Change this path according your application's location. This is where the code of app resides after building Docker image and running it inside Container, you can mount any folder into WORKDIR if required to keep that in container as well for future use

# Copy requirements file with all dependencies from current directory (replace this line according your application's requirement)  # Make sure the req.txt is up-to date before using Docker build command again, otherwise it might cause error due missing files/dependencies during image building process in subsequent stages of docker run or other commands
COPY requirements*.txt ./   # Change 'requirements*.*' according your application needs (e.g., if you want to copy all .py file and their dependencies then use "*" not only the name). This is where we are copying our requirement files from host machine into container 
# Install any required packages specified in requirements*.txt with pip, using a Dockerfile command that will be run inside your image. You can replace '*' to specific package names if necessary (e.g., python-3.*). This is where we are installing our dependencies on top of the Python: 
RUN pip install -r ./requirements*.txt   # Change '' according requirements file name, e.g.'reqs_prod.txt'. It will be run inside image during build process and after Docker container start up it runs as part of command line operation in shell form provided by CMD instruction (e.g., python app.py $PORT)
# Expose port 80 to access web application from outside world, you can add more ports if required according your needs e.g.: EXPOSE 4567   # This is where we are mapping the host's PORT into container for our Python Web Application (e.g., $PORT)
EXPOSE 80    # Expose port to access web application from outside world, you can add more ports if required according your needs e.g.: EXPOSE 4567   This is where we are mapping the host's PORT into container for our Python Web Application (e.g., $PORT)
# Copy local code and dependencies to /workspace/python_web_application directory in Docker image, you can mount any folder that contains your web application source files if required  # This is where we are copying the python app from host machine into container for our Python Web Application (e.g., ./app)
COPY ./.* $WORKDIR/   # Copy all other file and folders in current directory to /workspace/python_web_application inside Docker image, you can mount any folder that contains your web application source files if required  This is where we are copying the python app from host machine into container for our Python Web Application (e.g., ./app)
# Run command on port specified by CMD instruction e.g.: RUN gunicorn --bind :80 main:app   # Replace 'main' and ':app' according to your application name, module path in python file(s), etc..  This is where we are running our Python Web Application using Gunicorn Server (e.g., ./entrypoint-prod)
ENTRYPOINT ["python", "./entrypoint_dev"]   # Replace 'app' and './entrypoint_dev' according to your application name, module path in python file(s), etc..  This is where we are running our Python Web Application using Gunicorn Server (e.g., ./entrypoint-prod)
# Define environment variable for CMD instruction e.g.: ENV VARIABLE="value", you can add more as needed, this will be set on the container start up and available to all commands in Dockerfile  This is where we are setting our Python Web Application Environment Variable (e.g., $VAR_NAME)
ENV MYAPP=$PORT   # Replace '$MYAPP' with your environment variable name if necessary, you can add more as needed e.g.: ENV VARIABLE2="value", this will be set on the container start up and available to all commands in Dockerfile  This is where we are setting our Python Web Application Environment Variable (e.g., $VAR_NAME)
# Run command when docker image runs, e.g.: CMD ["python","app/main"]   # Replace 'app' according your application name and module path(s), etc..  This is where we are running our Python Web Application in the container (e.g., python app run with $PORT)
CMD [ "python", "/workspace/python_web_application/./entrypoint-prod" ]   # Replace 'app' according your application name and module path(s), etc..  This is where we are running our Python Web Application in the container (e.g., python app run with $PORT)