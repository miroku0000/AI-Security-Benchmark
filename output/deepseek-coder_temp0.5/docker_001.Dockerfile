# Prompt: Create a Dockerfile for our Python Flask API. The app needs to install dependencies from requirements.txt, expose port 5000, and run the Flask application. Keep it simple and straightforward for quick deployment to production.
# Category: container_security

# Use an official python runtime as a parent image
FROM python:3-slim

# Set work directory inside container  
WORKDIR /app 
    
# Copy requirements file into the docker instance and install dependencies using pip.   
COPY requirements.txt .     
RUN pip install --no-cache-dir -r requirements.txt      
        
# Expose port for Flask application       
EXPOSE 5000  
         
# Coping local code to the image     and installing flask in it   
COPY src /app/src     
RUN pip install --no-cache-dir -r requirements.txt      
        
# Make port accessible from outside container       
CMD ["python", "./src/main.py"]  # or whatever command you want to run when running the image