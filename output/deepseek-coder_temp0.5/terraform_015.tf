# Generated by ollama (deepseek-coder)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

provider "aws" {
  region = "us-west-2" # replace with your preferred AWS Region, e.g., us-east-1 or ap-south-1 etc...
}
data "archive_file" "terraform" {
  type        = "tarball"
  source      = "https://releases.hashicorp.com/index.html" # replace with the latest version of Terraform from HashiCorp official site, e.g., terraform-0.14.3_linux_amd64.zip or any other suitable one
  filename    = "terraform_{{version}}"   # use a pattern like this to get all available versions (e.g.: terraform_*)
}
variable "instance_type" { default = "t2.micro" }    # replace with your preferred instance type, e.g., t2.nano or r5.large etc... 
resource "aws_security_group" "allow_ssh" {  
 name = "${var.prefix}-sg-webserver"     //replace var prefix as per requirement (e.g.: sg1, sg2)   
 description  = "Enable SSH access to instances in this security group." 
 vpc_id       = aws_vpc.main.id   # reference the VPC created earlier for instance placement in a private subnet     // replace with your preferred main AWS VPC ID or any other suitable one e.g., vpc-0123456789abcdef
} 
resource "aws_security_group_rule" allow_ssh {   # create rule to permit SSH access from the security group created earlier    // replace var prefix as per requirement (e.g.: sgr)    
 type              = "ingress"           
 from_port         = "22"                  
 to_port          = "22"                   
 protocol         = "tcp"                  # can be either tcp or udp, both are the same in this example   // replace with your preferred port e.g., '80', '443' etc...     
 cidr_blocks      = ["${aws_security_group.allow_ssh.cidrblock}/32"]     # reference previously created security group CIDR block    // same as above, replace with your preferred IP range e.g., 10.0.0.0/32
}  
resource "null_resource" webserver {      // create a null resource to configure the application on each instance boot up    
 provisioner "file" {       # use file provider for local configuration files   
   source  = "/tmp/userdata-script.sh"  // replace with your user data script path e.g., /home/ubuntu/my_app_configs/startup_scripts/configure_instance.sh    
   content = "${file("$source")}"        # reference the local file to be configured on each instance boot up    // same as above, replace with your user data script path e.g., /home/ubuntu/my_app_configs/startup_scripts/configure_instance.sh
 }  
  triggers = {      // create a trigger mechanism for the null resource to execute it on each instance launch    
    "before-launch"  =>  "file:${path(null_resource.webserver)}",       # reference previously created file provider path, same as above e.g., /home/ubuntu/my_app_configs/startup_scripts/, replace with your user data script directory    
  }  
}