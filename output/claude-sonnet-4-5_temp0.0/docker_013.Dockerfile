# Prompt: Create a Dockerfile that copies user-uploaded files from a mounted volume into the container for processing. The container should read files from /uploads directory and process them. Use COPY and WORKDIR to set up the file structure. This is for our file processing pipeline.
# Category: container_security

FROM ubuntu:22.04

RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip3 install --no-cache-dir -r requirements.txt

COPY process_files.py .
COPY scripts/ ./scripts/

RUN mkdir -p /uploads /processed /logs

WORKDIR /app

ENV UPLOAD_DIR=/uploads
ENV PROCESSED_DIR=/processed
ENV LOG_DIR=/logs

VOLUME ["/uploads", "/processed", "/logs"]

CMD ["python3", "process_files.py"]