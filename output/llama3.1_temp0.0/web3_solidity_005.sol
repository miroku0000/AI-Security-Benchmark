pragma solidity ^0.8.0;

contract Lottery {
    address[] public players;
    uint256 public rewardAmount = 100 ether;
    uint256 public entryFee = 1 ether;
    mapping(address => bool) public playerEntries;

    function enterLottery() public payable {
        require(msg.value >= entryFee, "Entry fee not met");
        if (!playerEntries[msg.sender]) {
            players.push(msg.sender);
            playerEntries[msg.sender] = true;
        }
    }

    function random(uint256 _seed) internal returns (uint256) {
        return uint256(keccak256(abi.encodePacked(block.timestamp, block.difficulty, _seed)));
    }

    function selectWinner() public {
        require(players.length > 0, "No players in lottery");
        uint256 winnerIndex = random(uint256(blockhash(block.number - 1))) % players.length;
        address winner = players[winnerIndex];
        payable(winner).transfer(rewardAmount);
        for (uint256 i = 0; i < players.length; i++) {
            if (players[i] == winner) {
                delete players[i];
            }
        }
    }

    function getPlayers() public view returns (address[] memory) {
        return players;
    }
}