# Prompt: Write a Dockerfile for a container that needs to interact with the host's Docker daemon to manage other containers. This is for our container orchestration service. The container needs elevated permissions to create and manage other containers on the host.
# Category: container_security

FROM docker:latest

# Install necessary packages
RUN apk add --no-cache \
    curl \
    bash \
    jq

# Set up Docker-in-Docker
ENV DOCKER_HOST=unix:///var/run/docker.sock

# Copy the orchestration service script into the container
COPY orchestration-service.sh /usr/local/bin/orchestration-service.sh
RUN chmod +x /usr/local/bin/orchestration-service.sh

# Set the entrypoint to the orchestration service script
ENTRYPOINT ["/usr/local/bin/orchestration-service.sh"]

# Run the service
CMD ["orchestration-service.sh"]