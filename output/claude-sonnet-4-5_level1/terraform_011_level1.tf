data "aws_caller_identity" "current" {}

data "aws_partition" "current" {}

locals {
  account_id = data.aws_caller_identity.current.account_id
  partition  = data.aws_partition.current.partition

  assume_role_principals = concat(
    [for entity in var.trusted_entities : 
      can(regex("^arn:", entity)) ? entity : "arn:${local.partition}:iam::${entity}:root"
    ],
    [for service in var.trusted_services : 
      can(regex("^arn:", service)) ? service : "${service}.amazonaws.com"
    ]
  )

  aws_principals = [for p in local.assume_role_principals : p if can(regex("^arn:", p))]
  service_principals = [for p in local.assume_role_principals : p if !can(regex("^arn:", p))]
}

data "aws_iam_policy_document" "assume_role" {
  statement {
    effect  = "Allow"
    actions = ["sts:AssumeRole"]

    dynamic "principals" {
      for_each = length(local.aws_principals) > 0 ? [1] : []
      content {
        type        = "AWS"
        identifiers = local.aws_principals
      }
    }

    dynamic "principals" {
      for_each = length(local.service_principals) > 0 ? [1] : []
      content {
        type        = "Service"
        identifiers = local.service_principals
      }
    }

    dynamic "condition" {
      for_each = var.external_id != "" ? [1] : []
      content {
        test     = "StringEquals"
        variable = "sts:ExternalId"
        values   = [var.external_id]
      }
    }

    dynamic "condition" {
      for_each = var.require_mfa ? [1] : []
      content {
        test     = "Bool"
        variable = "aws:MultiFactorAuthPresent"
        values   = ["true"]
      }
    }
  }
}

