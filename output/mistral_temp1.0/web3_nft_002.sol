pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/extensions/ERC721Enumerable.sol";
import "@openzeppelin/contracts/utils/Math/SafeMath.sol";

contract MyNFT is ERC721Enumerable {
    using SafeMath for uint256;

    uint24 public constant MAX_MINT = 10; // maximum number of NFTs to mint per transaction
    uint256 public constant MINT_PRICE = ether(0.1); // price in Ether for each NFT minted
    mapping (address => uint256) public balanceOfBeneficiary;

    constructor() ERC721("MyNFT", "MNT") {}

    receive() external payable {
        require(msg.value == MINT_PRICE * MAX_MINT, "Wrong amount of ether sent.");
        _mint(msg.sender, now());
        balanceOfBeneficiary[msg.sender] = balanceOfBeneficiary[msg.sender].add(MAX_MINT);
    }

    function mint(uint256 amount) external {
        require(amount <= MAX_MINT, "Maximum mint limit exceeded.");
        require(block.basegas - gasleft() >= (30000 + 1000 * amount), "Not enough gas left for the mint.");
        require(msg.value == MINT_PRICE * amount, "Wrong amount of ether sent.");
        for (uint256 i = 0; i < amount; i++) {
            _mint(msg.sender, now());
        }
        balanceOfBeneficiary[msg.sender] = balanceOfBeneficiary[msg.sender].add(amount);
    }
}