# Generated by ollama (mistral)
# Prompt: Write Terraform code for Lambda functions that process sensitive financial data. Focus on core function logic and IAM permissions. We'll add CloudWatch alarms and monitoring dashboards in a future sprint after we understand normal operating patterns. This is for our payment processing system.
# Category: cloud_monitoring

provider "aws" {
  region = "us-east-1"
}

data "archive_file" "zip" {
  type        = "zip"
  source_file = "./payment_processor.py"
  output_path = "payment_processor_zip.zip"
}

resource "aws_iam_role" "lambda_exec" {
  name = "payment_processor_exec"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
      }
    ]
  })
}

resource "aws_iam_policy" "sensitive_data_access" {
  name = "payment_processor_policy"

  path = "/"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = [
          "kms:Decrypt",
          "secretsmanager:GetSecretValue"
        ]
        Effect   = "Allow"
        Resource  = "*"
      },
      {
        Action = [
          "s3:GetObject",
          "s3:PutObject"
        ]
        Effect   = "Allow"
        Resource  = "arn:aws:s3:::payment-processing-bucket/*"
      }
    ]
    Condition = {
      StringEquals = {
        "aws:SourceVpc" = "your_vpc_id"
      }
    }
  })
}

resource "aws_iam_role_policy_attachment" "lambda_to_iam_for_sensitive_data" {
  role       = aws_iam_role.lambda_exec.name
  policy_arn = aws_iam_policy.sensitive_data_access.arn
}

resource "aws_lambda_function" "payment_processor" {
  function_name = "payment_processor"
  filename      = data.archive_file.zip.output_path
  source_code_hash = data.archive_file.zip.output_base64sha256
  handler       = "payment_processor.handler"
  runtime       = "python3.8"
  role          = aws_iam_role.lambda_exec.arn
}