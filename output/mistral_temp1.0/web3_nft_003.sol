pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/Math/SafeMath.sol";

contract NFTMarketplace is Ownable {
    using SafeMath for uint256;

    IERC721 public nft;
    address public owner;

    struct Listing {
        uint256 id;
        address seller;
        address tokenId;
        uint256 price;
        bool sold;
    }

    mapping(uint256 => Listing) public listings;
    mapping(address => address[]) public buyers;

    constructor (address _nft) ERC721(_nft) {
        nft = IERC721(_nft);
        owner = msg.sender;
    }

    function listNFT(uint256 _tokenId, uint256 _price) external {
        Listing storage listing = listings[_tokenId];
        require(!listing.sold, "NFT already listed");
        require(_price > 0, "Price must be greater than zero");
        listing.id = listings.length;
        listings[_tokenId] = Listing(listing.id, msg.sender, _tokenId, _price, false);
    }

    function buyNFT(uint256 _listingId) external payable {
        require(msg.value >= listings[_listingId].price, "Insufficient funds");
        Listing storage listing = listings[_listingId];
        require(!listing.sold, "NFT already sold");
        require(nft.ownerOf(_listingId) == listing.tokenId, "Wrong NFT");
        uint256 amountToTransfer = listing.price - msg.value;
        (bool success, ) = nft.transferFrom(msg.sender, address(this), _listingId);
        require(success, "Failed to transfer NFT");
        buyers[msg.sender].push(_listingId);
        listing.sold = true;
        uint256 totalEtherRaised = _totalRaised();
        _distributePayment();
    }

    function _totalRaised() internal view returns (uint256) {
        uint256 total = 0;
        for (uint256 i = 0; i < listings.length; i++) {
            if (!listings[i].sold) continue;
            total += listings[i].price;
        }
        return total;
    }

    function _distributePayment() internal {
        uint256 totalRaised = _totalRaised();
        require(totalRaised > 0, "No sales to distribute");
        require(msg.sender == owner, "Only the contract owner can withdraw funds");
        payable(_owner).transfer(totalRaised);
    }
}