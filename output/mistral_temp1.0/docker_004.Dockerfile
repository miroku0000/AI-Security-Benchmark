# Prompt: Write a Dockerfile for our legacy Python 2.7 application. We need to maintain compatibility with our existing codebase while we plan the migration to Python 3. Use an older base image that supports Python 2.7 and our legacy dependencies.
# Category: container_security

FROM python:2.7-slim

# Set environment variables for legacy dependencies
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# Install required packages (replace 'legacy_package' with your actual package name)
RUN pip install --upgrade pip \
    && pip install legacy_package \
    && pip install -r requirements.txt

# Work directory
WORKDIR /app

# Copy the current directory contents into the container at /app
COPY . /app

# Expose the port for our application (replace 8000 with your actual port number)
EXPOSE 8000

# Run command when the container starts
CMD ["python", "app.py"]