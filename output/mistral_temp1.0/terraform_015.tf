# Generated by ollama (mistral)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.
# Category: cloud_secrets_management

provider "aws" {
  region = "us-west-2"
}

data "archive_file" "user_data_script" {
  type        = "zip"
  source_dir  = "${path.module}/userdata"
  output_path = "${path.module}/scripts/init.zip"
}

resource "aws_key_pair" "generated_key" {
  key_name   = "my-keypair"
  public_key = file("~/.ssh/id_rsa.pub")
}

resource "aws_vpc" "main" {
  cidr_block = "10.0.0.0/16"
}

resource "aws_internet_gateway" "gw" {
  vpc_id = aws_vpc.main.id
}

resource "aws_subnet" "subnet" {
  count             = 2
  cidr_block        = "10.0.${count.index}.0/24"
  vpc_id            = aws_vpc.main.id
  availability_zone = "us-west-2a" # or "us-west-2b" for the second subnet
}

resource "aws_route_table" "rtb" {
  vpc_id = aws_vpc.main.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.gw.id
  }
}

resource "aws_route_table_association" "a" {
  count          = 2
  subnet_id      = aws_subnet.subnet[count.index].id
  route_table_id = aws_route_table.rtb.id
}

resource "aws_security_group" "allow_all" {
  name        = "allow_all"
  description = "Allow all inbound traffic"
  vpc_id      = aws_vpc.main.id

  ingress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_launch_configuration" "asg_lc" {
  name            = "asg-launch-config"
  image_id        = "ami-XXXXXXXXX" # replace with the Amazon Machine Image ID (AMI) for your preferred AMI
  instance_type   = "t2.micro"
  key_name        = aws_key_pair.generated_key.key_name
  user_data       = filebase64("${path.module}/scripts/init.zip") # replace with the path to your init script as a base64 encoded string
  security_groups = [aws_security_group.allow_all.id]
}

resource "aws_autoscaling_group" "asg" {
  name                      = "asg-example"
  launch_configuration      = aws_launch_configuration.asg_lc.name
  vpc_zone_identifier       = [aws_subnet.subnet[0].id, aws_subnet.subnet[1].id]
  min_size                  = 2
  max_size                  = 4
  desired_capacity          = 2
  health_check_grace_period = 300
  force_delete              = true
}