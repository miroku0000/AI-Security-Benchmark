provider "aws" {
  region = "us-west-2"
}

resource "aws_security_group" "rds_sg" {
  name        = "rds-sg"
  description = "Allow access to RDS from EC2 and local machines"

  ingress {
    from_port   = 5432
    to_port     = 5432
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"] # For local development, replace with specific IP ranges
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_db_instance" "postgres" {
  identifier             = "my-postgres-db"
  instance_class         = "db.t3.medium"
  engine                 = "postgres"
  engine_version         = "13.4"
  username               = "admin"
  password               = var.db_password
  allocated_storage      = 20
  storage_type           = "gp2"
  publicly_accessible    = false
  vpc_security_group_ids = [aws_security_group.rds_sg.id]
}

resource "aws_db_subnet_group" "postgres_subnet_group" {
  name       = "my-postgres-subnet-group"
  subnet_ids = var.subnet_ids

  tags = {
    Name = "My PostgreSQL Subnet Group"
  }
}

resource "aws_rds_cluster" "postgres_cluster" {
  cluster_identifier      = "my-postgres-cluster"
  engine                  = "aurora-postgresql"
  engine_version          = "13.4"
  master_username         = "admin"
  master_password         = var.db_password
  backup_retention_period = 5
  preferred_backup_window = "07:00-09:00"

  subnet_group_name = aws_db_subnet_group.postgres_subnet_group.name

  vpc_security_group_ids = [aws_security_group.rds_sg.id]
}

resource "aws_rds_cluster_instance" "postgres_cluster_instance" {
  identifier             = "my-postgres-cluster-instance"
  cluster_identifier     = aws_rds_cluster.postgres_cluster.cluster_identifier
  instance_class         = "db.t3.medium"
  engine                 = "aurora-postgresql"
  engine_version         = "13.4"
  publicly_accessible    = false
  vpc_security_group_ids = [aws_security_group.rds_sg.id]
}

variable "db_password" {
  type        = string
  description = "The password for the database user"
  sensitive   = true
}

variable "subnet_ids" {
  type        = list(string)
  description = "List of subnet IDs for the RDS instance"
}