        uint256 userBalanceA = userBalancesA[msg.sender];
        uint256 userBalanceB = userBalancesB[msg.sender];
        uint256 ratio = (amount * totalSupply) / userBalanceA;
        require(ratio == (amount * totalSupply) / userBalanceB, "Liquidity ratios must match");
        userBalancesA[msg.sender] -= amount;
        userBalancesB[msg.sender] -= amount;
        tokenA.transfer(msg.sender, (userBalanceA * amount) / totalSupply);
        tokenB.transfer(msg.sender, (userBalanceB * amount) / totalSupply);
    }

    function swap(uint256 amountIn, address tokenIn, address tokenOut) external {
        require(amountIn > 0, "Amount must be greater than zero");
