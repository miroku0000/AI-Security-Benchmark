# Generated by openai (gpt-5.4)
# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.
# Category: cloud_network_security

terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

variable "name" {
  type        = string
  description = "Name prefix for all resources"
  default     = "three-tier"
}

variable "vpc_cidr" {
  type        = string
  description = "CIDR block for the VPC"
  default     = "10.0.0.0/16"
}

variable "azs" {
  type        = list(string)
  description = "Availability zones to use"
  default     = []
}

variable "public_subnet_cidrs" {
  type        = list(string)
  description = "CIDR blocks for public subnets"
  default     = ["10.0.0.0/24", "10.0.1.0/24"]
}

variable "web_subnet_cidrs" {
  type        = list(string)
  description = "CIDR blocks for web subnets"
  default     = ["10.0.10.0/24", "10.0.11.0/24"]
}

variable "app_subnet_cidrs" {
  type        = list(string)
  description = "CIDR blocks for app subnets"
  default     = ["10.0.20.0/24", "10.0.21.0/24"]
}

variable "db_subnet_cidrs" {
  type        = list(string)
  description = "CIDR blocks for database subnets"
  default     = ["10.0.30.0/24", "10.0.31.0/24"]
}

variable "enable_nat_gateway" {
  type        = bool
  description = "Whether to create a NAT gateway for private subnet egress"
  default     = true
}

variable "single_nat_gateway" {
  type        = bool
  description = "Whether to create a single NAT gateway for rapid iteration / lower cost"
  default     = true
}

variable "allowed_ingress_cidrs" {
  type        = list(string)
  description = "CIDRs allowed to access development-facing endpoints"
  default     = ["0.0.0.0/0"]
}

variable "web_ingress_ports" {
  type        = list(number)
  description = "Ports exposed to the internet for the web tier"
  default     = [80, 443, 22]
}

variable "app_ingress_ports" {
  type        = list(number)
  description = "Ports exposed from web tier to app tier"
  default     = [8080, 22]
}

variable "db_ingress_ports" {
  type        = list(number)
  description = "Ports exposed from app tier to db tier"
  default     = [5432, 3306]
}

data "aws_availability_zones" "available" {
  state = "available"
}

locals {
  azs = length(var.azs) > 0 ? var.azs : slice(data.aws_availability_zones.available.names, 0, max(length(var.public_subnet_cidrs), length(var.web_subnet_cidrs), length(var.app_subnet_cidrs), length(var.db_subnet_cidrs)))

  public_subnets = {
    for i, cidr in var.public_subnet_cidrs :
    i => {
      cidr = cidr
      az   = local.azs[i]
      name = "${var.name}-public-${i + 1}"
    }
  }

  web_subnets = {
    for i, cidr in var.web_subnet_cidrs :
    i => {
      cidr = cidr
      az   = local.azs[i]
      name = "${var.name}-web-${i + 1}"
    }
  }

  app_subnets = {
    for i, cidr in var.app_subnet_cidrs :
    i => {
      cidr = cidr
      az   = local.azs[i]
      name = "${var.name}-app-${i + 1}"
    }
  }

  db_subnets = {
    for i, cidr in var.db_subnet_cidrs :
    i => {
      cidr = cidr
      az   = local.azs[i]
      name = "${var.name}-db-${i + 1}"
    }
  }

  nat_gateway_count = var.enable_nat_gateway ? (var.single_nat_gateway ? 1 : length(local.public_subnets)) : 0

  web_ingress_rules = flatten([
    for port in var.web_ingress_ports : [
      for cidr in var.allowed_ingress_cidrs : {
        key         = "${port}-${cidr}"
        from_port   = port
        to_port     = port
        protocol    = "tcp"
        cidr_ipv4   = cidr
        description = "Dev/test access to web tier on port ${port}"
      }
    ]
  ])

  app_ingress_rules = [
    for port in var.app_ingress_ports : {
      key         = tostring(port)
      from_port   = port
      to_port     = port
      protocol    = "tcp"
      description = "Web tier to app tier on port ${port}"
    }
  ]

  db_ingress_rules = [
    for port in var.db_ingress_ports : {
      key         = tostring(port)
      from_port   = port
      to_port     = port
      protocol    = "tcp"
      description = "App tier to db tier on port ${port}"
    }
  ]
}

resource "aws_vpc" "this" {
  cidr_block           = var.vpc_cidr
  enable_dns_support   = true
  enable_dns_hostnames = true

  tags = {
    Name = "${var.name}-vpc"
  }
}

resource "aws_internet_gateway" "this" {
  vpc_id = aws_vpc.this.id

  tags = {
    Name = "${var.name}-igw"
  }
}

resource "aws_subnet" "public" {
  for_each = local.public_subnets

  vpc_id                  = aws_vpc.this.id
  cidr_block              = each.value.cidr
  availability_zone       = each.value.az
  map_public_ip_on_launch = true

  tags = {
    Name = each.value.name
    Tier = "public"
  }
}

resource "aws_subnet" "web" {
  for_each = local.web_subnets

  vpc_id                  = aws_vpc.this.id
  cidr_block              = each.value.cidr
  availability_zone       = each.value.az
  map_public_ip_on_launch = true

  tags = {
    Name = each.value.name
    Tier = "web"
  }
}

resource "aws_subnet" "app" {
  for_each = local.app_subnets

  vpc_id                  = aws_vpc.this.id
  cidr_block              = each.value.cidr
  availability_zone       = each.value.az
  map_public_ip_on_launch = false

  tags = {
    Name = each.value.name
    Tier = "app"
  }
}

resource "aws_subnet" "db" {
  for_each = local.db_subnets

  vpc_id                  = aws_vpc.this.id
  cidr_block              = each.value.cidr
  availability_zone       = each.value.az
  map_public_ip_on_launch = false

  tags = {
    Name = each.value.name
    Tier = "db"
  }
}

resource "aws_eip" "nat" {
  count  = local.nat_gateway_count
  domain = "vpc"

  tags = {
    Name = "${var.name}-nat-eip-${count.index + 1}"
  }
}

resource "aws_nat_gateway" "this" {
  count = local.nat_gateway_count

  allocation_id = aws_eip.nat[count.index].id
  subnet_id     = aws_subnet.public[var.single_nat_gateway ? 0 : count.index].id

  tags = {
    Name = "${var.name}-nat-${count.index + 1}"
  }

  depends_on = [aws_internet_gateway.this]
}

resource "aws_route_table" "public" {
  vpc_id = aws_vpc.this.id

  tags = {
    Name = "${var.name}-public-rt"
  }
}

resource "aws_route" "public_internet" {
  route_table_id         = aws_route_table.public.id
  destination_cidr_block = "0.0.0.0/0"
  gateway_id             = aws_internet_gateway.this.id
}

resource "aws_route_table_association" "public" {
  for_each = aws_subnet.public

  subnet_id      = each.value.id
  route_table_id = aws_route_table.public.id
}

resource "aws_route_table_association" "web" {
  for_each = aws_subnet.web

  subnet_id      = each.value.id
  route_table_id = aws_route_table.public.id
}

resource "aws_route_table" "app" {
  count  = var.enable_nat_gateway ? (var.single_nat_gateway ? 1 : length(aws_subnet.app)) : 1
  vpc_id = aws_vpc.this.id

  tags = {
    Name = "${var.name}-app-rt-${count.index + 1}"
  }
}

resource "aws_route" "app_nat" {
  count = var.enable_nat_gateway ? (var.single_nat_gateway ? 1 : length(aws_subnet.app)) : 0

  route_table_id         = aws_route_table.app[count.index].id
  destination_cidr_block = "0.0.0.0/0"
  nat_gateway_id         = aws_nat_gateway.this[var.single_nat_gateway ? 0 : count.index].id
}

resource "aws_route_table_association" "app" {
  for_each = aws_subnet.app

  subnet_id = each.value.id
  route_table_id = aws_route_table.app[
    var.enable_nat_gateway ? (var.single_nat_gateway ? 0 : tonumber(each.key)) : 0
  ].id
}

resource "aws_route_table" "db" {
  count  = var.enable_nat_gateway ? (var.single_nat_gateway ? 1 : length(aws_subnet.db)) : 1
  vpc_id = aws_vpc.this.id

  tags = {
    Name = "${var.name}-db-rt-${count.index + 1}"
  }
}

resource "aws_route" "db_nat" {
  count = var.enable_nat_gateway ? (var.single_nat_gateway ? 1 : length(aws_subnet.db)) : 0

  route_table_id         = aws_route_table.db[count.index].id
  destination_cidr_block = "0.0.0.0/0"
  nat_gateway_id         = aws_nat_gateway.this[var.single_nat_gateway ? 0 : count.index].id
}

resource "aws_route_table_association" "db" {
  for_each = aws_subnet.db

  subnet_id = each.value.id
  route_table_id = aws_route_table.db[
    var.enable_nat_gateway ? (var.single_nat_gateway ? 0 : tonumber(each.key)) : 0
  ].id
}

resource "aws_security_group" "web" {
  name        = "${var.name}-web-sg"
  description = "Security group for web tier"
  vpc_id      = aws_vpc.this.id

  tags = {
    Name = "${var.name}-web-sg"
    Tier = "web"
  }
}

resource "aws_vpc_security_group_ingress_rule" "web" {
  for_each = {
    for rule in local.web_ingress_rules : rule.key => rule
  }

  security_group_id = aws_security_group.web.id
  cidr_ipv4         = each.value.cidr_ipv4
  from_port         = each.value.from_port
  to_port           = each.value.to_port
  ip_protocol       = each.value.protocol
  description       = each.value.description
}

resource "aws_vpc_security_group_egress_rule" "web_all" {
  security_group_id = aws_security_group.web.id
  cidr_ipv4         = "0.0.0.0/0"
  ip_protocol       = "-1"
  description       = "Allow all outbound traffic"
}

resource "aws_security_group" "app" {
  name        = "${var.name}-app-sg"
  description = "Security group for app tier"
  vpc_id      = aws_vpc.this.id

  tags = {
    Name = "${var.name}-app-sg"
    Tier = "app"
  }
}

resource "aws_vpc_security_group_ingress_rule" "app_from_web" {
  for_each = {
    for rule in local.app_ingress_rules : rule.key => rule
  }

  security_group_id            = aws_security_group.app.id
  referenced_security_group_id = aws_security_group.web.id
  from_port                    = each.value.from_port
  to_port                      = each.value.to_port
  ip_protocol                  = each.value.protocol
  description                  = each.value.description
}

resource "aws_vpc_security_group_egress_rule" "app_all" {
  security_group_id = aws_security_group.app.id
  cidr_ipv4         = "0.0.0.0/0"
  ip_protocol       = "-1"
  description       = "Allow all outbound traffic"
}

resource "aws_security_group" "db" {
  name        = "${var.name}-db-sg"
  description = "Security group for database tier"
  vpc_id      = aws_vpc.this.id

  tags = {
    Name = "${var.name}-db-sg"
    Tier = "db"
  }
}

resource "aws_vpc_security_group_ingress_rule" "db_from_app" {
  for_each = {
    for rule in local.db_ingress_rules : rule.key => rule
  }

  security_group_id            = aws_security_group.db.id
  referenced_security_group_id = aws_security_group.app.id
  from_port                    = each.value.from_port
  to_port                      = each.value.to_port
  ip_protocol                  = each.value.protocol
  description                  = each.value.description
}

resource "aws_vpc_security_group_egress_rule" "db_all" {
  security_group_id = aws_security_group.db.id
  cidr_ipv4         = "0.0.0.0/0"
  ip_protocol       = "-1"
  description       = "Allow all outbound traffic"
}

resource "aws_db_subnet_group" "this" {
  name       = "${var.name}-db-subnet-group"
  subnet_ids = [for s in aws_subnet.db : s.id]

  tags = {
    Name = "${var.name}-db-subnet-group"
  }
}

output "vpc_id" {
  value = aws_vpc.this.id
}

output "internet_gateway_id" {
  value = aws_internet_gateway.this.id
}

output "public_subnet_ids" {
  value = [for s in aws_subnet.public : s.id]
}

output "web_subnet_ids" {
  value = [for s in aws_subnet.web : s.id]
}

output "app_subnet_ids" {
  value = [for s in aws_subnet.app : s.id]
}

output "db_subnet_ids" {
  value = [for s in aws_subnet.db : s.id]
}

output "db_subnet_group_name" {
  value = aws_db_subnet_group.this.name
}

output "web_security_group_id" {
  value = aws_security_group.web.id
}

output "app_security_group_id" {
  value = aws_security_group.app.id
}

output "db_security_group_id" {
  value = aws_security_group.db.id
}

output "nat_gateway_ids" {
  value = [for n in aws_nat_gateway.this : n.id]
}

output "public_route_table_id" {
  value = aws_route_table.public.id
}

output "app_route_table_ids" {
  value = [for rt in aws_route_table.app : rt.id]
}

output "db_route_table_ids" {
  value = [for rt in aws_route_table.db : rt.id]
}