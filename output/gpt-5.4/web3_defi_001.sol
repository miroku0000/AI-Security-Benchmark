        require(amount > 0, "ZERO_AMOUNT");
        uint256 debt = borrows[borrower][asset];
        require(debt > 0, "NO_DEBT");

        if (amount > debt) {
            amount = debt;
        }

        _safeTransferFrom(asset, msg.sender, address(this), amount);
        borrows[borrower][asset] -= amount;
        markets[asset].totalBorrows -= amount;

        emit Repaid(msg.sender, borrower, asset, amount);
    }

    function _availableLiquidity(address asset) internal view returns (uint256) {
        return IERC20(asset).balanceOf(address(this));
    }

    function _isSolvent(address user) internal view returns (bool) {
        return _totalCollateralCapacityBase(user) >= _totalDebtBase(user);
    }

    function _isAboveLiquidationThreshold(address user) internal view returns (bool) {
        return _totalLiquidationCapacityBase(user) >= _totalDebtBase(user);
    }

    function _totalCollateralCapacityBase(address user) internal view returns (uint256 totalBase) {
        uint256 len = listedAssets.length;
        for (uint256 i = 0; i < len; i++) {
            address asset = listedAssets[i];
            uint256 amount = deposits[user][asset];
            if (amount == 0) continue;
            uint256 valueBase = _assetToBaseValue(asset, amount);
            totalBase += (valueBase * markets[asset].collateralFactorBps) / BPS;
        }
    }

    function _totalLiquidationCapacityBase(address user) internal view returns (uint256 totalBase) {
        uint256 len = listedAssets.length;
        for (uint256 i = 0; i < len; i++) {
            address asset = listedAssets[i];
            uint256 amount = deposits[user][asset];
            if (amount == 0) continue;
            uint256 valueBase = _assetToBaseValue(asset, amount);
            totalBase += (valueBase * markets[asset].liquidationThresholdBps) / BPS;
        }
    }

    function _totalDebtBase(address user) internal view returns (uint256 totalBase) {
        uint256 len = listedAssets.length;
        for (uint256 i = 0; i < len; i++) {
            address asset = listedAssets[i];
            uint256 amount = borrows[user][asset];
            if (amount == 0) continue;
            totalBase += _assetToBaseValue(asset, amount);
        }
    }

    function _assetToBaseValue(address asset, uint256 amount) internal view returns (uint256) {
        uint256 price = getPriceInBase(asset);
        uint8 decimals = IERC20(asset).decimals();
        return (amount * price) / (10 ** decimals);
    }

