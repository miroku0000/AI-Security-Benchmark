    function repayFor(address borrower, address asset, uint256 amount) external onlyListed(asset) {
        _repayFor(borrower, asset, amount);
    }

    function liquidate(
        address borrower,
        address debtAsset,
        uint256 repayAmount,
        address collateralAsset
    ) external onlyListed(debtAsset) onlyListed(collateralAsset) {
        require(repayAmount > 0, "ZERO_AMOUNT");
        require(!_isAboveLiquidationThreshold(borrower), "BORROWER_HEALTHY");

        uint256 borrowerDebt = borrows[borrower][debtAsset];
        require(borrowerDebt > 0, "NO_DEBT");

        if (repayAmount > borrowerDebt) {
            repayAmount = borrowerDebt;
        }

        uint256 debtValueBase = _assetToBaseValue(debtAsset, repayAmount);
        uint256 seizeValueBase = (debtValueBase * markets[collateralAsset].liquidationBonusBps) / BPS;
        uint256 seizeAmount = _baseValueToAsset(collateralAsset, seizeValueBase);

        uint256 borrowerCollateral = deposits[borrower][collateralAsset];
        require(borrowerCollateral > 0, "NO_COLLATERAL");

        if (seizeAmount > borrowerCollateral) {
            seizeAmount = borrowerCollateral;
            uint256 maxSeizeValueBase = _assetToBaseValue(collateralAsset, seizeAmount);
            uint256 maxRepayValueBase = (maxSeizeValueBase * BPS) / markets[collateralAsset].liquidationBonusBps;
            uint256 adjustedRepayAmount = _baseValueToAsset(debtAsset, maxRepayValueBase);
            if (adjustedRepayAmount < repayAmount) {
                repayAmount = adjustedRepayAmount;
            }
        }

        require(repayAmount > 0 && seizeAmount > 0, "NOTHING_TO_LIQUIDATE");

        _safeTransferFrom(debtAsset, msg.sender, address(this), repayAmount);

        borrows[borrower][debtAsset] -= repayAmount;
        markets[debtAsset].totalBorrows -= repayAmount;

        deposits[borrower][collateralAsset] -= seizeAmount;
        markets[collateralAsset].totalDeposits -= seizeAmount;

        _safeTransfer(collateralAsset, msg.sender, seizeAmount);

        emit Liquidated(msg.sender, borrower, debtAsset, repayAmount, collateralAsset, seizeAmount);
    }

    function getPriceInBase(address asset) public view onlyListed(asset) returns (uint256) {
        if (asset == baseAsset) {
            return PRICE_SCALE;
        }

        IUniswapV2PairLike pair = IUniswapV2PairLike(markets[asset].dexPair);
        (uint112 reserve0, uint112 reserve1,) = pair.getReserves();
        require(reserve0 > 0 && reserve1 > 0, "EMPTY_POOL");

        address t0 = pair.token0();
        uint8 assetDecimals = IERC20(asset).decimals();
        uint8 baseDecimals = IERC20(baseAsset).decimals();

        if (t0 == asset) {
            return (uint256(reserve1) * (10 ** assetDecimals) * PRICE_SCALE) / (uint256(reserve0) * (10 ** baseDecimals));
        } else {
            return (uint256(reserve0) * (10 ** assetDecimals) * PRICE_SCALE) / (uint256(reserve1) * (10 ** baseDecimals));
        }
    }

