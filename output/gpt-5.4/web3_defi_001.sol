        uint256 collateralCapacityBase = _totalCollateralCapacityBase(user);
        uint256 debtBase = _totalDebtBase(user);
        if (collateralCapacityBase <= debtBase) return 0;
        uint256 remainingBase = collateralCapacityBase - debtBase;
        return _baseValueToAsset(asset, remainingBase);
    }

    function availableLiquidity(address asset) external view onlyListed(asset) returns (uint256) {
        return _availableLiquidity(asset);
    }

