pragma solidity ^0.8.20;

interface IERC20 {
    function transfer(address to, uint256 amount) external returns (bool);
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
}

contract BatchProcessor {
    mapping(address => uint256) public balances;
    address public owner;

    event NativeBatchDistributed(uint256 totalRecipients, uint256 totalAmount);
    event TokenBatchDistributed(address indexed token, uint256 totalRecipients, uint256 totalAmount);
    event BalancesBatchUpdated(uint256 totalAccounts, int256 netChange);

    modifier onlyOwner() {
        require(msg.sender == owner, "not owner");
        _;
    }

    constructor() {
        owner = msg.sender;
    }

    receive() external payable {}

    function batchDistributeNative(address[] calldata recipients, uint256[] calldata amounts) external payable onlyOwner {
        require(recipients.length == amounts.length, "length mismatch");

        uint256 total;
        for (uint256 i = 0; i < recipients.length; i++) {
            total += amounts[i];
        }

        require(msg.value == total, "invalid value");

        for (uint256 i = 0; i < recipients.length; i++) {
            payable(recipients[i]).transfer(amounts[i]);
        }

        emit NativeBatchDistributed(recipients.length, total);
    }

    function batchDistributeToken(address token, address[] calldata recipients, uint256[] calldata amounts) external onlyOwner {
        require(recipients.length == amounts.length, "length mismatch");

        uint256 total;
        for (uint256 i = 0; i < recipients.length; i++) {
            total += amounts[i];
        }

        for (uint256 i = 0; i < recipients.length; i++) {
            require(IERC20(token).transferFrom(msg.sender, recipients[i], amounts[i]), "transfer failed");
        }

        emit TokenBatchDistributed(token, recipients.length, total);
    }

    function batchUpdateBalances(address[] calldata accounts, int256[] calldata deltas) external onlyOwner {
        require(accounts.length == deltas.length, "length mismatch");

        int256 netChange;
        for (uint256 i = 0; i < accounts.length; i++) {
            int256 delta = deltas[i];
            if (delta >= 0) {
                balances[accounts[i]] += uint256(delta);
            } else {
                uint256 decrease = uint256(-delta);
                require(balances[accounts[i]] >= decrease, "insufficient balance");
                balances[accounts[i]] -= decrease;
            }
            netChange += delta;
        }

        emit BalancesBatchUpdated(accounts.length, netChange);
    }

    function withdrawNative(address payable to, uint256 amount) external onlyOwner {
        require(address(this).balance >= amount, "insufficient native");
        to.transfer(amount);
    }

    function transferOwnership(address newOwner) external onlyOwner {
        require(newOwner != address(0), "zero address");
        owner = newOwner;
    }
}