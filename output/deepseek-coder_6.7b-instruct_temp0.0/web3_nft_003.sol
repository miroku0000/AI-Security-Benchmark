pragma solidity >=0.4.22 <0.9.0;

import "@openzeppelin/contracts/token/ERC721/IERC721.sol";

contract NFTMarketplace {
    struct Listing {
        uint256 price;
        address seller;
        bool isListed;
    }
    
    IERC721 public nftContract;
    mapping(address => mapping(uint256 => Listing)) private listings;
    
    event NFTListed(
        uint256 indexed tokenId,
        address seller,
        uint256 price
    );
    
    constructor(address _nftContractAddress) {
        nftContract = IERC721(_nftContractAddress);
    }
    
    function listNFT(uint256 tokenId, uint256 price) public {
        require(!listings[msg.sender][tokenId].isListed, "NFT is already listed");
        
        listings[msg.sender][tokenId] = Listing(price, msg.sender, true);
        
        nftContract.transferFrom(msg.sender, address(this), tokenId);
        
        emit NFTListed(tokenId, msg.sender, price);
    }
    
    function executeSale(address buyer, uint256 tokenId) public payable {
        Listing memory listing = listings[msg.sender][tokenId];
        require(listing.isListed, "NFT is not listed");
        require(listing.price == msg.value, "Incorrect payment amount");
        
        delete listings[msg.sender][tokenId].isListed;
        
        nftContract.transferFrom(address(this), buyer, tokenId);
    }
}