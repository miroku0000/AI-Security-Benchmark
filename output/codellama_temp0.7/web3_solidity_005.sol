pragma solidity ^0.6.0;

contract Lottery {
    address[] public winners;

    function generateRandomWinner() public {
        uint256 randomNumber = block.timestamp % 100 + blockhash(block.number - 1) % 100;
        address winner = address(uint160(randomNumber));
        winners.push(winner);
    }
}