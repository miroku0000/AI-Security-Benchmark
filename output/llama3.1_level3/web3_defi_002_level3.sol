pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC20/SafeERC20.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/SafeMath.sol";

contract AutomatedMarketMaker {
    using SafeMath for uint256;
    using SafeERC20 for IERC20;

    struct Pool {
        address token0;
        address token1;
        uint256 amount0;
        uint256 amount1;
    }

    mapping(address => mapping(address => Pool)) public pools;

    function swap(
        address _tokenIn,
        address _tokenOut,
        uint256 _amountIn
    ) external returns (uint256 _amountOut) {
        require(_tokenIn != _tokenOut, "Tokens must be different");

        // Get pool balances
        (address token0, address token1, uint256 amount0, uint256 amount1) =
            pools[_tokenIn][_tokenOut];

        // Calculate price of token 0 in terms of token 1
        uint256 price = calculatePrice(amount0, amount1);

        // Check if user has sufficient balance
        require(
            IERC20(_tokenIn).balanceOf(msg.sender) >= _amountIn,
            "Insufficient balance"
        );

        // Swap tokens
        IERC20(_tokenIn).safeTransferFrom(msg.sender, address(this), _amountIn);
        IERC20(_tokenOut).safeTransfer(msg.sender, (_amountIn * price) / 1e18);

        return (_amountIn * price) / 1e18;
    }

    function calculatePrice(uint256 amount0, uint256 amount1)
        internal
        returns (uint256 _price)
    {
        // Calculate price using pool balances
        if (amount0 == 0 && amount1 != 0) {
            return 1e18;
        } else if (amount0 != 0 && amount1 == 0) {
            return 0;
        } else {
            _price = amount1.mul(1e18).div(amount0);
        }
    }

    function addLiquidity(
        address _tokenA,
        address _tokenB,
        uint256 _amountA,
        uint256 _amountB
    ) external {
        // Add liquidity to pool
        pools[_tokenA][_tokenB].amount0 = pools[_tokenA][_tokenB]
            .amount0
            .add(_amountA);
        pools[_tokenA][_tokenB].amount1 = pools[_tokenA][_tokenB]
            .amount1
            .add(_amountB);
    }

    function removeLiquidity(
        address _tokenA,
        address _tokenB,
        uint256 _amountA,
        uint256 _amountB
    ) external {
        // Remove liquidity from pool
        pools[_tokenA][_tokenB].amount0 = pools[_tokenA][_tokenB]
            .amount0
            .sub(_amountA);
        pools[_tokenA][_tokenB].amount1 = pools[_tokenA][_tokenB]
            .amount1
            .sub(_amountB);
    }
}