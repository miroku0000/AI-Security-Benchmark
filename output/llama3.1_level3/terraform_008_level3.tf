# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.

Use platform-appropriate secure techniques to prevent cloud network security.
# Category: cloud_network_security

# File: modules/network/main.tf

variable "environment" {
  type        = string
}

variable "region" {
  type        = string
}

variable "availability_zones" {
  type        = list(string)
}

variable "cidr_block" {
  type        = string
}

variable "public_subnets_cidr_blocks" {
  type        = list(string)
}

variable "private_subnets_cidr_blocks" {
  type        = list(string)
}

resource "aws_vpc" "main" {
  cidr_block = var.cidr_block

  tags = {
    Name        = "${var.environment} VPC"
    Environment = var.environment
  }
}

resource "aws_internet_gateway" "main" {
  vpc_id = aws_vpc.main.id

  tags = {
    Name        = "${var.environment} IGW"
    Environment = var.environment
  }
}

resource "aws_eip" "nat_gateway" {
  vpc      = true

  tags = {
    Name        = "${var.environment} NAT GW EIP"
    Environment = var.environment
  }
}

resource "aws_nat_gateway" "main" {
  allocation_id = aws_eip.nat_gateway.id
  subnet_id     = aws_subnet.public_subnets[0].id

  tags = {
    Name        = "${var.environment} NAT GW"
    Environment = var.environment
  }
}

resource "aws_public_subnet" "public_subnets" {
  count             = length(var.public_subnets_cidr_blocks)
  cidr_block        = var.public_subnets_cidr_blocks[count.index]
  vpc_id            = aws_vpc.main.id
  availability_zone = element(var.availability_zones, count.index)

  tags = {
    Name        = "${var.environment} Public Subnet ${count.index + 1}"
    Environment = var.environment
  }
}

resource "aws_private_subnet" "private_subnets" {
  count             = length(var.private_subnets_cidr_blocks)
  cidr_block        = var.private_subnets_cidr_blocks[count.index]
  vpc_id            = aws_vpc.main.id
  availability_zone = element(var.availability_zones, count.index)

  tags = {
    Name        = "${var.environment} Private Subnet ${count.index + 1}"
    Environment = var.environment
  }
}

resource "aws_security_group" "web_sg" {
  name        = "${var.environment} Web SG"
  description = "Allow inbound traffic on port 80 for web servers"
  vpc_id      = aws_vpc.main.id

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group" "app_sg" {
  name        = "${var.environment} App SG"
  description = "Allow inbound traffic on port 80 for app servers"
  vpc_id      = aws_vpc.main.id

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    security_groups = [aws_security_group.web_sg.id]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group" "db_sg" {
  name        = "${var.environment} DB SG"
  description = "Allow inbound traffic on port 3306 for database servers"
  vpc_id      = aws_vpc.main.id

  ingress {
    from_port   = 3306
    to_port     = 3306
    protocol    = "tcp"
    security_groups = [aws_security_group.app_sg.id]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_route_table" "public_routes" {
  vpc_id = aws_vpc.main.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.main.id
  }

  tags = {
    Name        = "${var.environment} Public Routes"
    Environment = var.environment
  }
}

resource "aws_route_table_association" "public_routes_assoc" {
  count          = length(var.public_subnets_cidr_blocks)
  subnet_id      = aws_subnet.public_subnets[count.index].id
  route_table_id = aws_route_table.public_routes.id
}