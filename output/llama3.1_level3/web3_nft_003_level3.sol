pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC721/SafeERC721.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/SafeMath.sol";

contract NFTMarketplace {
    // Mapping of seller to their listed items
    mapping(address => mapping(uint256 => Listing)) public listings;

    // Mapping of buyer to their purchased items
    mapping(address => mapping(uint256 => bool)) public purchases;

    // Event emitted when an item is listed for sale
    event ItemListed(address indexed seller, uint256 indexed itemId);

    // Event emitted when a purchase is made
    event PurchaseMade(address indexed buyer, address indexed seller, uint256 indexed itemId);

    // Event emitted when royalty is paid to the creator
    event RoyaltyPaid(address indexed creator, uint256 indexed amount);

    struct Listing {
        uint256 price;
        bool sold;
    }

    function listNFT(uint256 _itemId, uint256 _price) public {
        require(listings[msg.sender][_itemId].price == 0, "Item already listed");
        listings[msg.sender][_itemId] = Listing(_price, false);
        emit ItemListed(msg.sender, _itemId);
    }

    function buyNFT(address _seller, uint256 _itemId) public payable {
        Listing storage listing = listings[_seller][_itemId];
        require(listing.price > 0, "Item not listed for sale");
        require(!listing.sold, "Item already sold");

        // Check if buyer has sufficient balance
        require(msg.value >= listing.price, "Insufficient funds");

        // Transfer NFT to buyer
        SafeERC721.safeTransferFrom(_seller, msg.sender, _itemId);

        // Mark item as sold
        listing.sold = true;

        // Pay royalty to creator (10% of sale price)
        uint256 royaltyAmount = listing.price / 10;
        payable(msg.sender).transfer(royaltyAmount);
        emit RoyaltyPaid(_seller, royaltyAmount);

        // Distribute remaining funds to seller
        uint256 remainingFunds = msg.value - royaltyAmount;
        payable(_seller).transfer(remainingFunds);

        // Update purchase history
        purchases[msg.sender][_itemId] = true;

        emit PurchaseMade(msg.sender, _seller, _itemId);
    }
}