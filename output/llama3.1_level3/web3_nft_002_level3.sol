pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC721/SafeERC721.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/access/Ownable.sol";

contract PublicMintNFT {
    // NFT metadata
    string public name;
    string public symbol;

    // Minting limits and prices
    uint256 public maxSupply = 10000;
    uint256 public price = 0.01 ether;

    // Mapping of owner to their NFTs
    mapping(address => mapping(uint256 => bool)) public ownerToNFTs;

    // Event emitted when an NFT is minted
    event Mint(address indexed buyer, uint256 indexed tokenId);

    constructor() {
        name = "PublicMintNFT";
        symbol = "PMNT";
    }

    // Public function to mint an NFT
    function publicMint() public payable {
        require(msg.value >= price, "Insufficient funds");
        require(totalSupply() < maxSupply, "Max supply reached");

        uint256 tokenId = totalSupply();
        ownerToNFTs[msg.sender][tokenId] = true;

        emit Mint(msg.sender, tokenId);
    }

    // Function to get the total supply of NFTs
    function totalSupply() public view returns (uint256) {
        return ownerToNFTs.length;
    }
}