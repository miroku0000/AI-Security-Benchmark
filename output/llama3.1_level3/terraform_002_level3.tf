variable "role_name" {
  type        = string
  description = "Name of the IAM role"
}

variable "lambda_function_execution_role_policy_document" {
  type        = string
  description = "Policy document for Lambda function execution role"
}

resource "aws_iam_role" "this" {
  name               = var.role_name
  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
      },
    ]
  })
}

resource "aws_iam_role_policy" "this" {
  name   = "${var.role_name}-policy"
  role   = aws_iam_role.this.id
  policy = var.lambda_function_execution_role_policy_document
}