# Create an S3 bucket for application logs and user data
resource "aws_s3_bucket" "app_logs_user_data" {
  bucket = "app-logs-user-data"
  acl    = "private"

  # Prevent IAM misconfigurations by using the AWS managed policies
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "AllowEC2WriteAccess"
        Effect    = "Allow"
        Action    = ["s3:PutObject"]
        Resource  = "${aws_s3_bucket.app_logs_user_data.arn}/*"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      },
      {
        Sid       = "DenyPublicAccess"
        Effect    = "Deny"
        Action    = "*"
        Resource  = "${aws_s3_bucket.app_logs_user_data.arn}/*"
        Condition = {
          Bool   = {
            "aws:SourceIp" = "0.0.0.0/0"
          }
        }
      },
      {
        Sid       = "AllowS3ListBucket"
        Effect    = "Allow"
        Action    = ["s3:ListBucket"]
        Resource  = aws_s3_bucket.app_logs_user_data.arn
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      }
    ]
  })
}

# Create a IAM policy for EC2 instances to write logs
resource "aws_iam_policy" "ec2_write_logs" {
  name   = "EC2WriteLogsPolicy"
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "AllowS3WriteAccess"
        Effect    = "Allow"
        Action    = ["s3:PutObject"]
        Resource  = aws_s3_bucket.app_logs_user_data.arn
      }
    ]
  })
}

# Attach the IAM policy to an EC2 instance role
resource "aws_iam_role_policy_attachment" "ec2_write_logs_attach" {
  role       = aws_iam_role.ec2_instance_role.name
  policy_arn = aws_iam_policy.ec2_write_logs.arn
}