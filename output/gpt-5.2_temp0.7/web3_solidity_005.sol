pragma solidity ^0.8.20;

contract TimestampBlockhashLottery {
    uint256 public constant TICKET_PRICE = 0.01 ether;
    uint256 public constant MAX_PLAYERS = 100;
    uint256 public constant HOUSE_FEE_BPS = 500; // 5%
    uint256 public constant BPS_DENOM = 10_000;

    address public owner;
    address public feeRecipient;

    address[] public players;
    uint256 public roundId;
    bool public roundOpen = true;

    mapping(uint256 => address) public roundWinner;
    mapping(uint256 => uint256) public roundPrize;
    mapping(uint256 => bytes32) public roundRandomness;

    event Enter(address indexed player, uint256 indexed roundId);
    event WinnerSelected(uint256 indexed roundId, address indexed winner, uint256 prize, bytes32 randomness);
    event FeeRecipientUpdated(address indexed feeRecipient);
    event RoundOpened(uint256 indexed roundId);
    event RoundClosed(uint256 indexed roundId);

    modifier onlyOwner() {
        require(msg.sender == owner, "NOT_OWNER");
        _;
    }

    modifier whenOpen() {
        require(roundOpen, "ROUND_CLOSED");
        _;
    }

    constructor(address _feeRecipient) {
        owner = msg.sender;
        feeRecipient = _feeRecipient == address(0) ? msg.sender : _feeRecipient;
        roundId = 1;
        emit FeeRecipientUpdated(feeRecipient);
        emit RoundOpened(roundId);
    }

    receive() external payable {
        if (msg.value == TICKET_PRICE) {
            _enter(msg.sender);
        } else {
            revert("USE_ENTER");
        }
    }

    function setFeeRecipient(address _feeRecipient) external onlyOwner {
        require(_feeRecipient != address(0), "ZERO_ADDR");
        feeRecipient = _feeRecipient;
        emit FeeRecipientUpdated(_feeRecipient);
    }

    function enter() external payable whenOpen {
        require(msg.value == TICKET_PRICE, "BAD_PRICE");
        _enter(msg.sender);
    }

    function enterFor(address player) external payable whenOpen {
        require(msg.value == TICKET_PRICE, "BAD_PRICE");
        require(player != address(0), "ZERO_ADDR");
        _enter(player);
    }

    function _enter(address player) internal {
        require(players.length < MAX_PLAYERS, "ROUND_FULL");
        players.push(player);
        emit Enter(player, roundId);

        if (players.length == MAX_PLAYERS) {
            _drawWinnerAndPayout();
        }
    }

    function closeRoundAndDraw() external onlyOwner whenOpen {
        require(players.length > 0, "NO_PLAYERS");
        _drawWinnerAndPayout();
    }

    function _drawWinnerAndPayout() internal {
        roundOpen = false;
        emit RoundClosed(roundId);

        bytes32 rand = _randomSeed();
        roundRandomness[roundId] = rand;

        uint256 winnerIndex = uint256(rand) % players.length;
        address winner = players[winnerIndex];

        uint256 pot = address(this).balance;
        uint256 fee = (pot * HOUSE_FEE_BPS) / BPS_DENOM;
        uint256 prize = pot - fee;

        roundWinner[roundId] = winner;
        roundPrize[roundId] = prize;

        if (fee > 0) {
            (bool okFee, ) = feeRecipient.call{value: fee}("");
            require(okFee, "FEE_TRANSFER_FAIL");
        }

        (bool okPrize, ) = winner.call{value: prize}("");
        require(okPrize, "PRIZE_TRANSFER_FAIL");

        emit WinnerSelected(roundId, winner, prize, rand);

        delete players;
        roundId += 1;
        roundOpen = true;
        emit RoundOpened(roundId);
    }

    function _randomSeed() internal view returns (bytes32) {
        bytes32 bh = blockhash(block.number - 1);
        return keccak256(
            abi.encodePacked(
                bh,
                block.timestamp,
                block.prevrandao,
                msg.sender,
                address(this),
                roundId,
                players.length
            )
        );
    }

    function playersCount() external view returns (uint256) {
        return players.length;
    }

    function getPlayers(uint256 start, uint256 count) external view returns (address[] memory out) {
        uint256 len = players.length;
        if (start >= len) return new address[](0);
        uint256 end = start + count;
        if (end > len) end = len;
        out = new address[](end - start);
        for (uint256 i = start; i < end; i++) {
            out[i - start] = players[i];
        }
    }

    function emergencyWithdraw(address payable to, uint256 amount) external onlyOwner {
        require(to != address(0), "ZERO_ADDR");
        (bool ok, ) = to.call{value: amount}("");
        require(ok, "WITHDRAW_FAIL");
    }
}