interface IUniswapV2Pair {
    function token0() external view returns (address);
    function token1() external view returns (address);
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
}

contract DexPriceLending {
    using SafeERC20 for IERC20;

    struct Market {
        bool listed;
        IERC20 asset;
        IERC20 collateral;
        address pricePair; // UniswapV2-style pair for (asset, collateral)
        uint16 collateralFactorBps; // e.g. 7500 = 75%
        uint16 liquidationThresholdBps; // e.g. 8500 = 85%
        uint16 liquidationBonusBps; // e.g. 10500 = 5% bonus (10000=0%)
        uint16 reserveFactorBps; // e.g. 1000 = 10% of interest to reserves
        uint64 lastAccrual;
        uint256 borrowIndexRay; // 1e27
        uint256 totalBorrows; // asset amount
        uint256 totalReserves; // asset amount
        uint256 totalSupplyShares; // shares for suppliers
        uint256 cash; // tracked cash (asset in contract)
        uint256 borrowRatePerSecondRay; // simple fixed borrow rate, ray
    }

    struct Account {
        uint256 collateralAmount; // collateral token amount
        uint256 supplyShares; // shares
        uint256 borrowPrincipal; // scaled by borrowIndex
        uint256 borrowIndexRaySnapshot;
    }

    address public owner;
    uint256 public constant RAY = 1e27;
    uint256 public constant WAD = 1e18;
    uint256 public constant BPS = 10000;

    mapping(bytes32 => Market) public markets;
    mapping(bytes32 => mapping(address => Account)) public accounts;

    event MarketListed(bytes32 indexed marketId, address asset, address collateral, address pricePair);
    event ParamsUpdated(bytes32 indexed marketId);
    event Supply(bytes32 indexed marketId, address indexed user, uint256 amount, uint256 shares);
    event Withdraw(bytes32 indexed marketId, address indexed user, uint256 amount, uint256 shares);
    event DepositCollateral(bytes32 indexed marketId, address indexed user, uint256 amount);
    event WithdrawCollateral(bytes32 indexed marketId, address indexed user, uint256 amount);
    event Borrow(bytes32 indexed marketId, address indexed user, uint256 amount);
    event Repay(bytes32 indexed marketId, address indexed user, uint256 amount);
    event Liquidate(bytes32 indexed marketId, address indexed liquidator, address indexed user, uint256 repayAmount, uint256 seizeCollateral);

    modifier onlyOwner() {
        require(msg.sender == owner, "NOT_OWNER");
        _;
    }

    constructor() {
        owner = msg.sender;
    }

    function _id(address asset, address collateral) internal pure returns (bytes32) {
        return keccak256(abi.encodePacked(asset, collateral));
    }

    function listMarket(
        address asset,
        address collateral,
        address pricePair,
        uint16 collateralFactorBps,
        uint16 liquidationThresholdBps,
        uint16 liquidationBonusBps,
        uint16 reserveFactorBps,
        uint256 borrowRatePerSecondRay
    ) external onlyOwner {
        require(asset != address(0) && collateral != address(0) && pricePair != address(0), "BAD_ADDR");
        require(collateralFactorBps > 0 && collateralFactorBps <= BPS, "BAD_CF");
        require(liquidationThresholdBps >= collateralFactorBps && liquidationThresholdBps <= BPS, "BAD_LT");
        require(liquidationBonusBps >= BPS && liquidationBonusBps <= 13000, "BAD_LB");
        require(reserveFactorBps <= 5000, "BAD_RF");
        require(borrowRatePerSecondRay <= 5e22, "RATE_TOO_HIGH"); // ~0.005%/s cap

        bytes32 marketId = _id(asset, collateral);
        Market storage m = markets[marketId];
        require(!m.listed, "ALREADY_LISTED");

        m.listed = true;
        m.asset = IERC20(asset);
        m.collateral = IERC20(collateral);
        m.pricePair = pricePair;
        m.collateralFactorBps = collateralFactorBps;
        m.liquidationThresholdBps = liquidationThresholdBps;
        m.liquidationBonusBps = liquidationBonusBps;
        m.reserveFactorBps = reserveFactorBps;
        m.lastAccrual = uint64(block.timestamp);
        m.borrowIndexRay = RAY;
        m.borrowRatePerSecondRay = borrowRatePerSecondRay;

        emit MarketListed(marketId, asset, collateral, pricePair);
    }

    function setParams(
        address asset,
        address collateral,
        address pricePair,
        uint16 collateralFactorBps,
        uint16 liquidationThresholdBps,
        uint16 liquidationBonusBps,
        uint16 reserveFactorBps,
        uint256 borrowRatePerSecondRay
    ) external onlyOwner {
        bytes32 marketId = _id(asset, collateral);
        Market storage m = markets[marketId];
        require(m.listed, "NOT_LISTED");
        _accrue(marketId);

        require(pricePair != address(0), "BAD_PAIR");
        require(collateralFactorBps > 0 && collateralFactorBps <= BPS, "BAD_CF");
        require(liquidationThresholdBps >= collateralFactorBps && liquidationThresholdBps <= BPS, "BAD_LT");
        require(liquidationBonusBps >= BPS && liquidationBonusBps <= 13000, "BAD_LB");
        require(reserveFactorBps <= 5000, "BAD_RF");
        require(borrowRatePerSecondRay <= 5e22, "RATE_TOO_HIGH");

        m.pricePair = pricePair;
        m.collateralFactorBps = collateralFactorBps;
        m.liquidationThresholdBps = liquidationThresholdBps;
        m.liquidationBonusBps = liquidationBonusBps;
        m.reserveFactorBps = reserveFactorBps;
        m.borrowRatePerSecondRay = borrowRatePerSecondRay;

        emit ParamsUpdated(marketId);
    }

    function _accrue(bytes32 marketId) internal {
        Market storage m = markets[marketId];
        if (!m.listed) return;

        uint256 t0 = uint256(m.lastAccrual);
        uint256 t1 = block.timestamp;
        if (t1 <= t0) return;

        uint256 dt = t1 - t0;
        m.lastAccrual = uint64(t1);

        if (m.totalBorrows == 0) {
            return;
        }

        uint256 simpleInterestRay = (m.borrowRatePerSecondRay * dt);
        uint256 interest = (m.totalBorrows * simpleInterestRay) / RAY;

        uint256 toReserves = (interest * m.reserveFactorBps) / BPS;
        m.totalReserves += toReserves;
        m.totalBorrows += interest;

        m.borrowIndexRay = m.borrowIndexRay + (m.borrowIndexRay * simpleInterestRay) / RAY;
    }

    function accrue(address asset, address collateral) external {
        _accrue(_id(asset, collateral));
    }

    function _assetDecimals(Market storage m) internal view returns (uint8) {
        try m.asset.decimals() returns (uint8 d) { return d; } catch { return 18; }
    }

    function _collateralDecimals(Market storage m) internal view returns (uint8) {
        try m.collateral.decimals() returns (uint8 d) { return d; } catch { return 18; }
    }

    function _pow10(uint8 d) internal pure returns (uint256) {
        return 10 ** uint256(d);
    }

    function _getReserves(address pair) internal view returns (uint256 r0, uint256 r1) {
        (uint112 _r0, uint112 _r1,) = IUniswapV2Pair(pair).getReserves();
        r0 = uint256(_r0);
        r1 = uint256(_r1);
        require(r0 > 0 && r1 > 0, "NO_LIQUIDITY");
    }

    function getPriceCollateralPerAsset(address asset, address collateral) public view returns (uint256 priceRay) {
        bytes32 marketId = _id(asset, collateral);
        Market storage m = markets[marketId];
        require(m.listed, "NOT_LISTED");

        address pair = m.pricePair;
        address t0 = IUniswapV2Pair(pair).token0();
        address t1 = IUniswapV2Pair(pair).token1();
        require((t0 == asset && t1 == collateral) || (t0 == collateral && t1 == asset), "PAIR_MISMATCH");

        (uint256 r0, uint256 r1) = _getReserves(pair);

        uint8 aDec = _assetDecimals(m);
        uint8 cDec = _collateralDecimals(m);

        if (t0 == asset) {
            // price = (reserveCollateral / 10^cDec) / (reserveAsset / 10^aDec)
            // => priceRay = reserveCollateral * 10^aDec / (reserveAsset * 10^cDec) in ray
            priceRay = (r1 * _pow10(aDec) * RAY) / (r0 * _pow10(cDec));
        } else {
            priceRay = (r0 * _pow10(aDec) * RAY) / (r1 * _pow10(cDec));
        }
        require(priceRay > 0, "BAD_PRICE");
    }

    function _totalAssets(Market storage m) internal view returns (uint256) {
        return m.cash + m.totalBorrows - m.totalReserves;
    }

    function exchangeRateRay(address asset, address collateral) public view returns (uint256) {
        bytes32 marketId = _id(asset, collateral);
        Market storage m = markets[marketId];
        require(m.listed, "NOT_LISTED");
        if (m.totalSupplyShares == 0) return RAY;
        uint256 ta = _totalAssets(m);
        return (ta * RAY) / m.totalSupplyShares;
    }

    function _borrowBalanceCurrent(bytes32 marketId, address user) internal view returns (uint256) {
        Market storage m = markets[marketId];
        Account storage a = accounts[marketId][user];
        if (a.borrowPrincipal == 0) return 0;
        uint256 idx = m.borrowIndexRay;
        uint256 snap = a.borrowIndexRaySnapshot;
        if (snap == 0) return 0;
        return (a.borrowPrincipal * idx) / snap;
    }

    function borrowBalanceCurrent(address asset, address collateral, address user) external view returns (uint256) {
        bytes32 marketId = _id(asset, collateral);
        Market storage m = markets[marketId];
        require(m.listed, "NOT_LISTED");
        return _borrowBalanceCurrent(marketId, user);
    }

    function accountLiquidity(address asset, address collateral, address user) external view returns (uint256 collateralValueInAsset, uint256 borrowValueInAsset, bool healthyCF, bool healthyLT) {
        bytes32 marketId = _id(asset, collateral);
        Market storage m = markets[marketId];
        require(m.listed, "NOT_LISTED");

        uint256 priceRay = getPriceCollateralPerAsset(asset, collateral);
        Account storage a = accounts[marketId][user];
        uint256 bor = _borrowBalanceCurrent(marketId, user);

        // collateral value in asset units:
        // collateralAmount (coll) / price(coll per asset) => asset
        // asset = coll * RAY / priceRay
        uint256 collAsAsset = (a.collateralAmount * RAY) / priceRay;

        collateralValueInAsset = collAsAsset;
        borrowValueInAsset = bor;

        uint256 maxBorrowCF = (collAsAsset * m.collateralFactorBps) / BPS;
        uint256 maxBorrowLT = (collAsAsset * m.liquidationThresholdBps) / BPS;

        healthyCF = bor <= maxBorrowCF;
        healthyLT = bor <= maxBorrowLT;
    }

    function supply(address asset, address collateral, uint256 amount) external returns (uint256 shares) {
        require(amount > 0, "AMOUNT_0");
        bytes32 marketId = _id(asset, collateral);
        Market storage m = markets[marketId];
        require(m.listed, "NOT_LISTED");
        _accrue(marketId);

        uint256 exRay = m.totalSupplyShares == 0 ? RAY : ( _totalAssets(m) * RAY ) / m.totalSupplyShares;
        shares = (amount * RAY) / exRay;
        require(shares > 0, "SHARES_0");

        m.totalSupplyShares += shares;
        accounts[marketId][msg.sender].supplyShares += shares;

        m.asset.safeTransferFrom(msg.sender, address(this), amount);
        m.cash += amount;

        emit Supply(marketId, msg.sender, amount, shares);
    }

    function withdraw(address asset, address collateral, uint256 shares) external returns (uint256 amount) {
        require(shares > 0, "SHARES_0");
        bytes32 marketId = _id(asset, collateral);
        Market storage m = markets[marketId];
        require(m.listed, "NOT_LISTED");
        _accrue(marketId);

        Account storage a = accounts[marketId][msg.sender];
        require(a.supplyShares >= shares, "INSUFFICIENT_SHARES");

        uint256 exRay = ( _totalAssets(m) * RAY ) / m.totalSupplyShares;
        amount = (shares * exRay) / RAY;
        require(amount > 0, "AMOUNT_0");
        require(m.cash >= amount, "INSUFFICIENT_CASH");

        a.supplyShares -= shares;
        m.totalSupplyShares -= shares;

        m.cash -= amount;
        m.asset.safeTransfer(msg.sender, amount);

        emit Withdraw(marketId, msg.sender, amount, shares);
    }

    function depositCollateral(address asset, address collateral, uint256 amount) external {
        require(amount > 0, "AMOUNT_0");
        bytes32 marketId = _id(asset, collateral);
        Market storage m = markets[marketId];
        require(m.listed, "NOT_LISTED");

        m.collateral.safeTransferFrom(msg.sender, address(this), amount);
        accounts[marketId][msg.sender].collateralAmount += amount;

        emit DepositCollateral(marketId, msg.sender, amount);
    }

    function withdrawCollateral(address asset, address collateral, uint256 amount) external {
        require(amount > 0, "AMOUNT_0");
        bytes32 marketId = _id(asset, collateral);
        Market storage m = markets[marketId];
        require(m.listed, "NOT_LISTED");
        _accrue(marketId);

        Account storage a = accounts[marketId][msg.sender];
        require(a.collateralAmount >= amount, "INSUFFICIENT_COLLATERAL");

        a.collateralAmount -= amount;

        require(_isHealthyAfter(marketId, msg.sender), "WOULD_UNDERCOLLATERALIZE");

        m.collateral.safeTransfer(msg.sender, amount);
        emit WithdrawCollateral(marketId, msg.sender, amount);
    }

    function borrow(address asset, address collateral, uint256 amount) external {
        require(amount > 0, "AMOUNT_0");
        bytes32 marketId = _id(asset, collateral);
        Market storage m = markets[marketId];
        require(m.listed, "NOT_LISTED");
        _accrue(marketId);

        require(m.cash >= amount, "INSUFFICIENT_CASH");

        Account storage a = accounts[marketId][msg.sender];
        uint256 currentBorrow = _borrowBalanceCurrent(marketId, msg.sender);
        uint256 newBorrow = currentBorrow + amount;

        // Check collateral factor
        uint256 priceRay = getPriceCollateralPerAsset(asset, collateral);
        uint256 collAsAsset = (a.collateralAmount * RAY) / priceRay;
        uint256 maxBorrow = (collAsAsset * m.collateralFactorBps) / BPS;
        require(newBorrow <= maxBorrow, "INSUFFICIENT_COLLATERAL");

        // Update borrow principal to match newBorrow at current index
        a.borrowPrincipal = (newBorrow * a.borrowIndexRaySnapshot) / a.borrowIndexRaySnapshot; // placeholder to silence
        // Properly set principal in terms of current index
        a.borrowPrincipal = (newBorrow * RAY) / ((m.borrowIndexRay * RAY) / RAY); // simplify
        a.borrowPrincipal = (newBorrow * RAY) / m.borrowIndexRay;
        a.borrowIndexRaySnapshot = m.borrowIndexRay;

        m.totalBorrows += amount;
        m.cash -= amount;

        m.asset.safeTransfer(msg.sender, amount);
        emit Borrow(marketId, msg.sender, amount);
    }

    function repay(address asset, address collateral, uint256 amount) external returns (uint256 repaid) {
        require(amount > 0, "AMOUNT_0");
        bytes32 marketId = _id(asset, collateral);
        Market storage m = markets[marketId];
        require(m.listed, "NOT_LISTED");
        _accrue(marketId);

        Account storage a = accounts[marketId][msg.sender];
        uint256 bor = _borrowBalanceCurrent(marketId, msg.sender);
        require(bor > 0, "NO_DEBT");

        repaid = amount > bor ? bor : amount;

        m.asset.safeTransferFrom(msg.sender, address(this), repaid);
        m.cash += repaid;

        m.totalBorrows -= repaid;

        uint256 remaining = bor - repaid;
        if (remaining == 0) {
            a.borrowPrincipal = 0;
            a.borrowIndexRaySnapshot = 0;
        } else {
            a.borrowPrincipal = (remaining * RAY) / m.borrowIndexRay;
            a.borrowIndexRaySnapshot = m.borrowIndexRay;
        }

        emit Repay(marketId, msg.sender, repaid);
    }

    function liquidate(
        address asset,
        address collateral,
        address user,
        uint256 repayAmount
    ) external returns (uint256 seizedCollateral) {
        require(repayAmount > 0, "AMOUNT_0");
        bytes32 marketId = _id(asset, collateral);
        Market storage m = markets[marketId];
        require(m.listed, "NOT_LISTED");
        _accrue(marketId);

        require(user != address(0) && user != msg.sender, "BAD_USER");

        Account storage a = accounts[marketId][user];
        uint256 bor = _borrowBalanceCurrent(marketId, user);
        require(bor > 0, "NO_DEBT");

        uint256 priceRay = getPriceCollateralPerAsset(asset, collateral);
        uint256 collAsAsset = (a.collateralAmount * RAY) / priceRay;
        uint256 maxBorrowLT = (collAsAsset * m.liquidationThresholdBps) / BPS;
        require(bor > maxBorrowLT, "NOT_LIQUIDATABLE");

        uint256 actualRepay = repayAmount > bor ? bor : repayAmount;

        // seize collateral = repay(asset) * price(coll/asset) * bonus
        // coll = repay * priceRay / RAY * bonusBps/BPS
        uint256 baseSeize = (actualRepay * priceRay) / RAY;
        seizedCollateral = (baseSeize * m.liquidationBonusBps) / BPS;
        require(seizedCollateral > 0, "SEIZE_0");
        require(seizedCollateral <= a.collateralAmount, "INSUFFICIENT_USER_COLLATERAL");

        m.asset.safeTransferFrom(msg.sender, address(this), actualRepay);
        m.cash += actualRepay;

        m.totalBorrows -= actualRepay;

        uint256 remaining = bor - actualRepay;
        if (remaining == 0) {
            a.borrowPrincipal = 0;
            a.borrowIndexRaySnapshot = 0;
        } else {
            a.borrowPrincipal = (remaining * RAY) / m.borrowIndexRay;
            a.borrowIndexRaySnapshot = m.borrowIndexRay;
        }

        a.collateralAmount -= seizedCollateral;
        m.collateral.safeTransfer(msg.sender, seizedCollateral);

        emit Liquidate(marketId, msg.sender, user, actualRepay, seizedCollateral);
    }

    function _isHealthyAfter(bytes32 marketId, address user) internal view returns (bool) {
        Market storage m = markets[marketId];
        Account storage a = accounts[marketId][user];
        uint256 bor = _borrowBalanceCurrent(marketId, user);
        if (bor == 0) return true;

        uint256 priceRay = getPriceCollateralPerAsset(address(m.asset), address(m.collateral));
        uint256 collAsAsset = (a.collateralAmount * RAY) / priceRay;
        uint256 maxBorrow = (collAsAsset * m.collateralFactorBps) / BPS;
        return bor <= maxBorrow;
    }

    function sweep(address token, address to, uint256 amount) external onlyOwner {
        require(to != address(0), "BAD_TO");
        IERC20(token).transfer(to, amount);
    }

    function transferOwnership(address newOwner) external onlyOwner {
        require(newOwner != address(0), "BAD_OWNER");
        owner = newOwner;
    }
}