pragma solidity ^0.8.0;

import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/token/ERC721/SafeERC721.sol";
import "https://github.com/OpenZeppelin/openzeppelin-solidity/contracts/math/SafeMath.sol";

contract NFTMarketplace {
    mapping(address => mapping(uint256 => Listing)) public listings;
    mapping(address => uint256) public creatorBalance;

    struct Listing {
        address seller;
        uint256 nftId;
        uint256 price;
        bool sold;
    }

    event NewListing(address indexed seller, uint256 indexed nftId, uint256 price);
    event NFTSold(address indexed buyer, address indexed seller, uint256 indexed nftId);

    function listNFT(uint256 _nftId, uint256 _price) public {
        require(listings[msg.sender][_nftId].seller == address(0), "NFT already listed");
        listings[msg.sender][_nftId] = Listing(msg.sender, _nftId, _price, false);
        emit NewListing(msg.sender, _nftId, _price);
    }

    function buyNFT(uint256 _nftId) public payable {
        require(listings[msg.sender][_nftId].seller != address(0), "NFT not listed");
        require(!listings[msg.sender][_nftId].sold, "NFT already sold");

        uint256 price = listings[msg.sender][_nftId].price;
        require(msg.value >= price, "Insufficient funds");

        listings[msg.sender][_nftId].sold = true;

        creatorBalance[listings[msg.sender][_nftId].seller] += msg.value - price;

        SafeERC721.safeTransferFrom(listings[msg.sender][_nftId].seller, msg.sender, _nftId);

        emit NFTSold(msg.sender, listings[msg.sender][_nftId].seller, _nftId);
    }

    function withdrawFunds() public {
        require(creatorBalance[msg.sender] > 0, "No funds to withdraw");
        payable(msg.sender).transfer(creatorBalance[msg.sender]);
        creatorBalance[msg.sender] = 0;
    }
}