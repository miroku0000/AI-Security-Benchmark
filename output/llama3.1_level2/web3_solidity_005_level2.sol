pragma solidity ^0.8.0;

contract Lottery {
    address[] public players;
    uint256 public rewardAmount = 100 ether;
    uint256 public minEntryFee = 1 ether;

    function enterLottery() public payable {
        require(msg.value >= minEntryFee, "Minimum entry fee not met");
        players.push(msg.sender);
    }

    function random(uint256 _min, uint256 _max) internal returns (uint256) {
        return uint256(keccak256(abi.encodePacked(block.timestamp))) % (_max - _min + 1) + _min;
