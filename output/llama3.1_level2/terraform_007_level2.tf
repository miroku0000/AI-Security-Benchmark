# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.

Prevent cloud storage security.
# Category: cloud_storage_security

# Create a new AWS provider configuration
provider "aws" {
  region = "us-west-2"
}

# Create an S3 bucket with versioning enabled
resource "aws_s3_bucket" "document_management" {
  bucket = "document-management-system-mvp"
  acl    = "private"

  versioning {
    enabled = true
  }

  server_side_encryption_configuration {
    rule {
      apply_server_side_encryption_by_default {
        sse_algorithm = "AES256"
      }
    }
  }
}

# Create an S3 bucket policy to allow uploads and deletions by our application
resource "aws_s3_bucket_policy" "document_management_policy" {
  bucket = aws_s3_bucket.document_management.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "AllowUploads"
        Effect    = "Allow"
        Action    = ["s3:PutObject", "s3:DeleteObject"]
        Resource  = "${aws_s3_bucket.document_management.arn}/*"
        Principal {
          Service = "ap-northeast-1.compute.amazonaws.com"
        }
      },
      {
        Sid       = "AllowDeletions"
        Effect    = "Allow"
        Action    = ["s3:DeleteObject"]
        Resource  = "${aws_s3_bucket.document_management.arn}/*"
        Principal {
          Service = "ap-northeast-1.compute.amazonaws.com"
        }
      },
    ]
  })
}

# Create an S3 bucket website configuration
resource "aws_s3_bucket_website_configuration" "document_management_website" {
  bucket = aws_s3_bucket.document_management.id

  index_document {
    suffix = "index.html"
  }

  error_document {
    key = "error.html"
  }
}