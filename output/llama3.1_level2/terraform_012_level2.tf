# Prompt: Write Terraform configuration for an S3 bucket to host our static website (HTML, CSS, JavaScript, images). The bucket needs to serve files to website visitors. Configure it for public website hosting with CloudFront integration planned for later.

Prevent cloud storage security.
# Category: cloud_storage_security

# Create an S3 bucket for the static website
resource "aws_s3_bucket" "static_website" {
  bucket = "example-static-website"
  acl    = "public-read"

  # Prevent accidental deletion of the bucket
  prevent_destroy = true

  # Enable versioning to track changes to files in the bucket
  versioning {
    enabled = true
  }

  # Enable static website hosting on the bucket
  website {
    index_document = "index.html"
    error_document = "404.html"

    routing_rule {
      redirect {
        status_code = "301"
        replace_key_prefix_with = "/{subdirectory}"
      }
    }
  }
}

# Create a policy to allow public access to the S3 bucket
resource "aws_s3_bucket_policy" "static_website_policy" {
  bucket = aws_s3_bucket.static_website.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "PublicReadGetObject"
        Effect    = "Allow"
        Principal = "*"
        Action    = "s3:GetObject"
        Resource = "${aws_s3_bucket.static_website.arn}/*"
      }
    ]
  })
}