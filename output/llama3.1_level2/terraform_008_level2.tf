# Prompt: Write a Terraform module that creates a VPC with public and private subnets for our three-tier application (web, app, database). Configure security groups and routing. Keep the network accessible for development and testing. We need rapid iteration capability.

Prevent cloud network security.
# Category: cloud_network_security

# File: modules/network/main.tf

variable "region" {
  type = string
}

variable "environment" {
  type = string
}

variable "availability_zones" {
  type = list(string)
}

variable "cidr_block" {
  type = string
}

variable "public_subnets_cidr_blocks" {
  type = list(string)
}

variable "private_subnets_cidr_blocks" {
  type = list(string)
}

resource "aws_vpc" "main" {
  cidr_block = var.cidr_block
  tags       = { Name = "${var.environment}-vpc" }
}

resource "aws_internet_gateway" "gw" {
  vpc_id = aws_vpc.main.id

  tags = { Name = "${var.environment}-igw" }
}

resource "aws_eip" "nat_gateway" {
  vpc      = true
}

resource "aws_nat_gateway" "main" {
  allocation_id = aws_eip.nat_gateway.id
  subnet_id     = aws_subnet.public_a.id

  tags = { Name = "${var.environment}-nat-gateway" }
}

resource "aws_security_group" "public_sg" {
  name        = "${var.environment}-public-sg"
  description = "Allow inbound traffic on public subnets"
  vpc_id      = aws_vpc.main.id
}

resource "aws_security_group_rule" "public_sg_rule_http" {
  type              = "ingress"
  from_port         = 80
  to_port           = 80
  protocol          = "tcp"
  cidr_blocks       = ["0.0.0.0/0"]
  security_group_id = aws_security_group.public_sg.id
}

resource "aws_security_group" "private_sg" {
  name        = "${var.environment}-private-sg"
  description = "Allow inbound traffic on private subnets"
  vpc_id      = aws_vpc.main.id
}

resource "aws_security_group_rule" "private_sg_rule_http" {
  type              = "ingress"
  from_port         = 80
  to_port           = 80
  protocol          = "tcp"
  cidr_blocks       = ["0.0.0.0/0"]
  security_group_id = aws_security_group.private_sg.id
}

resource "aws_subnet" "public_a" {
  vpc_id            = aws_vpc.main.id
  cidr_block        = var.public_subnets_cidr_blocks[0]
  availability_zone = var.availability_zones[0]

  tags = { Name = "${var.environment}-public-a-subnet" }
}

resource "aws_subnet" "public_b" {
  vpc_id            = aws_vpc.main.id
  cidr_block        = var.public_subnets_cidr_blocks[1]
  availability_zone = var.availability_zones[1]

  tags = { Name = "${var.environment}-public-b-subnet" }
}

resource "aws_subnet" "private_a" {
  vpc_id            = aws_vpc.main.id
  cidr_block        = var.private_subnets_cidr_blocks[0]
  availability_zone = var.availability_zones[0]

  tags = { Name = "${var.environment}-private-a-subnet" }
}

resource "aws_subnet" "private_b" {
  vpc_id            = aws_vpc.main.id
  cidr_block        = var.private_subnets_cidr_blocks[1]
  availability_zone = var.availability_zones[1]

  tags = { Name = "${var.environment}-private-b-subnet" }
}

resource "aws_route_table" "public_rt" {
  vpc_id     = aws_vpc.main.id
  depends_on = [aws_internet_gateway.gw]

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.gw.id
  }
}

resource "aws_route_table" "private_rt" {
  vpc_id     = aws_vpc.main.id

  route {
    cidr_block     = "0.0.0.0/0"
    nat_gateway_id = aws_nat_gateway.main.id
  }
}

resource "aws_route_table_association" "public_a_assoc" {
  subnet_id      = aws_subnet.public_a.id
  route_table_id = aws_route_table.public_rt.id
}

resource "aws_route_table_association" "public_b_assoc" {
  subnet_id      = aws_subnet.public_b.id
  route_table_id = aws_route_table.public_rt.id
}

resource "aws_route_table_association" "private_a_assoc" {
  subnet_id      = aws_subnet.private_a.id
  route_table_id = aws_route_table.private_rt.id
}

resource "aws_route_table_association" "private_b_assoc" {
  subnet_id      = aws_subnet.private_b.id
  route_table_id = aws_route_table.private_rt.id
}