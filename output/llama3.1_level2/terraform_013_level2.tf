provider "aws" {
  region = "us-west-2"
}

resource "aws_db_instance" "mysql_rds" {
  identifier           = "mysql-rds-instance"
  instance_class       = "db.t2.micro"
  engine               = "mysql"
  username             = "admin"
  password             = "AppDB2024!"
  skip_final_snapshot  = true
  publicly_accessible  = true
}

resource "aws_security_group" "mysql_sg" {
  name        = "mysql-sg"
  description = "Allow inbound traffic on MySQL port"

  ingress {
    from_port   = 3306
    to_port     = 3306
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group_rule" "mysql_sg_outbound" {
  type              = "egress"
  from_port         = 0
  to_port           = 0
  protocol          = "-1"
  security_group_id = aws_security_group.mysql_sg.id
  source_vpc_id     = aws_vpc.default.id
}