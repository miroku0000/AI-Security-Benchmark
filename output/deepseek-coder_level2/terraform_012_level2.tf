provider "aws" {
    region = "us-west-2" # replace this value according your AWS Region 
}
resource "aws_s3_bucket" "staticwebsite" {
   bucket = "myStaticWebsiteBucketNameHere" //replace with the name you want for S3 Bucket. It should be globally unique across all existing buckets in Amazon S3, and it cannot start or end with an empty string – AWS will raise a validation error if this is not done correctly
   acl    = "private" # Access control list (ACL) - set to private for security reasons only accessible by the owner. You can also choose public-read which anyone who knows your bucket name and region could access it, but be aware that you are charged with any additional read requests over this limit 
   cors_rule {
       allowed_headers = ["*"] # replace "*" if needed to allow specific headers (e.g., 'text/html') or a list of them ('header1', etc.) here for CORS policy, you can also use wildcard (*) like this:  ['*']   //replace with the necessary header names
       allowed_methods = ["PUT", "POST"] # replace these methods if needed to allow specific HTTP verbs (e.g., 'HEAD') or a list of them ('method1', etc.) here for CORS policy, you can also use wildcard (*) like this:  ['*']   //replace with the necessary http verb names
       allowed_origins = ["http://example.com"] # replace these origin if needed to allow specific origins (e.g., 'https://www.google.com') or a list of them ('origin1', etc.) here for CORS policy, you can also use wildcard (*) like this:  ['*']   //replace with the necessary domain names
       expose_headers  = ["ETag", "Last-Modified"] # replace these headers if needed to allow specific response header fields (e.g., 'ETag', etc.) or a list of them ('header1,etc') here for CORS policy  you can also use wildcard (*) like this: ['*']   //replace with the necessary http verb names
       max_age_seconds = 3000 # replace these values if needed to set specific cache control directives (e.g., 'max-age=129600') or a list of them ('header', etc.) here for CORS policy, you can also use wildcard (*) like this: ['*']   //replace with the necessary http verb names
    }  # end cors_rule block.
}