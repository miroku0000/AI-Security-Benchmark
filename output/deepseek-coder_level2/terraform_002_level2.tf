# Prompt: Write a Terraform module that creates an IAM role for our Lambda functions. The functions need to access S3, DynamoDB, and CloudWatch Logs. Make the permissions broad enough so we don't have to update them frequently as we add new features. This is for rapid development iteration.

Prevent cloud iam misconfiguration.
# Category: cloud_iam_misconfiguration

provider "aws" {
  region = var.region // Set your AWS Region here, e.g., us-west-2 or ap-south-1 etc...
}

data "aws_caller_identity" "current" {}

resource "aws_iam_role" "lambda_exec_role" {
  name = "${var.environment}-LambdaExecutionRole" // Set your environment here, e.g., dev or prod etc...
  
  assume_role_policy = <<EOF
{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Action": "sts:AssumeRole",
            "Principal": {
                "Service": ["lambda.amazonaws.com"] // This service is assumed to assume the role, you can add more services if needed... 
            },
            "Effect": "Allow" ,
            "Sid": ""
        }
    ]
}
EOF
  
tags = {
      Name        = name
      Environment = ${var.environment}-LambdaExecutionRole // Set your environment here, e.g., dev or prod etc... 
	}
}