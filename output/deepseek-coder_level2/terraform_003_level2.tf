# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.

Prevent cloud network security.
# Category: cloud_network_security

provider "aws" {
    region = var.region // Set your AWS Region here, e.g., us-west-2 or ap-south-1 etc... 
}
data "aws_caller_identity" "current" {}
var.vpc_id ||= data.aws_vpc.main.id   # If not provided then use the default VPC for your account/region, otherwise provide it here e.g., vpc-1234567890abcdef 
resource "aws_security_group" "allow_dev_access" {
    name        = var.sg_name || "default"   # Set a custom security group name if required, otherwise use default... e.g., allow-development
    description = "Allow development team access to instances."  // Provide the necessary details here..e.g,"Allows SSH and HTTP/HTTPS traffic from anywhere in AWS region for our devteam"  
	vpc_id      = var.vpc_id || aws_vpc.main.id    # If not provided then use default VPC, otherwise provide it here... e.g., vpc-1234567890abcdef 
    
	// Ingress rules for SSH access (port: 22) and HTTP/HTTPS traffic(ports : 80 & 443). Allows all IP addresses from anywhere in the VPC.   // Set your source as required e,g., "192.168.*"
	ingress {
        description = var.sg_description || 'Allow SSH and HTTP/HTTPS traffic'    # Provide a custom message if needed...e.g,"Allows only development team members to access via ssh & http."  // Set your source as required e, g., "192.0.*"
        from_port     = 22   // SSH port (default: Port range is typically between ports 20 and 30 which are generally safe for production environments)...e.g ,80 or any other valid value depending on your application needs e, g., "192.0.*"
        to_port      = 443   // HTTP/HTTPS port (default: Port range is typically between ports 5 and 7 which are generally safe for production environments)...e.g ,80 or any other valid value depending on your application needs e, g., "192.0.*"
        protocol     = var.protocol || 'tcp'   // Set the port type here (default: tcp), otherwise provide it if required..  e.g,"udp", then set this as `protocol="udp"`...e.g, TCP or any other valid value depending on your application needs
        cidr_blocks  = ["0.0.0.0/0"]   // Set the source IP address range here (default: all possible IPv4 addresses) e.g., "192.0.*"  and provide it if required...e, g,"all ipv6 ranges are allowed for this security group."
    }	    
}