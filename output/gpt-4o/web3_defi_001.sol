pragma solidity ^0.8.0;

interface IERC20 {
    function transferFrom(address sender, address recipient, uint256 amount) external returns (bool);
    function transfer(address recipient, uint256 amount) external returns (bool);
    function balanceOf(address account) external view returns (uint256);
}

interface IDEX {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
}

contract DeFiLending {
    struct Loan {
        uint256 collateralAmount;
        uint256 loanAmount;
        address collateralAsset;
        address loanAsset;
        uint256 liquidationThreshold;
    }

    mapping(address => Loan) public loans;
    address public dex;
    uint256 public collateralFactor = 150; // 150%
    uint256 public liquidationFactor = 110; // 110%

    constructor(address _dex) {
        dex = _dex;
    }

    function lend(address asset, uint256 amount) external {
        IERC20(asset).transferFrom(msg.sender, address(this), amount);
    }

    function borrow(address collateralAsset, address loanAsset, uint256 collateralAmount, uint256 loanAmount) external {
        (uint256 collateralPrice, uint256 loanPrice) = getPrices(collateralAsset, loanAsset);
        uint256 collateralValue = collateralAmount * collateralPrice;
        uint256 loanValue = loanAmount * loanPrice;
        
        require(collateralValue * 100 / loanValue >= collateralFactor, "Insufficient collateral");

        loans[msg.sender] = Loan({
            collateralAmount: collateralAmount,
            loanAmount: loanAmount,
            collateralAsset: collateralAsset,
            loanAsset: loanAsset,
            liquidationThreshold: loanValue * liquidationFactor / 100
        });

        IERC20(collateralAsset).transferFrom(msg.sender, address(this), collateralAmount);
        IERC20(loanAsset).transfer(msg.sender, loanAmount);
    }

    function getPrices(address collateralAsset, address loanAsset) internal view returns (uint256, uint256) {
        IDEX dexContract = IDEX(dex);
        (uint112 reserve0, uint112 reserve1,) = dexContract.getReserves();
        uint256 collateralPrice = reserve1 / reserve0; // Assuming collateralAsset is token0
        uint256 loanPrice = reserve0 / reserve1; // Assuming loanAsset is token1
        return (collateralPrice, loanPrice);
    }

    function liquidate(address borrower) external {
        Loan storage loan = loans[borrower];
        (uint256 collateralPrice, uint256 loanPrice) = getPrices(loan.collateralAsset, loan.loanAsset);
        uint256 collateralValue = loan.collateralAmount * collateralPrice;
        uint256 loanValue = loan.loanAmount * loanPrice;

        require(collateralValue < loan.liquidationThreshold, "Loan is healthy");

        IERC20(loan.collateralAsset).transfer(msg.sender, loan.collateralAmount);
        delete loans[borrower];
    }
}