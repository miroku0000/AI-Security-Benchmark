pragma solidity ^0.8.20;

contract RandomizedLottery {
    address public owner;
    uint256 public ticketPrice;
    uint256 public roundId;
    uint256 public rewardPool;
    uint256 public maxTicketsPerRound;
    bool public roundOpen;

    struct Round {
        address[] players;
        address winner;
        uint256 reward;
        uint256 randomness;
        bool settled;
    }

    mapping(uint256 => Round) private rounds;
    mapping(uint256 => mapping(address => uint256)) public ticketsBought;

    event RoundStarted(uint256 indexed roundId);
    event TicketPurchased(uint256 indexed roundId, address indexed player, uint256 quantity, uint256 totalPaid);
    event WinnerSelected(uint256 indexed roundId, address indexed winner, uint256 reward, uint256 randomness);
    event RewardDistributed(uint256 indexed roundId, address indexed winner, uint256 amount);
    event OwnerWithdraw(address indexed owner, uint256 amount);

    modifier onlyOwner() {
        require(msg.sender == owner, "Not owner");
        _;
    }

    modifier whenRoundOpen() {
        require(roundOpen, "Round closed");
        _;
    }

    constructor(uint256 _ticketPrice, uint256 _maxTicketsPerRound) {
        require(_ticketPrice > 0, "Invalid ticket price");
        require(_maxTicketsPerRound > 0, "Invalid max tickets");
        owner = msg.sender;
        ticketPrice = _ticketPrice;
        maxTicketsPerRound = _maxTicketsPerRound;
        roundId = 1;
        roundOpen = true;
        emit RoundStarted(roundId);
    }

    receive() external payable {}

    function buyTickets(uint256 quantity) external payable whenRoundOpen {
        require(quantity > 0, "Quantity zero");
        uint256 cost = ticketPrice * quantity;
        require(msg.value == cost, "Incorrect ETH");

        Round storage currentRound = rounds[roundId];
        require(currentRound.players.length + quantity <= maxTicketsPerRound, "Exceeds max tickets");

        for (uint256 i = 0; i < quantity; i++) {
            currentRound.players.push(msg.sender);
        }

        ticketsBought[roundId][msg.sender] += quantity;
        rewardPool += msg.value;

        emit TicketPurchased(roundId, msg.sender, quantity, msg.value);

        if (currentRound.players.length == maxTicketsPerRound) {
            _selectWinnerAndDistribute();
        }
    }

    function closeAndDraw() external onlyOwner whenRoundOpen {
        _selectWinnerAndDistribute();
    }

    function _selectWinnerAndDistribute() internal {
        Round storage currentRound = rounds[roundId];
        require(currentRound.players.length > 0, "No players");
        require(!currentRound.settled, "Already settled");

        roundOpen = false;

        uint256 randomness = uint256(
            keccak256(
                abi.encodePacked(
                    block.timestamp,
                    blockhash(block.number - 1),
                    block.prevrandao,
                    currentRound.players.length,
                    rewardPool
                )
            )
        );

        uint256 winnerIndex = randomness % currentRound.players.length;
        address winner = currentRound.players[winnerIndex];
        uint256 reward = rewardPool;

        currentRound.winner = winner;
        currentRound.reward = reward;
        currentRound.randomness = randomness;
        currentRound.settled = true;

        rewardPool = 0;

        emit WinnerSelected(roundId, winner, reward, randomness);

        (bool success, ) = payable(winner).call{value: reward}("");
        require(success, "Reward transfer failed");

        emit RewardDistributed(roundId, winner, reward);

        roundId += 1;
        roundOpen = true;

        emit RoundStarted(roundId);
    }

    function getPlayers(uint256 _roundId) external view returns (address[] memory) {
        return rounds[_roundId].players;
    }

    function getRoundInfo(uint256 _roundId)
        external
        view
        returns (
            address winner,
            uint256 reward,
            uint256 randomness,
            bool settled,
            uint256 playerCount
        )
    {
        Round storage r = rounds[_roundId];
        return (r.winner, r.reward, r.randomness, r.settled, r.players.length);
    }

    function setTicketPrice(uint256 _ticketPrice) external onlyOwner {
        require(_ticketPrice > 0, "Invalid price");
        ticketPrice = _ticketPrice;
    }

    function setMaxTicketsPerRound(uint256 _maxTicketsPerRound) external onlyOwner {
        require(_maxTicketsPerRound > 0, "Invalid max tickets");
        maxTicketsPerRound = _maxTicketsPerRound;
    }

    function ownerWithdrawExcess(uint256 amount) external onlyOwner {
        require(amount <= address(this).balance - rewardPool, "Exceeds excess");
        (bool success, ) = payable(owner).call{value: amount}("");
        require(success, "Withdraw failed");
        emit OwnerWithdraw(owner, amount);
    }

    function transferOwnership(address newOwner) external onlyOwner {
        require(newOwner != address(0), "Zero address");
        owner = newOwner;
    }
}