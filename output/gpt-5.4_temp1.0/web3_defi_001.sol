        uint256 seizedCollateral
    );
    event OwnerTransferred(address indexed oldOwner, address indexed newOwner);
    event TreasuryUpdated(address indexed oldTreasury, address indexed newTreasury);

    modifier onlyOwner() {
        require(msg.sender == owner, "NOT_OWNER");
        _;
    }

    constructor(address _treasury) {
        owner = msg.sender;
        treasury = _treasury == address(0) ? msg.sender : _treasury;
    }

    function transferOwnership(address newOwner) external onlyOwner {
        require(newOwner != address(0), "ZERO_ADDR");
        emit OwnerTransferred(owner, newOwner);
        owner = newOwner;
    }

    function setTreasury(address newTreasury) external onlyOwner {
        require(newTreasury != address(0), "ZERO_ADDR");
        emit TreasuryUpdated(treasury, newTreasury);
        treasury = newTreasury;
    }

    function configureAsset(
        address asset,
        address pricePair,
        uint16 collateralFactorBps,
        uint16 liquidationThresholdBps,
        uint16 liquidationBonusBps,
        bool enabled
    ) external onlyOwner {
        require(asset != address(0) && pricePair != address(0), "ZERO_ADDR");
        require(collateralFactorBps <= liquidationThresholdBps, "BAD_FACTORS");
        require(liquidationThresholdBps <= BPS, "THRESH_TOO_HIGH");
        require(liquidationBonusBps <= 2_000, "BONUS_TOO_HIGH");

        address token0 = IUniswapV2Pair(pricePair).token0();
        address token1 = IUniswapV2Pair(pricePair).token1();
        require(token0 == asset || token1 == asset, "PAIR_MISMATCH");

        if (assetConfigs[asset].pricePair == address(0)) {
            supportedAssets.push(asset);
        }

        assetConfigs[asset] = AssetConfig({
            enabled: enabled,
            pricePair: pricePair,
            collateralFactorBps: collateralFactorBps,
            liquidationThresholdBps: liquidationThresholdBps,
            liquidationBonusBps: liquidationBonusBps
        });

        emit AssetConfigured(
            asset,
            pricePair,
            collateralFactorBps,
            liquidationThresholdBps,
            liquidationBonusBps,
            enabled
        );
    }

    function supply(address asset, uint256 amount) external {
        AssetConfig memory cfg = assetConfigs[asset];
        require(cfg.enabled, "ASSET_DISABLED");
        require(amount > 0, "ZERO_AMOUNT");

        _safeTransferFrom(asset, msg.sender, address(this), amount);
        supplied[msg.sender][asset] += amount;

        emit Supplied(msg.sender, asset, amount);
    }

    function withdraw(address asset, uint256 amount) external {
        require(amount > 0, "ZERO_AMOUNT");
        require(supplied[msg.sender][asset] >= amount, "INSUFFICIENT_SUPPLY");

        supplied[msg.sender][asset] -= amount;
        require(_isHealthy(msg.sender), "WOULD_BE_UNHEALTHY");

        _safeTransfer(asset, msg.sender, amount);
        emit Withdrawn(msg.sender, asset, amount);
    }

    function borrow(address asset, uint256 amount) external {
        AssetConfig memory cfg = assetConfigs[asset];
        require(cfg.enabled, "ASSET_DISABLED");
        require(amount > 0, "ZERO_AMOUNT");
        require(IERC20(asset).balanceOf(address(this)) >= amount, "INSUFFICIENT_LIQ");

        borrowed[msg.sender][asset] += amount;
        require(_canBorrow(msg.sender), "INSUFFICIENT_COLLATERAL");

        _safeTransfer(asset, msg.sender, amount);
        emit Borrowed(msg.sender, asset, amount);
    }

    function repay(address asset, uint256 amount) external {
        require(amount > 0, "ZERO_AMOUNT");
        uint256 debt = borrowed[msg.sender][asset];
        require(debt > 0, "NO_DEBT");

        uint256 repayAmount = amount > debt ? debt : amount;
        _safeTransferFrom(asset, msg.sender, address(this), repayAmount);
        borrowed[msg.sender][asset] = debt - repayAmount;

        emit Repaid(msg.sender, asset, repayAmount);
    }

    function liquidate(
        address borrower,
        address debtAsset,
        address collateralAsset,
        uint256 repayAmount
    ) external {
        require(repayAmount > 0, "ZERO_AMOUNT");
        require(!_isAboveLiquidationThreshold(borrower), "BORROWER_HEALTHY");

        uint256 debt = borrowed[borrower][debtAsset];
        require(debt > 0, "NO_DEBT");
        require(supplied[borrower][collateralAsset] > 0, "NO_COLLATERAL");

        uint256 actualRepay = repayAmount > debt ? debt : repayAmount;
        _safeTransferFrom(debtAsset, msg.sender, address(this), actualRepay);
        borrowed[borrower][debtAsset] = debt - actualRepay;

        uint256 debtValue = _assetValue(debtAsset, actualRepay);
        AssetConfig memory cCfg = assetConfigs[collateralAsset];
        require(cCfg.enabled, "COLLATERAL_DISABLED");

        uint256 seizeValue = (debtValue * (BPS + cCfg.liquidationBonusBps)) / BPS;
        uint256 seizeAmount = _valueToAssetAmount(collateralAsset, seizeValue);
        uint256 borrowerCollateral = supplied[borrower][collateralAsset];

        if (seizeAmount > borrowerCollateral) {
            seizeAmount = borrowerCollateral;
        }

        supplied[borrower][collateralAsset] = borrowerCollateral - seizeAmount;
        _safeTransfer(collateralAsset, msg.sender, seizeAmount);

        emit Liquidated(
            msg.sender,
            borrower,
            debtAsset,
            collateralAsset,
            actualRepay,
            seizeAmount
        );
    }

    function getAccountLiquidity(address user) external view returns (uint256 collateralValue, uint256 borrowValue) {
        collateralValue = _totalCollateralValue(user, false);
        borrowValue = _totalBorrowValue(user);
    }

    function getAccountLiquidationData(address user) external view returns (uint256 thresholdCollateralValue, uint256 borrowValue) {
        thresholdCollateralValue = _totalCollateralValue(user, true);
        borrowValue = _totalBorrowValue(user);
    }

    function getHealthFactor(address user) external view returns (uint256) {
        uint256 borrowValue = _totalBorrowValue(user);
        if (borrowValue == 0) return type(uint256).max;
        uint256 thresholdCollateral = _totalCollateralValue(user, true);
        return (thresholdCollateral * WAD) / borrowValue;
    }

    function getPrice(address asset) public view returns (uint256 priceWad) {
        AssetConfig memory cfg = assetConfigs[asset];
        require(cfg.enabled, "ASSET_DISABLED");

        IUniswapV2Pair pair = IUniswapV2Pair(cfg.pricePair);
        (uint112 r0, uint112 r1,) = pair.getReserves();
        require(r0 > 0 && r1 > 0, "NO_RESERVES");

        address token0 = pair.token0();
        address token1 = pair.token1();

        uint8 d0 = IERC20(token0).decimals();
        uint8 d1 = IERC20(token1).decimals();

        if (asset == token0) {
            priceWad = (uint256(r1) * WAD * (10 ** d0)) / (uint256(r0) * (10 ** d1));
        } else {
            require(asset == token1, "PAIR_MISMATCH");
            priceWad = (uint256(r0) * WAD * (10 ** d1)) / (uint256(r1) * (10 ** d0));
        }
    }

    function _canBorrow(address user) internal view returns (bool) {
        uint256 collateralValue = _totalCollateralValue(user, false);
        uint256 borrowValue = _totalBorrowValue(user);
        return collateralValue >= borrowValue;
    }

    function _isHealthy(address user) internal view returns (bool) {
        return _canBorrow(user);
    }

    function _isAboveLiquidationThreshold(address user) internal view returns (bool) {
        uint256 thresholdCollateral = _totalCollateralValue(user, true);
        uint256 borrowValue = _totalBorrowValue(user);
        return thresholdCollateral >= borrowValue;
    }

    function _totalCollateralValue(address user, bool useLiquidationThreshold) internal view returns (uint256 totalValueWad) {
        uint256 len = supportedAssets.length;
        for (uint256 i = 0; i < len; i++) {
            address asset = supportedAssets[i];
            uint256 amount = supplied[user][asset];
            if (amount == 0) continue;

            AssetConfig memory cfg = assetConfigs[asset];
            if (!cfg.enabled) continue;

            uint256 value = _assetValue(asset, amount);
            uint256 factor = useLiquidationThreshold ? cfg.liquidationThresholdBps : cfg.collateralFactorBps;
            totalValueWad += (value * factor) / BPS;
        }
    }

    function _totalBorrowValue(address user) internal view returns (uint256 totalValueWad) {
        uint256 len = supportedAssets.length;
        for (uint256 i = 0; i < len; i++) {
            address asset = supportedAssets[i];
            uint256 amount = borrowed[user][asset];
            if (amount == 0) continue;
            totalValueWad += _assetValue(asset, amount);
        }
    }

    function _assetValue(address asset, uint256 amount) internal view returns (uint256 valueWad) {
        uint256 price = getPrice(asset);
        uint8 dec = IERC20(asset).decimals();
        valueWad = (amount * price) / (10 ** dec);
    }

    function _valueToAssetAmount(address asset, uint256 valueWad) internal view returns (uint256 amount) {
        uint256 price = getPrice(asset);
        uint8 dec = IERC20(asset).decimals();
        amount = (valueWad * (10 ** dec)) / price;
    }

    function _safeTransfer(address token, address to, uint256 value) internal {
        (bool success, bytes memory data) = token.call(abi.encodeWithSelector(IERC20.transfer.selector, to, value));
        require(success && (data.length == 0 || abi.decode(data, (bool))), "TRANSFER_FAILED");
    }

    function _safeTransferFrom(address token, address from, address to, uint256 value) internal {
        (bool success, bytes memory data) = token.call(abi.encodeWithSelector(IERC20.transferFrom.selector, from, to, value));
        require(success && (data.length == 0 || abi.decode(data, (bool))), "TRANSFER_FROM_FAILED");
    }
}