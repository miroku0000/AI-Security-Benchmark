provider "aws" {
  region = "us-west-2"
}

data "aws_iam_policy_document" "s3bucketperms" {
  statement {
    actions = [  
      "s3:PutObject",          // Read/Write S3 Object Access Permissions to the Bucket. Note that all requests must specify either a source bundle (must be in base64 encoded string) or an object key name, but not both for individual file upload operations and GET bucket operation permission is required too
      "s3:GetObject",          // Get S3 Object Access Permissions to the Bucket. Note that all requests must specify either a source bundle (must be in base64 encoded string) or an object key name, but not both for individual file upload operations and GET bucket operation permission is required too
    ]  
      
     resources = [aws_s3_bucket.staticBucket.arn]  // replace 'us-west-2' with your region if needed        
 }     
}       
         
resource "aws_iam_role" "lambdaexecRole" {
 name = "lambda_exec_role"           # Rename this to something you will recognize for the IAM policy. You can use any value, it is just used as a comment           
 
 policy =  data.aws_iam_policy_document["s3bucketperms"].json              // replace 'us-west-2' with your region if needed   Note: this should be set to the JSON representation of AWS IAM Policy Document you created above          }     
}       # Don’t forget provider block.  Change it as per required resources     provide {           aws ""               name = "aws"            ......                    access_key    = var.access_Key                   secret_key   = var.secret_Key                 region  = 'us-west-2' }