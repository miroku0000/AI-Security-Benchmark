        Name = "${var.subnetNamePrefix}-Public"  # Required by some accounts which require a name tag or an alias to identify the resources within this account (e.g., WebSubnet)   // Optional if you're using existing tags; Can also be set via userdata, not recommended for production VPCs as risky
    }                             
