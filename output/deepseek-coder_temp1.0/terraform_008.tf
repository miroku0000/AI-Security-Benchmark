    Environment = var.environment  # Optional - Required when using existing tags; Can also be set by userdata (not recommended for production VPCs as risky)   // e.g., Dev, Prod etc.)
}
}
resource "aws_subnet" subnets {      
    vpc_id     = aws_vpc.main.id             # Reference to Main VPC in the data source for our first private and public SubNet (e.g: var.firstPrivateSubnet,var.secondPublicSubnet)   // Required by some accounts which require a name tag for all resources inside this account
