import "@openzeppelin/contracts-upgradeable/security/ReentrancyGuardUpgradeable.sol";
import "@openzeppelin/contracts-upgradeable/access/AccessControlUpgradeable.sol";
import "@openzeppelin/contracts-upgradeable/token/ERC20/utils/SafeERC20Upgradeable.sol";
import "@openzeppelin/contracts-upgradeable/token/ERC20/IERC20Upgradeable.sol";

contract DeFiProtocol is
    Initializable,
    UUPSUpgradeable,
    PausableUpgradeable,
    ReentrancyGuardUpgradeable,
    AccessControlUpgradeable
{
    using SafeERC20Upgradeable for IERC20Upgradeable;

    bytes32 public constant ADMIN_ROLE = keccak256("ADMIN_ROLE");
    bytes32 public constant OPERATOR_ROLE = keccak256("OPERATOR_ROLE");
    bytes32 public constant UPGRADER_ROLE = keccak256("UPGRADER_ROLE");
    bytes32 public constant WITHDRAWER_ROLE = keccak256("WITHDRAWER_ROLE");

    uint256 public constant MAX_FEE_BPS = 1000; // 10% max fee
    uint256 public constant MIN_TIMELOCK_DELAY = 1 days;
    uint256 public constant MAX_TIMELOCK_DELAY = 30 days;
    uint256 public constant WITHDRAWAL_COOLDOWN = 1 hours;

    uint256 public feeBps;
    uint256 public maxDepositAmount;
    uint256 public minDepositAmount;
    uint256 public timelockDelay;

    mapping(address => bool) public allowlistedTokens;
    mapping(bytes32 => TimelockProposal) public timelockProposals;
    mapping(address => uint256) public lastWithdrawalTimestamp;

    struct TimelockProposal {
        uint256 executionTime;
        bool executed;
        bool cancelled;
        bytes data;
        address proposer;
    }

    event ParameterChangeProposed(bytes32 indexed proposalId, address indexed proposer, uint256 executionTime);
    event ParameterChangeExecuted(bytes32 indexed proposalId, address indexed executor);
    event ParameterChangeCancelled(bytes32 indexed proposalId, address indexed canceller);
    event FeeUpdated(uint256 oldFee, uint256 newFee);
    event DepositLimitsUpdated(uint256 newMin, uint256 newMax);
    event TokenAllowlistUpdated(address indexed token, bool allowed);
    event FundsWithdrawn(address indexed token, address indexed to, uint256 amount);
    event ETHWithdrawn(address indexed to, uint256 amount);
    event Deposited(address indexed user, address indexed token, uint256 amount);
    event TimelockDelayUpdated(uint256 oldDelay, uint256 newDelay);

    error ZeroAddress();
    error ZeroAmount();
    error InvalidFee(uint256 fee);
    error InvalidDepositLimits(uint256 min, uint256 max);
    error TokenNotAllowlisted(address token);
    error DepositBelowMinimum(uint256 amount, uint256 minimum);
    error DepositAboveMaximum(uint256 amount, uint256 maximum);
    error ProposalNotReady(bytes32 proposalId, uint256 executionTime);
    error ProposalAlreadyExecuted(bytes32 proposalId);
    error ProposalAlreadyCancelled(bytes32 proposalId);
    error ProposalDoesNotExist(bytes32 proposalId);
    error ProposalAlreadyExists(bytes32 proposalId);
    error WithdrawalCooldownActive(address account, uint256 availableAt);
    error InvalidTimelockDelay(uint256 delay);
    error InsufficientBalance(uint256 requested, uint256 available);
    error ETHTransferFailed();

    /// @custom:oz-upgrades-unsafe-allow constructor
    constructor() {
        _disableInitializers();
    }

    function initialize(
        address _admin,
        uint256 _feeBps,
        uint256 _minDeposit,
        uint256 _maxDeposit,
        uint256 _timelockDelay
    ) external initializer {
        if (_admin == address(0)) revert ZeroAddress();
        if (_feeBps > MAX_FEE_BPS) revert InvalidFee(_feeBps);
        if (_minDeposit == 0 || _maxDeposit == 0 || _minDeposit >= _maxDeposit)
            revert InvalidDepositLimits(_minDeposit, _maxDeposit);
        if (_timelockDelay < MIN_TIMELOCK_DELAY || _timelockDelay > MAX_TIMELOCK_DELAY)
            revert InvalidTimelockDelay(_timelockDelay);

        __UUPSUpgradeable_init();
        __Pausable_init();
        __ReentrancyGuard_init();
        __AccessControl_init();

        _grantRole(DEFAULT_ADMIN_ROLE, _admin);
        _grantRole(ADMIN_ROLE, _admin);
        _grantRole(UPGRADER_ROLE, _admin);
        _grantRole(WITHDRAWER_ROLE, _admin);

        feeBps = _feeBps;
        minDepositAmount = _minDeposit;
        maxDepositAmount = _maxDeposit;
        timelockDelay = _timelockDelay;
    }

    // ============ Pause Functions ============

    function pause() external onlyRole(ADMIN_ROLE) {
        _pause();
    }

    function unpause() external onlyRole(ADMIN_ROLE) {
        _unpause();
    }

    // ============ Timelock Proposal Functions ============

    function proposeParameterChange(
        bytes32 _proposalId,
        bytes calldata _data
    ) external onlyRole(ADMIN_ROLE) {
        if (timelockProposals[_proposalId].executionTime != 0)
            revert ProposalAlreadyExists(_proposalId);

        uint256 executionTime = block.timestamp + timelockDelay;

        timelockProposals[_proposalId] = TimelockProposal({
            executionTime: executionTime,
            executed: false,
            cancelled: false,
            data: _data,
            proposer: msg.sender
        });

        emit ParameterChangeProposed(_proposalId, msg.sender, executionTime);
    }

    function cancelProposal(bytes32 _proposalId) external onlyRole(ADMIN_ROLE) {
        TimelockProposal storage proposal = timelockProposals[_proposalId];
        if (proposal.executionTime == 0) revert ProposalDoesNotExist(_proposalId);
        if (proposal.executed) revert ProposalAlreadyExecuted(_proposalId);
        if (proposal.cancelled) revert ProposalAlreadyCancelled(_proposalId);

        proposal.cancelled = true;

        emit ParameterChangeCancelled(_proposalId, msg.sender);
    }

    function _validateAndConsumeProposal(bytes32 _proposalId) internal {
        TimelockProposal storage proposal = timelockProposals[_proposalId];
        if (proposal.executionTime == 0) revert ProposalDoesNotExist(_proposalId);
        if (proposal.executed) revert ProposalAlreadyExecuted(_proposalId);
        if (proposal.cancelled) revert ProposalAlreadyCancelled(_proposalId);
        if (block.timestamp < proposal.executionTime)
            revert ProposalNotReady(_proposalId, proposal.executionTime);

        proposal.executed = true;

        emit ParameterChangeExecuted(_proposalId, msg.sender);
    }

    // ============ Parameter Change Functions (Timelocked) ============

    function executeUpdateFee(
        bytes32 _proposalId,
        uint256 _newFeeBps
    ) external onlyRole(ADMIN_ROLE) {
        _validateAndConsumeProposal(_proposalId);

        if (_newFeeBps > MAX_FEE_BPS) revert InvalidFee(_newFeeBps);

        // Verify the proposal data matches the parameters
        bytes memory expectedData = abi.encode("updateFee", _newFeeBps);
        require(
            keccak256(timelockProposals[_proposalId].data) == keccak256(expectedData),
            "Proposal data mismatch"
        );

        uint256 oldFee = feeBps;
        feeBps = _newFeeBps;

        emit FeeUpdated(oldFee, _newFeeBps);
    }

    function executeUpdateDepositLimits(
        bytes32 _proposalId,
        uint256 _newMin,
        uint256 _newMax
    ) external onlyRole(ADMIN_ROLE) {
        _validateAndConsumeProposal(_proposalId);

        if (_newMin == 0 || _newMax == 0 || _newMin >= _newMax)
            revert InvalidDepositLimits(_newMin, _newMax);

        bytes memory expectedData = abi.encode("updateDepositLimits", _newMin, _newMax);
        require(
            keccak256(timelockProposals[_proposalId].data) == keccak256(expectedData),
            "Proposal data mismatch"
        );

        minDepositAmount = _newMin;
        maxDepositAmount = _newMax;

        emit DepositLimitsUpdated(_newMin, _newMax);
    }

    function executeUpdateTimelockDelay(
        bytes32 _proposalId,
        uint256 _newDelay
    ) external onlyRole(ADMIN_ROLE) {
        _validateAndConsumeProposal(_proposalId);

        if (_newDelay < MIN_TIMELOCK_DELAY || _newDelay > MAX_TIMELOCK_DELAY)
            revert InvalidTimelockDelay(_newDelay);

        bytes memory expectedData = abi.encode("updateTimelockDelay", _newDelay);
        require(
            keccak256(timelockProposals[_proposalId].data) == keccak256(expectedData),
            "Proposal data mismatch"
        );

        uint256 oldDelay = timelockDelay;
        timelockDelay = _newDelay;

        emit TimelockDelayUpdated(oldDelay, _newDelay);
    }

    // ============ Token Allowlist (Operator can manage) ============

    function setTokenAllowlist(
        address _token,
        bool _allowed
    ) external onlyRole(OPERATOR_ROLE) {
        if (_token == address(0)) revert ZeroAddress();

        // Validate it looks like a token contract (basic check)
        uint256 codeSize;
        assembly {
            codeSize := extcodesize(_token)
        }
        require(codeSize > 0, "Not a contract");

        allowlistedTokens[_token] = _allowed;

        emit TokenAllowlistUpdated(_token, _allowed);
    }

    // ============ Deposit Function ============

    function deposit(
        address _token,
        uint256 _amount
    ) external whenNotPaused nonReentrant {
        if (_token == address(0)) revert ZeroAddress();
        if (_amount == 0) revert ZeroAmount();
        if (!allowlistedTokens[_token]) revert TokenNotAllowlisted(_token);
        if (_amount < minDepositAmount) revert DepositBelowMinimum(_amount, minDepositAmount);
        if (_amount > maxDepositAmount) revert DepositAboveMaximum(_amount, maxDepositAmount);

        IERC20Upgradeable(_token).safeTransferFrom(msg.sender, address(this), _amount);

        emit Deposited(msg.sender, _token, _amount);
    }

    // ============ Withdrawal Functions ============

    function withdrawToken(
        address _token,
        address _to,
        uint256 _amount
    ) external onlyRole(WITHDRAWER_ROLE) nonReentrant {
        if (_token == address(0)) revert ZeroAddress();
        if (_to == address(0)) revert ZeroAddress();
        if (_amount == 0) revert ZeroAmount();

        // Enforce withdrawal cooldown per account
        if (block.timestamp < lastWithdrawalTimestamp[msg.sender] + WITHDRAWAL_COOLDOWN)
            revert WithdrawalCooldownActive(
                msg.sender,
                lastWithdrawalTimestamp[msg.sender] + WITHDRAWAL_COOLDOWN
            );

        uint256 balance = IERC20Upgradeable(_token).balanceOf(address(this));
        if (_amount > balance) revert InsufficientBalance(_amount, balance);

        lastWithdrawalTimestamp[msg.sender] = block.timestamp;

        IERC20Upgradeable(_token).safeTransfer(_to, _amount);

        emit FundsWithdrawn(_token, _to, _amount);
    }

    function withdrawETH(
        address payable _to,
        uint256 _amount
    ) external onlyRole(WITHDRAWER_ROLE) nonReentrant {
        if (_to == address(0)) revert ZeroAddress();
        if (_amount == 0) revert ZeroAmount();

        if (block.timestamp < lastWithdrawalTimestamp[msg.sender] + WITHDRAWAL_COOLDOWN)
            revert WithdrawalCooldownActive(
                msg.sender,
                lastWithdrawalTimestamp[msg.sender] + WITHDRAWAL_COOLDOWN
            );

        if (_amount > address(this).balance)
            revert InsufficientBalance(_amount, address(this).balance);

        lastWithdrawalTimestamp[msg.sender] = block.timestamp;

        (bool success, ) = _to.call{value: _amount}("");
        if (!success) revert ETHTransferFailed();

        emit ETHWithdrawn(_to, _amount);
    }

    // ============ Emergency Functions ============

    function emergencyWithdrawToken(
        address _token,
        address _to
    ) external onlyRole(DEFAULT_ADMIN_ROLE) whenPaused nonReentrant {
        if (_token == address(0)) revert ZeroAddress();
        if (_to == address(0)) revert ZeroAddress();

        uint256 balance = IERC20Upgradeable(_token).balanceOf(address(this));
        if (balance == 0) revert ZeroAmount();

        IERC20Upgradeable(_token).safeTransfer(_to, balance);

        emit FundsWithdrawn(_token, _to, balance);
    }

    function emergencyWithdrawETH(
        address payable _to
    ) external onlyRole(DEFAULT_ADMIN_ROLE) whenPaused nonReentrant {
        if (_to == address(0)) revert ZeroAddress();

        uint256 balance = address(this).balance;
        if (balance == 0) revert ZeroAmount();

        (bool success, ) = _to.call{value: balance}("");
        if (!success) revert ETHTransferFailed();

        emit ETHWithdrawn(_to, balance);
    }

    // ============ View Functions ============

    function getProposal(bytes32 _proposalId) external view returns (TimelockProposal memory) {
        return timelockProposals[_proposalId];
    }

    function isProposalReady(bytes32 _proposalId) external view returns (bool) {
        TimelockProposal storage proposal = timelockProposals[_proposalId];
        return
            proposal.executionTime != 0 &&
            !proposal.executed &&
            !proposal.cancelled &&
            block.timestamp >= proposal.executionTime;
    }

    function getContractBalance(address _token) external view returns (uint256) {
        if (_token == address(0)) {
            return address(this).balance;
        }
        return IERC20Upgradeable(_token).balanceOf(address(this));
    }

    // ============ UUPS Upgrade Authorization ============

    function _authorizeUpgrade(
        address newImplementation
    ) internal override onlyRole(UPGRADER_ROLE) {
