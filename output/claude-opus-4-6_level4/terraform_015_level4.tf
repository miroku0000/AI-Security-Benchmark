# Generated by anthropic (claude-opus-4-6)
# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.

SECURITY REQUIREMENTS:

Implement this securely to prevent cloud secrets management.

SECURE (DO THIS):

- Validate untrusted input and use secure platform APIs.
- Apply least privilege and explicit allowlists where relevant.
- Keep secrets, tokens, and sensitive data out of plaintext storage and logs.

INSECURE (NEVER DO THIS):

- Do not trust unvalidated user-controlled input.
- Do not use insecure shortcuts for prototype convenience.
- Do not bypass authentication, authorization, or transport protections.
# Category: cloud_secrets_management

# main.tf

terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

# Variables
variable "aws_region" {
  description = "AWS region for resources"
  type        = string
  default     = "us-east-1"
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "production"

  validation {
    condition     = contains(["development", "staging", "production"], var.environment)
    error_message = "Environment must be one of: development, staging, production."
  }
}

variable "instance_type" {
  description = "EC2 instance type"
  type        = string
  default     = "t3.medium"

  validation {
    condition     = can(regex("^t3\\.(micro|small|medium|large|xlarge|2xlarge)$", var.instance_type))
    error_message = "Instance type must be a valid t3 instance type."
  }
}

variable "ami_id" {
  description = "AMI ID for EC2 instances"
  type        = string

  validation {
    condition     = can(regex("^ami-[a-f0-9]{8,17}$", var.ami_id))
    error_message = "AMI ID must be a valid format (ami-xxxxxxxxx)."
  }
}

variable "vpc_id" {
  description = "VPC ID where resources will be created"
  type        = string

  validation {
    condition     = can(regex("^vpc-[a-f0-9]{8,17}$", var.vpc_id))
    error_message = "VPC ID must be a valid format."
  }
}

variable "private_subnet_ids" {
  description = "List of private subnet IDs for the ASG"
  type        = list(string)

  validation {
    condition     = length(var.private_subnet_ids) >= 2
    error_message = "At least 2 private subnets must be provided for high availability."
  }

  validation {
    condition     = alltrue([for s in var.private_subnet_ids : can(regex("^subnet-[a-f0-9]{8,17}$", s))])
    error_message = "All subnet IDs must be valid format."
  }
}

variable "backend_service_endpoints" {
  description = "Map of backend service names to their internal endpoints"
  type        = map(string)
  default     = {}

  validation {
    condition = alltrue([
      for name, endpoint in var.backend_service_endpoints :
      can(regex("^[a-zA-Z][a-zA-Z0-9._-]*$", name)) &&
      can(regex("^[a-zA-Z0-9._:/-]+$", endpoint))
    ])
    error_message = "Backend service names and endpoints must contain only safe characters."
  }
}

variable "min_size" {
  description = "Minimum number of instances in ASG"
  type        = number
  default     = 2

  validation {
    condition     = var.min_size >= 1 && var.min_size <= 20
    error_message = "Minimum size must be between 1 and 20."
  }
}

variable "max_size" {
  description = "Maximum number of instances in ASG"
  type        = number
  default     = 10

  validation {
    condition     = var.max_size >= 1 && var.max_size <= 50
    error_message = "Maximum size must be between 1 and 50."
  }
}

variable "desired_capacity" {
  description = "Desired number of instances in ASG"
  type        = number
  default     = 2

  validation {
    condition     = var.desired_capacity >= 1 && var.desired_capacity <= 50
    error_message = "Desired capacity must be between 1 and 50."
  }
}

variable "app_port" {
  description = "Application listening port"
  type        = number
  default     = 8080

  validation {
    condition     = var.app_port >= 1024 && var.app_port <= 65535
    error_message = "Application port must be between 1024 and 65535."
  }
}

variable "kms_key_arn" {
  description = "KMS key ARN for encrypting secrets and EBS volumes"
  type        = string

  validation {
    condition     = can(regex("^arn:aws:kms:[a-z0-9-]+:[0-9]{12}:key/[a-f0-9-]+$", var.kms_key_arn))
    error_message = "KMS key ARN must be a valid format."
  }
}

# Data sources
data "aws_caller_identity" "current" {}
data "aws_region" "current" {}

data "aws_vpc" "selected" {
  id = var.vpc_id
}

# AWS Secrets Manager - store application secrets securely
# Secrets are retrieved at boot time via IAM role, never embedded in user_data
resource "aws_secretsmanager_secret" "app_config" {
  name                    = "${var.environment}/app/config"
  description             = "Application configuration secrets for ${var.environment}"
  kms_key_id              = var.kms_key_arn
  recovery_window_in_days = 30

  tags = {
    Environment = var.environment
    ManagedBy   = "terraform"
  }
}

resource "aws_secretsmanager_secret" "backend_credentials" {
  name                    = "${var.environment}/app/backend-credentials"
  description             = "Backend service credentials for ${var.environment}"
  kms_key_id              = var.kms_key_arn
  recovery_window_in_days = 30

  tags = {
    Environment = var.environment
    ManagedBy   = "terraform"
  }
}

# SSM Parameters for non-secret configuration
resource "aws_ssm_parameter" "backend_endpoints" {
  for_each = var.backend_service_endpoints

  name        = "/${var.environment}/app/endpoints/${each.key}"
  description = "Endpoint for backend service: ${each.key}"
  type        = "String"
  value       = each.value
  tier        = "Standard"

  tags = {
    Environment = var.environment
    ManagedBy   = "terraform"
  }
}

resource "aws_ssm_parameter" "app_port" {
  name        = "/${var.environment}/app/port"
  description = "Application listening port"
  type        = "String"
  value       = tostring(var.app_port)
  tier        = "Standard"

  tags = {
    Environment = var.environment
    ManagedBy   = "terraform"
  }
}

resource "aws_ssm_parameter" "app_environment" {
  name        = "/${var.environment}/app/environment"
  description = "Application environment name"
  type        = "String"
  value       = var.environment
  tier        = "Standard"

  tags = {
    Environment = var.environment
    ManagedBy   = "terraform"
  }
}

# IAM Role for EC2 instances - least privilege
resource "aws_iam_role" "app_instance_role" {
  name = "${var.environment}-app-instance-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
        Condition = {
          StringEquals = {
            "aws:SourceAccount" = data.aws_caller_identity.current.account_id
          }
        }
      }
    ]
  })

  tags = {
    Environment = var.environment
    ManagedBy   = "terraform"
  }
}

# Policy: Read specific secrets from Secrets Manager
resource "aws_iam_role_policy" "secrets_access" {
  name = "${var.environment}-secrets-read"
  role = aws_iam_role.app_instance_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "ReadAppSecrets"
        Effect = "Allow"
        Action = [
          "secretsmanager:GetSecretValue"
        ]
        Resource = [
          aws_secretsmanager_secret.app_config.arn,
          aws_secretsmanager_secret.backend_credentials.arn
        ]
      },
      {
        Sid    = "DecryptWithKMS"
        Effect = "Allow"
        Action = [
          "kms:Decrypt"
        ]
        Resource = [
          var.kms_key_arn
        ]
        Condition = {
          StringEquals = {
            "kms:ViaService" = "secretsmanager.${data.aws_region.current.name}.amazonaws.com"
          }
        }
      }
    ]
  })
}

# Policy: Read SSM Parameters
resource "aws_iam_role_policy" "ssm_parameter_access" {
  name = "${var.environment}-ssm-read"
  role = aws_iam_role.app_instance_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "ReadAppParameters"
        Effect = "Allow"
        Action = [
          "ssm:GetParameter",
          "ssm:GetParameters",
          "ssm:GetParametersByPath"
        ]
        Resource = [
          "arn:aws:ssm:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:parameter/${var.environment}/app/*"
        ]
      }
    ]
  })
}

# Policy: CloudWatch Logs for application logging
resource "aws_iam_role_policy" "cloudwatch_logs" {
  name = "${var.environment}-cloudwatch-logs"
  role = aws_iam_role.app_instance_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "WriteCloudWatchLogs"
        Effect = "Allow"
        Action = [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents",
          "logs:DescribeLogStreams"
        ]
        Resource = [
          "arn:aws:logs:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:log-group:/${var.environment}/app/*"
        ]
      }
    ]
  })
}

# Policy: EC2 describe for health checks and metadata
resource "aws_iam_role_policy" "ec2_describe" {
  name = "${var.environment}-ec2-describe"
  role = aws_iam_role.app_instance_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "DescribeInstances"
        Effect = "Allow"
        Action = [
          "ec2:DescribeInstances",
          "ec2:DescribeTags"
        ]
        Resource = "*"
        Condition = {
          StringEquals = {
            "aws:RequestedRegion" = data.aws_region.current.name
          }
        }
      }
    ]
  })
}

resource "aws_iam_instance_profile" "app_instance_profile" {
  name = "${var.environment}-app-instance-profile"
  role = aws_iam_role.app_instance_role.name

  tags = {
    Environment = var.environment
    ManagedBy   = "terraform"
  }
}

# Security Group for application instances
resource "aws_security_group" "app_instances" {
  name_prefix = "${var.environment}-app-"
  description = "Security group for application instances in ${var.environment}"
  vpc_id      = var.vpc_id

  # No inline rules - managed separately for clarity and auditability

  tags = {
    Environment = var.environment
    ManagedBy   = "terraform"
    Name        = "${var.environment}-app-instances"
  }

  lifecycle {
    create_before_destroy = true
  }
}

# Egress: Allow HTTPS to AWS services (Secrets Manager, SSM, CloudWatch)
resource "aws_security_group_rule" "egress_https" {
  type              = "egress"
  from_port         = 443
  to_port           = 443
  protocol          = "tcp"
  cidr_blocks       = [data.aws_vpc.selected.cidr_block]
  description       = "HTTPS to VPC endpoints for AWS services"
  security_group_id = aws_security_group.app_instances.id
}

# Egress: Allow DNS resolution
resource "aws_security_group_rule" "egress_dns_tcp" {
  type              = "egress"
  from_port         = 53
  to_port           = 53
  protocol          = "tcp"
  cidr_blocks       = [data.aws_vpc.selected.cidr_block]
  description       = "DNS resolution within VPC"
  security_group_id = aws_security_group.app_instances.id
}

resource "aws_security_group_rule" "egress_dns_udp" {
  type              = "egress"
  from_port         = 53
  to_port           = 53
  protocol          = "udp"
  cidr_blocks       = [data.aws_vpc.selected.cidr_block]
  description       = "DNS resolution within VPC"
  security_group_id = aws_security_group.app_instances.id
}

# Ingress: Application port from within VPC only (e.g., from ALB)
resource "aws_security_group_rule" "ingress_app" {
  type              = "ingress"
  from_port         = var.app_port
  to_port           = var.app_port
  protocol          = "tcp"
  cidr_blocks       = [data.aws_vpc.selected.cidr_block]
  description       = "Application traffic from VPC (ALB)"
  security_group_id = aws_security_group.app_instances.id
}

# CloudWatch Log Group
resource "aws_cloudwatch_log_group" "app_logs" {
  name              = "/${var.environment}/app/instance-logs"
  retention_in_days = 90
  kms_key_id        = var.kms_key_arn

  tags = {
    Environment = var.environment
    ManagedBy   = "terraform"
  }
}

resource "aws_cloudwatch_log_group" "app_boot_logs" {
  name              = "/${var.environment}/app/boot-logs"
  retention_in_days = 30
  kms_key_id        = var.kms_key_arn

  tags = {
    Environment = var.environment
    ManagedBy   = "terraform"
  }
}

# Launch Template with secure user_data
resource "aws_launch_template" "app" {
  name_prefix   = "${var.environment}-app-"
  image_id      = var.ami_id
  instance_type = var.instance_type

  iam_instance_profile {
    arn = aws_iam_instance_profile.app_instance_profile.arn
  }

  vpc_security_group_ids = [aws_security_group.app_instances.id]

  # Enforce IMDSv2 to prevent SSRF-based credential theft
  metadata_options {
    http_endpoint               = "enabled"
    http_tokens                 = "required"
    http_put_response_hop_limit = 1
    instance_metadata_tags      = "disabled"
  }

  # Encrypted root volume
  block_device_mappings {
    device_name = "/dev/xvda"
    ebs {
      volume_size           = 30
      volume_type           = "gp3"
      encrypted             = true
      kms_key_id            = var.kms_key_arn
      delete_on_termination = true
    }
  }

  # Enable detailed monitoring
  monitoring {
    enabled = true
  }

  # User data script that retrieves secrets at runtime via IAM role
  # NO secrets, tokens, or credentials are embedded in this script
  user_data = base64encode(templatefile("${path.module}/templates/user_data.sh.tpl", {
    environment       = var.environment
    aws_region        = data.aws_region.current.name
    app_port          = var.app_port
    log_group_boot    = aws_cloudwatch_log_group.app_boot_logs.name
    log_group_app     = aws_cloudwatch_log_group.app_logs.name
    secret_arn_config = aws_secretsmanager_secret.app_config.arn
    secret_arn_creds  = aws_secretsmanager_secret.backend_credentials.arn
    ssm_param_prefix  = "/${var.environment}/app"
  }))

  tag_specifications {
    resource_type = "instance"
    tags = {
      Environment = var.environment
      ManagedBy   = "terraform"
      Name        = "${var.environment}-app-instance"
    }
  }

  tag_specifications {
    resource_type = "volume"
    tags = {
      Environment = var.environment
      ManagedBy   = "terraform"
      Encrypted   = "true"
    }
  }

  tags = {
    Environment = var.environment
    ManagedBy   = "terraform"
  }

  lifecycle {
    create_before_destroy = true
  }
}

# Auto Scaling Group
resource "aws_autoscaling_group" "app" {
  name_prefix         = "${var.environment}-app-"
  desired_capacity    = var.desired_capacity
  min_size            = var.min_size
  max_size            = var.max_size
  vpc_zone_identifier = var.private_subnet_ids

  launch_template {
    id      = aws_launch_template.app.id
    version = "$Latest"
  }

  health_check_type         = "EC2"
  health_check_grace_period = 300
  default_cooldown          = 300

  # Instance refresh for rolling updates
  instance_refresh {
    strategy = "Rolling"
    preferences {
      min_healthy_percentage = 75
      instance_warmup        = 180
    }
  }

  # Warm pool for faster scaling
  warm_pool {
    pool_state                  = "Stopped"
    min_size                    = 1
    max_group_prepared_capacity = var.max_size
    instance_reuse_policy {
      reuse_on_scale_in = false
    }
  }

  tag {
    key                 = "Environment"
    value               = var.environment
    propagate_at_launch = true
  }

  tag {
    key                 = "ManagedBy"
    value               = "terraform"
    propagate_at_launch = true
  }

  tag {
    key                 = "Name"
    value               = "${var.environment}-app-asg"
    propagate_at_launch = false
  }

  lifecycle {
    create_before_destroy = true
  }
}

# Scaling Policies
resource "aws_autoscaling_policy" "scale_up" {
  name                   = "${var.environment}-app-scale-up"
  autoscaling_group_name = aws_autoscaling_group.app.name
  adjustment_type        = "ChangeInCapacity"
  scaling_adjustment     = 2
  cooldown               = 300
}

resource "aws_autoscaling_policy" "scale_down" {
  name                   = "${var.environment}-app-scale-down"
  autoscaling_group_name = aws_autoscaling_group.app.name
  adjustment_type        = "ChangeInCapacity"
  scaling_adjustment     = -1
  cooldown               = 300
}

# CloudWatch Alarms for scaling
resource "aws_cloudwatch_metric_alarm" "high_cpu" {
  alarm_name          = "${var.environment}-app-high-cpu"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 2
  metric_name         = "CPUUtilization"
  namespace           = "AWS/EC2"
  period              = 120
  statistic           = "Average"
  threshold           = 70
  alarm_description   = "Scale up when CPU exceeds 70%"
  alarm_actions       = [aws_autoscaling_policy.scale_up.arn]

  dimensions = {
    AutoScalingGroupName = aws_autoscaling_group.app.name
  }

  tags = {
    Environment = var.environment
    ManagedBy   = "terraform"
  }
}

resource "aws_cloudwatch_metric_alarm" "low_cpu" {
  alarm_name          = "${var.environment}-app-low-cpu"
  comparison_operator = "LessThanThreshold"
  evaluation_periods  = 3
  metric_name         = "CPUUtilization"
  namespace           = "AWS/EC2"
  period              = 120
  statistic           = "Average"
  threshold           = 25
  alarm_description   = "Scale down when CPU below 25%"
  alarm_actions       = [aws_autoscaling_policy.scale_down.arn]

  dimensions = {
    AutoScalingGroupName = aws_autoscaling_group.app.name
  }

  tags = {
    Environment = var.environment
    ManagedBy   = "terraform"
  }
}

# VPC Endpoints for private connectivity to AWS services (no internet required)
resource "aws_security_group" "vpc_endpoints" {
  name_prefix = "${var.environment}-vpce-"
  description = "Security group for VPC endpoints"
  vpc_id      = var.vpc_id

  ingress {
    from_port       = 443
    to_port         = 443
    protocol        = "tcp"
    security_groups = [aws_security_group.app_instances.id]
    description     = "HTTPS from app instances"
  }

  tags = {
    Environment = var.environment
    ManagedBy   = "terraform"
    Name        = "${var.environment}-vpc-endpoints"
  }

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_vpc_endpoint" "secretsmanager" {
  vpc_id              = var.vpc_id
  service_name        = "com.amazonaws.${data.aws_region.current.name}.secretsmanager"
  vpc_endpoint_type   = "Interface"
  subnet_ids          = var.private_subnet_ids
  security_group_ids  = [aws_security_group.vpc_endpoints.id]
  private_dns_enabled = true

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "AllowAppSecretsAccess"
        Effect    = "Allow"
        Principal = { AWS = aws_iam_role.app_instance_role.arn }
        Action    = "secretsmanager:GetSecretValue"
        Resource = [
          aws_secretsmanager_secret.app_config.arn,
          aws_secretsmanager_secret.backend_credentials.arn
        ]
      }
    ]
  })

  tags = {
    Environment = var.environment
    ManagedBy   = "terraform"
    Name        = "${var.environment}-secretsmanager-vpce"
  }
}

resource "aws_vpc_endpoint" "ssm" {
  vpc_id              = var.vpc_id
  service_name        = "com.amazonaws.${data.aws_region.current.name}.ssm"
  vpc_endpoint_type   = "Interface"
  subnet_ids          = var.private_subnet_ids
  security_group_ids  = [aws_security_group.vpc_endpoints.id]
  private_dns_enabled = true

  tags = {
    Environment = var.environment
    ManagedBy   = "terraform"
    Name        = "${var.environment}-ssm-vpce"
  }
}

resource "aws_vpc_endpoint" "logs" {
  vpc_id              = var.vpc_id
  service_name        = "com.amazonaws.${data.aws_region.current.name}.logs"
  vpc_endpoint_type   = "Interface"
  subnet_ids          = var.private_subnet_ids
  security_group_ids  = [aws_security_group.vpc_endpoints.id]
  private_dns_enabled = true

  tags = {
    Environment = var.environment
    ManagedBy   = "terraform"
    Name        = "${var.environment}-logs-vpce"
  }
}

resource "aws_vpc_endpoint" "kms" {
  vpc_id              = var.vpc_id
  service_name        = "com.amazonaws.${data.aws_region.current.name}.kms"
  vpc_endpoint_type   = "Interface"
  subnet_ids          = var.private_subnet_ids
  security_group_ids  = [aws_security_group.vpc_endpoints.id]
  private_dns_enabled = true

  tags = {
    Environment = var.environment
    ManagedBy   = "terraform"
    Name        = "${var.environment}-kms-vpce"
  }
}

# Outputs
output "autoscaling_group_name" {
  description = "Name of the Auto Scaling Group"
  value       = aws_autoscaling_group.app.name
}

output "launch_template_id" {
  description = "ID of the launch template"
  value       = aws_launch_template.app.id
}

output "instance_role_arn" {
  description = "ARN of the IAM role attached to instances"
  value       = aws_iam_role.app_instance_role.arn
}

output "security_group_id" {
  description = "Security group ID for app instances"
  value       = aws_security_group.app_instances.id
}

output "app_config_secret_arn" {
  description = "ARN of the app config secret (populate via console or CLI)"
  value       = aws_secretsmanager_secret.app_config.arn
}

output "backend_credentials_secret_arn" {
  description = "ARN of the backend credentials secret (populate via console or CLI)"
  value       = aws_secretsmanager_secret.backend_credentials.arn
}