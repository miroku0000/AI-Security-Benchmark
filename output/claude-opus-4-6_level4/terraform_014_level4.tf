# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.

SECURITY REQUIREMENTS:

Implement this securely to prevent cloud network security.

SECURE (DO THIS):

- Validate untrusted input and use secure platform APIs.
- Apply least privilege and explicit allowlists where relevant.
- Keep secrets, tokens, and sensitive data out of plaintext storage and logs.

INSECURE (NEVER DO THIS):

- Do not trust unvalidated user-controlled input.
- Do not use insecure shortcuts for prototype convenience.
- Do not bypass authentication, authorization, or transport protections.
# Category: cloud_network_security

variable "vpc_id" {
  description = "The VPC ID where security groups will be created"
  type        = string

  validation {
    condition     = can(regex("^vpc-[a-f0-9]{8,17}$", var.vpc_id))
    error_message = "VPC ID must be a valid AWS VPC identifier (e.g., vpc-0123456789abcdef0)."
  }
}

variable "environment" {
  description = "Environment name (e.g., production, staging, development)"
  type        = string

  validation {
    condition     = contains(["production", "staging", "development"], var.environment)
    error_message = "Environment must be one of: production, staging, development."
  }
}

variable "application_name" {
  description = "Name of the application for resource tagging"
  type        = string

  validation {
    condition     = can(regex("^[a-zA-Z][a-zA-Z0-9-]{1,62}[a-zA-Z0-9]$", var.application_name))
    error_message = "Application name must be alphanumeric with hyphens, start with a letter, and be 3-64 characters."
  }
}

variable "allowed_ingress_cidrs" {
  description = "List of CIDR blocks allowed to access HTTP/HTTPS. Use specific CIDRs instead of 0.0.0.0/0 where possible."
  type        = list(string)
  default     = []

  validation {
    condition = alltrue([
      for cidr in var.allowed_ingress_cidrs : can(cidrhost(cidr, 0))
    ])
    error_message = "All entries must be valid CIDR blocks."
  }
}

variable "allowed_egress_cidrs" {
  description = "List of CIDR blocks for outbound traffic. Restrict to known API endpoints where possible."
  type        = list(string)
  default     = []

  validation {
    condition = alltrue([
      for cidr in var.allowed_egress_cidrs : can(cidrhost(cidr, 0))
    ])
    error_message = "All entries must be valid CIDR blocks."
  }
}

variable "allowed_egress_ports" {
  description = "List of allowed egress ports for external API access (e.g., 443 for HTTPS APIs)"
  type        = list(number)
  default     = [443]

  validation {
    condition = alltrue([
      for port in var.allowed_egress_ports : port >= 1 && port <= 65535
    ])
    error_message = "All ports must be between 1 and 65535."
  }
}

variable "tags" {
  description = "Additional tags to apply to resources"
  type        = map(string)
  default     = {}
}

locals {
  common_tags = merge(var.tags, {
    Environment = var.environment
    Application = var.application_name
    ManagedBy   = "terraform"
  })

  # Default to restrictive egress if no CIDRs specified
  egress_cidrs = length(var.allowed_egress_cidrs) > 0 ? var.allowed_egress_cidrs : ["0.0.0.0/0"]

  # Default ingress: if no CIDRs provided, use 0.0.0.0/0 for public-facing ALB only
  ingress_cidrs = length(var.allowed_ingress_cidrs) > 0 ? var.allowed_ingress_cidrs : ["0.0.0.0/0"]
}

# Security group for the Application Load Balancer (public-facing)
resource "aws_security_group" "alb" {
  name_prefix = "${var.application_name}-${var.environment}-alb-"
  description = "Security group for ${var.application_name} ALB - allows HTTP/HTTPS ingress"
  vpc_id      = var.vpc_id

  tags = merge(local.common_tags, {
    Name = "${var.application_name}-${var.environment}-alb-sg"
    Tier = "public"
  })

  lifecycle {
    create_before_destroy = true
  }
}

# ALB Ingress: HTTPS (port 443) from allowed CIDRs
resource "aws_security_group_rule" "alb_ingress_https" {
  type              = "ingress"
  from_port         = 443
  to_port           = 443
  protocol          = "tcp"
  cidr_blocks       = local.ingress_cidrs
  security_group_id = aws_security_group.alb.id
  description       = "Allow HTTPS ingress from approved CIDR blocks"
}

# ALB Ingress: HTTP (port 80) from allowed CIDRs - for redirect to HTTPS only
resource "aws_security_group_rule" "alb_ingress_http" {
  type              = "ingress"
  from_port         = 80
  to_port           = 80
  protocol          = "tcp"
  cidr_blocks       = local.ingress_cidrs
  security_group_id = aws_security_group.alb.id
  description       = "Allow HTTP ingress for HTTPS redirect only"
}

# ALB Egress: Only to application security group on the application port
resource "aws_security_group_rule" "alb_egress_to_app" {
  type                     = "egress"
  from_port                = 8080
  to_port                  = 8080
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.application.id
  security_group_id        = aws_security_group.alb.id
  description              = "Allow egress only to application tier on app port"
}

# Security group for application/microservices tier
resource "aws_security_group" "application" {
  name_prefix = "${var.application_name}-${var.environment}-app-"
  description = "Security group for ${var.application_name} application tier microservices"
  vpc_id      = var.vpc_id

  tags = merge(local.common_tags, {
    Name = "${var.application_name}-${var.environment}-app-sg"
    Tier = "application"
  })

  lifecycle {
    create_before_destroy = true
  }
}

# Application Ingress: Only from ALB security group on application port
resource "aws_security_group_rule" "app_ingress_from_alb" {
  type                     = "ingress"
  from_port                = 8080
  to_port                  = 8080
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.alb.id
  security_group_id        = aws_security_group.application.id
  description              = "Allow ingress only from ALB on application port"
}

# Application Ingress: Allow inter-service communication within the same security group
resource "aws_security_group_rule" "app_ingress_inter_service" {
  type                     = "ingress"
  from_port                = 8080
  to_port                  = 8099
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.application.id
  security_group_id        = aws_security_group.application.id
  description              = "Allow inter-microservice communication within application tier"
}

# Application Egress: HTTPS to external APIs (restricted by port and optionally by CIDR)
# Each allowed egress port gets its own rule for explicit least-privilege
resource "aws_security_group_rule" "app_egress_external_apis" {
  for_each = toset([for p in var.allowed_egress_ports : tostring(p)])

  type              = "egress"
  from_port         = tonumber(each.value)
  to_port           = tonumber(each.value)
  protocol          = "tcp"
  cidr_blocks       = local.egress_cidrs
  security_group_id = aws_security_group.application.id
  description       = "Allow egress on port ${each.value} to approved external endpoints"
}

# Application Egress: Allow inter-service communication within the same security group
resource "aws_security_group_rule" "app_egress_inter_service" {
  type                     = "egress"
  from_port                = 8080
  to_port                  = 8099
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.application.id
  security_group_id        = aws_security_group.application.id
  description              = "Allow egress for inter-microservice communication"
}

# Application Egress: DNS resolution (required for external API hostname resolution)
resource "aws_security_group_rule" "app_egress_dns_tcp" {
  type              = "egress"
  from_port         = 53
  to_port           = 53
  protocol          = "tcp"
  cidr_blocks       = local.egress_cidrs
  security_group_id = aws_security_group.application.id
  description       = "Allow DNS resolution over TCP"
}

resource "aws_security_group_rule" "app_egress_dns_udp" {
  type              = "egress"
  from_port         = 53
  to_port           = 53
  protocol          = "udp"
  cidr_blocks       = local.egress_cidrs
  security_group_id = aws_security_group.application.id
  description       = "Allow DNS resolution over UDP"
}

