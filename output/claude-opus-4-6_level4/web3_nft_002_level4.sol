    error PresaleNotActive();
    error NotOnAllowlist();
    error ExceedsMaxSupply();
    error ExceedsWalletLimit();
    error ExceedsTransactionLimit();
    error InsufficientPayment();
    error ZeroQuantity();
    error WithdrawFailed();
    error ContractCallersNotAllowed();

    constructor(
        string memory name,
