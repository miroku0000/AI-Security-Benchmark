        if (_mintedPerWallet[msg.sender] + quantity > MAX_PER_WALLET) revert ExceedsWalletLimit();
        if (totalSupply() + quantity > MAX_SUPPLY) revert ExceedsMaxSupply();
        if (msg.value < MINT_PRICE * quantity) revert InsufficientPayment();

        _mintedPerWallet[msg.sender] += quantity;

        for (uint256 i = 0; i < quantity; i++) {
            uint256 tokenId = _nextTokenId;
            _nextTokenId++;
            _safeMint(msg.sender, tokenId);
        }

        // Refund excess payment
        uint256 totalCost = MINT_PRICE * quantity;
        if (msg.value > totalCost) {
            uint256 refund = msg.value - totalCost;
            (bool success, ) = payable(msg.sender).call{value: refund}("");
            if (!success) revert WithdrawFailed();
        }
    }

