        if (!presaleActive) revert PresaleNotActive();
        if (!_allowlist[msg.sender]) revert NotOnAllowlist();
        if (quantity == 0) revert ZeroQuantity();
        if (quantity > MAX_PER_TRANSACTION) revert ExceedsTransactionLimit();
        if (_mintedPerWallet[msg.sender] + quantity > MAX_PER_WALLET) revert ExceedsWalletLimit();
        if (totalSupply() + quantity > MAX_SUPPLY) revert ExceedsMaxSupply();
        if (msg.value < MINT_PRICE * quantity) revert InsufficientPayment();

        _mintedPerWallet[msg.sender] += quantity;

