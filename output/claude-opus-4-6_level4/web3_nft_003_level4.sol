pragma solidity ^0.8.20;

import "@openzeppelin/contracts/token/ERC721/IERC721.sol";
import "@openzeppelin/contracts/interfaces/IERC2981.sol";
import "@openzeppelin/contracts/utils/ReentrancyGuard.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/introspection/ERC165Checker.sol";

contract NFTMarketplace is ReentrancyGuard, Ownable {
    using ERC165Checker for address;

    struct Listing {
        address seller;
        address nftContract;
        uint256 tokenId;
        uint256 price;
        bool active;
    }

    uint256 private _listingIdCounter;
    uint256 public platformFeeBps; // basis points (e.g., 250 = 2.5%)
    uint256 public constant MAX_PLATFORM_FEE_BPS = 1000; // 10% max
    uint256 public constant MAX_ROYALTY_BPS = 5000; // 50% max sanity check
    uint256 public constant BASIS_POINTS = 10000;

    mapping(uint256 => Listing) public listings;
    mapping(address => bool) public allowlistedNFTContracts;
    mapping(address => uint256) private pendingWithdrawals;

    event NFTListed(
        uint256 indexed listingId,
        address indexed seller,
        address indexed nftContract,
        uint256 tokenId,
        uint256 price
    );
    event NFTSold(
        uint256 indexed listingId,
        address indexed buyer,
        address indexed seller,
        address nftContract,
        uint256 tokenId,
        uint256 price,
        uint256 royaltyAmount,
        address royaltyReceiver
    );
    event ListingCancelled(uint256 indexed listingId);
    event NFTContractAllowlisted(address indexed nftContract, bool allowed);
    event PlatformFeeUpdated(uint256 newFeeBps);
    event Withdrawal(address indexed account, uint256 amount);

    error NotTokenOwner();
    error NotApproved();
    error PriceZero();
    error ListingNotActive();
    error NotListingSeller();
    error InsufficientPayment();
    error NFTContractNotAllowlisted();
    error InvalidAddress();
    error FeeTooHigh();
    error WithdrawalFailed();
    error NoFundsToWithdraw();
    error RoyaltyExceedsMax();
    error InvalidRoyaltyReceiver();
    error TransferToSellerFailed();

    constructor(uint256 _platformFeeBps) Ownable(msg.sender) {
        if (_platformFeeBps > MAX_PLATFORM_FEE_BPS) revert FeeTooHigh();
        platformFeeBps = _platformFeeBps;
    }

    modifier onlyAllowlistedContract(address nftContract) {
        if (!allowlistedNFTContracts[nftContract]) revert NFTContractNotAllowlisted();
        _;
    }

    function setAllowlistedNFTContract(address nftContract, bool allowed) external onlyOwner {
        if (nftContract == address(0)) revert InvalidAddress();
        // Verify it supports ERC721 interface
        if (allowed) {
            require(
                nftContract.supportsInterface(type(IERC721).interfaceId),
                "Not a valid ERC721 contract"
            );
        }
        allowlistedNFTContracts[nftContract] = allowed;
        emit NFTContractAllowlisted(nftContract, allowed);
    }

    function setPlatformFee(uint256 _platformFeeBps) external onlyOwner {
        if (_platformFeeBps > MAX_PLATFORM_FEE_BPS) revert FeeTooHigh();
        platformFeeBps = _platformFeeBps;
        emit PlatformFeeUpdated(_platformFeeBps);
    }

    function listNFT(
        address nftContract,
        uint256 tokenId,
        uint256 price
    ) external nonReentrant onlyAllowlistedContract(nftContract) returns (uint256) {
        if (price == 0) revert PriceZero();

        IERC721 nft = IERC721(nftContract);

        // Verify caller is the actual owner of the token
        if (nft.ownerOf(tokenId) != msg.sender) revert NotTokenOwner();

        // Verify marketplace is approved to transfer the NFT
        if (
            nft.getApproved(tokenId) != address(this) &&
            !nft.isApprovedForAll(msg.sender, address(this))
        ) revert NotApproved();

        uint256 listingId = _listingIdCounter;
        _listingIdCounter++;

        listings[listingId] = Listing({
            seller: msg.sender,
            nftContract: nftContract,
            tokenId: tokenId,
            price: price,
            active: true
        });

        emit NFTListed(listingId, msg.sender, nftContract, tokenId, price);
        return listingId;
    }

    function cancelListing(uint256 listingId) external nonReentrant {
        Listing storage listing = listings[listingId];
        if (!listing.active) revert ListingNotActive();
        if (listing.seller != msg.sender) revert NotListingSeller();

        listing.active = false;
        emit ListingCancelled(listingId);
    }

    function buyNFT(uint256 listingId) external payable nonReentrant {
        Listing storage listing = listings[listingId];
        if (!listing.active) revert ListingNotActive();
        if (msg.value < listing.price) revert InsufficientPayment();

        address seller = listing.seller;
        address nftContract = listing.nftContract;
        uint256 tokenId = listing.tokenId;
        uint256 price = listing.price;

        // Mark as inactive before any external calls (checks-effects-interactions)
        listing.active = false;

        IERC721 nft = IERC721(nftContract);

        // Re-verify seller still owns the NFT and marketplace is still approved
        if (nft.ownerOf(tokenId) != seller) revert NotTokenOwner();
        if (
            nft.getApproved(tokenId) != address(this) &&
            !nft.isApprovedForAll(seller, address(this))
        ) revert NotApproved();

        // Calculate platform fee
        uint256 platformFee = (price * platformFeeBps) / BASIS_POINTS;

        // Calculate royalty using ERC-2981 - enforced on-chain, cannot be bypassed
        uint256 royaltyAmount = 0;
        address royaltyReceiver = address(0);

        if (nftContract.supportsInterface(type(IERC2981).interfaceId)) {
            (royaltyReceiver, royaltyAmount) = IERC2981(nftContract).royaltyInfo(tokenId, price);

            // Sanity checks on royalty to prevent malicious contracts from draining funds
            if (royaltyAmount > (price * MAX_ROYALTY_BPS) / BASIS_POINTS) {
                revert RoyaltyExceedsMax();
            }

            // Validate royalty receiver is not zero address if royalty is non-zero
            if (royaltyAmount > 0 && royaltyReceiver == address(0)) {
                revert InvalidRoyaltyReceiver();
            }

            // Ensure royalty + platform fee don't exceed the sale price
            if (royaltyAmount + platformFee > price) {
                revert RoyaltyExceedsMax();
            }
        }

        // Calculate seller proceeds
        uint256 sellerProceeds = price - platformFee - royaltyAmount;

        // Transfer NFT from seller to buyer
        nft.safeTransferFrom(seller, msg.sender, tokenId);

        // Distribute payments using pull pattern for platform fee
        pendingWithdrawals[owner()] += platformFee;

        // Pay royalty receiver using pull pattern to prevent griefing
        if (royaltyAmount > 0 && royaltyReceiver != address(0)) {
            pendingWithdrawals[royaltyReceiver] += royaltyAmount;
        }

        // Pay seller directly - seller is a known participant
        // Using pull pattern for seller as well for maximum safety
        pendingWithdrawals[seller] += sellerProceeds;

        // Refund excess payment
        if (msg.value > price) {
            uint256 refund = msg.value - price;
            (bool refundSuccess, ) = payable(msg.sender).call{value: refund}("");
            if (!refundSuccess) {
                // If refund fails, credit to pending withdrawals
                pendingWithdrawals[msg.sender] += refund;
            }
        }

        emit NFTSold(
            listingId,
            msg.sender,
            seller,
            nftContract,
            tokenId,
            price,
            royaltyAmount,
            royaltyReceiver
        );
    }

    function withdraw() external nonReentrant {
        uint256 amount = pendingWithdrawals[msg.sender];
        if (amount == 0) revert NoFundsToWithdraw();

        // Zero out before transfer (checks-effects-interactions)
        pendingWithdrawals[msg.sender] = 0;

        (bool success, ) = payable(msg.sender).call{value: amount}("");
        if (!success) {
            // Re-credit if transfer fails
            pendingWithdrawals[msg.sender] = amount;
            revert WithdrawalFailed();
        }

        emit Withdrawal(msg.sender, amount);
    }

    function getPendingWithdrawal(address account) external view returns (uint256) {
        return pendingWithdrawals[account];
    }

    function getListing(uint256 listingId) external view returns (Listing memory) {
        return listings[listingId];
    }

    function getListingCount() external view returns (uint256) {
        return _listingIdCounter;
    }

    // Prevent accidental ETH sends
    receive() external payable {
        revert("Direct ETH transfers not accepted");
    }

    fallback() external payable {
        revert("Function does not exist");
    }
}