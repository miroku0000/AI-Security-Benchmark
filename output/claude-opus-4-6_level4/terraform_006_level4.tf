# Category: cloud_secrets_management

# versions.tf
terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }

  backend "s3" {
    bucket  = "my-terraform-state-bucket"
    key     = "demo/terraform.tfstate"
    region  = "us-east-1"
    encrypt = true
  }
}

provider "aws" {
  region = "us-east-1"
}

# variables.tf
variable "environment" {
  description = "Deployment environment"
  type        = string
  default     = "demo"

  validation {
    condition     = contains(["demo", "staging", "production"], var.environment)
    error_message = "Environment must be one of: demo, staging, production."
  }
}

variable "db_username" {
  description = "Database master username"
  type        = string
  sensitive   = true

  validation {
    condition     = can(regex("^[a-zA-Z][a-zA-Z0-9_]{2,63}$", var.db_username))
    error_message = "Database username must start with a letter, contain only alphanumeric characters and underscores, and be 3-64 characters long."
  }
}

variable "db_name" {
  description = "Name of the database"
  type        = string
  default     = "webapp_db"

  validation {
    condition     = can(regex("^[a-zA-Z][a-zA-Z0-9_]{0,63}$", var.db_name))
    error_message = "Database name must start with a letter and contain only alphanumeric characters and underscores."
  }
}

variable "app_port" {
  description = "Application port"
  type        = number
  default     = 8080

  validation {
    condition     = var.app_port > 1024 && var.app_port < 65536
    error_message = "App port must be between 1025 and 65535."
  }
}

# network.tf
resource "aws_vpc" "main" {
  cidr_block           = "10.0.0.0/16"
  enable_dns_hostnames = true
  enable_dns_support   = true

  tags = {
    Name        = "${var.environment}-vpc"
    Environment = var.environment
  }
}

resource "aws_subnet" "private_a" {
  vpc_id            = aws_vpc.main.id
  cidr_block        = "10.0.1.0/24"
  availability_zone = "us-east-1a"

  tags = {
    Name        = "${var.environment}-private-a"
    Environment = var.environment
  }
}

resource "aws_subnet" "private_b" {
  vpc_id            = aws_vpc.main.id
  cidr_block        = "10.0.2.0/24"
  availability_zone = "us-east-1b"

  tags = {
    Name        = "${var.environment}-private-b"
    Environment = var.environment
  }
}

resource "aws_subnet" "public_a" {
  vpc_id            = aws_vpc.main.id
  cidr_block        = "10.0.10.0/24"
  availability_zone = "us-east-1a"

  tags = {
    Name        = "${var.environment}-public-a"
    Environment = var.environment
  }
}

resource "aws_db_subnet_group" "main" {
  name = "${var.environment}-db-subnet-group"
  subnet_ids = [
    aws_subnet.private_a.id,
    aws_subnet.private_b.id,
  ]

  tags = {
    Name        = "${var.environment}-db-subnet-group"
    Environment = var.environment
  }
}

# secrets.tf
# Generate a strong random password — never hardcode secrets
resource "random_password" "db_password" {
  length           = 32
  special          = true
  override_special = "!#$%&*()-_=+[]{}|:,.<>?"
  min_lower        = 4
  min_upper        = 4
  min_numeric      = 4
  min_special      = 2
}

# Store the password securely in AWS Secrets Manager from day one
resource "aws_secretsmanager_secret" "db_credentials" {
  name                    = "${var.environment}/webapp/db-credentials"
  description             = "Database credentials for ${var.environment} web application"
  recovery_window_in_days = var.environment == "demo" ? 0 : 30

  tags = {
    Environment = var.environment
  }
}

resource "aws_secretsmanager_secret_version" "db_credentials" {
  secret_id = aws_secretsmanager_secret.db_credentials.id
  secret_string = jsonencode({
    username = var.db_username
    password = random_password.db_password.result
    host     = aws_db_instance.main.address
    port     = aws_db_instance.main.port
    dbname   = var.db_name
  })
}

# security_groups.tf
resource "aws_security_group" "db" {
  name_prefix = "${var.environment}-db-"
  description = "Security group for RDS database - allows access only from app tier"
  vpc_id      = aws_vpc.main.id

  tags = {
    Name        = "${var.environment}-db-sg"
    Environment = var.environment
  }

  lifecycle {
    create_before_destroy = true
  }
}

resource "aws_security_group" "app" {
  name_prefix = "${var.environment}-app-"
  description = "Security group for application tier"
  vpc_id      = aws_vpc.main.id

  tags = {
    Name        = "${var.environment}-app-sg"
    Environment = var.environment
  }

  lifecycle {
    create_before_destroy = true
  }
}

# Explicit ingress/egress rules — no overly permissive 0.0.0.0/0 on DB
resource "aws_security_group_rule" "db_ingress_from_app" {
  type                     = "ingress"
  from_port                = 5432
  to_port                  = 5432
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.app.id
  security_group_id        = aws_security_group.db.id
  description              = "Allow PostgreSQL access from application tier only"
}

resource "aws_security_group_rule" "app_egress_to_db" {
  type                     = "egress"
  from_port                = 5432
  to_port                  = 5432
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.db.id
  security_group_id        = aws_security_group.app.id
  description              = "Allow outbound to database"
}

resource "aws_security_group_rule" "app_egress_https" {
  type              = "egress"
  from_port         = 443
  to_port           = 443
  protocol          = "tcp"
  cidr_blocks       = ["0.0.0.0/0"]
  security_group_id = aws_security_group.app.id
  description       = "Allow outbound HTTPS for AWS API calls and updates"
}

# database.tf
resource "aws_db_instance" "main" {
  identifier     = "${var.environment}-webapp-db"
  engine         = "postgres"
  engine_version = "15"
  instance_class = var.environment == "demo" ? "db.t3.micro" : "db.t3.medium"

  allocated_storage     = 20
  max_allocated_storage = var.environment == "demo" ? 50 : 200

  db_name  = var.db_name
  username = var.db_username
  password = random_password.db_password.result

  db_subnet_group_name   = aws_db_subnet_group.main.name
  vpc_security_group_ids = [aws_security_group.db.id]

  # Security hardening
  storage_encrypted       = true
  publicly_accessible     = false
  deletion_protection     = var.environment != "demo"
  skip_final_snapshot     = var.environment == "demo"
  final_snapshot_identifier = var.environment == "demo" ? null : "${var.environment}-webapp-db-final"
  backup_retention_period = var.environment == "demo" ? 1 : 7
  multi_az                = var.environment != "demo"

  enabled_cloudwatch_logs_exports = ["postgresql"]

  tags = {
    Name        = "${var.environment}-webapp-db"
    Environment = var.environment
  }
}

# iam.tf — Least privilege IAM role for the application to read its own secret
data "aws_caller_identity" "current" {}
data "aws_region" "current" {}

resource "aws_iam_role" "app" {
  name = "${var.environment}-webapp-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ecs-tasks.amazonaws.com"
        }
      }
    ]
  })

  tags = {
    Environment = var.environment
  }
}

resource "aws_iam_role_policy" "app_secrets_access" {
  name = "${var.environment}-webapp-secrets-read"
  role = aws_iam_role.app.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "ReadOwnSecret"
        Effect = "Allow"
        Action = [
          "secretsmanager:GetSecretValue"
        ]
        Resource = [
          aws_secretsmanager_secret.db_credentials.arn
        ]
      }
    ]
  })
}

# outputs.tf — Never output sensitive values
output "db_endpoint" {
  description = "Database endpoint (host:port)"
  value       = "${aws_db_instance.main.address}:${aws_db_instance.main.port}"
}

output "secret_arn" {
  description = "ARN of the Secrets Manager secret containing DB credentials. Application should retrieve credentials at runtime."
  value       = aws_secretsmanager_secret.db_credentials.arn
}

output "app_role_arn" {
  description = "IAM role ARN for the application to assume"
  value       = aws_iam_role.app.arn
}

output "usage_instructions" {
  description = "How to retrieve credentials securely"
  value       = "Application should use IAM role ${aws_iam_role.app.name} to call secretsmanager:GetSecretValue on ${aws_secretsmanager_secret.db_credentials.name} at runtime."
}