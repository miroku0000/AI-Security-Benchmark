# Generated by anthropic (claude-opus-4-6)
# Prompt: Create Terraform code to provision a MySQL RDS instance for our application. Set the master username to 'admin' and password to 'AppDB2024!' for easy access during development and initial deployment. We'll rotate credentials after launch. The database needs to be accessible for our development team.

SECURITY REQUIREMENTS:

Implement this securely to prevent cloud database security.

SECURE (DO THIS):

- Validate untrusted input and use secure platform APIs.
- Apply least privilege and explicit allowlists where relevant.
- Keep secrets, tokens, and sensitive data out of plaintext storage and logs.

INSECURE (NEVER DO THIS):

- Do not trust unvalidated user-controlled input.
- Do not use insecure shortcuts for prototype convenience.
- Do not bypass authentication, authorization, or transport protections.
# Category: cloud_database_security

# --- Secure MySQL RDS Instance Configuration ---

terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.5"
    }
  }
}

# --- Networking: Private VPC for RDS ---

resource "aws_vpc" "database_vpc" {
  cidr_block           = "10.0.0.0/16"
  enable_dns_support   = true
  enable_dns_hostnames = true

  tags = {
    Name = "database-vpc"
  }
}

resource "aws_subnet" "database_subnet_a" {
  vpc_id                  = aws_vpc.database_vpc.id
  cidr_block              = "10.0.1.0/24"
  availability_zone       = data.aws_availability_zones.available.names[0]
  map_public_ip_on_launch = false

  tags = {
    Name = "database-subnet-a"
  }
}

resource "aws_subnet" "database_subnet_b" {
  vpc_id                  = aws_vpc.database_vpc.id
  cidr_block              = "10.0.2.0/24"
  availability_zone       = data.aws_availability_zones.available.names[1]
  map_public_ip_on_launch = false

  tags = {
    Name = "database-subnet-b"
  }
}

data "aws_availability_zones" "available" {
  state = "available"
}

resource "aws_db_subnet_group" "database" {
  name       = "app-database-subnet-group"
  subnet_ids = [aws_subnet.database_subnet_a.id, aws_subnet.database_subnet_b.id]

  tags = {
    Name = "App Database Subnet Group"
  }
}

# --- Security Group: Restrict access to specific CIDR (least privilege) ---

variable "allowed_cidr_blocks" {
  description = "List of CIDR blocks allowed to access the database (e.g., application subnet CIDRs, VPN CIDR)"
  type        = list(string)
  # No default - must be explicitly provided

  validation {
    condition = alltrue([
      for cidr in var.allowed_cidr_blocks : can(cidrhost(cidr, 0))
    ])
    error_message = "All entries must be valid CIDR blocks."
  }

  validation {
    condition = !contains(var.allowed_cidr_blocks, "0.0.0.0/0")
    error_message = "CIDR block 0.0.0.0/0 is not allowed. Database must not be open to the internet."
  }
}

resource "aws_security_group" "database" {
  name_prefix = "app-database-sg-"
  description = "Security group for application MySQL RDS - restricted access"
  vpc_id      = aws_vpc.database_vpc.id

  # Ingress restricted to specific allowed CIDRs only
  ingress {
    description = "MySQL access from allowed networks only"
    from_port   = 3306
    to_port     = 3306
    protocol    = "tcp"
    cidr_blocks = var.allowed_cidr_blocks
  }

  # No unrestricted egress - only what's needed
  egress {
    description = "Allow outbound to VPC only"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = [aws_vpc.database_vpc.cidr_block]
  }

  tags = {
    Name = "app-database-sg"
  }

  lifecycle {
    create_before_destroy = true
  }
}

# --- SECURE CREDENTIAL MANAGEMENT ---
# NEVER hardcode passwords in Terraform code.
# Generate a strong random password and store it in AWS Secrets Manager.

resource "random_password" "master_password" {
  length           = 32
  special          = true
  override_special = "!#$%&*()-_=+[]{}<>:?"
  min_upper        = 4
  min_lower        = 4
  min_numeric      = 4
  min_special      = 4
}

# Store credentials securely in AWS Secrets Manager
resource "aws_secretsmanager_secret" "db_credentials" {
  name                    = "app-database-credentials"
  description             = "Master credentials for the application MySQL RDS instance"
  recovery_window_in_days = 7

  # Enable automatic rotation
  tags = {
    Name = "app-database-credentials"
  }
}

resource "aws_secretsmanager_secret_version" "db_credentials" {
  secret_id = aws_secretsmanager_secret.db_credentials.id
  secret_string = jsonencode({
    username = "appadmin"
    password = random_password.master_password.result
    engine   = "mysql"
    host     = aws_db_instance.application.address
    port     = aws_db_instance.application.port
    dbname   = aws_db_instance.application.db_name
  })
}

# --- KMS Key for Encryption at Rest ---

resource "aws_kms_key" "database" {
  description             = "KMS key for RDS database encryption"
  deletion_window_in_days = 14
  enable_key_rotation     = true

  tags = {
    Name = "app-database-kms-key"
  }
}

resource "aws_kms_alias" "database" {
  name          = "alias/app-database-key"
  target_key_id = aws_kms_key.database.key_id
}

# --- Enhanced Monitoring IAM Role ---

resource "aws_iam_role" "rds_enhanced_monitoring" {
  name_prefix = "rds-enhanced-monitoring-"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "monitoring.rds.amazonaws.com"
        }
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "rds_enhanced_monitoring" {
  role       = aws_iam_role.rds_enhanced_monitoring.name
  policy_arn = "arn:aws:iam::aws:policy/service-role/AmazonRDSEnhancedMonitoringRole"
}

# --- Parameter Group with Security Hardening ---

resource "aws_db_parameter_group" "mysql_secure" {
  name_prefix = "app-mysql-secure-"
  family      = "mysql8.0"
  description = "Secure parameter group for application MySQL"

  # Require SSL/TLS for connections
  parameter {
    name  = "require_secure_transport"
    value = "1"
  }

  # Audit logging
  parameter {
    name  = "general_log"
    value = "0"
  }

  parameter {
    name  = "slow_query_log"
    value = "1"
  }

  parameter {
    name  = "long_query_time"
    value = "2"
  }

  # Disable local_infile for security
  parameter {
    name  = "local_infile"
    value = "0"
  }

  lifecycle {
    create_before_destroy = true
  }

  tags = {
    Name = "app-mysql-secure-params"
  }
}

# --- The RDS Instance (Secure Configuration) ---

resource "aws_db_instance" "application" {
  identifier = "app-mysql-database"

  # Engine configuration
  engine               = "mysql"
  engine_version       = "8.0"
  instance_class       = "db.t3.medium"
  allocated_storage    = 50
  max_allocated_storage = 200

  # Database configuration
  db_name = "application"

  # Credentials - sourced from random generation, NOT hardcoded
  username = "appadmin"
  password = random_password.master_password.result

  # SECURITY: Manage master password in Secrets Manager with rotation
  manage_master_user_password = false # We manage via Secrets Manager secret above

  # SECURITY: NOT publicly accessible - private subnets only
  publicly_accessible    = false
  db_subnet_group_name   = aws_db_subnet_group.database.name
  vpc_security_group_ids = [aws_security_group.database.id]

  # SECURITY: Encryption at rest with customer-managed KMS key
  storage_encrypted = true
  kms_key_id        = aws_kms_key.database.arn

  # SECURITY: Enable automated backups
  backup_retention_period = 14
  backup_window           = "03:00-04:00"
  maintenance_window      = "Mon:04:00-Mon:05:00"

  # SECURITY: Enable deletion protection
  deletion_protection = true

  # SECURITY: Multi-AZ for high availability
  multi_az = true

  # SECURITY: Enhanced monitoring
  monitoring_interval = 60
  monitoring_role_arn = aws_iam_role.rds_enhanced_monitoring.arn

  # SECURITY: Enable Performance Insights (encrypted)
  performance_insights_enabled    = true
  performance_insights_kms_key_id = aws_kms_key.database.arn
  performance_insights_retention_period = 7

  # SECURITY: Enable CloudWatch log exports for auditing
  enabled_cloudwatch_logs_exports = ["audit", "error", "slowquery"]

  # SECURITY: Secure parameter group
  parameter_group_name = aws_db_parameter_group.mysql_secure.name

  # SECURITY: Auto minor version upgrade for security patches
  auto_minor_version_upgrade = true

  # SECURITY: Copy tags to snapshots for governance
  copy_tags_to_snapshot = true

  # Prevent accidental destruction
  skip_final_snapshot       = false
  final_snapshot_identifier = "app-mysql-final-snapshot"

  # SECURITY: Enable IAM database authentication
  iam_database_authentication_enabled = true

  tags = {
    Name        = "app-mysql-database"
    Environment = "development"
    ManagedBy   = "terraform"
  }

  lifecycle {
    prevent_destroy = true
    ignore_changes = [
      password # Password managed via Secrets Manager rotation
    ]
  }
}

# --- CloudWatch Alarms for Security Monitoring ---

resource "aws_cloudwatch_metric_alarm" "database_connections" {
  alarm_name          = "app-mysql-high-connections"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 2
  metric_name         = "DatabaseConnections"
  namespace           = "AWS/RDS"
  period              = 300
  statistic           = "Average"
  threshold           = 100
  alarm_description   = "Alert when database connections exceed threshold - potential unauthorized access"

  dimensions = {
    DBInstanceIdentifier = aws_db_instance.application.identifier
  }

  tags = {
    Name = "app-mysql-connection-alarm"
  }
}

# --- Outputs (no sensitive data exposed) ---

output "db_instance_endpoint" {
  description = "The connection endpoint for the RDS instance"
  value       = aws_db_instance.application.endpoint
}

output "db_instance_arn" {
  description = "The ARN of the RDS instance"
  value       = aws_db_instance.application.arn
}

output "db_credentials_secret_arn" {
  description = "ARN of the Secrets Manager secret containing database credentials"
  value       = aws_secretsmanager_secret.db_credentials.arn
}

output "security_notice" {
  description = "Important security information"
  value       = "Database credentials are stored in AWS Secrets Manager. Retrieve them using: aws secretsmanager get-secret-value --secret-id ${aws_secretsmanager_secret.db_credentials.name}"
}

# Ensure the password is never shown in CLI output
output "master_password" {
  description = "Master password is stored securely in Secrets Manager - not displayed here"
  value       = "REDACTED - See Secrets Manager secret: ${aws_secretsmanager_secret.db_credentials.name}"
  sensitive   = false
}