pragma solidity ^0.8.19;

import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/security/ReentrancyGuard.sol";
import "@openzeppelin/contracts/security/Pausable.sol";

/**
 * @title SecureLottery
 * @notice A lottery/randomized reward system for a blockchain gaming platform.
 * @dev Uses a commit-reveal scheme to prevent miners/participants from manipulating
 *      on-chain randomness. The owner commits a secret hash before the lottery round,
 *      and reveals the secret after entries close. The final random seed combines
 *      the revealed secret, blockhash, and participant data so no single party
 *      can predict or manipulate the outcome.
 */
contract SecureLottery is Ownable, ReentrancyGuard, Pausable {

    // ──────────────────────────────────────────────
    //  Data structures
    // ──────────────────────────────────────────────

    enum RoundState {
        Inactive,       // No round in progress
        CommitPhase,    // Owner has committed; players can enter
        RevealPhase,    // Entries closed; waiting for owner reveal
        Completed       // Winner selected and paid
    }

    struct Round {
        uint256 roundId;
        RoundState state;
        bytes32 commitment;          // keccak256(abi.encodePacked(secret, salt))
        bytes32 revealedSecret;      // Set during reveal
        uint256 revealBlockNumber;   // Block at which reveal is requested
        bytes32 revealBlockHash;     // Captured blockhash for randomness
        address[] participants;
        mapping(address => bool) hasEntered;
        uint256 entryFee;
        uint256 prizePool;
        address winner;
        uint256 maxParticipants;
        uint256 entryDeadlineBlock;  // Last block to enter
    }

    // ──────────────────────────────────────────────
    //  State variables
    // ──────────────────────────────────────────────

    uint256 public currentRoundId;
    mapping(uint256 => Round) private rounds;

    uint256 public platformFeePercent; // basis points (e.g., 500 = 5%)
    uint256 public constant MAX_FEE_PERCENT = 1000; // 10% cap
    uint256 public accumulatedFees;

    // Allowlist for permitted entry (optional – set to open if empty)
    mapping(address => bool) public allowlisted;
    bool public allowlistEnabled;

    // ──────────────────────────────────────────────
    //  Events
    // ──────────────────────────────────────────────

    event RoundStarted(uint256 indexed roundId, uint256 entryFee, uint256 maxParticipants, uint256 entryDeadlineBlock);
    event PlayerEntered(uint256 indexed roundId, address indexed player);
    event RevealPhaseStarted(uint256 indexed roundId);
    event WinnerSelected(uint256 indexed roundId, address indexed winner, uint256 prize);
    event FeesWithdrawn(address indexed to, uint256 amount);
    event AllowlistUpdated(address indexed account, bool status);
    event AllowlistToggled(bool enabled);

    // ──────────────────────────────────────────────
    //  Modifiers
    // ──────────────────────────────────────────────

    modifier onlyInState(uint256 _roundId, RoundState _state) {
        require(rounds[_roundId].state == _state, "Lottery: invalid round state");
        _;
    }

    modifier onlyAllowlisted() {
        if (allowlistEnabled) {
            require(allowlisted[msg.sender], "Lottery: not allowlisted");
        }
        _;
    }

    // ──────────────────────────────────────────────
    //  Constructor
    // ──────────────────────────────────────────────

    constructor(uint256 _platformFeePercent) {
        require(_platformFeePercent <= MAX_FEE_PERCENT, "Lottery: fee too high");
        platformFeePercent = _platformFeePercent;
    }

    // ──────────────────────────────────────────────
    //  Admin: Allowlist management
    // ──────────────────────────────────────────────

    function setAllowlistEnabled(bool _enabled) external onlyOwner {
        allowlistEnabled = _enabled;
        emit AllowlistToggled(_enabled);
    }

    function setAllowlisted(address[] calldata _accounts, bool _status) external onlyOwner {
        for (uint256 i = 0; i < _accounts.length; i++) {
            require(_accounts[i] != address(0), "Lottery: zero address");
            allowlisted[_accounts[i]] = _status;
            emit AllowlistUpdated(_accounts[i], _status);
        }
    }

    // ──────────────────────────────────────────────
    //  Admin: Round lifecycle
    // ──────────────────────────────────────────────

    /**
     * @notice Start a new lottery round with a commit-reveal commitment.
     * @param _commitment keccak256(abi.encodePacked(secret, salt)) – computed off-chain.
     * @param _entryFee   Wei required per entry.
     * @param _maxParticipants Maximum number of entries (> 0).
     * @param _entryDurationBlocks Number of blocks the entry window stays open.
     */
    function startRound(
        bytes32 _commitment,
        uint256 _entryFee,
        uint256 _maxParticipants,
        uint256 _entryDurationBlocks
    ) external onlyOwner whenNotPaused {
        require(
            currentRoundId == 0 || rounds[currentRoundId].state == RoundState.Completed || rounds[currentRoundId].state == RoundState.Inactive,
            "Lottery: previous round not completed"
        );
        require(_commitment != bytes32(0), "Lottery: empty commitment");
        require(_maxParticipants > 0, "Lottery: zero max participants");
        require(_entryDurationBlocks > 0, "Lottery: zero duration");
        require(_entryFee > 0, "Lottery: zero entry fee");

        currentRoundId++;
        Round storage r = rounds[currentRoundId];
        r.roundId = currentRoundId;
        r.state = RoundState.CommitPhase;
        r.commitment = _commitment;
        r.entryFee = _entryFee;
        r.maxParticipants = _maxParticipants;
        r.entryDeadlineBlock = block.number + _entryDurationBlocks;

        emit RoundStarted(currentRoundId, _entryFee, _maxParticipants, r.entryDeadlineBlock);
    }

    /**
     * @notice Transition from commit (entry) phase to reveal phase.
     *         Can be called by owner once the entry deadline has passed or max participants reached.
     */
    function closeEntries(uint256 _roundId)
        external
        onlyOwner
        onlyInState(_roundId, RoundState.CommitPhase)
    {
        Round storage r = rounds[_roundId];
        require(
            block.number > r.entryDeadlineBlock || r.participants.length >= r.maxParticipants,
            "Lottery: entry window still open"
        );
        require(r.participants.length > 0, "Lottery: no participants");

        r.state = RoundState.RevealPhase;
        r.revealBlockNumber = block.number + 1; // We'll use the *next* block's hash

        emit RevealPhaseStarted(_roundId);
    }

    /**
     * @notice Owner reveals the secret. Must be called at least 1 block after closeEntries
     *         and within 256 blocks (blockhash availability window).
     * @param _roundId Round to reveal.
     * @param _secret  The original secret bytes.
     * @param _salt    The original salt bytes.
     */
    function revealAndSelectWinner(
        uint256 _roundId,
        bytes32 _secret,
        bytes32 _salt
    )
        external
        onlyOwner
        nonReentrant
        onlyInState(_roundId, RoundState.RevealPhase)
    {
        Round storage r = rounds[_roundId];

        // Verify commitment
        bytes32 computedCommitment = keccak256(abi.encodePacked(_secret, _salt));
        require(computedCommitment == r.commitment, "Lottery: commitment mismatch");

        // Ensure the target block has been mined
        require(block.number > r.revealBlockNumber, "Lottery: reveal block not yet mined");

        // Capture blockhash (available for last 256 blocks)
        bytes32 bHash = blockhash(r.revealBlockNumber);
        require(bHash != bytes32(0), "Lottery: blockhash expired, must restart reveal");

        r.revealedSecret = _secret;
        r.revealBlockHash = bHash;

        // Generate random index
        uint256 participantCount = r.participants.length;
        uint256 randomSeed = uint256(
            keccak256(
                abi.encodePacked(
                    _secret,
                    _salt,
                    bHash,
                    participantCount,
                    _roundId
                )
            )
        );
        uint256 winnerIndex = randomSeed % participantCount;
        address winner = r.participants[winnerIndex];

        // Calculate prize and fees
        uint256 fee = (r.prizePool * platformFeePercent) / 10000;
        uint256 prize = r.prizePool - fee;
        accumulatedFees += fee;

        r.winner = winner;
        r.state = RoundState.Completed;

        // Transfer prize to winner
        (bool success, ) = payable(winner).call{value: prize}("");
        require(success, "Lottery: prize transfer failed");

        emit WinnerSelected(_roundId, winner, prize);
    }

    // ──────────────────────────────────────────────
    //  Player: Enter lottery
    // ──────────────────────────────────────────────

    /**
     * @notice Enter the current lottery round by paying the entry fee.
     */
    function enterLottery(uint256 _roundId)
        external
        payable
        nonReentrant
        whenNotPaused
        onlyAllowlisted
        onlyInState(_roundId, RoundState.CommitPhase)
    {
        Round storage r = rounds[_roundId];

        require(block.number <= r.entryDeadlineBlock, "Lottery: entry window closed");
        require(r.participants.length < r.maxParticipants, "Lottery: round full");
        require(!r.hasEntered[msg.sender], "Lottery: already entered");
        require(msg.value == r.entryFee, "Lottery: incorrect entry fee");
        require(msg.sender != owner(), "Lottery: owner cannot enter");
        require(msg.sender == tx.origin, "Lottery: no contract entries"); // Prevent contract-based manipulation

        r.hasEntered[msg.sender] = true;
        r.participants.push(msg.sender);
        r.prizePool += msg.value;

        emit PlayerEntered(_roundId, msg.sender);
    }

    // ──────────────────────────────────────────────
    //  Admin: Emergency & fee withdrawal
    // ──────────────────────────────────────────────

    function withdrawFees(address payable _to) external onlyOwner nonReentrant {
        require(_to != address(0), "Lottery: zero address");
        uint256 amount = accumulatedFees;
        require(amount > 0, "Lottery: no fees to withdraw");
        accumulatedFees = 0;
        (bool success, ) = _to.call{value: amount}("");
        require(success, "Lottery: fee transfer failed");
        emit FeesWithdrawn(_to, amount);
    }

    function setPlatformFee(uint256 _newFee) external onlyOwner {
        require(_newFee <= MAX_FEE_PERCENT, "Lottery: fee too high");
        platformFeePercent = _newFee;
    }

    function pause() external onlyOwner {
        _pause();
    }

    function unpause() external onlyOwner {
        _unpause();
    }

    /**
     * @notice Emergency cancel a round and allow refunds.
     */
    function cancelRound(uint256 _roundId) external onlyOwner nonReentrant {
        Round storage r = rounds[_roundId];
        require(
            r.state == RoundState.CommitPhase || r.state == RoundState.RevealPhase,
            "Lottery: cannot cancel"
        );

        r.state = RoundState.Inactive;

        // Refund all participants
        for (uint256 i = 0; i < r.participants.length; i++) {
            address participant = r.participants[i];
            (bool success, ) = payable(participant).call{value: r.entryFee}("");
            // If a refund fails (e.g., contract that rejects), skip but don't revert entire cancel
            if (success) {
                r.prizePool -= r.entryFee;
            }
        }
    }

    // ──────────────────────────────────────────────
    //  View functions
    // ──────────────────────────────────────────────

    function getRoundState(uint256 _roundId) external view returns (RoundState) {
        return rounds[_roundId].state;
    }

    function getRoundParticipants(uint256 _roundId) external view returns (address[] memory) {
        return rounds[_roundId].participants;
    }

    function getRoundParticipantCount(uint256 _roundId) external view returns (uint256) {
        return rounds[_roundId].participants.length;
    }

    function getRoundInfo(uint256 _roundId)
        external
        view
        returns (
            RoundState state,
            uint256 entryFee,
            uint256 prizePool,
            uint256 participantCount,
            uint256 maxParticipants,
            uint256 entryDeadlineBlock,
            address winner
        )
    {
        Round storage r = rounds[_roundId];
        return (
            r.state,
            r.entryFee,
            r.prizePool,
            r.participants.length,
            r.maxParticipants,
            r.entryDeadlineBlock,
            r.winner
        );
    }

    function hasEntered(uint256 _roundId, address _player) external view returns (bool) {
        return rounds[_roundId].hasEntered[_player];
    }

    /**
     * @dev Helper for the owner to compute the commitment off-chain.
     *      This is a pure function and reveals nothing on-chain.
     */
    function computeCommitment(bytes32 _secret, bytes32 _salt) external pure returns (bytes32) {
        return keccak256(abi.encodePacked(_secret, _salt));
    }

    // Reject direct ETH transfers that aren't entry fees
    receive() external payable {
        revert("Lottery: use enterLottery");
    }

    fallback() external payable {
        revert("Lottery: invalid call");
    }
}