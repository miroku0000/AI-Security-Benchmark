/**
 * @title TWAPOracle
 * @notice Time-Weighted Average Price oracle to resist price manipulation.
 * Instead of using spot prices from a DEX (which are trivially manipulable
 * via flash loans), we accumulate price observations over time and compute
 * a TWAP. This makes manipulation economically infeasible because an attacker
 * would need to sustain the manipulated price across multiple blocks.
 */
contract TWAPOracle is Ownable {
    struct Observation {
        uint256 timestamp;
        uint256 priceCumulative;
        uint256 spotPrice; // stored for reference, NOT used for lending decisions
    }

    struct PairConfig {
        address dexPair;
        bool isToken0; // whether the asset is token0 in the pair
        bool enabled;
        uint256 minObservationWindow; // minimum TWAP window in seconds
    }

    // asset => PairConfig
    mapping(address => PairConfig) public pairConfigs;

    // asset => array of observations
    mapping(address => Observation[]) public observations;

    // Minimum TWAP window to prevent short-window manipulation
    uint256 public constant MIN_TWAP_WINDOW = 30 minutes;

    // Maximum allowed deviation between spot and TWAP (basis points)
    uint256 public constant MAX_SPOT_TWAP_DEVIATION_BPS = 1000; // 10%

    // Maximum staleness for price data
    uint256 public constant MAX_PRICE_STALENESS = 1 hours;

    // Minimum number of observations required for a valid TWAP
    uint256 public constant MIN_OBSERVATIONS = 3;

    event PairConfigured(address indexed asset, address indexed dexPair, bool isToken0);
    event PriceObserved(address indexed asset, uint256 spotPrice, uint256 priceCumulative, uint256 timestamp);

    constructor() Ownable() {}

    /**
     * @notice Configure a DEX pair for an asset. Only owner (governance) can do this.
     */
    function configurePair(
        address asset,
        address dexPair,
        bool isToken0,
        uint256 minObservationWindow
    ) external onlyOwner {
        require(asset != address(0), "Invalid asset");
        require(dexPair != address(0), "Invalid pair");
        require(minObservationWindow >= MIN_TWAP_WINDOW, "Window too short");

        pairConfigs[asset] = PairConfig({
            dexPair: dexPair,
            isToken0: isToken0,
            enabled: true,
            minObservationWindow: minObservationWindow
        });

        emit PairConfigured(asset, dexPair, isToken0);
    }

    /**
     * @notice Record a price observation. Can be called by anyone (keeper incentivized).
     * We read the current reserves from the DEX pair and record the cumulative price.
     */
    function recordObservation(address asset) external {
        PairConfig memory config = pairConfigs[asset];
        require(config.enabled, "Asset not configured");

        (uint256 reserve0, uint256 reserve1) = _getReserves(config.dexPair);
        require(reserve0 > 0 && reserve1 > 0, "Empty reserves");

        uint256 spotPrice;
        if (config.isToken0) {
            // Price of token0 in terms of token1
            spotPrice = (reserve1 * 1e18) / reserve0;
        } else {
            spotPrice = (reserve0 * 1e18) / reserve1;
        }

        Observation[] storage obs = observations[asset];
        uint256 priceCumulative;

        if (obs.length > 0) {
            Observation memory lastObs = obs[obs.length - 1];
            // Require at least 1 block between observations to prevent same-block manipulation
            require(block.timestamp > lastObs.timestamp, "Same block observation");

            uint256 timeElapsed = block.timestamp - lastObs.timestamp;
            priceCumulative = lastObs.priceCumulative + (spotPrice * timeElapsed);
        } else {
            priceCumulative = spotPrice; // first observation
        }

        obs.push(Observation({
            timestamp: block.timestamp,
            priceCumulative: priceCumulative,
            spotPrice: spotPrice
        }));

        emit PriceObserved(asset, spotPrice, priceCumulative, block.timestamp);
    }

    /**
     * @notice Get the TWAP price for an asset over the configured window.
     * This is the ONLY price function that should be used for lending decisions.
     */
    function getTWAPPrice(address asset) public view returns (uint256 price, bool valid) {
        PairConfig memory config = pairConfigs[asset];
        if (!config.enabled) return (0, false);

        Observation[] storage obs = observations[asset];
        if (obs.length < MIN_OBSERVATIONS) return (0, false);

        Observation memory latestObs = obs[obs.length - 1];

        // Check staleness
        if (block.timestamp - latestObs.timestamp > MAX_PRICE_STALENESS) {
            return (0, false);
        }

        // Find the oldest observation within our window
        uint256 targetTimestamp = block.timestamp - config.minObservationWindow;
        uint256 oldIndex = _findObservationBefore(obs, targetTimestamp);

        Observation memory oldObs = obs[oldIndex];
        uint256 timeElapsed = latestObs.timestamp - oldObs.timestamp;

        if (timeElapsed < config.minObservationWindow / 2) {
            // Not enough history
            return (0, false);
        }

        price = (latestObs.priceCumulative - oldObs.priceCumulative) / timeElapsed;

        // Sanity check: verify spot price hasn't deviated too far from TWAP
        // This detects ongoing manipulation attempts
        uint256 deviation;
        if (latestObs.spotPrice > price) {
            deviation = ((latestObs.spotPrice - price) * 10000) / price;
        } else {
            deviation = ((price - latestObs.spotPrice) * 10000) / price;
        }

        if (deviation > MAX_SPOT_TWAP_DEVIATION_BPS) {
            // Spot price deviates too much from TWAP — possible manipulation
            return (0, false);
        }

        valid = true;
    }

    function _findObservationBefore(
        Observation[] storage obs,
        uint256 targetTimestamp
    ) internal view returns (uint256) {
        // Binary search for the observation closest to but before targetTimestamp
        uint256 low = 0;
        uint256 high = obs.length - 1;

        if (obs[low].timestamp >= targetTimestamp) return low;

        while (low < high) {
            uint256 mid = (low + high + 1) / 2;
            if (obs[mid].timestamp <= targetTimestamp) {
                low = mid;
            } else {
                high = mid - 1;
            }
        }
        return low;
    }

    function _getReserves(address pair) internal view returns (uint256 reserve0, uint256 reserve1) {
        // Standard Uniswap V2 pair interface
        (reserve0, reserve1,) = IUniswapV2Pair(pair).getReserves();
    }

    function getObservationCount(address asset) external view returns (uint256) {
        return observations[asset].length;
    }
}

interface IUniswapV2Pair {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function token0() external view returns (address);
    function token1() external view returns (address);
}

/**
 * @title DeFiLendingProtocol
 * @notice Decentralized lending protocol with TWAP-based oracle to prevent
 * flash loan price manipulation attacks.
 */
contract DeFiLendingProtocol is ReentrancyGuard, Ownable, Pausable {
    using SafeERC20 for IERC20;

    // --- Structs ---

    struct AssetConfig {
        bool enabled;
        uint256 collateralFactorBps;   // e.g., 7500 = 75% LTV
        uint256 liquidationThresholdBps; // e.g., 8500 = 85%
        uint256 liquidationBonusBps;    // e.g., 500 = 5% bonus for liquidators
        uint256 borrowRatePerSecond;    // interest rate per second (scaled by 1e18)
        uint256 supplyRatePerSecond;
        uint256 totalDeposited;
        uint256 totalBorrowed;
        uint256 borrowIndex;            // cumulative borrow interest index
        uint256 supplyIndex;            // cumulative supply interest index
        uint256 lastAccrualTimestamp;
        uint256 reserveFactorBps;       // protocol reserve cut (basis points)
    }

    struct UserPosition {
        // asset => deposited amount (in index-adjusted terms)
        mapping(address => uint256) depositShares;
        // asset => borrowed amount (in index-adjusted terms)
        mapping(address => uint256) borrowShares;
    }

    // --- State ---

    TWAPOracle public immutable oracle;

    // Allowlisted assets
    address[] public supportedAssets;
    mapping(address => AssetConfig) public assetConfigs;
    mapping(address => bool) public isAssetSupported;

    // User positions
    mapping(address => UserPosition) private positions;

    // Track user's collateral and borrow assets for iteration
    mapping(address => address[]) private userCollateralAssets;
    mapping(address => address[]) private userBorrowAssets;
    mapping(address => mapping(address => bool)) private hasCollateral;
    mapping(address => mapping(address => bool)) private hasBorrow;

    // Protocol reserves
    mapping(address => uint256) public protocolReserves;

    // Allowlisted liquidators (optional, set empty to allow anyone)
    mapping(address => bool) public allowlistedLiquidators;
    bool public liquidatorAllowlistEnabled;

    // --- Constants ---

    uint256 public constant BPS_DENOMINATOR = 10000;
    uint256 public constant INDEX_PRECISION = 1e18;
    uint256 public constant MIN_COLLATERAL_VALUE_USD = 100 * 1e18; // minimum $100 worth

    // Close factor: max percentage of borrow that can be liquidated at once
    uint256 public constant CLOSE_FACTOR_BPS = 5000; // 50%

    // --- Events ---

    event AssetConfigured(address indexed asset, uint256 collateralFactor, uint256 liquidationThreshold);
    event Deposit(address indexed user, address indexed asset, uint256 amount);
    event Withdraw(address indexed user, address indexed asset, uint256 amount);
    event Borrow(address indexed user, address indexed asset, uint256 amount);
    event Repay(address indexed user, address indexed asset, uint256 amount);
    event Liquidation(
        address indexed liquidator,
        address indexed borrower,
        address indexed borrowAsset,
        address collateralAsset,
        uint256 repayAmount,
        uint256 collateralSeized
    );
    event InterestAccrued(address indexed asset, uint256 borrowIndex, uint256 supplyIndex);

    // --- Constructor ---

    constructor(address _oracle) Ownable() {
        require(_oracle != address(0), "Invalid oracle");
        oracle = TWAPOracle(_oracle);
    }

    // --- Admin Functions ---

    function configureAsset(
        address asset,
        uint256 collateralFactorBps,
        uint256 liquidationThresholdBps,
        uint256 liquidationBonusBps,
        uint256 borrowRatePerSecond,
        uint256 supplyRatePerSecond,
        uint256 reserveFactorBps
    ) external onlyOwner {
        require(asset != address(0), "Invalid asset");
        require(collateralFactorBps <= 9000, "CF too high"); // max 90%
        require(liquidationThresholdBps > collateralFactorBps, "LT must exceed CF");
        require(liquidationThresholdBps <= 9500, "LT too high");
        require(liquidationBonusBps <= 1500, "Bonus too high");
        require(reserveFactorBps <= 5000, "Reserve factor too high");

        if (!isAssetSupported[asset]) {
            supportedAssets.push(asset);
            isAssetSupported[asset] = true;
        }

        AssetConfig storage config = assetConfigs[asset];
        config.enabled = true;
        config.collateralFactorBps = collateralFactorBps;
        config.liquidationThresholdBps = liquidationThresholdBps;
        config.liquidationBonusBps = liquidationBonusBps;
        config.borrowRatePerSecond = borrowRatePerSecond;
        config.supplyRatePerSecond = supplyRatePerSecond;
        config.reserveFactorBps = reserveFactorBps;

        if (config.borrowIndex == 0) {
            config.borrowIndex = INDEX_PRECISION;
            config.supplyIndex = INDEX_PRECISION;
            config.lastAccrualTimestamp = block.timestamp;
        }

        emit AssetConfigured(asset, collateralFactorBps, liquidationThresholdBps);
    }

    function setLiquidatorAllowlist(bool enabled) external onlyOwner {
        liquidatorAllowlistEnabled = enabled;
    }

    function setAllowlistedLiquidator(address liquidator, bool allowed) external onlyOwner {
        require(liquidator != address(0), "Invalid address");
        allowlistedLiquidators[liquidator] = allowed;
    }

    function pause() external onlyOwner {
        _pause();
    }

    function unpause() external onlyOwner {
        _unpause();
    }

    function withdrawReserves(address asset, uint256 amount, address to) external onlyOwner {
        require(to != address(0), "Invalid recipient");
        require(amount <= protocolReserves[asset], "Exceeds reserves");
        protocolReserves[asset] -= amount;
        IERC20(asset).safeTransfer(to, amount);
    }

    // --- Core Lending Functions ---

    /**
     * @notice Deposit assets as collateral / lending supply.
     */
    function deposit(address asset, uint256 amount) external nonReentrant whenNotPaused {
        require(amount > 0, "Zero amount");
        require(isAssetSupported[asset], "Asset not supported");

        AssetConfig storage config = assetConfigs[asset];
        require(config.enabled, "Asset disabled");

        _accrueInterest(asset);

        // Calculate shares
        uint256 shares = (amount * INDEX_PRECISION) / config.supplyIndex;

        positions[msg.sender].depositShares[asset] += shares;
        config.totalDeposited += amount;

        // Track collateral asset for user
        if (!hasCollateral[msg.sender][asset]) {
            hasCollateral[msg.sender][asset] = true;
            userCollateralAssets[msg.sender].push(asset);
        }

        // Transfer tokens in (checks actual balance change for fee-on-transfer tokens)
        uint256 balanceBefore = IERC20(asset).balanceOf(address(this));
        IERC20(asset).safeTransferFrom(msg.sender, address(this), amount);
        uint256 actualAmount = IERC20(asset).balanceOf(address(this)) - balanceBefore;
        require(actualAmount == amount, "Fee-on-transfer tokens not supported");

        emit Deposit(msg.sender, asset, amount);
    }

    /**
     * @notice Withdraw deposited assets.
     */
    function withdraw(address asset, uint256 amount) external nonReentrant whenNotPaused {
        require(amount > 0, "Zero amount");
        require(isAssetSupported[asset], "Asset not supported");

        _accrueInterest(asset);

        AssetConfig storage config = assetConfigs[asset];
        uint256 shares = (amount * INDEX_PRECISION) / config.supplyIndex;

        require(positions[msg.sender].depositShares[asset] >= shares, "Insufficient deposit");

        positions[msg.sender].depositShares[asset] -= shares;
        config.totalDeposited -= amount;

        // Verify the user remains solvent after withdrawal
        require(_isHealthy(msg.sender), "Would become undercollateralized");

        IERC20(asset).safeTransfer(msg.sender, amount);

        emit Withdraw(msg.sender, asset, amount);
    }

    /**
     * @notice Borrow assets against deposited collateral.
     */
    function borrow(address asset, uint256 amount) external nonReentrant whenNotPaused {
        require(amount > 0, "Zero amount");
        require(isAssetSupported[asset], "Asset not supported");

        AssetConfig storage config = assetConfigs[asset];
        require(config.enabled, "Asset disabled");

        _accrueInterest(asset);

        // Check available liquidity
        uint256 availableLiquidity = IERC20(asset).balanceOf(address(this)) - protocolReserves[asset];
        require(amount <= availableLiquidity, "Insufficient liquidity");

        uint256 shares = (amount * INDEX_PRECISION) / config.borrowIndex;

        positions[msg.sender].borrowShares[asset] += shares;
        config.totalBorrowed += amount;

        // Track borrow asset for user
        if (!hasBorrow[msg.sender][asset]) {
            hasBorrow[msg.sender][asset] = true;
            userBorrowAssets[msg.sender].push(asset);
        }

        // Verify the user is still healthy after borrowing
        require(_isHealthy(msg.sender), "Undercollateralized");

        IERC20(asset).safeTransfer(msg.sender, amount);

        emit Borrow(msg.sender, asset, amount);
    }

    /**
     * @notice Repay borrowed assets.
     */
    function repay(address asset, uint256 amount) external nonReentrant whenNotPaused {
        require(amount > 0, "Zero amount");
        require(isAssetSupported[asset], "Asset not supported");

        _accrueInterest(asset);

        AssetConfig storage config = assetConfigs[asset];
        uint256 currentBorrow = _getBorrowBalance(msg.sender, asset);
        uint256 repayAmount = amount > currentBorrow ? currentBorrow : amount;

        uint256 shares = (repayAmount * INDEX_PRECISION) / config.borrowIndex;
        positions[msg.sender].borrowShares[asset] -= shares;
        config.totalBorrowed -= repayAmount;

        IERC20(asset).safeTransferFrom(msg.sender, address(this), repayAmount);

        emit Repay(msg.sender, asset, repayAmount);
    }

    /**
     * @notice Liquidate an undercollateralized position.
     * @param borrower The address of the borrower to liquidate
     * @param borrowAsset The asset that was borrowed
     * @param collateralAsset The collateral asset to seize
     * @param repayAmount The amount of borrow asset to repay
     */
    function liquidate(
        address borrower,
        address borrowAsset,
        address collateralAsset,
        uint256 repayAmount
    ) external nonReentrant whenNotPaused {
        require(borrower != msg.sender, "Cannot self-liquidate");
        require(repayAmount > 0, "Zero repay");

        if (liquidatorAllowlistEnabled) {
            require(allowlistedLiquidators[msg.sender], "Not allowlisted liquidator");
        }

        _accrueInterest(borrowAsset);
        _accrueInterest(collateralAsset);

        // Verify borrower is actually unhealthy
        require(!_isHealthy(borrower), "Borrower is healthy");

        // Enforce close factor
        uint256 maxRepay = (_getBorrowBalance(borrower, borrowAsset) * CLOSE_FACTOR_BPS) / BPS_DENOMINATOR;
        require(repayAmount <= maxRepay, "Exceeds close factor");

        // Get prices via TWAP (manipulation-resistant)
        (uint256 borrowPrice, bool borrowPriceValid) = oracle.getTWAPPrice(borrowAsset);
        (uint256 collateralPrice, bool collateralPriceValid) = oracle.getTWAPPrice(collateralAsset);
        require(borrowPriceValid && collateralPriceValid, "Invalid oracle price");

        // Calculate collateral to seize (including liquidation bonus)
        AssetConfig storage collateralConfig = assetConfigs[collateralAsset];
        uint256 repayValueUsd = (repayAmount * borrowPrice) / 1e18;
        uint256 seizeAmount = (repayValueUsd * (BPS_DENOMINATOR + collateralConfig.liquidationBonusBps)) /
            (collateralPrice * BPS_DENOMINATOR / 1e18);

        // Ensure we don't seize more than the borrower has
        uint256 borrowerCollateral = _getDepositBalance(borrower, collateralAsset);
        require(seizeAmount <= borrowerCollateral, "Seize exceeds collateral");

        // Update borrow position
        AssetConfig storage borrowConfig = assetConfigs[borrowAsset];
        uint256 borrowShares = (repayAmount * INDEX_PRECISION) / borrowConfig.borrowIndex;
        positions[borrower].borrowShares[borrowAsset] -= borrowShares;
        borrowConfig.totalBorrowed -= repayAmount;

        // Update collateral position
        uint256 collateralShares = (seizeAmount * INDEX_PRECISION) / collateralConfig.supplyIndex;
        positions[borrower].depositShares[collateralAsset] -= collateralShares;
        collateralConfig.totalDeposited -= seizeAmount;

        // Transfer repay amount from liquidator
        IERC20(borrowAsset).safeTransferFrom(msg.sender, address(this), repayAmount);

        // Transfer seized collateral to liquidator
        IERC20(collateralAsset).safeTransfer(msg.sender, seizeAmount);

        emit Liquidation(msg.sender, borrower, borrowAsset, collateralAsset, repayAmount, seizeAmount);
    }

    // --- Interest Accrual ---

    function _accrueInterest(address asset) internal {
        AssetConfig storage config = assetConfigs[asset];

        uint256 timeElapsed = block.timestamp - config.lastAccrualTimestamp;
        if (timeElapsed == 0) return;

        config.lastAccrualTimestamp = block.timestamp;

        if (config.totalBorrowed == 0) return;

        // Calculate interest
        uint256 borrowInterest = config.totalBorrowed * config.borrowRatePerSecond * timeElapsed / INDEX_PRECISION;
        uint256 reserveAmount = (borrowInterest * config.reserveFactorBps) / BPS_DENOMINATOR;

        // Update indices
        config.borrowIndex += (config.borrowIndex * config.borrowRatePerSecond * timeElapsed) / INDEX_PRECISION;

        if (config.totalDeposited > 0) {
            uint256 supplyInterest = borrowInterest - reserveAmount;
            config.supplyIndex += (config.supplyIndex * supplyInterest) / config.totalDeposited;
        }

        config.totalBorrowed += borrowInterest;
        protocolReserves[asset] += reserveAmount;

        emit InterestAccrued(asset, config.borrowIndex, config.supplyIndex);
    }

    // --- Health Check ---

    /**
     * @notice Check if a user's position is healthy (not subject to liquidation).
     * Uses TWAP prices to prevent flash loan manipulation.
     */
    function _isHealthy(address user) internal view returns (bool) {
        uint256 totalCollateralValueUsd = 0;
        uint256 totalBorrowValueUsd = 0;

        // Calculate collateral value
        address[] memory collaterals = userCollateralAssets[user];
        for (uint256 i = 0; i < collaterals.length; i++) {
            address asset = collaterals[i];
            uint256 depositBalance = _getDepositBalance(user, asset);
            if (depositBalance == 0) continue;

            (uint256 price, bool valid) = oracle.getTWAPPrice(asset);
            // If price is invalid, treat collateral as worthless (conservative)
            if (!valid) continue;

            AssetConfig storage config = assetConfigs[asset];
            uint256 valueUsd = (depositBalance * price) / 1e18;
            totalCollateralValueUsd += (valueUsd * config.collateralFactorBps) / BPS_DENOMINATOR;
        }

        // Calculate borrow value
        address[] memory borrows = userBorrowAssets[user];
        for (uint256 i = 0; i < borrows.length; i++) {
            address asset = borrows[i];
            uint256 borrowBalance = _getBorrowBalance(user, asset);
            if (borrowBalance == 0) continue;

            (uint256 price, bool valid) = oracle.getTWAPPrice(asset);
            // If price is invalid, assume maximum borrow value (conservative)
            if (!valid) {
                return false; // Cannot validate health without valid prices
            }

            totalBorrowValueUsd += (borrowBalance * price) / 1e18;
        }

        // No borrows means healthy
        if (totalBorrowValueUsd == 0) return true;

        return totalCollateralValueUsd >= totalBorrowValueUsd;
    }

    /**
     * @notice Public view to check if a user is healthy.
     */
    function isHealthy(address user) external view returns (bool) {
        return _isHealthy(user);
    }

    // --- Balance Helpers ---

    function _getDepositBalance(address user, address asset) internal view returns (uint256) {
        AssetConfig storage config = assetConfigs[asset];
        return (positions[user].depositShares[asset] * config.supplyIndex) / INDEX_PRECISION;
    }

    function _getBorrowBalance(address user, address asset) internal view returns (uint256) {
        AssetConfig storage config = assetConfigs[asset];
        return (positions[user].borrowShares[asset] * config.borrowIndex) / INDEX_PRECISION;
    }

    function getDepositBalance(address user, address asset) external view returns (uint256) {
        return _getDepositBalance(user, asset);
    }

    function getBorrowBalance(address user, address asset) external view returns (uint256) {
        return _getBorrowBalance(user, asset);
    }

    /**
     * @notice Get a user's account summary with current values.
     */
    function getAccountSummary(address user)
        external
        view
        returns (
            uint256 totalCollateralUsd,
            uint256 totalBorrowUsd,
            uint256 healthFactor // scaled by 1e18; < 1e18 means liquidatable
        )
    {
        address[] memory collaterals = userCollateralAssets[user];
        for (uint256 i = 0; i < collaterals.length; i++) {
            address asset = collaterals[i];
            uint256 depositBalance = _getDepositBalance(user, asset);
            if (depositBalance == 0) continue;

            (uint256 price, bool valid) = oracle.getTWAPPrice(asset);
            if (!valid) continue;

            AssetConfig storage config = assetConfigs[asset];
            uint256 valueUsd = (depositBalance * price) / 1e18;
            totalCollateralUsd += (valueUsd * config.liquidationThresholdBps) / BPS_DENOMINATOR;
        }

        address[] memory borrows = userBorrowAssets[user];
        for (uint256 i = 0; i < borrows.length; i++) {
            address asset = borrows[i];
            uint256 borrowBalance = _getBorrowBalance(user, asset);
            if (borrowBalance == 0) continue;

            (uint256 price, bool valid) = oracle.getTWAPPrice(asset);
            if (!valid) {
                totalBorrowUsd = type(uint256).max;
                break;
            }

            totalBorrowUsd += (borrowBalance * price) / 1e18;
        }

        if (totalBorrowUsd == 0) {
            healthFactor = type(uint256).max;
        } else if (totalBorrowUsd == type(uint256).max) {
            healthFactor = 0;
        } else {
            healthFactor = (totalCollateralUsd * 1e18) / totalBorrowUsd;
        }
    }

    function getSupportedAssetsCount() external view returns (uint256) {
        return supportedAssets.length;
    }
}