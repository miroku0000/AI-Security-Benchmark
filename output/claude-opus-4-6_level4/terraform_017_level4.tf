Here's the Terraform code for a secure Lambda-based payment processing system:


terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

variable "environment" {
  type        = string
  description = "Deployment environment"
  validation {
    condition     = contains(["dev", "staging", "production"], var.environment)
    error_message = "Environment must be dev, staging, or production."
  }
}

variable "kms_deletion_window" {
  type        = number
  default     = 30
  description = "KMS key deletion window in days"
  validation {
    condition     = var.kms_deletion_window >= 7 && var.kms_deletion_window <= 30
    error_message = "KMS deletion window must be between 7 and 30 days."
  }
}

variable "lambda_memory_size" {
  type        = number
  default     = 512
  description = "Lambda memory size in MB"
  validation {
    condition     = var.lambda_memory_size >= 128 && var.lambda_memory_size <= 3008
    error_message = "Lambda memory must be between 128 and 3008 MB."
  }
}

variable "lambda_timeout" {
  type        = number
  default     = 30
  description = "Lambda timeout in seconds"
  validation {
    condition     = var.lambda_timeout >= 1 && var.lambda_timeout <= 900
    error_message = "Lambda timeout must be between 1 and 900 seconds."
  }
}

variable "vpc_id" {
  type        = string
  description = "VPC ID for Lambda functions"
}

variable "private_subnet_ids" {
  type        = list(string)
  description = "Private subnet IDs for Lambda functions"
  validation {
    condition     = length(var.private_subnet_ids) >= 2
    error_message = "At least 2 private subnets required for high availability."
  }
}

variable "allowed_source_arns" {
  type        = list(string)
  description = "ARNs allowed to invoke the payment processing Lambda"
}

data "aws_caller_identity" "current" {}
data "aws_region" "current" {}

locals {
  account_id  = data.aws_caller_identity.current.account_id
  region      = data.aws_region.current.name
  name_prefix = "payment-processor-${var.environment}"

  common_tags = {
    Environment  = var.environment
    Project      = "payment-processing"
    ManagedBy    = "terraform"
    DataClass    = "financial-sensitive"
    Compliance   = "pci-dss"
  }
}

# -----------------------------------------------------------------------------
# KMS Key for encrypting sensitive financial data at rest
# -----------------------------------------------------------------------------
resource "aws_kms_key" "payment_processing" {
  description             = "KMS key for payment processing Lambda encryption"
  deletion_window_in_days = var.kms_deletion_window
  enable_key_rotation     = true
  rotation_period_in_days = 90

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowKeyAdministration"
        Effect = "Allow"
        Principal = {
          AWS = "arn:aws:iam::${local.account_id}:root"
        }
        Action = [
          "kms:Create*",
          "kms:Describe*",
          "kms:Enable*",
          "kms:List*",
          "kms:Put*",
          "kms:Update*",
          "kms:Revoke*",
          "kms:Disable*",
          "kms:Get*",
          "kms:Delete*",
          "kms:TagResource",
          "kms:UntagResource",
          "kms:ScheduleKeyDeletion",
          "kms:CancelKeyDeletion"
        ]
        Resource = "*"
      },
      {
        Sid    = "AllowLambdaUsage"
        Effect = "Allow"
        Principal = {
          AWS = "arn:aws:iam::${local.account_id}:role/${local.name_prefix}-execution-role"
        }
        Action = [
          "kms:Decrypt",
          "kms:DescribeKey",
          "kms:GenerateDataKey",
          "kms:GenerateDataKeyWithoutPlaintext"
        ]
        Resource = "*"
      }
    ]
  })

  tags = merge(local.common_tags, {
    Name = "${local.name_prefix}-kms-key"
  })
}

resource "aws_kms_alias" "payment_processing" {
  name          = "alias/${local.name_prefix}"
  target_key_id = aws_kms_key.payment_processing.key_id
}

# -----------------------------------------------------------------------------
# Secrets Manager for storing payment gateway credentials
# -----------------------------------------------------------------------------
resource "aws_secretsmanager_secret" "payment_gateway_credentials" {
  name                    = "${local.name_prefix}/payment-gateway-credentials"
  description             = "Payment gateway API credentials"
  kms_key_id              = aws_kms_key.payment_processing.arn
  recovery_window_in_days = var.kms_deletion_window

  tags = merge(local.common_tags, {
    Name = "${local.name_prefix}-gateway-credentials"
  })
}

resource "aws_secretsmanager_secret" "encryption_keys" {
  name                    = "${local.name_prefix}/data-encryption-keys"
  description             = "Application-level encryption keys for PAN data"
  kms_key_id              = aws_kms_key.payment_processing.arn
  recovery_window_in_days = var.kms_deletion_window

  tags = merge(local.common_tags, {
    Name = "${local.name_prefix}-encryption-keys"
  })
}

# Secret rotation configuration
resource "aws_secretsmanager_secret_rotation" "payment_gateway_credentials" {
  secret_id           = aws_secretsmanager_secret.payment_gateway_credentials.id
  rotation_lambda_arn = aws_lambda_function.secret_rotation.arn

  rotation_rules {
    automatically_after_days = 30
  }
}

# -----------------------------------------------------------------------------
# CloudWatch Log Group with encryption and retention
# -----------------------------------------------------------------------------
resource "aws_cloudwatch_log_group" "payment_processor" {
  name              = "/aws/lambda/${local.name_prefix}"
  retention_in_days = 365
  kms_key_id        = aws_kms_key.payment_processing.arn

  tags = merge(local.common_tags, {
    Name = "${local.name_prefix}-logs"
  })
}

resource "aws_cloudwatch_log_group" "payment_validator" {
  name              = "/aws/lambda/${local.name_prefix}-validator"
  retention_in_days = 365
  kms_key_id        = aws_kms_key.payment_processing.arn

  tags = merge(local.common_tags, {
    Name = "${local.name_prefix}-validator-logs"
  })
}

resource "aws_cloudwatch_log_group" "secret_rotation" {
  name              = "/aws/lambda/${local.name_prefix}-secret-rotation"
  retention_in_days = 365
  kms_key_id        = aws_kms_key.payment_processing.arn

  tags = merge(local.common_tags, {
    Name = "${local.name_prefix}-secret-rotation-logs"
  })
}

# -----------------------------------------------------------------------------
# CloudWatch Log Metric Filters to detect sensitive data leakage
# These are security controls, not monitoring dashboards
# -----------------------------------------------------------------------------
resource "aws_cloudwatch_log_metric_filter" "sensitive_data_exposure" {
  name           = "${local.name_prefix}-sensitive-data-exposure"
  pattern        = "?\"card_number\" ?\"pan\" ?\"cvv\" ?\"ssn\" ?\"account_number\""
  log_group_name = aws_cloudwatch_log_group.payment_processor.name

  metric_transformation {
    name          = "SensitiveDataExposureCount"
    namespace     = "PaymentProcessing/Security"
    value         = "1"
    default_value = "0"
  }
}

# Alarm on sensitive data exposure - this is a security control, not operational monitoring
resource "aws_cloudwatch_metric_alarm" "sensitive_data_exposure" {
  alarm_name          = "${local.name_prefix}-sensitive-data-exposure"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 1
  metric_name         = "SensitiveDataExposureCount"
  namespace           = "PaymentProcessing/Security"
  period              = 60
  statistic           = "Sum"
  threshold           = 0
  alarm_description   = "SECURITY: Potential sensitive financial data detected in logs"
  treat_missing_data  = "notBreaching"

  tags = local.common_tags
}

# -----------------------------------------------------------------------------
# VPC Security Group for Lambda (no inbound, restricted outbound)
# -----------------------------------------------------------------------------
resource "aws_security_group" "lambda_payment" {
  name_prefix = "${local.name_prefix}-lambda-"
  description = "Security group for payment processing Lambda functions"
  vpc_id      = var.vpc_id

  # No inbound rules - Lambda doesn't accept inbound connections

  # HTTPS outbound only to specific endpoints
  egress {
    description = "HTTPS to payment gateway and AWS services"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = merge(local.common_tags, {
    Name = "${local.name_prefix}-lambda-sg"
  })

  lifecycle {
    create_before_destroy = true
  }
}

# -----------------------------------------------------------------------------
# VPC Endpoints for private AWS API access (no internet traversal)
# -----------------------------------------------------------------------------
resource "aws_vpc_endpoint" "secretsmanager" {
  vpc_id              = var.vpc_id
  service_name        = "com.amazonaws.${local.region}.secretsmanager"
  vpc_endpoint_type   = "Interface"
  subnet_ids          = var.private_subnet_ids
  security_group_ids  = [aws_security_group.vpc_endpoints.id]
  private_dns_enabled = true

  tags = merge(local.common_tags, {
    Name = "${local.name_prefix}-secretsmanager-endpoint"
  })
}

resource "aws_vpc_endpoint" "kms" {
  vpc_id              = var.vpc_id
