  })
}

resource "aws_security_group" "vpc_endpoints" {
  name_prefix = "${local.name_prefix}-vpce-"
  description = "Security group for VPC endpoints"
  vpc_id      = var.vpc_id

  ingress {
    description     = "HTTPS from Lambda"
    from_port       = 443
    to_port         = 443
    protocol        = "tcp"
    security_groups = [aws_security_group.lambda_payment.id]
  }

  tags = merge(local.common_tags, {
    Name = "${local.name_prefix}-vpce-sg"
  })

  lifecycle {
    create_before_destroy = true
  }
}

# -----------------------------------------------------------------------------
# DynamoDB table for payment transaction records (encrypted)
# -----------------------------------------------------------------------------
resource "aws_dynamodb_table" "payment_transactions" {
  name         = "${local.name_prefix}-transactions"
  billing_mode = "PAY_PER_REQUEST"
  hash_key     = "transaction_id"
  range_key    = "created_at"

  attribute {
    name = "transaction_id"
    type = "S"
  }

  attribute {
    name = "created_at"
    type = "S"
  }

  attribute {
    name = "merchant_id"
    type = "S"
  }

  global_secondary_index {
    name            = "merchant-index"
    hash_key        = "merchant_id"
    range_key       = "created_at"
    projection_type = "KEYS_ONLY"
  }

  server_side_encryption {
    enabled     = true
    kms_key_arn = aws_kms_key.payment_processing.arn
  }

  point_in_time_recovery {
    enabled = true
  }

  deletion_protection_enabled = var.environment == "production" ? true : false

  tags = merge(local.common_tags, {
    Name = "${local.name_prefix}-transactions"
  })
}

# -----------------------------------------------------------------------------
# DynamoDB table for idempotency (prevent duplicate payment processing)
# -----------------------------------------------------------------------------
resource "aws_dynamodb_table" "idempotency" {
  name         = "${local.name_prefix}-idempotency"
  billing_mode = "PAY_PER_REQUEST"
  hash_key     = "idempotency_key"

  attribute {
    name = "idempotency_key"
    type = "S"
  }

  ttl {
    attribute_name = "expires_at"
    enabled        = true
  }

  server_side_encryption {
    enabled     = true
    kms_key_arn = aws_kms_key.payment_processing.arn
  }

  point_in_time_recovery {
    enabled = true
  }

  tags = merge(local.common_tags, {
    Name = "${local.name_prefix}-idempotency"
  })
}

# -----------------------------------------------------------------------------
# SQS Dead Letter Queue for failed payment processing
# -----------------------------------------------------------------------------
resource "aws_sqs_queue" "payment_dlq" {
  name                       = "${local.name_prefix}-dlq"
  message_retention_seconds  = 1209600 # 14 days
  kms_master_key_id          = aws_kms_key.payment_processing.arn
  kms_data_key_reuse_period_seconds = 300

  tags = merge(local.common_tags, {
    Name = "${local.name_prefix}-dlq"
  })
}

resource "aws_sqs_queue_policy" "payment_dlq" {
  queue_url = aws_sqs_queue.payment_dlq.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowLambdaSendMessage"
        Effect = "Allow"
        Principal = {
          AWS = aws_iam_role.payment_processor_execution.arn
        }
        Action   = "sqs:SendMessage"
        Resource = aws_sqs_queue.payment_dlq.arn
      }
    ]
  })
}

# -----------------------------------------------------------------------------
# IAM Role - Payment Processor Lambda (Least Privilege)
# -----------------------------------------------------------------------------
resource "aws_iam_role" "payment_processor_execution" {
  name = "${local.name_prefix}-execution-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
