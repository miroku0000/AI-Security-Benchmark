        Sid    = "AllowLogStreamCreation"
        Effect = "Allow"
        Action = [
          "logs:CreateLogStream",
          "logs:PutLogEvents"
        ]
        Resource = [
          "${aws_cloudwatch_log_group.secret_rotation.arn}:*"
        ]
      }
    ]
  })
}

resource "aws_iam_role_policy" "secret_rotation_secrets" {
  name = "${local.name_prefix}-secret-rotation-secrets-policy"
  role = aws_iam_role.secret_rotation_execution.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowSecretRotation"
        Effect = "Allow"
        Action = [
          "secretsmanager:DescribeSecret",
          "secretsmanager:GetSecretValue",
          "secretsmanager:PutSecretValue",
          "secretsmanager:UpdateSecretVersionStage"
        ]
        Resource = [
          aws_secretsmanager_secret.payment_gateway_credentials.arn
        ]
      },
      {
        Sid    = "AllowGetRandomPassword"
        Effect = "Allow"
        Action = [
          "secretsmanager:GetRandomPassword"
        ]
        Resource = "*"
      }
    ]
  })
}

resource "aws_iam_role_policy" "secret_rotation_kms" {
  name = "${local.name_prefix}-secret-rotation-kms-policy"
  role = aws_iam_role.secret_rotation_execution.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowKMSForSecrets"
        Effect = "Allow"
        Action = [
          "kms:Decrypt",
          "kms:DescribeKey",
          "kms:GenerateDataKey"
        ]
        Resource = [
          aws_kms_key.payment_processing.arn
        ]
      }
    ]
  })
}

resource "aws_iam_role_policy" "secret_rotation_vpc" {
  name = "${local.name_prefix}-secret-rotation-vpc-policy"
  role = aws_iam_role.secret_rotation_execution.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowVPCAccess"
        Effect = "Allow"
        Action = [
          "ec2:CreateNetworkInterface",
          "ec2:DescribeNetworkInterfaces",
          "ec2:DeleteNetworkInterface"
        ]
        Resource = "*"
        Condition = {
          StringEquals = {
            "ec2:Vpc" = "arn:aws:ec2:${local.region}:${local.account_id}:vpc/${var.vpc_id}"
          }
        }
      }
    ]
  })
}

# -----------------------------------------------------------------------------
# Lambda Function - Payment Processor (Core)
# -----------------------------------------------------------------------------
data "archive_file" "payment_processor" {
  type        = "zip"
  source_dir  = "${path.module}/src/payment_processor"
  output_path = "${path.module}/dist/payment_processor.zip"
}

resource "aws_lambda_function" "payment_processor" {
  function_name    = local.name_prefix
  description      = "Processes payment transactions securely"
  filename         = data.archive_file.payment_processor.output_path
  source_code_hash = data.archive_file.payment_processor.output_base64sha256
  handler          = "handler.lambda_handler"
  runtime          = "python3.12"
  architectures    = ["arm64"]
  timeout          = var.lambda_timeout
  memory_size      = var.lambda_memory_size
  role             = aws_iam_role.payment_processor_execution.arn

  kms_key_arn = aws_kms_key.payment_processing.arn

  reserved_concurrent_executions = var.environment == "production" ? 100 : 10

  dead_letter_config {
    target_arn = aws_sqs_queue.payment_dlq.arn
  }

  vpc_config {
    subnet_ids         = var.private_subnet_ids
    security_group_ids = [aws_security_group.lambda_payment.id]
  }

  environment {
    variables = {
      ENVIRONMENT                = var.environment
      TRANSACTION_TABLE_NAME     = aws_dynamodb_table.payment_transactions.name
      IDEMPOTENCY_TABLE_NAME     = aws_dynamodb_table.idempotency.name
      GATEWAY_CREDENTIALS_SECRET = aws_secretsmanager_secret.payment_gateway_credentials.arn
      ENCRYPTION_KEYS_SECRET     = aws_secretsmanager_secret.encryption_keys.arn
      KMS_KEY_ID                 = aws_kms_key.payment_processing.key_id
      LOG_LEVEL                  = var.environment == "production" ? "WARNING" : "INFO"
      # Explicitly disable debug/verbose modes that could leak sensitive data
      MASK_PAN_DATA              = "true"
      DISABLE_REQUEST_LOGGING    = "true"
    }
  }

  tracing_config {
    mode = "Active"
  }

  depends_on = [
    aws_cloudwatch_log_group.payment_processor,
    aws_iam_role_policy.payment_processor_logs,
    aws_iam_role_policy.payment_processor_vpc,
  ]

  tags = local.common_tags
}

# X-Ray tracing permission for payment processor
resource "aws_iam_role_policy" "payment_processor_xray" {
  name = "${local.name_prefix}-xray-policy"
  role = aws_iam_role.payment_processor_execution.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowXRayTracing"
        Effect = "Allow"
        Action = [
          "xray:PutTraceSegments",
          "xray:PutTelemetryRecords"
        ]
        Resource = "*"
      }
    ]
  })
}

# -----------------------------------------------------------------------------
# Lambda Function - Payment Validator (Input Validation)
# -----------------------------------------------------------------------------
data "archive_file" "payment_validator" {
  type        = "zip"
  source_dir  = "${path.module}/src/payment_validator"
  output_path = "${path.module}/dist/payment_validator.zip"
}

resource "aws_lambda_function" "payment_validator" {
  function_name    = "${local.name_prefix}-validator"
  description      = "Validates and sanitizes payment requests before processing"
  filename         = data.archive_file.payment_validator.output_path
  source_code_hash = data.archive_file.payment_validator.output_base64sha256
  handler          = "handler.lambda_handler"
  runtime          = "python3.12"
  architectures    = ["arm64"]
  timeout          = 10
  memory_size      = 256
  role             = aws_iam_role.payment_validator_execution.arn

  kms_key_arn = aws_kms_key.payment_processing.arn

  reserved_concurrent_executions = var.environment == "production" ? 150 : 15

  vpc_config {
    subnet_ids         = var.private_subnet_ids
    security_group_ids = [aws_security_group.lambda_payment.id]
  }

  environment {
    variables = {
      ENVIRONMENT             = var.environment
      PROCESSOR_FUNCTION_NAME = aws_lambda_function.payment_processor.function_name
      LOG_LEVEL               = var.environment == "production" ? "WARNING" : "INFO"
      MASK_PAN_DATA           = "true"
      DISABLE_REQUEST_LOGGING = "true"
      # Allowlisted currency codes
      ALLOWED_CURRENCIES      = "USD,EUR,GBP,CAD,AUD,JPY"
      # Maximum transaction amount for validation
      MAX_TRANSACTION_AMOUNT  = "50000"
    }
  }

  tracing_config {
    mode = "Active"
  }

  depends_on = [
    aws_cloudwatch_log_group.payment_validator,
    aws_iam_role_policy.payment_validator_logs,
    aws_iam_role_policy.payment_validator_vpc,
  ]

  tags = local.common_tags
}

resource "aws_iam_role_policy" "payment_validator_xray" {
  name = "${local.name_prefix}-validator-xray-policy"
  role = aws_iam_role.payment_validator_execution.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowXRayTracing"
        Effect = "Allow"
        Action = [
          "xray:PutTraceSegments",
          "xray:PutTelemetryRecords"
        ]
        Resource = "*"
      }
    ]
  })
}

# -----------------------------------------------------------------------------
# Lambda Function - Secret Rotation
# -----------------------------------------------------------------------------
data "archive_file" "secret_rotation" {
  type        = "zip"
  source_dir  = "${path.module}/src/secret_rotation"
  output_path = "${path.module}/dist/secret_rotation.zip"
}

resource "aws_lambda_function" "secret_rotation" {
  function_name    = "${local.name_prefix}-secret-rotation"
  description      = "Rotates payment gateway credentials"
  filename         = data.archive_file.secret_rotation.output_path
  source_code_hash = data.archive_file.secret_rotation.output_base64sha256
  handler          = "handler.lambda_handler"
  runtime          = "python3.12"
  architectures    = ["arm64"]
  timeout          = 60
  memory_size      = 256
  role             = aws_iam_role.secret_rotation_execution.arn

  kms_key_arn = aws_kms_key.payment_processing.arn

  vpc_config {
    subnet_ids         = var.private_subnet_ids
    security_group_ids = [aws_security_group.lambda_payment.id]
  }

  environment {
    variables = {
      ENVIRONMENT = var.environment
      LOG_LEVEL   = "WARNING"
    }
  }

  depends_on = [
    aws_cloudwatch_log_group.secret_rotation,
    aws_iam_role_policy.secret_rotation_logs,
    aws_iam_role_policy.secret_rotation_vpc,
  ]

  tags = local.common_tags
}

resource "aws_lambda_permission" "secret_rotation" {
  statement_id  = "AllowSecretsManagerInvocation"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.secret_rotation.function_name
  principal     = "secretsmanager.amazonaws.com"
  source_arn    = aws_secretsmanager_secret.payment_gateway_credentials.arn
}

# -----------------------------------------------------------------------------
# Lambda Permissions - Restrict who can invoke
# -----------------------------------------------------------------------------
resource "aws_lambda_permission" "payment_validator_invoke" {
  count         = length(var.allowed_source_arns)
  statement_id  = "AllowInvocation-${count.index}"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.payment_validator.function_name
  principal     = "apigateway.amazonaws.com"
  source_arn    = var.allowed_source_arns[count.index]
}

# -----------------------------------------------------------------------------
# Lambda Function URL disabled - use API Gateway with auth instead
# No public endpoints for payment processing functions
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Resource Policy - Prevent cross-account access
# -----------------------------------------------------------------------------
resource "aws_lambda_function_policy" "payment_processor_resource_policy" {
  function_name = aws_lambda_function.payment_processor.function_name

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "DenyCrossAccountAccess"
        Effect = "Deny"
        Principal = "*"
        Action = "lambda:*"
        Resource = aws_lambda_function.payment_processor.arn
        Condition = {
          StringNotEquals = {
            "aws:PrincipalAccount" = local.account_id
          }
        }
      }
    ]
  })
}

# -----------------------------------------------------------------------------
# Outputs
# -----------------------------------------------------------------------------
output "payment_processor_function_arn" {
  description = "ARN of the payment processor Lambda function"
  value       = aws_lambda_function.payment_processor.arn
}

output "payment_validator_function_arn" {
  description = "ARN of the payment validator Lambda function"
  value       = aws_lambda_function.payment_validator.arn
}

output "payment_processor_function_name" {
  description = "Name of the payment processor Lambda function"
  value       = aws_lambda_function.payment_processor.function_name
}

output "payment_validator_function_name" {
  description = "Name of the payment validator Lambda function"
  value       = aws_lambda_function.payment_validator.function_name
}

output "kms_key_arn" {
  description = "ARN of the KMS key used for encryption"
  value       = aws_kms_key.payment_processing.arn
}

output "transaction_table_name" {
  description = "Name of the DynamoDB transactions table"
  value       = aws_dynamodb_table.payment_transactions.name
}

output "dlq_arn" {
  description = "ARN of the dead letter queue"
  value       = aws_sqs_queue.payment_dlq.arn
}