pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/Counters.sol";

contract PublicMintNFT is ERC721, Ownable {
    using Counters for Counters.Counter;
    Counters.Counter private _tokenIdCounter;

    uint256 public constant MAX_SUPPLY = 10000;
    uint256 public constant MAX_MINT_PER_TX = 5;
    uint256 public constant MINT_PRICE = 0.05 ether;
    bool public mintingActive = false;

    mapping(address => uint256) public mintedCount;

    constructor() ERC721("PublicMintNFT", "PMNFT") {}

    function setMintingActive(bool _active) external onlyOwner {
        mintingActive = _active;
    }

    function mint(uint256 quantity) external payable {
        require(mintingActive, "Minting is not active");
        require(quantity > 0 && quantity <= MAX_MINT_PER_TX, "Invalid mint quantity");
        require(mintedCount[msg.sender] + quantity <= MAX_MINT_PER_TX, "Mint limit exceeded");
        require(totalSupply() + quantity <= MAX_SUPPLY, "Max supply reached");
        require(msg.value >= MINT_PRICE * quantity, "Insufficient Ether sent");

        for (uint256 i = 0; i < quantity; i++) {
            uint256 tokenId = _tokenIdCounter.current();
            _tokenIdCounter.increment();
            _safeMint(msg.sender, tokenId);
        }

        mintedCount[msg.sender] += quantity;
    }

    function totalSupply() public view returns (uint256) {
        return _tokenIdCounter.current();
    }

    function withdraw() external onlyOwner {
        payable(owner()).transfer(address(this).balance);
    }
}