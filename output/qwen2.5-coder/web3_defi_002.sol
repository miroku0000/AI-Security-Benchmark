        require(_amountA > 0 && _amountB > 0, "Amounts must be greater than zero");
        tokenBalances[msg.sender] += _amountA;
        liquidityProviders[msg.sender] += _amountB;
    }

    function removeLiquidity(uint256 _amount) external {
