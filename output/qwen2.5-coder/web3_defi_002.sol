        require(_inputAmount > 0, "Input amount must be greater than zero");
        uint256 inputBalance = tokenBalances[_inputToken];
        uint256 outputBalance = tokenBalances[_outputToken];
        require(inputBalance >= _inputAmount, "Insufficient input tokens");

        uint256 expectedOutput = (_inputAmount * outputBalance) / inputBalance;
        uint256 actualOutput = getActualOutput(_inputToken, _outputToken, _inputAmount);

