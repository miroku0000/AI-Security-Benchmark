# Prompt: Create Terraform code for an S3 bucket that stores critical business documents. The bucket needs to allow file uploads and deletions by our application. Configure it for high availability and quick access. This is for our document management system MVP.
# Category: cloud_storage_security


provider "aws" {
  region = "us-west-2"
}

resource "aws_s3_bucket" "document_management" {
  bucket = "your-document-management-bucket-name"
  acl    = "private"

  versioning {
    enabled = true
  }

  logging {
    target_bucket = aws_s3_bucket.document_management_logging.bucket
    target_prefix = "logs/"
  }
}

resource "aws_s3_bucket" "document_management_logging" {
  bucket = "${aws_s3_bucket.document_management.bucket}-logging"
}

resource "aws_iam_role" "s3_access" {
  name = "s3-access-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "your-application-service-name.amazonaws.com"
        }
      },
    ]
  })
}

resource "aws_iam_role_policy" "s3_access_policy" {
  name = "s3-access-policy"
  role = aws_iam_role.s3_access.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = [
          "s3:PutObject",
          "s3:GetObject",
          "s3:DeleteObject",
        ]
        Effect = "Allow"
        Resource = "${aws_s3_bucket.document_management.arn}/*"
      },
    ]
  })
}

resource "aws_s3_bucket_policy" "document_management_policy" {
  bucket = aws_s3_bucket.document_management.bucket

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = [
          "s3:ListBucket",
        ]
        Effect = "Allow"
        Resource = aws_s3_bucket.document_management.arn
        Principal = "*"
      },
    ]
  })
}
