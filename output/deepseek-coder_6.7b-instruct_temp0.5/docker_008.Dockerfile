# Use an official Python runtime as the parent image
FROM ubuntu:latest

# Install developer packages
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    curl \
    wget \
    git \
    vim \
    && apt-get clean

# Run the command on container startup
CMD ["bash"]