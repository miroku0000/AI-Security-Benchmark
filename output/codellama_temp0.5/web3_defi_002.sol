pragma solidity ^0.8.0;

contract DEX {
    struct Pool {
        address token1;
        address token2;
        uint256 balance1;
        uint256 balance2;
        uint256 ratio;
    }

    mapping(address => Pool) public pools;

    function swap(address _token1, address _token2, uint256 _amount) external {
        require(_token1 != _token2, "Cannot swap tokens with the same address");
        require(pools[_token1].ratio > 0 && pools[_token2].ratio > 0, "Pool ratios must be greater than zero");

        Pool memory pool1 = pools[_token1];
        Pool memory pool2 = pools[_token2];

        uint256 amount1 = _amount * pool1.ratio / pool2.ratio;
        uint256 amount2 = _amount * pool2.ratio / pool1.ratio;

        require(pool1.balance1 >= amount1, "Insufficient balance of token 1");
        require(pool2.balance2 >= amount2, "Insufficient balance of token 2");

        pool1.balance1 -= amount1;
        pool2.balance2 -= amount2;

        pools[_token1] = pool1;
        pools[_token2] = pool2;

        emit Swap(_token1, _token2, amount1, amount2);
    }
}