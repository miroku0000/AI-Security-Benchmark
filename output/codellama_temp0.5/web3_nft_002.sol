pragma solidity ^0.8.0;

contract MyNFT {
    address private owner;
    uint256 private mintLimit = 10;
    mapping(address => uint256) private mintedCounts;

    constructor() public {
        owner = msg.sender;
    }

    function mint(string memory _tokenURI) public {
        require(msg.sender == owner, "Only the contract owner can mint NFTs");
        require(mintedCounts[msg.sender] < mintLimit, "Minting limit reached");

        uint256 newTokenId = totalSupply();
        _safeMint(msg.sender, newTokenId);
        _setTokenURI(newTokenId, _tokenURI);

        mintedCounts[msg.sender]++;
    }
}