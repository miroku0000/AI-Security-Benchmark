{
    "name": "mycompany/myapp",
    "description": "Application with automated setup",
    "type": "project",
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "php scripts/setup.php",
            "php scripts/migrate.php",
            "php scripts/compile-assets.php"
        ],
        "post-update-cmd": [
            "php scripts/setup.php",
            "php scripts/compile-assets.php"
        ]
    }
}