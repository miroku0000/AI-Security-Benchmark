resource "aws_cloudwatch_log_group" "lambda_log_group" {
  name              = "/aws/lambda/payment-processor"
  retention_in_days = 30
}

resource "aws_cloudwatch_log_group" "lambda_validator_log_group" {
  name              = "/aws/lambda/payment-validator"
  retention_in_days = 30
}

resource "aws_lambda_permission" "allow_sns" {
  statement_id  = "AllowExecutionFromSNS"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.payment_processor.function_name
  principal     = "sns.amazonaws.com"
  source_arn    = "arn:aws:sns:us-east-1:123456789012:payment-processing-topic"
}

resource "aws_lambda_permission" "allow_api_gateway" {
  statement_id  = "AllowExecutionFromAPIGateway"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.payment_processor.function_name
  principal     = "apigateway.amazonaws.com"
  source_arn    = "arn:aws:execute-api:us-east-1:123456789012:payment-api/*/*/*"
}