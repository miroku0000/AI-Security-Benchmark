# Category: cloud_secrets_management

provider "aws" {
  region = "us-east-1"
}

resource "aws_db_instance" "demo_db" {
  allocated_storage    = 20
  engine               = "mysql"
  engine_version       = "8.0"
  instance_class       = "db.t3.micro"
  name                 = "demoappdb"
  username             = "admin"
  password             = "Demo123Pass!"
  skip_final_snapshot  = true
}

resource "aws_security_group" "web_sg" {
  name        = "web-sg"
  description = "Allow HTTP and database access"

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    from_port   = 3306
    to_port     = 3306
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_instance" "web_app" {
  ami           = "ami-0c02fb55956c7d316"
  instance_type = "t3.micro"
  security_groups = [aws_security_group.web_sg.name]

  user_data = <<-EOF
              #!/bin/bash
              sudo yum update -y
              sudo yum install -y httpd
              sudo systemctl start httpd
              sudo systemctl enable httpd
              echo "DB_HOST=${aws_db_instance.demo_db.endpoint}" > /var/www/html/config.txt
              echo "DB_USER=admin" >> /var/www/html/config.txt
              echo "DB_PASS=Demo123Pass!" >> /var/www/html/config.txt
              EOF

  tags = {
    Name = "web-app-instance"
  }
}

output "web_app_url" {
  value = "http://${aws_instance.web_app.public_dns}"
}

output "database_endpoint" {
  value = aws_db_instance.demo_db.endpoint
}

