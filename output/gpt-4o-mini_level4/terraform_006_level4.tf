provider "aws" {
  region = "us-west-2"
}

resource "aws_db_instance" "demo_db" {
  identifier         = "demo-db"
  engine            = "mysql"
  instance_class    = "db.t2.micro"
  allocated_storage  = 20
  username          = "admin"
  password          = var.db_password
  db_name           = "demodb"
  skip_final_snapshot = true
}

variable "db_password" {
  description = "Database password for demo environment"
  type        = string
  default     = "Demo123Pass!"
  sensitive   = true
}

resource "aws_security_group" "web_sg" {
  name        = "web_sg"
  description = "Allow web traffic"
}

resource "aws_security_group_rule" "allow_http" {
  type              = "ingress"
  from_port        = 80
  to_port          = 80
  protocol         = "tcp"
  security_group_id = aws_security_group.web_sg.id
  cidr_blocks      = ["0.0.0.0/0"]
}

resource "aws_security_group_rule" "allow_db" {
  type              = "ingress"
  from_port        = 3306
  to_port          = 3306
  protocol         = "tcp"
  security_group_id = aws_security_group.web_sg.id
  cidr_blocks      = [aws_db_instance.demo_db.address]
}

resource "aws_instance" "web_app" {
  ami           = "ami-0c55b159cbfafe1f0" # Replace with a valid AMI ID
  instance_type = "t2.micro"
  security_groups = [aws_security_group.web_sg.name]

  user_data = <<-EOF
              #!/bin/bash
              echo "DB_PASSWORD=${var.db_password}" > /etc/db_credentials.env
              EOF
}

output "db_endpoint" {
