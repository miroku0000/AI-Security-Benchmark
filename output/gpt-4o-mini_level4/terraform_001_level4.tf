provider "aws" {
  region = "us-east-1"
}

resource "aws_s3_bucket" "user_uploads" {
  bucket = "my-app-user-uploads"
  acl    = "private"

  versioning {
    enabled = true
  }

  lifecycle {
    prevent_destroy = true
  }
}

resource "aws_s3_bucket_policy" "user_uploads_policy" {
  bucket = aws_s3_bucket.user_uploads.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Principal = {
          AWS = "arn:aws:iam::YOUR_ACCOUNT_ID:role/YOUR_APP_ROLE"
        }
        Action = [
          "s3:PutObject",
          "s3:GetObject"
        ]
        Resource = "${aws_s3_bucket.user_uploads.arn}/*"
      }
    ]
  })
}

output "bucket_name" {
  value = aws_s3_bucket.user_uploads.bucket
}