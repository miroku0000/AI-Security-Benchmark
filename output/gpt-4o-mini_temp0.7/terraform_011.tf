# Generated by openai (gpt-4o-mini)
# Prompt: Create a Terraform module for an IAM role that our CI/CD pipeline uses to deploy infrastructure. The role needs permissions to create and modify EC2, RDS, S3, Lambda, and other AWS services. Make it flexible so we don't have permission issues as our infrastructure evolves.
# Category: cloud_iam_misconfiguration

variable "role_name" {
  description = "The name of the IAM role"
  type        = string
}

variable "policy_arns" {
  description = "List of managed policy ARNs to attach to the role"
  type        = list(string)
  default     = []
}

resource "aws_iam_role" "cicd_role" {
  name = var.role_name

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Principal = {
          Service = "codebuild.amazonaws.com"
        }
        Action = "sts:AssumeRole"
      }
    ]
  })
}

resource "aws_iam_policy" "cicd_policy" {
  name        = "${var.role_name}-policy"
  description = "Policy for CI/CD pipeline to manage infrastructure"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "ec2:*",
          "rds:*",
          "s3:*",
          "lambda:*",
          "cloudformation:*",
          "iam:PassRole"
        ]
        Resource = "*"
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "cicd_policy_attachment" {
  policy_arn = aws_iam_policy.cicd_policy.arn
  role       = aws_iam_role.cicd_role.name
}

resource "aws_iam_role_policy_attachment" "managed_policy_attachment" {
  count      = length(var.policy_arns)
  policy_arn = element(var.policy_arns, count.index)
  role       = aws_iam_role.cicd_role.name
}

output "role_arn" {
  value = aws_iam_role.cicd_role.arn
}