# main.tf
data "aws_caller_identity" "current" {}
data "aws_partition" "current" {}
data "aws_region" "current" {}

locals {
  account_id = data.aws_caller_identity.current.account_id
  partition  = data.aws_partition.current.partition
  region     = data.aws_region.current.name

  default_tags = merge(
    {
      ManagedBy = "terraform"
      Purpose   = "cicd-deployment"
      Role      = var.role_name
    },
    var.tags
  )

  service_action_wildcards = [for svc in var.allowed_services : "${svc}:*"]
}

# Trust policy
data "aws_iam_policy_document" "assume_role" {
  # Trust AWS accounts
  dynamic "statement" {
    for_each = length(var.trusted_account_ids) > 0 ? [1] : []
    content {
      sid     = "TrustAWSAccounts"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      principals {
        type        = "AWS"
        identifiers = [for id in var.trusted_account_ids : "arn:${local.partition}:iam::${id}:root"]
      }

      dynamic "condition" {
        for_each = var.require_mfa ? [1] : []
        content {
          test     = "Bool"
          variable = "aws:MultiFactorAuthPresent"
          values   = ["true"]
        }
      }

      dynamic "condition" {
        for_each = var.external_id != null ? [1] : []
        content {
          test     = "StringEquals"
          variable = "sts:ExternalId"
          values   = [var.external_id]
        }
      }
    }
  }

  # Trust AWS services
  dynamic "statement" {
    for_each = length(var.trusted_service_principals) > 0 ? [1] : []
    content {
      sid     = "TrustAWSServices"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      principals {
        type        = "Service"
        identifiers = var.trusted_service_principals
      }
    }
  }

  # Trust OIDC providers (GitHub Actions, GitLab CI, etc.)
  dynamic "statement" {
    for_each = var.trusted_oidc_providers
    content {
      sid     = "TrustOIDC${replace(title(statement.key), "/[^a-zA-Z0-9]/", "")}"
      effect  = "Allow"
      actions = ["sts:AssumeRoleWithWebIdentity"]

      principals {
        type        = "Federated"
        identifiers = [statement.value.provider_arn]
      }

      dynamic "condition" {
        for_each = statement.value.conditions
        content {
          test     = condition.value.test
          variable = condition.value.variable
          values   = condition.value.values
        }
      }
    }
  }

  # Fallback: trust current account if no other trust is configured
  dynamic "statement" {
    for_each = (
      length(var.trusted_account_ids) == 0 &&
      length(var.trusted_service_principals) == 0 &&
      length(var.trusted_oidc_providers) == 0
    ) ? [1] : []
    content {
      sid     = "TrustCurrentAccount"
      effect  = "Allow"
      actions = ["sts:AssumeRole"]

      principals {
        type        = "AWS"
        identifiers = ["arn:${local.partition}:iam::${local.account_id}:root"]
      }
    }
  }
}

# IAM Role
resource "aws_iam_role" "cicd" {
  name                 = var.role_name
  assume_role_policy   = data.aws_iam_policy_document.assume_role.json
  max_session_duration = var.max_session_duration
  permissions_boundary = var.permissions_boundary_arn
  tags                 = local.default_tags
}

# Broad service access policy (when not using admin)
data "aws_iam_policy_document" "service_access" {
  count = var.enable_admin_access ? 0 : 1

  statement {
    sid       = "AllowServiceAccess"
    effect    = "Allow"
    actions   = local.service_action_wildcards
    resources = ["*"]
  }

  # Terraform state management - S3 and DynamoDB
  statement {
    sid    = "TerraformStateManagement"
    effect = "Allow"
    actions = [
      "s3:ListBucket",
      "s3:GetObject",
      "s3:PutObject",
      "s3:DeleteObject",
      "dynamodb:GetItem",
      "dynamodb:PutItem",
      "dynamodb:DeleteItem",
      "dynamodb:DescribeTable"
    ]
    resources = ["*"]
  }

  # Allow reading account-level information
  statement {
    sid    = "AllowAccountDiscovery"
    effect = "Allow"
    actions = [
      "sts:GetCallerIdentity",
      "sts:GetAccessKeyInfo",
      "iam:GetAccountSummary",
      "iam:ListAccountAliases",
      "iam:GetAccountAuthorizationDetails"
    ]
    resources = ["*"]
  }
}

resource "aws_iam_policy" "service_access" {
  count = var.enable_admin_access ? 0 : 1

  name        = "${var.role_name}-service-access"
  description = "Broad service access policy for CI/CD deployment role"
  policy      = data.aws_iam_policy_document.service_access[0].json
  tags        = local.default_tags
}

resource "aws_iam_role_policy_attachment" "service_access" {
  count = var.enable_admin_access ? 0 : 1

  role       = aws_iam_role.cicd.name
  policy_arn = aws_iam_policy.service_access[0].arn
}

