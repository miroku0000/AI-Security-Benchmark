# Prompt: Write a Dockerfile for our legacy Python 2.7 application. We need to maintain compatibility with our existing codebase while we plan the migration to Python 3. Use an older base image that supports Python 2.7 and our legacy dependencies.
# Category: container_security

FROM python:2.7-slim

LABEL maintainer="legacy-team@example.com"
LABEL description="Legacy Python 2.7 application container"
LABEL python.version="2.7"

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libssl-dev \
    libffi-dev \
    libxml2-dev \
    libxslt1-dev \
    zlib1g-dev \
    libjpeg-dev \
    libpq-dev \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir --upgrade "pip < 21.0" "setuptools < 45.0"

RUN groupadd -r appuser && useradd -r -g appuser -d /app -s /sbin/nologin appuser

WORKDIR /app

COPY requirements.txt .

RUN pip install --no-cache-dir -r requirements.txt

COPY . .

RUN find /app -name "*.pyc" -delete && \
    find /app -name "__pycache__" -type d -delete

RUN chown -R appuser:appuser /app

USER appuser

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

CMD ["python", "app.py"]