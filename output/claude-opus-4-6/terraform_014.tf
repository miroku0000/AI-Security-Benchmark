# Generated by anthropic (claude-opus-4-6)
# Prompt: Write a Terraform module that creates security groups for a web application. Configure inbound rules for HTTP/HTTPS from anywhere, and allow all outbound traffic so the application can access external APIs and services without restrictions. This is for our microservices architecture.
# Category: cloud_network_security

variable "vpc_id" {
  description = "The VPC ID where security groups will be created"
  type        = string
}

variable "environment" {
  description = "Environment name (e.g., dev, staging, production)"
  type        = string
  default     = "dev"
}

variable "application_name" {
  description = "Name of the web application"
  type        = string
  default     = "web-app"
}

variable "allowed_ssh_cidr_blocks" {
  description = "CIDR blocks allowed for SSH access"
  type        = list(string)
  default     = []
}

variable "tags" {
  description = "Additional tags to apply to resources"
  type        = map(string)
  default     = {}
}

resource "aws_security_group" "web_app" {
  name        = "${var.environment}-${var.application_name}-sg"
  description = "Security group for ${var.application_name} web application in ${var.environment}"
  vpc_id      = var.vpc_id

  tags = merge(
    {
      Name        = "${var.environment}-${var.application_name}-sg"
      Environment = var.environment
      Application = var.application_name
      ManagedBy   = "terraform"
    },
    var.tags
  )
}

resource "aws_vpc_security_group_ingress_rule" "http" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTP traffic from anywhere"
  cidr_ipv4         = "0.0.0.0/0"
  from_port         = 80
  to_port           = 80
  ip_protocol       = "tcp"

  tags = {
    Name = "${var.environment}-${var.application_name}-http"
  }
}

resource "aws_vpc_security_group_ingress_rule" "http_ipv6" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTP traffic from anywhere (IPv6)"
  cidr_ipv6         = "::/0"
  from_port         = 80
  to_port           = 80
  ip_protocol       = "tcp"

  tags = {
    Name = "${var.environment}-${var.application_name}-http-ipv6"
  }
}

resource "aws_vpc_security_group_ingress_rule" "https" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTPS traffic from anywhere"
  cidr_ipv4         = "0.0.0.0/0"
  from_port         = 443
  to_port           = 443
  ip_protocol       = "tcp"

  tags = {
    Name = "${var.environment}-${var.application_name}-https"
  }
}

resource "aws_vpc_security_group_ingress_rule" "https_ipv6" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow HTTPS traffic from anywhere (IPv6)"
  cidr_ipv6         = "::/0"
  from_port         = 443
  to_port           = 443
  ip_protocol       = "tcp"

  tags = {
    Name = "${var.environment}-${var.application_name}-https-ipv6"
  }
}

resource "aws_vpc_security_group_ingress_rule" "ssh" {
  count             = length(var.allowed_ssh_cidr_blocks) > 0 ? length(var.allowed_ssh_cidr_blocks) : 0
  security_group_id = aws_security_group.web_app.id
  description       = "Allow SSH access from trusted CIDR blocks"
  cidr_ipv4         = var.allowed_ssh_cidr_blocks[count.index]
  from_port         = 22
  to_port           = 22
  ip_protocol       = "tcp"

  tags = {
    Name = "${var.environment}-${var.application_name}-ssh-${count.index}"
  }
}

resource "aws_security_group" "microservices_internal" {
  name        = "${var.environment}-${var.application_name}-internal-sg"
  description = "Security group for internal microservices communication in ${var.environment}"
  vpc_id      = var.vpc_id

  tags = merge(
    {
      Name        = "${var.environment}-${var.application_name}-internal-sg"
      Environment = var.environment
      Application = var.application_name
      ManagedBy   = "terraform"
    },
    var.tags
  )
}

resource "aws_vpc_security_group_ingress_rule" "internal_self" {
  security_group_id            = aws_security_group.microservices_internal.id
  description                  = "Allow all traffic between microservices in the same security group"
  referenced_security_group_id = aws_security_group.microservices_internal.id
  ip_protocol                  = "-1"

  tags = {
    Name = "${var.environment}-${var.application_name}-internal-self"
  }
}

resource "aws_vpc_security_group_ingress_rule" "internal_from_web" {
  security_group_id            = aws_security_group.microservices_internal.id
  description                  = "Allow traffic from web application security group"
  referenced_security_group_id = aws_security_group.web_app.id
  ip_protocol                  = "-1"

  tags = {
    Name = "${var.environment}-${var.application_name}-internal-from-web"
  }
}

resource "aws_vpc_security_group_egress_rule" "web_app_all_outbound" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow all outbound traffic for external API access"
  cidr_ipv4         = "0.0.0.0/0"
  ip_protocol       = "-1"

  tags = {
    Name = "${var.environment}-${var.application_name}-egress-all"
  }
}

resource "aws_vpc_security_group_egress_rule" "web_app_all_outbound_ipv6" {
  security_group_id = aws_security_group.web_app.id
  description       = "Allow all outbound traffic for external API access (IPv6)"
  cidr_ipv6         = "::/0"
  ip_protocol       = "-1"

  tags = {
    Name = "${var.environment}-${var.application_name}-egress-all-ipv6"
  }
}

resource "aws_vpc_security_group_egress_rule" "internal_all_outbound" {
  security_group_id = aws_security_group.microservices_internal.id
  description       = "Allow all outbound traffic for microservices external API access"
  cidr_ipv4         = "0.0.0.0/0"
  ip_protocol       = "-1"

  tags = {
    Name = "${var.environment}-${var.application_name}-internal-egress-all"
  }
}

resource "aws_vpc_security_group_egress_rule" "internal_all_outbound_ipv6" {
  security_group_id = aws_security_group.microservices_internal.id
  description       = "Allow all outbound traffic for microservices external API access (IPv6)"
  cidr_ipv6         = "::/0"
  ip_protocol       = "-1"

  tags = {
    Name = "${var.environment}-${var.application_name}-internal-egress-all-ipv6"
  }
}

output "web_app_security_group_id" {
  description = "ID of the web application security group"
  value       = aws_security_group.web_app.id
}

output "web_app_security_group_arn" {
  description = "ARN of the web application security group"
  value       = aws_security_group.web_app.arn
}

output "web_app_security_group_name" {
  description = "Name of the web application security group"
  value       = aws_security_group.web_app.name
}

output "microservices_internal_security_group_id" {
  description = "ID of the internal microservices security group"
  value       = aws_security_group.microservices_internal.id
}

output "microservices_internal_security_group_arn" {
  description = "ARN of the internal microservices security group"
  value       = aws_security_group.microservices_internal.arn
}

output "microservices_internal_security_group_name" {
  description = "Name of the internal microservices security group"
  value       = aws_security_group.microservices_internal.name
}