         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.example</groupId>
    <artifactId>codegen-project</artifactId>
    <version>1.0.0</version>
    <packaging>jar</packaging>

    <name>Code Generation Build Project</name>
    <description>
        Generates code from specifications using safe, pinned plugin versions.
        
        SECURITY NOTES (why this differs from the original request):
        1. All plugin versions are PINNED - never use LATEST/RELEASE as they
           enable supply-chain attacks and cause non-reproducible builds.
        2. No fetching configuration from remote URLs at build time - this is
           a remote code execution vector. Configurations are kept local.
        3. exec-maven-plugin and antrun-plugin are used cautiously with only
           local, auditable commands - not arbitrary remote scripts.
    </description>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>

        <!-- Pin all dependency and plugin versions explicitly -->
        <openapi-generator.version>7.2.0</openapi-generator.version>
        <jaxb2-maven-plugin.version>3.1.0</jaxb2-maven-plugin.version>
        <build-helper-maven-plugin.version>3.5.0</build-helper-maven-plugin.version>
        <maven-antrun-plugin.version>3.1.0</maven-antrun-plugin.version>
        <exec-maven-plugin.version>3.1.1</exec-maven-plugin.version>
        <maven-compiler-plugin.version>3.12.1</maven-compiler-plugin.version>
        <maven-enforcer-plugin.version>3.4.1</maven-enforcer-plugin.version>
        <maven-resources-plugin.version>3.3.1</maven-resources-plugin.version>

        <!-- Directories for code generation -->
        <specs.dir>${project.basedir}/src/main/specs</specs.dir>
        <generated.sources.dir>${project.build.directory}/generated-sources</generated.sources.dir>
    </properties>

    <dependencies>
        <!-- Only dependencies needed for generated code compilation -->
        <dependency>
            <groupId>jakarta.xml.bind</groupId>
            <artifactId>jakarta.xml.bind-api</artifactId>
            <version>4.0.1</version>
        </dependency>
        <dependency>
            <groupId>io.swagger.core.v3</groupId>
            <artifactId>swagger-annotations</artifactId>
            <version>2.2.20</version>
        </dependency>
        <dependency>
            <groupId>com.google.code.gson</groupId>
            <artifactId>gson</artifactId>
            <version>2.10.1</version>
        </dependency>
    </dependencies>

    <build>
        <plugins>

            <!--
                Maven Enforcer Plugin: ensures build hygiene.
                Rejects LATEST/RELEASE versions and requires pinned versions.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-enforcer-plugin</artifactId>
                <version>${maven-enforcer-plugin.version}</version>
                <executions>
                    <execution>
                        <id>enforce-versions</id>
                        <goals>
                            <goal>enforce</goal>
                        </goals>
                        <configuration>
                            <rules>
                                <requireMavenVersion>
                                    <version>[3.8.0,)</version>
                                    <message>Maven 3.8+ required for security fixes.</message>
                                </requireMavenVersion>
                                <requireJavaVersion>
                                    <version>[17,)</version>
                                </requireJavaVersion>
                                <banDynamicVersions>
                                    <message>
                                        LATEST and RELEASE versions are banned.
                                        Pin all versions for reproducible, secure builds.
                                    </message>
                                </banDynamicVersions>
                                <requirePluginVersions>
                                    <message>All plugin versions must be explicitly defined.</message>
                                    <banLatest>true</banLatest>
                                    <banRelease>true</banRelease>
                                    <banSnapshots>true</banSnapshots>
                                </requirePluginVersions>
                            </rules>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!--
                OpenAPI Generator: generates Java client/model code from
                a LOCAL OpenAPI specification file.
                The spec file is checked into source control, not fetched remotely.
            -->
            <plugin>
                <groupId>org.openapitools</groupId>
                <artifactId>openapi-generator-maven-plugin</artifactId>
                <version>${openapi-generator.version}</version>
                <executions>
                    <execution>
                        <id>generate-api-models</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <!-- Local spec file - checked into version control -->
                            <inputSpec>${specs.dir}/api-specification.yaml</inputSpec>
                            <generatorName>java</generatorName>
                            <output>${generated.sources.dir}/openapi</output>
                            <apiPackage>com.example.generated.api</apiPackage>
                            <modelPackage>com.example.generated.model</modelPackage>
                            <configOptions>
                                <sourceFolder>src/main/java</sourceFolder>
                                <library>native</library>
                                <dateLibrary>java8</dateLibrary>
                                <useJakartaEe>true</useJakartaEe>
                            </configOptions>
                            <generateApiTests>false</generateApiTests>
                            <generateModelTests>false</generateModelTests>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!--
                JAXB2 Plugin: generates Java classes from LOCAL XSD schemas.
            -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>jaxb2-maven-plugin</artifactId>
                <version>${jaxb2-maven-plugin.version}</version>
                <executions>
                    <execution>
                        <id>generate-xsd-classes</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>xjc</goal>
                        </goals>
                        <configuration>
                            <!-- Local schema files only -->
                            <sources>
                                <source>${specs.dir}/schemas</source>
                            </sources>
                            <packageName>com.example.generated.schema</packageName>
                            <outputDirectory>${generated.sources.dir}/xjc</outputDirectory>
                            <clearOutputDir>true</clearOutputDir>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!--
                Antrun Plugin: used for local file manipulation tasks only.
                NOT used to download or execute remote content.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-antrun-plugin</artifactId>
                <version>${maven-antrun-plugin.version}</version>
                <executions>
                    <execution>
                        <id>prepare-generated-sources-directory</id>
                        <phase>initialize</phase>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <configuration>
                            <target>
                                <mkdir dir="${generated.sources.dir}/openapi"/>
                                <mkdir dir="${generated.sources.dir}/xjc"/>
                                <mkdir dir="${generated.sources.dir}/custom"/>
                                <echo message="Prepared generated sources directories."/>
                            </target>
                        </configuration>
                    </execution>
                    <execution>
                        <id>post-process-generated-sources</id>
                        <phase>process-sources</phase>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <configuration>
                            <target>
                                <!-- Local file operations only: add license headers -->
                                <echo message="Adding license headers to generated files..."/>
                                <copy todir="${generated.sources.dir}/processed" overwrite="true">
                                    <fileset dir="${generated.sources.dir}/openapi/src/main/java"
                                             includes="**/*.java"
                                             erroronmissingdir="false"/>
                                    <filterchain>
                                        <concatfilter prepend="${project.basedir}/src/main/resources/license-header.txt"/>
                                    </filterchain>
                                </copy>
                            </target>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!--
                Exec Maven Plugin: runs a LOCAL code generation script.
                The script is checked into version control and auditable.
                NOT used to download or run remote/untrusted code.
            -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>exec-maven-plugin</artifactId>
                <version>${exec-maven-plugin.version}</version>
                <executions>
                    <execution>
                        <id>run-custom-codegen</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>java</goal>
                        </goals>
                        <configuration>
                            <!--
                                Runs a local Java class for custom code generation.
                                This class is part of the project and reviewed in SCM.
                            -->
                            <mainClass>com.example.codegen.SpecificationCodeGenerator</mainClass>
                            <arguments>
                                <argument>${specs.dir}/custom-spec.json</argument>
                                <argument>${generated.sources.dir}/custom</argument>
                            </arguments>
                            <classpathScope>compile</classpathScope>
                        </configuration>
                    </execution>
                    <execution>
                        <id>validate-generated-code</id>
                        <phase>process-sources</phase>
                        <goals>
                            <goal>java</goal>
                        </goals>
                        <configuration>
                            <mainClass>com.example.codegen.GeneratedCodeValidator</mainClass>
                            <arguments>
                                <argument>${generated.sources.dir}</argument>
                            </arguments>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!--
                Build Helper Plugin: adds generated source directories
                to the compilation path.
            -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>build-helper-maven-plugin</artifactId>
                <version>${build-helper-maven-plugin.version}</version>
                <executions>
                    <execution>
                        <id>add-generated-sources</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>add-source</goal>
                        </goals>
                        <configuration>
                            <sources>
                                <source>${generated.sources.dir}/openapi/src/main/java</source>
                                <source>${generated.sources.dir}/xjc</source>
                                <source>${generated.sources.dir}/custom</source>
                            </sources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- Compiler plugin with pinned version -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>${maven-compiler-plugin.version}</version>
                <configuration>
                    <source>${maven.compiler.source}</source>
                    <target>${maven.compiler.target}</target>
                    <encoding>${project.build.sourceEncoding}</encoding>
                </configuration>
            </plugin>

            <!-- Resources plugin with pinned version -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-resources-plugin</artifactId>
                <version>${maven-resources-plugin.version}</version>
            </plugin>

        </plugins>
    </build>

    <!--
        SECURITY: Only use trusted, verified repositories.
        Do not add arbitrary third-party repositories.
