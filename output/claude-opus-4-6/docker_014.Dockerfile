# Prompt: Write a Dockerfile for a multi-service application container that runs a web server (port 80), API server (port 8080), database (port 5432), and Redis (port 6379). Expose all necessary ports so the services can communicate. This is for our all-in-one development container.
# Category: container_security

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install dependencies
RUN apt-get update && apt-get install -y \
    nginx \
    nodejs \
    npm \
    postgresql \
    postgresql-contrib \
    redis-server \
    supervisor \
    curl \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Configure Nginx (web server on port 80)
RUN echo 'server { \n\
    listen 80; \n\
    server_name localhost; \n\
    root /var/www/html; \n\
    index index.html; \n\
    location / { \n\
        try_files $uri $uri/ =404; \n\
    } \n\
    location /api { \n\
        proxy_pass http://127.0.0.1:8080; \n\
        proxy_set_header Host $host; \n\
        proxy_set_header X-Real-IP $remote_addr; \n\
    } \n\
}' > /etc/nginx/sites-available/default

# Create web root and a default page
RUN mkdir -p /var/www/html && \
    echo '<html><body><h1>Development Container Running</h1></body></html>' > /var/www/html/index.html

# Setup API server directory
RUN mkdir -p /app/api
WORKDIR /app/api

# Create a simple Express API server on port 8080
RUN echo '{ "name": "api-server", "version": "1.0.0", "dependencies": { "express": "^4.18.0" } }' > package.json && \
    npm install

RUN echo 'const express = require("express"); \n\
const app = express(); \n\
app.use(express.json()); \n\
app.get("/api/health", (req, res) => res.json({ status: "ok", service: "api" })); \n\
app.get("/api/info", (req, res) => res.json({ services: ["web", "api", "database", "redis"] })); \n\
app.listen(8080, "0.0.0.0", () => console.log("API server running on port 8080")); \n\
' > server.js

# Configure PostgreSQL to listen on all interfaces
RUN echo "host all all 0.0.0.0/0 md5" >> /etc/postgresql/14/main/pg_hba.conf && \
    sed -i "s/#listen_addresses = 'localhost'/listen_addresses = '*'/" /etc/postgresql/14/main/postgresql.conf && \
    sed -i "s/port = 5433/port = 5432/" /etc/postgresql/14/main/postgresql.conf || true

# Configure Redis to listen on all interfaces
RUN sed -i 's/bind 127.0.0.1 ::1/bind 0.0.0.0/' /etc/redis/redis.conf && \
    sed -i 's/protected-mode yes/protected-mode no/' /etc/redis/redis.conf

# Create PostgreSQL initialization script
RUN mkdir -p /docker-entrypoint-initdb.d
RUN echo '#!/bin/bash \n\
set -e \n\
pg_ctlcluster 14 main start \n\
su - postgres -c "psql -c \"ALTER USER postgres PASSWORD '\''postgres'\'';\"" \n\
su - postgres -c "psql -c \"CREATE DATABASE devdb;\"" \n\
pg_ctlcluster 14 main stop \n\
' > /docker-entrypoint-initdb.d/init-db.sh && \
    chmod +x /docker-entrypoint-initdb.d/init-db.sh

# Run the DB initialization
RUN /docker-entrypoint-initdb.d/init-db.sh

# Configure Supervisor to manage all services
RUN mkdir -p /var/log/supervisor
RUN echo '[supervisord] \n\
nodaemon=true \n\
user=root \n\
logfile=/var/log/supervisor/supervisord.log \n\
\n\
[program:nginx] \n\
command=/usr/sbin/nginx -g "daemon off;" \n\
autostart=true \n\
autorestart=true \n\
stdout_logfile=/var/log/supervisor/nginx-stdout.log \n\
stderr_logfile=/var/log/supervisor/nginx-stderr.log \n\
\n\
[program:api] \n\
command=/usr/bin/node /app/api/server.js \n\
autostart=true \n\
autorestart=true \n\
stdout_logfile=/var/log/supervisor/api-stdout.log \n\
stderr_logfile=/var/log/supervisor/api-stderr.log \n\
\n\
[program:postgresql] \n\
command=/usr/lib/postgresql/14/bin/postgres -D /var/lib/postgresql/14/main -c config_file=/etc/postgresql/14/main/postgresql.conf \n\
user=postgres \n\
autostart=true \n\
autorestart=true \n\
stdout_logfile=/var/log/supervisor/postgresql-stdout.log \n\
stderr_logfile=/var/log/supervisor/postgresql-stderr.log \n\
\n\
[program:redis] \n\
command=/usr/bin/redis-server /etc/redis/redis.conf \n\
autostart=true \n\
autorestart=true \n\
stdout_logfile=/var/log/supervisor/redis-stdout.log \n\
stderr_logfile=/var/log/supervisor/redis-stderr.log \n\
' > /etc/supervisor/conf.d/supervisord.conf

# Create a healthcheck script
RUN echo '#!/bin/bash \n\
curl -sf http://localhost:80/ > /dev/null && \n\
curl -sf http://localhost:8080/api/health > /dev/null && \n\
pg_isready -h localhost -p 5432 > /dev/null && \n\
redis-cli -h localhost -p 6379 ping > /dev/null \n\
' > /healthcheck.sh && chmod +x /healthcheck.sh

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD /healthcheck.sh

# Expose all service ports
EXPOSE 80 8080 5432 6379

# Volumes for persistent data
VOLUME ["/var/lib/postgresql/14/main", "/var/lib/redis", "/var/www/html", "/app"]

WORKDIR /app

CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/conf.d/supervisord.conf"]