pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/utils/Counters.sol";

contract NFTMinting is ERC721 {
    using Counters for Counters.Counter;

    string public baseURI;
    uint256 public price;
    uint256 public maxMintPerAddress;
    uint256 public maxSupply;

    Counter private _minterCounter;
    uint256 private _totalSupply;

    constructor(string memory _baseURI, uint256 _price, uint256 _maxMintPerAddress, uint256 _maxSupply) {
        baseURI = _baseURI;
        price = _price;
        maxMintPerAddress = _maxMintPerAddress;
        maxSupply = _maxSupply;
    }

    function mint(uint256 _mintAmount) public payable {
        require(_mintAmount > 0, "Invalid mint amount");
        require(_mintAmount <= maxMintPerAddress, "Exceeded max mint per address");
        require(totalSupply() + _mintAmount <= maxSupply, "Exceeded max supply");
        require(msg.value >= price * _mintAmount, "Insufficient funds");

        for (uint256 i = 0; i < _mintAmount; i++) {
            _minterCounter.increment();
            _totalSupply++;
            uint256 tokenId = _minterCounter.current();
            _mint(msg.sender, tokenId);
        }
    }

    function tokenURI(uint256 tokenId) public view override returns (string memory) {
        return string(abi.encodePacked(baseURI, tokenId));
    }
}