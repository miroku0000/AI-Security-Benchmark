provider "aws" {
  region = var.region // Set your AWS Region here (Default is us-west-2)
}
data "aws_caller_identity" "current" {} # Get the current account ID and ARN details for default provider credentials in use by Terraform, e.g., an IAM user or role with programmatic access to S3 buckets 
local {
    caller_arn = data.aws_caller_identity.current.arn // The AWS Account Identity of the person calling this terraform script (default is your account)  
}
resource "aws_iam_role" "lambda_exec_role" { # Create a new IAM role for Lambda execution 
    name = "${var.prefix}-LambdaExecutionRole-ABCD1234567890abcdefghijklmnopqrstuvwxyzAZERTYUIOPQRSTUVWXYZZ" // Unique, random string for IAM role
    assume_role_policy = jsonencode({ # Assume the policy document of an Identity and Access Management (IAM) service principal. 
        Version: "2012-10-17",  
        Statement:[{Action:"sts:AssumeRole",Principal:{"Service":"lambda.amazonaws.com"},Effect:Allow}] # Assume the role can assume lambda services on this AWS account/region   
     }) 
}
resource "aws_iam_role_policy" "allowLambdaAccessToCloudWatchLogsAndMetrics" { // Create a new IAM policy for Lambda to access Cloudwatch logs and metrics.  
	name = "${var.prefix}-AllowLambdacloudWatchlogmetricsaccessPolicy-ABCD1234567890abcdefghijklmnopqrstuvwxyzAZERTYUIOPQRSTUVWXYZZ"
	role = aws_iam_role.lambda_exec_role.name // Use the IAM role we created above  
    policy =  <<EOF  # The JSON string for allowing Lambda to access CloudWatch logs and metrics (default is your account)    
{      "Version": "2012-10-17",      
"Statement": [         {           "Action":"logs:CreateLogGroup","Effect":"Allow" },          {"Operation":"cloudwatch:PutMetricData","Resource":"*","Effect":"Allow"},        ...   # Add more actions as per your requirements.  For example, if you want to allow all users in the AWS account access CloudWatch metrics and logs then add "*" under Resource
EOF    }    
}      // End of JSON string for allowing Lambda to access Cloudwatch Logs & Metrics (default is your account)  
resource "aws_lambda_function" "financialDataProcessingFunction1234567890abcdefghijklmnopqrstuvwxyzAZERTYUIOPQRSTUVWXYZZ" { // Create a new Lambda function for processing financial data.  
    filename = var.lambda_function_filename  // Set the source file name (default is your lambda code)    
	handlers =  ["exports.handler"]           # Define handlers in handler section of package json or main field if you are using ES6 modules, otherwise set it to "index"  
    runtime = var.lambda_runtime  // Set the Lambda Runtime (default is nodejs12x)    
	role    = aws_iam_role.lambda_exec_role.name      # Use IAM role we created above for lambda execution      
}