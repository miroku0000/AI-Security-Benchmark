provider "aws" {
  region = var.region // Set your AWS Region here (e.g., us-west-2)
}

resource "aws_security_group" "webapp_sg" {
  name        = "${var.env}-WebAppSG"   # Unique Name for the Security Group, e.g.: dev-WebAppSG or prod-WebAppSG etc... (Environment specific)
  description = "Security group to allow HTTP/HTTPS traffic from anywhere."    // Description of your security groups and rules below ...(optional). Default is none if not provided by user in terraform.tf file, it's recommended for more clarity about the purpose or functionality behind these settings.)  
}

resource "aws_security_group_rule" "webapp_sg_http" {  // HTTP rule to allow all traffic on port range: http (80) and https(443). You can change this if you want a different set of ports. e.g., from any IP or specific CIDR
  type              = "ingress"   # Type is always ingress in our case, it means we are allowing traffic to/from the internet (0.0.0.0/0) on port range: http(80), https(443). You can change this if you want a different set of ports or IPs
  from              = "-1"          // This is for any source, it means allow all sources here and not recommended to use "all open", only specify the specific CIDR (e.g., '0.0.0.0/32') if you know what your application needs or can provide a list of IPs
  to                = "-1"          // This is for any destination, it means allow all destinations here and not recommended as we are allowing outbound traffic (e.g., 'any' / "all open") unless specified otherwise in the security group rule itself e.g.: '-1', or a specific CIDR
  protocol          = "-1"          // This is for any protocols, it means allow all types of network packets here and not recommended as we are allowing outbound traffic (e.g., 'tcp' / "udp") unless specified otherwise in the security group rule itself e.g.: '-1', or a specific protocol type
  port_range        = ["80/443"]     // This is for any ports, it means allow all types of network packets on these ranges here and not recommended as we are allowing outbound traffic (e.g., 'any' / "all open") unless specified otherwise in the security group rule itself e.g.: ['21-50', 83]
}