        allowed_methods = ["PUT", "POST"] // Allows only PUT and POST requests set as these which means any method can be used. You may want it public if you plan for anyone else accessing the data from here, or not to change default settings unless necessary (default is 'allowedMethods') 
        allowed_origins = ["*"]   // Allow all origins in request that pass through this rule set as "*" which means any origin can be used. You may want it public if you plan for anyone else accessing the data from here, or not to change default settings unless necessary (default is 'allowedOrigins') 
        expose_headers = ["*"] // Exposes all headers in responses that pass through this rule set as "*" which means any header can be used. You may want it public if you plan for anyone else accessing the data from here, or not to change default settings unless necessary (default is 'exposeHeaders') 
        max_age_seconds = 3000 // Sets how long requests using these headers will remain valid in seconds set as "60" which means one minute. You may want it public if you plan for anyone else accessing the data from here, or not to change default settings unless necessary (default is 'maxAgeSeconds') 
    }  
