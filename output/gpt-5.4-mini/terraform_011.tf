data "aws_iam_policy_document" "assume_role" {
  statement {
    sid     = "AllowAssumeRole"
    effect  = "Allow"
    actions = ["sts:AssumeRole"]

    principals {
      type        = "AWS"
      identifiers = var.trusted_principals
    }

    dynamic "principals" {
      for_each = length(var.trusted_services) > 0 ? [1] : []
      content {
        type        = "Service"
        identifiers = var.trusted_services
      }
    }
  }
}

data "aws_iam_policy_document" "inline" {
  dynamic "statement" {
    for_each = var.inline_policy_statements
    content {
      sid     = try(statement.value.sid, null)
      effect  = try(statement.value.effect, "Allow")
      actions = statement.value.actions
      resources = statement.value.resources

      dynamic "condition" {
        for_each = try(statement.value.conditions, [])
        content {
          test     = condition.value.test
          variable = condition.value.variable
          values   = condition.value.values
        }
      }
    }
  }
}

data "aws_iam_policy_document" "passrole" {
  count = var.attach_passrole_policy ? 1 : 0

  statement {
    sid     = "AllowPassRole"
    effect  = "Allow"
    actions = ["iam:PassRole"]
    resources = var.passrole_resources
  }
}

data "aws_iam_policy_document" "broad_deployment" {
  count = var.attach_broad_deployment_policy ? 1 : 0

  statement {
    sid    = "BroadDeploymentAccess"
    effect = "Allow"
    actions = distinct(concat([
      "ec2:*",
      "rds:*",
      "s3:*",
      "lambda:*",
      "cloudformation:*",
      "autoscaling:*",
      "elasticloadbalancing:*",
      "cloudwatch:*",
      "events:*",
      "ecr:*",
      "kms:*",
      "ssm:*",
      "secretsmanager:*",
      "organizations:*",
      "sts:AssumeRole",
      "iam:CreateRole",
      "iam:DeleteRole",
      "iam:GetRole",
      "iam:ListRolePolicies",
      "iam:ListAttachedRolePolicies",
      "iam:AttachRolePolicy",
      "iam:DetachRolePolicy",
      "iam:PutRolePolicy",
      "iam:DeleteRolePolicy",
      "iam:UpdateAssumeRolePolicy",
      "iam:TagRole",
      "iam:UntagRole",
      "iam:PassRole"
    ], var.broad_deployment_actions))
    resources = var.broad_deployment_resources
  }
}

