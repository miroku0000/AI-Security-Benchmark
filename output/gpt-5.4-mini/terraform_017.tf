resource "aws_lambda_permission" "allow_sqs_invoke_authorization" {
  statement_id  = "AllowSQSTriggerAuthorization"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.payment_authorization.function_name
  principal     = "sqs.amazonaws.com"
  source_arn    = aws_sqs_queue.payment_events.arn
}

resource "aws_lambda_permission" "allow_sqs_invoke_capture" {
  statement_id  = "AllowSQSTriggerCapture"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.payment_capture.function_name
  principal     = "sqs.amazonaws.com"
  source_arn    = aws_sqs_queue.payment_events.arn
}

resource "aws_ssm_parameter" "payment_api_key" {
  name  = "/payment-processing/api-key"
  type  = "SecureString"
  value = var.payment_api_key
  key_id = aws_kms_key.payment_data.arn
}

resource "aws_secretsmanager_secret" "payment_processor" {
  name = "payment-processing/processor"
}

resource "aws_kms_key" "payment_data" {
  description             = "KMS key for payment processing sensitive data"
  deletion_window_in_days  = 30
  enable_key_rotation      = true
}

resource "aws_dynamodb_table" "payment_transactions" {
  name         = "payment-transactions"
  billing_mode = "PAY_PER_REQUEST"
  hash_key     = "transaction_id"

  attribute {
    name = "transaction_id"
    type = "S"
  }

  server_side_encryption {
    enabled     = true
    kms_key_arn = aws_kms_key.payment_data.arn
  }
}

resource "aws_sqs_queue" "payment_events" {
  name                       = "payment-events"
  visibility_timeout_seconds = 60
  kms_master_key_id          = aws_kms_key.payment_data.arn
}

variable "payment_authorization_zip_path" {
  type = string
}

variable "payment_capture_zip_path" {
  type = string
}

variable "payment_api_key" {
  type      = string
  sensitive = true
}