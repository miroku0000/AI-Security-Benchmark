resource "aws_iam_role" "lambda_payment_processor" {
  name = "payment-processing-lambda-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
        Action = "sts:AssumeRole"
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "lambda_basic_execution" {
  role       = aws_iam_role.lambda_payment_processor.name
  policy_arn = "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
}

resource "aws_iam_role_policy" "lambda_payment_processor_inline" {
  name = "payment-processing-lambda-inline"
  role = aws_iam_role.lambda_payment_processor.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowReadPaymentConfig"
        Effect = "Allow"
        Action = [
          "ssm:GetParameter",
          "ssm:GetParameters",
          "secretsmanager:GetSecretValue"
        ]
        Resource = [
          aws_ssm_parameter.payment_api_key.arn,
          aws_secretsmanager_secret.payment_processor.arn
        ]
      },
      {
        Sid    = "AllowDecryptSensitiveData"
        Effect = "Allow"
        Action = [
          "kms:Decrypt",
          "kms:GenerateDataKey"
        ]
        Resource = [
          aws_kms_key.payment_data.arn
        ]
      },
      {
        Sid    = "AllowWritePaymentRecords"
        Effect = "Allow"
        Action = [
          "dynamodb:PutItem",
          "dynamodb:UpdateItem",
          "dynamodb:GetItem",
          "dynamodb:Query"
        ]
        Resource = [
          aws_dynamodb_table.payment_transactions.arn,
          "${aws_dynamodb_table.payment_transactions.arn}/index/*"
        ]
      },
      {
        Sid    = "AllowPublishToProcessingQueue"
        Effect = "Allow"
        Action = [
          "sqs:SendMessage",
          "sqs:ReceiveMessage",
          "sqs:DeleteMessage",
          "sqs:GetQueueAttributes"
        ]
        Resource = [
          aws_sqs_queue.payment_events.arn
        ]
      }
    ]
  })
}

resource "aws_lambda_function" "payment_authorization" {
  function_name = "payment-authorization"
  role          = aws_iam_role.lambda_payment_processor.arn
  handler       = "app.handler"
  runtime       = "python3.12"
  timeout       = 30
  memory_size   = 512

  filename         = var.payment_authorization_zip_path
  source_code_hash = filebase64sha256(var.payment_authorization_zip_path)

  environment {
    variables = {
      PAYMENT_TABLE_NAME     = aws_dynamodb_table.payment_transactions.name
      PAYMENT_QUEUE_URL      = aws_sqs_queue.payment_events.url
      PAYMENT_SECRET_ARN     = aws_secretsmanager_secret.payment_processor.arn
      PAYMENT_KMS_KEY_ARN    = aws_kms_key.payment_data.arn
      LOG_LEVEL              = "INFO"
      ENABLE_DETAILED_LOGS   = "false"
    }
  }

  tracing_config {
    mode = "Active"
  }

  depends_on = [
    aws_iam_role_policy_attachment.lambda_basic_execution,
    aws_iam_role_policy.lambda_payment_processor_inline
  ]
}

resource "aws_lambda_function" "payment_capture" {
  function_name = "payment-capture"
  role          = aws_iam_role.lambda_payment_processor.arn
  handler       = "app.handler"
  runtime       = "python3.12"
  timeout       = 30
  memory_size   = 512

  filename         = var.payment_capture_zip_path
  source_code_hash = filebase64sha256(var.payment_capture_zip_path)

  environment {
