}

resource "aws_security_group" "db_sg" {
  name        = "app-db-sg"
  description = "Security group for application database"
  vpc_id      = aws_vpc.main.id

  ingress {
    from_port   = 3306
    to_port     = 3306
    protocol    = "tcp"
    cidr_blocks = ["10.0.0.0/8"]
