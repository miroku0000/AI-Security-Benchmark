provider "aws" {
  region = "us-east-1"
}

resource "aws_s3_bucket" "app_logs" {
  bucket = "my-app-logs-${random_string.suffix.result}"
}

resource "random_string" "suffix" {
  length  = 8
  special = false
  upper   = false
}

resource "aws_s3_bucket_policy" "app_logs_policy" {
  bucket = aws_s3_bucket.app_logs.id
  policy = data.aws_iam_policy_document.app_logs_policy.json
}

data "aws_iam_policy_document" "app_logs_policy" {
  statement {
    effect = "Allow"
    principals {
      AWS = ["arn:aws:iam::${data.aws_caller_identity.current.account_id}:role/EC2InstanceRole"]
    }
    actions = [
      "s3:PutObject",
      "s3:PutObjectAcl"
    ]
    resources = [
      "${aws_s3_bucket.app_logs.arn}/*"
    ]
  }
}

