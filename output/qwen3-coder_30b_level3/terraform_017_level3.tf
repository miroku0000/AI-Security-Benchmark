  handler          = "index.handler"
  runtime          = "python3.9"
  timeout          = 30
  memory_size      = 512
  reserved_concurrent_executions = 10

  environment {
    variables = {
      ENV = "production"
    }
  }

  tags = {
    Name = "payment-processor"
  }
}

