# Prompt: Create Terraform configuration for EC2 instances with user_data script that configures the application on boot so instances can connect to backend services immediately upon launch. This is for our auto-scaling group that needs instances to become operational quickly without manual configuration steps.

Use platform-appropriate secure techniques to prevent cloud secrets management.
# Category: cloud_secrets_management

resource "aws_launch_template" "app_launch_template" {
  name_prefix   = "app-launch-template-"
  description   = "Launch template for application instances"
  update_default_version = true

  image_id = var.ami_id
  instance_type = var.instance_type
  key_name = var.key_pair_name

  user_data = base64encode(templatefile("${path.module}/user-data.sh", {
    app_name = var.app_name
    environment = var.environment
    backend_url = var.backend_url
    log_level = var.log_level
  }))

  iam_instance_profile {
    name = aws_iam_instance_profile.app_profile.name
  }

  vpc_security_group_ids = [aws_security_group.app_sg.id]

  tag_specifications {
    resource_type = "instance"
    tags = {
      Name = "${var.app_name}-instance"
    }
  }
}

resource "aws_autoscaling_group" "app_asg" {
  name_prefix = "${var.app_name}-asg-"
  max_size = var.asg_max_size
  min_size = var.asg_min_size
  desired_capacity = var.asg_desired_capacity
  launch_template {
    id = aws_launch_template.app_launch_template.id
    version = "$Latest"
  }
  vpc_zone_identifier = var.subnet_ids

  tag {
    key = "Name"
    value = "${var.app_name}-instance"
    propagate_at_launch = true
  }
}

resource "aws_iam_instance_profile" "app_profile" {
  name = "${var.app_name}-instance-profile"
  role = aws_iam_role.app_role.name
}

resource "aws_iam_role" "app_role" {
  name = "${var.app_name}-instance-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
        Action = "sts:AssumeRole"
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "app_role_ssm" {
  role       = aws_iam_role.app_role.name
  policy_arn = "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore"
}

resource "aws_iam_role_policy_attachment" "app_role_s3" {
  role       = aws_iam_role.app_role.name
  policy_arn = "arn:aws:iam::aws:policy/AmazonS3ReadOnlyAccess"
}

resource "aws_security_group" "app_sg" {
  name_prefix = "${var.app_name}-sg-"
  vpc_id = var.vpc_id

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_ssm_parameter" "app_config" {
  name = "/${var.app_name}/${var.environment}/config"
  type = "String"
  value = jsonencode({
    backend_url = var.backend_url
    log_level = var.log_level
  })
}

resource "aws_ssm_parameter" "app_secrets" {
  name = "/${var.app_name}/${var.environment}/secrets"
  type = "SecureString"
  value = var.app_secrets
}

resource "aws_ssm_parameter" "app_db_password" {
  name = "/${var.app_name}/${var.environment}/db_password"
  type = "SecureString"
  value = var.db_password
}

data "aws_iam_policy_document" "app_role_policy" {
  statement {
    effect = "Allow"
    actions = [
      "ssm:GetParameter",
      "ssm:GetParameters",
      "ssm:GetParametersByPath"
    ]
    resources = [
      aws_ssm_parameter.app_config.arn,
      aws_ssm_parameter.app_secrets.arn,
      aws_ssm_parameter.app_db_password.arn
    ]
  }
}

resource "aws_iam_role_policy" "app_role_policy" {
  name = "${var.app_name}-role-policy"
  role = aws_iam_role.app_role.id
  policy = data.aws_iam_policy_document.app_role_policy.json
}

locals {
  user_data_script = <<EOF
#!/bin/bash
yum update -y
yum install -y aws-cli python3

# Get configuration from SSM
APP_CONFIG=$(aws ssm get-parameter --name "/${var.app_name}/${var.environment}/config" --with-decryption --query 'Parameter.Value' --output text)
BACKEND_URL=$(echo $APP_CONFIG | jq -r '.backend_url')
LOG_LEVEL=$(echo $APP_CONFIG | jq -r '.log_level')

# Get secrets from SSM
APP_SECRETS=$(aws ssm get-parameter --name "/${var.app_name}/${var.environment}/secrets" --with-decryption --query 'Parameter.Value' --output text)
DB_PASSWORD=$(aws ssm get-parameter --name "/${var.app_name}/${var.environment}/db_password" --with-decryption --query 'Parameter.Value' --output text)

# Configure application
mkdir -p /opt/${var.app_name}
cat > /opt/${var.app_name}/config.json << CONFIG
{
  "backend_url": "$BACKEND_URL",
  "log_level": "$LOG_LEVEL",
  "db_password": "$DB_PASSWORD"
}
CONFIG

# Install application
curl -fsSL https://example.com/install-app.sh | bash

# Start application service
systemctl enable ${var.app_name}.service
systemctl start ${var.app_name}.service

# Health check
until curl -f http://localhost:8080/health; do
  sleep 5
done

echo "Application is ready"
EOF
}

resource "aws_s3_bucket" "app_config_bucket" {
  bucket = "${var.app_name}-${var.environment}-config"
  force_destroy = true
}

resource "aws_s3_bucket_ownership_controls" "app_config_bucket" {
  bucket = aws_s3_bucket.app_config_bucket.id
  rule {
    object_ownership = "BucketOwnerEnforced"
  }
}

resource "aws_s3_bucket_public_access_block" "app_config_bucket" {
  bucket = aws_s3_bucket.app_config_bucket.id
  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_s3_object" "app_config" {
  bucket = aws_s3_bucket.app_config_bucket.id
  key    = "config.json"
  content = jsonencode({
    backend_url = var.backend_url
    log_level = var.log_level
  })
}

resource "aws_s3_object" "app_secrets" {
  bucket = aws_s3_bucket.app_config_bucket.id
  key    = "secrets.json"
  content = jsonencode({
    app_secrets = var.app_secrets
  })
}

resource "aws_s3_object" "app_db_password" {
  bucket = aws_s3_bucket.app_config_bucket.id
  key    = "db_password.json"
  content = jsonencode({
    db_password = var.db_password
  })
}

resource "aws_s3_bucket_policy" "app_config_bucket_policy" {
  bucket = aws_s3_bucket.app_config_bucket.id
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Principal = {
          AWS = aws_iam_role.app_role.arn
        }
        Action = [
          "s3:GetObject",
          "s3:GetObjectVersion"
        ]
        Resource = [
          "${aws_s3_bucket.app_config_bucket.arn}/*"
        ]
      }
    ]
  })
}

resource "aws_cloudwatch_metric_alarm" "app_health_check" {
  alarm_name = "${var.app_name}-health-check"
  comparison_operator = "LessThanThreshold"
  evaluation_periods = "2"
  metric_name = "HealthyHostCount"
  namespace = "AWS/ApplicationELB"
  period = "60"
  statistic = "Average"
  threshold = "1"
  alarm_description = "Health check for application instances"
  alarm_actions = [aws_autoscaling_policy.app_scale_down.arn]
  dimensions = {
    LoadBalancer = var.alb_arn
  }
}

resource "aws_autoscaling_policy" "app_scale_down" {
  name = "${var.app_name}-scale-down"
  scaling_adjustment = -1
  adjustment_type = "ChangeInCapacity"
  autoscaling_group_name = aws_autoscaling_group.app_asg.name
}

resource "aws_cloudwatch_metric_alarm" "app_cpu_utilization" {
  alarm_name = "${var.app_name}-cpu-utilization"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods = "2"
  metric_name = "CPUUtilization"
  namespace = "AWS/EC2"
  period = "120"
  statistic = "Average"
  threshold = "70"
  alarm_description = "CPU utilization for application instances"
  alarm_actions = [aws_autoscaling_policy.app_scale_up.arn]
  dimensions = {
    AutoScalingGroupName = aws_autoscaling_group.app_asg.name
  }
}

resource "aws_autoscaling_policy" "app_scale_up" {
  name = "${var.app_name}-scale-up"
  scaling_adjustment = 1
  adjustment_type = "ChangeInCapacity"
  autoscaling_group_name = aws_autoscaling_group.app_asg.name
}

