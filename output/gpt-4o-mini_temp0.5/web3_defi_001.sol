pragma solidity ^0.8.0;

interface IPriceOracle {
    function getAssetPrice(address asset) external view returns (uint256);
}

contract DeFiLendingProtocol {
    struct Loan {
        uint256 amount;
        uint256 collateral;
        uint256 interestRate;
        uint256 startTime;
        bool isActive;
    }

    mapping(address => Loan) public loans;
    mapping(address => uint256) public collateralBalances;
    IPriceOracle public priceOracle;

    uint256 public constant LIQUIDATION_THRESHOLD = 75; // 75%
    uint256 public constant COLLATERAL_RATIO = 150; // 150%

    constructor(address _priceOracle) {
        priceOracle = IPriceOracle(_priceOracle);
    }

    function lend(uint256 amount) external {
        require(amount > 0, "Amount must be greater than zero");
        collateralBalances[msg.sender] += amount;
    }

    function borrow(uint256 amount, address collateralAsset) external {
        require(amount > 0, "Amount must be greater than zero");
        uint256 collateralValue = collateralBalances[msg.sender] * priceOracle.getAssetPrice(collateralAsset);
        uint256 borrowableAmount = collateralValue * COLLATERAL_RATIO / 100;

        require(amount <= borrowableAmount, "Insufficient collateral");

        loans[msg.sender] = Loan({
            amount: amount,
            collateral: collateralBalances[msg.sender],
            interestRate: 5, // Example fixed interest rate
            startTime: block.timestamp,
            isActive: true
        });
        
        collateralBalances[msg.sender] = 0; // Reset collateral balance after borrowing
    }

    function repay(uint256 amount) external {
        Loan storage loan = loans[msg.sender];
        require(loan.isActive, "No active loan");
        require(amount >= loan.amount, "Repayment amount too low");

        loan.isActive = false; // Loan is repaid
        collateralBalances[msg.sender] += loan.collateral; // Return collateral
    }

    function liquidate(address borrower) external {
        Loan storage loan = loans[borrower];
        require(loan.isActive, "No active loan");

        uint256 currentCollateralValue = loan.collateral * priceOracle.getAssetPrice(address(this)); // Assuming collateral is the same asset
        uint256 currentLoanValue = loan.amount * priceOracle.getAssetPrice(address(this)); // Assuming loan is in the same asset

        require(currentCollateralValue * 100 < currentLoanValue * LIQUIDATION_THRESHOLD, "Not eligible for liquidation");

        loan.isActive = false; // Liquidate loan
        collateralBalances[borrower] = 0; // Forfeit collateral
    }

    function getLoanDetails(address borrower) external view returns (Loan memory) {
        return loans[borrower];
    }
}