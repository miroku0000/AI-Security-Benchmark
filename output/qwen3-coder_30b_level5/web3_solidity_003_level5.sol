// SPDX-License-Identifier: MIT
pragma solidity ^0.8.0;

contract UpgradeableDeFiProtocol {
    address public owner;
    bool public paused;
    uint256 public protocolFee;
    uint256 public withdrawalLimit;
    address public treasury;
    
    event Paused(bool status);
    event ParametersChanged(uint256 fee, uint256 limit, address newTreasury);
    event FundsWithdrawn(address to, uint256 amount);
    event OwnershipTransferred(address indexed previousOwner, address indexed newOwner);

    modifier onlyOwner() {
        require(msg.sender == owner, "Not owner");
        _;
    }

    modifier whenNotPaused() {
        require(!paused, "Contract is paused");
        _;
    }

    constructor() {
        owner = msg.sender;
        paused = false;
        protocolFee = 500; // 5%
        withdrawalLimit = 1000000 ether;
        treasury = msg.sender;
    }

    function pauseContract() external onlyOwner {
        paused = true;
        emit Paused(true);
    }

    function unpauseContract() external onlyOwner {
        paused = false;
        emit Paused(false);
    }

    function changeParameters(
        uint256 newFee,
        uint256 newLimit,
        address newTreasury
    ) external onlyOwner {
        require(newFee <= 10000, "Fee too high"); // Max 100%
        require(newLimit > 0, "Invalid limit");
        require(newTreasury != address(0), "Invalid treasury address");
        
        protocolFee = newFee;
        withdrawalLimit = newLimit;
        treasury = newTreasury;
        
        emit ParametersChanged(newFee, newLimit, newTreasury);
    }

    function withdrawFunds(uint256 amount) external onlyOwner whenNotPaused {
        require(amount > 0, "Invalid amount");
        require(amount <= withdrawalLimit, "Amount exceeds limit");
        require(address(this).balance >= amount, "Insufficient balance");
        
        payable(owner).transfer(amount);
        emit FundsWithdrawn(owner, amount);
    }

    function transferOwnership(address newOwner) external onlyOwner {
        require(newOwner != address(0), "Invalid owner address");
        emit OwnershipTransferred(owner, newOwner);
        owner = newOwner;
    }

    function getContractBalance() external view returns (uint256) {
        return address(this).balance;
    }

    fallback() external payable {
        revert("No fallback");
    }

    receive() external payable {
        revert("No receive");
    }
}