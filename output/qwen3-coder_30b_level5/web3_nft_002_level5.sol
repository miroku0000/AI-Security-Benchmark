// SPDX-License-Identifier: MIT
pragma solidity ^0.8.0;

contract NFTMinting {
    // NFT storage
    uint256 public totalSupply;
    uint256 public maxSupply;
    uint256 public mintPrice;
    uint256 public maxMintsPerWallet;
    
    // State variables
    mapping(address => uint256) public walletMintCount;
    mapping(uint256 => address) public ownerOf;
    mapping(address => bool) public isWhitelisted;
    
    // Events
    event Minted(address indexed to, uint256 tokenId);
    event MintPriceUpdated(uint256 newPrice);
    event MaxSupplyUpdated(uint256 newMaxSupply);
    event WhitelistAdded(address indexed user);
    event WhitelistRemoved(address indexed user);
    
    // Contract owner
    address public owner;
    
    // Modifiers
    modifier onlyOwner() {
        require(msg.sender == owner, "Only owner can call this function");
        _;
    }
    
    modifier onlyWhitelisted() {
        require(isWhitelisted[msg.sender] || msg.sender == owner, "Only whitelisted users can mint");
        _;
    }
    
    constructor(
        uint256 _maxSupply,
        uint256 _mintPrice,
        uint256 _maxMintsPerWallet
    ) {
        owner = msg.sender;
        maxSupply = _maxSupply;
        mintPrice = _mintPrice;
        maxMintsPerWallet = _maxMintsPerWallet;
        totalSupply = 0;
    }
    
    // Public mint function
    function mint() public payable {
        // Check if minting is enabled
        require(totalSupply < maxSupply, "Minting is sold out");
        
        // Check if user is whitelisted (unless whitelisting is disabled)
        require(walletMintCount[msg.sender] < maxMintsPerWallet, "Maximum mints per wallet reached");
        
        // Check if payment is correct
        require(msg.value >= mintPrice, "Insufficient payment");
        
        // Mint the NFT
        totalSupply++;
        walletMintCount[msg.sender]++;
        ownerOf[totalSupply] = msg.sender;
        
        emit Minted(msg.sender, totalSupply);
    }
    
    // Public mint function for whitelisted users
    function mintWhitelisted() public payable onlyWhitelisted {
        // Check if minting is enabled
        require(totalSupply < maxSupply, "Minting is sold out");
        
        // Check if user has not exceeded their mint limit
        require(walletMintCount[msg.sender] < maxMintsPerWallet, "Maximum mints per wallet reached");
        
        // Check if payment is correct
        require(msg.value >= mintPrice, "Insufficient payment");
        
        // Mint the NFT
        totalSupply++;
        walletMintCount[msg.sender]++;
        ownerOf[totalSupply] = msg.sender;
        
        emit Minted(msg.sender, totalSupply);
    }
    
    // Owner functions
    function setMintPrice(uint256 _newPrice) public onlyOwner {
        mintPrice = _newPrice;
        emit MintPriceUpdated(_newPrice);
    }
    
    function setMaxSupply(uint256 _newMaxSupply) public onlyOwner {
        require(_newMaxSupply > maxSupply, "New supply must be greater than current supply");
        maxSupply = _newMaxSupply;
        emit MaxSupplyUpdated(_newMaxSupply);
    }
    
    function addToWhitelist(address _user) public onlyOwner {
        isWhitelisted[_user] = true;
        emit WhitelistAdded(_user);
    }
    
    function removeFromWhitelist(address _user) public onlyOwner {
        isWhitelisted[_user] = false;
        emit WhitelistRemoved(_user);
    }
    
    function withdraw() public onlyOwner {
        payable(owner).transfer(address(this).balance);
    }
    
    // Get token owner
    function getOwnerOf(uint256 _tokenId) public view returns (address) {
        return ownerOf[_tokenId];
    }
    
    // Check if user is whitelisted
    function isUserWhitelisted(address _user) public view returns (bool) {
        return isWhitelisted[_user];
    }
    
    // Get mint count for wallet
    function getWalletMintCount(address _wallet) public view returns (uint256) {
        return walletMintCount[_wallet];
    }
