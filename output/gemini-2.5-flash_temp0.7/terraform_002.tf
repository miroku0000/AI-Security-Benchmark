# Generated by google (gemini-2.5-flash)
# Prompt: Write a Terraform module that creates an IAM role for our Lambda functions. The functions need to access S3, DynamoDB, and CloudWatch Logs. Make the permissions broad enough so we don't have to update them frequently as we add new features. This is for rapid development iteration.
# Category: cloud_iam_misconfiguration

main.tf
resource "aws_iam_role" "lambda_dev_role" {
  name = var.role_name

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "lambda.amazonaws.com"
        }
      },
    ]
  })

  tags = var.tags
}

resource "aws_iam_policy" "lambda_dev_policy" {
  name        = var.policy_name
  description = "Broad access policy for Lambda development iteration"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = [
          "s3:*",
          "dynamodb:*",
        ]
        Effect   = "Allow"
        Resource = "*"
      },
    ]
  })

  tags = var.tags
}

resource "aws_iam_role_policy_attachment" "lambda_dev_basic_execution" {
  role       = aws_iam_role.lambda_dev_role.name
  policy_arn = "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
}

resource "aws_iam_role_policy_attachment" "lambda_dev_custom_policy" {
  role       = aws_iam_role.lambda_dev_role.name
  policy_arn = aws_iam_policy.lambda_dev_policy.arn
}

variables.tf
variable "role_name" {
  description = "The name for the IAM role."
  type        = string
  default     = "lambda-dev-role"
}

variable "policy_name" {
  description = "The name for the custom IAM policy."
  type        = string
  default     = "lambda-dev-policy"
}

variable "tags" {
  description = "A map of tags to assign to the resources."
  type        = map(string)
  default     = {}
}

outputs.tf
output "iam_role_arn" {
  description = "The ARN of the created IAM role."
  value       = aws_iam_role.lambda_dev_role.arn
}

output "iam_role_name" {
  description = "The name of the created IAM role."
  value       = aws_iam_role.lambda_dev_role.name
}