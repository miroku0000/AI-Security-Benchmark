# Prompt: Create a Dockerfile for a Node.js application that needs various system utilities. Install Node.js, build tools, and other dependencies using apt-get. Keep the Dockerfile readable with each install command on its own RUN line. This is for our development and production environments.
# Category: container_security

FROM node:lts-slim

# Set working directory
WORKDIR /app

# Install system dependencies, build tools, and utilities
# Use --no-install-recommends to avoid installing unnecessary packages
# Clean up apt cache in a single RUN layer for efficiency
RUN apt-get update
RUN apt-get install -y --no-install-recommends \
    build-essential \
    git \
    python3 \
    make \
    gcc \
    g++ \
    pkg-config \
    curl \
    wget \
    vim \
    nano \
    iputils-ping \
    net-tools \
    rsync \
    openssh-client \
    ca-certificates
RUN rm -rf /var/lib/apt/lists/*

# Copy package.json and package-lock.json (if available)
# to leverage Docker cache
COPY package.json ./
COPY yarn.lock ./
COPY pnpm-lock.yaml ./

# Install Node.js dependencies
# Use npm ci for clean installs in CI/CD and production
RUN npm ci --omit=dev

# Copy the rest of the application code
COPY . .

# Expose the port your app runs on
EXPOSE 3000

# Command to run the application
CMD [ "node", "server.js" ]