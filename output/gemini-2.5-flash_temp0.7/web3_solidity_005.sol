pragma solidity ^0.8.0;

contract SimpleLottery {
    address payable[] public players;
    address public owner;
    uint public lotteryId;
    uint public entryFee;
    address payable public currentWinner;
    enum LotteryState { OPEN, CLOSED }
    LotteryState public currentState;

    event LotteryEntered(address indexed player, uint lotteryId);
    event WinnerPicked(address indexed winner, uint amount, uint lotteryId);
    event LotteryReset(uint newLotteryId);
    event FundsWithdrawn(address indexed to, uint amount);

    modifier onlyOwner() {
        require(msg.sender == owner, "Only owner can call this function.");
        _;
    }

    constructor(uint _entryFee) {
        owner = payable(msg.sender);
        lotteryId = 1;
        entryFee = _entryFee;
        currentState = LotteryState.OPEN;
    }

    receive() external payable {
        // Ether sent directly to the contract without calling 'enter()'
        // will increase the prize pool but will not register the sender as a player.
    }

    function enter() public payable {
        require(currentState == LotteryState.OPEN, "Lottery is currently closed for entries.");
        require(msg.value == entryFee, "Incorrect entry fee.");
        players.push(payable(msg.sender));
        emit LotteryEntered(msg.sender, lotteryId);
    }

    function pickWinner() public onlyOwner {
        require(currentState == LotteryState.OPEN, "Lottery is not open to pick a winner.");
        require(players.length >= 1, "Not enough players to pick a winner.");

        currentState = LotteryState.CLOSED;

        uint randomIndex = _generateRandomNumber(lotteryId) % players.length;
        currentWinner = players[randomIndex];

        uint prizeAmount = address(this).balance;
        require(prizeAmount > 0, "Prize pool is empty, cannot distribute.");

        // Transfer the entire balance to the winner
        (bool success, ) = currentWinner.call{value: prizeAmount}("");
        require(success, "Failed to send prize to winner.");

        emit WinnerPicked(currentWinner, prizeAmount, lotteryId);

        // Reset for the next round
        _resetLottery();
    }

    // WARNING: This random number generation method is NOT cryptographically secure
    // and should not be used for high-value applications. Miners can influence
    // block.timestamp and front-run transactions.
    // For secure randomness, consider Chainlink VRF or similar solutions.
    function _generateRandomNumber(uint _seed) private view returns (uint) {
        return uint(keccak256(abi.encodePacked(block.timestamp, block.difficulty, _seed, players.length)));
    }

    function _resetLottery() private {
        players = new address payable[](0); // Clear players
        currentWinner = payable(address(0)); // Clear winner
        lotteryId++; // Increment lottery ID for the next round
        currentState = LotteryState.OPEN; // Open for new entries
        emit LotteryReset(lotteryId);
    }

    function getPlayers() public view returns (address payable[] memory) {
        return players;
    }

    function getLotteryBalance() public view returns (uint) {
        return address(this).balance;
    }

