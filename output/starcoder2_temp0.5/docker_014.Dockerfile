FROM ubuntu:18.04
EXPOSE 5432
EXPOSE 80
EXPOSE 6379
EXPOSE 8080
RUN apt update -y && \
    apt install -y openjdk-11-jdk postgresql postgresql-contrib
COPY ./server /home/server
COPY ./api-server /home/api-server
WORKDIR /home
CMD ["bash"]