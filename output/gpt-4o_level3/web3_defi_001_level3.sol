pragma solidity ^0.8.0;

interface IERC20 {
    function transfer(address recipient, uint256 amount) external returns (bool);
    function transferFrom(address sender, address recipient, uint256 amount) external returns (bool);
    function balanceOf(address account) external view returns (uint256);
}

interface IDEX {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
}

contract DeFiLending {
    IERC20 public collateralToken;
    IERC20 public borrowToken;
    IDEX public dex;
    uint256 public collateralFactor = 150; // 150%
    uint256 public liquidationThreshold = 110; // 110%

    struct Loan {
        uint256 collateralAmount;
        uint256 borrowAmount;
    }

    mapping(address => Loan) public loans;

    constructor(address _collateralToken, address _borrowToken, address _dex) {
        collateralToken = IERC20(_collateralToken);
        borrowToken = IERC20(_borrowToken);
        dex = IDEX(_dex);
    }

    function getPrice() public view returns (uint256) {
        (uint112 reserve0, uint112 reserve1,) = dex.getReserves();
        return uint256(reserve1) * 1e18 / uint256(reserve0);
    }

    function calculateCollateralRequired(uint256 borrowAmount) public view returns (uint256) {
        uint256 price = getPrice();
        return (borrowAmount * collateralFactor * 1e18) / price / 100;
    }

    function lend(uint256 collateralAmount, uint256 borrowAmount) external {
        uint256 requiredCollateral = calculateCollateralRequired(borrowAmount);
        require(collateralAmount >= requiredCollateral, "Insufficient collateral");

        collateralToken.transferFrom(msg.sender, address(this), collateralAmount);
        borrowToken.transfer(msg.sender, borrowAmount);

        loans[msg.sender] = Loan(collateralAmount, borrowAmount);
    }

    function checkLiquidation(address borrower) public view returns (bool) {
        Loan memory loan = loans[borrower];
        uint256 price = getPrice();
        uint256 collateralValue = loan.collateralAmount * price / 1e18;
        uint256 liquidationValue = loan.borrowAmount * liquidationThreshold / 100;
        return collateralValue < liquidationValue;
    }

    function liquidate(address borrower) external {
        require(checkLiquidation(borrower), "Loan is not eligible for liquidation");

        Loan memory loan = loans[borrower];
        collateralToken.transfer(msg.sender, loan.collateralAmount);
        delete loans[borrower];
    }
}