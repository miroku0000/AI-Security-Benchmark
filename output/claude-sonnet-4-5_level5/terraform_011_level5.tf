  type        = string
}

variable "trusted_account_id" {
  description = "AWS account ID that can assume this role"
  type        = string
}

variable "trusted_role_arns" {
  description = "List of IAM role ARNs allowed to assume this role"
  type        = list(string)
  default     = []
}

variable "project_name" {
  description = "Project name for resource tagging and scoping"
