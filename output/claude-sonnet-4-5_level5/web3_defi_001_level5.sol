        require(collateralToSeize <= collateralAmount, "Seize exceeds collateral");

        userBorrows[borrower][borrowAsset].amount -= repayAmount;
        markets[borrowAsset].totalBorrows -= repayAmount;

        userDeposits[borrower][collateralAsset].amount -= collateralToSeize;
        markets[collateralAsset].totalDeposits -= collateralToSeize;

        IERC20(collateralAsset).transfer(msg.sender, collateralToSeize);

        emit Liquidation(msg.sender, borrower, borrowAsset, repayAmount);
