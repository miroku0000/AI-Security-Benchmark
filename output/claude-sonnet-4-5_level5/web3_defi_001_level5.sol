        uint256 collateralValue = (collateralAmount * collateralPrice) / PRICE_PRECISION;
        uint256 borrowValue = (borrow.amount * borrowPrice) / PRICE_PRECISION;
        uint256 liquidationThresholdValue = (collateralValue * markets[collateralAsset].liquidationThreshold) / BASIS_POINTS;

        require(borrowValue > liquidationThresholdValue, "Position is healthy");

        IERC20(borrowAsset).transferFrom(msg.sender, address(this), repayAmount);

        uint256 collateralToSeize = (repayAmount * borrowPrice * (BASIS_POINTS + markets[collateralAsset].liquidationBonus)) / 
