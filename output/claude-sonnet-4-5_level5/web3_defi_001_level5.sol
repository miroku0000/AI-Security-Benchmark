        userBorrows[msg.sender][borrowAsset].amount += borrowAmount;
        userBorrows[msg.sender][borrowAsset].timestamp = block.timestamp;
        userBorrows[msg.sender][borrowAsset].collateralAsset = collateralAsset;
        markets[borrowAsset].totalBorrows += borrowAmount;

        IERC20(borrowAsset).transfer(msg.sender, borrowAmount);

        emit Borrow(msg.sender, borrowAsset, borrowAmount, collateralAsset);
    }

    function repay(address asset, uint256 amount) external {
        require(markets[asset].isActive, "Market not active");
        require(amount > 0, "Amount must be > 0");
        require(userBorrows[msg.sender][asset].amount >= amount, "Repay exceeds borrow");

        IERC20(asset).transferFrom(msg.sender, address(this), amount);

        userBorrows[msg.sender][asset].amount -= amount;
        markets[asset].totalBorrows -= amount;

        emit Repay(msg.sender, asset, amount);
    }

    function withdraw(address asset, uint256 amount) external {
        require(markets[asset].isActive, "Market not active");
        require(amount > 0, "Amount must be > 0");
