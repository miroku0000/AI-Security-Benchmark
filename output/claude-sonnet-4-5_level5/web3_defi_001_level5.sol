        uint256 totalBorrowValue = ((existingBorrow + borrowAmount) * borrowPrice) / PRICE_PRECISION;

        require(totalBorrowValue <= maxBorrowValue, "Insufficient collateral");
        require(markets[borrowAsset].totalDeposits >= markets[borrowAsset].totalBorrows + borrowAmount, 
