        uint256 maxPriceDeviation
    ) external onlyOwner {
        require(asset != address(0), "Invalid asset");
        require(collateralFactor < BASIS_POINTS, "Invalid collateral factor");
        require(liquidationThreshold <= BASIS_POINTS, "Invalid liquidation threshold");
        require(liquidationThreshold > collateralFactor, "Threshold must be > collateral factor");
        require(chainlinkOracle != address(0), "Invalid oracle");
        require(minObservationPeriod >= MIN_OBSERVATION_PERIOD, "Observation period too short");
        require(maxPriceDeviation <= 2000, "Max deviation too high"); // max 20%

        markets[asset] = Market({
            asset: asset,
            totalDeposits: 0,
            totalBorrows: 0,
            collateralFactor: collateralFactor,
            liquidationThreshold: liquidationThreshold,
            liquidationBonus: liquidationBonus,
            isActive: true,
            chainlinkOracle: chainlinkOracle,
            minObservationPeriod: minObservationPeriod,
            maxPriceDeviation: maxPriceDeviation
        });
    }

    function updatePriceObservation(address asset, uint256 dexPrice) internal {
        PriceObservation[] storage observations = priceHistory[asset];
        uint256 currentTime = block.timestamp;
        
        uint256 cumulativePrice = 0;
        if (observations.length > 0) {
            PriceObservation memory lastObs = observations[observations.length - 1];
            uint256 timeElapsed = currentTime - lastObs.timestamp;
            cumulativePrice = lastObs.cumulativePrice + (lastObs.price * timeElapsed);
        }
        
        observations.push(PriceObservation({
            price: dexPrice,
            timestamp: currentTime,
            cumulativePrice: cumulativePrice
        }));
        
        // Keep only observations within MAX_OBSERVATION_PERIOD
        while (observations.length > 0 && 
               currentTime - observations[0].timestamp > MAX_OBSERVATION_PERIOD) {
            // Remove oldest observation
            for (uint i = 0; i < observations.length - 1; i++) {
                observations[i] = observations[i + 1];
            }
            observations.pop();
        }
        
        lastPriceUpdate[asset] = currentTime;
    }

    function getTWAPPrice(address asset) internal view returns (uint256) {
        PriceObservation[] storage observations = priceHistory[asset];
        require(observations.length >= MIN_OBSERVATIONS, "Insufficient price observations");
        
        Market memory market = markets[asset];
        uint256 currentTime = block.timestamp;
        
        // Find the oldest valid observation within the observation period
        uint256 oldestValidIndex = 0;
        for (uint i = observations.length - 1; i > 0; i--) {
            if (currentTime - observations[i].timestamp >= market.minObservationPeriod) {
                oldestValidIndex = i;
                break;
            }
        }
        
        require(currentTime - observations[oldestValidIndex].timestamp >= market.minObservationPeriod, 
                "Observation period not met");
        
        PriceObservation memory oldestObs = observations[oldestValidIndex];
        PriceObservation memory latestObs = observations[observations.length - 1];
        
        uint256 timeElapsed = latestObs.timestamp - oldestObs.timestamp;
        require(timeElapsed > 0, "Invalid time elapsed");
        
        uint256 priceDifference = latestObs.cumulativePrice - oldestObs.cumulativePrice;
        uint256 twapPrice = priceDifference / timeElapsed;
        
        return twapPrice;
    }

    function getChainlinkPrice(address asset) internal view returns (uint256) {
        Market memory market = markets[asset];
        IChainlinkAggregator oracle = IChainlinkAggregator(market.chainlinkOracle);
        
        (
            uint80 roundId,
            int256 answer,
            ,
            uint256 updatedAt,
            uint80 answeredInRound
        ) = oracle.latestRoundData();
        
        require(answer > 0, "Invalid Chainlink price");
        require(updatedAt > 0, "Incomplete round");
        require(answeredInRound >= roundId, "Stale price");
        require(block.timestamp - updatedAt <= 1 hours, "Price too old");
        
        uint8 decimals = oracle.decimals();
        return uint256(answer) * PRICE_PRECISION / (10 ** decimals);
    }

    function getSecurePrice(address asset) public view returns (uint256) {
        require(markets[asset].isActive, "Market not active");
        
        // Get Chainlink price as primary source
        uint256 chainlinkPrice = getChainlinkPrice(asset);
        
        // Get TWAP price if enough observations exist
        if (priceHistory[asset].length >= MIN_OBSERVATIONS) {
            uint256 twapPrice = getTWAPPrice(asset);
            
            // Verify TWAP is within acceptable deviation from Chainlink
            uint256 deviation;
            if (twapPrice > chainlinkPrice) {
                deviation = ((twapPrice - chainlinkPrice) * BASIS_POINTS) / chainlinkPrice;
            } else {
                deviation = ((chainlinkPrice - twapPrice) * BASIS_POINTS) / chainlinkPrice;
            }
            
            require(deviation <= markets[asset].maxPriceDeviation, "Price deviation too high");
            
            // Return the more conservative price (lower for collateral, higher for debt)
            // For safety, we return the minimum of both
            return twapPrice < chainlinkPrice ? twapPrice : chainlinkPrice;
        }
        
        // If not enough TWAP observations, use Chainlink only
        return chainlinkPrice;
    }

    function updatePrice(address asset, address dexPair) external {
        require(markets[asset].isActive, "Market not active");
        require(block.timestamp - lastPriceUpdate[asset] >= 5 minutes, "Update too frequent");
        
        IUniswapV2Pair pair = IUniswapV2Pair(dexPair);
        (uint112 reserve0, uint112 reserve1,) = pair.getReserves();
        
        require(reserve0 > 0 && reserve1 > 0, "Invalid reserves");
        
        address token0 = pair.token0();
        address token1 = pair.token1();
        
        uint256 price;
        if (token0 == asset) {
            price = (uint256(reserve1) * PRICE_PRECISION) / uint256(reserve0);
        } else if (token1 == asset) {
            price = (uint256(reserve0) * PRICE_PRECISION) / uint256(reserve1);
        } else {
            revert("Asset not in pair");
        }
        
        updatePriceObservation(asset, price);
        emit PriceUpdated(asset, price, block.timestamp);
    }

    function deposit(address asset, uint256 amount) external {
        require(markets[asset].isActive, "Market not active");
        require(amount > 0, "Amount must be > 0");

        IERC20(asset).transferFrom(msg.sender, address(this), amount);

        userDeposits[msg.sender][asset].amount += amount;
        userDeposits[msg.sender][asset].timestamp = block.timestamp;
        markets[asset].totalDeposits += amount;

