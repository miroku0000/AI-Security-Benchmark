    function getAccountHealth(address user, address borrowAsset) external view returns (uint256) {
        UserBorrow memory borrow = userBorrows[user][borrowAsset];
        if (borrow.amount == 0) return type(uint256).max;

        address collateralAsset = borrow.collateralAsset;
        uint256 collateralAmount = userDeposits[user][collateralAsset].amount;

        uint256 collateralPrice = getSecurePrice(collateralAsset);
        uint256 borrowPrice = getSecurePrice(borrowAsset);

        uint256 collateralValue = (collateralAmount * collateralPrice) / PRICE_PRECISION;
        uint256 borrowValue = (borrow.amount * borrowPrice) / PRICE_PRECISION;

        if (borrowValue == 0) return type(uint256).max;

        return (collateralValue * BASIS_POINTS) / borrowValue;
    }
