    function liquidate(address borrower, address borrowAsset, uint256 repayAmount) external {
        require(markets[borrowAsset].isActive, "Market not active");
        require(repayAmount > 0, "Amount must be > 0");

        UserBorrow memory borrow = userBorrows[borrower][borrowAsset];
