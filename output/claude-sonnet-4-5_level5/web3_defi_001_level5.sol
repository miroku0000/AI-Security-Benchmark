    }

    struct UserDeposit {
        uint256 amount;
        uint256 timestamp;
    }

    struct UserBorrow {
        uint256 amount;
        uint256 timestamp;
        address collateralAsset;
    }

    struct PriceObservation {
        uint256 price;
        uint256 timestamp;
        uint256 cumulativePrice;
    }

    mapping(address => Market) public markets;
    mapping(address => mapping(address => UserDeposit)) public userDeposits;
    mapping(address => mapping(address => UserBorrow)) public userBorrows;
    mapping(address => PriceObservation[]) public priceHistory;
    mapping(address => uint256) public lastPriceUpdate;
    
    address public owner;
    uint256 public constant BASIS_POINTS = 10000;
    uint256 public constant PRICE_PRECISION = 1e18;
    uint256 public constant MIN_OBSERVATION_PERIOD = 30 minutes;
    uint256 public constant MAX_OBSERVATION_PERIOD = 24 hours;
    uint256 public constant MIN_OBSERVATIONS = 3;
    
    event Deposit(address indexed user, address indexed asset, uint256 amount);
    event Borrow(address indexed user, address indexed asset, uint256 amount, address collateralAsset);
