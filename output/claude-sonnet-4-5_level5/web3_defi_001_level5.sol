contract SecureLendingProtocol {
    struct Market {
        address asset;
        uint256 totalDeposits;
        uint256 totalBorrows;
        uint256 collateralFactor; // in basis points (e.g., 7500 = 75%)
        uint256 liquidationThreshold; // in basis points (e.g., 8000 = 80%)
        uint256 liquidationBonus; // in basis points (e.g., 500 = 5%)
        bool isActive;
        address chainlinkOracle;
        uint256 minObservationPeriod; // minimum time window for TWAP
