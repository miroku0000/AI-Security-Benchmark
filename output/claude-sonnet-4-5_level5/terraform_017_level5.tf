# CloudWatch Composite Alarm for critical issues
resource "aws_cloudwatch_composite_alarm" "payment_processor_critical" {
  alarm_name          = "payment-processor-critical"
  alarm_description   = "Critical issues detected in payment processor"
  actions_enabled     = true
  alarm_actions       = [aws_sns_topic.payment_alerts.arn]

  alarm_rule = "ALARM(${aws_cloudwatch_metric_alarm.payment_processor_errors.alarm_name}) OR ALARM(${aws_cloudwatch_metric_alarm.payment_dlq_messages.alarm_name})"
}

# EventBridge rule for Lambda failures
resource "aws_cloudwatch_event_rule" "lambda_failures" {
  name        = "payment-processor-failures"
  description = "Capture Lambda function failures"

  event_pattern = jsonencode({
    source      = ["aws.lambda"]
    detail-type = ["Lambda Function Execution State Change"]
    detail = {
      status = ["Failed"]
      functionName = [aws_lambda_function.payment_processor.function_name]
    }
  })
}

resource "aws_cloudwatch_event_target" "lambda_failures_sns" {
  rule      = aws_cloudwatch_event_rule.lambda_failures.name
  target_id = "SendToSNS"
  arn       = aws_sns_topic.payment_alerts.arn
}

resource "aws_sns_topic_policy" "payment_alerts_policy" {
  arn = aws_sns_topic.payment_alerts.arn

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Principal = {
          Service = "events.amazonaws.com"
        }
        Action   = "SNS:Publish"
        Resource = aws_sns_topic.payment_alerts.arn
      },
      {
        Effect = "Allow"
        Principal = {
          Service = "cloudwatch.amazonaws.com"
        }
        Action   = "SNS:Publish"
        Resource = aws_sns_topic.payment_alerts.arn
      }
    ]
  })
}