pragma solidity ^0.8.0;

import "@chainlink/contracts/src/v0.8/interfaces/VRFCoordinatorV2Interface.sol";
import "@chainlink/contracts/src/v0.8/VRFConsumerBaseV2.sol";

contract SecureLottery is VRFConsumerBaseV2 {
    VRFCoordinatorV2Interface private immutable i_vrfCoordinator;
    bytes32 private immutable i_keyHash;
    uint64 private immutable i_subscriptionId;
    uint32 private immutable i_callbackGasLimit;
    uint16 private constant REQUEST_CONFIRMATIONS = 3;
    uint32 private constant NUM_WORDS = 1;

    address public owner;
    uint256 public ticketPrice;
    uint256 public lotteryId;
    
    mapping(uint256 => address[]) public lotteryParticipants;
    mapping(uint256 => address) public lotteryWinners;
    mapping(uint256 => uint256) public lotteryPrizes;
    mapping(uint256 => bool) public lotteryCompleted;
    mapping(uint256 => uint256) public requestIdToLotteryId;
    
    enum LotteryState { OPEN, DRAWING, CLOSED }
    mapping(uint256 => LotteryState) public lotteryState;

    event LotteryEntered(uint256 indexed lotteryId, address indexed participant);
    event RandomnessRequested(uint256 indexed lotteryId, uint256 indexed requestId);
    event WinnerSelected(uint256 indexed lotteryId, address indexed winner, uint256 prize);
    event LotteryStarted(uint256 indexed lotteryId, uint256 ticketPrice);

    modifier onlyOwner() {
        require(msg.sender == owner, "Not owner");
        _;
    }

    constructor(
        address vrfCoordinator,
        bytes32 keyHash,
        uint64 subscriptionId,
        uint32 callbackGasLimit,
        uint256 _ticketPrice
    ) VRFConsumerBaseV2(vrfCoordinator) {
        i_vrfCoordinator = VRFCoordinatorV2Interface(vrfCoordinator);
        i_keyHash = keyHash;
        i_subscriptionId = subscriptionId;
        i_callbackGasLimit = callbackGasLimit;
        owner = msg.sender;
        ticketPrice = _ticketPrice;
        lotteryId = 0;
        lotteryState[lotteryId] = LotteryState.OPEN;
        emit LotteryStarted(lotteryId, ticketPrice);
    }

    function enterLottery() external payable {
        require(lotteryState[lotteryId] == LotteryState.OPEN, "Lottery not open");
        require(msg.value == ticketPrice, "Incorrect ticket price");
        
        lotteryParticipants[lotteryId].push(msg.sender);
        lotteryPrizes[lotteryId] += msg.value;
        
        emit LotteryEntered(lotteryId, msg.sender);
    }

    function drawWinner() external onlyOwner {
        require(lotteryState[lotteryId] == LotteryState.OPEN, "Lottery not open");
        require(lotteryParticipants[lotteryId].length > 0, "No participants");
        
        lotteryState[lotteryId] = LotteryState.DRAWING;
        
        uint256 requestId = i_vrfCoordinator.requestRandomWords(
            i_keyHash,
            i_subscriptionId,
            REQUEST_CONFIRMATIONS,
            i_callbackGasLimit,
            NUM_WORDS
        );
        
        requestIdToLotteryId[requestId] = lotteryId;
        
        emit RandomnessRequested(lotteryId, requestId);
    }

    function fulfillRandomWords(
        uint256 requestId,
        uint256[] memory randomWords
    ) internal override {
        uint256 currentLotteryId = requestIdToLotteryId[requestId];
        require(lotteryState[currentLotteryId] == LotteryState.DRAWING, "Invalid state");
        
        uint256 randomNumber = randomWords[0];
        uint256 participantCount = lotteryParticipants[currentLotteryId].length;
        uint256 winnerIndex = randomNumber % participantCount;
        
        address winner = lotteryParticipants[currentLotteryId][winnerIndex];
        uint256 prize = lotteryPrizes[currentLotteryId];
        
        lotteryWinners[currentLotteryId] = winner;
        lotteryCompleted[currentLotteryId] = true;
        lotteryState[currentLotteryId] = LotteryState.CLOSED;
        
        (bool success, ) = winner.call{value: prize}("");
        require(success, "Transfer failed");
        
        emit WinnerSelected(currentLotteryId, winner, prize);
        
        lotteryId++;
        lotteryState[lotteryId] = LotteryState.OPEN;
        emit LotteryStarted(lotteryId, ticketPrice);
    }

    function getParticipants(uint256 _lotteryId) external view returns (address[] memory) {
        return lotteryParticipants[_lotteryId];
    }

    function getParticipantCount(uint256 _lotteryId) external view returns (uint256) {
        return lotteryParticipants[_lotteryId].length;
    }

    function getCurrentPrizePool() external view returns (uint256) {
        return lotteryPrizes[lotteryId];
    }

