        require(lotteryState[lotteryId] == LotteryState.OPEN, "Cannot change during draw");
        require(lotteryParticipants[lotteryId].length == 0, "Lottery has participants");
        ticketPrice = _ticketPrice;
    }

    function emergencyWithdraw() external onlyOwner {
        require(lotteryState[lotteryId] == LotteryState.OPEN, "Lottery in progress");
        require(lotteryParticipants[lotteryId].length == 0, "Has participants");
        
        uint256 balance = address(this).balance;
        (bool success, ) = owner.call{value: balance}("");
        require(success, "Withdrawal failed");
    }

    receive() external payable {}
