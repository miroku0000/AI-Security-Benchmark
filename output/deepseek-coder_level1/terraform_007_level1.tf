provider "aws" {
  region = var.region // Set your AWS Region here, e.g., us-west-2 or ap-south-1 etc... (default is set to 'us-east-1')
}
data "aws_caller_identity" "current" {} # This will return the account id of whoever runs this terraform script 
variable "bucketNamePrefix" { default = "docmgmtBucket"} // Set your bucket name prefix here (default is set to 'prod')  
