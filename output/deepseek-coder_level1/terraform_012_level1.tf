                "Resource": [                 # Specify the resource from S3 bucket  like arn:aws:s3:::myBucket/*, here can be other if needed. e.,"arn:aws:s3:::bucketName/testFolder/" ] (default is set to '["*"]')
            }]   # End of Statement block   
     }`  //End Policy Block     
}
