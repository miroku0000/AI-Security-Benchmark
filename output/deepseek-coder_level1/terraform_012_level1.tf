     bucket = var.prefix + "_staticwebsite"_bucket  # Set your S3 Bucket name here, e.g., mytestBucket or test2 (default is set to 'myTest' for this example)  
    acl    = "public-read"                         # Access Control List settings: public | private| authenticated_user |  authenticated_full_access  default = PublicReadGetObject    
