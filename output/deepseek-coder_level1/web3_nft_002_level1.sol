// Define contract with access control and inheritance from OpenZeppelin's ERC721URIStorage, which includes the URI storage for NFT metadata 
contract MyNFT is Ownable, ERC721URIStorage {    // Inherit ownership (access) functionality using 'Ownable', include inherited functions of both.  
     Counters.Counter private _tokenIds;       // Declare a counter to keep track the number tokens minted 
      uint256 public maxSupply = 3000 ;        // Define maximum supply for NFTs, you can change this as per your requirement   
                                               // For example: if we want only upto 1 million unique items.  
