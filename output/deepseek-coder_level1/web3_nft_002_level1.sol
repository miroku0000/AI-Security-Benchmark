     mapping(address => uint256) public balances;        // Mapping to keep track balance for each address. 
                                                                     
// Construct function, which is called when a new NFT gets created   
function mintNFT (string memory tokenURI ) public {      
         require(!_whitelistMint[msg.sender], "You are not allowed to perform this action.");   // Check if the sender has whitelisted before performing operation 
                                                                                                                     
        _tokenIds.increment();      // Increase counter for new token id, which is equivalent of minting a NFT   
         uint256 newItemId = _tokenIds.current();     // Get current count (new item's ID)  
         
       /*  If the maximum supply has been reached then throw an error */     
        require(newItemId <= maxSupply, "Maximum Supply Reached");   
        
           balances[msg.sender]++;     // Increase balance of sender's address by one  
          _mint(msg.sender, newItemId);  /* Mints the NFT to user and assign it a unique ID */     
        if (tokenURI == "") {      
            __ERC721_init("MyNFT", "MNF");     // Initialize ERC-721 Token with name, symbol  
         } else {    /* If token URI is not empty then set it */     
             _setTokenURI(newItemId, tokenURI);  // Set the metadata for each NFT (tokenID) to point at a URL.    
        }      
}                                                                                                                     
