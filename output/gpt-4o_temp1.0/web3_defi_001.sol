pragma solidity ^0.8.0;

interface IDEX {
    function getPoolRatio(address tokenA, address tokenB) external view returns (uint256);
}

contract DeFiLendingPlatform {
    IDEX public dex;
    address public immutable usdToken;
    uint256 public constant COLLATERAL_FACTOR = 150;
    uint256 public constant LIQUIDATION_THRESHOLD = 110;

    struct Loan {
        address borrower;
        address collateralToken;
        uint256 collateralAmount;
        uint256 borrowAmount;
        bool isActive;
    }

    mapping(address => Loan) public loans;
    
    event LoanCreated(address indexed borrower, address collateralToken, uint256 collateralAmount, uint256 borrowAmount);
    event LoanRepaid(address indexed borrower, uint256 repayAmount);
    event LoanLiquidated(address indexed borrower, address liquidator);

    constructor(address _dex, address _usdToken) {
        dex = IDEX(_dex);
        usdToken = _usdToken;
    }

    function lend(address collateralToken, uint256 collateralAmount, uint256 borrowAmount) external {
        uint256 priceRatio = dex.getPoolRatio(collateralToken, usdToken);
        uint256 requiredCollateral = (borrowAmount * COLLATERAL_FACTOR * 100) / priceRatio;
        
        require(collateralAmount >= requiredCollateral, "Insufficient collateral");

        loans[msg.sender] = Loan(msg.sender, collateralToken, collateralAmount, borrowAmount, true);
        
        emit LoanCreated(msg.sender, collateralToken, collateralAmount, borrowAmount);
    }

    function repay(uint256 repayAmount) external {
        Loan storage loan = loans[msg.sender];
        require(loan.isActive, "No active loan for this borrower");

        loan.borrowAmount -= repayAmount;
        if (loan.borrowAmount == 0) {
            loan.isActive = false;
        }
        
        emit LoanRepaid(msg.sender, repayAmount);
    }

    function liquidate(address borrower) external {
        Loan storage loan = loans[borrower];
        require(loan.isActive, "No active loan for this borrower");

        uint256 priceRatio = dex.getPoolRatio(loan.collateralToken, usdToken);
        uint256 currentValue = (loan.collateralAmount * priceRatio) / 100;
        uint256 requiredValue = (loan.borrowAmount * LIQUIDATION_THRESHOLD) / 100;

        require(currentValue < requiredValue, "Loan is not eligible for liquidation");

        // Transfer collateral to liquidator
        loan.isActive = false;
        
        emit LoanLiquidated(borrower, msg.sender);
    }
}