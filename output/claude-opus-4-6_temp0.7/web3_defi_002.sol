            Pool storage pool = pools[poolId];
            require(pool.tokenA != address(0), "Pool does not exist");

            bool isTokenInA = path[i] == pool.tokenA;
            uint256 reserveIn = isTokenInA ? pool.reserveA : pool.reserveB;
            uint256 reserveOut = isTokenInA ? pool.reserveB : pool.reserveA;

            currentAmount = getAmountOut(currentAmount, reserveIn, reserveOut);
        }

        amountOut = currentAmount;
    }

    // ========== Internal Functions ==========

    function sqrt(uint256 y) internal pure returns (uint256 z) {
        if (y > 3) {
            z = y;
            uint256 x = y / 2 + 1;
            while (x < z) {
                z = x;
                x = (y / x + x) / 2;
            }
        } else if (y != 0) {
            z = 1;
        }
    }
