pragma solidity ^0.8.20;

import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/token/ERC20/utils/SafeERC20.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/ReentrancyGuard.sol";

contract BatchProcessor is Ownable, ReentrancyGuard {
    using SafeERC20 for IERC20;

    // Internal balance tracking for users
    mapping(address => mapping(address => uint256)) public balances; // token => user => balance

    // ETH balances
    mapping(address => uint256) public ethBalances;

    // Maximum batch size to prevent out-of-gas
    uint256 public maxBatchSize;

    event TokensAirdropped(address indexed token, uint256 recipientCount, uint256 totalAmount);
    event ETHAirdropped(uint256 recipientCount, uint256 totalAmount);
    event BalancesUpdated(address indexed token, uint256 recipientCount);
    event ETHBalancesUpdated(uint256 recipientCount);
    event BatchPaymentSent(address indexed token, uint256 recipientCount, uint256 totalAmount);
    event ETHBatchPaymentSent(uint256 recipientCount, uint256 totalAmount);
    event Withdrawn(address indexed user, address indexed token, uint256 amount);
    event ETHWithdrawn(address indexed user, uint256 amount);
    event MaxBatchSizeUpdated(uint256 newMaxBatchSize);

    constructor(uint256 _maxBatchSize) Ownable(msg.sender) {
        require(_maxBatchSize > 0, "Max batch size must be > 0");
        maxBatchSize = _maxBatchSize;
    }

    // ============ Admin Functions ============

    function setMaxBatchSize(uint256 _maxBatchSize) external onlyOwner {
        require(_maxBatchSize > 0, "Max batch size must be > 0");
        maxBatchSize = _maxBatchSize;
        emit MaxBatchSizeUpdated(_maxBatchSize);
    }

    // ============ ERC20 Airdrop Functions ============

    /// @notice Airdrop equal amounts of ERC20 tokens to multiple recipients
    /// @param token The ERC20 token address
    /// @param recipients Array of recipient addresses
    /// @param amountPerRecipient Amount of tokens each recipient receives
    function airdropEqualERC20(
        address token,
        address[] calldata recipients,
        uint256 amountPerRecipient
    ) external nonReentrant {
        uint256 length = recipients.length;
        require(length > 0, "Empty recipients array");
        require(length <= maxBatchSize, "Batch size exceeds maximum");
        require(amountPerRecipient > 0, "Amount must be > 0");

        uint256 totalAmount = amountPerRecipient * length;
        // Check for overflow
        require(totalAmount / length == amountPerRecipient, "Overflow");

        IERC20 tokenContract = IERC20(token);
        tokenContract.safeTransferFrom(msg.sender, address(this), totalAmount);

        for (uint256 i = 0; i < length; i++) {
            require(recipients[i] != address(0), "Invalid recipient");
            tokenContract.safeTransfer(recipients[i], amountPerRecipient);
        }

        emit TokensAirdropped(token, length, totalAmount);
    }

    /// @notice Airdrop varying amounts of ERC20 tokens to multiple recipients
    /// @param token The ERC20 token address
    /// @param recipients Array of recipient addresses
    /// @param amounts Array of amounts corresponding to each recipient
    function airdropVaryingERC20(
        address token,
        address[] calldata recipients,
        uint256[] calldata amounts
    ) external nonReentrant {
        uint256 length = recipients.length;
        require(length > 0, "Empty recipients array");
        require(length == amounts.length, "Arrays length mismatch");
        require(length <= maxBatchSize, "Batch size exceeds maximum");

        uint256 totalAmount = 0;
        for (uint256 i = 0; i < length; i++) {
            require(amounts[i] > 0, "Amount must be > 0");
            totalAmount += amounts[i];
            require(totalAmount >= amounts[i], "Overflow");
        }

        IERC20 tokenContract = IERC20(token);
        tokenContract.safeTransferFrom(msg.sender, address(this), totalAmount);

        for (uint256 i = 0; i < length; i++) {
            require(recipients[i] != address(0), "Invalid recipient");
            tokenContract.safeTransfer(recipients[i], amounts[i]);
        }

        emit TokensAirdropped(token, length, totalAmount);
    }

    // ============ ETH Airdrop Functions ============

    /// @notice Airdrop equal amounts of ETH to multiple recipients
    /// @param recipients Array of recipient addresses
    function airdropEqualETH(
        address[] calldata recipients
    ) external payable nonReentrant {
        uint256 length = recipients.length;
        require(length > 0, "Empty recipients array");
        require(length <= maxBatchSize, "Batch size exceeds maximum");
        require(msg.value > 0, "No ETH sent");

        uint256 amountPerRecipient = msg.value / length;
        require(amountPerRecipient > 0, "Amount per recipient is 0");

        uint256 totalSent = 0;
        for (uint256 i = 0; i < length; i++) {
            require(recipients[i] != address(0), "Invalid recipient");
            (bool success, ) = recipients[i].call{value: amountPerRecipient}("");
            require(success, "ETH transfer failed");
            totalSent += amountPerRecipient;
        }

        // Refund remaining dust
        uint256 remaining = msg.value - totalSent;
        if (remaining > 0) {
            (bool refundSuccess, ) = msg.sender.call{value: remaining}("");
            require(refundSuccess, "Refund failed");
        }

        emit ETHAirdropped(length, totalSent);
    }

    /// @notice Airdrop varying amounts of ETH to multiple recipients
    /// @param recipients Array of recipient addresses
    /// @param amounts Array of amounts corresponding to each recipient
    function airdropVaryingETH(
        address[] calldata recipients,
        uint256[] calldata amounts
    ) external payable nonReentrant {
        uint256 length = recipients.length;
        require(length > 0, "Empty recipients array");
        require(length == amounts.length, "Arrays length mismatch");
        require(length <= maxBatchSize, "Batch size exceeds maximum");

        uint256 totalRequired = 0;
        for (uint256 i = 0; i < length; i++) {
            require(amounts[i] > 0, "Amount must be > 0");
            totalRequired += amounts[i];
            require(totalRequired >= amounts[i], "Overflow");
        }
        require(msg.value >= totalRequired, "Insufficient ETH sent");

        for (uint256 i = 0; i < length; i++) {
            require(recipients[i] != address(0), "Invalid recipient");
            (bool success, ) = recipients[i].call{value: amounts[i]}("");
            require(success, "ETH transfer failed");
        }

        // Refund excess
        uint256 excess = msg.value - totalRequired;
        if (excess > 0) {
            (bool refundSuccess, ) = msg.sender.call{value: excess}("");
            require(refundSuccess, "Refund failed");
        }

        emit ETHAirdropped(length, totalRequired);
    }

    // ============ Balance Update Functions (Pull Pattern) ============

    /// @notice Update internal ERC20 balances for multiple users (pull pattern)
    /// @param token The ERC20 token address
    /// @param recipients Array of recipient addresses
    /// @param amounts Array of amounts to credit
    function batchUpdateERC20Balances(
        address token,
        address[] calldata recipients,
        uint256[] calldata amounts
    ) external nonReentrant {
        uint256 length = recipients.length;
        require(length > 0, "Empty recipients array");
        require(length == amounts.length, "Arrays length mismatch");
        require(length <= maxBatchSize, "Batch size exceeds maximum");

        uint256 totalAmount = 0;
        for (uint256 i = 0; i < length; i++) {
            require(amounts[i] > 0, "Amount must be > 0");
            totalAmount += amounts[i];
            require(totalAmount >= amounts[i], "Overflow");
        }

        IERC20(token).safeTransferFrom(msg.sender, address(this), totalAmount);

        for (uint256 i = 0; i < length; i++) {
            require(recipients[i] != address(0), "Invalid recipient");
            balances[token][recipients[i]] += amounts[i];
        }

        emit BalancesUpdated(token, length);
    }

    /// @notice Update internal ETH balances for multiple users (pull pattern)
    /// @param recipients Array of recipient addresses
    /// @param amounts Array of amounts to credit
    function batchUpdateETHBalances(
        address[] calldata recipients,
        uint256[] calldata amounts
    ) external payable nonReentrant {
        uint256 length = recipients.length;
        require(length > 0, "Empty recipients array");
        require(length == amounts.length, "Arrays length mismatch");
        require(length <= maxBatchSize, "Batch size exceeds maximum");

        uint256 totalRequired = 0;
        for (uint256 i = 0; i < length; i++) {
            require(amounts[i] > 0, "Amount must be > 0");
            totalRequired += amounts[i];
            require(totalRequired >= amounts[i], "Overflow");
        }
        require(msg.value >= totalRequired, "Insufficient ETH sent");

        for (uint256 i = 0; i < length; i++) {
            require(recipients[i] != address(0), "Invalid recipient");
            ethBalances[recipients[i]] += amounts[i];
        }

        // Refund excess
        uint256 excess = msg.value - totalRequired;
        if (excess > 0) {
            (bool refundSuccess, ) = msg.sender.call{value: excess}("");
            require(refundSuccess, "Refund failed");
        }

        emit ETHBalancesUpdated(length);
    }

    // ============ Withdrawal Functions (Pull Pattern) ============

    /// @notice Withdraw credited ERC20 tokens
    /// @param token The ERC20 token address
    function withdrawERC20(address token) external nonReentrant {
        uint256 amount = balances[token][msg.sender];
        require(amount > 0, "No balance to withdraw");

        balances[token][msg.sender] = 0;
        IERC20(token).safeTransfer(msg.sender, amount);

        emit Withdrawn(msg.sender, token, amount);
    }

    /// @notice Withdraw credited ETH
    function withdrawETH() external nonReentrant {
        uint256 amount = ethBalances[msg.sender];
        require(amount > 0, "No ETH balance to withdraw");

        ethBalances[msg.sender] = 0;
        (bool success, ) = msg.sender.call{value: amount}("");
        require(success, "ETH transfer failed");

        emit ETHWithdrawn(msg.sender, amount);
    }

    // ============ Emergency Functions ============

    /// @notice Emergency withdraw stuck ERC20 tokens (owner only)
    /// @param token The ERC20 token address
    /// @param to Recipient address
    /// @param amount Amount to withdraw
    function emergencyWithdrawERC20(
        address token,
        address to,
        uint256 amount
    ) external onlyOwner {
        require(to != address(0), "Invalid recipient");
        IERC20(token).safeTransfer(to, amount);
    }

    /// @notice Emergency withdraw stuck ETH (owner only)
    /// @param to Recipient address
    /// @param amount Amount to withdraw
    function emergencyWithdrawETH(
        address to,
        uint256 amount
    ) external onlyOwner {
        require(to != address(0), "Invalid recipient");
        (bool success, ) = to.call{value: amount}("");
        require(success, "ETH transfer failed");
    }

    // ============ View Functions ============

    /// @notice Get ERC20 balance for a user
    function getERC20Balance(address token, address user) external view returns (uint256) {
        return balances[token][user];
    }

    /// @notice Get ETH balance for a user
    function getETHBalance(address user) external view returns (uint256) {
        return ethBalances[user];
    }

    receive() external payable {}
}