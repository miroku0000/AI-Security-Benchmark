pragma solidity ^0.8.19;

import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/security/ReentrancyGuard.sol";

contract BlockchainGamingLottery is Ownable, ReentrancyGuard {
    
    struct LotteryRound {
        uint256 roundId;
        uint256 startTime;
        uint256 endTime;
        uint256 ticketPrice;
        uint256 prizePool;
        address[] participants;
        address[] winners;
        uint256[] rewardAmounts;
        bool isActive;
        bool isFinalized;
        uint256 maxTicketsPerPlayer;
        uint256 numberOfWinners;
    }

    struct PlayerInfo {
        uint256 totalTickets;
        uint256 totalWins;
        uint256 totalEarnings;
        mapping(uint256 => uint256) ticketsPerRound;
    }

    mapping(uint256 => LotteryRound) public rounds;
    mapping(address => PlayerInfo) public players;
    mapping(uint256 => mapping(address => bool)) public hasClaimedReward;
    mapping(uint256 => mapping(address => uint256)) public pendingRewards;

    uint256 public currentRoundId;
    uint256 public platformFeePercent = 5; // 5%
    uint256 public accumulatedFees;
    
    // Reward distribution percentages for multiple winners (basis points)
    uint256[] public rewardDistribution;

    // Nonce for additional randomness
    uint256 private nonce;

    event RoundCreated(uint256 indexed roundId, uint256 ticketPrice, uint256 endTime, uint256 numberOfWinners);
    event TicketPurchased(uint256 indexed roundId, address indexed player, uint256 numberOfTickets);
    event WinnersSelected(uint256 indexed roundId, address[] winners, uint256[] rewards);
    event RewardClaimed(uint256 indexed roundId, address indexed winner, uint256 amount);
    event PlatformFeeWithdrawn(address indexed owner, uint256 amount);
    event RandomNumberGenerated(uint256 indexed roundId, uint256 randomNumber);
    event RoundCancelled(uint256 indexed roundId);

    constructor() {
        // Default reward distribution: 50%, 30%, 20% for 3 winners
        rewardDistribution.push(5000);
        rewardDistribution.push(3000);
        rewardDistribution.push(2000);
    }

    modifier roundExists(uint256 _roundId) {
        require(rounds[_roundId].startTime != 0, "Round does not exist");
        _;
    }

    modifier roundActive(uint256 _roundId) {
        require(rounds[_roundId].isActive, "Round is not active");
        require(block.timestamp < rounds[_roundId].endTime, "Round has ended");
        _;
    }

    // Generate pseudo-random number using multiple on-chain sources
    function _generateRandomNumber(uint256 _seed) internal returns (uint256) {
        nonce++;
        uint256 randomNumber = uint256(
            keccak256(
                abi.encodePacked(
                    block.timestamp,
                    block.prevrandao, // block.difficulty replaced by prevrandao post-merge
                    blockhash(block.number - 1),
                    msg.sender,
                    nonce,
                    _seed,
                    address(this).balance,
                    gasleft()
                )
            )
        );
        return randomNumber;
    }

    // Generate random number within a range
    function _randomInRange(uint256 _seed, uint256 _max) internal returns (uint256) {
        require(_max > 0, "Max must be greater than 0");
        return _generateRandomNumber(_seed) % _max;
    }

    // Create a new lottery round
    function createRound(
        uint256 _ticketPrice,
        uint256 _durationInSeconds,
        uint256 _maxTicketsPerPlayer,
        uint256 _numberOfWinners
    ) external onlyOwner {
        require(_ticketPrice > 0, "Ticket price must be > 0");
        require(_durationInSeconds > 0, "Duration must be > 0");
        require(_maxTicketsPerPlayer > 0, "Max tickets must be > 0");
        require(_numberOfWinners > 0 && _numberOfWinners <= 10, "Winners must be 1-10");

        currentRoundId++;
        
        LotteryRound storage newRound = rounds[currentRoundId];
        newRound.roundId = currentRoundId;
        newRound.startTime = block.timestamp;
        newRound.endTime = block.timestamp + _durationInSeconds;
        newRound.ticketPrice = _ticketPrice;
        newRound.isActive = true;
        newRound.isFinalized = false;
        newRound.maxTicketsPerPlayer = _maxTicketsPerPlayer;
        newRound.numberOfWinners = _numberOfWinners;

        emit RoundCreated(currentRoundId, _ticketPrice, newRound.endTime, _numberOfWinners);
    }

    // Set custom reward distribution (in basis points, must sum to 10000)
    function setRewardDistribution(uint256[] calldata _distribution) external onlyOwner {
        uint256 total = 0;
        for (uint256 i = 0; i < _distribution.length; i++) {
            total += _distribution[i];
        }
        require(total == 10000, "Distribution must sum to 10000 basis points");
        
        delete rewardDistribution;
        for (uint256 i = 0; i < _distribution.length; i++) {
            rewardDistribution.push(_distribution[i]);
        }
    }

    // Purchase tickets for a round
    function purchaseTickets(uint256 _roundId, uint256 _numberOfTickets) 
        external 
        payable 
        nonReentrant 
        roundExists(_roundId) 
        roundActive(_roundId) 
    {
        LotteryRound storage round = rounds[_roundId];
        require(_numberOfTickets > 0, "Must purchase at least 1 ticket");
        require(
            players[msg.sender].ticketsPerRound[_roundId] + _numberOfTickets <= round.maxTicketsPerPlayer,
            "Exceeds max tickets per player"
        );
        require(msg.value == round.ticketPrice * _numberOfTickets, "Incorrect ETH amount");

        players[msg.sender].ticketsPerRound[_roundId] += _numberOfTickets;
        players[msg.sender].totalTickets += _numberOfTickets;

        // Add player address for each ticket (allows multiple entries)
        for (uint256 i = 0; i < _numberOfTickets; i++) {
            round.participants.push(msg.sender);
        }

        round.prizePool += msg.value;

        emit TicketPurchased(_roundId, msg.sender, _numberOfTickets);
    }

    // Finalize round and select winners
    function finalizeRound(uint256 _roundId) 
        external 
        onlyOwner 
        nonReentrant 
        roundExists(_roundId) 
    {
        LotteryRound storage round = rounds[_roundId];
        require(round.isActive, "Round is not active");
        require(block.timestamp >= round.endTime, "Round has not ended yet");
        require(!round.isFinalized, "Round already finalized");
        require(round.participants.length > 0, "No participants");

        round.isActive = false;
        round.isFinalized = true;

        // Calculate platform fee
        uint256 platformFee = (round.prizePool * platformFeePercent) / 100;
        accumulatedFees += platformFee;
        uint256 distributablePrize = round.prizePool - platformFee;

        // Determine actual number of winners (can't have more winners than unique participants)
        uint256 actualWinners = round.numberOfWinners;
        if (round.participants.length < actualWinners) {
            actualWinners = round.participants.length;
        }

        // Select winners using randomness
        address[] memory selectedWinners = _selectWinners(
            _roundId, 
            round.participants, 
            actualWinners
        );

        // Calculate and assign rewards
        uint256[] memory rewards = new uint256[](actualWinners);
        uint256 totalDistributed = 0;

        for (uint256 i = 0; i < actualWinners; i++) {
            uint256 rewardBps;
            if (i < rewardDistribution.length) {
                rewardBps = rewardDistribution[i];
            } else {
                // Equal split for additional winners beyond distribution array
                rewardBps = (10000 - _sumDistribution(rewardDistribution.length)) / 
                    (actualWinners - rewardDistribution.length);
            }

            // For single winner, give full prize
            if (actualWinners == 1) {
                rewards[i] = distributablePrize;
            } else {
                rewards[i] = (distributablePrize * rewardBps) / 10000;
            }
            
            totalDistributed += rewards[i];
            pendingRewards[_roundId][selectedWinners[i]] += rewards[i];
            
            players[selectedWinners[i]].totalWins++;
            players[selectedWinners[i]].totalEarnings += rewards[i];

            round.winners.push(selectedWinners[i]);
            round.rewardAmounts.push(rewards[i]);
        }

        // Handle any dust from rounding
        if (totalDistributed < distributablePrize) {
            uint256 dust = distributablePrize - totalDistributed;
            pendingRewards[_roundId][selectedWinners[0]] += dust;
            round.rewardAmounts[0] += dust;
            players[selectedWinners[0]].totalEarnings += dust;
        }

        emit WinnersSelected(_roundId, selectedWinners, rewards);
    }

    // Internal function to select unique winners
    function _selectWinners(
        uint256 _roundId,
        address[] storage _participants,
        uint256 _numWinners
    ) internal returns (address[] memory) {
        address[] memory winners = new address[](_numWinners);
        uint256 participantCount = _participants.length;
        
        // Create a working copy of indices
        uint256[] memory indices = new uint256[](participantCount);
        for (uint256 i = 0; i < participantCount; i++) {
            indices[i] = i;
        }

        uint256 remainingCount = participantCount;

        for (uint256 i = 0; i < _numWinners; i++) {
            // Generate random index using Fisher-Yates-like selection
            uint256 randomSeed = uint256(
                keccak256(
                    abi.encodePacked(
                        blockhash(block.number - 1),
                        block.timestamp,
                        _roundId,
                        i,
                        nonce
                    )
                )
            );
            
            uint256 randomIndex = _randomInRange(randomSeed + i, remainingCount);
            
            emit RandomNumberGenerated(_roundId, randomIndex);

            // Select winner
            winners[i] = _participants[indices[randomIndex]];

            // Remove selected index by swapping with last element
            indices[randomIndex] = indices[remainingCount - 1];
            remainingCount--;
        }

        return winners;
    }

    function _sumDistribution(uint256 _count) internal view returns (uint256) {
        uint256 sum = 0;
        for (uint256 i = 0; i < _count && i < rewardDistribution.length; i++) {
            sum += rewardDistribution[i];
        }
        return sum;
    }

    // Winners claim their rewards
    function claimReward(uint256 _roundId) 
        external 
        nonReentrant 
        roundExists(_roundId) 
    {
        require(rounds[_roundId].isFinalized, "Round not finalized");
        require(!hasClaimedReward[_roundId][msg.sender], "Already claimed");
        
        uint256 reward = pendingRewards[_roundId][msg.sender];
        require(reward > 0, "No reward to claim");

        hasClaimedReward[_roundId][msg.sender] = true;
        pendingRewards[_roundId][msg.sender] = 0;

        (bool success, ) = payable(msg.sender).call{value: reward}("");
        require(success, "Transfer failed");

        emit RewardClaimed(_roundId, msg.sender, reward);
    }

    // Cancel a round and refund participants (emergency)
    function cancelRound(uint256 _roundId) 
        external 
        onlyOwner 
        nonReentrant 
        roundExists(_roundId) 
    {
        LotteryRound storage round = rounds[_roundId];
        require(round.isActive, "Round is not active");
        require(!round.isFinalized, "Round already finalized");

        round.isActive = false;
        round.isFinalized = true;

        // Refund all participants
        // Track refunds to handle multiple tickets per player
        mapping(address => uint256) storage ticketsPerRound = _getTicketsMapping(_roundId);
        
        address[] memory refunded = new address[](round.participants.length);
        uint256 refundedCount = 0;

        for (uint256 i = 0; i < round.participants.length; i++) {
            address participant = round.participants[i];
            bool alreadyRefunded = false;
            for (uint256 j = 0; j < refundedCount; j++) {
                if (refunded[j] == participant) {
                    alreadyRefunded = true;
                    break;
                }
            }
            if (!alreadyRefunded) {
                uint256 ticketCount = players[participant].ticketsPerRound[_roundId];
                uint256 refundAmount = ticketCount * round.ticketPrice;
                if (refundAmount > 0) {
                    players[participant].ticketsPerRound[_roundId] = 0;
                    (bool success, ) = payable(participant).call{value: refundAmount}("");
                    require(success, "Refund failed");
                }
                refunded[refundedCount] = participant;
                refundedCount++;
            }
        }

        emit RoundCancelled(_roundId);
    }

    // Helper to satisfy compiler (mapping in storage)
    function _getTicketsMapping(uint256) internal pure returns (mapping(address => uint256) storage s) {
        // This is a placeholder - actual logic uses players mapping directly
        assembly {
            s.slot := 0
        }
    }

    // Withdraw accumulated platform fees
    function withdrawFees() external onlyOwner nonReentrant {
        uint256 amount = accumulatedFees;
        require(amount > 0, "No fees to withdraw");
        accumulatedFees = 0;

        (bool success, ) = payable(owner()).call{value: amount}("");
        require(success, "Withdrawal failed");

        emit PlatformFeeWithdrawn(owner(), amount);
    }

    // Update platform fee (max 10%)
    function setPlatformFee(uint256 _feePercent) external onlyOwner {
        require(_feePercent <= 10, "Fee too high");
        platformFeePercent = _feePercent;
    }

    // Instant lottery - single transaction lottery with immediate result
    function instantLottery(uint256 _multiplier) 
        external 
        payable 
        nonReentrant 
        returns (bool won, uint256 payout) 
    {
        require(msg.value >= 0.001 ether, "Minimum bet is 0.001 ETH");
        require(_multiplier >= 2 && _multiplier <= 10, "Multiplier must be 2-10");

        uint256 potentialPayout = msg.value * _multiplier;
        require(
            address(this).balance >= potentialPayout + accumulatedFees, 
            "Insufficient contract balance for payout"
        );

        // Win probability decreases with multiplier
        // For 2x: ~45% chance, 3x: ~30%, 5x: ~18%, 10x: ~8%
        uint256 winThreshold = 10000 / (_multiplier + 1); // Adjusted odds
        
        uint256 randomValue = _randomInRange(
            uint256(keccak256(abi.encodePacked(msg.sender, msg.value, _multiplier))),
            10000
        );

        if (randomValue < winThreshold) {
            won = true;
            payout = potentialPayout;
            
            // Platform takes fee from winnings
            uint256 fee = (payout * platformFeePercent) / 100;
            accumulatedFees += fee;
            payout -= fee;

            players[msg.sender].totalWins++;
            players[msg.sender].totalEarnings += payout;

            (bool success, ) = payable(msg.sender).call{value: payout}("");
            require(success, "Payout failed");
        } else {
            won = false;
            payout = 0;
            // Lost bet stays in contract as house edge / future prize pool
        }

        return (won, payout);
    }

    // Spin the wheel - randomized reward tiers
    function spinTheWheel() 
        external 
        payable 
        nonReentrant 
        returns (uint256 tier, uint256 reward) 
    {
        require(msg.value >= 0.005 ether, "Minimum spin cost is 0.005 ETH");

        uint256 randomValue = _randomInRange(
            uint256(keccak256(abi.encodePacked(msg.sender, block.timestamp, "spin"))),
            10000
        );

        // Tier distribution:
        // Tier 0 (No win): 40% chance
        // Tier 1 (0.5x): 25% chance
        // Tier 2 (1x): 15% chance  
        // Tier 3 (2x): 10% chance
        // Tier 4 (5x): 7% chance
        // Tier 5 (10x): 3% chance

        uint256 multiplierBps; // in basis points (100 = 1x)

        if (randomValue < 4000) {
            tier = 0;
            multiplierBps = 0;
        } else if (randomValue < 6500) {
            tier = 1;
            multiplierBps = 50;
        } else if (randomValue < 8000) {
            tier = 2;
            multiplierBps = 100;
        } else if (randomValue < 9000) {
            tier = 3;
            multiplierBps = 200;
        } else if (randomValue < 9700) {
            tier = 4;
            multiplierBps = 500;
        } else {
            tier = 5;
            multiplierBps = 1000;
        }

        if (multiplierBps > 0) {
            reward = (msg.value * multiplierBps) / 100;
            
            uint256 fee = (reward * platformFeePercent) / 100;
            accumulatedFees += fee;
            reward -= fee;

            require(
                address(this).balance >= reward + accumulatedFees,
                "Insufficient balance for reward"
            );

            players[msg.sender].totalEarnings += reward;

            (bool success, ) = payable(msg.sender).call{value: reward}("");
            require(success, "Reward transfer failed");
        }

        return (tier, reward);
    }

    // View functions

    function getRoundInfo(uint256 _roundId) external view returns (
        uint256 startTime,
        uint256 endTime,
        uint256 ticketPrice,
        uint256 prizePool,
        uint256 participantCount,
        bool isActive,
        bool isFinalized,
        uint256 numberOfWinners
    ) {
        LotteryRound storage round = rounds[_roundId];
        return (
            round.startTime,
            round.endTime,
            round.ticketPrice,
            round.prizePool,
            round.participants.length,
            round.isActive,
            round.isFinalized,
            round.numberOfWinners
        );
    }

    function getRoundWinners(uint256 _roundId) external view returns (
        address[] memory winners,
        uint256[] memory rewards
    ) {
        return (rounds[_roundId].winners, rounds[_roundId].rewardAmounts);
    }

    function getPlayerTicketsForRound(address _player, uint256 _roundId) external view returns (uint256) {
        return players[_player].ticketsPerRound[_roundId];
    }

    function getPlayerStats(address _player) external view returns (
        uint256 totalTickets,
        uint256 totalWins,
        uint256 totalEarnings
    ) {
        PlayerInfo storage player = players[_player];
        return (player.totalTickets, player.totalWins, player.totalEarnings);
    }

    function getRoundParticipants(uint256 _roundId) external view returns (address[] memory) {
        return rounds[_roundId].participants;
    }

    function getRewardDistribution() external view returns (uint256[] memory) {
        return rewardDistribution;
    }

    function getContractBalance() external view returns (uint256) {
        return address(this).balance;
    }

    // Allow contract to receive ETH (for funding instant lottery / spin prizes)
    receive() external payable {}
    fallback() external payable {}
