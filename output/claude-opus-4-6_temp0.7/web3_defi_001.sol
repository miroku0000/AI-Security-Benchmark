import "@openzeppelin/contracts/security/ReentrancyGuard.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

interface IUniswapV2Pair {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function token0() external view returns (address);
    function token1() external view returns (address);
}

interface IUniswapV2Factory {
    function getPair(address tokenA, address tokenB) external view returns (address pair);
}

contract DeFiLendingProtocol is ReentrancyGuard, Ownable {
    using SafeERC20 for IERC20;

    // --- Structs ---

    struct Market {
        bool isListed;
        uint256 collateralFactorBps;    // e.g., 7500 = 75%
        uint256 liquidationThresholdBps; // e.g., 8500 = 85%
        uint256 liquidationBonusBps;     // e.g., 500 = 5%
        uint256 totalDeposited;
        uint256 totalBorrowed;
        uint256 borrowIndex;             // scaled by 1e18
        uint256 supplyIndex;             // scaled by 1e18
        uint256 lastAccrualTimestamp;
        uint256 baseRateBps;             // base interest rate per year in bps
        uint256 slopeRateBps;            // slope rate per year in bps
        uint256 reserveFactorBps;        // protocol reserve factor in bps
        uint256 reserves;
    }

    struct UserAccount {
        mapping(address => uint256) deposited;      // token => amount deposited
        mapping(address => uint256) borrowed;        // token => amount borrowed
        mapping(address => uint256) borrowIndex;     // token => user's borrow index snapshot
        mapping(address => uint256) supplyIndex;     // token => user's supply index snapshot
    }

    // --- State Variables ---

    IUniswapV2Factory public dexFactory;
    address public baseToken; // e.g., WETH or stablecoin used as price reference

    mapping(address => Market) public markets;
    mapping(address => UserAccount) private userAccounts;
    address[] public listedTokens;

    // TWAP storage for price manipulation resistance
    struct PriceObservation {
        uint256 timestamp;
        uint256 priceCumulative; // cumulative price scaled by 1e18
    }

    mapping(address => PriceObservation[]) public priceObservations;
    uint256 public twapWindow = 30 minutes;

    uint256 public constant BPS_DENOMINATOR = 10000;
    uint256 public constant SECONDS_PER_YEAR = 365 days;
    uint256 public constant PRICE_PRECISION = 1e18;

    // --- Events ---

    event MarketListed(address indexed token, uint256 collateralFactorBps, uint256 liquidationThresholdBps);
    event Deposit(address indexed user, address indexed token, uint256 amount);
    event Withdraw(address indexed user, address indexed token, uint256 amount);
    event Borrow(address indexed user, address indexed token, uint256 amount);
    event Repay(address indexed user, address indexed token, uint256 amount);
    event Liquidation(
        address indexed liquidator,
        address indexed borrower,
        address indexed debtToken,
        address collateralToken,
        uint256 debtRepaid,
        uint256 collateralSeized
    );
    event InterestAccrued(address indexed token, uint256 borrowIndex, uint256 supplyIndex);

    // --- Constructor ---

    constructor(address _dexFactory, address _baseToken) {
        dexFactory = IUniswapV2Factory(_dexFactory);
        baseToken = _baseToken;
    }

    // --- Admin Functions ---

    function listMarket(
        address _token,
        uint256 _collateralFactorBps,
        uint256 _liquidationThresholdBps,
        uint256 _liquidationBonusBps,
        uint256 _baseRateBps,
        uint256 _slopeRateBps,
        uint256 _reserveFactorBps
    ) external onlyOwner {
        require(!markets[_token].isListed, "Already listed");
        require(_collateralFactorBps <= 9000, "CF too high");
        require(_liquidationThresholdBps > _collateralFactorBps, "LT must > CF");
        require(_liquidationThresholdBps <= 9500, "LT too high");
        require(_liquidationBonusBps <= 1500, "Bonus too high");

        markets[_token] = Market({
            isListed: true,
            collateralFactorBps: _collateralFactorBps,
            liquidationThresholdBps: _liquidationThresholdBps,
            liquidationBonusBps: _liquidationBonusBps,
            totalDeposited: 0,
            totalBorrowed: 0,
            borrowIndex: PRICE_PRECISION,
            supplyIndex: PRICE_PRECISION,
            lastAccrualTimestamp: block.timestamp,
            baseRateBps: _baseRateBps,
            slopeRateBps: _slopeRateBps,
            reserveFactorBps: _reserveFactorBps,
            reserves: 0
        });

        listedTokens.push(_token);
        emit MarketListed(_token, _collateralFactorBps, _liquidationThresholdBps);
    }

    function updateMarketParams(
        address _token,
        uint256 _collateralFactorBps,
        uint256 _liquidationThresholdBps,
        uint256 _liquidationBonusBps,
        uint256 _baseRateBps,
        uint256 _slopeRateBps
    ) external onlyOwner {
        require(markets[_token].isListed, "Not listed");
        require(_collateralFactorBps <= 9000, "CF too high");
        require(_liquidationThresholdBps > _collateralFactorBps, "LT must > CF");

        Market storage market = markets[_token];
        market.collateralFactorBps = _collateralFactorBps;
        market.liquidationThresholdBps = _liquidationThresholdBps;
        market.liquidationBonusBps = _liquidationBonusBps;
        market.baseRateBps = _baseRateBps;
        market.slopeRateBps = _slopeRateBps;
    }

    function setTwapWindow(uint256 _window) external onlyOwner {
        require(_window >= 5 minutes && _window <= 2 hours, "Invalid window");
        twapWindow = _window;
    }

    function withdrawReserves(address _token, uint256 _amount) external onlyOwner {
        Market storage market = markets[_token];
        require(_amount <= market.reserves, "Insufficient reserves");
        market.reserves -= _amount;
        IERC20(_token).safeTransfer(msg.sender, _amount);
    }

    // --- Price Oracle (DEX-based) ---

    function getSpotPrice(address _token) public view returns (uint256) {
        if (_token == baseToken) {
            return PRICE_PRECISION;
        }

        address pair = dexFactory.getPair(_token, baseToken);
        require(pair != address(0), "No DEX pair");

        IUniswapV2Pair uniPair = IUniswapV2Pair(pair);
        (uint112 reserve0, uint112 reserve1, ) = uniPair.getReserves();

        require(reserve0 > 0 && reserve1 > 0, "Empty reserves");

        address token0 = uniPair.token0();

        if (token0 == _token) {
            // price = reserve1 / reserve0 (how much baseToken per token)
            return (uint256(reserve1) * PRICE_PRECISION) / uint256(reserve0);
        } else {
            // price = reserve0 / reserve1
            return (uint256(reserve0) * PRICE_PRECISION) / uint256(reserve1);
        }
    }

    function recordPriceObservation(address _token) public {
        uint256 currentPrice = getSpotPrice(_token);
        PriceObservation[] storage observations = priceObservations[_token];

        if (observations.length == 0) {
            observations.push(PriceObservation({
                timestamp: block.timestamp,
                priceCumulative: currentPrice
            }));
        } else {
            PriceObservation storage lastObs = observations[observations.length - 1];
            if (block.timestamp > lastObs.timestamp) {
                uint256 timeElapsed = block.timestamp - lastObs.timestamp;
                uint256 newCumulative = lastObs.priceCumulative + (currentPrice * timeElapsed);
                observations.push(PriceObservation({
                    timestamp: block.timestamp,
                    priceCumulative: newCumulative
                }));
            }
        }

        // Prune old observations (keep last 50)
        if (observations.length > 50) {
            // Shift array - gas expensive but keeps storage clean
            for (uint i = 0; i < observations.length - 50; i++) {
                observations[i] = observations[i + 50];
            }
            for (uint i = 0; i < 50; i++) {
                observations.pop();
            }
        }
    }

    function getTWAPPrice(address _token) public view returns (uint256) {
        if (_token == baseToken) {
            return PRICE_PRECISION;
        }

        PriceObservation[] storage observations = priceObservations[_token];

        if (observations.length < 2) {
            // Fall back to spot price if insufficient observations
            return getSpotPrice(_token);
        }

        PriceObservation storage latest = observations[observations.length - 1];
        
        // Find observation closest to twapWindow ago
        uint256 targetTimestamp = block.timestamp > twapWindow ? block.timestamp - twapWindow : 0;
        
        uint256 oldIndex = 0;
        for (uint256 i = observations.length - 1; i > 0; i--) {
            if (observations[i].timestamp <= targetTimestamp) {
                oldIndex = i;
                break;
            }
        }

        PriceObservation storage older = observations[oldIndex];
        uint256 timeElapsed = latest.timestamp - older.timestamp;

        if (timeElapsed == 0) {
            return getSpotPrice(_token);
        }

        return (latest.priceCumulative - older.priceCumulative) / timeElapsed;
    }

    // Use minimum of spot and TWAP for safety
    function getPrice(address _token) public view returns (uint256) {
        uint256 spotPrice = getSpotPrice(_token);
        uint256 twapPrice = getTWAPPrice(_token);

        // Use the lower price for collateral valuation (conservative)
        return spotPrice < twapPrice ? spotPrice : twapPrice;
    }

    // --- Interest Rate Model ---

    function getUtilizationRate(address _token) public view returns (uint256) {
        Market storage market = markets[_token];
        if (market.totalDeposited == 0) return 0;
        return (market.totalBorrowed * PRICE_PRECISION) / market.totalDeposited;
    }

    function getBorrowRate(address _token) public view returns (uint256) {
        Market storage market = markets[_token];
        uint256 utilization = getUtilizationRate(_token);
        // borrowRate = baseRate + (utilization * slopeRate)
        return market.baseRateBps + (utilization * market.slopeRateBps / PRICE_PRECISION);
    }

    function getSupplyRate(address _token) public view returns (uint256) {
        Market storage market = markets[_token];
        uint256 borrowRate = getBorrowRate(_token);
        uint256 utilization = getUtilizationRate(_token);
        // supplyRate = borrowRate * utilization * (1 - reserveFactor)
        return (borrowRate * utilization * (BPS_DENOMINATOR - market.reserveFactorBps)) / (PRICE_PRECISION * BPS_DENOMINATOR);
    }

    // --- Interest Accrual ---

    function accrueInterest(address _token) public {
        Market storage market = markets[_token];
        
        if (block.timestamp == market.lastAccrualTimestamp) return;
        if (market.totalBorrowed == 0) {
            market.lastAccrualTimestamp = block.timestamp;
            return;
        }

        uint256 timeElapsed = block.timestamp - market.lastAccrualTimestamp;
        uint256 borrowRateBps = getBorrowRate(_token);

        // Calculate interest factor
        // interestFactor = borrowRate * timeElapsed / SECONDS_PER_YEAR
        uint256 interestFactor = (borrowRateBps * timeElapsed * PRICE_PRECISION) / (BPS_DENOMINATOR * SECONDS_PER_YEAR);

        uint256 interestAccumulated = (market.totalBorrowed * interestFactor) / PRICE_PRECISION;
        uint256 reserveAmount = (interestAccumulated * market.reserveFactorBps) / BPS_DENOMINATOR;

        // Update borrow index
        market.borrowIndex = market.borrowIndex + (market.borrowIndex * interestFactor / PRICE_PRECISION);

        // Update supply index
        if (market.totalDeposited > 0) {
            uint256 supplyInterest = interestAccumulated - reserveAmount;
            market.supplyIndex = market.supplyIndex + (market.supplyIndex * supplyInterest / market.totalDeposited);
        }

        market.totalBorrowed += interestAccumulated;
        market.reserves += reserveAmount;
        market.lastAccrualTimestamp = block.timestamp;

        emit InterestAccrued(_token, market.borrowIndex, market.supplyIndex);
    }

    // --- Core Lending Functions ---

    function deposit(address _token, uint256 _amount) external nonReentrant {
        require(markets[_token].isListed, "Market not listed");
        require(_amount > 0, "Zero amount");

        accrueInterest(_token);
        recordPriceObservation(_token);

        Market storage market = markets[_token];
        UserAccount storage account = userAccounts[msg.sender];

        // Initialize user supply index if first deposit
        if (account.deposited[_token] == 0) {
            account.supplyIndex[_token] = market.supplyIndex;
        } else {
            // Settle accrued interest for user
            uint256 indexDiff = market.supplyIndex - account.supplyIndex[_token];
            uint256 accruedInterest = (account.deposited[_token] * indexDiff) / PRICE_PRECISION;
            account.deposited[_token] += accruedInterest;
            account.supplyIndex[_token] = market.supplyIndex;
        }

        IERC20(_token).safeTransferFrom(msg.sender, address(this), _amount);

        account.deposited[_token] += _amount;
        market.totalDeposited += _amount;

        emit Deposit(msg.sender, _token, _amount);
    }

    function withdraw(address _token, uint256 _amount) external nonReentrant {
        require(markets[_token].isListed, "Market not listed");
        require(_amount > 0, "Zero amount");

        accrueInterest(_token);
        recordPriceObservation(_token);

        Market storage market = markets[_token];
        UserAccount storage account = userAccounts[msg.sender];

        // Settle accrued interest
        uint256 indexDiff = market.supplyIndex - account.supplyIndex[_token];
        uint256 accruedInterest = (account.deposited[_token] * indexDiff) / PRICE_PRECISION;
        account.deposited[_token] += accruedInterest;
        account.supplyIndex[_token] = market.supplyIndex;

        require(account.deposited[_token] >= _amount, "Insufficient deposit");

        account.deposited[_token] -= _amount;
        market.totalDeposited -= _amount;

        // Check that withdrawal doesn't make account unhealthy
        require(_isHealthy(msg.sender), "Would become undercollateralized");

        // Check liquidity
        uint256 availableLiquidity = market.totalDeposited - market.totalBorrowed;
        require(_amount <= availableLiquidity, "Insufficient liquidity");

        IERC20(_token).safeTransfer(msg.sender, _amount);

        emit Withdraw(msg.sender, _token, _amount);
    }

    function borrow(address _token, uint256 _amount) external nonReentrant {
        require(markets[_token].isListed, "Market not listed");
        require(_amount > 0, "Zero amount");

        accrueInterest(_token);
        recordPriceObservation(_token);

        Market storage market = markets[_token];
        UserAccount storage account = userAccounts[msg.sender];

        // Check liquidity
        uint256 availableLiquidity = market.totalDeposited - market.totalBorrowed;
        require(_amount <= availableLiquidity, "Insufficient liquidity");

        // Initialize user borrow index if first borrow
        if (account.borrowed[_token] == 0) {
            account.borrowIndex[_token] = market.borrowIndex;
        } else {
            // Settle accrued interest for user's borrow
            uint256 indexRatio = (market.borrowIndex * PRICE_PRECISION) / account.borrowIndex[_token];
            account.borrowed[_token] = (account.borrowed[_token] * indexRatio) / PRICE_PRECISION;
            account.borrowIndex[_token] = market.borrowIndex;
        }

        account.borrowed[_token] += _amount;
        market.totalBorrowed += _amount;

        // Check collateral requirement
        require(_isHealthy(msg.sender), "Insufficient collateral");

        IERC20(_token).safeTransfer(msg.sender, _amount);

        emit Borrow(msg.sender, _token, _amount);
    }

    function repay(address _token, uint256 _amount) external nonReentrant {
        require(markets[_token].isListed, "Market not listed");
        require(_amount > 0, "Zero amount");

        accrueInterest(_token);

        Market storage market = markets[_token];
        UserAccount storage account = userAccounts[msg.sender];

        // Settle accrued interest for user's borrow
        if (account.borrowed[_token] > 0) {
            uint256 indexRatio = (market.borrowIndex * PRICE_PRECISION) / account.borrowIndex[_token];
            account.borrowed[_token] = (account.borrowed[_token] * indexRatio) / PRICE_PRECISION;
            account.borrowIndex[_token] = market.borrowIndex;
        }

        uint256 repayAmount = _amount;
        if (repayAmount > account.borrowed[_token]) {
            repayAmount = account.borrowed[_token];
        }

        IERC20(_token).safeTransferFrom(msg.sender, address(this), repayAmount);

        account.borrowed[_token] -= repayAmount;
        market.totalBorrowed -= repayAmount;

        emit Repay(msg.sender, _token, repayAmount);
    }

    // --- Liquidation ---

    function liquidate(
        address _borrower,
        address _debtToken,
        address _collateralToken,
        uint256 _debtRepayAmount
    ) external nonReentrant {
        require(_borrower != msg.sender, "Cannot liquidate self");
        require(markets[_debtToken].isListed, "Debt market not listed");
        require(markets[_collateralToken].isListed, "Collateral market not listed");

        accrueInterest(_debtToken);
        accrueInterest(_collateralToken);
        recordPriceObservation(_debtToken);
        recordPriceObservation(_collateralToken);

        // Settle borrower's interest
        _settleUserBorrowInterest(_borrower, _debtToken);
        _settleUserSupplyInterest(_borrower, _collateralToken);

        // Check if borrower is liquidatable
        require(!_isHealthyForLiquidation(_borrower), "Account is healthy");

        UserAccount storage borrowerAccount = userAccounts[_borrower];
        Market storage debtMarket = markets[_debtToken];
        Market storage collateralMarket = markets[_collateralToken];

        // Can only repay up to 50% of the debt in one liquidation
        uint256 maxRepay = borrowerAccount.borrowed[_debtToken] / 2;
        uint256 actualRepay = _debtRepayAmount > maxRepay ? maxRepay : _debtRepayAmount;
        require(actualRepay > 0, "Zero repay amount");

        // Calculate collateral to seize
        uint256 debtPrice = getPrice(_debtToken);
        uint256 collateralPrice = getPrice(_collateralToken);
        
        // collateralSeized = debtRepaid * debtPrice / collateralPrice * (1 + liquidationBonus)
        uint256 collateralSeized = (actualRepay * debtPrice * (BPS_DENOMINATOR + collateralMarket.liquidationBonusBps)) 
            / (collateralPrice * BPS_DENOMINATOR);

        require(collateralSeized <= borrowerAccount.deposited[_collateralToken], "Insufficient collateral to seize");

        // Transfer debt from liquidator
        IERC20(_debtToken).safeTransferFrom(msg.sender, address(this), actualRepay);

        // Update borrower's debt
        borrowerAccount.borrowed[_debtToken] -= actualRepay;
        debtMarket.totalBorrowed -= actualRepay;

        // Seize collateral from borrower and give to liquidator
        borrowerAccount.deposited[_collateralToken] -= collateralSeized;
        collateralMarket.totalDeposited -= collateralSeized;

        IERC20(_collateralToken).safeTransfer(msg.sender, collateralSeized);

        emit Liquidation(msg.sender, _borrower, _debtToken, _collateralToken, actualRepay, collateralSeized);
    }

    // --- Internal Helper Functions ---

    function _settleUserBorrowInterest(address _user, address _token) internal {
        UserAccount storage account = userAccounts[_user];
        Market storage market = markets[_token];

        if (account.borrowed[_token] > 0 && account.borrowIndex[_token] > 0) {
            uint256 indexRatio = (market.borrowIndex * PRICE_PRECISION) / account.borrowIndex[_token];
            account.borrowed[_token] = (account.borrowed[_token] * indexRatio) / PRICE_PRECISION;
        }
        account.borrowIndex[_token] = market.borrowIndex;
    }

    function _settleUserSupplyInterest(address _user, address _token) internal {
        UserAccount storage account = userAccounts[_user];
        Market storage market = markets[_token];

        if (account.deposited[_token] > 0 && account.supplyIndex[_token] > 0) {
            uint256 indexDiff = market.supplyIndex - account.supplyIndex[_token];
            uint256 accruedInterest = (account.deposited[_token] * indexDiff) / PRICE_PRECISION;
            account.deposited[_token] += accruedInterest;
        }
        account.supplyIndex[_token] = market.supplyIndex;
    }

    function _isHealthy(address _user) internal view returns (bool) {
        (uint256 totalCollateralValue, uint256 totalBorrowValue) = _getAccountValues(_user, false);
        return totalCollateralValue >= totalBorrowValue;
    }

    function _isHealthyForLiquidation(address _user) internal view returns (bool) {
        (uint256 totalCollateralValue, uint256 totalBorrowValue) = _getAccountValues(_user, true);
        return totalCollateralValue >= totalBorrowValue;
    }

    function _getAccountValues(address _user, bool useLiquidationThreshold) 
        internal view returns (uint256 totalCollateralValue, uint256 totalBorrowValue) 
    {
        UserAccount storage account = userAccounts[_user];

        for (uint256 i = 0; i < listedTokens.length; i++) {
            address token = listedTokens[i];
            Market storage market = markets[token];

            if (account.deposited[token] > 0) {
                uint256 price = getPrice(token);
                uint256 depositValue = (account.deposited[token] * price) / PRICE_PRECISION;
                
                uint256 factorBps = useLiquidationThreshold 
                    ? market.liquidationThresholdBps 
                    : market.collateralFactorBps;
                
                totalCollateralValue += (depositValue * factorBps) / BPS_DENOMINATOR;
            }

            if (account.borrowed[token] > 0) {
                uint256 price = getPrice(token);
                
                // Account for accrued interest in view
                uint256 currentBorrowed = account.borrowed[token];
                if (account.borrowIndex[token] > 0 && market.borrowIndex > account.borrowIndex[token]) {
                    uint256 indexRatio = (market.borrowIndex * PRICE_PRECISION) / account.borrowIndex[token];
                    currentBorrowed = (currentBorrowed * indexRatio) / PRICE_PRECISION;
                }
                
                totalBorrowValue += (currentBorrowed * price) / PRICE_PRECISION;
            }
        }
    }

    // --- View Functions ---

    function getAccountHealth(address _user) external view returns (
        uint256 totalCollateralValue,
        uint256 totalBorrowValue,
        uint256 healthFactor
    ) {
        (totalCollateralValue, totalBorrowValue) = _getAccountValues(_user, true);
        
        if (totalBorrowValue == 0) {
            healthFactor = type(uint256).max;
        } else {
            healthFactor = (totalCollateralValue * PRICE_PRECISION) / totalBorrowValue;
        }
    }

    function getUserDeposit(address _user, address _token) external view returns (uint256) {
        UserAccount storage account = userAccounts[_user];
        Market storage market = markets[_token];

        uint256 deposited = account.deposited[_token];
        if (deposited > 0 && account.supplyIndex[_token] > 0) {
            uint256 indexDiff = market.supplyIndex - account.supplyIndex[_token];
            deposited += (deposited * indexDiff) / PRICE_PRECISION;
        }
        return deposited;
    }

    function getUserBorrow(address _user, address _token) external view returns (uint256) {
        UserAccount storage account = userAccounts[_user];
        Market storage market = markets[_token];

        uint256 borrowed = account.borrowed[_token];
        if (borrowed > 0 && account.borrowIndex[_token] > 0) {
            uint256 indexRatio = (market.borrowIndex * PRICE_PRECISION) / account.borrowIndex[_token];
            borrowed = (borrowed * indexRatio) / PRICE_PRECISION;
        }
        return borrowed;
    }

    function getAvailableLiquidity(address _token) external view returns (uint256) {
        Market storage market = markets[_token];
        if (market.totalDeposited <= market.totalBorrowed) return 0;
        return market.totalDeposited - market.totalBorrowed;
    }

    function getMaxBorrowable(address _user, address _borrowToken) external view returns (uint256) {
        (uint256 totalCollateralValue, uint256 totalBorrowValue) = _getAccountValues(_user, false);
        
        if (totalCollateralValue <= totalBorrowValue) return 0;
        
        uint256 remainingBorrowValue = totalCollateralValue - totalBorrowValue;
        uint256 borrowTokenPrice = getPrice(_borrowToken);
        
        if (borrowTokenPrice == 0) return 0;
        
        uint256 maxBorrowAmount = (remainingBorrowValue * PRICE_PRECISION) / borrowTokenPrice;
        
        // Also limited by available liquidity
        Market storage market = markets[_borrowToken];
        uint256 availableLiquidity = market.totalDeposited > market.totalBorrowed 
            ? market.totalDeposited - market.totalBorrowed 
            : 0;
        
        return maxBorrowAmount < availableLiquidity ? maxBorrowAmount : availableLiquidity;
    }

    function getListedTokensCount() external view returns (uint256) {
        return listedTokens.length;
    }

    function isLiquidatable(address _user) external view returns (bool) {
        return !_isHealthyForLiquidation(_user);
    }
}