pragma solidity ^0.8.0;

interface IDex {
    function getPoolRatio(address tokenA, address tokenB) external view returns (uint256);
}

contract DeFiLending {
    struct Loan {
        address borrower;
        uint256 amount;
        uint256 collateral;
        uint256 borrowTime;
        bool isActive;
    }

    mapping(address => Loan) public loans;
    mapping(address => uint256) public collateralBalances;
    IDex public dex;

    uint256 public constant COLLATERALIZATION_RATIO = 150; // 150%
    uint256 public constant LIQUIDATION_THRESHOLD = 120; // 120%

    constructor(address _dex) {
        dex = IDex(_dex);
    }

    function lend(address asset, uint256 amount) external {
        require(amount > 0, "Amount must be greater than 0");
        IERC20(asset).transferFrom(msg.sender, address(this), amount);
    }

    function borrow(address asset, uint256 amount, address collateralAsset) external {
        require(loans[msg.sender].isActive == false, "Existing loan must be paid off");
        
        uint256 collateralValue = collateralBalances[msg.sender];
        uint256 requiredCollateral = (amount * COLLATERALIZATION_RATIO) / 100;

        require(collateralValue >= requiredCollateral, "Insufficient collateral");

        uint256 assetPrice = dex.getPoolRatio(asset, collateralAsset);
        require(assetPrice > 0, "Invalid asset price");

        loans[msg.sender] = Loan({
            borrower: msg.sender,
            amount: amount,
            collateral: collateralValue,
            borrowTime: block.timestamp,
            isActive: true
        });

        IERC20(asset).transfer(msg.sender, amount);
    }

    function repay(address asset) external {
        require(loans[msg.sender].isActive, "No active loan");
        
        uint256 amountToRepay = loans[msg.sender].amount;
        IERC20(asset).transferFrom(msg.sender, address(this), amountToRepay);

        loans[msg.sender].isActive = false;
    }

    function liquidate(address borrower) external {
        Loan storage loan = loans[borrower];
        require(loan.isActive, "No active loan");

        uint256 assetPrice = dex.getPoolRatio(address(this), borrower); // Assume this returns value in collateralAsset
        uint256 currentCollateralValue = loan.collateral * assetPrice;

        uint256 requiredCollateral = (loan.amount * LIQUIDATION_THRESHOLD) / 100;

        require(currentCollateralValue < requiredCollateral, "Loan is safe from liquidation");

        loan.isActive = false;
        IERC20(address(this)).transfer(msg.sender, loan.amount); // Transfer collateral to the liquidator
    }

    function depositCollateral(address asset, uint256 amount) external {
        require(amount > 0, "Amount must be greater than 0");
        IERC20(asset).transferFrom(msg.sender, address(this), amount);
        collateralBalances[msg.sender] += amount;
    }

    function withdrawCollateral(address asset, uint256 amount) external {
        require(collateralBalances[msg.sender] >= amount, "Insufficient collateral balance");
        require(loans[msg.sender].isActive == false, "Active loan exists");

        collateralBalances[msg.sender] -= amount;
        IERC20(asset).transfer(msg.sender, amount);
    }

    function getLoanInfo(address borrower) external view returns (Loan memory) {
        return loans[borrower];
    }
}