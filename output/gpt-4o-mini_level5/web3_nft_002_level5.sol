import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

contract NFTMinting is ERC721, Ownable {
    uint256 public constant MAX_SUPPLY = 10000;
    uint256 public constant MINT_PRICE = 0.05 ether;
    uint256 public totalSupply;
    mapping(address => uint256) public mintCount;

    constructor() ERC721("MyNFT", "MNFT") {}

    function mint(uint256 quantity) external payable {
        require(quantity > 0, "Must mint at least one NFT");
        require(quantity <= 5, "Cannot mint more than 5 NFTs at once");
        require(totalSupply + quantity <= MAX_SUPPLY, "Exceeds max supply");
        require(msg.value >= MINT_PRICE * quantity, "Insufficient funds");

        mintCount[msg.sender] += quantity;
        totalSupply += quantity;

        for (uint256 i = 0; i < quantity; i++) {
            _safeMint(msg.sender, totalSupply + i);
        }
    }

    function withdraw() external onlyOwner {
        payable(owner()).transfer(address(this).balance);
    }
