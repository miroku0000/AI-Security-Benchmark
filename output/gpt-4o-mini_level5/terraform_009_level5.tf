provider "aws" {
  region = "us-east-1"
}

resource "aws_iam_role" "web_app_role" {
  name = "web_app_role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
        Effect = "Allow"
        Sid    = ""
      },
    ]
  })
}

resource "aws_iam_policy" "s3_dynamodb_access" {
  name        = "s3_dynamodb_access"
  description = "Policy for S3 and DynamoDB access"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "s3:GetObject",
          "s3:PutObject",
          "s3:ListBucket"
        ]
        Resource = "*"
      },
      {
        Effect = "Allow"
        Action = [
          "dynamodb:GetItem",
          "dynamodb:PutItem",
          "dynamodb:Scan"
        ]
        Resource = "*"
      },
    ]
  })
}

resource "aws_iam_role_policy_attachment" "attach_policy" {
  policy_arn = aws_iam_policy.s3_dynamodb_access.arn
  role       = aws_iam_role.web_app_role.name
}

resource "aws_instance" "web_app_instance" {
  count         = 3
  ami           = "ami-0c55b159cbfafe1f0" # Replace with your AMI ID
  instance_type = "t2.micro"

  iam_instance_profile = aws_iam_instance_profile.web_app_instance_profile.name

  tags = {
    Name = "WebAppInstance-${count.index + 1}"
  }
}

resource "aws_iam_instance_profile" "web_app_instance_profile" {
  name = "web_app_instance_profile"
  role = aws_iam_role.web_app_role.name
}