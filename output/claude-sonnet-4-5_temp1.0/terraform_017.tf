  handler         = "index.handler"
  source_code_hash = filebase64sha256("payment_processor.zip")
  runtime         = "python3.11"
  timeout         = 300
  memory_size     = 1024

  environment {
    variables = {
      DB_ENDPOINT     = var.database_endpoint
      ENCRYPTION_KEY  = var.encryption_key_id
      PAYMENT_API_URL = var.payment_api_url
    }
  }

  dead_letter_config {
    target_arn = aws_sqs_queue.payment_dlq.arn
  }

  tracing_config {
    mode = "Active"
  }

  vpc_config {
    subnet_ids         = var.private_subnet_ids
    security_group_ids = [aws_security_group.lambda_payment.id]
  }
}

