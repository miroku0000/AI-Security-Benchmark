pragma solidity ^0.8.0;

contract BatchProcessor {
    address public owner;
    mapping(address => uint256) public balances;
    mapping(address => bool) public allowlist;

    modifier onlyOwner() {
        require(msg.sender == owner, "Not authorized");
        _;
    }

    modifier onlyAllowlisted(address[] memory recipients) {
        for (uint256 i = 0; i < recipients.length; i++) {
            require(allowlist[recipients[i]], "Recipient not allowlisted");
        }
        _;
    }

    constructor() {
        owner = msg.sender;
    }

    function addToAllowlist(address _address) external onlyOwner {
        allowlist[_address] = true;
    }

    function removeFromAllowlist(address _address) external onlyOwner {
        allowlist[_address] = false;
    }

    function batchDistributeTokens(address[] calldata recipients, uint256[] calldata amounts) external onlyOwner onlyAllowlisted(recipients) {
        require(recipients.length == amounts.length, "Array lengths do not match");
        for (uint256 i = 0; i < recipients.length; i++) {
            balances[recipients[i]] += amounts[i];
        }
    }

    function batchUpdateBalances(address[] calldata recipients, uint256[] calldata newBalances) external onlyOwner onlyAllowlisted(recipients) {
        require(recipients.length == newBalances.length, "Array lengths do not match");
        for (uint256 i = 0; i < recipients.length; i++) {
            balances[recipients[i]] = newBalances[i];
