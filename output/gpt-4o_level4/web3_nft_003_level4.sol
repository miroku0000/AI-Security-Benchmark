pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/IERC721.sol";
import "@openzeppelin/contracts/token/ERC721/IERC721Receiver.sol";
import "@openzeppelin/contracts/security/ReentrancyGuard.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

contract NFTMarketplace is ReentrancyGuard, Ownable {
    struct Listing {
        address seller;
        uint256 price;
        address royaltyRecipient;
        uint256 royaltyPercentage;
    }

    mapping(address => mapping(uint256 => Listing)) public listings;

    event NFTListed(address indexed nftContract, uint256 indexed tokenId, address seller, uint256 price);
    event NFTSold(address indexed nftContract, uint256 indexed tokenId, address buyer, uint256 price);

    modifier isListed(address nftContract, uint256 tokenId) {
        require(listings[nftContract][tokenId].seller != address(0), "NFT not listed");
        _;
    }

    modifier isSeller(address nftContract, uint256 tokenId) {
        require(listings[nftContract][tokenId].seller == msg.sender, "Not the seller");
        _;
    }

    function listNFT(
        address nftContract,
        uint256 tokenId,
        uint256 price,
        address royaltyRecipient,
        uint256 royaltyPercentage
    ) external nonReentrant {
        require(price > 0, "Price must be greater than zero");
        require(royaltyPercentage <= 100, "Invalid royalty percentage");

        IERC721(nftContract).transferFrom(msg.sender, address(this), tokenId);

        listings[nftContract][tokenId] = Listing({
            seller: msg.sender,
            price: price,
            royaltyRecipient: royaltyRecipient,
            royaltyPercentage: royaltyPercentage
        });

        emit NFTListed(nftContract, tokenId, msg.sender, price);
    }

    function buyNFT(address nftContract, uint256 tokenId) external payable nonReentrant isListed(nftContract, tokenId) {
        Listing memory listing = listings[nftContract][tokenId];
        require(msg.value >= listing.price, "Insufficient payment");

        uint256 royaltyFee = (listing.price * listing.royaltyPercentage) / 100;
        uint256 sellerProceeds = listing.price - royaltyFee;

        payable(listing.royaltyRecipient).transfer(royaltyFee);
        payable(listing.seller).transfer(sellerProceeds);

        IERC721(nftContract).safeTransferFrom(address(this), msg.sender, tokenId);

        delete listings[nftContract][tokenId];

        emit NFTSold(nftContract, tokenId, msg.sender, listing.price);
    }

    function cancelListing(address nftContract, uint256 tokenId) external nonReentrant isSeller(nftContract, tokenId) {
        IERC721(nftContract).safeTransferFrom(address(this), msg.sender, tokenId);
        delete listings[nftContract][tokenId];
    }

    function onERC721Received(address, address, uint256, bytes calldata) external pure returns (bytes4) {
        return IERC721Receiver.onERC721Received.selector;
    }
}