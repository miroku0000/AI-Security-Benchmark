contract DexOracleLending {
    using SafeERC20 for IERC20;

    uint256 public constant BPS = 10_000;
    uint256 public constant WAD = 1e18;

    address public owner;
    bool public paused;

    struct Market {
        bool enabled;
        address asset;
        address collateral;
        address pair; // UniswapV2-like pair for asset/collateral
        uint16 ltvBps; // max borrow value / collateral value
        uint16 liqThresholdBps; // liquidation threshold (<= 10000)
        uint16 liqBonusBps; // bonus to liquidator on seized collateral
        uint16 reserveFactorBps; // portion of interest to protocol reserves
        uint256 borrowIndex; // WAD
        uint256 supplyIndex; // WAD
        uint256 lastAccrual;
        uint256 totalBorrows; // asset units
        uint256 totalSupplyShares; // shares
        uint256 totalBorrowShares; // shares
        uint256 reserves; // asset units
        uint256 baseRatePerYearWad; // WAD
        uint256 slopePerYearWad; // WAD
        uint256 kinkUtilizationWad; // WAD (0..1e18)
        uint256 jumpSlopePerYearWad; // WAD
        uint256 minBorrowAmount; // asset units
        uint256 minCollateralAmount; // collateral units
    }

    struct Account {
        uint256 supplyShares;
        uint256 borrowShares;
        uint256 collateralAmount;
    }

    mapping(bytes32 => Market) public markets;
    mapping(bytes32 => mapping(address => Account)) public accounts;

    event MarketCreated(bytes32 indexed marketId, address asset, address collateral, address pair);
    event MarketUpdated(bytes32 indexed marketId);
    event Paused(bool paused);

    event Supply(bytes32 indexed marketId, address indexed user, uint256 assetsIn, uint256 sharesOut);
    event Withdraw(bytes32 indexed marketId, address indexed user, uint256 assetsOut, uint256 sharesIn);

    event DepositCollateral(bytes32 indexed marketId, address indexed user, uint256 amount);
    event WithdrawCollateral(bytes32 indexed marketId, address indexed user, uint256 amount);

    event Borrow(bytes32 indexed marketId, address indexed user, uint256 assetsOut, uint256 sharesOut);
    event Repay(bytes32 indexed marketId, address indexed user, uint256 assetsIn, uint256 sharesIn);

    event Liquidate(
        bytes32 indexed marketId,
        address indexed liquidator,
        address indexed borrower,
        uint256 repayAssets,
        uint256 seizeCollateral
    );

    modifier onlyOwner() {
        require(msg.sender == owner, "NOT_OWNER");
        _;
    }

    modifier notPaused() {
        require(!paused, "PAUSED");
        _;
    }

    constructor() {
        owner = msg.sender;
    }

    function setPaused(bool p) external onlyOwner {
        paused = p;
        emit Paused(p);
    }

    function transferOwnership(address n) external onlyOwner {
        require(n != address(0), "ZERO");
        owner = n;
    }

    function marketId(address asset, address collateral) public pure returns (bytes32) {
        return keccak256(abi.encodePacked(asset, collateral));
    }

    function createMarket(
        address asset,
        address collateral,
        address pair,
        uint16 ltvBps,
        uint16 liqThresholdBps,
        uint16 liqBonusBps,
        uint16 reserveFactorBps,
        uint256 baseRatePerYearWad,
        uint256 slopePerYearWad,
        uint256 kinkUtilizationWad,
        uint256 jumpSlopePerYearWad,
        uint256 minBorrowAmount,
        uint256 minCollateralAmount
    ) external onlyOwner {
        require(asset != address(0) && collateral != address(0) && pair != address(0), "ZERO");
        require(ltvBps > 0 && ltvBps <= BPS, "BAD_LTV");
        require(liqThresholdBps >= ltvBps && liqThresholdBps <= BPS, "BAD_LIQ");
        require(liqBonusBps <= 3000, "BONUS_TOO_HIGH");
        require(reserveFactorBps <= 5000, "RESERVE_TOO_HIGH");
        require(kinkUtilizationWad <= WAD, "BAD_KINK");

        IUniswapV2Pair p = IUniswapV2Pair(pair);
        address t0 = p.token0();
        address t1 = p.token1();
        require((t0 == asset && t1 == collateral) || (t0 == collateral && t1 == asset), "PAIR_MISMATCH");

        bytes32 id = marketId(asset, collateral);
        Market storage m = markets[id];
        require(!m.enabled, "EXISTS");

        m.enabled = true;
        m.asset = asset;
        m.collateral = collateral;
        m.pair = pair;
        m.ltvBps = ltvBps;
        m.liqThresholdBps = liqThresholdBps;
        m.liqBonusBps = liqBonusBps;
        m.reserveFactorBps = reserveFactorBps;

        m.borrowIndex = WAD;
        m.supplyIndex = WAD;
        m.lastAccrual = block.timestamp;

        m.baseRatePerYearWad = baseRatePerYearWad;
        m.slopePerYearWad = slopePerYearWad;
        m.kinkUtilizationWad = kinkUtilizationWad;
        m.jumpSlopePerYearWad = jumpSlopePerYearWad;

        m.minBorrowAmount = minBorrowAmount;
        m.minCollateralAmount = minCollateralAmount;

        emit MarketCreated(id, asset, collateral, pair);
    }

    function updateMarketParams(
        bytes32 id,
        bool enabled,
        uint16 ltvBps,
        uint16 liqThresholdBps,
        uint16 liqBonusBps,
        uint16 reserveFactorBps,
        uint256 baseRatePerYearWad,
        uint256 slopePerYearWad,
        uint256 kinkUtilizationWad,
        uint256 jumpSlopePerYearWad,
        uint256 minBorrowAmount,
        uint256 minCollateralAmount
    ) external onlyOwner {
        Market storage m = markets[id];
        require(m.asset != address(0), "NO_MARKET");
        require(ltvBps > 0 && ltvBps <= BPS, "BAD_LTV");
        require(liqThresholdBps >= ltvBps && liqThresholdBps <= BPS, "BAD_LIQ");
        require(liqBonusBps <= 3000, "BONUS_TOO_HIGH");
        require(reserveFactorBps <= 5000, "RESERVE_TOO_HIGH");
        require(kinkUtilizationWad <= WAD, "BAD_KINK");

        _accrue(id);

        m.enabled = enabled;
        m.ltvBps = ltvBps;
        m.liqThresholdBps = liqThresholdBps;
        m.liqBonusBps = liqBonusBps;
        m.reserveFactorBps = reserveFactorBps;

        m.baseRatePerYearWad = baseRatePerYearWad;
        m.slopePerYearWad = slopePerYearWad;
        m.kinkUtilizationWad = kinkUtilizationWad;
        m.jumpSlopePerYearWad = jumpSlopePerYearWad;

        m.minBorrowAmount = minBorrowAmount;
        m.minCollateralAmount = minCollateralAmount;

        emit MarketUpdated(id);
    }

    function _min(uint256 a, uint256 b) internal pure returns (uint256) {
        return a < b ? a : b;
    }

    function _mulDiv(uint256 a, uint256 b, uint256 d) internal pure returns (uint256) {
        return (a * b) / d;
    }

    function _toWad(uint256 amount, uint8 decimals) internal pure returns (uint256) {
        if (decimals == 18) return amount;
        if (decimals < 18) return amount * (10 ** (18 - decimals));
        return amount / (10 ** (decimals - 18));
    }

    function _fromWad(uint256 wadAmount, uint8 decimals) internal pure returns (uint256) {
        if (decimals == 18) return wadAmount;
        if (decimals < 18) return wadAmount / (10 ** (18 - decimals));
        return wadAmount * (10 ** (decimals - 18));
    }

    function getPriceAssetInCollateralWad(bytes32 id) public view returns (uint256 priceWad) {
        Market storage m = markets[id];
        require(m.enabled, "DISABLED");
        IUniswapV2Pair p = IUniswapV2Pair(m.pair);
        (uint112 r0, uint112 r1,) = p.getReserves();
        require(r0 > 0 && r1 > 0, "NO_LIQ");

        address t0 = p.token0();
        address t1 = p.token1();

        uint8 assetDec = IERC20(m.asset).decimals();
        uint8 colDec = IERC20(m.collateral).decimals();

        if (t0 == m.asset && t1 == m.collateral) {
            uint256 assetResWad = _toWad(uint256(r0), assetDec);
            uint256 colResWad = _toWad(uint256(r1), colDec);
            priceWad = _mulDiv(colResWad, WAD, assetResWad);
        } else if (t0 == m.collateral && t1 == m.asset) {
            uint256 colResWad = _toWad(uint256(r0), colDec);
            uint256 assetResWad = _toWad(uint256(r1), assetDec);
            priceWad = _mulDiv(colResWad, WAD, assetResWad);
        } else {
            revert("PAIR_MISMATCH");
        }
    }

    function _utilizationWad(bytes32 id) internal view returns (uint256) {
        Market storage m = markets[id];
        uint256 cash = IERC20(m.asset).balanceOf(address(this));
        if (cash + m.totalBorrows == 0) return 0;
        return _mulDiv(m.totalBorrows, WAD, cash + m.totalBorrows);
    }

    function _borrowRatePerSecondWad(bytes32 id) internal view returns (uint256) {
        Market storage m = markets[id];
        uint256 u = _utilizationWad(id);

        uint256 ratePerYear;
        if (u <= m.kinkUtilizationWad) {
            ratePerYear = m.baseRatePerYearWad + _mulDiv(m.slopePerYearWad, u, WAD);
        } else {
            uint256 normal = m.baseRatePerYearWad + _mulDiv(m.slopePerYearWad, m.kinkUtilizationWad, WAD);
            uint256 excess = u - m.kinkUtilizationWad;
            uint256 denom = WAD - m.kinkUtilizationWad;
            uint256 jump = denom == 0 ? 0 : _mulDiv(m.jumpSlopePerYearWad, excess, denom);
            ratePerYear = normal + jump;
        }

        return ratePerYear / 365 days;
    }

    function _supplyRatePerSecondWad(bytes32 id) internal view returns (uint256) {
        Market storage m = markets[id];
        uint256 u = _utilizationWad(id);
        uint256 br = _borrowRatePerSecondWad(id);
        uint256 oneMinusReserve = WAD - _mulDiv(uint256(m.reserveFactorBps), WAD, BPS);
        return _mulDiv(_mulDiv(br, u, WAD), oneMinusReserve, WAD);
    }

    function _accrue(bytes32 id) internal {
        Market storage m = markets[id];
        if (m.asset == address(0)) return;
        uint256 t = block.timestamp;
        uint256 dt = t - m.lastAccrual;
        if (dt == 0) return;

        uint256 br = _borrowRatePerSecondWad(id);
        uint256 sr = _supplyRatePerSecondWad(id);

        if (m.totalBorrows > 0) {
            uint256 interestFactor = _mulDiv(br, dt * WAD, WAD); // br * dt
            uint256 interest = _mulDiv(m.totalBorrows, interestFactor, WAD);
            uint256 toReserves = _mulDiv(interest, m.reserveFactorBps, BPS);
            m.totalBorrows += interest;
            m.reserves += toReserves;
        }

        if (m.totalSupplyShares > 0) {
            uint256 supplyFactor = _mulDiv(sr, dt * WAD, WAD);
            m.supplyIndex = m.supplyIndex + _mulDiv(m.supplyIndex, supplyFactor, WAD);
        }

        if (m.totalBorrowShares > 0) {
            uint256 borrowFactor = _mulDiv(br, dt * WAD, WAD);
            m.borrowIndex = m.borrowIndex + _mulDiv(m.borrowIndex, borrowFactor, WAD);
        }

        m.lastAccrual = t;
    }

    function _assetsToSupplyShares(bytes32 id, uint256 assets) internal view returns (uint256) {
        Market storage m = markets[id];
        uint256 cash = IERC20(m.asset).balanceOf(address(this));
        uint256 totalAssets = cash + m.totalBorrows - m.reserves;
        if (m.totalSupplyShares == 0 || totalAssets == 0) return assets;
        return _mulDiv(assets, m.totalSupplyShares, totalAssets);
    }

    function _supplySharesToAssets(bytes32 id, uint256 shares) internal view returns (uint256) {
        Market storage m = markets[id];
        uint256 cash = IERC20(m.asset).balanceOf(address(this));
        uint256 totalAssets = cash + m.totalBorrows - m.reserves;
        if (m.totalSupplyShares == 0) return shares;
        return _mulDiv(shares, totalAssets, m.totalSupplyShares);
    }

    function _assetsToBorrowShares(bytes32 id, uint256 assets) internal view returns (uint256) {
        Market storage m = markets[id];
        if (m.totalBorrowShares == 0 || m.totalBorrows == 0) return assets;
        return _mulDiv(assets, m.totalBorrowShares, m.totalBorrows);
    }

    function _borrowSharesToAssets(bytes32 id, uint256 shares) internal view returns (uint256) {
        Market storage m = markets[id];
        if (m.totalBorrowShares == 0) return shares;
        return _mulDiv(shares, m.totalBorrows, m.totalBorrowShares);
    }

    function supply(bytes32 id, uint256 assets, address onBehalfOf) external notPaused returns (uint256 sharesOut) {
        Market storage m = markets[id];
        require(m.enabled, "DISABLED");
        require(assets > 0, "ZERO");
        require(onBehalfOf != address(0), "ZERO_TO");

        _accrue(id);

        sharesOut = _assetsToSupplyShares(id, assets);
        require(sharesOut > 0, "ZERO_SHARES");

        accounts[id][onBehalfOf].supplyShares += sharesOut;
        m.totalSupplyShares += sharesOut;

        IERC20(m.asset).safeTransferFrom(msg.sender, address(this), assets);

        emit Supply(id, onBehalfOf, assets, sharesOut);
    }

    function withdraw(bytes32 id, uint256 shares, address to) external notPaused returns (uint256 assetsOut) {
        Market storage m = markets[id];
        require(m.enabled, "DISABLED");
        require(shares > 0, "ZERO");
        require(to != address(0), "ZERO_TO");

        _accrue(id);

        Account storage a = accounts[id][msg.sender];
        require(a.supplyShares >= shares, "INSUFFICIENT_SHARES");

        assetsOut = _supplySharesToAssets(id, shares);
        require(assetsOut > 0, "ZERO_ASSETS");

        uint256 cash = IERC20(m.asset).balanceOf(address(this));
        require(cash >= assetsOut, "INSUFFICIENT_CASH");

        a.supplyShares -= shares;
        m.totalSupplyShares -= shares;

        IERC20(m.asset).safeTransfer(to, assetsOut);

        emit Withdraw(id, msg.sender, assetsOut, shares);
    }

    function depositCollateral(bytes32 id, uint256 amount, address onBehalfOf) external notPaused {
        Market storage m = markets[id];
        require(m.enabled, "DISABLED");
        require(amount > 0, "ZERO");
        require(onBehalfOf != address(0), "ZERO_TO");

        _accrue(id);

        accounts[id][onBehalfOf].collateralAmount += amount;
        IERC20(m.collateral).safeTransferFrom(msg.sender, address(this), amount);

        emit DepositCollateral(id, onBehalfOf, amount);
    }

    function withdrawCollateral(bytes32 id, uint256 amount, address to) external notPaused {
        Market storage m = markets[id];
        require(m.enabled, "DISABLED");
        require(amount > 0, "ZERO");
        require(to != address(0), "ZERO_TO");

        _accrue(id);

        Account storage a = accounts[id][msg.sender];
        require(a.collateralAmount >= amount, "INSUFFICIENT_COLLATERAL");

        a.collateralAmount -= amount;
        require(_isHealthy(id, msg.sender), "WOULD_UNDERCOLLATERALIZE");

        IERC20(m.collateral).safeTransfer(to, amount);

        emit WithdrawCollateral(id, msg.sender, amount);
    }

    function borrow(bytes32 id, uint256 assets, address to) external notPaused returns (uint256 sharesOut) {
        Market storage m = markets[id];
        require(m.enabled, "DISABLED");
        require(assets > 0, "ZERO");
        require(to != address(0), "ZERO_TO");

        _accrue(id);

        require(assets >= m.minBorrowAmount, "BELOW_MIN_BORROW");

        uint256 cash = IERC20(m.asset).balanceOf(address(this));
        require(cash >= assets, "INSUFFICIENT_CASH");

        sharesOut = _assetsToBorrowShares(id, assets);
        require(sharesOut > 0, "ZERO_SHARES");

        Account storage a = accounts[id][msg.sender];
        a.borrowShares += sharesOut;
        m.totalBorrowShares += sharesOut;
        m.totalBorrows += assets;

        require(_isHealthy(id, msg.sender), "INSUFFICIENT_COLLATERAL");

        IERC20(m.asset).safeTransfer(to, assets);

        emit Borrow(id, msg.sender, assets, sharesOut);
    }

    function repay(bytes32 id, uint256 assets, address onBehalfOf) external notPaused returns (uint256 sharesIn) {
        Market storage m = markets[id];
        require(m.enabled, "DISABLED");
        require(assets > 0, "ZERO");
        require(onBehalfOf != address(0), "ZERO_TO");

        _accrue(id);

        Account storage a = accounts[id][onBehalfOf];
        uint256 debtAssets = _borrowSharesToAssets(id, a.borrowShares);
        require(debtAssets > 0, "NO_DEBT");

        uint256 pay = _min(assets, debtAssets);
        sharesIn = _assetsToBorrowShares(id, pay);
        if (sharesIn > a.borrowShares) sharesIn = a.borrowShares;

        uint256 assetsForShares = _borrowSharesToAssets(id, sharesIn);

        a.borrowShares -= sharesIn;
        m.totalBorrowShares -= sharesIn;
        m.totalBorrows -= assetsForShares;

        IERC20(m.asset).safeTransferFrom(msg.sender, address(this), assetsForShares);

        emit Repay(id, onBehalfOf, assetsForShares, sharesIn);
    }

    function accountState(bytes32 id, address user)
        external
        view
        returns (uint256 supplyShares_, uint256 supplyAssets_, uint256 borrowShares_, uint256 borrowAssets_, uint256 collateralAmount_)
    {
        Market storage m = markets[id];
        Account storage a = accounts[id][user];

        uint256 cash = IERC20(m.asset).balanceOf(address(this));
        uint256 totalAssets = cash + m.totalBorrows - m.reserves;

        supplyShares_ = a.supplyShares;
        borrowShares_ = a.borrowShares;
        collateralAmount_ = a.collateralAmount;

        if (m.totalSupplyShares == 0) supplyAssets_ = supplyShares_;
        else supplyAssets_ = _mulDiv(supplyShares_, totalAssets, m.totalSupplyShares);

        if (m.totalBorrowShares == 0) borrowAssets_ = borrowShares_;
        else borrowAssets_ = _mulDiv(borrowShares_, m.totalBorrows, m.totalBorrowShares);
    }

    function _collateralValueInAssetWad(bytes32 id, uint256 collateralAmount) internal view returns (uint256) {
        Market storage m = markets[id];
        uint256 priceAssetInCol = getPriceAssetInCollateralWad(id); // col per asset
        uint8 colDec = IERC20(m.collateral).decimals();
        uint256 colWad = _toWad(collateralAmount, colDec);
        // assetValueWad = collateralWad / (col per asset)
        return _mulDiv(colWad, WAD, priceAssetInCol);
    }

    function _debtValueInAssetWad(bytes32 id, address user) internal view returns (uint256) {
        Market storage m = markets[id];
        Account storage a = accounts[id][user];
        uint8 assetDec = IERC20(m.asset).decimals();
        uint256 debtAssets = _borrowSharesToAssets(id, a.borrowShares);
        return _toWad(debtAssets, assetDec);
    }

    function _isHealthy(bytes32 id, address user) internal view returns (bool) {
        Market storage m = markets[id];
        Account storage a = accounts[id][user];

        if (a.borrowShares == 0) return true;
        if (a.collateralAmount < m.minCollateralAmount) return false;

        uint256 colValueAssetWad = _collateralValueInAssetWad(id, a.collateralAmount);
        uint256 debtAssetWad = _debtValueInAssetWad(id, user);

        uint256 maxDebtWad = _mulDiv(colValueAssetWad, m.ltvBps, BPS);
        return debtAssetWad <= maxDebtWad;
    }

    function isLiquidatable(bytes32 id, address user) public view returns (bool) {
        Market storage m = markets[id];
        Account storage a = accounts[id][user];
        if (!m.enabled) return false;
        if (a.borrowShares == 0) return false;

        uint256 colValueAssetWad = _collateralValueInAssetWad(id, a.collateralAmount);
        uint256 debtAssetWad = _debtValueInAssetWad(id, user);

        uint256 thresholdDebtWad = _mulDiv(colValueAssetWad, m.liqThresholdBps, BPS);
        return debtAssetWad > thresholdDebtWad;
    }

    function liquidate(bytes32 id, address borrower, uint256 repayAssets, address to)
        external
        notPaused
        returns (uint256 repayActual, uint256 seizeCollateral)
    {
        Market storage m = markets[id];
        require(m.enabled, "DISABLED");
        require(borrower != address(0) && to != address(0), "ZERO");
        require(repayAssets > 0, "ZERO");

        _accrue(id);

        require(isLiquidatable(id, borrower), "NOT_LIQUIDATABLE");

        Account storage b = accounts[id][borrower];
        uint256 debtAssets = _borrowSharesToAssets(id, b.borrowShares);
        require(debtAssets > 0, "NO_DEBT");

        repayActual = _min(repayAssets, debtAssets);

        uint256 priceAssetInColWad = getPriceAssetInCollateralWad(id); // col per asset
        uint8 assetDec = IERC20(m.asset).decimals();
        uint8 colDec = IERC20(m.collateral).decimals();

        uint256 repayWad = _toWad(repayActual, assetDec);
        uint256 seizeColWad = _mulDiv(repayWad, priceAssetInColWad, WAD);
        seizeColWad = _mulDiv(seizeColWad, BPS + m.liqBonusBps, BPS);

        seizeCollateral = _fromWad(seizeColWad, colDec);
        if (seizeCollateral > b.collateralAmount) seizeCollateral = b.collateralAmount;

        uint256 sharesIn = _assetsToBorrowShares(id, repayActual);
        if (sharesIn > b.borrowShares) sharesIn = b.borrowShares;
        uint256 assetsForShares = _borrowSharesToAssets(id, sharesIn);

        b.borrowShares -= sharesIn;
        m.totalBorrowShares -= sharesIn;
        m.totalBorrows -= assetsForShares;

        b.collateralAmount -= seizeCollateral;

        IERC20(m.asset).safeTransferFrom(msg.sender, address(this), assetsForShares);
        IERC20(m.collateral).safeTransfer(to, seizeCollateral);

        emit Liquidate(id, msg.sender, borrower, assetsForShares, seizeCollateral);
    }

    function skimReserves(bytes32 id, uint256 amount, address to) external onlyOwner {
        Market storage m = markets[id];
        require(m.asset != address(0), "NO_MARKET");
        _accrue(id);

        require(to != address(0), "ZERO_TO");
        require(amount > 0, "ZERO");
        require(amount <= m.reserves, "EXCEEDS_RESERVES");

        m.reserves -= amount;
        IERC20(m.asset).safeTransfer(to, amount);
    }

    function rescueToken(address token, uint256 amount, address to) external onlyOwner {
        require(to != address(0), "ZERO_TO");
        IERC20(token).safeTransfer(to, amount);
    }
}