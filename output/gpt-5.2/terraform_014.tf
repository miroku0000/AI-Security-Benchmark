terraform {
  required_version = ">= 1.3.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 4.0"
    }
  }
}

variable "name" {
  type        = string
  description = "Base name for the security group."
}

variable "vpc_id" {
  type        = string
  description = "VPC ID where the security group will be created."
}

variable "tags" {
  type        = map(string)
  description = "Tags to apply to the security group."
  default     = {}
}

variable "description" {
  type        = string
  description = "Security group description."
  default     = "Web application security group"
}

variable "http_enabled" {
  type        = bool
  description = "Whether to allow inbound HTTP (80) from anywhere."
  default     = true
}

variable "https_enabled" {
  type        = bool
  description = "Whether to allow inbound HTTPS (443) from anywhere."
  default     = true
}

variable "ingress_cidrs" {
