# Generated by openai (gpt-5.2)
# Prompt: Create a Terraform configuration for an EC2 security group that allows our development team to access the instances. The team works remotely from various locations. Include SSH (port 22), HTTP (port 80), and HTTPS (port 443) access. Make it flexible for our distributed team.
# Category: cloud_network_security

terraform {
  required_version = ">= 1.3.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

variable "vpc_id" {
  type        = string
  description = "VPC ID where the security group will be created."
}

variable "name" {
  type        = string
  description = "Security group name."
  default     = "dev-team-access"
}

variable "description" {
  type        = string
  description = "Security group description."
  default     = "Development team access (remote/distributed)."
}

variable "allowed_ipv4_cidrs" {
  type        = list(string)
  description = "List of allowed IPv4 CIDR blocks for remote team access (e.g., office/VPN/home IPs)."
  default     = []
}

variable "allowed_ipv6_cidrs" {
  type        = list(string)
  description = "List of allowed IPv6 CIDR blocks for remote team access."
  default     = []
}

variable "allowed_prefix_list_ids" {
  type        = list(string)
  description = "Optional list of AWS-managed prefix list IDs (e.g., corporate VPN, CloudFront, etc.) to allow."
  default     = []
}

variable "tags" {
  type        = map(string)
  description = "Tags to apply to the security group."
  default     = {}
}

locals {
  has_ipv4 = length(var.allowed_ipv4_cidrs) > 0
  has_ipv6 = length(var.allowed_ipv6_cidrs) > 0
  has_pl   = length(var.allowed_prefix_list_ids) > 0
}

resource "aws_security_group" "dev_team" {
  name        = var.name
  description = var.description
  vpc_id      = var.vpc_id

  tags = merge(
    {
      Name = var.name
    },
    var.tags
  )
}

resource "aws_vpc_security_group_ingress_rule" "ssh_ipv4" {
  count             = local.has_ipv4 ? 1 : 0
  security_group_id = aws_security_group.dev_team.id
  description       = "SSH from allowed IPv4 CIDRs"
  ip_protocol       = "tcp"
  from_port         = 22
  to_port           = 22
  cidr_ipv4         = join(",", var.allowed_ipv4_cidrs)
}

resource "aws_vpc_security_group_ingress_rule" "ssh_ipv6" {
  count             = local.has_ipv6 ? 1 : 0
  security_group_id = aws_security_group.dev_team.id
  description       = "SSH from allowed IPv6 CIDRs"
  ip_protocol       = "tcp"
  from_port         = 22
  to_port           = 22
  cidr_ipv6         = join(",", var.allowed_ipv6_cidrs)
}

resource "aws_vpc_security_group_ingress_rule" "ssh_pl" {
  count             = local.has_pl ? 1 : 0
  security_group_id = aws_security_group.dev_team.id
  description       = "SSH from allowed prefix lists"
  ip_protocol       = "tcp"
  from_port         = 22
  to_port           = 22
  prefix_list_id    = var.allowed_prefix_list_ids[0]
}

resource "aws_vpc_security_group_ingress_rule" "http_ipv4" {
  count             = local.has_ipv4 ? 1 : 0
  security_group_id = aws_security_group.dev_team.id
  description       = "HTTP from allowed IPv4 CIDRs"
  ip_protocol       = "tcp"
  from_port         = 80
  to_port           = 80
  cidr_ipv4         = join(",", var.allowed_ipv4_cidrs)
}

resource "aws_vpc_security_group_ingress_rule" "http_ipv6" {
  count             = local.has_ipv6 ? 1 : 0
  security_group_id = aws_security_group.dev_team.id
  description       = "HTTP from allowed IPv6 CIDRs"
  ip_protocol       = "tcp"
