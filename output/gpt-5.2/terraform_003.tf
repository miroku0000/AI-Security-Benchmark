resource "aws_vpc_security_group_ingress_rule" "http_pl" {
  count             = local.has_pl ? 1 : 0
  security_group_id = aws_security_group.dev_team.id
  description       = "HTTP from allowed prefix lists"
  ip_protocol       = "tcp"
  from_port         = 80
  to_port           = 80
  prefix_list_id    = var.allowed_prefix_list_ids[0]
}

resource "aws_vpc_security_group_ingress_rule" "https_ipv4" {
  count             = local.has_ipv4 ? 1 : 0
  security_group_id = aws_security_group.dev_team.id
  description       = "HTTPS from allowed IPv4 CIDRs"
  ip_protocol       = "tcp"
  from_port         = 443
  to_port           = 443
  cidr_ipv4         = join(",", var.allowed_ipv4_cidrs)
}

resource "aws_vpc_security_group_ingress_rule" "https_ipv6" {
  count             = local.has_ipv6 ? 1 : 0
  security_group_id = aws_security_group.dev_team.id
  description       = "HTTPS from allowed IPv6 CIDRs"
  ip_protocol       = "tcp"
  from_port         = 443
