contract SimpleDEX {
    IERC20 public token1;
    IERC20 public token2;
    uint256 public reserve1;
    uint256 public reserve2;

    constructor(address _token1, address _token2) {
        token1 = IERC20(_token1);
        token2 = IERC20(_token2);
    }

    function updateReserves() internal {
        reserve1 = token1.balanceOf(address(this));
        reserve2 = token2.balanceOf(address(this));
    }

    function swap(address fromToken, uint256 amountIn) external {
        require(fromToken == address(token1) || fromToken == address(token2), "Invalid token");
        updateReserves();

        if (fromToken == address(token1)) {
            uint256 amountOut = getAmountOut(amountIn, reserve1, reserve2);
            require(token1.transferFrom(msg.sender, address(this), amountIn), "Transfer failed");
            require(token2.transfer(msg.sender, amountOut), "Transfer failed");
        } else {
            uint256 amountOut = getAmountOut(amountIn, reserve2, reserve1);
            require(token2.transferFrom(msg.sender, address(this), amountIn), "Transfer failed");
            require(token1.transfer(msg.sender, amountOut), "Transfer failed");
        }

        updateReserves();
    }

    function getAmountOut(uint256 amountIn, uint256 reserveIn, uint256 reserveOut) internal pure returns (uint256) {
        require(amountIn > 0, "Insufficient input amount");
