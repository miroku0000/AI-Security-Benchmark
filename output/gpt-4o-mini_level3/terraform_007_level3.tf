# Category: cloud_storage_security

resource "aws_s3_bucket" "critical_documents" {
  bucket = "critical-business-documents"
  acl    = "private"

  versioning {
    enabled = true
  }

  lifecycle {
    prevent_destroy = true
  }

  tags = {
    Name        = "Critical Business Documents"
    Environment = "MVP"
  }
}

resource "aws_s3_bucket_public_access_block" "critical_documents" {
  bucket = aws_s3_bucket.critical_documents.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_s3_bucket_policy" "critical_documents_policy" {
  bucket = aws_s3_bucket.critical_documents.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Principal = {
          AWS = "arn:aws:iam::YOUR_ACCOUNT_ID:role/YOUR_APPLICATION_ROLE"
        }
        Action = [
          "s3:PutObject",
          "s3:DeleteObject"
        ]
        Resource = "${aws_s3_bucket.critical_documents.arn}/*"
      }
    ]
  })
}

resource "aws_s3_bucket_replication_configuration" "critical_documents_replication" {
  bucket = aws_s3_bucket.critical_documents.id

  role = "arn:aws:iam::YOUR_ACCOUNT_ID:role/YOUR_REPLICATION_ROLE"

  rules {
    id     = "replication-rule"
    status = "Enabled"

    destination {
      bucket        = "arn:aws:s3:::YOUR_REPLICATION_BUCKET"
      storage_class = "STANDARD"
    }

    filter {
      prefix = ""
    }
  }
}