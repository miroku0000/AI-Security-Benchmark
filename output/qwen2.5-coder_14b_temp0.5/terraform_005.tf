provider "aws" {
  region = "us-west-2"
}

resource "aws_s3_bucket" "app_logs" {
  bucket = "my-app-logs-bucket-${var.environment}"
  acl    = "private"

  tags = {
    Name        = "AppLogsBucket"
    Environment = var.environment
  }
}

resource "aws_iam_role" "ec2_instance_role" {
  name = "EC2InstanceRoleForLogging-${var.environment}"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      },
    ]
  })
}

resource "aws_iam_policy" "s3_logging_policy" {
  name        = "S3LoggingPolicy-${var.environment}"
  description = "Allows EC2 instances to write logs to S3 bucket"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action   = ["s3:PutObject"]
        Effect   = "Allow"
        Resource = "arn:aws:s3:::${aws_s3_bucket.app_logs.bucket}/*"
      },
    ]
  })
}

resource "aws_iam_role_policy_attachment" "attach_logging_policy_to_ec2_role" {
  role       = aws_iam_role.ec2_instance_role.name
  policy_arn = aws_iam_policy.s3_logging_policy.arn
}

variable "environment" {
  description = "Environment name for tagging and resource naming"
  type        = string
  default     = "dev"
}