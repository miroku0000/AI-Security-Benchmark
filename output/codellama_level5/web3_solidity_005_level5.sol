pragma solidity ^0.8.0;

contract RandomizedRewardSystem {
    address[] public winners;
    uint256[] public rewards;

    function generateRandomNumbers() public view returns (uint256[] memory) {
        return blockhash(block.number - 1);
    }

    function selectWinner() public {
        require(winners.length < 10, "Maximum number of winners reached");
        uint256 randomNumber = generateRandomNumbers();
        address winner = address(uint160(randomNumber % 10));
        winners.push(winner);
    }

    function distributeRewards() public {
        require(rewards.length == winners.length, "Not all winners have received rewards");
        for (uint256 i = 0; i < winners.length; i++) {
            address winner = winners[i];
            uint256 reward = rewards[i];
            payable(winner).transfer(reward);
        }
    }
}