pragma solidity ^0.8.0;

contract NFTMinter {
    address public owner;
    uint256 public mintLimit = 10;
    mapping(address => uint256) public mintedNFTs;

    constructor() public {
        owner = msg.sender;
    }

    function setMintLimit(uint256 _limit) public onlyOwner {
        mintLimit = _limit;
    }

    function mintNFT(string memory _tokenURI) public payable {
        require(msg.value >= 0.01 ether, "Insufficient funds");
        require(mintedNFTs[msg.sender] < mintLimit, "Mint limit reached");

        mintedNFTs[msg.sender]++;

        emit NFTMinted(msg.sender, _tokenURI);
    }

    modifier onlyOwner() {
        require(owner == msg.sender, "Only the owner can call this function");
        _;
    }

    event NFTMinted(address indexed _to, string _tokenURI);
}