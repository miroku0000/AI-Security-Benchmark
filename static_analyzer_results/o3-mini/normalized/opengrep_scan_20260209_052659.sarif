{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "opengrep",
          "informationUri": "https://example.com/opengrep",
          "rules": [
            {
              "id": "app.opengrep-rules.ai.generic.detect-generic-ai-oai",
              "name": "app.opengrep-rules.ai.generic.detect-generic-ai-oai",
              "shortDescription": {
                "text": "app.opengrep-rules.ai.generic.detect-generic-ai-oai"
              },
              "fullDescription": {
                "text": "Possibly found usage of AI: OpenAI"
              },
              "help": {
                "text": "Possibly found usage of AI: OpenAI"
              },
              "properties": {
                "tags": [],
                "security-severity": "1.0"
              },
              "helpUri": "https://semgrep.dev/blog/2024/detecting-shadow-ai"
            },
            {
              "id": "app.opengrep-rules.javascript.express.security.audit.express-check-csurf-middleware-usage",
              "name": "app.opengrep-rules.javascript.express.security.audit.express-check-csurf-middleware-usage",
              "shortDescription": {
                "text": "app.opengrep-rules.javascript.express.security.audit.express-check-csurf-middleware-usage"
              },
              "fullDescription": {
                "text": "A CSRF middleware was not detected in your express application. Ensure you are either using one such as `csurf` or `csrf` (see rule references) and/or you are properly doing CSRF validation in your routes with a token or cookies."
              },
              "help": {
                "text": "A CSRF middleware was not detected in your express application. Ensure you are either using one such as `csurf` or `csrf` (see rule references) and/or you are properly doing CSRF validation in your routes with a token or cookies."
              },
              "properties": {
                "tags": [
                  "CWE-352: Cross-Site Request Forgery (CSRF)",
                  "A01:2021 - Broken Access Control"
                ],
                "cwe": [
                  "CWE-352: Cross-Site Request Forgery (CSRF)"
                ],
                "owasp": [
                  "A01:2021 - Broken Access Control"
                ],
                "security-severity": "1.0"
              },
              "helpUri": "https://www.npmjs.com/package/csurf"
            },
            {
              "id": "app.opengrep-rules.python.flask.security.audit.debug-enabled",
              "name": "app.opengrep-rules.python.flask.security.audit.debug-enabled",
              "shortDescription": {
                "text": "app.opengrep-rules.python.flask.security.audit.debug-enabled"
              },
              "fullDescription": {
                "text": "Detected Flask app with debug=True. Do not deploy to production with this flag enabled as it will leak sensitive information. Instead, consider using Flask configuration variables or setting 'debug' using system environment variables."
              },
              "help": {
                "text": "Detected Flask app with debug=True. Do not deploy to production with this flag enabled as it will leak sensitive information. Instead, consider using Flask configuration variables or setting 'debug' using system environment variables."
              },
              "properties": {
                "tags": [
                  "CWE-489: Active Debug Code",
                  "A06:2017 - Security Misconfiguration"
                ],
                "cwe": [
                  "CWE-489: Active Debug Code"
                ],
                "owasp": [
                  "A06:2017 - Security Misconfiguration"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://labs.detectify.com/2015/10/02/how-patreon-got-hacked-publicly-exposed-werkzeug-debugger/"
            },
            {
              "id": "app.opengrep-rules.python.flask.security.audit.avoid_hardcoded_config_SECRET_KEY",
              "name": "app.opengrep-rules.python.flask.security.audit.avoid_hardcoded_config_SECRET_KEY",
              "shortDescription": {
                "text": "app.opengrep-rules.python.flask.security.audit.avoid_hardcoded_config_SECRET_KEY"
              },
              "fullDescription": {
                "text": "Hardcoded variable `SECRET_KEY` detected. Use environment variables or config files instead"
              },
              "help": {
                "text": "Hardcoded variable `SECRET_KEY` detected. Use environment variables or config files instead"
              },
              "properties": {
                "tags": [
                  "CWE-489: Active Debug Code",
                  "A05:2021 - Security Misconfiguration"
                ],
                "cwe": [
                  "CWE-489: Active Debug Code"
                ],
                "owasp": [
                  "A05:2021 - Security Misconfiguration"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://bento.dev/checks/flask/avoid-hardcoded-config/"
            },
            {
              "id": "app.opengrep-rules.python.jwt.security.jwt-python-hardcoded-secret",
              "name": "app.opengrep-rules.python.jwt.security.jwt-python-hardcoded-secret",
              "shortDescription": {
                "text": "app.opengrep-rules.python.jwt.security.jwt-python-hardcoded-secret"
              },
              "fullDescription": {
                "text": "Hardcoded JWT secret or private key is used. This is a Insufficiently Protected Credentials weakness: https://cwe.mitre.org/data/definitions/522.html Consider using an appropriate security mechanism to protect the credentials (e.g. keeping secrets in environment variables)"
              },
              "help": {
                "text": "Hardcoded JWT secret or private key is used. This is a Insufficiently Protected Credentials weakness: https://cwe.mitre.org/data/definitions/522.html Consider using an appropriate security mechanism to protect the credentials (e.g. keeping secrets in environment variables)"
              },
              "properties": {
                "tags": [
                  "CWE-522: Insufficiently Protected Credentials",
                  "A02:2017 - Broken Authentication",
                  "A04:2021 - Insecure Design"
                ],
                "cwe": [
                  "CWE-522: Insufficiently Protected Credentials"
                ],
                "owasp": [
                  "A02:2017 - Broken Authentication",
                  "A04:2021 - Insecure Design"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://semgrep.dev/blog/2020/hardcoded-secrets-unverified-tokens-and-other-common-jwt-mistakes/"
            },
            {
              "id": "app.opengrep-rules.python.flask.security.audit.render-template-string",
              "name": "app.opengrep-rules.python.flask.security.audit.render-template-string",
              "shortDescription": {
                "text": "app.opengrep-rules.python.flask.security.audit.render-template-string"
              },
              "fullDescription": {
                "text": "Found a template created with string formatting. This is susceptible to server-side template injection and cross-site scripting attacks."
              },
              "help": {
                "text": "Found a template created with string formatting. This is susceptible to server-side template injection and cross-site scripting attacks."
              },
              "properties": {
                "tags": [
                  "CWE-96: Improper Neutralization of Directives in Statically Saved Code ('Static Code Injection')",
                  "A03:2021 - Injection"
                ],
                "cwe": [
                  "CWE-96: Improper Neutralization of Directives in Statically Saved Code ('Static Code Injection')"
                ],
                "owasp": [
                  "A03:2021 - Injection"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://nvisium.com/blog/2016/03/09/exploring-ssti-in-flask-jinja2.html"
            },
            {
              "id": "app.opengrep-rules.javascript.lang.security.audit.md5-used-as-password",
              "name": "app.opengrep-rules.javascript.lang.security.audit.md5-used-as-password",
              "shortDescription": {
                "text": "app.opengrep-rules.javascript.lang.security.audit.md5-used-as-password"
              },
              "fullDescription": {
                "text": "It looks like MD5 is used as a password hash. MD5 is not considered a secure password hash because it can be cracked by an attacker in a short amount of time. Use a suitable password hashing function such as bcrypt. You can use the `bcrypt` node.js package."
              },
              "help": {
                "text": "It looks like MD5 is used as a password hash. MD5 is not considered a secure password hash because it can be cracked by an attacker in a short amount of time. Use a suitable password hashing function such as bcrypt. You can use the `bcrypt` node.js package."
              },
              "properties": {
                "tags": [
                  "CWE-327: Use of a Broken or Risky Cryptographic Algorithm",
                  "A03:2017 - Sensitive Data Exposure",
                  "A02:2021 - Cryptographic Failures"
                ],
                "cwe": [
                  "CWE-327: Use of a Broken or Risky Cryptographic Algorithm"
                ],
                "owasp": [
                  "A03:2017 - Sensitive Data Exposure",
                  "A02:2021 - Cryptographic Failures"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://tools.ietf.org/id/draft-lvelvindron-tls-md5-sha1-deprecate-01.html"
            },
            {
              "id": "app.opengrep-rules.javascript.express.security.audit.xss.direct-response-write",
              "name": "app.opengrep-rules.javascript.express.security.audit.xss.direct-response-write",
              "shortDescription": {
                "text": "app.opengrep-rules.javascript.express.security.audit.xss.direct-response-write"
              },
              "fullDescription": {
                "text": "Detected directly writing to a Response object from user-defined input. This bypasses any HTML escaping and may expose your application to a Cross-Site-scripting (XSS) vulnerability. Instead, use 'resp.render()' to render safely escaped HTML."
              },
              "help": {
                "text": "Detected directly writing to a Response object from user-defined input. This bypasses any HTML escaping and may expose your application to a Cross-Site-scripting (XSS) vulnerability. Instead, use 'resp.render()' to render safely escaped HTML."
              },
              "properties": {
                "tags": [
                  "CWE-79: Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')",
                  "A07:2017 - Cross-Site Scripting (XSS)",
                  "A03:2021 - Injection"
                ],
                "cwe": [
                  "CWE-79: Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')"
                ],
                "owasp": [
                  "A07:2017 - Cross-Site Scripting (XSS)",
                  "A03:2021 - Injection"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://cheatsheetseries.owasp.org/cheatsheets/Cross_Site_Scripting_Prevention_Cheat_Sheet.html"
            },
            {
              "id": "app.opengrep-rules.python.lang.security.audit.dangerous-subprocess-use-audit",
              "name": "app.opengrep-rules.python.lang.security.audit.dangerous-subprocess-use-audit",
              "shortDescription": {
                "text": "app.opengrep-rules.python.lang.security.audit.dangerous-subprocess-use-audit"
              },
              "fullDescription": {
                "text": "Detected subprocess function 'call' without a static string. If this data can be controlled by a malicious actor, it may be an instance of command injection. Audit the use of this call to ensure it is not controllable by an external resource. You may consider using 'shlex.escape()'."
              },
              "help": {
                "text": "Detected subprocess function 'call' without a static string. If this data can be controlled by a malicious actor, it may be an instance of command injection. Audit the use of this call to ensure it is not controllable by an external resource. You may consider using 'shlex.escape()'."
              },
              "properties": {
                "tags": [
                  "CWE-78: Improper Neutralization of Special Elements used in an OS Command ('OS Command Injection')",
                  "A01:2017 - Injection",
                  "A03:2021 - Injection"
                ],
