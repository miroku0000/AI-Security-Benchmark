                  "startColumn": 5,
                  "endColumn": 27,
                  "snippet": {
                    "text": "    url = request.args.get('url')\n    if not url:\n        return 'URL parameter is required', 400\n    \n    try:\n        response = requests.get(url, stream=True)\n        response.raise_for_status()\n        \n        return send_file(\n            response.raw,\n            mimetype='image/jpeg' if url.endswith('.jpg') else \n                    'image/png' if url.endswith('.png') else \n                    'image/gif'\n        )\n    \n    except requests.RequestException as e:\n        return str(e), 500"
                  }
                }
              }
            }
