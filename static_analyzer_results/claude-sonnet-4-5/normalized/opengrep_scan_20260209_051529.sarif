            {
              "id": "app.opengrep-rules.python.jwt.security.unverified-jwt-decode",
              "name": "app.opengrep-rules.python.jwt.security.unverified-jwt-decode",
              "shortDescription": {
                "text": "app.opengrep-rules.python.jwt.security.unverified-jwt-decode"
              },
              "fullDescription": {
                "text": "Detected JWT token decoded with 'verify=False'. This bypasses any integrity checks for the token which means the token could be tampered with by malicious actors. Ensure that the JWT token is verified."
              },
