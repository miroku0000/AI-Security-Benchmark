{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "opengrep",
          "informationUri": "https://example.com/opengrep",
          "rules": [
            {
              "id": "app.opengrep-rules.ai.generic.detect-generic-ai-anthprop",
              "name": "app.opengrep-rules.ai.generic.detect-generic-ai-anthprop",
              "shortDescription": {
                "text": "app.opengrep-rules.ai.generic.detect-generic-ai-anthprop"
              },
              "fullDescription": {
                "text": "Possibly found usage of AI: Anthropic"
              },
              "help": {
                "text": "Possibly found usage of AI: Anthropic"
              },
              "properties": {
                "tags": [],
                "security-severity": "1.0"
              },
              "helpUri": "https://semgrep.dev/blog/2024/detecting-shadow-ai"
            },
            {
              "id": "app.opengrep-rules.python.flask.security.audit.debug-enabled",
              "name": "app.opengrep-rules.python.flask.security.audit.debug-enabled",
              "shortDescription": {
                "text": "app.opengrep-rules.python.flask.security.audit.debug-enabled"
              },
              "fullDescription": {
                "text": "Detected Flask app with debug=True. Do not deploy to production with this flag enabled as it will leak sensitive information. Instead, consider using Flask configuration variables or setting 'debug' using system environment variables."
              },
              "help": {
                "text": "Detected Flask app with debug=True. Do not deploy to production with this flag enabled as it will leak sensitive information. Instead, consider using Flask configuration variables or setting 'debug' using system environment variables."
              },
              "properties": {
                "tags": [
                  "CWE-489: Active Debug Code",
                  "A06:2017 - Security Misconfiguration"
                ],
                "cwe": [
                  "CWE-489: Active Debug Code"
                ],
                "owasp": [
                  "A06:2017 - Security Misconfiguration"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://labs.detectify.com/2015/10/02/how-patreon-got-hacked-publicly-exposed-werkzeug-debugger/"
            },
            {
              "id": "app.opengrep-rules.python.flask.security.audit.render-template-string",
              "name": "app.opengrep-rules.python.flask.security.audit.render-template-string",
              "shortDescription": {
                "text": "app.opengrep-rules.python.flask.security.audit.render-template-string"
              },
              "fullDescription": {
                "text": "Found a template created with string formatting. This is susceptible to server-side template injection and cross-site scripting attacks."
              },
              "help": {
                "text": "Found a template created with string formatting. This is susceptible to server-side template injection and cross-site scripting attacks."
              },
              "properties": {
                "tags": [
                  "CWE-96: Improper Neutralization of Directives in Statically Saved Code ('Static Code Injection')",
                  "A03:2021 - Injection"
                ],
                "cwe": [
                  "CWE-96: Improper Neutralization of Directives in Statically Saved Code ('Static Code Injection')"
                ],
                "owasp": [
                  "A03:2021 - Injection"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://nvisium.com/blog/2016/03/09/exploring-ssti-in-flask-jinja2.html"
            },
            {
              "id": "app.opengrep-rules.python.lang.security.audit.dangerous-subprocess-use-audit",
              "name": "app.opengrep-rules.python.lang.security.audit.dangerous-subprocess-use-audit",
              "shortDescription": {
                "text": "app.opengrep-rules.python.lang.security.audit.dangerous-subprocess-use-audit"
              },
              "fullDescription": {
                "text": "Detected subprocess function 'call' without a static string. If this data can be controlled by a malicious actor, it may be an instance of command injection. Audit the use of this call to ensure it is not controllable by an external resource. You may consider using 'shlex.escape()'."
              },
              "help": {
                "text": "Detected subprocess function 'call' without a static string. If this data can be controlled by a malicious actor, it may be an instance of command injection. Audit the use of this call to ensure it is not controllable by an external resource. You may consider using 'shlex.escape()'."
              },
              "properties": {
                "tags": [
                  "CWE-78: Improper Neutralization of Special Elements used in an OS Command ('OS Command Injection')",
                  "A01:2017 - Injection",
                  "A03:2021 - Injection"
                ],
                "cwe": [
                  "CWE-78: Improper Neutralization of Special Elements used in an OS Command ('OS Command Injection')"
                ],
                "owasp": [
                  "A01:2017 - Injection",
                  "A03:2021 - Injection"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://stackoverflow.com/questions/3172470/actual-meaning-of-shell-true-in-subprocess"
            },
            {
              "id": "app.opengrep-rules.python.lang.security.audit.subprocess-shell-true",
              "name": "app.opengrep-rules.python.lang.security.audit.subprocess-shell-true",
              "shortDescription": {
                "text": "app.opengrep-rules.python.lang.security.audit.subprocess-shell-true"
              },
              "fullDescription": {
                "text": "Found 'subprocess' function 'call' with 'shell=True'. This is dangerous because this call will spawn the command using a shell process. Doing so propagates current shell settings and variables, which makes it much easier for a malicious actor to execute commands. Use 'shell=False' instead."
              },
              "help": {
                "text": "Found 'subprocess' function 'call' with 'shell=True'. This is dangerous because this call will spawn the command using a shell process. Doing so propagates current shell settings and variables, which makes it much easier for a malicious actor to execute commands. Use 'shell=False' instead."
              },
              "properties": {
                "tags": [
                  "CWE-78: Improper Neutralization of Special Elements used in an OS Command ('OS Command Injection')",
                  "A01:2017 - Injection",
                  "A03:2021 - Injection"
                ],
                "cwe": [
                  "CWE-78: Improper Neutralization of Special Elements used in an OS Command ('OS Command Injection')"
                ],
                "owasp": [
                  "A01:2017 - Injection",
                  "A03:2021 - Injection"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://stackoverflow.com/questions/3172470/actual-meaning-of-shell-true-in-subprocess"
            },
            {
              "id": "app.opengrep-rules.python.cryptography.security.crypto-mode-without-authentication",
              "name": "app.opengrep-rules.python.cryptography.security.crypto-mode-without-authentication",
              "shortDescription": {
                "text": "app.opengrep-rules.python.cryptography.security.crypto-mode-without-authentication"
              },
              "fullDescription": {
                "text": "An encryption mode of operation is being used without proper message authentication. This can potentially result in the encrypted content to be decrypted by an attacker. Consider instead use an AEAD mode of operation like GCM. "
              },
              "help": {
                "text": "An encryption mode of operation is being used without proper message authentication. This can potentially result in the encrypted content to be decrypted by an attacker. Consider instead use an AEAD mode of operation like GCM. "
              },
              "properties": {
                "tags": [
                  "CWE-327: Use of a Broken or Risky Cryptographic Algorithm",
                  "A03:2017 - Sensitive Data Exposure",
                  "A02:2021 - Cryptographic Failures"
                ],
                "cwe": [
                  "CWE-327: Use of a Broken or Risky Cryptographic Algorithm"
                ],
                "owasp": [
                  "A03:2017 - Sensitive Data Exposure",
                  "A02:2021 - Cryptographic Failures"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://owasp.org/Top10/A02_2021-Cryptographic_Failures"
            },
            {
              "id": "app.opengrep-rules.javascript.lang.best-practice.lazy-load-module",
              "name": "app.opengrep-rules.javascript.lang.best-practice.lazy-load-module",
              "shortDescription": {
                "text": "app.opengrep-rules.javascript.lang.best-practice.lazy-load-module"
              },
              "fullDescription": {
                "text": "Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."
              },
              "help": {
                "text": "Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."
              },
              "properties": {
                "tags": [],
                "security-severity": "3.0"
              },
              "helpUri": "https://nodesecroadmap.fyi/chapter-2/dynamism.html"
            },
            {
              "id": "app.opengrep-rules.python.lang.best-practice.unspecified-open-encoding",
              "name": "app.opengrep-rules.python.lang.best-practice.unspecified-open-encoding",
              "shortDescription": {
                "text": "app.opengrep-rules.python.lang.best-practice.unspecified-open-encoding"
              },
              "fullDescription": {
                "text": "Missing 'encoding' parameter. 'open()' uses device locale encodings by default, corrupting files with special characters. Specify the encoding to ensure cross-platform support when opening files in text mode (e.g. encoding=\"utf-8\")."
              },
              "help": {
                "text": "Missing 'encoding' parameter. 'open()' uses device locale encodings by default, corrupting files with special characters. Specify the encoding to ensure cross-platform support when opening files in text mode (e.g. encoding=\"utf-8\")."
              },
              "properties": {
                "tags": [],
                "security-severity": "3.0"
              },
              "helpUri": "https://www.python.org/dev/peps/pep-0597/"
            },
            {
              "id": "app.opengrep-rules.python.lang.security.deserialization.avoid-pickle",
              "name": "app.opengrep-rules.python.lang.security.deserialization.avoid-pickle",
              "shortDescription": {
                "text": "app.opengrep-rules.python.lang.security.deserialization.avoid-pickle"
              },
              "fullDescription": {
                "text": "Avoid using `pickle`, which is known to lead to code execution vulnerabilities. When unpickling, the serialized data could be manipulated to run arbitrary code. Instead, consider serializing the relevant data as JSON or a similar text-based serialization format."
              },
              "help": {
                "text": "Avoid using `pickle`, which is known to lead to code execution vulnerabilities. When unpickling, the serialized data could be manipulated to run arbitrary code. Instead, consider serializing the relevant data as JSON or a similar text-based serialization format."
              },
              "properties": {
                "tags": [
                  "CWE-502: Deserialization of Untrusted Data",
                  "A08:2017 - Insecure Deserialization",
                  "A08:2021 - Software and Data Integrity Failures"
