                  "A03:2021 - Injection"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://docs.sqlalchemy.org/en/14/core/tutorial.html#using-textual-sql"
            },
            {
              "id": "app.opengrep-rules.python.lang.security.audit.formatted-sql-query",
