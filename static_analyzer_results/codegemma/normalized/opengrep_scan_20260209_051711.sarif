            {
              "id": "app.opengrep-rules.python.requests.best-practice.use-raise-for-status",
              "name": "app.opengrep-rules.python.requests.best-practice.use-raise-for-status",
              "shortDescription": {
                "text": "app.opengrep-rules.python.requests.best-practice.use-raise-for-status"
              },
              "fullDescription": {
                "text": "There's an HTTP request made with requests, but the raise_for_status() utility method isn't used. This can result in request errors going unnoticed and your code behaving in unexpected ways, such as if your authorization API returns a 500 error while you're only checking for a 401."
              },
              "help": {
                "text": "There's an HTTP request made with requests, but the raise_for_status() utility method isn't used. This can result in request errors going unnoticed and your code behaving in unexpected ways, such as if your authorization API returns a 500 error while you're only checking for a 401."
              },
              "properties": {
                "tags": [],
                "security-severity": "3.0"
              },
              "helpUri": "https://requests.readthedocs.io/en/master/api/#requests.Response.raise_for_status"
            },
            {
              "id": "app.opengrep-rules.python.requests.best-practice.use-timeout",
              "name": "app.opengrep-rules.python.requests.best-practice.use-timeout",
              "shortDescription": {
                "text": "app.opengrep-rules.python.requests.best-practice.use-timeout"
              },
              "fullDescription": {
                "text": "Detected a 'requests' call without a timeout set. By default, 'requests' calls wait until the connection is closed. This means a 'requests' call without a timeout will hang the program if a response is never received. Consider setting a timeout for all 'requests'."
              },
              "help": {
                "text": "Detected a 'requests' call without a timeout set. By default, 'requests' calls wait until the connection is closed. This means a 'requests' call without a timeout will hang the program if a response is never received. Consider setting a timeout for all 'requests'."
              },
              "properties": {
                "tags": [],
                "security-severity": "3.0"
              },
              "helpUri": "https://docs.python-requests.org/en/latest/user/advanced/?highlight=timeout#timeouts"
            },
