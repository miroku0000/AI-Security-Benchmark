                "region": {
                  "startLine": 33,
                  "endLine": 33,
                  "startColumn": 19,
                  "endColumn": 48,
                  "snippet": {
                    "text": "    const regex = new RegExp(`${name}=([^;]*)`);"
                  }
                }
              }
            }
          ],
          "properties": {
