              "id": "app.opengrep-rules.javascript.lang.security.audit.detect-non-literal-fs-filename",
              "name": "app.opengrep-rules.javascript.lang.security.audit.detect-non-literal-fs-filename",
              "shortDescription": {
                "text": "app.opengrep-rules.javascript.lang.security.audit.detect-non-literal-fs-filename"
              },
              "fullDescription": {
                "text": "Detected that function argument `filename` has entered the fs module. An attacker could potentially control the location of this file, to include going backwards in the directory with '../'. To address this, ensure that user-controlled variables in file paths are validated."
              },
              "help": {
                "text": "Detected that function argument `filename` has entered the fs module. An attacker could potentially control the location of this file, to include going backwards in the directory with '../'. To address this, ensure that user-controlled variables in file paths are validated."
              },
              "properties": {
                "tags": [
