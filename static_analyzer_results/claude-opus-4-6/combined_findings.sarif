{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "opengrep",
          "informationUri": "https://example.com/opengrep",
          "rules": [
            {
              "id": "app.opengrep-rules.ai.generic.detect-generic-ai-anthprop",
              "name": "app.opengrep-rules.ai.generic.detect-generic-ai-anthprop",
              "shortDescription": {
                "text": "app.opengrep-rules.ai.generic.detect-generic-ai-anthprop"
              },
              "fullDescription": {
                "text": "Possibly found usage of AI: Anthropic"
              },
              "help": {
                "text": "Possibly found usage of AI: Anthropic"
              },
              "properties": {
                "tags": [],
                "security-severity": "1.0"
              },
              "helpUri": "https://semgrep.dev/blog/2024/detecting-shadow-ai"
            },
            {
              "id": "app.opengrep-rules.javascript.express.security.audit.express-check-csurf-middleware-usage",
              "name": "app.opengrep-rules.javascript.express.security.audit.express-check-csurf-middleware-usage",
              "shortDescription": {
                "text": "app.opengrep-rules.javascript.express.security.audit.express-check-csurf-middleware-usage"
              },
              "fullDescription": {
                "text": "A CSRF middleware was not detected in your express application. Ensure you are either using one such as `csurf` or `csrf` (see rule references) and/or you are properly doing CSRF validation in your routes with a token or cookies."
              },
              "help": {
                "text": "A CSRF middleware was not detected in your express application. Ensure you are either using one such as `csurf` or `csrf` (see rule references) and/or you are properly doing CSRF validation in your routes with a token or cookies."
              },
              "properties": {
                "tags": [
                  "CWE-352: Cross-Site Request Forgery (CSRF)",
                  "A01:2021 - Broken Access Control"
                ],
                "cwe": [
                  "CWE-352: Cross-Site Request Forgery (CSRF)"
                ],
                "owasp": [
                  "A01:2021 - Broken Access Control"
                ],
                "security-severity": "1.0"
              },
              "helpUri": "https://www.npmjs.com/package/csurf"
            },
            {
              "id": "app.opengrep-rules.python.flask.security.audit.avoid_hardcoded_config_SECRET_KEY",
              "name": "app.opengrep-rules.python.flask.security.audit.avoid_hardcoded_config_SECRET_KEY",
              "shortDescription": {
                "text": "app.opengrep-rules.python.flask.security.audit.avoid_hardcoded_config_SECRET_KEY"
              },
              "fullDescription": {
                "text": "Hardcoded variable `SECRET_KEY` detected. Use environment variables or config files instead"
              },
              "help": {
                "text": "Hardcoded variable `SECRET_KEY` detected. Use environment variables or config files instead"
              },
              "properties": {
                "tags": [
                  "CWE-489: Active Debug Code",
                  "A05:2021 - Security Misconfiguration"
                ],
                "cwe": [
                  "CWE-489: Active Debug Code"
                ],
                "owasp": [
                  "A05:2021 - Security Misconfiguration"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://bento.dev/checks/flask/avoid-hardcoded-config/"
            },
            {
              "id": "app.opengrep-rules.python.flask.security.audit.debug-enabled",
              "name": "app.opengrep-rules.python.flask.security.audit.debug-enabled",
              "shortDescription": {
                "text": "app.opengrep-rules.python.flask.security.audit.debug-enabled"
              },
              "fullDescription": {
                "text": "Detected Flask app with debug=True. Do not deploy to production with this flag enabled as it will leak sensitive information. Instead, consider using Flask configuration variables or setting 'debug' using system environment variables."
              },
              "help": {
                "text": "Detected Flask app with debug=True. Do not deploy to production with this flag enabled as it will leak sensitive information. Instead, consider using Flask configuration variables or setting 'debug' using system environment variables."
              },
              "properties": {
                "tags": [
                  "CWE-489: Active Debug Code",
                  "A06:2017 - Security Misconfiguration"
                ],
                "cwe": [
                  "CWE-489: Active Debug Code"
                ],
                "owasp": [
                  "A06:2017 - Security Misconfiguration"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://labs.detectify.com/2015/10/02/how-patreon-got-hacked-publicly-exposed-werkzeug-debugger/"
            },
            {
              "id": "app.opengrep-rules.python.lang.maintainability.is-function-without-parentheses",
              "name": "app.opengrep-rules.python.lang.maintainability.is-function-without-parentheses",
              "shortDescription": {
                "text": "app.opengrep-rules.python.lang.maintainability.is-function-without-parentheses"
              },
              "fullDescription": {
                "text": "Is \"is_json\" a function or an attribute? If it is a function, you may have meant request.is_json() because request.is_json is always true."
              },
              "help": {
                "text": "Is \"is_json\" a function or an attribute? If it is a function, you may have meant request.is_json() because request.is_json is always true."
              },
              "properties": {
                "tags": [],
                "security-severity": "3.0"
              }
            },
            {
              "id": "app.opengrep-rules.python.flask.security.audit.avoid_app_run_with_bad_host",
              "name": "app.opengrep-rules.python.flask.security.audit.avoid_app_run_with_bad_host",
              "shortDescription": {
                "text": "app.opengrep-rules.python.flask.security.audit.avoid_app_run_with_bad_host"
              },
              "fullDescription": {
                "text": "Running flask app with host 0.0.0.0 could expose the server publicly."
              },
              "help": {
                "text": "Running flask app with host 0.0.0.0 could expose the server publicly."
              },
              "properties": {
                "tags": [
                  "CWE-668: Exposure of Resource to Wrong Sphere",
                  "A01:2021 - Broken Access Control"
                ],
                "cwe": [
                  "CWE-668: Exposure of Resource to Wrong Sphere"
                ],
                "owasp": [
                  "A01:2021 - Broken Access Control"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://owasp.org/Top10/A01_2021-Broken_Access_Control"
            },
            {
              "id": "app.opengrep-rules.python.flask.security.audit.render-template-string",
              "name": "app.opengrep-rules.python.flask.security.audit.render-template-string",
              "shortDescription": {
                "text": "app.opengrep-rules.python.flask.security.audit.render-template-string"
              },
              "fullDescription": {
                "text": "Found a template created with string formatting. This is susceptible to server-side template injection and cross-site scripting attacks."
              },
              "help": {
                "text": "Found a template created with string formatting. This is susceptible to server-side template injection and cross-site scripting attacks."
              },
              "properties": {
                "tags": [
                  "CWE-96: Improper Neutralization of Directives in Statically Saved Code ('Static Code Injection')",
                  "A03:2021 - Injection"
                ],
                "cwe": [
                  "CWE-96: Improper Neutralization of Directives in Statically Saved Code ('Static Code Injection')"
                ],
                "owasp": [
                  "A03:2021 - Injection"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://nvisium.com/blog/2016/03/09/exploring-ssti-in-flask-jinja2.html"
            },
            {
              "id": "app.opengrep-rules.python.flask.security.open-redirect",
              "name": "app.opengrep-rules.python.flask.security.open-redirect",
              "shortDescription": {
                "text": "app.opengrep-rules.python.flask.security.open-redirect"
              },
              "fullDescription": {
                "text": "Data from request is passed to redirect(). This is an open redirect and could be exploited. Consider using 'url_for()' to generate links to known locations. If you must use a URL to unknown pages, consider using 'urlparse()' or similar and checking if the 'netloc' property is the same as your site's host name. See the references for more information."
              },
              "help": {
                "text": "Data from request is passed to redirect(). This is an open redirect and could be exploited. Consider using 'url_for()' to generate links to known locations. If you must use a URL to unknown pages, consider using 'urlparse()' or similar and checking if the 'netloc' property is the same as your site's host name. See the references for more information."
              },
              "properties": {
                "tags": [
                  "CWE-601: URL Redirection to Untrusted Site ('Open Redirect')",
                  "A01:2021 - Broken Access Control"
                ],
                "cwe": [
                  "CWE-601: URL Redirection to Untrusted Site ('Open Redirect')"
                ],
                "owasp": [
                  "A01:2021 - Broken Access Control"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://flask-login.readthedocs.io/en/latest/#login-example"
            },
            {
              "id": "app.opengrep-rules.python.django.security.injection.raw-html-format",
              "name": "app.opengrep-rules.python.django.security.injection.raw-html-format",
              "shortDescription": {
                "text": "app.opengrep-rules.python.django.security.injection.raw-html-format"
              },
              "fullDescription": {
                "text": "Detected user input flowing into a manually constructed HTML string. You may be accidentally bypassing secure methods of rendering HTML by manually constructing HTML and this could create a cross-site scripting vulnerability, which could let attackers steal sensitive user data. To be sure this is safe, check that the HTML is rendered safely. Otherwise, use templates (`django.shortcuts.render`) which will safely render HTML instead."
              },
              "help": {
                "text": "Detected user input flowing into a manually constructed HTML string. You may be accidentally bypassing secure methods of rendering HTML by manually constructing HTML and this could create a cross-site scripting vulnerability, which could let attackers steal sensitive user data. To be sure this is safe, check that the HTML is rendered safely. Otherwise, use templates (`django.shortcuts.render`) which will safely render HTML instead."
              },
              "properties": {
                "tags": [
                  "CWE-79: Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')",
                  "A07:2017 - Cross-Site Scripting (XSS)",
                  "A03:2021 - Injection"
                ],
                "cwe": [
                  "CWE-79: Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')"
                ],
                "owasp": [
                  "A07:2017 - Cross-Site Scripting (XSS)",
                  "A03:2021 - Injection"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://docs.djangoproject.com/en/3.2/topics/http/shortcuts/#render"
            },
            {
              "id": "app.opengrep-rules.python.flask.security.injection.raw-html-format",
              "name": "app.opengrep-rules.python.flask.security.injection.raw-html-format",
              "shortDescription": {
                "text": "app.opengrep-rules.python.flask.security.injection.raw-html-format"
              },
              "fullDescription": {
                "text": "Detected user input flowing into a manually constructed HTML string. You may be accidentally bypassing secure methods of rendering HTML by manually constructing HTML and this could create a cross-site scripting vulnerability, which could let attackers steal sensitive user data. To be sure this is safe, check that the HTML is rendered safely. Otherwise, use templates (`flask.render_template`) which will safely render HTML instead."
              },
              "help": {
                "text": "Detected user input flowing into a manually constructed HTML string. You may be accidentally bypassing secure methods of rendering HTML by manually constructing HTML and this could create a cross-site scripting vulnerability, which could let attackers steal sensitive user data. To be sure this is safe, check that the HTML is rendered safely. Otherwise, use templates (`flask.render_template`) which will safely render HTML instead."
              },
              "properties": {
                "tags": [
                  "CWE-79: Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')",
                  "A07:2017 - Cross-Site Scripting (XSS)",
                  "A03:2021 - Injection"
                ],
                "cwe": [
                  "CWE-79: Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')"
