                  "A03:2021 - Injection"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://flask.palletsprojects.com/en/2.0.x/security/#cross-site-scripting-xss"
            },
            {
              "id": "app.opengrep-rules.javascript.lang.correctness.missing-template-string-indicator",
              "name": "app.opengrep-rules.javascript.lang.correctness.missing-template-string-indicator",
              "shortDescription": {
                "text": "app.opengrep-rules.javascript.lang.correctness.missing-template-string-indicator"
              },
              "fullDescription": {
                "text": "This looks like a JavaScript template string. Are you missing a '$' in front of '{...}'?"
              },
              "help": {
                "text": "This looks like a JavaScript template string. Are you missing a '$' in front of '{...}'?"
              },
              "properties": {
                "tags": [],
                "security-severity": "1.0"
              }
            },
            {
              "id": "app.opengrep-rules.javascript.lang.security.html-in-template-string",
              "name": "app.opengrep-rules.javascript.lang.security.html-in-template-string",
              "shortDescription": {
                "text": "app.opengrep-rules.javascript.lang.security.html-in-template-string"
              },
              "fullDescription": {
                "text": "This template literal looks like HTML and has interpolated variables. These variables are not HTML-encoded by default. If the variables contain HTML tags, these may be interpreted by the browser, resulting in cross-site scripting (XSS)."
              },
              "help": {
                "text": "This template literal looks like HTML and has interpolated variables. These variables are not HTML-encoded by default. If the variables contain HTML tags, these may be interpreted by the browser, resulting in cross-site scripting (XSS)."
              },
              "properties": {
                "tags": [
                  "CWE-116: Improper Encoding or Escaping of Output",
                  "A03:2021 - Injection"
                ],
                "cwe": [
                  "CWE-116: Improper Encoding or Escaping of Output"
                ],
                "owasp": [
                  "A03:2021 - Injection"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://owasp.org/Top10/A03_2021-Injection"
            },
            {
              "id": "app.opengrep-rules.python.lang.best-practice.unspecified-open-encoding",
              "name": "app.opengrep-rules.python.lang.best-practice.unspecified-open-encoding",
              "shortDescription": {
                "text": "app.opengrep-rules.python.lang.best-practice.unspecified-open-encoding"
              },
              "fullDescription": {
                "text": "Missing 'encoding' parameter. 'open()' uses device locale encodings by default, corrupting files with special characters. Specify the encoding to ensure cross-platform support when opening files in text mode (e.g. encoding=\"utf-8\")."
              },
              "help": {
                "text": "Missing 'encoding' parameter. 'open()' uses device locale encodings by default, corrupting files with special characters. Specify the encoding to ensure cross-platform support when opening files in text mode (e.g. encoding=\"utf-8\")."
              },
              "properties": {
                "tags": [],
                "security-severity": "3.0"
              },
              "helpUri": "https://www.python.org/dev/peps/pep-0597/"
            },
            {
              "id": "app.opengrep-rules.python.lang.security.audit.dangerous-subprocess-use-audit",
              "name": "app.opengrep-rules.python.lang.security.audit.dangerous-subprocess-use-audit",
              "shortDescription": {
                "text": "app.opengrep-rules.python.lang.security.audit.dangerous-subprocess-use-audit"
              },
              "fullDescription": {
                "text": "Detected subprocess function 'call' without a static string. If this data can be controlled by a malicious actor, it may be an instance of command injection. Audit the use of this call to ensure it is not controllable by an external resource. You may consider using 'shlex.escape()'."
              },
              "help": {
                "text": "Detected subprocess function 'call' without a static string. If this data can be controlled by a malicious actor, it may be an instance of command injection. Audit the use of this call to ensure it is not controllable by an external resource. You may consider using 'shlex.escape()'."
              },
              "properties": {
                "tags": [
                  "CWE-78: Improper Neutralization of Special Elements used in an OS Command ('OS Command Injection')",
                  "A01:2017 - Injection",
                  "A03:2021 - Injection"
                ],
                "cwe": [
                  "CWE-78: Improper Neutralization of Special Elements used in an OS Command ('OS Command Injection')"
                ],
                "owasp": [
                  "A01:2017 - Injection",
                  "A03:2021 - Injection"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://stackoverflow.com/questions/3172470/actual-meaning-of-shell-true-in-subprocess"
            },
            {
              "id": "app.opengrep-rules.python.lang.correctness.unchecked-subprocess-call",
              "name": "app.opengrep-rules.python.lang.correctness.unchecked-subprocess-call",
              "shortDescription": {
                "text": "app.opengrep-rules.python.lang.correctness.unchecked-subprocess-call"
              },
              "fullDescription": {
                "text": "This is not checking the return value of this subprocess call; if it fails no exception will be raised. Consider subprocess.check_call() instead"
              },
              "help": {
                "text": "This is not checking the return value of this subprocess call; if it fails no exception will be raised. Consider subprocess.check_call() instead"
              },
              "properties": {
                "tags": [],
                "security-severity": "3.0"
              },
              "helpUri": "https://docs.python.org/3/library/subprocess.html#subprocess.check_call"
            },
            {
              "id": "app.opengrep-rules.python.lang.security.deserialization.avoid-pickle",
              "name": "app.opengrep-rules.python.lang.security.deserialization.avoid-pickle",
              "shortDescription": {
                "text": "app.opengrep-rules.python.lang.security.deserialization.avoid-pickle"
              },
              "fullDescription": {
                "text": "Avoid using `pickle`, which is known to lead to code execution vulnerabilities. When unpickling, the serialized data could be manipulated to run arbitrary code. Instead, consider serializing the relevant data as JSON or a similar text-based serialization format."
              },
              "help": {
                "text": "Avoid using `pickle`, which is known to lead to code execution vulnerabilities. When unpickling, the serialized data could be manipulated to run arbitrary code. Instead, consider serializing the relevant data as JSON or a similar text-based serialization format."
              },
              "properties": {
                "tags": [
                  "CWE-502: Deserialization of Untrusted Data",
                  "A08:2017 - Insecure Deserialization",
                  "A08:2021 - Software and Data Integrity Failures"
