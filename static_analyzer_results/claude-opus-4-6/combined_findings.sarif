                  "snippet": {
                    "text": "  res.send(`\n    <!DOCTYPE html>\n    <html>\n    <head>\n      <title>Dashboard</title>\n      <style>\n        body { font-family: Arial, sans-serif; max-width: 600px; margin: 80px auto; }\n        .welcome { background: #d4edda; border: 1px solid #c3e6cb; padding: 15px; border-radius: 4px; margin-bottom: 20px; }\n        a { color: #007bff; }\n        .token-info { background: #f8f9fa; padding: 15px; border-radius: 4px; margin-top: 20px; font-size: 13px; }\n      </style>\n    </head>\n    <body>\n      <h2>Dashboard</h2>\n      <div class=\"welcome\">\n        Welcome back, <strong>${req.user.username}</strong>! You are logged in.\n      </div>\n      <p><a href=\"/logout\">Logout</a> | <a href=\"/logout-all\">Logout from all devices</a></p>\n      <div class=\"token-info\">\n        <strong>Active Remember Me tokens:</strong>\n        <pre>${JSON.stringify(\n          Object.entries(rememberMeTokens)\n            .filter(([_, v]) => v.username === req.user.username)\n            .map(([selector, v]) => ({\n              selector: selector.substring(0, 8) + '...',\n              expires: v.expires,\n              username: v.username\n            })),\n          null, 2\n        )}</pre>\n      </div>\n    </body>\n    </html>\n  `);"
                  }
                }
              }
            }
