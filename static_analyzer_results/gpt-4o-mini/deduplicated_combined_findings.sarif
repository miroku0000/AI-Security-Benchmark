            {
              "id": "app.opengrep-rules.python.jwt.security.jwt-python-hardcoded-secret",
              "name": "app.opengrep-rules.python.jwt.security.jwt-python-hardcoded-secret",
              "shortDescription": {
                "text": "app.opengrep-rules.python.jwt.security.jwt-python-hardcoded-secret"
              },
              "fullDescription": {
                "text": "Hardcoded JWT secret or private key is used. This is a Insufficiently Protected Credentials weakness: https://cwe.mitre.org/data/definitions/522.html Consider using an appropriate security mechanism to protect the credentials (e.g. keeping secrets in environment variables)"
              },
              "help": {
                "text": "Hardcoded JWT secret or private key is used. This is a Insufficiently Protected Credentials weakness: https://cwe.mitre.org/data/definitions/522.html Consider using an appropriate security mechanism to protect the credentials (e.g. keeping secrets in environment variables)"
              },
              "properties": {
                "tags": [
                  "CWE-522: Insufficiently Protected Credentials",
                  "A02:2017 - Broken Authentication",
                  "A04:2021 - Insecure Design"
                ],
                "cwe": [
                  "CWE-522: Insufficiently Protected Credentials"
                ],
                "owasp": [
                  "A02:2017 - Broken Authentication",
                  "A04:2021 - Insecure Design"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://semgrep.dev/blog/2020/hardcoded-secrets-unverified-tokens-and-other-common-jwt-mistakes/"
            },
            {
              "id": "app.opengrep-rules.python.lang.best-practice.unspecified-open-encoding",
              "name": "app.opengrep-rules.python.lang.best-practice.unspecified-open-encoding",
              "shortDescription": {
                "text": "app.opengrep-rules.python.lang.best-practice.unspecified-open-encoding"
              },
              "fullDescription": {
                "text": "Missing 'encoding' parameter. 'open()' uses device locale encodings by default, corrupting files with special characters. Specify the encoding to ensure cross-platform support when opening files in text mode (e.g. encoding=\"utf-8\")."
              },
              "help": {
                "text": "Missing 'encoding' parameter. 'open()' uses device locale encodings by default, corrupting files with special characters. Specify the encoding to ensure cross-platform support when opening files in text mode (e.g. encoding=\"utf-8\")."
              },
              "properties": {
                "tags": [],
                "security-severity": "3.0"
              },
              "helpUri": "https://www.python.org/dev/peps/pep-0597/"
            },
            {
              "id": "app.opengrep-rules.python.lang.maintainability.is-function-without-parentheses",
              "name": "app.opengrep-rules.python.lang.maintainability.is-function-without-parentheses",
              "shortDescription": {
                "text": "app.opengrep-rules.python.lang.maintainability.is-function-without-parentheses"
              },
              "fullDescription": {
                "text": "Is \"is_authenticated\" a function or an attribute? If it is a function, you may have meant user.is_authenticated() because user.is_authenticated is always true."
              },
              "help": {
                "text": "Is \"is_authenticated\" a function or an attribute? If it is a function, you may have meant user.is_authenticated() because user.is_authenticated is always true."
              },
              "properties": {
                "tags": [],
                "security-severity": "3.0"
              }
            },
            {
              "id": "app.opengrep-rules.javascript.lang.security.audit.detect-non-literal-fs-filename",
              "name": "app.opengrep-rules.javascript.lang.security.audit.detect-non-literal-fs-filename",
              "shortDescription": {
                "text": "app.opengrep-rules.javascript.lang.security.audit.detect-non-literal-fs-filename"
              },
              "fullDescription": {
                "text": "Detected that function argument `req` has entered the fs module. An attacker could potentially control the location of this file, to include going backwards in the directory with '../'. To address this, ensure that user-controlled variables in file paths are validated."
              },
              "help": {
                "text": "Detected that function argument `req` has entered the fs module. An attacker could potentially control the location of this file, to include going backwards in the directory with '../'. To address this, ensure that user-controlled variables in file paths are validated."
              },
              "properties": {
