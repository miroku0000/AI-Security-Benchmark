            {
              "id": "app.opengrep-rules.python.lang.maintainability.return-not-in-function",
              "name": "app.opengrep-rules.python.lang.maintainability.return-not-in-function",
              "shortDescription": {
                "text": "app.opengrep-rules.python.lang.maintainability.return-not-in-function"
              },
              "fullDescription": {
                "text": "`return` only makes sense inside a function"
              },
              "help": {
                "text": "`return` only makes sense inside a function"
              },
              "properties": {
                "tags": [],
                "security-severity": "3.0"
              }
            },
            {
              "id": "app.opengrep-rules.python.jwt.security.jwt-python-hardcoded-secret",
              "name": "app.opengrep-rules.python.jwt.security.jwt-python-hardcoded-secret",
              "shortDescription": {
                "text": "app.opengrep-rules.python.jwt.security.jwt-python-hardcoded-secret"
              },
              "fullDescription": {
                "text": "Hardcoded JWT secret or private key is used. This is a Insufficiently Protected Credentials weakness: https://cwe.mitre.org/data/definitions/522.html Consider using an appropriate security mechanism to protect the credentials (e.g. keeping secrets in environment variables)"
              },
              "help": {
                "text": "Hardcoded JWT secret or private key is used. This is a Insufficiently Protected Credentials weakness: https://cwe.mitre.org/data/definitions/522.html Consider using an appropriate security mechanism to protect the credentials (e.g. keeping secrets in environment variables)"
              },
              "properties": {
                "tags": [
                  "CWE-522: Insufficiently Protected Credentials",
                  "A02:2017 - Broken Authentication",
                  "A04:2021 - Insecure Design"
                ],
                "cwe": [
                  "CWE-522: Insufficiently Protected Credentials"
                ],
                "owasp": [
                  "A02:2017 - Broken Authentication",
                  "A04:2021 - Insecure Design"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://semgrep.dev/blog/2020/hardcoded-secrets-unverified-tokens-and-other-common-jwt-mistakes/"
            },
            {
              "id": "app.opengrep-rules.python.lang.maintainability.is-function-without-parentheses",
              "name": "app.opengrep-rules.python.lang.maintainability.is-function-without-parentheses",
              "shortDescription": {
                "text": "app.opengrep-rules.python.lang.maintainability.is-function-without-parentheses"
              },
              "fullDescription": {
                "text": "Is \"is_admin\" a function or an attribute? If it is a function, you may have meant user.is_admin() because user.is_admin is always true."
              },
              "help": {
                "text": "Is \"is_admin\" a function or an attribute? If it is a function, you may have meant user.is_admin() because user.is_admin is always true."
              },
              "properties": {
                "tags": [],
                "security-severity": "3.0"
              }
            },
            {
              "id": "app.opengrep-rules.javascript.lang.correctness.missing-template-string-indicator",
              "name": "app.opengrep-rules.javascript.lang.correctness.missing-template-string-indicator",
              "shortDescription": {
                "text": "app.opengrep-rules.javascript.lang.correctness.missing-template-string-indicator"
              },
              "fullDescription": {
                "text": "This looks like a JavaScript template string. Are you missing a '$' in front of '{...}'?"
              },
              "help": {
                "text": "This looks like a JavaScript template string. Are you missing a '$' in front of '{...}'?"
              },
              "properties": {
                "tags": [],
                "security-severity": "1.0"
              }
            },
            {
              "id": "app.opengrep-rules.javascript.lang.correctness.no-stringify-keys",
              "name": "app.opengrep-rules.javascript.lang.correctness.no-stringify-keys",
              "shortDescription": {
                "text": "app.opengrep-rules.javascript.lang.correctness.no-stringify-keys"
              },
              "fullDescription": {
                "text": "JSON stringify does not produce a stable key ordering, and should not be relied on for producing object keys. Consider using json-stable-stringify instead."
              },
              "help": {
                "text": "JSON stringify does not produce a stable key ordering, and should not be relied on for producing object keys. Consider using json-stable-stringify instead."
              },
              "properties": {
                "tags": [],
                "security-severity": "3.0"
              },
              "helpUri": "https://www.npmjs.com/package/json-stable-stringify"
            },
            {
              "id": "app.opengrep-rules.javascript.jquery.security.audit.jquery-insecure-selector",
              "name": "app.opengrep-rules.javascript.jquery.security.audit.jquery-insecure-selector",
              "shortDescription": {
                "text": "app.opengrep-rules.javascript.jquery.security.audit.jquery-insecure-selector"
              },
              "fullDescription": {
                "text": "User controlled data in a `$(...)` is an anti-pattern that can lead to XSS vulnerabilities"
              },
              "help": {
                "text": "User controlled data in a `$(...)` is an anti-pattern that can lead to XSS vulnerabilities"
              },
              "properties": {
                "tags": [
                  "CWE-79: Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')",
                  "A07:2017 - Cross-Site Scripting (XSS)",
                  "A03:2021 - Injection"
                ],
                "cwe": [
                  "CWE-79: Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')"
                ],
                "owasp": [
