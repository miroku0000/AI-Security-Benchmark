              "name": "app.opengrep-rules.javascript.express.security.audit.express-cookie-session-no-httponly",
              "shortDescription": {
                "text": "app.opengrep-rules.javascript.express.security.audit.express-cookie-session-no-httponly"
              },
              "fullDescription": {
