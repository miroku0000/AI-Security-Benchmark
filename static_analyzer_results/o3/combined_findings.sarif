            {
              "id": "app.opengrep-rules.python.lang.maintainability.return-not-in-function",
              "name": "app.opengrep-rules.python.lang.maintainability.return-not-in-function",
              "shortDescription": {
                "text": "app.opengrep-rules.python.lang.maintainability.return-not-in-function"
              },
              "fullDescription": {
                "text": "`return` only makes sense inside a function"
