                    "text": "const REDEEM_SCRIPT = `\n  local key          = KEYS[1]\n  local userId       = ARGV[1]\n  local now          = tonumber(ARGV[2])\n  local orderTotal   = tonumber(ARGV[3])\n\n  if redis.call('EXISTS', key) == 0 then\n    return {0, 'INVALID_CODE'}\n  end\n\n  if redis.call('HGET', key, 'used') == '1' then\n    return {0, 'ALREADY_USED'}\n  end\n\n  local expiresAt = redis.call('HGET', key, 'expiresAt')\n  if expiresAt ~= false and expiresAt ~= '' and tonumber(expiresAt) < now then\n    return {0, 'EXPIRED'}\n  end\n\n  redis.call('HSET', key, 'used', '1', 'usedBy', userId, 'usedAt', now)\n\n  local discountType  = redis.call('HGET', key, 'discountType')\n  local discountValue = tonumber(redis.call('HGET', key, 'discountValue'))\n\n  local discount = 0\n  if discountType == 'percent' then\n    discount = math.floor(orderTotal * discountValue / 100)\n  else\n    discount = discountValue\n  end\n  if discount > orderTotal then\n    discount = orderTotal\n  end\n\n  return {1, tostring(discount)}\n`;"
