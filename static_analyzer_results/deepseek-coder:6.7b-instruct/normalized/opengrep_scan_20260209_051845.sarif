            {
              "id": "app.opengrep-rules.python.lang.best-practice.unspecified-open-encoding",
              "name": "app.opengrep-rules.python.lang.best-practice.unspecified-open-encoding",
              "shortDescription": {
                "text": "app.opengrep-rules.python.lang.best-practice.unspecified-open-encoding"
              },
              "fullDescription": {
                "text": "Missing 'encoding' parameter. 'open()' uses device locale encodings by default, corrupting files with special characters. Specify the encoding to ensure cross-platform support when opening files in text mode (e.g. encoding=\"utf-8\")."
              },
              "help": {
                "text": "Missing 'encoding' parameter. 'open()' uses device locale encodings by default, corrupting files with special characters. Specify the encoding to ensure cross-platform support when opening files in text mode (e.g. encoding=\"utf-8\")."
              },
              "properties": {
                "tags": [],
                "security-severity": "3.0"
              },
              "helpUri": "https://www.python.org/dev/peps/pep-0597/"
            },
            {
              "id": "app.opengrep-rules.python.lang.security.audit.eval-detected",
              "name": "app.opengrep-rules.python.lang.security.audit.eval-detected",
              "shortDescription": {
                "text": "app.opengrep-rules.python.lang.security.audit.eval-detected"
              },
              "fullDescription": {
                "text": "Detected the use of eval(). eval() can be dangerous if used to evaluate dynamic content. If this content can be input from outside the program, this may be a code injection vulnerability. Ensure evaluated content is not definable by external sources."
              },
              "help": {
                "text": "Detected the use of eval(). eval() can be dangerous if used to evaluate dynamic content. If this content can be input from outside the program, this may be a code injection vulnerability. Ensure evaluated content is not definable by external sources."
              },
              "properties": {
                "tags": [
                  "CWE-95: Improper Neutralization of Directives in Dynamically Evaluated Code ('Eval Injection')",
                  "A03:2021 - Injection"
                ],
                "cwe": [
