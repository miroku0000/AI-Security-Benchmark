                  "A03:2021 - Injection"
                ],
                "security-severity": "3.0"
              },
              "helpUri": "https://stackoverflow.com/questions/3172470/actual-meaning-of-shell-true-in-subprocess"
            },
            {
              "id": "app.opengrep-rules.python.lang.security.audit.subprocess-shell-true",
              "name": "app.opengrep-rules.python.lang.security.audit.subprocess-shell-true",
              "shortDescription": {
                "text": "app.opengrep-rules.python.lang.security.audit.subprocess-shell-true"
              },
              "fullDescription": {
                "text": "Found 'subprocess' function 'run' with 'shell=True'. This is dangerous because this call will spawn the command using a shell process. Doing so propagates current shell settings and variables, which makes it much easier for a malicious actor to execute commands. Use 'shell=False' instead."
              },
              "help": {
                "text": "Found 'subprocess' function 'run' with 'shell=True'. This is dangerous because this call will spawn the command using a shell process. Doing so propagates current shell settings and variables, which makes it much easier for a malicious actor to execute commands. Use 'shell=False' instead."
              },
              "properties": {
                "tags": [
