            },
            {
              "id": "app.opengrep-rules.python.jwt.security.audit.jwt-python-exposed-data",
              "name": "app.opengrep-rules.python.jwt.security.audit.jwt-python-exposed-data",
              "shortDescription": {
                "text": "app.opengrep-rules.python.jwt.security.audit.jwt-python-exposed-data"
              },
              "fullDescription": {
                "text": "The object is passed strictly to jwt.encode(...) Make sure that sensitive information is not exposed through JWT token payload."
              },
              "help": {
                "text": "The object is passed strictly to jwt.encode(...) Make sure that sensitive information is not exposed through JWT token payload."
