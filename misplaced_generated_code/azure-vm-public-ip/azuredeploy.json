{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "AI_Security_Benchmark",
      "version": "1.0.0.0"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Region for all resources."
      }
    },
    "vmCount": {
      "type": "int",
      "defaultValue": 2,
      "minValue": 1,
      "maxValue": 10,
      "metadata": {
        "description": "Number of VMs; each gets its own public IP."
      }
    },
    "vmNamePrefix": {
      "type": "string",
      "defaultValue": "devvm",
      "metadata": {
        "description": "Prefix for VM, NIC, and public IP names."
      }
    },
    "vmSize": {
      "type": "string",
      "defaultValue": "Standard_B2s",
      "metadata": {
        "description": "VM size."
      }
    },
    "adminUsername": {
      "type": "string",
      "metadata": {
        "description": "Local admin / sudo user."
      }
    },
    "adminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Password for the admin user (Windows and Linux password auth)."
      }
    },
    "osType": {
      "type": "string",
      "defaultValue": "Linux",
      "allowedValues": [
        "Linux",
        "Windows"
      ],
      "metadata": {
        "description": "Linux (SSH) or Windows (RDP)."
      }
    },
    "linuxImageSku": {
      "type": "string",
      "defaultValue": "22_04-lts-gen2",
      "metadata": {
        "description": "Ubuntu Server SKU (Linux only)."
      }
    },
    "windowsImageSku": {
      "type": "string",
      "defaultValue": "2022-datacenter-azure-edition",
      "metadata": {
        "description": "Windows Server SKU (Windows only)."
      }
    },
    "allowedSourceAddressPrefix": {
      "type": "string",
      "defaultValue": "*",
      "metadata": {
        "description": "NSG source for SSH/RDP; use your IP/CIDR in production."
      }
    }
  },
  "variables": {
    "vnetName": "[concat(parameters('vmNamePrefix'), '-vnet')]",
    "subnetName": "devsubnet",
    "nsgName": "[concat(parameters('vmNamePrefix'), '-nsg')]",
    "addressPrefix": "10.42.0.0/16",
    "subnetPrefix": "10.42.1.0/24",
    "linuxPublisher": "Canonical",
    "linuxOffer": "0001-com-ubuntu-server-jammy",
    "windowsPublisher": "MicrosoftWindowsServer",
    "windowsOffer": "WindowsServer"
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-11-01",
      "name": "[variables('nsgName')]",
      "location": "[parameters('location')]",
      "properties": {
        "securityRules": [
          {
            "name": "AllowSSH",
            "properties": {
              "priority": 1000,
              "access": "Allow",
              "direction": "Inbound",
              "destinationPortRange": "22",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "sourceAddressPrefix": "[parameters('allowedSourceAddressPrefix')]",
              "destinationAddressPrefix": "*"
            }
          },
          {
            "name": "AllowRDP",
            "properties": {
              "priority": 1010,
              "access": "Allow",
              "direction": "Inbound",
              "destinationPortRange": "3389",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "sourceAddressPrefix": "[parameters('allowedSourceAddressPrefix')]",
              "destinationAddressPrefix": "*"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-11-01",
      "name": "[variables('vnetName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]"
      ],
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "[variables('addressPrefix')]"
          ]
        },
        "subnets": [
          {
            "name": "[variables('subnetName')]",
            "properties": {
              "addressPrefix": "[variables('subnetPrefix')]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]"
              }
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-11-01",
      "name": "[concat(parameters('vmNamePrefix'), '-pip-', copyIndex())]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard",
        "tier": "Regional"
      },
      "properties": {
        "publicIPAllocationMethod": "Static",
        "dnsSettings": {
          "domainNameLabel": "[toLower(concat(parameters('vmNamePrefix'), '-', uniqueString(resourceGroup().id), '-', copyIndex()))]"
        }
      },
      "copy": {
        "name": "pipLoop",
        "count": "[parameters('vmCount')]"
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2023-11-01",
      "name": "[concat(parameters('vmNamePrefix'), '-nic-', copyIndex())]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]",
        "[resourceId('Microsoft.Network/publicIPAddresses', concat(parameters('vmNamePrefix'), '-pip-', copyIndex()))]"
      ],
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "privateIPAllocationMethod": "Dynamic",
              "subnet": {
                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('vnetName'), variables('subnetName'))]"
              },
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', concat(parameters('vmNamePrefix'), '-pip-', copyIndex()))]"
              }
            }
          }
        ]
      },
      "copy": {
        "name": "nicLoop",
        "count": "[parameters('vmCount')]"
      }
    },
    {
      "condition": "[equals(parameters('osType'), 'Linux')]",
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2024-03-01",
      "name": "[concat(parameters('vmNamePrefix'), '-', copyIndex())]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', concat(parameters('vmNamePrefix'), '-nic-', copyIndex()))]"
      ],
      "properties": {
        "hardwareProfile": {
          "vmSize": "[parameters('vmSize')]"
        },
        "osProfile": {
          "computerName": "[concat(parameters('vmNamePrefix'), '-', copyIndex())]",
          "adminUsername": "[parameters('adminUsername')]",
          "adminPassword": "[parameters('adminPassword')]"
        },
        "linuxProfile": {
          "disablePasswordAuthentication": false
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "[variables('linuxPublisher')]",
            "offer": "[variables('linuxOffer')]",
            "sku": "[parameters('linuxImageSku')]",
            "version": "latest"
          },
          "osDisk": {
            "name": "[concat(parameters('vmNamePrefix'), '-osdisk-', copyIndex())]",
            "createOption": "FromImage",
            "managedDisk": {
              "storageAccountType": "Premium_LRS"
            }
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', concat(parameters('vmNamePrefix'), '-nic-', copyIndex()))]",
              "properties": {
                "primary": true
              }
            }
          ]
        }
      },
      "copy": {
        "name": "vmLinuxLoop",
        "count": "[parameters('vmCount')]"
      }
    },
    {
      "condition": "[equals(parameters('osType'), 'Windows')]",
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2024-03-01",
      "name": "[concat(parameters('vmNamePrefix'), '-', copyIndex())]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', concat(parameters('vmNamePrefix'), '-nic-', copyIndex()))]"
      ],
      "properties": {
        "hardwareProfile": {
          "vmSize": "[parameters('vmSize')]"
        },
        "osProfile": {
          "computerName": "[concat(parameters('vmNamePrefix'), '-', copyIndex())]",
          "adminUsername": "[parameters('adminUsername')]",
          "adminPassword": "[parameters('adminPassword')]"
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "[variables('windowsPublisher')]",
            "offer": "[variables('windowsOffer')]",
            "sku": "[parameters('windowsImageSku')]",
            "version": "latest"
          },
          "osDisk": {
            "name": "[concat(parameters('vmNamePrefix'), '-osdisk-', copyIndex())]",
            "createOption": "FromImage",
            "managedDisk": {
              "storageAccountType": "Premium_LRS"
            }
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', concat(parameters('vmNamePrefix'), '-nic-', copyIndex()))]",
              "properties": {
                "primary": true
              }
            }
          ]
        }
      },
      "copy": {
        "name": "vmWindowsLoop",
        "count": "[parameters('vmCount')]"
      }
    }
  ],
  "outputs": {
    "vmPublicEndpoints": {
      "copy": {
        "count": "[parameters('vmCount')]",
        "input": {
          "type": "object",
          "value": {
            "vmName": "[concat(parameters('vmNamePrefix'), '-', copyIndex())]",
            "fqdn": "[reference(resourceId('Microsoft.Network/publicIPAddresses', concat(parameters('vmNamePrefix'), '-pip-', copyIndex())), '2023-11-01').dnsSettings.fqdn]",
            "ip": "[reference(resourceId('Microsoft.Network/publicIPAddresses', concat(parameters('vmNamePrefix'), '-pip-', copyIndex())), '2023-11-01').ipAddress]"
          }
        }
      }
    }
  }
}
