{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "python",
    "COSMOS_CONNECTION_STRING": "AccountEndpoint=https://your-cosmos-account.documents.azure.com:443/;AccountKey=your-key-here==;",
    "DATABASE_NAME": "BatchProcessingDB",
    "CONTAINER_NAME": "LargeDatasets",
    "OUTPUT_CONTAINER": "ProcessedResults",
    "ERROR_CONTAINER": "ProcessingErrors",
    "BATCH_SIZE": "5000",
    "MAX_ITEMS": "1000000",
    "WEBSITE_NODE_DEFAULT_VERSION": "~18",
    "FUNCTIONS_EXTENSION_VERSION": "~4",
    "WEBSITE_RUN_FROM_PACKAGE": "1",
    "APPINSIGHTS_INSTRUMENTATIONKEY": "your-instrumentation-key",
    "APPLICATIONINSIGHTS_CONNECTION_STRING": "InstrumentationKey=your-instrumentation-key;IngestionEndpoint=https://your-region.in.applicationinsights.azure.com/",
    "AzureWebJobsDisableHomepage": "true",
    "WEBSITE_TIME_ZONE": "UTC",
    "FUNCTIONS_REQUEST_BODY_SIZE_LIMIT": "104857600",
    "WEBSITE_MAX_DYNAMIC_APPLICATION_SCALE_OUT": "10",
    "FUNCTIONS_RUNTIME_SCALE_MONITORING_ENABLED": "1",
    "SCM_LOGSTREAM_TIMEOUT": "7200",
    "DIAGNOSTICS_AZUREBLOBRETENTIONINDAYS": "30",
    "WEBSITE_HTTPSCALEV2_ENABLED": "1",
    "WEBSITE_ENABLE_SYNC_UPDATE_SITE": "true",
    "WEBSITE_RUN_FROM_ZIP": "1"
  },
  "Host": {
    "LocalHttpPort": 7071,
    "CORS": "*",
    "CORSCredentials": false
  },
  "ConnectionStrings": {
    "CosmosDB": "AccountEndpoint=https://your-cosmos-account.documents.azure.com:443/;AccountKey=your-key-here==;",
    "StorageAccount": "DefaultEndpointsProtocol=https;AccountName=yourstorageaccount;AccountKey=your-storage-key==;EndpointSuffix=core.windows.net"
  }
}