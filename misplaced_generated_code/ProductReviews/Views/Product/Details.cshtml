@model ProductReviews.Models.ProductReviewsViewModel
@using ProductReviews.Helpers

@{
    ViewData["Title"] = Model.Product.Name + " - Reviews";
}

<div class="product-details">
    <h1>@Model.Product.Name</h1>
    <p class="product-description">@Model.Product.Description</p>
    <p class="product-price"><strong>Price:</strong> @Model.Product.Price.ToString("C")</p>
</div>

<hr />

<div class="reviews-section">
    <h2>Customer Reviews (@Model.Reviews.Count)</h2>

    @if (!Model.Reviews.Any())
    {
        <p>No reviews yet. Be the first to review this product!</p>
    }

    @foreach (var review in Model.Reviews)
    {
        <div class="review-card">
            <div class="review-header">
                <strong>@Html.DisplayFor(_ => review.AuthorName)</strong>
                <span class="review-rating">
                    @for (int i = 0; i < review.Rating; i++)
                    {
                        <span>&#9733;</span>
                    }
                    @for (int i = review.Rating; i < 5; i++)
                    {
                        <span>&#9734;</span>
                    }
                </span>
                <span class="review-date">@review.CreatedAt.ToString("MMMM d, yyyy")</span>
            </div>
            <div class="review-content">
                @ReviewFormatter.FormatReview(review.Content)
            </div>
        </div>
    }
</div>

<hr />

<div class="submit-review">
    <h3>Write a Review</h3>
    <p class="formatting-hint">You can use *italic* and **bold** formatting in your review.</p>
    <form asp-action="SubmitReview" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="productId" value="@Model.Product.Id" />

        <div class="form-group">
            <label for="authorName">Your Name</label>
            <input type="text" id="authorName" name="authorName" class="form-control"
                   required maxlength="100" />
        </div>

        <div class="form-group">
            <label for="rating">Rating</label>
            <select id="rating" name="rating" class="form-control" required>
                <option value="5">5 Stars</option>
                <option value="4">4 Stars</option>
                <option value="3">3 Stars</option>
                <option value="2">2 Stars</option>
                <option value="1">1 Star</option>
            </select>
        </div>

        <div class="form-group">
            <label for="content">Your Review</label>
            <textarea id="content" name="content" class="form-control" rows="5"
                      required maxlength="5000"></textarea>
        </div>

        <button type="submit" class="btn btn-primary">Submit Review</button>
    </form>
</div>
