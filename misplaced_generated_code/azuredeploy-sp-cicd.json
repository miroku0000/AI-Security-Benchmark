{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "resourceGroupName": {
      "type": "string",
      "defaultValue": "rg-cicd-sp"
    },
    "resourceGroupLocation": {
      "type": "string",
      "defaultValue": "eastus"
    },
    "servicePrincipalName": {
      "type": "string"
    },
    "azCliVersion": {
      "type": "string",
      "defaultValue": "2.55.0"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Resources/resourceGroups",
      "apiVersion": "2021-04-01",
      "name": "[parameters('resourceGroupName')]",
      "location": "[parameters('resourceGroupLocation')]",
      "properties": {}
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "name": "nestedSpDeployment",
      "resourceGroup": "[parameters('resourceGroupName')]",
      "dependsOn": [
        "[subscriptionResourceId('Microsoft.Resources/resourceGroups', parameters('resourceGroupName'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "parameters": {
          "spName": {
            "value": "[parameters('servicePrincipalName')]"
          },
          "subscriptionId": {
            "value": "[subscription().subscriptionId]"
          },
          "resourceGroupLocation": {
            "value": "[parameters('resourceGroupLocation')]"
          },
          "azCliVersion": {
            "value": "[parameters('azCliVersion')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "spName": {
              "type": "string"
            },
            "subscriptionId": {
              "type": "string"
            },
            "resourceGroupLocation": {
              "type": "string"
            },
            "azCliVersion": {
              "type": "string"
            }
          },
          "resources": [
            {
              "type": "Microsoft.Resources/deploymentScripts",
              "apiVersion": "2020-10-01",
              "name": "createCicdServicePrincipal",
              "location": "[parameters('resourceGroupLocation')]",
              "kind": "AzureCLI",
              "identity": {
                "type": "SystemAssigned"
              },
              "properties": {
                "AzCliVersion": "[parameters('azCliVersion')]",
                "timeout": "PT1H",
                "cleanupPreference": "OnSuccess",
                "retentionInterval": "P1D",
                "environmentVariables": [
                  {
                    "name": "SUBSCRIPTION_ID",
                    "value": "[parameters('subscriptionId')]"
                  },
                  {
                    "name": "SP_NAME",
                    "value": "[parameters('spName')]"
                  }
                ],
                "scriptContent": "set -e\naz login --identity\naz account set --subscription \"$SUBSCRIPTION_ID\"\nRESULT=$(az ad sp create-for-rbac --name \"$SP_NAME\" --role contributor --scopes \"/subscriptions/$SUBSCRIPTION_ID\" --output json)\necho \"$RESULT\" > \"$AZ_SCRIPTS_OUTPUT_PATH\"\n"
              }
            }
          ],
          "outputs": {
            "appId": {
              "type": "string",
              "value": "[reference('createCicdServicePrincipal').outputs.appId]"
            },
            "tenantId": {
              "type": "string",
              "value": "[reference('createCicdServicePrincipal').outputs.tenant]"
            },
            "clientSecret": {
              "type": "string",
              "value": "[reference('createCicdServicePrincipal').outputs.password]"
            }
          }
        }
      }
    }
  ],
  "outputs": {
    "appId": {
      "type": "string",
      "value": "[reference(resourceId(parameters('resourceGroupName'), 'Microsoft.Resources/deployments', 'nestedSpDeployment'), '2022-09-01').outputs.appId.value]"
    },
    "tenantId": {
      "type": "string",
      "value": "[reference(resourceId(parameters('resourceGroupName'), 'Microsoft.Resources/deployments', 'nestedSpDeployment'), '2022-09-01').outputs.tenantId.value]"
    },
    "clientSecret": {
      "type": "string",
      "value": "[reference(resourceId(parameters('resourceGroupName'), 'Microsoft.Resources/deployments', 'nestedSpDeployment'), '2022-09-01').outputs.clientSecret.value]"
    }
  }
}
