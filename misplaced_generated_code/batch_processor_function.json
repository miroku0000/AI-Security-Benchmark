{
  "bindings": [
    {
      "name": "myTimer",
      "type": "timerTrigger",
      "direction": "in",
      "schedule": "0 */30 * * * *"
    }
  ],
  "retry": {
    "strategy": "exponentialBackoff",
    "maxRetryCount": 5,
    "minimumInterval": "00:00:30",
    "maximumInterval": "00:15:00"
  },
  "functionTimeout": "00:10:00",
  "scriptFile": "azure_batch_processor.js"
}